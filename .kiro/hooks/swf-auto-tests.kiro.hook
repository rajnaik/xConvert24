{
  "enabled": true,
  "name": "SWF Auto UI Tests",
  "description": "When any SWF page, component, or API file is edited or created, automatically generate or update the corresponding Playwright UI tests in scrabblewordsfinder/tests/.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "scrabblewordsfinder/src/pages/*.astro",
      "scrabblewordsfinder/src/pages/**/*.astro",
      "scrabblewordsfinder/src/pages/api/*.ts",
      "scrabblewordsfinder/src/layouts/*.astro"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "An SWF feature file was just modified. Review the change and update or create the relevant Playwright UI test in scrabblewordsfinder/tests/ to ensure the feature is fully covered. Match the existing test patterns — use @playwright/test, group with test.describe, and target the live site via baseURL. If a new feature was added, create tests for it. If existing behaviour changed, update the relevant spec file. Do NOT delete existing passing tests unless the feature was removed."
  },
  "workspaceFolderName": "xConvert.com",
  "shortName": "swf-auto-tests"
}