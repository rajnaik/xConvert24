{
  "enabled": true,
  "name": "Test Reminder After Task",
  "description": "After completing a spec task, reminds the agent to write Playwright tests for the delivered feature if none were created during the task.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "STOP — before marking this task done, check: did you write Playwright tests for the feature you just built? Per the always-test steering rule, every feature needs minimum 2 positive + 2 negative tests in the tests/ directory. If no tests were written, write them NOW before proceeding. If tests were already written this session, confirm the test file name and count."
  }
}