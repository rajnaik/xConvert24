{
  "enabled": true,
  "name": "UI Test Watcher",
  "description": "When a UI file (.astro, .html, popup.html) is edited, analyze the change and suggest or write a corresponding Playwright test. Check if existing tests still cover the change.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.astro",
      "*.html"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A UI file was just edited. Analyze the change and: 1) Write a new Playwright test if a new feature was added. 2) Update existing tests if behaviour changed. 3) Do NOT delete passing tests unless the feature was removed. Place tests in the appropriate tests/ folder. Match existing test patterns."
  }
}