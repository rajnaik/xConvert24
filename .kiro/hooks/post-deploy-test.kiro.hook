{
  "enabled": false,
  "name": "Post-Deploy Tests",
  "description": "After a task is completed (like a build or deploy), remind the agent to run tests against the live site and log the build details.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "After deploying, run a quick smoke test by checking that the homepage and a few key pages return HTTP 200 from www.xconvert24.com. Report any failures. Also log the build version, timestamp, and status to the build log in localStorage by executing JS to add an entry to the 'xconvert24-build-log' key."
  }
}