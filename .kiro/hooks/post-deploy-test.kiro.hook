{
  "enabled": true,
  "name": "Post-Deploy Tests",
  "description": "After a task is completed (like a build or deploy), run Playwright tests including mobile hamburger navigation against the live site and log the results.",
  "version": "2",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "After deploying to staging or live, run the full Playwright test suite against the deployed site:\n1. Run `npx playwright test tests/mobile-hamburger.spec.ts` to verify the mobile hamburger menu opens, a random nav link can be tapped, and the destination returns HTTP 200.\n2. Run `npx playwright test tests/site.spec.ts` for the main smoke tests.\n3. Report any failures with details. If all pass, confirm success.\n4. Log the result to the AuditLog."
  }
}