---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Add to Home Screen — Install xConvert24" description="Save xConvert24 to your iOS or Android home screen for instant access like a native app. Step-by-step instructions." keywords="add to home screen, install web app, ios home screen, pwa install, save to home screen, xConvert24 app">
  <div class="max-w-2xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">📱</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Add to Home Screen</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Save xConvert24 to your home screen for instant access — works like a native app with no install from the App Store.</p>
    </div>

    <!-- iOS Instructions -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">iPhone & iPad (iOS)</h2>
          <p class="text-xs text-gray-500 dark:text-gray-400">Safari browser required</p>
        </div>
      </div>

      <ol class="space-y-4">
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center font-bold text-sm">1</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Open in Safari</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Navigate to <strong>www.xconvert24.com</strong> in Safari. This won't work from Chrome or other browsers on iOS.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center font-bold text-sm">2</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Tap the Share button</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Tap the <strong>Share</strong> icon (square with upward arrow) at the bottom of Safari.</p>
            <div class="mt-2 inline-flex items-center gap-1 px-3 py-1.5 bg-gray-100 dark:bg-gray-800 rounded-lg">
              <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              <span class="text-xs text-gray-600 dark:text-gray-400 font-medium">Share</span>
            </div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center font-bold text-sm">3</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Tap "Add to Home Screen"</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Scroll down in the share sheet and tap <strong>Add to Home Screen</strong>. You may need to scroll right on the icons row.</p>
            <div class="mt-2 inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 dark:bg-gray-800 rounded-lg">
              <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              <span class="text-xs text-gray-600 dark:text-gray-400 font-medium">Add to Home Screen</span>
            </div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center font-bold text-sm">4</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Tap "Add"</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Confirm the name (xConvert24) and tap <strong>Add</strong> in the top-right corner. The app icon will appear on your home screen.</p>
          </div>
        </li>
      </ol>

      <div class="mt-5 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
        <p class="text-xs text-green-700 dark:text-green-400"><strong>✓ Done!</strong> xConvert24 will now open full-screen like a native app — no browser bars, instant load from your home screen.</p>
      </div>
    </div>

    <!-- Android Instructions -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 2.047l1.41 1.41-2.09 2.09C18.15 6.84 19 8.82 19 11H5c0-2.18.85-4.16 2.16-5.45l-2.09-2.09 1.41-1.41 2.35 2.35C10.04 3.54 11.46 3 13 3c1.06 0 2.06.25 2.97.69l1.55-1.62zM7 13v7c0 1.1.9 2 2 2h1v3h2v-3h2v3h2v-3h1c1.1 0 2-.9 2-2v-7H7zm-3-1h2v7H4c-.55 0-1-.45-1-1v-5c0-.55.45-1 1-1zm16 0c.55 0 1 .45 1 1v5c0 .55-.45 1-1 1h-1v-7h1zM11 9c.55 0 1-.45 1-1s-.45-1-1-1-1 .45-1 1 .45 1 1 1zm4 0c.55 0 1-.45 1-1s-.45-1-1-1-1 .45-1 1 .45 1 1 1z"/></svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Android</h2>
          <p class="text-xs text-gray-500 dark:text-gray-400">Chrome, Edge, or Samsung Internet</p>
        </div>
      </div>

      <ol class="space-y-4">
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 flex items-center justify-center font-bold text-sm">1</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Open in Chrome</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Navigate to <strong>www.xconvert24.com</strong> in Chrome (or Edge/Samsung Internet).</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 flex items-center justify-center font-bold text-sm">2</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Tap the menu (⋮)</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Tap the three-dot menu in the top-right corner of Chrome.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 flex items-center justify-center font-bold text-sm">3</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Tap "Add to Home screen" or "Install app"</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Some browsers show an install prompt automatically. Otherwise, look for "Add to Home screen" in the menu.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-8 h-8 shrink-0 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 flex items-center justify-center font-bold text-sm">4</div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Confirm</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Tap <strong>Add</strong> or <strong>Install</strong>. The app shortcut will appear on your home screen.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Benefits -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Why add to Home Screen?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-lg">⚡</span>
          <div>
            <p class="text-xs font-medium text-gray-900 dark:text-white">Instant access</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">One tap from your home screen — no typing URLs</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-lg">📱</span>
          <div>
            <p class="text-xs font-medium text-gray-900 dark:text-white">Full-screen experience</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Opens without browser bars — feels like a real app</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-lg">🚀</span>
          <div>
            <p class="text-xs font-medium text-gray-900 dark:text-white">Fast loading</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Cached assets load instantly, even on slow connections</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-lg">💾</span>
          <div>
            <p class="text-xs font-medium text-gray-900 dark:text-white">No install needed</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Zero storage used — it's just a shortcut to the web app</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
