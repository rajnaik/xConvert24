---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blog Schedule | Admin | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
    .back { color: #9ca3af; text-decoration: none; font-size: 14px; }
    .back:hover { color: #fbbf24; }
    .logo { font-size: 16px; font-weight: 600; color: #d1d5db; }
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 24px; }
    .stats { display: flex; gap: 12px; margin-bottom: 24px; }
    .stat { background: #111827; border: 1px solid #1f2937; border-radius: 8px; padding: 12px 16px; text-align: center; flex: 1; }
    .stat-val { font-size: 24px; font-weight: 700; color: #fbbf24; }
    .stat-label { font-size: 11px; color: #6b7280; margin-top: 2px; }
    .calendar { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; margin-top: 16px; }
    .cal-header { text-align: center; font-size: 12px; font-weight: 600; color: #6b7280; padding: 10px 0; }
    .cal-day { aspect-ratio: 1; background: rgba(17,24,39,0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 14px; position: relative; display: flex; flex-direction: column; transition: all 0.2s; min-height: 120px; }
    .cal-day:hover { border-color: rgba(251,191,36,0.4); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .cal-day.has-post { border-color: rgba(255,255,255,0.12); background: rgba(17,24,39,0.8); }
    .cal-day.published { border-color: rgba(34,197,94,0.5); background: rgba(5,46,22,0.6); box-shadow: 0 0 12px rgba(34,197,94,0.1); }
    .cal-day-num { font-size: 15px; font-weight: 700; color: #9ca3af; margin-bottom: 8px; }
    .cal-day.published .cal-day-num { color: #4ade80; }
    .cal-post { font-size: 8px; color: #9ca3af; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
    .cal-check { position: absolute; bottom: 10px; right: 10px; width: 22px; height: 22px; accent-color: #16a34a; cursor: pointer; border-radius: 4px; }
    .month-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .month-nav button { background: #1f2937; border: 1px solid #374151; color: #d1d5db; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .month-nav button:hover { border-color: #fbbf24; color: #fbbf24; }
    .month-title { font-size: 16px; font-weight: 600; color: #f9fafb; }
    .legend { display: flex; gap: 16px; margin-top: 16px; font-size: 11px; color: #6b7280; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 4px; }
  </style>
</head>
<body>
  <div class="header">
    <a href="/admin" class="back">← Dashboard</a>
    <span class="logo">📅 Blog Schedule</span>
  </div>

  <div class="container">
    <h1>Blog Post Release Schedule</h1>
    <p class="subtitle">Click checkboxes to publish/unpublish posts. Green = published, dark = draft.</p>

    <div class="stats" id="stats">
      <div class="stat"><div class="stat-val" id="total-posts">—</div><div class="stat-label">Total Posts</div></div>
      <div class="stat"><div class="stat-val" id="published-posts">—</div><div class="stat-label">Published</div></div>
      <div class="stat"><div class="stat-val" id="draft-posts">—</div><div class="stat-label">Drafts</div></div>
    </div>

    <div class="month-nav">
      <button id="prev-month">← Prev</button>
      <span class="month-title" id="month-title">June 2025</span>
      <button id="next-month">Next →</button>
    </div>

    <div class="calendar" id="calendar">
      <div class="cal-header">Sun</div>
      <div class="cal-header">Mon</div>
      <div class="cal-header">Tue</div>
      <div class="cal-header">Wed</div>
      <div class="cal-header">Thu</div>
      <div class="cal-header">Fri</div>
      <div class="cal-header">Sat</div>
    </div>

    <div class="legend">
      <span><span class="legend-dot" style="background:#16a34a;"></span> Published</span>
      <span><span class="legend-dot" style="background:#374151;"></span> Scheduled (draft)</span>
      <span><span class="legend-dot" style="background:#1f2937;"></span> No post</span>
    </div>
  </div>

  <script>
    let posts = [];
    let currentYear = 2025;
    let currentMonth = 5; // June (0-indexed)

    const calEl = document.getElementById('calendar');
    const titleEl = document.getElementById('month-title');

    async function loadPosts() {
      try {
        const res = await fetch('/api/blog-posts');
        const data = await res.json();
        posts = data.posts || [];
        updateStats();
        renderCalendar();
      } catch (e) {
        calEl.innerHTML += '<div style="grid-column:span 7;text-align:center;padding:40px;color:#f87171;">Failed to load posts</div>';
      }
    }

    function updateStats() {
      document.getElementById('total-posts').textContent = posts.length.toString();
      document.getElementById('published-posts').textContent = posts.filter(p => p.status == 1).length.toString();
      document.getElementById('draft-posts').textContent = posts.filter(p => p.status == 0).length.toString();
    }

    function renderCalendar() {
      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      titleEl.textContent = monthNames[currentMonth] + ' ' + currentYear;

      // Clear day cells (keep headers)
      const headers = calEl.querySelectorAll('.cal-header');
      calEl.innerHTML = '';
      headers.forEach(h => calEl.appendChild(h));

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

      // Empty cells before first day
      for (let i = 0; i < firstDay; i++) {
        const empty = document.createElement('div');
        empty.className = 'cal-day';
        empty.style.opacity = '0.2';
        empty.style.border = '1px solid rgba(255,255,255,0.03)';
        calEl.appendChild(empty);
      }

      // Day cells
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = currentYear + '-' + String(currentMonth + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
        const dayPosts = posts.filter(p => p.pub_date === dateStr);
        const cell = document.createElement('div');
        const hasPublished = dayPosts.some(p => p.status == 1);
        cell.className = 'cal-day' + (dayPosts.length ? ' has-post' : '') + (hasPublished ? ' published' : '');

        let html = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">';
        html += '<span style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:' + (hasPublished ? '#4ade80' : '#9ca3af') + ';">' + d + '</span>';
        if (dayPosts.length) {
          var isPublished = dayPosts[0].status == 1;
          html += '<input type="checkbox" class="cal-check" style="position:static;width:22px;height:22px;" data-blogid="' + dayPosts[0].blogid + '" data-date="' + dateStr + '" ' + (isPublished ? 'checked' : '') + ' title="' + (isPublished ? 'Published' : 'Draft') + '"/>';
        }
        html += '</div>';
        dayPosts.forEach(p => {
          html += '<div class="cal-post" title="' + p.topic + '">' + p.topic.slice(0, 20) + '</div>';
        });

        cell.innerHTML = html;
        calEl.appendChild(cell);
      }

      // Attach checkbox handlers
      calEl.querySelectorAll('.cal-check').forEach(cb => {
        cb.addEventListener('change', async (e) => {
          const checkbox = e.target;
          const blogid = checkbox.dataset.blogid;
          const pubDate = checkbox.dataset.date;
          const newStatus = checkbox.checked ? 1 : 0;

          await fetch('/api/blog-posts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ blogid, status: newStatus, pub_date: pubDate }),
          });

          // Update local data
          const post = posts.find(p => p.blogid === blogid);
          if (post) { post.status = newStatus; post.pub_date = pubDate; }
          updateStats();
          renderCalendar();
        });
      });
    }

    document.getElementById('prev-month').addEventListener('click', () => {
      currentMonth--;
      if (currentMonth < 0) { currentMonth = 11; currentYear--; }
      renderCalendar();
    });

    document.getElementById('next-month').addEventListener('click', () => {
      currentMonth++;
      if (currentMonth > 11) { currentMonth = 0; currentYear++; }
      renderCalendar();
    });

    loadPosts();
  </script>
</body>
</html>
