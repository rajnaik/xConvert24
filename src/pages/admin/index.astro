---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Dashboard | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .logo { font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #fbbf24, #d97706); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .user { display: flex; align-items: center; gap: 12px; }
    .avatar { width: 32px; height: 32px; border-radius: 50%; }
    .user-name { font-size: 14px; color: #d1d5db; }
    .logout-btn { font-size: 13px; color: #9ca3af; text-decoration: none; padding: 6px 12px; border-radius: 6px; border: 1px solid #374151; transition: all 0.2s; }
    .logout-btn:hover { color: #f87171; border-color: #7f1d1d; background: #1f2937; }
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { background: #111827; border: 1px solid #1f2937; border-radius: 12px; padding: 24px; transition: border-color 0.2s; }
    .card:hover { border-color: #f59e0b; }
    .card-icon { font-size: 32px; margin-bottom: 12px; }
    .card-title { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
    .card-desc { font-size: 13px; color: #6b7280; line-height: 1.5; }
    .card a { color: inherit; text-decoration: none; display: block; }
    .stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin-bottom: 32px; }
    .stat { background: #111827; border: 1px solid #1f2937; border-radius: 10px; padding: 20px; text-align: center; }
    .stat-value { font-size: 36px; font-weight: 700; color: #fbbf24; }
    .stat-label { font-size: 12px; color: #6b7280; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .section-title { font-size: 14px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; }
    a.card-link { display: block; text-decoration: none; color: inherit; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">⚙️ xConvert24 Admin</div>
    <div class="user">
      {user.picture && <img src={user.picture} alt="User avatar" class="avatar" referrerpolicy="no-referrer" />}
      <span class="user-name">{user.name || user.email}</span>
      <a href="/admin/logout" class="logout-btn">Sign out</a>
    </div>
  </div>

  <div class="container">
    <h1>Dashboard</h1>
    <p class="subtitle">Welcome back, {user.name || user.email}. Manage your xConvert24.com site from here.</p>

    <!-- Stats -->
    <div class="stats">
      <div class="stat">
        <div class="stat-value">38</div>
        <div class="stat-label">Total Pages</div>
      </div>
      <div class="stat">
        <div class="stat-value">18</div>
        <div class="stat-label">Converters</div>
      </div>
      <div class="stat">
        <div class="stat-value">9</div>
        <div class="stat-label">Tools</div>
      </div>
      <div class="stat">
        <div class="stat-value">150+</div>
        <div class="stat-label">Units Indexed</div>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="section-title">Quick Actions</div>
    <div class="grid">
      <div class="card">
        <a href="/admin/blog-schedule" class="card-link">
          <div class="card-icon">📅</div>
          <div class="card-title">Blog Schedule</div>
          <div class="card-desc">Manage blog post release calendar and publish status.</div>
        </a>
      </div>
      <div class="card">
        <a href="/admin/bugs" class="card-link">
          <div class="card-icon">🐛</div>
          <div class="card-title">Bug Reports</div>
          <div class="card-desc">View and manage bug reports submitted by users.</div>
        </a>
      </div>
      <div class="card">
        <a href="/releases" class="card-link">
          <div class="card-icon">📋</div>
          <div class="card-title">Release Notes</div>
          <div class="card-desc">View the release history and changelog.</div>
        </a>
      </div>
      <div class="card">
        <a href="/admin/analytics" class="card-link">
          <div class="card-icon">📊</div>
          <div class="card-title">Analytics</div>
          <div class="card-desc">View site traffic and usage data via Google Analytics.</div>
        </a>
      </div>
      <div class="card">
        <a href="/search" class="card-link">
          <div class="card-icon">🔍</div>
          <div class="card-title">Search Index</div>
          <div class="card-desc">150+ entries across all categories, units, and tools.</div>
        </a>
      </div>
      <div class="card">
        <a href="/" class="card-link">
          <div class="card-icon">🌐</div>
          <div class="card-title">View Live Site</div>
          <div class="card-desc">Open the public-facing xConvert24.com site.</div>
        </a>
      </div>
      <div class="card">
        <a href="/admin/settings" class="card-link">
          <div class="card-icon">⚙️</div>
          <div class="card-title">Settings</div>
          <div class="card-desc">Manage admin configuration and environment.</div>
        </a>
      </div>
    </div>

    <!-- Draggable panels container -->
    <div id="panels-container" style="margin-top: 40px; display: flex; flex-wrap: wrap; gap: 20px;">
      <!-- Bug Reports Panel -->
      <div class="panel" id="panel-bugs" style="flex: 1; min-width: 400px; background: #111827; border: 1px solid #1f2937; border-radius: 12px; overflow: hidden; cursor: move;">
        <div class="panel-header" style="display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; background: #1f2937; border-bottom: 1px solid #374151;">
          <span style="font-size: 14px; font-weight: 600; color: #f9fafb;">🐛 Bug Reports (by votes)</span>
          <button id="bugs-expand" style="background: #374151; border: none; color: #fbbf24; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 16px; font-weight: 700; line-height: 1;">+</button>
        </div>
        <div id="admin-bugs" style="padding: 12px;">
          <div style="color: #6b7280; font-size: 14px; font-style: italic; padding: 20px; text-align: center;">Loading…</div>
        </div>
      </div>

      <!-- Suggestions Panel -->
      <div class="panel" id="panel-suggestions" style="flex: 1; min-width: 400px; background: #111827; border: 1px solid #1f2937; border-radius: 12px; overflow: hidden; cursor: move;">
        <div class="panel-header" style="display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; background: #1f2937; border-bottom: 1px solid #374151;">
          <span style="font-size: 14px; font-weight: 600; color: #f9fafb;">💡 Community Suggestions (by rating)</span>
          <button id="sug-expand" style="background: #374151; border: none; color: #fbbf24; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 16px; font-weight: 700; line-height: 1;">+</button>
        </div>
        <div id="admin-suggestions" style="padding: 12px;">
          <div style="color: #6b7280; font-size: 14px; font-style: italic; padding: 20px; text-align: center;">Loading…</div>
        </div>
      </div>
    </div>
  </div>


  <script>
    (function() {
      var bugsContainer = document.getElementById('admin-bugs');
      var sugContainer = document.getElementById('admin-suggestions');
      var bugsExpanded = false;
      var sugExpanded = false;
      var allBugs = [];
      var allSuggestions = [];

      var sevColors = { high: '#f87171', medium: '#fb923c', low: '#fbbf24' };
      var sevBg = { high: '#450a0a', medium: '#431407', low: '#422006' };
      var sevEmoji = { high: '🔴', medium: '🟠', low: '🟡' };

      function renderBugs() {
        var bugs = bugsExpanded ? allBugs : allBugs.slice(0, 5);
        if (!allBugs.length) { bugsContainer.innerHTML = '<div style="color:#6b7280;font-size:13px;text-align:center;padding:20px;">No bugs reported yet.</div>'; return; }
        bugsContainer.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px;">' + bugs.map(function(bug) {
          return '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;background:#0f172a;border-radius:8px;">' +
            '<div style="text-align:center;min-width:36px;"><div style="font-size:16px;font-weight:700;color:#fbbf24;">' + (bug.votes || 0) + '</div><div style="font-size:9px;color:#6b7280;">votes</div></div>' +
            '<div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;"><span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:100px;background:' + (sevBg[bug.severity] || sevBg.low) + ';color:' + (sevColors[bug.severity] || sevColors.low) + ';">' + (sevEmoji[bug.severity] || '🟡') + '</span>' + (bug.page ? '<span style="font-size:11px;color:#fbbf24;">' + bug.page + '</span>' : '') + '</div>' +
            '<div style="font-size:12px;color:#d1d5db;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + bug.description.replace(/</g,'&lt;') + '</div></div></div>';
        }).join('') + '</div><div style="margin-top:8px;font-size:11px;color:#6b7280;text-align:center;">Showing ' + bugs.length + ' of ' + allBugs.length + '</div>';
      }

      function renderSuggestions() {
        var sug = sugExpanded ? allSuggestions : allSuggestions.slice(0, 5);
        if (!allSuggestions.length) { sugContainer.innerHTML = '<div style="color:#6b7280;font-size:13px;text-align:center;padding:20px;">No suggestions yet.</div>'; return; }
        sugContainer.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px;">' + sug.map(function(s) {
          return '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;background:#0f172a;border-radius:8px;">' +
            '<div style="text-align:center;min-width:36px;"><div style="font-size:16px;font-weight:700;color:#fbbf24;">' + (s.rating ? s.rating.toFixed(1) : '—') + '</div><div style="font-size:9px;color:#6b7280;">' + (s.votes_count || 0) + ' votes</div></div>' +
            '<div style="flex:1;min-width:0;"><div style="font-size:12px;font-weight:600;color:#f9fafb;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + s.title.replace(/</g,'&lt;') + '</div>' +
            (s.category ? '<div style="font-size:10px;color:#6b7280;margin-top:2px;">' + s.category + '</div>' : '') + '</div></div>';
        }).join('') + '</div><div style="margin-top:8px;font-size:11px;color:#6b7280;text-align:center;">Showing ' + sug.length + ' of ' + allSuggestions.length + '</div>';
      }

      document.getElementById('bugs-expand').addEventListener('click', function() { bugsExpanded = !bugsExpanded; this.textContent = bugsExpanded ? '−' : '+'; renderBugs(); });
      document.getElementById('sug-expand').addEventListener('click', function() { sugExpanded = !sugExpanded; this.textContent = sugExpanded ? '−' : '+'; renderSuggestions(); });

      // Drag panels
      var panels = document.querySelectorAll('.panel');
      var panelContainer = document.getElementById('panels-container');
      var dragEl = null;
      panels.forEach(function(p) {
        p.setAttribute('draggable', 'true');
        p.addEventListener('dragstart', function() { dragEl = p; p.style.opacity = '0.5'; });
        p.addEventListener('dragend', function() { p.style.opacity = '1'; dragEl = null; });
        p.addEventListener('dragover', function(e) { e.preventDefault(); });
        p.addEventListener('drop', function(e) { e.preventDefault(); if (dragEl && dragEl !== p) { var kids = Array.from(panelContainer.children); if (kids.indexOf(dragEl) < kids.indexOf(p)) panelContainer.insertBefore(dragEl, p.nextSibling); else panelContainer.insertBefore(dragEl, p); } });
      });

      fetch('/api/bugs').then(function(r) { return r.json(); }).then(function(d) { allBugs = d.bugs || []; renderBugs(); }).catch(function() { bugsContainer.innerHTML = '<div style="color:#f87171;font-size:13px;text-align:center;padding:20px;">Failed to load.</div>'; });
      fetch('/api/suggestions').then(function(r) { return r.json(); }).then(function(d) { allSuggestions = d.suggestions || []; renderSuggestions(); }).catch(function() { sugContainer.innerHTML = '<div style="color:#f87171;font-size:13px;text-align:center;padding:20px;">Failed to load.</div>'; });
    })();
  </script>
</body>
</html>
