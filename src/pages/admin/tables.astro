---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };

// Complete schema reference derived from migrations 0001–0016
const tables = [
  {
    name: 'bugs',
    migration: '0001',
    description: 'User-submitted bug reports with severity and voting',
    columns: [
      { name: 'id', type: 'TEXT', constraints: 'PRIMARY KEY' },
      { name: 'page', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'href', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'severity', type: 'TEXT', constraints: "DEFAULT 'low'" },
      { name: 'description', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'email', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'votes', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'validated', type: 'INTEGER', constraints: 'DEFAULT 0 (added 0011)' },
      { name: 'reporter_uid', type: 'TEXT', constraints: "DEFAULT '' (added 0011)" },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_bugs_votes (votes DESC)', 'idx_bugs_created (created_at DESC)'],
  },
  {
    name: 'builds',
    migration: '0002',
    description: 'Deployment build log — version, status, bundle size, pages, assets',
    columns: [
      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'version', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'timestamp', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
      { name: 'status', type: 'TEXT', constraints: "DEFAULT 'success'" },
      { name: 'duration', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'bundle_size', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'pages', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'assets', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'worker_version_id', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'notes', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_builds_timestamp (timestamp DESC)'],
  },
  {
    name: 'test_runs',
    migration: '0002',
    description: 'Post-build test results — pass/fail/skipped counts',
    columns: [
      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'version', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'timestamp', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
      { name: 'total', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'passed', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'failed', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'skipped', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'duration', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'tests_json', type: 'TEXT', constraints: "DEFAULT '[]'" },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_test_runs_timestamp (timestamp DESC)'],
  },
  {
    name: 'code_reviews',
    migration: '0003',
    description: 'SonarQube code review results per build',
    columns: [
      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'version', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'timestamp', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
      { name: 'status', type: 'TEXT', constraints: "DEFAULT 'passed'" },
      { name: 'issues_found', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'issues_critical', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'issues_major', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'issues_minor', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'duration', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'reviewer', type: 'TEXT', constraints: "DEFAULT 'sonarqube'" },
      { name: 'branch', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'commit_hash', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'summary', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_code_reviews_timestamp (timestamp DESC)', 'idx_code_reviews_status (status)'],
  },
  {
    name: 'code_scans',
    migration: '0004',
    description: 'SonarQube scan results — bugs, vulns, code smells, coverage',
    columns: [
      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'version', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'timestamp', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
      { name: 'status', type: 'TEXT', constraints: "DEFAULT 'passed'" },
      { name: 'bugs', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'vulnerabilities', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'code_smells', type: 'INTEGER', constraints: 'DEFAULT 0' },
      { name: 'coverage', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'duplications', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'duration', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'branch', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'commit_hash', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'scanner', type: 'TEXT', constraints: "DEFAULT 'sonarqube'" },
      { name: 'summary', type: 'TEXT', constraints: "DEFAULT ''" },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_code_scans_timestamp (timestamp DESC)', 'idx_code_scans_status (status)'],
  },
  {
    name: 'templates',
    migration: '0005',
    description: 'Reusable content templates with versioning',
    columns: [
      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'name', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'body', type: 'TEXT', constraints: "NOT NULL DEFAULT ''" },
      { name: 'version', type: 'INTEGER', constraints: 'DEFAULT 1' },
      { name: 'status', type: 'INTEGER', constraints: 'DEFAULT 1' },
      { name: 'created_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
      { name: 'modified_at', type: 'TEXT', constraints: "DEFAULT datetime('now')" },
    ],
    indexes: ['idx_templates_modified (modified_at DESC)'],
  },
  {
    name: 'template_versions',
    migration: '0005',
