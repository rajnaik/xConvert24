<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DB Tables | Admin | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .logo { font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #fbbf24, #d97706); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .user { display: flex; align-items: center; gap: 12px; }
    .avatar { width: 32px; height: 32px; border-radius: 50%; }
    .user-name { font-size: 14px; color: #d1d5db; }
    .back-btn { font-size: 13px; color: #9ca3af; text-decoration: none; padding: 6px 12px; border-radius: 6px; border: 1px solid #374151; transition: all 0.2s; }
    .back-btn:hover { color: #fbbf24; border-color: #d97706; background: #1f2937; }

    .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 24px; }

    .summary-bar { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 32px; }
    .summary-stat { background: #111827; border: 1px solid #1f2937; border-radius: 10px; padding: 14px 20px; text-align: center; }
    .summary-stat .val { font-size: 24px; font-weight: 700; color: #fbbf24; }
    .summary-stat .lbl { font-size: 11px; color: #6b7280; text-transform: uppercase; margin-top: 2px; }

    .search-wrap { margin-bottom: 24px; }
    .search-input { width: 100%; max-width: 400px; padding: 10px 14px; border-radius: 8px; border: 1px solid #374151; background: #111827; color: #f9fafb; font-size: 14px; outline: none; transition: border-color 0.2s; }
    .search-input:focus { border-color: #fbbf24; }
    .search-input::placeholder { color: #6b7280; }

    .table-card { background: #111827; border: 1px solid #1f2937; border-radius: 12px; margin-bottom: 16px; overflow: hidden; transition: border-color 0.2s; }
    .table-card:hover { border-color: #374151; }
    .table-card.expanded { border-color: #d97706; }
    .table-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; cursor: pointer; user-select: none; }
    .table-header:hover { background: #1f2937; }
    .table-name { font-size: 15px; font-weight: 700; color: #fbbf24; font-family: 'JetBrains Mono', monospace; }
    .table-meta { display: flex; align-items: center; gap: 12px; }
    .table-migration { font-size: 10px; color: #6b7280; background: #1f2937; padding: 2px 8px; border-radius: 100px; }
    .table-cols-count { font-size: 11px; color: #9ca3af; }
    .table-chevron { font-size: 14px; color: #6b7280; transition: transform 0.2s; }
    .table-card.expanded .table-chevron { transform: rotate(90deg); }
    .table-desc { font-size: 12px; color: #9ca3af; padding: 0 18px; margin-top: -4px; margin-bottom: 8px; }
    .table-body { display: none; padding: 0 18px 16px; }
    .table-card.expanded .table-body { display: block; }

    .schema-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .schema-table th { text-align: left; padding: 8px 10px; color: #6b7280; font-weight: 600; text-transform: uppercase; font-size: 10px; letter-spacing: 0.05em; border-bottom: 1px solid #1f2937; }
    .schema-table td { padding: 7px 10px; border-bottom: 1px solid #111827; color: #d1d5db; }
    .schema-table tr:last-child td { border-bottom: none; }
    .col-name { font-family: 'JetBrains Mono', monospace; color: #f9fafb; font-weight: 500; }
    .col-type { color: #60a5fa; font-family: 'JetBrains Mono', monospace; }
    .col-constraint { color: #6b7280; font-size: 11px; }

    .indexes { margin-top: 10px; padding: 10px 12px; background: #0f172a; border-radius: 8px; }
    .indexes-title { font-size: 10px; color: #6b7280; text-transform: uppercase; font-weight: 600; margin-bottom: 6px; }
    .index-item { font-size: 11px; color: #9ca3af; font-family: 'JetBrains Mono', monospace; padding: 2px 0; }

    .hidden { display: none !important; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">⚙️ xConvert24 Admin</div>
    <div class="user">
      <a href="/admin" class="back-btn">← Dashboard</a>
      {user.picture && <img src={user.picture} alt="User avatar" class="avatar" referrerpolicy="no-referrer" />}
      <span class="user-name">{user.name || user.email}</span>
    </div>
  </div>

  <div class="container">
    <h1>🗄️ Database Tables</h1>
    <p class="subtitle">Complete schema reference for all D1 database tables across all environments (dev, staging, live).</p>

    <div class="summary-bar">
      <div class="summary-stat">
        <div class="val">{tables.length}</div>
        <div class="lbl">Tables</div>
      </div>
      <div class="summary-stat">
        <div class="val">{tables.reduce((sum, t) => sum + t.columns.length, 0)}</div>
        <div class="lbl">Columns</div>
      </div>
      <div class="summary-stat">
        <div class="val">{tables.reduce((sum, t) => sum + t.indexes.length, 0)}</div>
        <div class="lbl">Indexes</div>
      </div>
      <div class="summary-stat">
        <div class="val">16</div>
        <div class="lbl">Migrations</div>
      </div>
    </div>

    <div class="search-wrap">
      <input type="text" class="search-input" id="table-search" placeholder="Search tables or columns…" autocomplete="off" />
    </div>

    <div id="tables-list">
      {tables.map((table) => (
        <div class="table-card" data-name={table.name} data-cols={table.columns.map(c => c.name).join(' ')}>
          <div class="table-header" onclick="this.parentElement.classList.toggle('expanded')">
            <div>
              <span class="table-name">{table.name}</span>
            </div>
            <div class="table-meta">
              <span class="table-cols-count">{table.columns.length} cols</span>
              <span class="table-migration">{table.migration}</span>
              <span class="table-chevron">▶</span>
            </div>
          </div>
          <div class="table-desc">{table.description}</div>
          <div class="table-body">
            <table class="schema-table">
              <thead>
                <tr>
                  <th>Column</th>
                  <th>Type</th>
                  <th>Constraints</th>
                </tr>
              </thead>
              <tbody>
                {table.columns.map((col) => (
                  <tr>
                    <td class="col-name">{col.name}</td>
                    <td class="col-type">{col.type}</td>
                    <td class="col-constraint">{col.constraints}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            {table.indexes.length > 0 && (
              <div class="indexes">
                <div class="indexes-title">Indexes</div>
                {table.indexes.map((idx) => (
                  <div class="index-item">{idx}</div>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    document.getElementById('table-search').addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      var cards = document.querySelectorAll('.table-card');
      cards.forEach(function(card) {
        var name = card.getAttribute('data-name') || '';
        var cols = card.getAttribute('data-cols') || '';
        var match = !q || name.includes(q) || cols.includes(q);
        card.classList.toggle('hidden', !match);
      });
    });
  </script>
</body>
</html>
