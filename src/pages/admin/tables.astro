      { name: 'id', type: 'INTEGER', constraints: 'PRIMARY KEY AUTOINCREMENT' },
      { name: 'user_id', type: 'TEXT', constraints: 'NOT NULL' },
      { name: 'user_name', type: 'TEXT', constraints: "NOT NULL DEFAULT ''" },
