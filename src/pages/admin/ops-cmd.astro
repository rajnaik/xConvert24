      // Map commands to agents for display
      var agentMap = {
        'HACK': {icon:'⚙️', name:'Kiro'}, 'CHOP': {icon:'📝', name:'Quill'},
        'Metadesc': {icon:'📝', name:'Quill'}, 'Metadesc fix': {icon:'📝', name:'Quill'},
        'Prettify': {icon:'📝', name:'Quill'}, 'PRETTIFY': {icon:'📝', name:'Quill'},
        'Blog Pipeline': {icon:'📝', name:'Quill'}, 'Blog Burst': {icon:'📝', name:'Quill'},
        'xPolinate': {icon:'🎯', name:'Archer'}, 'SEOImprove': {icon:'🎯', name:'Archer'},
        'SEOImprove #3 & #8': {icon:'🎯', name:'Archer'}, 'SEOImprove #4,5,9': {icon:'🎯', name:'Archer'},
        'CheckSeoHealth': {icon:'🎯', name:'Archer'}, 'CheckSeoHealth live': {icon:'🎯', name:'Archer'},
        'CheckSeoHealth staging': {icon:'🎯', name:'Archer'}, 'CheckSeoHealth dev': {icon:'🎯', name:'Archer'},
        'Fire Your Engine': {icon:'⚙️', name:'Kiro'}, 'Fire your engine': {icon:'⚙️', name:'Kiro'},
        'Half Throttle': {icon:'⚙️', name:'Kiro'}, 'Full Throttle': {icon:'⚙️', name:'Kiro'},
        'Ship It': {icon:'⚙️', name:'Kiro'}, 'FreshClicks': {icon:'⚙️', name:'Kiro'},
        'Spring Clean': {icon:'⚙️', name:'Kiro'}, 'Full Maintenance': {icon:'⚙️', name:'Kiro'},
        'Converter Burst': {icon:'⚙️', name:'Kiro'}, 'Polish': {icon:'📝', name:'Quill'},
        'TEST': {icon:'🧪', name:'Kiro'},
      };
      function getAgent(cmd) {
        if (agentMap[cmd]) return agentMap[cmd];
        if (cmd && cmd.match(/^HACK/i)) return {icon:'⚙️', name:'Kiro'};
        if (cmd && cmd.match(/^CHOP/i)) return {icon:'📝', name:'Quill'};
        if (cmd && cmd.match(/^SEO/i)) return {icon:'🎯', name:'Archer'};
        if (cmd && cmd.match(/^Check/i)) return {icon:'🎯', name:'Archer'};
        return {icon:'🤖', name:'System'};
      }
      function loadAuditFeed() {
        fetch('/api/auditlog?limit=30')
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var logs = d.logs || [];
            if (!logs.length) {
              auditFeed.innerHTML = '<div style="color:#6b7280;font-style:italic;text-align:center;padding:20px;">No audit entries yet.</div>';
              return;
            }
            auditFeed.innerHTML = logs.map(function(log) {
              var statusIcon = log.status === 1 ? '<span style="color:#4ade80;">✓</span>' : '<span style="color:#f87171;">✗</span>';
              var date = log.created_at ? new Date(log.created_at + 'Z').toLocaleString() : '—';
              var detailText = (log.details || '').replace(/</g,'&lt;');
              var agent = getAgent(log.command);
              var details = '';
              if (detailText) {
                if ((log.command || '').toUpperCase() === 'TEST' && detailText.indexOf('total') > -1) {
                  details = '<div style="font-size:10px;margin-top:3px;display:flex;gap:8px;flex-wrap:wrap;">' +
                    '<span style="color:#d1d5db;">📋 ' + detailText + '</span>' +
