      loadAuditFeed();
      setInterval(loadAuditFeed, 15000);

      // Load Click Stream Feed
      var clicksFeed = document.getElementById('clicks-feed');
      var clicksCount = document.getElementById('clicks-feed-count');
      var lastClicksFeedId = 0;
      function loadClicksFeed() {
        fetch('/api/clicks?limit=30')
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var clicks = d.clicks || [];
            clicksCount.textContent = clicks.length + ' events';
            if (!clicks.length) {
              clicksFeed.innerHTML = '<div style="color:#6b7280;font-style:italic;text-align:center;padding:20px;">No clicks recorded yet.</div>';
              return;
            }
            // Play sound if new clicks arrived
            if (clicks[0] && clicks[0].id > lastClicksFeedId && lastClicksFeedId > 0) {
              playNotifSound();
            }
            if (clicks[0]) lastClicksFeedId = clicks[0].id;
            clicksFeed.innerHTML = clicks.map(function(c) {
              var date = c.created_at ? new Date(c.created_at + 'Z').toLocaleString() : '—';
              var uid = (c.user_id || '').slice(0, 12);
              var el = (c.ui_element || '').replace(/</g, '&lt;').slice(0, 50);
              var url = (c.url || '/').replace(/</g, '&lt;');
              var ip = (c.ip_address || '—');
              return '<div style="padding:4px 0;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:8px;">' +
                '<span style="color:#fbbf24;font-size:10px;min-width:70px;">' + uid + '</span>' +
                '<span style="color:#22d3ee;font-size:10px;min-width:100px;">' + ip + '</span>' +
                '<span style="color:#d1d5db;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + el + '">' + el + '</span>' +
                '<span style="color:#6b7280;font-size:10px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + url + '">' + url + '</span>' +
                '<span style="color:#6b7280;font-size:10px;white-space:nowrap;">' + date + '</span>' +
                '</div>';
            }).join('');
            clicksFeed.scrollTop = 0;
          })
          .catch(function() {
            clicksFeed.innerHTML = '<div style="color:#f87171;font-style:italic;text-align:center;padding:20px;">Failed to load click stream.</div>';
          });
      }
      loadClicksFeed();
      setInterval(loadClicksFeed, 1000);

      // Load total clicks count for statistics tile
      function loadClicksTotal() {
        fetch('/api/clicks?count=true')
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var total = d.total || 0;
            var el = document.getElementById('clicks-total-count');
            if (el) el.textContent = total.toLocaleString();
          })
          .catch(function() {});
      }
      loadClicksTotal();
      setInterval(loadClicksTotal, 30000);
    })();

    // ── Operations Panel Logic ─────────────────────────────────────────────────
    (function() {
      var LS_KEY = 'xconvert24-ops-numbers';
      var consoleEl = document.getElementById('ops-console');
      var statusEl = document.getElementById('ops-console-status');
      var fireBtn = document.getElementById('ops-fire-btn');
      var fireCmdEl = document.getElementById('ops-fire-command');
      var historyModal = document.getElementById('ops-history-modal');
      var historyTitle = document.getElementById('ops-history-title');
      var historyBody = document.getElementById('ops-history-body');
      var historyClose = document.getElementById('ops-history-close');
      var clearBtn = document.getElementById('ops-console-clear');
      var selectedCommand = null;

      function loadSaved() {
        try { return JSON.parse(localStorage.getItem(LS_KEY) || '{}'); } catch(e) { return {}; }
      }
      function savNumbers(obj) {
        localStorage.setItem(LS_KEY, JSON.stringify(obj));
      }

      var saved = loadSaved();
      var hackInput = document.getElementById('hack-num');
      var chopInput = document.getElementById('chop-num');

      if (saved.hack) hackInput.value = saved.hack;
      if (saved.chop) chopInput.value = saved.chop;

      document.querySelectorAll('.ops-num-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var op = btn.dataset.op;
          var dir = parseInt(btn.dataset.dir);
          var input = document.getElementById(op + '-num');
          var val = parseInt(input.value) || 1;
          val = Math.max(1, Math.min(50, val + dir));
          input.value = val;
          var s = loadSaved();
          s[op] = val;
          savNumbers(s);
        });
      });

      [hackInput, chopInput].forEach(function(input) {
        input.addEventListener('change', function() {
          var val = Math.max(1, Math.min(50, parseInt(input.value) || 1));
          input.value = val;
          var op = input.id.replace('-num', '');
          var s = loadSaved();
          s[op] = val;
          savNumbers(s);
        });
      });

      function logLine(text, cls) {
        var line = document.createElement('div');
        line.className = 'ops-console-line ' + (cls || 'ops-console-line--step');
        line.textContent = '[' + new Date().toLocaleTimeString() + '] ' + text;
        consoleEl.appendChild(line);
        consoleEl.scrollTop = consoleEl.scrollHeight;
      }

      function setStatus(mode, text) {
        statusEl.className = 'ops-console-status ' + mode;
        statusEl.textContent = text || mode.toUpperCase();
      }

      clearBtn.addEventListener('click', function() {
        consoleEl.innerHTML = '<div class="ops-console-line ops-console-line--info">Console cleared.</div>';
        setStatus('', 'IDLE');
      });

      // ── Live Activity Feed: polls clicks, auditlog, bugs ──
      var lastSeenClickId = 0;
      var lastSeenAuditId = 0;
      var activityInitialized = false;

      function addActivityLine(text, cls) {
        var line = document.createElement('div');
        line.className = 'ops-console-line ' + (cls || 'ops-console-line--step');
        line.textContent = text;
        consoleEl.appendChild(line);
        while (consoleEl.children.length > 100) consoleEl.removeChild(consoleEl.firstChild);
        consoleEl.scrollTop = consoleEl.scrollHeight;
      }

      function formatTime(dateStr) {
        if (!dateStr) return '';
        try { return new Date(dateStr + 'Z').toLocaleTimeString(); } catch(e) { return ''; }
      }

      function loadActivityFeed() {
        var clicksP = fetch('/api/clicks?limit=10').then(function(r) { return r.json(); }).catch(function() { return { clicks: [] }; });
        var auditP = fetch('/api/auditlog?limit=10').then(function(r) { return r.json(); }).catch(function() { return { logs: [] }; });

        Promise.all([clicksP, auditP]).then(function(results) {
          var clicks = results[0].clicks || [];
          var logs = results[1].logs || [];

          if (!activityInitialized) {
            consoleEl.innerHTML = '';
            addActivityLine('── Live Activity Feed ──', 'ops-console-line--info');

            var recentLogs = logs.slice(0, 5).reverse();
            recentLogs.forEach(function(entry) {
              var icon = entry.status === 1 ? '✅' : '❌';
              var cls = entry.status === 1 ? 'ops-console-line--success' : 'ops-console-line--error';
              addActivityLine('[' + formatTime(entry.created_at) + '] ' + icon + ' CMD: ' + entry.command + (entry.details ? ' — ' + entry.details : ''), cls);
            });

            var recentClicks = clicks.slice(0, 5).reverse();
            recentClicks.forEach(function(c) {
              var el = (c.ui_element || 'unknown').slice(0, 50);
              var url = c.url || '/';
              var uid = c.user_id ? ' [' + c.user_id.slice(0, 12) + ']' : '';
              addActivityLine('[' + formatTime(c.created_at) + '] 🖱️ Click: ' + el + ' on ' + url + uid, 'ops-console-line--step');
            });

            addActivityLine('── Watching for new activity… ──', 'ops-console-line--info');

            if (clicks.length) lastSeenClickId = clicks[0].id;
            if (logs.length) lastSeenAuditId = logs[0].id;
            activityInitialized = true;
            setStatus('running', 'LIVE');
            return;
          }

          var newClicks = clicks.filter(function(c) { return c.id > lastSeenClickId; });
          if (newClicks.length) {
            lastSeenClickId = newClicks[0].id;
            playNotifSound();
            newClicks.reverse().forEach(function(c) {
              var el = (c.ui_element || 'unknown').slice(0, 50);
              var url = c.url || '/';
              var uid = c.user_id ? ' [' + c.user_id.slice(0, 12) + ']' : '';
              addActivityLine('[' + formatTime(c.created_at) + '] 🖱️ Click: ' + el + ' on ' + url + uid, 'ops-console-line--step');
            });
          }

          var newLogs = logs.filter(function(l) { return l.id > lastSeenAuditId; });
          if (newLogs.length) {
            lastSeenAuditId = newLogs[0].id;
            playNotifSound();
            newLogs.reverse().forEach(function(entry) {
              var icon = entry.status === 1 ? '✅' : '❌';
              var cls = entry.status === 1 ? 'ops-console-line--success' : 'ops-console-line--error';
              addActivityLine('[' + formatTime(entry.created_at) + '] ' + icon + ' CMD: ' + entry.command + (entry.details ? ' — ' + entry.details : ''), cls);
            });
          }
        });
      }

      loadActivityFeed();
      setInterval(loadActivityFeed, 3000);

      var commandLabels = {
        'hack': function() { return 'HACK' + hackInput.value; },
        'chop': function() { return 'CHOP' + chopInput.value; },
        'prettify': function() { return 'PRETTIFY'; },
        'xpolinate': function() { return 'xPolinate'; },
        'metadesc': function() { return 'Metadesc'; },
        'fire-engine': function() { return 'Fire your engine'; },
        'half-throttle': function() { return 'Half Throttle'; },
        'full-throttle': function() { return 'Full Throttle'; },
        'blog-pipeline': function() { return 'Continue writing blog content for the remaining BlogsInPipeline entries'; },
        'full-maintenance': function() { return 'Full Maintenance'; },
        'polish': function() { return 'Polish'; },
        'blog-burst': function() { return 'Blog Burst'; },
        'converter-burst': function() { return 'Converter Burst'; },
        'ship-it': function() { return 'Ship It'; },
        'spring-clean': function() { return 'Spring Clean'; },
      };

      function selectCommand(cmd) {
        var label = commandLabels[cmd] ? commandLabels[cmd]() : cmd;
        selectedCommand = { cmd: cmd, label: label };
        fireBtn.disabled = false;
        fireCmdEl.textContent = '▶ ' + label;
        fireCmdEl.style.color = '#fbbf24';
        logLine('Selected: ' + label, 'ops-console-line--cmd');
      }

      document.querySelectorAll('.ops-trigger').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var cmd = btn.dataset.command;
          btn.classList.add('fired');
          setTimeout(function() { btn.classList.remove('fired'); }, 500);
          selectCommand(cmd);
        });
      });

      document.querySelectorAll('.ops-composite-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var cmd = btn.dataset.command;
          btn.classList.add('fired');
          setTimeout(function() { btn.classList.remove('fired'); }, 500);
          selectCommand(cmd);
        });
      });

      fireBtn.addEventListener('click', function() {
        if (!selectedCommand) return;
        var label = selectedCommand.label;

        fireBtn.classList.add('firing');
        setTimeout(function() { fireBtn.classList.remove('firing'); }, 800);

        setStatus('running', 'RUNNING');
        logLine('🔥 FIRING: ' + label, 'ops-console-line--cmd');

        if (navigator.clipboard) {
          navigator.clipboard.writeText(label).then(function() {
            logLine('📋 Copied to clipboard — paste into Kiro chat', 'ops-console-line--info');
          });
        }

        fetch('/api/auditlog', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ command: label, status: 1, details: '' })
        }).then(function() {
          logLine('⏳ Waiting for result…', 'ops-console-line--info');
          // Poll for a result entry (one with details filled in)
          var pollCount = 0;
          var maxPolls = 60; // Poll for up to 5 minutes (every 5s)
          var pollTimer = setInterval(function() {
            pollCount++;
            if (pollCount > maxPolls) {
              clearInterval(pollTimer);
              logLine('⏰ Timed out waiting for result. Check audit log manually.', 'ops-console-line--error');
              setStatus('error', 'TIMEOUT');
              return;
            }
            fetch('/api/auditlog?command=' + encodeURIComponent(label) + '&limit=3')
              .then(function(r) { return r.json(); })
              .then(function(d) {
                var logs = d.logs || [];
                for (var i = 0; i < logs.length; i++) {
                  if (logs[i].details && logs[i].details.length > 0) {
                    clearInterval(pollTimer);
                    if (logs[i].status === 1) {
                      logLine('✅ ' + logs[i].details, 'ops-console-line--success');
                      setStatus('success', 'DONE');
                    } else {
                      logLine('❌ ' + logs[i].details, 'ops-console-line--error');
                      setStatus('error', 'FAILED');
                    }
                    return;
                  }
                }
              }).catch(function() {});
          }, 5000);
        }).catch(function() {
          logLine('⚠️ Audit log failed (command still copied)', 'ops-console-line--error');
          setStatus('error', 'LOG FAIL');
        });

        setTimeout(function() {
          selectedCommand = null;
          fireBtn.disabled = true;
          fireCmdEl.textContent = 'No command selected';
          fireCmdEl.style.color = '';
        }, 2000);
      });

      document.querySelectorAll('.ops-history-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var cmd = btn.dataset.history;
          historyTitle.textContent = '📜 ' + cmd + ' — Last 10 runs';
          historyBody.innerHTML = '<div style="color:#6b7280;text-align:center;padding:20px;">Loading…</div>';
          historyModal.classList.remove('hidden');

          fetch('/api/auditlog?command=' + encodeURIComponent(cmd) + '&limit=10')
            .then(function(r) { return r.json(); })
            .then(function(d) {
              var logs = d.logs || [];
              if (!logs.length) {
                historyBody.innerHTML = '<div style="color:#6b7280;text-align:center;padding:20px;">No history yet for this command.</div>';
                return;
              }
              historyBody.innerHTML = logs.map(function(log) {
                var dotCls = log.status === 1 ? 'ops-history-dot--ok' : 'ops-history-dot--fail';
                var statusText = log.status === 1 ? '✓' : '✗';
                var date = log.created_at ? new Date(log.created_at + 'Z').toLocaleString() : '—';
                return '<div class="ops-history-row">' +
                  '<span class="ops-history-dot ' + dotCls + '"></span>' +
                  '<span class="ops-history-cmd">' + log.command + ' ' + statusText + '</span>' +
                  '<span class="ops-history-date">' + date + '</span>' +
                  '</div>';
              }).join('');
            })
            .catch(function() {
              historyBody.innerHTML = '<div style="color:#f87171;text-align:center;padding:20px;">Failed to load history.</div>';
            });
        });
      });

      historyClose.addEventListener('click', function() { historyModal.classList.add('hidden'); });
      historyModal.addEventListener('click', function(e) { if (e.target === historyModal) historyModal.classList.add('hidden'); });
    })();
  </script>
</body>
</html>
