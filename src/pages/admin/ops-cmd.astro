                '<span style="color:#22d3ee;font-size:10px;min-width:44px;">' + agent.name + '</span>' +
                '<span style="color:#fbbf24;font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + (log.command || '').replace(/</g,'&lt;') + '</span>' +
                '<span style="color:#6b7280;font-size:10px;white-space:nowrap;">' + date + '</span>' +
