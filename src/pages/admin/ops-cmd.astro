            if (t.created_at) {
              var diff = Date.now() - new Date(t.created_at).getTime();
              var mins = Math.floor(diff / 60000);
              if (mins < 1) ago = 'just now';
              else if (mins < 60) ago = mins + 'm ago';
              else if (mins < 1440) ago = Math.floor(mins/60) + 'h ago';
              else ago = Math.floor(mins/1440) + 'd ago';
            }
            return '<div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #1e293b;">' +
