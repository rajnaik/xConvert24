---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };

const personas = [
  {
    id: 'user',
    icon: '👤',
    name: 'The User',
    role: 'Primary Customer',
    color: '#3b82f6',
    summary: 'Daily user who converts units, uses tools, earns ConvertCoins.',
    link: '/admin/personas/user',
  },
  {
    id: 'referee',
    icon: '🔗',
    name: 'The Referee',
    role: 'Prospective Customer',
    color: '#8b5cf6',
    summary: 'Arrives via referral or social share. Evaluating the site for first time.',
    link: '/admin/personas/referee',
  },
  {
    id: 'power-user',
    icon: '⚡',
    name: 'The Power User',
    role: 'High-Engagement Champion',
    color: '#f59e0b',
    summary: 'Uses multiple converters daily, maintains streaks, reports bugs, suggests features.',
    link: '/admin/personas/power-user',
  },
  {
    id: 'developer',
    icon: '🛠️',
    name: 'The Developer',
    role: 'Widget Integrator',
    color: '#10b981',
    summary: 'Embeds xConvert widgets in their own apps. Uses the embed/API endpoints.',
    link: '/admin/personas/developer',
  },
  {
    id: 'educator',
    icon: '📚',
    name: 'The Educator',
    role: 'Teaching Professional',
    color: '#ec4899',
    summary: 'Teacher or tutor who uses converters as teaching aids for students.',
    link: '/admin/personas/educator',
  },
  {
    id: 'mobile-user',
    icon: '📱',
    name: 'The Mobile User',
    role: 'On-the-Go Converter',
    color: '#06b6d4',
    summary: 'Primarily accesses via phone. Needs fast, thumb-friendly interactions.',
    link: '/admin/personas/mobile-user',
  },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Personas | Admin | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .logo { font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #fbbf24, #d97706); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .back-link { color: #9ca3af; text-decoration: none; font-size: 13px; padding: 6px 12px; border-radius: 6px; border: 1px solid #374151; transition: all 0.2s; }
    .back-link:hover { color: #fbbf24; border-color: #fbbf24; }
    .container { max-width: 1000px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
    .personas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .persona-card { background: #111827; border: 1px solid #1f2937; border-radius: 16px; padding: 24px; transition: all 0.2s; text-decoration: none; color: inherit; display: block; position: relative; overflow: hidden; }
    .persona-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .persona-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); }
    .persona-icon { font-size: 40px; margin-bottom: 12px; }
    .persona-name { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .persona-role { font-size: 12px; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
    .persona-summary { font-size: 13px; color: #9ca3af; line-height: 1.6; }
    .persona-arrow { position: absolute; bottom: 20px; right: 20px; color: #374151; font-size: 18px; transition: color 0.2s; }
    .persona-card:hover .persona-arrow { color: var(--accent); }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">⚙️ xConvert24 Admin</div>
    <a href="/admin" class="back-link">← Back to Dashboard</a>
  </div>

  <div class="container">
    <h1>👥 Personas</h1>
    <p class="subtitle">User archetypes who interact with xConvert24.com. Click each persona to see their full profile.</p>

    <div class="personas-grid">
      {personas.map(p => (
        <a href={p.link} class="persona-card" style={`--accent: ${p.color}`}>
          <div class="persona-icon">{p.icon}</div>
          <div class="persona-name">{p.name}</div>
          <div class="persona-role">{p.role}</div>
          <div class="persona-summary">{p.summary}</div>
          <div class="persona-arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</body>
</html>
