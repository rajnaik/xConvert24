---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Databases | Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    nav { background: #1e293b; padding: 0.8rem 1.5rem; border-bottom: 1px solid #334155; display: flex; gap: 1.5rem; align-items: center; }
    nav a { color: #94a3b8; text-decoration: none; font-size: 0.85rem; font-weight: 500; }
    nav a:hover { color: #f59e0b; }
    .container { max-width: 1400px; margin: 0 auto; padding: 1.5rem; }
    h1 { color: #f8fafc; margin-bottom: 1rem; }
    .tables-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
    .table-chip { padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; background: #1e293b; border: 1px solid #334155; color: #94a3b8; transition: all 0.15s; }
    .table-chip:hover, .table-chip.active { background: #f59e0b; color: #000; border-color: #f59e0b; }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; font-size: 0.8rem; }
    th { background: #1e293b; color: #94a3b8; padding: 0.6rem 0.8rem; text-align: left; font-size: 0.7rem; text-transform: uppercase; border-bottom: 1px solid #334155; position: sticky; top: 0; }
    td { padding: 0.5rem 0.8rem; border-bottom: 1px solid #1e293b; color: #e2e8f0; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    tr:hover td { background: #1e293b; }
    .btn-del { background: #ef4444; color: white; border: none; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; cursor: pointer; }
    .btn-del:hover { opacity: 0.8; }
    .stats { color: #64748b; font-size: 0.8rem; margin-bottom: 0.5rem; }
    .table-wrap { max-height: 70vh; overflow: auto; border: 1px solid #334155; border-radius: 8px; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin">← Admin</a>
    <a href="/admin/databases" style="color:#f59e0b;">🗄️ Databases</a>
  </nav>
  <div class="container">
    <h1>🗄️ Databases</h1>
    <div class="tables-list" id="tablesList"></div>
    <div class="stats" id="stats"></div>
    <div class="table-wrap">
      <table>
        <thead id="thead"></thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    var currentTable = '';

    async function loadTables() {
      var res = await fetch('/api/databases');
      var data = await res.json();
      var list = document.getElementById('tablesList');
      list.innerHTML = data.tables.map(function(t) {
        return '<span class="table-chip" data-table="' + t + '">' + t + '</span>';
      }).join('');
      list.querySelectorAll('.table-chip').forEach(function(chip) {
        chip.addEventListener('click', function() {
          document.querySelectorAll('.table-chip').forEach(function(c) { c.classList.remove('active'); });
          this.classList.add('active');
          loadTable(this.getAttribute('data-table'));
        });
      });
    }

    async function loadTable(name) {
      currentTable = name;
      var res = await fetch('/api/databases?table=' + encodeURIComponent(name));
      var data = await res.json();
      document.getElementById('stats').textContent = data.count + ' rows in "' + name + '"';

      var cols = data.columns || [];
      var idCol = cols.length > 0 ? cols[0].name : 'id';

      document.getElementById('thead').innerHTML = '<tr>' +
        cols.map(function(c) { return '<th>' + c.name + '</th>'; }).join('') +
        '<th>Actions</th></tr>';

      document.getElementById('tbody').innerHTML = data.rows.map(function(row) {
        return '<tr>' +
          cols.map(function(c) {
            var val = row[c.name];
            if (val === null) return '<td style="color:#475569;">NULL</td>';
            return '<td title="' + String(val).replace(/"/g, '&quot;') + '">' + String(val).slice(0, 80) + '</td>';
          }).join('') +
          '<td><button class="btn-del" onclick="deleteRow(\'' + name + '\',\'' + idCol + '\',\'' + String(row[idCol]).replace(/'/g, "\\'") + '\')">Del</button></td>' +
        '</tr>';
      }).join('') || '<tr><td colspan="' + (cols.length + 1) + '" style="text-align:center;color:#64748b;padding:2rem;">Empty table</td></tr>';
    }

    window.deleteRow = async function(table, idCol, id) {
      if (!confirm('Delete this row?')) return;
      await fetch('/api/databases?table=' + table + '&idCol=' + idCol + '&id=' + encodeURIComponent(id), { method: 'DELETE' });
      loadTable(table);
    };

    loadTables();
  </script>
</body>
</html>
