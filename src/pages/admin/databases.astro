---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Databases | Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; padding: 1rem; }
    h1 { color: #f8fafc; margin-bottom: 1rem; }
    h2 { color: #f8fafc; margin: 1.5rem 0 0.5rem; }
    .nav { margin-bottom: 1.5rem; display: flex; gap: 1rem; align-items: center; }
    .nav a { color: #94a3b8; text-decoration: none; font-size: 0.85rem; }
    .nav a:hover { color: #f59e0b; }
    .tables-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.8rem; margin-bottom: 1.5rem; }
    .table-card { background: #1e293b; border: 1px solid #334155; border-radius: 8px; padding: 1rem; cursor: pointer; transition: all 0.15s; }
    .table-card:hover { border-color: #f59e0b; background: #1e293b; }
    .table-card.active { border-color: #f59e0b; box-shadow: 0 0 0 2px rgba(245,158,11,0.2); }
    .table-card h3 { color: #f59e0b; font-size: 0.9rem; margin-bottom: 0.3rem; }
    .table-card p { color: #64748b; font-size: 0.75rem; }
    table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; font-size: 0.8rem; }
    th, td { padding: 0.5rem 0.8rem; text-align: left; border-bottom: 1px solid #334155; }
    th { background: #1e293b; color: #94a3b8; font-size: 0.75rem; text-transform: uppercase; position: sticky; top: 0; }
    td { color: #e2e8f0; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .data-view { max-height: 500px; overflow: auto; border: 1px solid #334155; border-radius: 8px; }
    .toolbar { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; align-items: center; }
    .btn { padding: 0.4rem 0.8rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem; font-weight: 500; }
    .btn-primary { background: #3b82f6; color: white; }
    .btn-danger { background: #ef4444; color: white; }
    .btn-success { background: #10b981; color: white; }
    .btn:hover { opacity: 0.85; }
    input, select { padding: 0.4rem 0.6rem; background: #0f172a; border: 1px solid #475569; border-radius: 4px; color: #e2e8f0; font-size: 0.8rem; }
    .status { color: #10b981; font-size: 0.8rem; margin-left: 1rem; }
  </style>
</head>
<body>
  <div class="nav">
    <a href="/admin">← Admin</a>
    <h1>🗄️ Databases</h1>
    <span class="status" id="status"></span>
  </div>

  <div class="tables-grid" id="tablesGrid"></div>

  <div id="tableView" style="display:none;">
    <div class="toolbar">
      <h2 id="tableName"></h2>
      <span style="color:#64748b;font-size:0.8rem;margin-left:0.5rem;" id="rowCount"></span>
      <input type="number" id="limitInput" value="50" min="1" max="500" style="width:60px;margin-left:auto;" title="Row limit" />
      <button class="btn btn-primary" id="refreshRows">🔄 Refresh</button>
    </div>
    <div class="data-view">
      <table>
        <thead id="tableHead"></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    var currentTable = '';

    async function loadTables() {
      var res = await fetch('/api/databases');
      var data = await res.json();
      var grid = document.getElementById('tablesGrid');
      grid.innerHTML = data.tables.map(function(t) {
        return '<div class="table-card" data-table="' + t.name + '">' +
          '<h3>' + t.name + '</h3>' +
          '<p>' + (t.count || 0) + ' rows</p>' +
        '</div>';
      }).join('');

      grid.querySelectorAll('.table-card').forEach(function(card) {
        card.addEventListener('click', function() {
          grid.querySelectorAll('.table-card').forEach(function(c) { c.classList.remove('active'); });
          card.classList.add('active');
          currentTable = card.getAttribute('data-table');
          loadRows();
        });
      });
    }

    async function loadRows() {
      if (!currentTable) return;
      var limit = document.getElementById('limitInput').value || 50;
      document.getElementById('tableName').textContent = currentTable;
      document.getElementById('tableView').style.display = 'block';

      var res = await fetch('/api/databases?table=' + currentTable + '&limit=' + limit);
      var data = await res.json();

      if (!data.rows || data.rows.length === 0) {
        document.getElementById('tableHead').innerHTML = '<tr><th>Empty table</th></tr>';
        document.getElementById('tableBody').innerHTML = '<tr><td>No rows</td></tr>';
        document.getElementById('rowCount').textContent = '(0 rows)';
        return;
      }

      var cols = Object.keys(data.rows[0]);
      document.getElementById('rowCount').textContent = '(' + data.rows.length + ' rows shown)';
      document.getElementById('tableHead').innerHTML = '<tr>' + cols.map(function(c) { return '<th>' + c + '</th>'; }).join('') + '</tr>';
      document.getElementById('tableBody').innerHTML = data.rows.map(function(row) {
        return '<tr>' + cols.map(function(c) {
          var val = row[c];
          if (val === null) return '<td style="color:#475569;">NULL</td>';
          return '<td title="' + String(val).replace(/"/g, '&quot;') + '">' + String(val).slice(0, 80) + '</td>';
        }).join('') + '</tr>';
      }).join('');
    }

    document.getElementById('refreshRows').addEventListener('click', loadRows);
    document.getElementById('limitInput').addEventListener('change', loadRows);

    loadTables();
  </script>
</body>
</html>
