---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Analytics | Admin | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
    .back { color: #9ca3af; text-decoration: none; font-size: 14px; }
    .back:hover { color: #fbbf24; }
    .logo { font-size: 16px; font-weight: 600; color: #d1d5db; }
    .container { max-width: 900px; margin: 0 auto; padding: 32px 24px; text-align: center; }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
    .ga-link { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: #1f2937; border: 1px solid #374151; border-radius: 10px; color: #fbbf24; font-weight: 600; font-size: 15px; text-decoration: none; transition: all 0.2s; }
    .ga-link:hover { background: #374151; border-color: #f59e0b; }
    .id-badge { margin-top: 16px; font-size: 12px; color: #6b7280; font-family: monospace; }
  </style>
</head>
<body>
  <div class="header">
    <a href="/admin" class="back">← Dashboard</a>
    <span class="logo">Analytics</span>
  </div>

  <div class="container">
    <h1>📊 Analytics</h1>
    <p class="subtitle">Your Google Analytics dashboard for xConvert24.com</p>

    <a href="https://analytics.google.com/analytics/web/#/p/G-BZMZ2XC247" target="_blank" rel="noopener" class="ga-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      Open Google Analytics
    </a>
    <div class="id-badge">Property ID: G-BZMZ2XC247</div>
  </div>
</body>
</html>
