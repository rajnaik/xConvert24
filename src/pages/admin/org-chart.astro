---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Org Chart | xConvert24 Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .logo { font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #fbbf24, #d97706); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .back-link { font-size: 13px; color: #9ca3af; text-decoration: none; padding: 6px 12px; border-radius: 6px; border: 1px solid #374151; transition: all 0.2s; }
    .back-link:hover { color: #fbbf24; border-color: #fbbf24; }
    .container { max-width: 1000px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }

    /* Org chart */
    .org-tree { display: flex; flex-direction: column; align-items: center; gap: 0; }
    .org-level { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; position: relative; }
    .org-connector { width: 2px; height: 32px; background: #374151; margin: 0 auto; }
    .org-branch { display: flex; justify-content: center; position: relative; }
    .org-branch::before { content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 2px; background: #374151; }

    .org-card { background: #111827; border: 1px solid #1f2937; border-radius: 14px; padding: 20px; text-align: center; width: 180px; cursor: pointer; transition: all 0.2s; position: relative; }
    .org-card:hover { border-color: #fbbf24; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(251,191,36,0.1); }
    .org-card.active { border-color: #fbbf24; box-shadow: 0 0 0 2px #fbbf2440; }
    .org-icon { font-size: 36px; margin-bottom: 8px; }
    .org-name { font-size: 14px; font-weight: 700; color: #f9fafb; margin-bottom: 2px; }
    .org-role { font-size: 11px; color: #fbbf24; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .org-desc { font-size: 10px; color: #6b7280; line-height: 1.4; }
    .org-status { position: absolute; top: 10px; right: 10px; width: 8px; height: 8px; border-radius: 50%; }
    .status-active { background: #4ade80; box-shadow: 0 0 6px #4ade80; }
    .status-standby { background: #fbbf24; }
    .status-planned { background: #6b7280; }

    /* Job history panel */
    .jobs-panel { display: none; margin-top: 24px; background: #111827; border: 1px solid #1f2937; border-radius: 12px; overflow: hidden; }
    .jobs-panel.open { display: block; }
    .jobs-header { padding: 14px 18px; background: #1f2937; border-bottom: 1px solid #374151; display: flex; align-items: center; justify-content: space-between; }
    .jobs-title { font-size: 13px; font-weight: 600; color: #f9fafb; }
    .jobs-close { background: none; border: none; color: #9ca3af; font-size: 18px; cursor: pointer; padding: 4px; }
    .jobs-close:hover { color: #f9fafb; }
    .jobs-list { padding: 12px; max-height: 400px; overflow-y: auto; }
    .job-row { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 8px; margin-bottom: 6px; background: #0f172a; }
    .job-row:hover { background: #1e293b; }
    .job-num { font-size: 10px; color: #6b7280; width: 20px; text-align: right; shrink: 0; }
    .job-info { flex: 1; min-width: 0; }
    .job-task { font-size: 12px; color: #d1d5db; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .job-date { font-size: 10px; color: #6b7280; margin-top: 2px; }
    .job-duration { font-size: 11px; color: #fbbf24; font-weight: 600; font-family: monospace; white-space: nowrap; }
    .empty-jobs { text-align: center; padding: 24px; color: #6b7280; font-size: 12px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">🏢 Org Chart</div>
    <a href="/admin" class="back-link">← Dashboard</a>
  </div>

  <div class="container">
    <h1>🏢 Organisation Chart</h1>
    <p class="subtitle">The xConvert24.com team — agents and their roles.</p>

    <!-- Org tree -->
    <div class="org-tree">
      <!-- CEO -->
      <div class="org-level">
        <div class="org-card" data-agent="henry">
          <div class="org-status status-active"></div>
          <div class="org-icon">👑</div>
          <div class="org-name">Henry</div>
          <div class="org-role">CEO & Founder</div>
          <div class="org-desc">Vision, strategy, and final decisions</div>
        </div>
      </div>

      <div class="org-connector"></div>

      <!-- CTO (Kiro) -->
      <div class="org-level">
        <div class="org-card" data-agent="kiro">
          <div class="org-status status-active"></div>
          <div class="org-icon">🤖</div>
          <div class="org-name">Kiro</div>
          <div class="org-role">CTO</div>
          <div class="org-desc">Architecture, development, deployment, coordination</div>
        </div>
      </div>

      <div class="org-connector"></div>

      <!-- Team -->
      <div class="org-level org-branch">
        <div class="org-card" data-agent="quill">
          <div class="org-status status-active"></div>
          <div class="org-icon">✍️</div>
          <div class="org-name">Quill</div>
          <div class="org-role">Content Strategist</div>
          <div class="org-desc">SEO blog posts, content calendar, publishing</div>
        </div>
        <div class="org-card" data-agent="archer">
          <div class="org-status status-active"></div>
          <div class="org-icon">🎯</div>
          <div class="org-name">Archer</div>
          <div class="org-role">SEO Champion</div>
          <div class="org-desc">Technical SEO, keywords, structured data, audits</div>
        </div>
        <div class="org-card" data-agent="sentinel">
          <div class="org-status status-planned"></div>
          <div class="org-icon">🛡️</div>
          <div class="org-name">Sentinel</div>
          <div class="org-role">Contagion Tracker</div>
          <div class="org-desc">Beta Plays — disease data, news aggregation</div>
        </div>
      </div>
    </div>

    <!-- Job history panel -->
    <div id="jobs-panel" class="jobs-panel">
      <div class="jobs-header">
        <span class="jobs-title" id="jobs-agent-name">—</span>
        <button class="jobs-close" id="jobs-close">✕</button>
      </div>
      <div class="jobs-list" id="jobs-list">
        <div class="empty-jobs">Select an agent to view their work history.</div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    var JOBS_KEY = 'xconvert24-agent-jobs';

    // Default job data (seeded from what each agent has done)
    var defaultJobs = {
      henry: [
        { task: 'Reviewed v1.8.0 release and approved deploy', date: '2025-06-05T19:30:00', duration: '2m' },
        { task: 'Named Sentinel as contagion tracker agent', date: '2025-06-05T19:10:00', duration: '1m' },
        { task: 'Named Archer as SEO champion agent', date: '2025-06-05T19:05:00', duration: '1m' },
        { task: 'Approved custom domain xconvert24.com purchase', date: '2025-06-04T14:00:00', duration: '5m' },
        { task: 'Set project vision: Fast, Free, No Signups', date: '2025-06-04T10:00:00', duration: '10m' },
      ],
      kiro: [
        { task: 'Deployed v1.8.0 — mobile fix, contact form, version variable', date: '2025-06-05T19:35:00', duration: '58s' },
        { task: 'Built Guitar Tuner with Web Audio pitch detection', date: '2025-06-05T18:00:00', duration: '8m' },
        { task: 'Rebuilt Crypto Bubbles with D3.js + watchlists', date: '2025-06-05T17:10:00', duration: '12m' },
        { task: 'Created Online Ruler with calibration & pick-up', date: '2025-06-05T16:45:00', duration: '6m' },
        { task: 'Built Audio & Video Converters with download history', date: '2025-06-05T16:06:00', duration: '10m' },
        { task: 'Created Image Converter with resize & quality', date: '2025-06-05T15:02:00', duration: '7m' },
        { task: 'Admin dashboard reorganisation + SEO Editor', date: '2025-06-05T16:42:00', duration: '9m' },
        { task: 'Fixed Suggestions API with COALESCE query', date: '2025-06-05T17:02:00', duration: '3m' },
        { task: 'SEO: sitemap 37→65 URLs, og:image PNG, PWA meta', date: '2025-06-05T15:50:00', duration: '5m' },
        { task: 'Deployed v1.6.5 — media category, Google Ads tag', date: '2025-06-05T15:57:00', duration: '41s' },
      ],
      quill: [
        { task: 'Published blog #25: "Understanding Cryptocurrency Basics"', date: '2025-06-29T21:00:00', duration: '45m' },
        { task: 'Published blog #24: "Compound Interest Explained"', date: '2025-06-28T21:00:00', duration: '40m' },
        { task: 'Published blog #23: "Miles to Kilometers Running"', date: '2025-06-27T21:00:00', duration: '35m' },
        { task: 'Published blog #22: "Age Calculator — Exact Days Alive"', date: '2025-06-26T21:00:00', duration: '38m' },
        { task: 'Published blog #21: "Baby Weight Conversion Chart"', date: '2025-06-25T21:00:00', duration: '42m' },
        { task: 'Wrote 50 SEO blog posts across all categories', date: '2025-06-05T12:00:00', duration: '4h' },
        { task: 'Created blog content calendar (Jun 5 – Jul 24)', date: '2025-06-05T11:00:00', duration: '30m' },
        { task: 'Researched keywords for blog topics', date: '2025-06-05T10:30:00', duration: '20m' },
      ],
      archer: [
        { task: 'Agent created and configured', date: '2025-06-05T19:24:00', duration: '2m' },
        { task: 'Defined audit checklist (title, desc, H1, schema)', date: '2025-06-05T19:24:00', duration: '1m' },
        { task: 'Ready for first audit assignment', date: '2025-06-05T19:25:00', duration: '—' },
      ],
      sentinel: [
        { task: 'Agent named and role defined', date: '2025-06-05T19:10:00', duration: '1m' },
        { task: 'Assigned to Beta Plays category (planned)', date: '2025-06-05T19:10:00', duration: '—' },
      ],
    };

    function getJobs() {
      try {
        var stored = JSON.parse(localStorage.getItem(JOBS_KEY) || 'null');
        if (stored) return stored;
      } catch {}
      // Seed defaults
      localStorage.setItem(JOBS_KEY, JSON.stringify(defaultJobs));
      return defaultJobs;
    }

    function renderJobs(agentId) {
      var jobs = getJobs();
      var agentJobs = (jobs[agentId] || []).slice(0, 10);
      var panel = document.getElementById('jobs-panel');
      var list = document.getElementById('jobs-list');
      var title = document.getElementById('jobs-agent-name');

      var names = { henry: '👑 Henry — CEO', kiro: '🤖 Kiro — CTO', quill: '✍️ Quill — Content', archer: '🎯 Archer — SEO', sentinel: '🛡️ Sentinel — Contagion' };
      title.textContent = names[agentId] || agentId;

      if (!agentJobs.length) {
        list.innerHTML = '<div class="empty-jobs">No jobs recorded yet for this agent.</div>';
      } else {
        list.innerHTML = agentJobs.map(function(job, i) {
          var date = new Date(job.date);
          var dateStr = date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' + date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
          return '<div class="job-row"><span class="job-num">#' + (i + 1) + '</span><div class="job-info"><div class="job-task">' + escapeHtml(job.task) + '</div><div class="job-date">' + dateStr + '</div></div><span class="job-duration">' + (job.duration || '—') + '</span></div>';
        }).join('');
      }

      panel.classList.add('open');

      // Highlight active card
      document.querySelectorAll('.org-card').forEach(function(c) { c.classList.remove('active'); });
      document.querySelector('[data-agent="' + agentId + '"]')?.classList.add('active');
    }

    function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // Card click handlers
    document.querySelectorAll('.org-card').forEach(function(card) {
      card.addEventListener('click', function() {
        renderJobs(card.getAttribute('data-agent'));
      });
    });

    // Close panel
    document.getElementById('jobs-close').addEventListener('click', function() {
      document.getElementById('jobs-panel').classList.remove('open');
      document.querySelectorAll('.org-card').forEach(function(c) { c.classList.remove('active'); });
    });
  })();
  </script>
</body>
</html>
