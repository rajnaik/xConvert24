---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dependency Chart | Admin | xConvert24.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; background: #030712; color: #f9fafb; }
    .header { background: #111827; border-bottom: 1px solid #1f2937; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .logo { font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #fbbf24, #d97706); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .back-link { color: #9ca3af; text-decoration: none; font-size: 13px; padding: 6px 12px; border-radius: 6px; border: 1px solid #374151; }
    .back-link:hover { color: #fbbf24; border-color: #fbbf24; }
    .container { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
    h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
    .dep-section { margin-bottom: 32px; }
    .dep-title { font-size: 14px; font-weight: 700; color: #fbbf24; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .dep-table { width: 100%; border-collapse: collapse; background: #111827; border-radius: 12px; overflow: hidden; border: 1px solid #1f2937; }
    .dep-table th { text-align: left; padding: 12px 16px; background: #1f2937; font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; }
    .dep-table td { padding: 10px 16px; border-top: 1px solid #1f2937; font-size: 12px; color: #d1d5db; vertical-align: top; }
    .dep-table tr:hover td { background: #0f172a; }
    .trigger { color: #fbbf24; font-weight: 600; }
    .action { color: #10b981; }
    .condition { color: #f59e0b; font-style: italic; }
    .coins { color: #fbbf24; font-weight: 700; }
    .event-tag { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 600; background: #1e3a5f; color: #93c5fd; margin-right: 4px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">⚙️ xConvert24 Admin</div>
    <a href="/admin" class="back-link">← Dashboard</a>
  </div>

  <div class="container">
    <h1>🔗 Dependency Chart</h1>
    <p class="subtitle">Every user action and its chain of dependent reactions. When Activity X happens, Actions Y and Z are triggered automatically.</p>

    <!-- CONVERTERS -->
    <div class="dep-section">
      <div class="dep-title">📐 Converters</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">View any converter page</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award first_conversion coins<br/>→ Log analytics (converter_view)<br/>→ Log to rewards history</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">View 3 different converters</td>
            <td class="condition">Same session, first time today</td>
            <td class="action">→ Award multi_converter coins<br/>→ Log analytics<br/>→ Log to rewards history</td>
            <td class="coins">+10 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Use cooking converter</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award cooking_convert coins<br/>→ Log analytics</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Use shoe/clothing size</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award fashion_convert coins<br/>→ Log analytics</td>
            <td class="coins">+5 🪙</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- TOOLS -->
    <div class="dep-section">
      <div class="dep-title">🔧 Tools & Utilities</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Use crypto tools</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award crypto_use coins<br/>→ Log analytics (tool_view)</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Use finance tools (loan/tip/discount)</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award finance_use coins<br/>→ Log analytics (tool_view)</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Add coin to crypto watchlist</td>
            <td class="condition">First time for that coin</td>
            <td class="action">→ Award crypto_watchlist coins<br/>→ Log analytics (crypto_add)<br/>→ Log to rewards history</td>
            <td class="coins">+2 🪙</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- FAVOURITES & BOOKMARKS -->
    <div class="dep-section">
      <div class="dep-title">⭐ Favourites & Bookmarks</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Bookmark a page</td>
            <td class="condition">First time for that page</td>
            <td class="action">→ Award bookmark_page coins<br/>→ Log analytics (bookmark_click)<br/>→ Log to rewards history<br/>→ Save to bookmark list</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Add to favourites</td>
            <td class="condition">First time for that item</td>
            <td class="action">→ Award add_favourite coins<br/>→ Log analytics (favourite_add)<br/>→ Log to rewards history</td>
            <td class="coins">+3 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Reach 5 favourites</td>
            <td class="condition">Total favourites = 5</td>
            <td class="action">→ Award favourite_5 milestone coins<br/>→ Log to rewards history</td>
            <td class="coins">+10 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Publish your favourites</td>
            <td class="condition">First time publishing</td>
            <td class="action">→ Store in favourites_published DB<br/>→ Award publish_favourites coins<br/>→ Visible in "See What Others Are Liking"</td>
            <td class="coins">+10 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Hide your favourites</td>
            <td class="condition">User clicks Hide</td>
            <td class="action">→ Set hidden=1 in DB<br/>→ Removed from public feed</td>
            <td class="coins">—</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- BUG REPORTS -->
    <div class="dep-section">
      <div class="dep-title">🐛 Bug Reports</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Submit a bug report</td>
            <td class="condition">First time today</td>
            <td class="action">→ Log analytics (bug_report_submit)<br/>→ Store reporter_uid in DB<br/>→ Insert into bugs table<br/>→ Emit event: bug_reported</td>
            <td class="coins">—</td>
          </tr>
          <tr>
            <td class="trigger">Bug gets validated by admin</td>
            <td class="condition">Admin checks validation box</td>
            <td class="action">→ Award bug_report coins to reporter_uid<br/>→ Log coin_event<br/>→ Emit event: bug_validated<br/>→ Update reporter level if threshold crossed</td>
            <td class="coins">+25 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Vote on a bug</td>
            <td class="condition">First vote on that bug by this user</td>
            <td class="action">→ Award vote_bug coins<br/>→ Log analytics (bug_vote)<br/>→ Log to rewards history<br/>→ Increment bug vote count</td>
            <td class="coins">+3 🪙</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- SUGGESTIONS -->
    <div class="dep-section">
      <div class="dep-title">💡 Suggestions</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Submit a feature suggestion</td>
            <td class="condition">First time today</td>
            <td class="action">→ Award suggest_feature coins<br/>→ Log analytics (feature_suggest_submit)<br/>→ Log to rewards history<br/>→ Insert into suggestions table</td>
            <td class="coins">+10 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Rate/vote on a suggestion</td>
            <td class="condition">First vote on that suggestion</td>
            <td class="action">→ Award vote_suggestion coins<br/>→ Log analytics (suggestion_vote)<br/>→ Log to rewards history<br/>→ Recalculate suggestion rating</td>
            <td class="coins">+3 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Suggestion reaches 4+ star rating</td>
            <td class="condition">Average rating ≥ 4.0</td>
            <td class="action">→ Emit event: suggestion_high_rated<br/>→ Award 30 coins to original suggester</td>
            <td class="coins">+30 🪙 (to suggester)</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- STREAKS & VISITS -->
    <div class="dep-section">
      <div class="dep-title">🔥 Streaks & Daily Activity</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Visit site</td>
            <td class="condition">First visit today</td>
            <td class="action">→ Award daily_visit coins<br/>→ Increment streak counter<br/>→ Update last_active date<br/>→ Log analytics</td>
            <td class="coins">+5 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Reach 7-day streak</td>
            <td class="condition">streak = 7, not already awarded today</td>
            <td class="action">→ Award streak_7 coins<br/>→ Emit event: streak_achieved<br/>→ Show streak flame 🔥</td>
            <td class="coins">+50 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Reach 30-day streak</td>
            <td class="condition">streak = 30, not already awarded today</td>
            <td class="action">→ Award streak_30 coins<br/>→ Emit event: streak_achieved</td>
            <td class="coins">+200 🪙</td>
          </tr>
          <tr>
            <td class="trigger">Read a blog post</td>
            <td class="condition">First time for that post</td>
            <td class="action">→ Award blog_read coins<br/>→ Log analytics (blog_view)<br/>→ Log to rewards history</td>
            <td class="coins">+5 🪙</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- CRYPTO WATCHLIST -->
    <div class="dep-section">
      <div class="dep-title">💰 Crypto Watchlist</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Create a watchlist</td>
            <td class="condition">First watchlist creation</td>
            <td class="action">→ Log analytics (crypto_add)<br/>→ Store in localStorage</td>
            <td class="coins">—</td>
          </tr>
          <tr>
            <td class="trigger">Add a coin to watchlist</td>
            <td class="condition">First time adding that specific coin</td>
            <td class="action">→ Award crypto_watchlist coins<br/>→ Log analytics (crypto_add)<br/>→ Log to rewards history<br/>→ Persist watchlist</td>
            <td class="coins">+2 🪙</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- OPINIONS -->
    <div class="dep-section">
      <div class="dep-title">💬 Opinions</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Reward</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Cast an opinion vote</td>
            <td class="condition">First vote on that question</td>
            <td class="action">→ Store in opinions DB<br/>→ Log analytics (opinion_vote)<br/>→ Mark as voted in localStorage</td>
            <td class="coins">—</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- SYSTEM / PIPELINE -->
    <div class="dep-section">
      <div class="dep-title">⚙️ System Events (Pipeline)</div>
      <table class="dep-table">
        <thead><tr><th>Trigger</th><th>Condition</th><th>Actions Fired</th><th>Effect</th></tr></thead>
        <tbody>
          <tr>
            <td class="trigger">Deployment starts</td>
            <td class="condition">Pipeline step 10+ begins</td>
            <td class="action">→ Emit event: deployment_start<br/>→ Set SiteStatus = Green<br/>→ Update admin dashboard star</td>
            <td>🟢 Green</td>
          </tr>
          <tr>
            <td class="trigger">All tests pass</td>
            <td class="condition">Post-live tests 100% pass</td>
            <td class="action">→ Emit event: deployment_done<br/>→ Set SiteStatus = Golden<br/>→ Update admin dashboard star</td>
            <td>🌟 Golden</td>
          </tr>
          <tr>
            <td class="trigger">Tests fail</td>
            <td class="condition">Any gate test fails</td>
            <td class="action">→ Emit event: test_failed<br/>→ Set SiteStatus = Red<br/>→ Update admin dashboard star</td>
            <td>🔴 Red</td>
          </tr>
          <tr>
            <td class="trigger">Task completed by agent</td>
            <td class="condition">POST /api/org-chart (task)</td>
            <td class="action">→ Insert org_task<br/>→ Update agent status<br/>→ Invalidate pipeline cache<br/>→ Appear in admin Tasks panel</td>
            <td>📝 Logged</td>
          </tr>
          <tr>
            <td class="trigger">User levels up</td>
            <td class="condition">total_earned crosses 500n threshold</td>
            <td class="action">→ Update level in user_coins<br/>→ Emit event: level_up<br/>→ Log to org_tasks (system)</td>
            <td>⬆️ Level up</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Legend -->
    <div style="margin-top:24px;padding:16px;background:#111827;border:1px solid #1f2937;border-radius:12px;">
      <div style="font-size:12px;font-weight:600;color:#f9fafb;margin-bottom:8px;">Legend</div>
      <div style="display:flex;flex-wrap:wrap;gap:16px;font-size:11px;">
        <span><span class="trigger">Yellow</span> = Trigger (user action)</span>
        <span><span class="condition">Italic amber</span> = Condition (must be true)</span>
        <span><span class="action">Green</span> = Chain reactions fired</span>
        <span><span class="coins">Gold</span> = Coins awarded</span>
        <span><span class="event-tag">event</span> = Emitted to Event Bus</span>
      </div>
    </div>
  </div>
</body>
</html>
