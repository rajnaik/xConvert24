---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="500 — Something Broke" description="An unexpected error occurred on xConvert24.com. We're working on it.">
  <div class="flex flex-col items-center justify-center text-center py-16 lg:py-24">
    <!-- Big 500 -->
    <div class="relative mb-6">
      <span class="text-[10rem] lg:text-[14rem] font-black text-gray-100 dark:text-gray-800 leading-none select-none">500</span>
      <span class="absolute inset-0 flex items-center justify-center text-6xl lg:text-7xl">💥</span>
    </div>

    <!-- Funny tagline -->
    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 dark:text-white mb-3">
      Our math went terribly wrong
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-md mb-2">
      We tried to divide by zero and this happened.
    </p>
    <p class="text-sm text-gray-400 dark:text-gray-500 italic mb-8">
      "Error 500: 1 server ÷ 0 patience = undefined chaos."
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-600 transition-colors shadow-sm">
        ← Back to Home
      </a>
      <button onclick="window.location.reload()" class="px-6 py-3 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-semibold hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors border border-gray-200 dark:border-gray-700">
        🔄 Try Again
      </button>
    </div>

    <!-- Debugging humor -->
    <div class="mt-12 p-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 max-w-sm text-left shadow-sm">
      <div class="text-xs font-semibold text-red-500 dark:text-red-400 uppercase tracking-wide mb-2">Incident Report</div>
      <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
        <li>☕ Coffee levels: <span class="font-mono text-red-500">critically low</span></li>
        <li>🔥 Server mood: <span class="font-mono text-red-500">spicy</span></li>
        <li>🛠️ Fix ETA: <span class="font-mono text-amber-500">soon™</span></li>
        <li>🐛 Bugs squashed: <span class="font-mono text-green-500">working on it</span></li>
      </ul>
    </div>
  </div>
</Layout>
