</Layout>

<script>
  // Fetch pipeline config from API and populate tooltips
  async function loadPipelineStats() {
    try {
      const res = await fetch('/api/cicd-pipeline');
      const data = await res.json();
      const xml = data.xml || '';

      // Parse XML
      const parser = new DOMParser();
      const doc = parser.parseFromString(xml, 'text/xml');
      const steps = Array.from(doc.querySelectorAll('step'));

      // All steps
      const enabledSteps = steps.filter(s => s.getAttribute('enabled') === 'true');
      document.getElementById('stat-steps')!.textContent = enabledSteps.length.toString();
      document.getElementById('tip-steps-list')!.innerHTML = enabledSteps.map(s =>
        `<div>• ${s.getAttribute('name')}</div>`
      ).join('');

      // Gates
      const gates = enabledSteps.filter(s => s.getAttribute('gate') === 'true');
      document.getElementById('stat-gates')!.textContent = gates.length.toString();
      document.getElementById('tip-gates-list')!.innerHTML = gates.map(s =>
        `<div>⛔ ${s.getAttribute('name')}</div>`
      ).join('');

      // Security (steps 5, 8 + any with "security" in name/tools)
      const securitySteps = enabledSteps.filter(s => {
        const name = (s.getAttribute('name') || '').toLowerCase();
        const tools = (s.querySelector('tools')?.textContent || '').toLowerCase();
        return name.includes('security') || name.includes('sast') || name.includes('checkmarx') || name.includes('aikido') || tools.includes('security') || tools.includes('sast');
      });
      document.getElementById('stat-security')!.textContent = securitySteps.length.toString();
      document.getElementById('tip-security-list')!.innerHTML = securitySteps.map(s =>
        `<div>🛡️ ${s.getAttribute('name')}</div>`
      ).join('');

      // Tools — collect unique tools from all enabled steps
      const allTools = new Set<string>();
      enabledSteps.forEach(s => {
        const tools = s.querySelector('tools')?.textContent || '';
        tools.split(',').forEach(t => { if (t.trim()) allTools.add(t.trim()); });
      });
      document.getElementById('stat-tools')!.textContent = allTools.size.toString();
      document.getElementById('tip-tools-list')!.innerHTML = Array.from(allTools).sort().map(t =>
        `<div>🔧 ${t}</div>`
      ).join('');
    } catch {
      // Fallback — keep static values
    }
  }

  // Tooltip hover behavior
  document.querySelectorAll('[data-stat]').forEach(tile => {
    const tooltip = tile.querySelector('.stat-tooltip') as HTMLElement;
    tile.addEventListener('mouseenter', () => tooltip?.classList.remove('hidden'));
    tile.addEventListener('mouseleave', () => tooltip?.classList.add('hidden'));
  });

  loadPipelineStats();
</script>
