---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { VERSION } from '../data/siteStats';
---

<Layout title="CI/CD Build Pipeline — xConvert24" description="Our 13-step continuous integration and deployment pipeline. From code to Golden certification with quality gates at every stage." keywords="CI/CD pipeline, build pipeline, deployment, quality gates, xconvert24 infrastructure">
