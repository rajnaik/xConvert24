---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Favourites" description="Your saved favourite converters and tools on xConvert24.com." keywords="favourites, saved converters, my tools, quick access">
  <div class="max-w-4xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">❤️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Favourites</h1>
        <span id="fav-page-count" class="ml-auto px-3 py-1 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-sm font-bold">0</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Your saved converters and tools. Click the ❤️ on any converter page to add it here.</p>
    </div>

    <div id="fav-list" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <div class="text-center py-12 text-gray-400 italic col-span-full">Loading…</div>
    </div>

    <div id="fav-empty" class="hidden text-center py-16">
      <div class="text-5xl mb-4">💔</div>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">No favourites yet</h2>
      <p class="text-gray-500 dark:text-gray-400 mb-4">Browse converters and click the ❤️ to save them here.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">
        Browse Converters
      </a>
    </div>
  </div>
</Layout>

<script>
  const FAV_KEY = 'xconvert24-favourites';
  const listEl = document.getElementById('fav-list')!;
  const emptyEl = document.getElementById('fav-empty')!;

  interface FavItem { name: string; href: string; category: string; addedAt: number; }

  function getFavs(): FavItem[] {
    try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
  }

  function saveFavs(favs: FavItem[]) {
    localStorage.setItem(FAV_KEY, JSON.stringify(favs));
  }

  function render() {
    const favs = getFavs();
    const pageCount = document.getElementById('fav-page-count');
    if (pageCount) pageCount.textContent = favs.length.toString();

    if (!favs.length) {
      listEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');

    listEl.innerHTML = favs.map(f => `
      <a href="${f.href}" class="relative bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm hover:border-red-300 dark:hover:border-red-700 hover:shadow-md transition-all group aspect-square flex flex-col items-center justify-center p-4 text-center overflow-hidden no-underline">
        <!-- Background heart -->
        <span class="absolute inset-0 flex items-center justify-center pointer-events-none select-none leading-none" style="font-size:140px;color:rgba(252,165,165,0.2);">❤️</span>
        <!-- Remove button -->
        <button data-remove="${f.href}" class="remove-fav-btn absolute top-2 right-2 z-10 w-7 h-7 rounded-full bg-red-500 text-white flex items-center justify-center hover:bg-red-600 transition-colors shadow-sm" aria-label="Remove from favourites" title="Unfavourite">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <!-- Content -->
        <div class="relative z-[1] flex flex-col items-center gap-2 w-full">
          <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors truncate w-full">${f.name}</div>
          ${f.category ? `<div class="text-xs text-gray-400 truncate w-full">${f.category}</div>` : ''}
        </div>
      </a>
    `).join('');

    listEl.querySelectorAll('.remove-fav-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const href = (btn as HTMLElement).dataset.remove!;
        const updated = getFavs().filter(f => f.href !== href);
        saveFavs(updated);
        render();
      });
    });
  }

  render();
</script>
