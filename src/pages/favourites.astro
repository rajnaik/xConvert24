---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Favourites" description="Your saved favourite converters and tools. Quick access to the xConvert24 tools you use most — stored locally, no sign-up." keywords="favourites, saved converters, my tools, quick access">
  <div class="max-w-4xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">❤️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Favourites</h1>
        <span id="fav-page-count" class="ml-auto px-3 py-1 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-sm font-bold">0</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Your saved converters and tools. Click the ❤️ on any converter page to add it here.</p>
      <!-- Publish & Hide buttons -->
      <div class="flex items-center gap-3 mt-3">
        <button id="publish-favs-btn" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green-500 hover:bg-green-600 text-white text-xs font-semibold transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          Publish Favourites
        </button>
        <button id="hide-favs-btn" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 text-xs font-semibold transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          Hide Mine
        </button>
        <span id="publish-status" class="text-xs text-green-600 dark:text-green-400 hidden"></span>
      </div>
    </div>

    <div id="fav-list" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <div class="text-center py-12 text-gray-400 italic col-span-full">Loading…</div>
    </div>

    <div id="fav-empty" class="hidden text-center py-16">
      <div class="text-5xl mb-4">💔</div>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">No favourites yet</h2>
      <p class="text-gray-500 dark:text-gray-400 mb-4">Browse converters and click the ❤️ to save them here.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">
        Browse Converters
      </a>
    </div>

    <!-- What Others Are Adding -->
    <div class="mt-8 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-2xl">👀</span>
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">What Others Are Adding</h2>
      </div>
      <div id="others-favs" class="space-y-2">
        <div class="text-center py-4 text-gray-400 dark:text-gray-500 text-xs italic">Loading...</div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const FAV_KEY = 'xconvert24-favourites';
  const listEl = document.getElementById('fav-list')!;
  const emptyEl = document.getElementById('fav-empty')!;

  interface FavItem { name: string; href: string; category: string; addedAt: number; }

  function getFavs(): FavItem[] {
    try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
  }

  function saveFavs(favs: FavItem[]) {
    localStorage.setItem(FAV_KEY, JSON.stringify(favs));
  }

  function render() {
    const favs = getFavs();
    const pageCount = document.getElementById('fav-page-count');
    if (pageCount) pageCount.textContent = favs.length.toString();

    if (!favs.length) {
      listEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');

    listEl.innerHTML = favs.map(f => `
      <a href="${f.href}" class="relative bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm hover:border-red-300 dark:hover:border-red-700 hover:shadow-md transition-all group aspect-square flex flex-col items-center justify-center p-4 text-center overflow-hidden no-underline">
        <!-- Background heart -->
        <span class="absolute inset-0 flex items-center justify-center pointer-events-none select-none leading-none" style="font-size:140px;color:rgba(252,165,165,0.2);">❤️</span>
        <!-- Remove button -->
        <button data-remove="${f.href}" class="remove-fav-btn absolute top-2 right-2 z-10 w-7 h-7 rounded-full bg-red-500 text-white flex items-center justify-center hover:bg-red-600 transition-colors shadow-sm" aria-label="Remove from favourites" title="Unfavourite">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <!-- Content -->
        <div class="relative z-[1] flex flex-col items-center gap-2 w-full">
          <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors truncate w-full">${f.name}</div>
          ${f.category ? `<div class="text-xs text-gray-400 truncate w-full">${f.category}</div>` : ''}
        </div>
      </a>
    `).join('');

    listEl.querySelectorAll('.remove-fav-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const href = (btn as HTMLElement).dataset.remove!;
        const updated = getFavs().filter(f => f.href !== href);
        saveFavs(updated);
        render();
      });
    });
  }

  render();

  // --- Publish & Hide functionality ---
  function getUid(): string {
    let uid = localStorage.getItem('xconvert24-uid');
    if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem('xconvert24-uid', uid); }
    return uid;
  }

  const COIN_PREFIX = 'xc-coin-';
  const today = new Date().toISOString().split('T')[0];

  // Check favourite_5 reward on every render
  function checkFavourite5Reward() {
    const favs = getFavs();
    if (favs.length >= 5 && !localStorage.getItem(COIN_PREFIX + 'favourite_5')) {
      localStorage.setItem(COIN_PREFIX + 'favourite_5', today);
      // Award coins
      const uid = getUid();
      fetch('/api/coins', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uid, activity: 'favourite_5' })
      }).catch(() => {});
      // Log reward
      const REWARDS_KEY = 'xconvert24-rewards-log';
      let rewards: any[] = [];
      try { rewards = JSON.parse(localStorage.getItem(REWARDS_KEY) || '[]'); } catch {}
      rewards.unshift({ activity: 'favourite_5', description: 'Added 5 items to favourites', coins: 10, date: new Date().toISOString() });
      localStorage.setItem(REWARDS_KEY, JSON.stringify(rewards.slice(0, 100)));
    }
  }
  checkFavourite5Reward();

  // Publish
  document.getElementById('publish-favs-btn')!.addEventListener('click', async () => {
    const favs = getFavs();
    if (!favs.length) { alert('Add some favourites first!'); return; }
    const uid = getUid();
    const statusEl = document.getElementById('publish-status')!;

    try {
      const res = await fetch('/api/favourites', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, items: favs.map(f => f.name), hidden: false })
      });
      // Show success even if API fails (local dev has no DB)
      const apiOk = res.ok;
      statusEl.textContent = apiOk ? '✅ Published!' : '✅ Published locally (DB unavailable)';
      statusEl.classList.remove('hidden');
      setTimeout(() => statusEl.classList.add('hidden'), 4000);

        // Award publish_favourites coins (once)
        if (!localStorage.getItem(COIN_PREFIX + 'publish_favourites')) {
          localStorage.setItem(COIN_PREFIX + 'publish_favourites', today);
          fetch('/api/coins', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid, activity: 'publish_favourites' })
          }).catch(() => {});
          // Emit event to event bus
          fetch('/api/events', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_type: 'favourites_published', payload: { user_id: uid, item_count: favs.length } })
          }).catch(() => {});
          // Log to analytics
          fetch('/api/analytics', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: uid, event: 'favourites_published', page: '/favourites', metadata: String(favs.length) })
          }).catch(() => {});
          const REWARDS_KEY = 'xconvert24-rewards-log';
          let rewards: any[] = [];
          try { rewards = JSON.parse(localStorage.getItem(REWARDS_KEY) || '[]'); } catch {}
          rewards.unshift({ activity: 'publish_favourites', description: 'Published your favourites', coins: 10, date: new Date().toISOString() });
          localStorage.setItem(REWARDS_KEY, JSON.stringify(rewards.slice(0, 100)));
        }
    } catch {
      statusEl.textContent = '❌ Failed to publish';
      statusEl.classList.remove('hidden');
    }
  });

  // Hide
  document.getElementById('hide-favs-btn')!.addEventListener('click', async () => {
    const uid = getUid();
    const statusEl = document.getElementById('publish-status')!;
    try {
      await fetch('/api/favourites', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, hidden: true })
      });
      statusEl.textContent = '🙈 Favourites hidden from public';
      statusEl.classList.remove('hidden');
      setTimeout(() => statusEl.classList.add('hidden'), 3000);
    } catch {}
  });

  // Load what others are adding
  async function loadOthersFavs() {
    const container = document.getElementById('others-favs')!;
    try {
      const res = await fetch('/api/favourites?limit=5');
      const data = await res.json();
      const published = data.published || [];

      if (!published.length) {
        container.innerHTML = '<div class="text-center py-4 text-gray-400 dark:text-gray-500 text-xs italic">No one has published yet. Be the first — click Publish above!</div>';
        return;
      }

      container.innerHTML = published.map((p: any) => {
        let items: string[] = [];
        try { items = JSON.parse(p.items); } catch { items = []; }
        let ago = '';
        if (p.created_at) {
          const diff = Date.now() - new Date(p.created_at).getTime();
          const mins = Math.floor(diff / 60000);
          if (mins < 1) ago = 'just now';
          else if (mins < 60) ago = mins + 'm ago';
          else if (mins < 1440) ago = Math.floor(mins / 60) + 'h ago';
          else ago = Math.floor(mins / 1440) + 'd ago';
        }
        // Train engine SVG (placed before the first carriage)
        const engineWidth = 52;
        const engine = `<div class="inline-flex items-center relative flex-shrink-0" style="width:${engineWidth}px;height:38px;">
          <svg viewBox="0 0 ${engineWidth} 38" width="${engineWidth}" height="38" xmlns="http://www.w3.org/2000/svg" class="absolute inset-0">
            <rect x="1" y="4" width="46" height="24" rx="4" fill="#1f2937" stroke="#111827" stroke-width="1"/>
            <rect x="38" y="8" width="12" height="12" rx="2" fill="#374151" stroke="#111827" stroke-width="0.5"/>
            <rect x="42" y="2" width="5" height="6" rx="1.5" fill="#6b7280"/>
            <rect x="4" y="8" width="20" height="10" rx="2" fill="#4b5563"/>
            <polygon points="1,28 4,22 10,22 7,28" fill="#f59e0b"/>
            <line x1="0" y1="30" x2="${engineWidth}" y2="30" stroke="#6b7280" stroke-width="1.5"/>
            <circle cx="12" cy="33" r="4" fill="#374151" stroke="#1f2937" stroke-width="1"/>
            <circle cx="28" cy="33" r="4" fill="#374151" stroke="#1f2937" stroke-width="1"/>
            <circle cx="42" cy="33" r="3.5" fill="#374151" stroke="#1f2937" stroke-width="1"/>
          </svg>
        </div>`;

        // Render each item as a train carriage whose width scales with text length
        const carriages = items.map((item: string) => {
          // Approx 7px per char + padding for the carriage width
          const charWidth = Math.max(item.length * 7 + 32, 60);
          return `<div class="inline-flex items-center relative" style="width:${charWidth}px;height:38px;">
            <svg viewBox="0 0 ${charWidth} 38" width="${charWidth}" height="38" xmlns="http://www.w3.org/2000/svg" class="absolute inset-0">
              <rect x="1" y="2" width="${charWidth - 2}" height="28" rx="4" fill="#d97706" stroke="#92400e" stroke-width="1"/>
              <rect x="4" y="5" width="${charWidth - 8}" height="18" rx="2" fill="#fef3c7" stroke="#d97706" stroke-width="0.5"/>
              <line x1="0" y1="30" x2="${charWidth}" y2="30" stroke="#6b7280" stroke-width="1.5"/>
              <circle cx="${charWidth * 0.25}" cy="33" r="4" fill="#374151" stroke="#1f2937" stroke-width="1"/>
              <circle cx="${charWidth * 0.75}" cy="33" r="4" fill="#374151" stroke="#1f2937" stroke-width="1"/>
            </svg>
            <span class="relative z-10 w-full text-center text-[10px] font-semibold text-gray-800 truncate px-2" style="line-height:28px;">${item}</span>
          </div>`;
        }).join('');
        return `<div class="p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <div class="flex flex-wrap items-end gap-1 overflow-x-auto">${engine}${carriages}</div>
          <div class="text-[10px] text-gray-400 mt-1.5">${p.item_count} favourites · ${ago}</div>
        </div>`;
      }).join('');
    } catch {
      container.innerHTML = '<div class="text-center py-4 text-gray-400 text-xs">Could not load.</div>';
    }
  }
  loadOthersFavs();
</script>
