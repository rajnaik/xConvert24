---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Favourites" description="Your saved favourite converters and tools on xConvert24.com." keywords="favourites, saved converters, my tools, quick access">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">❤️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Favourites</h1>
        <span id="fav-page-count" class="ml-auto px-3 py-1 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-sm font-bold">0</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Your saved converters and tools for quick access. Click the ❤️ on any converter page to add it here.</p>
    </div>

    <div id="fav-list" class="space-y-2">
      <div class="text-center py-12 text-gray-400 italic">Loading…</div>
    </div>

    <div id="fav-empty" class="hidden text-center py-16">
      <div class="text-5xl mb-4">💔</div>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">No favourites yet</h2>
      <p class="text-gray-500 dark:text-gray-400 mb-4">Browse converters and click the ❤️ button to save them here.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">
        Browse Converters
      </a>
    </div>
  </div>
</Layout>

<script>
  const FAV_KEY = 'xconvert24-favourites';
  const listEl = document.getElementById('fav-list')!;
  const emptyEl = document.getElementById('fav-empty')!;

  interface FavItem { name: string; href: string; category: string; addedAt: number; }

  function getFavs(): FavItem[] {
    try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
  }

  function saveFavs(favs: FavItem[]) {
    localStorage.setItem(FAV_KEY, JSON.stringify(favs));
  }

  function render() {
    const favs = getFavs();
    const pageCount = document.getElementById('fav-page-count');
    if (pageCount) pageCount.textContent = favs.length.toString();

    if (!favs.length) {
      listEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');

    listEl.innerHTML = favs.map(f => `
      <div class="flex items-center gap-3 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 shadow-sm hover:border-red-300 dark:hover:border-red-700 transition-colors group">
        <a href="${f.href}" class="flex-1 min-w-0 flex items-center gap-3">
          <span class="text-red-500 text-lg">❤️</span>
          <div class="min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400 truncate transition-colors">${f.name}</div>
            ${f.category ? `<div class="text-xs text-gray-400">${f.category}</div>` : ''}
          </div>
        </a>
        <button data-remove="${f.href}" class="shrink-0 px-3 py-1.5 text-xs font-medium text-red-500 border border-red-200 dark:border-red-800 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="Remove from favourites">
          Unfavourite
        </button>
      </div>
    `).join('');

    listEl.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        const href = (btn as HTMLElement).dataset.remove!;
        const updated = getFavs().filter(f => f.href !== href);
        saveFavs(updated);
        render();
      });
    });
  }

  render();
</script>
