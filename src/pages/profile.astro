---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Profile — ConvertCoins" description="Track your ConvertCoins, streak, level, and activity on xConvert24.com." keywords="profile, convertcoins, rewards, streak, gamification">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">🪙</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Profile</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Your ConvertCoins balance, streak, and activity.</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-amber-500" id="p-coins">0</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">🪙 Coins</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-orange-500" id="p-streak">0</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">🔥 Day Streak</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-purple-500" id="p-level">1</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">⭐ Level</p>
      </div>
    </div>

    <!-- How to earn -->
    <!-- How to earn -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">How to Earn ConvertCoins</h2>
      <div id="milestones-list" class="space-y-2">
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="first_conversion">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">📐 First conversion of the day</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+5 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="multi_converter">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">🔄 Use 3 different converters in one session</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+10 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="streak_7">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">🔥 7-day visit streak</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+50 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="streak_30">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">🔥 30-day visit streak</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+200 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="home_screen">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">📱 Add to Home Screen</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+100 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="report_bug">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">🐛 Report a bug (validated)</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+25 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="suggest_feature">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">💡 Suggest a feature (rated 4+ stars)</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+30 🪙</span>
        </div>
        <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded-lg" data-milestone="blog_read">
          <div class="flex items-center gap-2">
            <span class="milestone-check text-gray-300 dark:text-gray-600 text-sm">○</span>
            <span class="text-xs text-gray-600 dark:text-gray-400">📖 Read a blog post</span>
          </div>
          <span class="text-xs font-bold text-amber-600">+5 🪙</span>
        </div>
      </div>
      <!-- Total wallet balance -->
      <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">💰 Your Wallet</span>
        <span class="text-lg font-bold text-amber-500" id="p-wallet-total">0 🪙</span>
      </div>
    </div>

    <!-- Level progression -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Level Progression</h2>
      <div class="mb-4">
        <div class="flex justify-between text-xs text-gray-500 mb-1">
          <span>Level <span id="p-current-level">1</span></span>
          <span id="p-progress-text">0 / 500 coins to next level</span>
        </div>
        <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
          <div id="p-progress-bar" class="h-full bg-gradient-to-r from-amber-400 to-amber-600 rounded-full transition-all" style="width: 0%"></div>
        </div>
      </div>

      <!-- Level carousel -->
      <div class="relative">
        <button id="level-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -ml-2 w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-amber-50 dark:hover:bg-amber-900/20 hover:border-amber-400 transition-colors z-10">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="level-next" class="absolute right-0 top-1/2 -translate-y-1/2 -mr-2 w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-amber-50 dark:hover:bg-amber-900/20 hover:border-amber-400 transition-colors z-10">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>

        <div id="level-card" class="mx-8 p-5 rounded-xl border-2 text-center transition-all duration-300">
          <!-- Populated by JS -->
        </div>
      </div>

      <div class="flex justify-center gap-1.5 mt-3" id="level-dots">
        <!-- Dots populated by JS -->
      </div>
    </div>

    <!-- Link to full rewards info -->
    <div class="bg-amber-50 dark:bg-amber-900/10 rounded-xl border border-amber-200 dark:border-amber-800 p-4 mt-6">
      <p class="text-sm text-amber-800 dark:text-amber-200">
        <strong>🪙 Want the full details?</strong> See the <a href="/rewards" class="underline font-semibold hover:text-amber-600">ConvertCoins Rewards Guide</a> — learn all activities, level system, and how to keep your coins safe.
      </p>
    </div>

    <!-- Future Features -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mt-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-2xl">🚀</span>
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">What You'll Be Able to Do with ConvertCoins</h2>
      </div>
      <div class="space-y-3">
        <div class="flex items-start gap-3 p-3 bg-purple-50 dark:bg-purple-900/10 rounded-lg border border-purple-100 dark:border-purple-800">
          <span class="text-base">🎨</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Custom Themes</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Unlock premium colour themes and UI customisations for your profile</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-blue-50 dark:bg-blue-900/10 rounded-lg border border-blue-100 dark:border-blue-800">
          <span class="text-base">📊</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Conversion History Dashboard</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Access a personal dashboard showing your conversion history and most-used tools</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-green-50 dark:bg-green-900/10 rounded-lg border border-green-100 dark:border-green-800">
          <span class="text-base">🏆</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Leaderboard & Badges</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Compete with other users, earn achievement badges, and appear on the community leaderboard</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-amber-50 dark:bg-amber-900/10 rounded-lg border border-amber-100 dark:border-amber-800">
          <span class="text-base">⭐</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Priority Feature Voting</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Spend coins to boost your favourite feature suggestion and make it happen faster</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-cyan-50 dark:bg-cyan-900/10 rounded-lg border border-cyan-100 dark:border-cyan-800">
          <span class="text-base">🔗</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Shareable Profiles</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Share your converter profile, level, and badges with a public link</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-pink-50 dark:bg-pink-900/10 rounded-lg border border-pink-100 dark:border-pink-800">
          <span class="text-base">🎁</span>
          <div>
            <p class="text-xs font-semibold text-gray-900 dark:text-white">Coin Redemption</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Redeem coins for ad-free experiences, exclusive tools, or donate to charity</p>
          </div>
        </div>
      </div>
      <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
        <p class="text-xs text-gray-600 dark:text-gray-400">
          💡 <strong>Have an idea?</strong> Tell us how you'd like to use your ConvertCoins — <a href="/suggest" class="text-amber-600 dark:text-amber-400 hover:underline font-medium">suggest a feature →</a>
        </p>
      </div>
    </div>

    <!-- Your Opinion link -->
    <div class="bg-purple-50 dark:bg-purple-900/10 rounded-xl border border-purple-200 dark:border-purple-800 p-4 mt-4">
      <p class="text-sm text-purple-800 dark:text-purple-200">
        <strong>💬 We want to hear from you!</strong> Should xConvert24 add email sign-on? <a href="/opinion" class="underline font-semibold hover:text-purple-600">Share your opinion →</a>
      </p>
    </div>

    <!-- Reward Summary -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mt-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-2xl">📊</span>
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Reward Summary</h2>
      </div>
      <div id="reward-summary" class="space-y-2">
        <div class="text-center py-8 text-gray-400 dark:text-gray-500 text-sm italic">Loading rewards...</div>
      </div>
      <div id="reward-empty" class="hidden text-center py-8">
        <div class="text-3xl mb-2">🎯</div>
        <p class="text-sm text-gray-500 dark:text-gray-400">No rewards yet. Start converting to earn ConvertCoins!</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  function getUid(): string {
    let uid = localStorage.getItem('xconvert24-uid');
    if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem('xconvert24-uid', uid); }
    return uid;
  }

  async function loadProfile() {
    const uid = getUid();
    try {
      const res = await fetch(`/api/coins?uid=${uid}`);
      if (!res.ok) return;
      const data = await res.json();

      document.getElementById('p-coins')!.textContent = (data.coins || 0).toString();
      document.getElementById('p-streak')!.textContent = (data.streak || 0).toString();
      document.getElementById('p-level')!.textContent = (data.level || 1).toString();
      document.getElementById('p-current-level')!.textContent = (data.level || 1).toString();

      const totalEarned = data.total_earned || 0;
      const levelCoins = totalEarned % 500;
      const progressPct = Math.min(100, (levelCoins / 500) * 100);
      document.getElementById('p-progress-bar')!.style.width = progressPct + '%';
      document.getElementById('p-progress-text')!.textContent = `${levelCoins} / 500 coins to next level`;
    } catch {}
  }

  function loadRewardSummary() {
    const REWARDS_KEY = 'xconvert24-rewards-log';
    const container = document.getElementById('reward-summary')!;
    const emptyEl = document.getElementById('reward-empty')!;

    let rewards: Array<{ activity: string; description: string; coins: number; date: string }> = [];
    try {
      rewards = JSON.parse(localStorage.getItem(REWARDS_KEY) || '[]');
    } catch {
      rewards = [];
    }

    if (rewards.length === 0) {
      container.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      return;
    }

    const activityIcons: Record<string, string> = {
      first_conversion: '📐',
      daily_visit: '📅',
      multi_converter: '🔄',
      blog_read: '📖',
      bookmark_page: '🔖',
      report_bug: '🐛',
      vote_bug: '🗳️',
      suggest_feature: '💡',
      vote_suggestion: '⭐',
      crypto_watchlist: '💰',
      add_favourite: '❤️',
      crypto_use: '📈',
      cooking_convert: '🍳',
      finance_use: '💵',
      fashion_convert: '👗',
      streak_7: '🔥',
      streak_30: '🏆',
    };

    const html = rewards.slice(0, 50).map((r) => {
      const icon = activityIcons[r.activity] || '🪙';
      const date = new Date(r.date);
      const timeAgo = formatTimeAgo(date);
      return `
        <div class="flex items-center justify-between p-2.5 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-base shrink-0">${icon}</span>
            <div class="min-w-0">
              <div class="text-xs font-medium text-gray-700 dark:text-gray-300 truncate">${escapeHtml(r.description)}</div>
              <div class="text-[10px] text-gray-400 dark:text-gray-500">${timeAgo}</div>
            </div>
          </div>
          <span class="text-xs font-bold text-amber-600 dark:text-amber-400 shrink-0 ml-2">+${r.coins} 🪙</span>
        </div>
      `;
    }).join('');

    container.innerHTML = html;
  }

  function formatTimeAgo(date: Date): string {
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'Just now';
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}d ago`;
    return date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function loadMilestones() {
    const COIN_PREFIX = 'xc-coin-';
    const today = new Date().toISOString().split('T')[0];

    // Map milestone IDs to their localStorage keys
    const milestoneKeys: Record<string, string> = {
      'first_conversion': COIN_PREFIX + 'first_conversion',
      'multi_converter': COIN_PREFIX + 'multi_converter',
      'streak_7': COIN_PREFIX + 'streak_7',
      'streak_30': COIN_PREFIX + 'streak_30',
      'home_screen': COIN_PREFIX + 'home_screen',
      'report_bug': COIN_PREFIX + 'report_bug',
      'suggest_feature': COIN_PREFIX + 'suggest_feature',
      'blog_read': COIN_PREFIX + 'blog_read_/blog/',
    };

    // Coin values for each milestone
    const coinValues: Record<string, number> = {
      'first_conversion': 5,
      'multi_converter': 10,
      'streak_7': 50,
      'streak_30': 200,
      'home_screen': 100,
      'report_bug': 25,
      'suggest_feature': 30,
      'blog_read': 5,
    };

    let totalEarned = 0;

    document.querySelectorAll('[data-milestone]').forEach((row) => {
      const id = row.getAttribute('data-milestone')!;
      const key = milestoneKeys[id];
      const checkEl = row.querySelector('.milestone-check') as HTMLElement;

      // Check if milestone was achieved (any date stored means achieved at least once)
      let achieved = false;
      if (id === 'blog_read') {
        // Blog read: check if ANY blog key exists
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (k && k.startsWith(COIN_PREFIX + 'blog_read_')) { achieved = true; break; }
        }
      } else if (key && localStorage.getItem(key)) {
        achieved = true;
      }

      if (achieved) {
        checkEl.textContent = '✅';
        checkEl.classList.remove('text-gray-300', 'dark:text-gray-600');
        row.classList.add('border', 'border-green-200', 'dark:border-green-800');
        (row as HTMLElement).style.background = '';
        totalEarned += coinValues[id] || 0;
      }
    });

    // Update wallet total from the server-fetched value (more accurate)
    const walletEl = document.getElementById('p-wallet-total')!;
    const coinsEl = document.getElementById('p-coins');
    if (coinsEl) {
      // Use the value from loadProfile which fetches from server
      const observer = new MutationObserver(() => {
        walletEl.textContent = coinsEl.textContent + ' 🪙';
      });
      observer.observe(coinsEl, { childList: true, characterData: true, subtree: true });
      // Set initial value
      walletEl.textContent = coinsEl.textContent + ' 🪙';
    }
  }

  // Level Carousel — metal-themed levels
  const levels = [
    { level: 1, name: 'Bronze', icon: '🥉', color: '#cd7f32', border: '#92400e', bg: 'bg-orange-50 dark:bg-orange-900/10', coins: 0, details: 'Starting level. Welcome to xConvert24!' },
    { level: 2, name: 'Silver', icon: '🥈', color: '#c0c0c0', border: '#6b7280', bg: 'bg-gray-50 dark:bg-gray-800', coins: 500, details: 'Regular user. You\'ve built a habit.' },
    { level: 3, name: 'Gold', icon: '🥇', color: '#ffd700', border: '#d97706', bg: 'bg-amber-50 dark:bg-amber-900/10', coins: 1000, details: 'Power converter. Consistent daily usage.' },
    { level: 4, name: 'Platinum', icon: '💎', color: '#e5e4e2', border: '#9ca3af', bg: 'bg-slate-50 dark:bg-slate-800', coins: 2500, details: 'Expert level. Multi-tool master.' },
    { level: 5, name: 'Diamond', icon: '💠', color: '#b9f2ff', border: '#06b6d4', bg: 'bg-cyan-50 dark:bg-cyan-900/10', coins: 5000, details: 'Elite contributor. Community champion.' },
    { level: 6, name: 'Emerald', icon: '🟢', color: '#50c878', border: '#059669', bg: 'bg-emerald-50 dark:bg-emerald-900/10', coins: 10000, details: 'Legendary status. Top 1% of all users.' },
    { level: 7, name: 'Obsidian', icon: '⬛', color: '#1a1a2e', border: '#4c1d95', bg: 'bg-purple-50 dark:bg-purple-900/10', coins: 25000, details: 'Mythic tier. Master of all conversions.' },
  ];

  let currentLevelIdx = 0;

  function renderLevelCard() {
    const l = levels[currentLevelIdx];
    const card = document.getElementById('level-card')!;
    const userLevel = parseInt(document.getElementById('p-current-level')?.textContent || '1');
    const isCurrentLevel = l.level === userLevel;
    const isAchieved = l.level <= userLevel;

    card.style.borderColor = l.border;
    card.innerHTML = `
      <div style="font-size:40px;margin-bottom:8px;">${l.icon}</div>
      <div style="font-size:18px;font-weight:700;color:${l.color};">${l.name}</div>
      <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">Level ${l.level}</div>
      <div class="text-xs text-gray-600 dark:text-gray-300 mt-2">${l.details}</div>
      <div class="mt-3 text-xs font-mono ${isAchieved ? 'text-green-600 dark:text-green-400' : 'text-gray-400'}">
        ${l.coins === 0 ? 'Starting level' : `Requires ${l.coins.toLocaleString()} coins`}
      </div>
      ${isCurrentLevel ? '<div class="mt-2 text-[10px] font-bold text-amber-600 bg-amber-100 dark:bg-amber-900/20 rounded-full px-3 py-1 inline-block">← YOU ARE HERE</div>' : ''}
      ${isAchieved && !isCurrentLevel ? '<div class="mt-2 text-[10px] font-bold text-green-600">✅ Achieved</div>' : ''}
    `;

    // Update dots
    const dotsEl = document.getElementById('level-dots')!;
    dotsEl.innerHTML = levels.map((_, i) =>
      `<div class="w-2 h-2 rounded-full ${i === currentLevelIdx ? 'bg-amber-500' : 'bg-gray-300 dark:bg-gray-600'}"></div>`
    ).join('');
  }

  document.getElementById('level-prev')!.addEventListener('click', () => {
    currentLevelIdx = Math.max(0, currentLevelIdx - 1);
    renderLevelCard();
  });
  document.getElementById('level-next')!.addEventListener('click', () => {
    currentLevelIdx = Math.min(levels.length - 1, currentLevelIdx + 1);
    renderLevelCard();
  });

  // Start at user's current level
  function initLevelCarousel() {
    const userLevel = parseInt(document.getElementById('p-current-level')?.textContent || '1');
    currentLevelIdx = Math.min(userLevel - 1, levels.length - 1);
    renderLevelCard();
  }

  // Call after profile loads (observe the level element)
  const levelObserver = new MutationObserver(() => { initLevelCarousel(); });
  const levelEl = document.getElementById('p-current-level');
  if (levelEl) levelObserver.observe(levelEl, { childList: true, characterData: true, subtree: true });
  initLevelCarousel();

  loadProfile();
  loadRewardSummary();
  loadMilestones();
</script>
