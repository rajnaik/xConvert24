---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { STATS } from '../data/siteStats';

const faqs = [
  {
    q: 'Is xConvert24.com free to use?',
    a: 'Yes, completely free. All converters and tools are available without sign-up, ads in your face, or hidden fees.',
  },
  {
    q: 'How accurate are the conversions?',
    a: 'We use industry-standard conversion factors sourced from NIST and ISO standards. Results are displayed to 7 significant figures. For critical applications (medical, engineering, financial), always verify with professional instruments or certified software.',
  },
  {
    q: 'Are the currency exchange rates live?',
    a: 'No. Our currency converter uses static reference rates for estimation purposes. For live trading rates, please use a licensed financial service like your bank or a forex platform.',
  },
  {
    q: 'Do I need to create an account?',
    a: 'No account is needed. All tools work instantly in your browser. Your preferences (dark mode, bookmarks) are stored locally in your browser.',
  },
  {
    q: 'Does the site work offline?',
    a: 'Since all conversions are calculated in your browser (no server calls), most pages will work if you\'ve visited them before and your browser cached them. However, an internet connection is needed for the initial load.',
  },
  {
    q: 'What units are supported?',
    a: `We support ${STATS.unitsIndexed}+ units across ${STATS.categories} categories including weight, length, temperature, area, volume, speed, data storage, energy, pressure, power, fuel economy, angle, frequency, time, cooking, currency (${STATS.currencies} currencies), number bases, Roman numerals, and more.`,
  },
  {
    q: 'How do I convert between two specific units?',
    a: 'Go to the relevant converter page (e.g. Weight), select the "From" unit in the first dropdown, enter your value, and select the "To" unit in the second dropdown. The result updates instantly.',
  },
  {
    q: 'Can I swap the "from" and "to" units?',
    a: 'Yes! Every converter has a "Swap" button between the two unit selectors. Click it to reverse the conversion direction instantly.',
  },
  {
    q: 'What\'s the difference between SI and binary data units?',
    a: 'SI units (KB, MB, GB) use powers of 1000 (1 KB = 1,000 bytes). Binary units (KiB, MiB, GiB) use powers of 1024 (1 KiB = 1,024 bytes). Our Data Storage converter supports both systems.',
  },
  {
    q: 'How does the BMI Calculator work?',
    a: 'Enter your height and weight (in metric or imperial units). BMI is calculated as weight(kg) ÷ height(m)². Results show your BMI value, WHO category, a visual scale, and your healthy weight range.',
  },
  {
    q: 'Is the Scientific Calculator a full replacement for a physical calculator?',
    a: 'It covers basic arithmetic, trigonometric functions (sin, cos, tan with inverse), logarithms (log, ln), powers, square root, factorial, and constants (π, e). It supports both DEG and RAD modes. For advanced features like graphing or symbolic math, a dedicated app may be better suited.',
  },
  {
    q: 'How does the Loan Calculator work?',
    a: 'Enter the loan amount, annual interest rate, and term (months or years). It calculates your monthly payment, total interest paid, total amount, and shows an amortization schedule for the first 24 months.',
  },
  {
    q: 'What is dark mode and how do I enable it?',
    a: 'Dark mode switches the site to a dark background with light text, reducing eye strain in low-light environments. Click the moon/sun icon in the top-right header to toggle. Your preference is saved automatically.',
  },
  {
    q: 'How do I bookmark a converter?',
    a: 'Click the bookmark icon (🔖) in the header on any page. Bookmarked pages are saved in your browser\'s local storage. You can remove a bookmark by clicking the icon again.',
  },
  {
    q: 'Can I use this site on my phone?',
    a: 'Yes! xConvert24 is fully responsive and works on all screen sizes. On mobile, tap the hamburger menu (☰) to open the navigation sidebar. You can also add the site to your home screen for app-like access.',
  },
  {
    q: 'How do I report a bug or suggest a feature?',
    a: 'Click the bug icon (🐛) in the header or visit the Report Bug page. Select the affected converter, choose a severity level, describe the issue, and submit. You can also vote on existing bugs to help us prioritise fixes.',
  },
  {
    q: 'Does xConvert24 track me?',
    a: 'We use Google Analytics to understand which converters are popular and to improve the site. You can control this via the cookie consent banner. We do not collect personal information, and all conversion inputs stay in your browser — nothing is sent to our servers.',
  },
  {
    q: 'Can I use xConvert24 for commercial purposes?',
    a: 'Yes, you can use our tools for personal, educational, or professional work. However, for critical commercial applications (financial trading, engineering safety, medical dosing), always verify results with authoritative professional tools.',
  },
  {
    q: 'What browsers are supported?',
    a: 'xConvert24 works in all modern browsers: Chrome, Firefox, Safari, Edge (latest versions). We use modern CSS and JavaScript features that require relatively recent browser versions.',
  },
  {
    q: 'How often is the site updated?',
    a: 'We ship improvements regularly. Check the <a href="/releases" class="text-amber-600 dark:text-amber-400 hover:underline">Release Notes</a> page for a full changelog of features and bug fixes.',
  },
  {
    q: 'Do you accept any donations?',
    a: `Yes we do! You can donate crypto to us. We accept Solana (SOL).
      <span class="flex items-center gap-2 mt-2 p-2 bg-gray-50 dark:bg-gray-800 rounded-lg">
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 128 128" fill="none"><path d="M25.6 95.5l16.3-17.1c.6-.6 1.4-1 2.3-1h78.2c1.4 0 2.2 1.7 1.2 2.8l-16.3 17.1c-.6.6-1.4 1-2.3 1H26.8c-1.4 0-2.2-1.7-1.2-2.8z" fill="url(#faq-sol1)"/><path d="M25.6 30.2l16.3-17.1c.6-.6 1.4-1 2.3-1h78.2c1.4 0 2.2 1.7 1.2 2.8L107.3 32c-.6.6-1.4 1-2.3 1H26.8c-1.4 0-2.2-1.7-1.2-2.8z" fill="url(#faq-sol2)"/><path d="M107.3 62.5l-16.3-17.1c-.6-.6-1.4-1-2.3-1H10.5c-1.4 0-2.2 1.7-1.2 2.8l16.3 17.1c.6.6 1.4 1 2.3 1h78.2c1.4 0 2.2-1.7 1.2-2.8z" fill="url(#faq-sol3)"/><defs><linearGradient id="faq-sol1" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient><linearGradient id="faq-sol2" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient><linearGradient id="faq-sol3" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient></defs></svg>
        <code id="faq-sol-address" class="flex-1 text-xs font-mono text-gray-900 dark:text-white break-all select-all">Loading...</code>
        <button id="faq-copy-sol" class="shrink-0 px-2 py-1 bg-purple-500 hover:bg-purple-600 text-white text-[10px] font-semibold rounded transition-colors">Copy</button>
      </span>`,
  },
];
---

<Layout title="Frequently Asked Questions" description="Answers to common questions about xConvert24. Learn about accuracy, privacy, supported units, and how to use our free tools." keywords="FAQ, frequently asked questions, help, conversion questions, how to convert, xConvert24 FAQ">
  <div class="max-w-3xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">❓</span>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Frequently Asked Questions</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Answers to common questions about xConvert24.com</p>
    </div>

    <!-- FAQ Schema (JSON-LD for SEO rich results) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />

    <!-- FAQ accordion -->
    <div class="space-y-3" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
          <button
            class="faq-toggle w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-semibold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
          >
            <span>{faq.q}</span>
            <svg class="faq-chevron w-4 h-4 shrink-0 text-gray-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id={`faq-answer-${i}`} class="faq-answer hidden px-5 pb-4">
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed" set:html={faq.a}></p>
          </div>
        </div>
      ))}
    </div>

    <!-- Still have questions -->
    <div class="mt-8 bg-amber-50 dark:bg-amber-900/20 rounded-xl border border-amber-200 dark:border-amber-800 p-6 text-center">
      <p class="text-sm text-amber-700 dark:text-amber-400 font-medium mb-2">Still have questions?</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">
        Contact Us
      </a>
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        answer.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        chevron.classList.remove('rotate-180');
      } else {
        answer.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        chevron.classList.add('rotate-180');
      }
    });
  });

  // Load wallet address for donation FAQ
  fetch('/api/wallet')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('faq-sol-address');
      if (el && data.address) el.textContent = data.address;
      else if (el) el.textContent = '(Wallet not configured yet)';
    })
    .catch(() => {
      const el = document.getElementById('faq-sol-address');
      if (el) el.textContent = '(Unable to load — visit /support)';
    });

  document.getElementById('faq-copy-sol')?.addEventListener('click', () => {
    const addr = document.getElementById('faq-sol-address')!.textContent || '';
    if (addr.startsWith('(')) return;
    navigator.clipboard.writeText(addr).then(() => {
      const btn = document.getElementById('faq-copy-sol')!;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
