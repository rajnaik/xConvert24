---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';

const widgets = [
  { name: 'Weight Converter', slug: 'weight', type: 'weight', from: 'kg', to: 'lb', icon: '⚖️' },
  { name: 'Length Converter', slug: 'length', type: 'length', from: 'km', to: 'mi', icon: '📏' },
  { name: 'Temperature Converter', slug: 'temperature', type: 'temperature', from: 'c', to: 'f', icon: '🌡️' },
  { name: 'Volume Converter', slug: 'volume', type: 'volume', from: 'l', to: 'gal_us', icon: '🧪' },
  { name: 'Speed Converter', slug: 'speed', type: 'speed', from: 'kmh', to: 'mph', icon: '🚀' },
  { name: 'Data Storage', slug: 'data', type: 'data', from: 'GB', to: 'MB', icon: '💾' },
];
---

<Layout title="Widget Library — Embed Converters on Your Site" description="Browse and embed free xConvert24 converter widgets. Weight, length, temperature, volume, speed and data storage widgets available." keywords="converter widget, embed widget, free widget, embeddable converter, website widget, unit converter widget">
  <div class="max-w-4xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">⚙️</span>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Widget Library</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Embeddable converter widgets for your website. Pick one, customise, and copy the code.</p>
      <a href="/embed" class="inline-flex items-center gap-1.5 mt-2 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
        📋 See full embed documentation →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {widgets.map(w => (
        <a href={`/widgets/${w.slug}`} class="group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 shadow-sm hover:border-amber-400 dark:hover:border-amber-500 hover:shadow-md transition-all">
          <div class="text-3xl mb-3">{w.icon}</div>
          <h2 class="font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors mb-1">{w.name}</h2>
          <p class="text-xs text-gray-500 dark:text-gray-400">Default: {w.from.toUpperCase()} → {w.to.toUpperCase()}</p>
          <div class="mt-3 text-xs text-amber-600 dark:text-amber-400 font-medium">View & copy code →</div>
        </a>
      ))}
    </div>
  </div>
</Layout>
