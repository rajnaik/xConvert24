---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Speed Converter Widget" description="Embed a free speed converter widget on your website. Converts km/h, mph, knots, m/s and more." keywords="speed converter widget, embed speed converter, kmh to mph widget">
  <div class="max-w-2xl">
    <nav class="text-sm text-gray-400 mb-4"><a href="/widgets" class="hover:text-amber-600">Widgets</a> › <span class="text-gray-600 dark:text-gray-300">Speed</span></nav>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">🚀 Speed Converter Widget</h1>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Preview</h2>
      <div id="xconvert24-widget" data-type="speed" data-from="kmh" data-to="mph"></div>
      <script src="/embed/widget.js" is:inline></script>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Embed Code</h2>
      <div class="bg-gray-950 rounded-lg p-4 overflow-x-auto">
        <pre class="text-sm text-green-400 font-mono whitespace-pre-wrap">&lt;div id="xconvert24-widget" data-type="speed" data-from="kmh" data-to="mph"&gt;&lt;/div&gt;
&lt;script src="https://www.xconvert24.com/embed/widget.js"&gt;&lt;/script&gt;</pre>
      </div>
    </div>
  </div>
</Layout>
