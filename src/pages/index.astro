---

<Layout title="Free Online Converters & Calculators" description="Free Online Unit Converter & Calculators. Get 100% accurate results for 34+ tools including weight, length, & loans. No sign-up or ads. Start converting now!" keywords="unit converter, online calculator, convert units, weight converter, length converter, temperature converter, currency converter, free converter, metric conversion, imperial conversion, crypto solana donation, bmi calculator, loan calculator, image converter">
  <!-- Hero -->
  <div class="mb-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-sm font-medium mb-4">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Fast, Free and No Signups
    </div>
    <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white tracking-tight mb-3">
      All your conversions, one place.
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl">
      {STATS.converters} Converters and {STATS.tools} Utilities. No sign-up required — just accurate results instantly.
    </p>
  </div>

  <!-- 70/30 layout: converters + install panel -->
  <div class="flex gap-6 items-start">
    <!-- Left: Category grid (70%) -->
    <div class="flex-1 min-w-0">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="group flex items-start gap-4 p-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-500 hover:shadow-md transition-all duration-200"
          >
            <div class={`flex-shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br ${cat.color} flex items-center justify-center text-2xl shadow-sm`}>
              {cat.icon}
            </div>
            <div class="min-w-0">
              <div class="font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
                {cat.title}
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 truncate">
                {cat.desc}
              </div>
            </div>
            <svg class="ml-auto flex-shrink-0 w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-amber-500 transition-colors mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: Add to Home Screen CTA (30%) — hidden if standalone or dismissed -->
    <div id="install-panel" class="hidden w-72 shrink-0 sticky top-20 lg:block opacity-0 translate-x-8 transition-all duration-700 ease-out">
      <a href="/install" class="block bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-amber-400 dark:hover:border-amber-500 transition-all hover:shadow-md no-underline">
        <!-- Large phone illustration with instructions ON the screen -->
        <div class="bg-gradient-to-b from-gray-900 to-gray-800 p-5 flex justify-center">
          <div class="relative w-44 h-72 bg-black rounded-[28px] border-[4px] border-gray-600 shadow-2xl overflow-hidden">
            <!-- Notch -->
            <div class="absolute top-1 left-1/2 -translate-x-1/2 w-16 h-2 bg-gray-800 rounded-full z-10"></div>
            <!-- Screen content -->
            <div class="absolute inset-2 bg-gradient-to-b from-blue-50 to-white rounded-[20px] flex flex-col items-center pt-6 px-3 pb-3">
              <!-- Step 1 -->
              <div class="flex items-center gap-2 mb-3 w-full">
                <div class="w-5 h-5 rounded-full bg-amber-500 text-white flex items-center justify-center text-[9px] font-bold shrink-0">1</div>
                <p class="text-[9px] text-gray-700 leading-tight">Open in <strong>Safari</strong> or <strong>Chrome</strong></p>
              </div>
              <!-- Step 2 with share icon -->
              <div class="flex items-center gap-2 mb-3 w-full">
                <div class="w-5 h-5 rounded-full bg-amber-500 text-white flex items-center justify-center text-[9px] font-bold shrink-0">2</div>
                <div class="flex items-center gap-1">
                  <p class="text-[9px] text-gray-700 leading-tight">Tap</p>
                  <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                  <p class="text-[9px] text-gray-700 leading-tight"><strong>Share</strong></p>
                </div>
              </div>
              <!-- Step 3 -->
              <div class="flex items-center gap-2 mb-4 w-full">
                <div class="w-5 h-5 rounded-full bg-amber-500 text-white flex items-center justify-center text-[9px] font-bold shrink-0">3</div>
                <div class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                  <p class="text-[9px] text-gray-700 leading-tight"><strong>Add to Home Screen</strong></p>
                </div>
              </div>
              <!-- App icon result -->
              <div class="flex flex-col items-center mt-auto mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-md border border-amber-500 mb-1">
                  <span class="text-white text-[8px] font-bold">x24</span>
                </div>
                <p class="text-[8px] text-gray-600 font-semibold">xConvert24</p>
                <div class="text-amber-500 animate-bounce mt-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                </div>
              </div>
            </div>
            <!-- Home bar -->
            <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-10 h-1 bg-gray-600 rounded-full"></div>
          </div>
        </div>
        <!-- CTA text -->
        <div class="p-4 text-center">
          <p class="text-sm font-bold text-gray-900 dark:text-white">📱 Add to Home Screen</p>
          <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-1">Tap for full guide</p>
        </div>
      </a>
      <button id="dismiss-install" class="block w-full mt-2 text-[10px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-center">Dismiss</button>
    </div>
  </div>
</Layout>

<script>
  // Show install panel after 4 minutes of browse time with slide-in animation
  (function() {
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;
    const dismissed = localStorage.getItem('xconvert24-install-dismissed');
    const installed = localStorage.getItem('xc-coin-home_screen'); // Set when user earns home_screen coins
    const panel = document.getElementById('install-panel');

    if (isStandalone || dismissed || installed) return; // Never show if installed, earned coin, or dismissed

    // Show after 4 minutes (240000ms)
    var DELAY = 240000;
    var startTime = parseInt(sessionStorage.getItem('xconvert24-session-start') || '0');
    if (!startTime) { startTime = Date.now(); sessionStorage.setItem('xconvert24-session-start', startTime.toString()); }

    var elapsed = Date.now() - startTime;
    var remaining = Math.max(0, DELAY - elapsed);

    setTimeout(function() {
      // Double-check standalone status at show time
      var nowStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;
      if (nowStandalone || !panel) return;

      // Reveal with slide-in animation
      panel.classList.remove('hidden');
      // Trigger reflow so transition kicks in
      void panel.offsetWidth;
      panel.classList.remove('opacity-0', 'translate-x-8');
      panel.classList.add('opacity-100', 'translate-x-0');
    }, remaining);

    document.getElementById('dismiss-install')?.addEventListener('click', () => {
      localStorage.setItem('xconvert24-install-dismissed', '1');
      // Animate out
      if (panel) {
        panel.classList.add('opacity-0', 'translate-x-8');
        panel.classList.remove('opacity-100', 'translate-x-0');
        setTimeout(() => panel.classList.add('hidden'), 700);
      }
    });
  })();
</script>
