<script>
  // Show install panel after 4 minutes of browse time with slide-in animation
  // On homepage: no dismiss — always shows (unless installed/standalone)
  (function() {
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;
    const installed = localStorage.getItem('xc-coin-home_screen'); // Set when user earns home_screen coins
    const panel = document.getElementById('install-panel');

    if (isStandalone || installed) return; // Never show if installed or earned coin

    // Show after 4 minutes (240000ms)
    var DELAY = 240000;
    var startTime = parseInt(sessionStorage.getItem('xconvert24-session-start') || '0');
    if (!startTime) { startTime = Date.now(); sessionStorage.setItem('xconvert24-session-start', startTime.toString()); }

    var elapsed = Date.now() - startTime;
    var remaining = Math.max(0, DELAY - elapsed);

    setTimeout(function() {
      // Double-check standalone status at show time
      var nowStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;
      if (nowStandalone || !panel) return;

      // Reveal with slide-in animation
      panel.classList.remove('hidden');
      // Trigger reflow so transition kicks in
      void panel.offsetWidth;
      panel.classList.remove('opacity-0', 'translate-x-8');
      panel.classList.add('opacity-100', 'translate-x-0');
    }, remaining);
  })();
</script>

<script>
  // Pinned Tracker widget — breaking news feed
  (function() {
    let ftDisease = 'ebola';
    const ftNews = document.getElementById('ft-news')!;

    async function loadFTNews(refresh = false) {
      ftNews.innerHTML = '<div class="flex items-center justify-center py-4"><span class="text-xs text-gray-400 animate-pulse">Loading breaking news...</span></div>';
      try {
        const url = `/api/breaking-news?disease=${ftDisease}${refresh ? '&refresh=true' : ''}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error('News fetch failed');
        const data = await res.json();
        const news = data.news || [];

        if (news.length === 0) {
          ftNews.innerHTML = '<p class="text-[10px] text-gray-400 text-center py-3">No breaking news at this time.</p>';
          return;
        }

        ftNews.innerHTML = news.slice(0, 5).map((item: any) =>
          `<a href="${item.url}" target="_blank" rel="noopener" class="block p-2 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-red-50 dark:hover:bg-red-900/10 border border-transparent hover:border-red-200 dark:hover:border-red-800/50 transition-all group">
            <p class="text-[11px] font-medium text-gray-900 dark:text-white group-hover:text-red-700 dark:group-hover:text-red-300 line-clamp-2 leading-tight">${item.title}</p>
            ${item.source ? `<p class="text-[9px] text-amber-600 dark:text-amber-400 mt-0.5">📰 ${item.source}</p>` : ''}
          </a>`
        ).join('');
      } catch {
        ftNews.innerHTML = '<p class="text-[10px] text-gray-400 text-center py-3">Unable to load news.</p>';
      }
    }

    function updateFTTabs() {
      document.querySelectorAll('.ft-tab').forEach(btn => {
        const isActive = (btn as HTMLElement).dataset.ftDisease === ftDisease;
        if (isActive) {
          (btn as HTMLElement).className = 'ft-tab px-2 py-1 rounded text-[10px] font-semibold bg-amber-500 text-white transition-colors flex items-center gap-1';
        } else {
          (btn as HTMLElement).className = 'ft-tab px-2 py-1 rounded text-[10px] font-semibold text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors flex items-center gap-1';
        }
      });
    }

    document.querySelectorAll('.ft-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        ftDisease = (btn as HTMLElement).dataset.ftDisease!;
        updateFTTabs();
        loadFTNews();
      });
    });

    // Refresh button — triggers Tavily search via ?refresh=true
    document.getElementById('ft-refresh-btn')!.addEventListener('click', async () => {
      const btn = document.getElementById('ft-refresh-btn')!;
      btn.classList.add('animate-spin');
      btn.setAttribute('disabled', '');
      await loadFTNews(true);
      btn.classList.remove('animate-spin');
      btn.removeAttribute('disabled');
    });

    loadFTNews();

    // Auto-refresh every hour via Tavily
    setInterval(() => {
      loadFTNews(true);
    }, 3600000); // 1 hour in ms
  })();
</script>
