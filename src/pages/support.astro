---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Support Us — Help Keep xConvert24 Free" description="Support xConvert24.com — a free tool used by students, tradespeople, engineers, and professionals worldwide. Donate via Solana (SOL) to keep us running." keywords="support xconvert24, donate, solana donation, help free tools, support open source, crypto donation">
  <div class="max-w-3xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">💜</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Support Us</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Help keep xConvert24 free, fast, and ad-free for everyone.</p>
    </div>

    <!-- Appeal -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Why Your Support Matters</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">xConvert24 is a bootstrapped startup with a simple mission: give everyone instant access to accurate conversions and calculations — no sign-up, no paywalls.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">🔧</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Tradespeople</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Plumbers converting pipe sizes, electricians checking voltage, builders measuring in feet and metres — quick conversions save time on every job.</p>
        </div>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">🎓</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Students</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Physics homework, chemistry conversions, maths calculators — a free tool that's always available without textbook costs.</p>
        </div>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">✈️</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Travellers</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Currency exchange, temperature in a new country, luggage weight limits — conversions you need when you're far from home.</p>
        </div>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">👨‍🍳</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Home Cooks</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Cups to ml, Fahrenheit to Celsius for oven temps, tablespoons to grams — essential for international recipes.</p>
        </div>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">💻</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Developers & Engineers</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Data units (MB/GB/TB), epoch timestamps, hex colours, number base conversions — dev tools without leaving the browser.</p>
        </div>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <span class="text-2xl mb-2 block">🏥</span>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Healthcare Workers</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">BMI calculations, medication dosing (ml to tsp), weight conversions for patient records — accuracy matters.</p>
        </div>
      </div>

      <div class="p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
        <p class="text-sm text-amber-800 dark:text-amber-300"><strong>Our promise:</strong> Your support keeps the lights on — server costs, domain fees, and development time. We will never sell your data, never add intrusive ads, and never lock features behind a paywall.</p>
      </div>
    </div>

    <!-- Solana Donation -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <!-- Solana logo -->
        <div class="w-10 h-10 rounded-full bg-black flex items-center justify-center">
          <svg width="24" height="24" viewBox="0 0 128 128" fill="none">
            <path d="M25.6 95.5l16.3-17.1c.6-.6 1.4-1 2.3-1h78.2c1.4 0 2.2 1.7 1.2 2.8l-16.3 17.1c-.6.6-1.4 1-2.3 1H26.8c-1.4 0-2.2-1.7-1.2-2.8z" fill="url(#sol1)"/>
            <path d="M25.6 30.2l16.3-17.1c.6-.6 1.4-1 2.3-1h78.2c1.4 0 2.2 1.7 1.2 2.8L107.3 32c-.6.6-1.4 1-2.3 1H26.8c-1.4 0-2.2-1.7-1.2-2.8z" fill="url(#sol2)"/>
            <path d="M107.3 62.5l-16.3-17.1c-.6-.6-1.4-1-2.3-1H10.5c-1.4 0-2.2 1.7-1.2 2.8l16.3 17.1c.6.6 1.4 1 2.3 1h78.2c1.4 0 2.2-1.7 1.2-2.8z" fill="url(#sol3)"/>
            <defs>
              <linearGradient id="sol1" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient>
              <linearGradient id="sol2" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient>
              <linearGradient id="sol3" x1="5" y1="120" x2="120" y2="5"><stop stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient>
            </defs>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Donate with Solana (SOL)</h2>
          <p class="text-xs text-gray-500 dark:text-gray-400">Fast, low-fee transactions on the Solana network</p>
        </div>
      </div>

      <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg mb-4">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">Send SOL to:</p>
        <div class="flex items-center gap-2">
          <code id="sol-address" class="flex-1 text-sm font-mono text-gray-900 dark:text-white bg-white dark:bg-gray-900 px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 break-all select-all">Loading...</code>
          <button id="copy-sol" class="shrink-0 px-3 py-2 bg-purple-500 hover:bg-purple-600 text-white text-xs font-semibold rounded-lg transition-colors">Copy</button>
        </div>
      </div>

      <div class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-400">
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Near-zero fees
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Instant confirmation
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Any amount helps
        </div>
      </div>
    </div>

    <!-- What your support covers -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Where Your Contribution Goes</h2>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">☁️</div>
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white">Hosting & Infrastructure</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Cloudflare Workers, D1 databases, domain fees</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-sm">🛠️</div>
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white">Development</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">AI tokens for development using Kiro, new converters, tools, bug fixes, performance improvements</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-sm">📝</div>
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white">Content</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Blog posts, educational guides, format documentation</p>
          </div>
        </div>
      </div>
      <p class="mt-4 text-xs text-gray-400 dark:text-gray-500 text-center">Every contribution, no matter how small, helps us stay independent and ad-free. 💜</p>
    </div>
  </div>
</Layout>

<script>
  // Load wallet address from API
  fetch('/api/wallet')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('sol-address');
      if (el && data.address) el.textContent = data.address;
      else if (el) el.textContent = '(Wallet not configured yet)';
    })
    .catch(() => {});

  document.getElementById('copy-sol')?.addEventListener('click', () => {
    const addr = document.getElementById('sol-address')!.textContent || '';
    if (addr.startsWith('(')) return; // Don't copy placeholder text
    navigator.clipboard.writeText(addr).then(() => {
      const btn = document.getElementById('copy-sol')!;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);

      // Notify via email that wallet address was copied
      fetch('/api/notify-copy', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ address: addr, timestamp: new Date().toISOString() })
      }).catch(() => {});
    });
  });
</script>
