          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">TypeScript</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">typescriptlang.org</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Type-safe JavaScript for reliable API endpoints and complex application logic.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Design & Branding -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-orange-600 dark:text-orange-500 uppercase tracking-wider mb-4 flex items-center gap-2"><span aria-hidden="true">🎨</span> Design & Branding</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://vercel.com/design" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://vercel.com/favicon.ico" alt="Vercel Design logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Vercel Design</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">vercel.com/design</p>
