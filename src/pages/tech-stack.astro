    <!-- Design & Branding -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-orange-600 dark:text-orange-500 uppercase tracking-wider mb-4 flex items-center gap-2"><span aria-hidden="true">🎨</span> Design & Branding</h2>
