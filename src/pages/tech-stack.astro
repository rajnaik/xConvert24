            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">godaddy.com</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Domain registration for xconvert24.com.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Frameworks & Runtime -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-orange-600 dark:text-orange-500 uppercase tracking-wider mb-4 flex items-center gap-2"><span aria-hidden="true">⚡</span> Frameworks & Runtime</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://astro.build/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://astro.build/favicon.svg" alt="Astro logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Astro</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">astro.build</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">The web framework for content-driven websites. Delivers fast, static pages with islands of interactivity.</p>
          </div>
        </a>
        <a href="https://nodejs.org/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://nodejs.org/static/images/favicons/favicon.png" alt="Node.js logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Node.js</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">nodejs.org</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">JavaScript runtime powering our build process, tooling, and local development server.</p>
          </div>
        </a>
        <a href="https://tailwindcss.com/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://tailwindcss.com/favicons/favicon.ico" alt="Tailwind CSS logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Tailwind CSS</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">tailwindcss.com</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Utility-first CSS framework for rapid, consistent UI styling across the entire site.</p>
          </div>
        </a>
        <a href="https://www.typescriptlang.org/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
