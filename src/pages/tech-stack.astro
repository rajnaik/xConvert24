---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { VERSION } from '../data/siteStats';
---

<Layout title="Tech Stack — The Tools Behind xConvert24" description="Discover the technologies, platforms, and tools that power xConvert24.com. From AI development with Kiro to Cloudflare Workers deployment." keywords="tech stack, xconvert24 technology, cloudflare workers, astro, kiro, tools we use">
  <div class="max-w-4xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">🧱</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Tech Stack</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">The tools, platforms, and services that power xConvert24.com.</p>
    </div>

    <!-- Development & AI -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-orange-600 dark:text-orange-500 uppercase tracking-wider mb-4 flex items-center gap-2"><span aria-hidden="true">🤖</span> Development & AI</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://kiro.dev/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://kiro.dev/favicon.ico" alt="Kiro logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Kiro</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">kiro.dev</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">AI-powered development environment. Our primary coding partner for building and maintaining the entire platform.</p>
          </div>
        </a>
        <a href="https://skills.sh/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://skills.sh/favicon.ico" alt="Skills.sh logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Skills.sh</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">skills.sh</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Teaching AI agent coding skills. Used to enhance our development agent's capabilities.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Hosting & Infrastructure -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-orange-600 dark:text-orange-500 uppercase tracking-wider mb-4 flex items-center gap-2"><span aria-hidden="true">☁️</span> Hosting & Infrastructure</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://cloudflare.com/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://www.cloudflare.com/favicon.ico" alt="Cloudflare logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Cloudflare</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">cloudflare.com</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Edge hosting via Workers, D1 database, R2 storage, and CDN. Our entire backend runs on Cloudflare's global network.</p>
          </div>
        </a>
        <a href="https://godaddy.com/" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
          <img src="https://www.godaddy.com/favicon.ico" alt="GoDaddy logo" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
