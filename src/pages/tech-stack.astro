        <a href="https://vercel.com/design" target="_blank" rel="noopener" class="tech-card group flex items-start gap-4 p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-amber-400 dark:hover:border-amber-600 transition-all shadow-sm hover:shadow-md">
