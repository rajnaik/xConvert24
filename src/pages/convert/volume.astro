---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'l', label: 'Liters (L)' },
  { value: 'ml', label: 'Milliliters (mL)' },
  { value: 'm3', label: 'Cubic Meters (m³)' },
  { value: 'cm3', label: 'Cubic Centimeters (cm³)' },
  { value: 'ft3', label: 'Cubic Feet (ft³)' },
  { value: 'in3', label: 'Cubic Inches (in³)' },
  { value: 'gal_us', label: 'Gallons US (gal)' },
  { value: 'gal_uk', label: 'Gallons UK (gal)' },
  { value: 'qt', label: 'Quarts US (qt)' },
  { value: 'pt', label: 'Pints US (pt)' },
  { value: 'cup', label: 'Cups US' },
  { value: 'floz', label: 'Fluid Ounces US (fl oz)' },
  { value: 'tbsp', label: 'Tablespoons (tbsp)' },
  { value: 'tsp', label: 'Teaspoons (tsp)' },
];
---
<Layout title="Liters to Gallons Converter — Free & Instant" description="Free Volume Converter. Convert litres to gallons, cups to mL, and more instantly. 100% accurate results with no ads or sign-up." keywords="liters to gallons, ml to cups, volume converter, gallons to liters, fluid ounces to ml, pints to liters, quarts to ml, liquid measurement">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">🧪</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Volume & Capacity Converter — Liters, Gallons, Cups, mL</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of volume and capacity</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 6}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">0.264172</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 L = 0.264172 gal (US)</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 L','0.264172 gal (US) / 0.219969 gal (UK)'],['1 gal (US)','3.78541 L'],['1 gal (UK)','4.54609 L'],['1 cup (US)','236.588 mL'],['1 pt (US)','473.176 mL'],['1 qt (US)','946.353 mL'],['1 fl oz (US)','29.5735 mL'],['1 tbsp','14.7868 mL'],['1 tsp','4.92892 mL']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How Do I Convert Volume Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Volume conversion is essential for cooking, chemistry, medicine, and shipping. The metric system uses liters and milliliters, while the US system uses gallons, quarts, pints, cups, and fluid ounces. Note that US and UK gallons are different sizes.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Liters → US Gallons</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">1 US gallon = 3.785 liters. Divide liters by 3.785.</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Liters → UK Gallons</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">1 UK gallon = 4.546 liters. Divide liters by 4.546.</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">US vs UK Measurements</h2>
        <p class="text-gray-600 dark:text-gray-400">Be careful: US and UK fluid measurements differ. A US cup = 236.6 mL, a US pint = 473.2 mL, while a UK pint = 568.3 mL. Recipes from different countries may use different standards.</p>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Common Volume Conversions</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 liter = 0.264 US gallons = 4.227 US cups = 33.81 fl oz</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 US cup = 236.6 mL = 16 tablespoons = 48 teaspoons</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 tablespoon = 14.79 mL = 3 teaspoons</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 cubic meter = 1000 liters = 264.2 US gallons</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 cubic foot = 28.32 liters = 7.481 US gallons</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many liters in a US gallon?", "acceptedAnswer": { "@type": "Answer", "text": "1 US gallon equals approximately 3.785 liters. Note that 1 UK (imperial) gallon equals 4.546 liters." }},
        { "@type": "Question", "name": "How many cups in a liter?", "acceptedAnswer": { "@type": "Answer", "text": "There are approximately 4.227 US cups in 1 liter, or about 4 cups for a rough estimate." }},
        { "@type": "Question", "name": "How many ml in a tablespoon?", "acceptedAnswer": { "@type": "Answer", "text": "1 US tablespoon equals approximately 14.787 ml. 1 metric tablespoon is exactly 15 ml." }}
      ]
    })} />
  </div>
</Layout>
<script>
  // All values in liters
  const toLiter: Record<string,number> = {
    l:1, ml:0.001, m3:1000, cm3:0.001, ft3:28.316846592,
    in3:0.016387064, gal_us:3.785411784, gal_uk:4.54609,
    qt:0.946352946, pt:0.473176473, cup:0.2365882365,
    floz:0.0295735296875, tbsp:0.0147867648, tsp:0.00492892159
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toLiter[fu.value]/toLiter[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toLiter[fu.value]/toLiter[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
