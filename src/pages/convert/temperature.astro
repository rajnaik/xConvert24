---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';

const units = [
  { value: 'c', label: 'Celsius (°C)' },
  { value: 'f', label: 'Fahrenheit (°F)' },
  { value: 'k', label: 'Kelvin (K)' },
];
---

<Layout title="Temperature Converter — °C, °F, Kelvin" description="Instant Temperature Converter. Switch between Celsius, Fahrenheit & Kelvin in seconds. Supports Celsius, Fahrenheit, and Kelvin for all your cooking or scientific needs. Free, accurate, no sign-up." keywords="celsius to fahrenheit, fahrenheit to celsius, temperature converter, kelvin to celsius, C to F, F to C, temperature conversion chart">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🌡️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Temperature Converter</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert between Celsius, Fahrenheit, and Kelvin</p>
      <ConverterBlogLinks />
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" placeholder="Enter value" value="100" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" aria-label="Swap units" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
          Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 1}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">212</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">°F = (°C × 9/5) + 32</div>
    </div>

    <!-- Thermometer Visual -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Visual Thermometer</h2>
      <div class="flex items-center gap-8 justify-center">
        <!-- SVG Thermometer -->
        <div class="relative" style="width: 60px; height: 280px;">
          <!-- Thermometer body -->
          <svg width="60" height="280" viewBox="0 0 60 280" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer body -->
            <rect x="18" y="10" width="24" height="210" rx="12" fill="#e5e7eb" stroke="#9ca3af" stroke-width="1.5"/>
            <!-- Bulb -->
            <circle cx="30" cy="245" r="25" fill="#e5e7eb" stroke="#9ca3af" stroke-width="1.5"/>
            <!-- Inner tube (mercury) -->
            <rect id="thermo-tube" x="24" y="20" width="12" height="190" rx="6" fill="#d1d5db"/>
            <!-- Mercury fill (dynamic) -->
            <rect id="thermo-fill" x="24" y="110" width="12" height="100" rx="6" fill="#ef4444"/>
            <!-- Bulb fill -->
            <circle id="thermo-bulb" cx="30" cy="245" r="18" fill="#ef4444"/>
            <!-- Scale marks -->
            <line x1="43" y1="25" x2="50" y2="25" stroke="#6b7280" stroke-width="1"/>
            <text x="53" y="29" font-size="8" fill="#6b7280" font-family="Inter,sans-serif">100°</text>
            <line x1="43" y1="72" x2="48" y2="72" stroke="#6b7280" stroke-width="0.5"/>
            <line x1="43" y1="120" x2="50" y2="120" stroke="#6b7280" stroke-width="1"/>
            <text x="53" y="124" font-size="8" fill="#6b7280" font-family="Inter,sans-serif">50°</text>
            <line x1="43" y1="167" x2="48" y2="167" stroke="#6b7280" stroke-width="0.5"/>
            <line x1="43" y1="215" x2="50" y2="215" stroke="#6b7280" stroke-width="1"/>
            <text x="53" y="219" font-size="8" fill="#6b7280" font-family="Inter,sans-serif">0°</text>
          </svg>
          <!-- Temperature display on thermometer -->
          <div id="thermo-temp-display" class="absolute left-0 right-0 text-center font-bold text-sm" style="top: 235px; color: white;">37°C</div>
        </div>
        <!-- Slider & readouts -->
        <div class="flex flex-col items-center gap-4 flex-1 max-w-xs">
          <div class="text-center">
            <p id="thermo-celsius" class="text-4xl font-bold text-gray-900 dark:text-white">37°C</p>
            <p id="thermo-fahrenheit" class="text-xl text-gray-500 dark:text-gray-400 mt-1">98.6°F</p>
            <p id="thermo-kelvin" class="text-base text-gray-400 dark:text-gray-500 mt-0.5">310.15 K</p>
          </div>
          <!-- Temperature description -->
          <div id="thermo-desc" class="px-3 py-1.5 rounded-full text-xs font-semibold bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">Body Temperature</div>
          <!-- Slider -->
          <div class="w-full">
            <input id="thermo-slider" type="range" min="-50" max="150" value="37" class="w-full h-3 rounded-full appearance-none cursor-pointer" style="background: linear-gradient(to right, #3b82f6, #6b7280, #f59e0b, #ef4444);"/>
            <div class="flex justify-between text-xs text-gray-400 mt-1">
              <span>-50°C</span>
              <span>0°C</span>
              <span>50°C</span>
              <span>100°C</span>
              <span>150°C</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Common Temperatures</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300">
            <tr>
              <th class="px-4 py-2 text-left font-medium">Description</th>
              <th class="px-4 py-2 text-left font-medium">°C</th>
              <th class="px-4 py-2 text-left font-medium">°F</th>
              <th class="px-4 py-2 text-left font-medium">K</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[
              ['Absolute Zero', '-273.15', '-459.67', '0'],
              ['Water Freezes', '0', '32', '273.15'],
              ['Body Temperature', '37', '98.6', '310.15'],
              ['Water Boils', '100', '212', '373.15'],
              ['Oven (moderate)', '180', '356', '453.15'],
            ].map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{row[0]}</td>
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{row[1]}</td>
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{row[2]}</td>
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{row[3]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How to Convert Temperature</h2>
        <p class="text-gray-600 dark:text-gray-400">Temperature conversion between Celsius, Fahrenheit, and Kelvin is essential for cooking, weather, science, and travel. Most of the world uses Celsius, while the US primarily uses Fahrenheit. Kelvin is used in scientific contexts.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Celsius → Fahrenheit</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">°F = (°C × 9/5) + 32. Quick tip: double, subtract 10%, add 32.</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Fahrenheit → Celsius</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">°C = (°F − 32) × 5/9. Example: 98.6°F = 37°C.</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Key Temperature Points</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Water freezes: 0°C = 32°F = 273.15 K</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Water boils: 100°C = 212°F = 373.15 K</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Body temperature: 37°C = 98.6°F</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Room temperature: ~20-22°C = 68-72°F</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Absolute zero: -273.15°C = -459.67°F = 0 K</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  const formulas: Record<string, Record<string, string>> = {
    c: { f: '°F = (°C × 9/5) + 32', k: 'K = °C + 273.15' },
    f: { c: '°C = (°F − 32) × 5/9', k: 'K = (°F − 32) × 5/9 + 273.15' },
    k: { c: '°C = K − 273.15', f: '°F = (K − 273.15) × 9/5 + 32' },
  };

  function convert(val: number, from: string, to: string): number {
    if (from === to) return val;
    // convert to Celsius first
    let c: number;
    if (from === 'c') c = val;
    else if (from === 'f') c = (val - 32) * 5 / 9;
    else c = val - 273.15; // kelvin
    // convert from Celsius to target
    if (to === 'c') return c;
    if (to === 'f') return c * 9 / 5 + 32;
    return c + 273.15;
  }

  const fromUnit = document.getElementById('from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('to-unit') as HTMLSelectElement;
  const fromVal = document.getElementById('from-value') as HTMLInputElement;
  const resultEl = document.getElementById('result')!;
  const formulaEl = document.getElementById('formula')!;

  function update() {
    const val = parseFloat(fromVal.value);
    if (isNaN(val)) { resultEl.textContent = '—'; return; }
    const res = convert(val, fromUnit.value, toUnit.value);
    resultEl.textContent = parseFloat(res.toFixed(4)).toString();
    const key = fromUnit.value + toUnit.value;
    formulaEl.textContent = formulas[fromUnit.value]?.[toUnit.value] || formulas[toUnit.value]?.[fromUnit.value] || `Same unit`;
  }

  fromVal.addEventListener('input', update);
  fromUnit.addEventListener('change', update);
  toUnit.addEventListener('change', update);
  document.getElementById('swap-btn')!.addEventListener('click', () => {
    const tmp = fromUnit.value; fromUnit.value = toUnit.value; toUnit.value = tmp; update();
  });
  update();

  // ── Thermometer visual ──────────────────────────────────────────────────
  const thermoSlider = document.getElementById('thermo-slider') as HTMLInputElement;
  const thermoFill = document.getElementById('thermo-fill')!;
  const thermoBulb = document.getElementById('thermo-bulb')!;
  const thermoCelsius = document.getElementById('thermo-celsius')!;
  const thermoFahrenheit = document.getElementById('thermo-fahrenheit')!;
  const thermoKelvin = document.getElementById('thermo-kelvin')!;
  const thermoDesc = document.getElementById('thermo-desc')!;
  const thermoTempDisplay = document.getElementById('thermo-temp-display')!;

  function updateThermometer() {
    const celsius = parseFloat(thermoSlider.value);
    const fahrenheit = celsius * 9 / 5 + 32;
    const kelvin = celsius + 273.15;

    thermoCelsius.textContent = `${celsius}°C`;
    thermoFahrenheit.textContent = `${fahrenheit.toFixed(1)}°F`;
    thermoKelvin.textContent = `${kelvin.toFixed(2)} K`;
    thermoTempDisplay.textContent = `${celsius}°`;

    // Calculate fill height (range: -50 to 150 maps to tube y:215 down to y:25)
    const pct = (celsius - (-50)) / (150 - (-50)); // 0 to 1
    const tubeTop = 25;
    const tubeBottom = 215;
    const tubeHeight = tubeBottom - tubeTop;
    const fillHeight = pct * tubeHeight;
    const fillY = tubeBottom - fillHeight;

    thermoFill.setAttribute('y', fillY.toString());
    thermoFill.setAttribute('height', fillHeight.toString());

    // Color gradient: blue (cold) → gray → orange → red (hot)
    let color: string;
    if (celsius <= -20) color = '#2563eb'; // deep blue
    else if (celsius <= 0) { const t = (celsius + 20) / 20; color = interpolateColor('#2563eb', '#6b7280', t); }
    else if (celsius <= 30) { const t = celsius / 30; color = interpolateColor('#6b7280', '#f59e0b', t); }
    else if (celsius <= 60) { const t = (celsius - 30) / 30; color = interpolateColor('#f59e0b', '#ef4444', t); }
    else { const t = Math.min(1, (celsius - 60) / 90); color = interpolateColor('#ef4444', '#7f1d1d', t); }

    thermoFill.setAttribute('fill', color);
    thermoBulb.setAttribute('fill', color);

    // Description
    let desc = '';
    if (celsius <= -40) desc = '🥶 Extreme Cold';
    else if (celsius <= -10) desc = '❄️ Freezing';
    else if (celsius <= 0) desc = '🧊 Below Freezing';
    else if (celsius <= 15) desc = '🧥 Cold';
    else if (celsius <= 25) desc = '😊 Room Temperature';
    else if (celsius <= 37) desc = '🌤️ Warm';
    else if (celsius <= 45) desc = '🔥 Hot';
    else if (celsius <= 100) desc = '♨️ Very Hot';
    else desc = '🌋 Extreme Heat';
    thermoDesc.textContent = desc;
  }

  function interpolateColor(c1: string, c2: string, t: number): string {
    const r1 = parseInt(c1.slice(1, 3), 16), g1 = parseInt(c1.slice(3, 5), 16), b1 = parseInt(c1.slice(5, 7), 16);
    const r2 = parseInt(c2.slice(1, 3), 16), g2 = parseInt(c2.slice(3, 5), 16), b2 = parseInt(c2.slice(5, 7), 16);
    const r = Math.round(r1 + (r2 - r1) * t), g = Math.round(g1 + (g2 - g1) * t), b = Math.round(b1 + (b2 - b1) * t);
    return `rgb(${r},${g},${b})`;
  }

  thermoSlider.addEventListener('input', updateThermometer);
  updateThermometer();
</script>
