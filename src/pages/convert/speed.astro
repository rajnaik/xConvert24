---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'kmh', label: 'Kilometers per hour (km/h)', mobileLabel: 'km/h' },
  { value: 'mph', label: 'Miles per hour (mph)', mobileLabel: 'mph' },
  { value: 'ms', label: 'Meters per second (m/s)', mobileLabel: 'm/s' },
  { value: 'fps', label: 'Feet per second (ft/s)', mobileLabel: 'ft/s' },
  { value: 'kn', label: 'Knots (kn)', mobileLabel: 'Knots' },
  { value: 'mach', label: 'Mach', mobileLabel: 'Mach' },
];
---
<Layout title="KM/H to MPH Converter — Fast & Free" description="Fast Speed Converter. Convert km/h to mph, knots to m/s, and Mach instantly. Ideal for travel and professional calculations. No ads, no hassle." keywords="km/h to mph, mph to km/h, speed converter, m/s to mph, knots to mph, mach to mph, velocity converter">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">💨</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Speed Converter — km/h, mph, Knots, Mach</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of speed and velocity</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="100" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 1} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">62.1371</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 km/h = 0.621371 mph</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 km/h','0.621371 mph / 0.277778 m/s'],['1 mph','1.60934 km/h / 0.44704 m/s'],['1 m/s','3.6 km/h / 2.23694 mph'],['1 knot','1.852 km/h / 1.15078 mph'],['Mach 1','1235.0 km/h / 767.3 mph'],['Speed of light','1.079×10⁹ km/h']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How Do I Convert Speed Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Speed conversion is important for driving abroad, aviation, marine navigation, and science. The most common conversions are between kilometers per hour (km/h) and miles per hour (mph), used in different countries' road systems.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">km/h → mph</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">Multiply km/h by 0.621371. Example: 100 km/h = 62.14 mph.</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Mach & Knots</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">Mach 1 ≈ 1235 km/h. 1 knot = 1.852 km/h.</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Quick Reference</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>100 km/h = 62.14 mph (typical highway speed in Europe)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>60 mph = 96.56 km/h (typical US highway speed)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 m/s = 3.6 km/h = 2.237 mph</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Speed of sound (Mach 1) ≈ 343 m/s = 1235 km/h</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Speed of light ≈ 299,792 km/s = 670,616,629 mph</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How do I convert km/h to mph?", "acceptedAnswer": { "@type": "Answer", "text": "To convert km/h to mph, divide by 1.60934. For example, 100 km/h ÷ 1.60934 = 62.14 mph." }},
        { "@type": "Question", "name": "What is Mach 1 in km/h?", "acceptedAnswer": { "@type": "Answer", "text": "Mach 1 (speed of sound at sea level) is approximately 1,235 km/h or 767 mph." }},
        { "@type": "Question", "name": "How many knots in 1 mph?", "acceptedAnswer": { "@type": "Answer", "text": "1 mph equals approximately 0.868976 knots. To convert mph to knots, multiply by 0.868976." }}
      ]
    })} />
  </div>
</Layout>
<script>
  // All in m/s
  const toMs: Record<string,number> = {
    kmh: 1/3.6, mph: 0.44704, ms: 1,
    fps: 0.3048, kn: 0.514444, mach: 340.29
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toMs[fu.value]/toMs[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toMs[fu.value]/toMs[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
