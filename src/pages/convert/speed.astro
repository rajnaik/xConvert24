---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
const units = [
  { value: 'kmh', label: 'Kilometers per hour (km/h)' },
  { value: 'mph', label: 'Miles per hour (mph)' },
  { value: 'ms', label: 'Meters per second (m/s)' },
  { value: 'fps', label: 'Feet per second (ft/s)' },
  { value: 'kn', label: 'Knots (kn)' },
  { value: 'mach', label: 'Mach' },
];
---
<Layout title="Speed Converter — km/h to mph, m/s to knots" description="Free online speed converter. Convert km/h to mph, m/s to knots, Mach number and more velocity units. Instant results." keywords="km/h to mph, mph to km/h, speed converter, m/s to mph, knots to mph, mach to mph, velocity converter">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">💨</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Speed Converter</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of speed and velocity</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="100" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 1}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">62.1371</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 km/h = 0.621371 mph</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-800"><tr><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Value</th><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 km/h','0.621371 mph / 0.277778 m/s'],['1 mph','1.60934 km/h / 0.44704 m/s'],['1 m/s','3.6 km/h / 2.23694 mph'],['1 knot','1.852 km/h / 1.15078 mph'],['Mach 1','1235.0 km/h / 767.3 mph'],['Speed of light','1.079×10⁹ km/h']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">How to Convert Speed Units</h2>
        <p class="text-gray-600 dark:text-gray-400">Speed conversion is important for driving abroad, aviation, marine navigation, and science. The most common conversions are between kilometers per hour (km/h) and miles per hour (mph), used in different countries' road systems.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">km/h to mph</h3>
        <p class="text-gray-600 dark:text-gray-400">Multiply km/h by 0.621371 to get mph. For example, 100 km/h = 62.14 mph. Most European speed limits are posted in km/h, while the US and UK use mph.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Understanding Mach and Knots</h3>
        <p class="text-gray-600 dark:text-gray-400">Mach 1 is the speed of sound (~1235 km/h or 767 mph at sea level). Knots are used in aviation and maritime — 1 knot = 1 nautical mile per hour = 1.852 km/h.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Quick Reference</h3>
        <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1">
          <li>100 km/h = 62.14 mph (typical highway speed in Europe)</li>
          <li>60 mph = 96.56 km/h (typical US highway speed)</li>
          <li>1 m/s = 3.6 km/h = 2.237 mph</li>
          <li>Speed of sound (Mach 1) ≈ 343 m/s = 1235 km/h</li>
          <li>Speed of light ≈ 299,792 km/s = 670,616,629 mph</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
<script>
  // All in m/s
  const toMs: Record<string,number> = {
    kmh: 1/3.6, mph: 0.44704, ms: 1,
    fps: 0.3048, kn: 0.514444, mach: 340.29
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toMs[fu.value]/toMs[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toMs[fu.value]/toMs[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
