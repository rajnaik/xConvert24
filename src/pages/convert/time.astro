---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'ms', label: 'Milliseconds (ms)', mobileLabel: 'ms' },
  { value: 's', label: 'Seconds (s)', mobileLabel: 'Secs' },
  { value: 'min', label: 'Minutes (min)', mobileLabel: 'Mins' },
  { value: 'h', label: 'Hours (h)', mobileLabel: 'Hrs' },
  { value: 'd', label: 'Days (d)', mobileLabel: 'Days' },
  { value: 'wk', label: 'Weeks (wk)', mobileLabel: 'Wks' },
  { value: 'mo', label: 'Months (mo)', mobileLabel: 'Mos' },
  { value: 'yr', label: 'Years (yr)', mobileLabel: 'Yrs' },
];
---
<Layout title="Time Converter — Hours to Minutes, Days to Seconds" description="Free Time Converter. Convert hours to minutes, days to seconds, and more instantly. Accurate results with no sign-up needed." keywords="hours to minutes, days to seconds, time converter, minutes to hours, weeks to days, months to years, time unit conversion">
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many seconds in a year?","acceptedAnswer":{"@type":"Answer","text":"A standard year has 31,536,000 seconds (365 days × 24 hours × 60 minutes × 60 seconds). A leap year has 31,622,400 seconds."}},{"@type":"Question","name":"How many weeks in a year?","acceptedAnswer":{"@type":"Answer","text":"A year has approximately 52.14 weeks (365 days ÷ 7). This is why some years have 53 weeks in certain calendar systems."}},{"@type":"Question","name":"What is a fortnight?","acceptedAnswer":{"@type":"Answer","text":"A fortnight is exactly 14 days (2 weeks). The term comes from Old English 'fourteen nights' and is still commonly used in the UK and Australia."}}]}</script>
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">⏱️</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Time Converter — Hours, Minutes, Seconds, Days</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of time</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===3} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===2} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">60</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 h = 60 min</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 minute','60 seconds'],['1 hour','60 minutes / 3,600 seconds'],['1 day','24 hours / 86,400 seconds'],['1 week','7 days / 168 hours'],['1 month (avg)','30.4375 days'],['1 year','365.25 days / 8,766 hours'],['1 year','31,557,600 seconds']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
<!-- Report a bug · Suggest a feature -->
<div class="mt-6 flex items-center justify-center gap-4 flex-wrap">
  <a href="/report-bug?tool=Time+Converter" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 hover:underline font-medium">
    <span aria-hidden="true">🐛</span> Report a bug
  </a>
  <span class="text-gray-300 dark:text-gray-600">|</span>
  <a href="/suggest?title=Time+Converter" class="inline-flex items-center gap-1.5 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
    <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
  </a>
</div>

    <div class="mt-8 prose prose-sm dark:prose-invert max-w-none">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">About Time Conversion</h2>
      <p class="text-gray-600 dark:text-gray-400">Time conversion is essential for project planning, scientific calculations, and everyday scheduling. Our converter handles everything from milliseconds to years, including less common units like fortnights and lunar months.</p>
      <p class="text-gray-600 dark:text-gray-400">Convert between seconds, minutes, hours, days, weeks, months, and years instantly. Also supports milliseconds, microseconds, and nanoseconds for technical use.</p>
    </div>
</Layout>
<script>
  // All in seconds
  const toSec: Record<string,number> = {
    ms:0.001, s:1, min:60, h:3600, d:86400,
    wk:604800, mo:2629800, yr:31557600
  };
  function fmt(n: number) { return n<0.0001||n>1e12?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toSec[fu.value]/toSec[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toSec[fu.value]/toSec[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
