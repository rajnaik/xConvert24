---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
---

<Layout title="Body Weight % Calculator — Free & Fast" description="Free Body Weight Percentage Calculator. Track weight loss or gain as a percentage of body weight. Set fitness goals with accurate results. No sign-up." keywords="body weight percentage calculator, weight loss percentage, weight gain percentage, fitness calculator, weight change calculator, percentage of body weight">
  <div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🏋️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Body Weight Percentage Calculator — Track Loss & Gain</h1>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400 ml-2">NEW</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Calculate weight change as a percentage of body weight</p>
      <ConverterBlogLinks />
    </div>

    <!-- Calculator card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <!-- Unit toggle -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Unit</label>
        <div class="flex gap-2">
          <button id="unit-kg" class="flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-800">kg</button>
          <button id="unit-lb" class="flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700">lbs</button>
        </div>
      </div>

      <!-- Starting weight -->
      <div class="mb-4">
        <label for="start-weight" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Starting Weight</label>
        <input
          id="start-weight"
          type="number"
          placeholder="e.g. 85"
          class="w-full h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
        />
      </div>

      <!-- Current weight -->
      <div class="mb-4">
        <label for="current-weight" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Current Weight</label>
        <input
          id="current-weight"
          type="number"
          placeholder="e.g. 80"
          class="w-full h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
        />
      </div>

      <!-- Result -->
      <div id="result-card" class="mt-5 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg hidden">
        <div class="text-center">
          <div id="result-percentage" role="status" aria-live="polite" class="text-3xl font-bold text-amber-700 dark:text-amber-400">—</div>
          <div id="result-label" class="text-sm text-gray-600 dark:text-gray-400 mt-1">weight change</div>
          <div id="result-absolute" class="text-sm text-gray-500 dark:text-gray-500 mt-2 font-mono">—</div>
        </div>
      </div>
    </div>

    <!-- Use cases -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Common Uses</h2>
      </div>
      <div class="p-6">
        <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
          <li class="flex gap-2"><span class="text-amber-500">•</span>Track weight loss progress during a diet or fitness program</li>
          <li class="flex gap-2"><span class="text-amber-500">•</span>Monitor weight gain for muscle building or recovery</li>
          <li class="flex gap-2"><span class="text-amber-500">•</span>Calculate weight percentage for medical requirements (e.g. medication dosing)</li>
          <li class="flex gap-2"><span class="text-amber-500">•</span>Set realistic fitness goals based on percentage milestones</li>
          <li class="flex gap-2"><span class="text-amber-500">•</span>Compare weight changes across different body sizes fairly</li>
        </ul>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How to Calculate Body Weight Percentage Change</h2>
        <p class="text-gray-600 dark:text-gray-400">The formula is simple: ((Current Weight − Starting Weight) ÷ Starting Weight) × 100. A negative result means weight loss, positive means weight gain. This percentage is more meaningful than absolute numbers because it accounts for different body sizes.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-1 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Why Use Percentages?</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">A 5 kg loss means very different things for someone weighing 60 kg (8.3%) vs 120 kg (4.2%). Percentages normalize the comparison across body sizes.</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Healthy Weight Change Guidelines</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Safe weight loss: 0.5–1% of body weight per week</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Moderate weight loss: 5–10% over 6 months (clinically significant)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Muscle gain: 0.25–0.5% per week for beginners</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Dehydration warning: losing more than 2% body weight in a day (fluid loss)</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  const startInput = document.getElementById('start-weight') as HTMLInputElement;
  const currentInput = document.getElementById('current-weight') as HTMLInputElement;
  const resultCard = document.getElementById('result-card')!;
  const resultPct = document.getElementById('result-percentage')!;
  const resultLabel = document.getElementById('result-label')!;
  const resultAbs = document.getElementById('result-absolute')!;
  const unitKg = document.getElementById('unit-kg')!;
  const unitLb = document.getElementById('unit-lb')!;

  let unit = 'kg';

  function setUnit(u: string) {
    unit = u;
    if (u === 'kg') {
      unitKg.className = 'flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-800';
      unitLb.className = 'flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700';
    } else {
      unitLb.className = 'flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-800';
      unitKg.className = 'flex-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700';
    }
    calculate();
  }

  function calculate() {
    const start = parseFloat(startInput.value);
    const current = parseFloat(currentInput.value);

    if (isNaN(start) || isNaN(current) || start <= 0) {
      resultCard.classList.add('hidden');
      return;
    }

    const change = current - start;
    const pct = (change / start) * 100;
    const absPct = Math.abs(pct);

    resultCard.classList.remove('hidden');
    resultPct.textContent = `${pct >= 0 ? '+' : '−'}${absPct.toFixed(2)}%`;
    resultLabel.textContent = pct < 0 ? 'weight lost' : pct > 0 ? 'weight gained' : 'no change';
    resultAbs.textContent = `${Math.abs(change).toFixed(2)} ${unit} ${pct < 0 ? 'lost' : 'gained'}`;

    // Color coding
    if (pct < 0) {
      resultPct.className = 'text-3xl font-bold text-green-600 dark:text-green-400';
    } else if (pct > 0) {
      resultPct.className = 'text-3xl font-bold text-red-600 dark:text-red-400';
    } else {
      resultPct.className = 'text-3xl font-bold text-gray-600 dark:text-gray-400';
    }
  }

  startInput.addEventListener('input', calculate);
  currentInput.addEventListener('input', calculate);
  unitKg.addEventListener('click', () => setUnit('kg'));
  unitLb.addEventListener('click', () => setUnit('lb'));
</script>
