---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';

const units = [
  { value: 'km', label: 'Kilometers (km)', mobileLabel: 'Kms (km)' },
  { value: 'm', label: 'Meters (m)', mobileLabel: 'Mtrs (m)' },
  { value: 'cm', label: 'Centimeters (cm)', mobileLabel: 'Cms (cm)' },
  { value: 'mm', label: 'Millimeters (mm)', mobileLabel: 'Mms (mm)' },
  { value: 'mi', label: 'Miles (mi)', mobileLabel: 'Miles (mi)' },
  { value: 'yd', label: 'Yards (yd)', mobileLabel: 'Yds (yd)' },
  { value: 'ft', label: 'Feet (ft)', mobileLabel: 'Feet (ft)' },
  { value: 'in', label: 'Inches (in)', mobileLabel: 'Ins (in)' },
  { value: 'nmi', label: 'Nautical Miles (nmi)', mobileLabel: 'NM (nmi)' },
];
---

<Layout title="KM to Miles Converter — Free & Instant" description="Fast Length & Distance Converter. Quickly convert inches to cm, miles to km, and feet to meters. Free, 100% accurate, and no sign-up hassle. Try it today!" keywords="km to miles, feet to meters, length converter, inches to cm, miles to km, meter to feet, distance converter, yards to meters, nautical miles">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">📏</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Length & Distance Converter — KM, Miles, Feet, Inches</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of length and distance</p>
      <ConverterBlogLinks />
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" placeholder="Enter value" value="1" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" aria-label="Swap units" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
          Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u) => <option value={u.value} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center truncate">0.621371</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 km = 0.621371 mi</div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300">
            <tr>
              <th class="px-4 py-2 text-left font-medium">Value</th>
              <th class="px-4 py-2 text-left font-medium">Equivalent</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[
              ['1 km', '0.621371 miles'],
              ['1 mile', '1.60934 km'],
              ['1 m', '3.28084 ft'],
              ['1 foot', '0.3048 m'],
              ['1 inch', '2.54 cm'],
              ['1 yard', '0.9144 m'],
              ['1 nautical mile', '1.852 km'],
            ].map(([a, b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td>
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How Do I Convert Length Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Length conversion between metric and imperial systems is needed constantly — for travel, construction, science, and everyday measurements. The metric system (meters, kilometers) is used globally, while miles, feet, and inches remain standard in the US and UK.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Kilometers → Miles</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">Multiply km by 0.621371. Quick shortcut: km × 0.6</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Feet → Meters</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">Multiply feet by 0.3048. 1 foot = 30.48 cm</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Common Length Conversions</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 kilometer = 0.6214 miles = 1000 meters = 3281 feet</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 mile = 1.609 kilometers = 5280 feet = 1760 yards</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 meter = 3.281 feet = 39.37 inches = 100 centimeters</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 inch = 2.54 centimeters (exact)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 nautical mile = 1.852 kilometers = 1.151 miles</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many miles in a kilometer?", "acceptedAnswer": { "@type": "Answer", "text": "1 kilometer equals approximately 0.621371 miles. To convert km to miles, multiply by 0.621371." }},
        { "@type": "Question", "name": "How many feet in a meter?", "acceptedAnswer": { "@type": "Answer", "text": "1 meter equals approximately 3.28084 feet. To convert meters to feet, multiply by 3.28084." }},
        { "@type": "Question", "name": "How many inches in a centimeter?", "acceptedAnswer": { "@type": "Answer", "text": "1 centimeter equals approximately 0.3937 inches. To convert cm to inches, divide by 2.54." }}
      ]
    })} />
  </div>
</Layout>

<script>
  const toM: Record<string, number> = {
    km: 1000, m: 1, cm: 0.01, mm: 0.001,
    mi: 1609.344, yd: 0.9144, ft: 0.3048,
    in: 0.0254, nmi: 1852,
  };

  function convert(val: number, from: string, to: string) {
    return val * toM[from] / toM[to];
  }

  const fromUnit = document.getElementById('from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('to-unit') as HTMLSelectElement;
  const fromVal = document.getElementById('from-value') as HTMLInputElement;
  const resultEl = document.getElementById('result')!;
  const formulaEl = document.getElementById('formula')!;

  function fmt(n: number) {
    return n < 0.0001 || n > 1e9 ? n.toExponential(4) : parseFloat(n.toPrecision(7)).toString();
  }

  function update() {
    const val = parseFloat(fromVal.value);
    if (isNaN(val)) { resultEl.textContent = '—'; return; }
    const res = convert(val, fromUnit.value, toUnit.value);
    resultEl.textContent = fmt(res);
    const f = convert(1, fromUnit.value, toUnit.value);
    formulaEl.textContent = `1 ${fromUnit.value} = ${fmt(f)} ${toUnit.value}`;
  }

  fromVal.addEventListener('input', update);
  fromUnit.addEventListener('change', update);
  toUnit.addEventListener('change', update);
  document.getElementById('swap-btn')!.addEventListener('click', () => {
    const tmp = fromUnit.value; fromUnit.value = toUnit.value; toUnit.value = tmp; update();
  });
  toUnit.value = 'mi';
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
