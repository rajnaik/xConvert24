---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';

const units = [
  { value: 'g', label: 'Grams (g)' },
  { value: 'kg', label: 'Kilograms (kg)' },
  { value: 'ozt', label: 'Troy Ounces (oz t)' },
  { value: 'ct', label: 'Carats (ct)' },
  { value: 'dwt', label: 'Pennyweights (dwt)' },
  { value: 'gr', label: 'Grains (gr)' },
  { value: 'tola', label: 'Tola' },
  { value: 'oz', label: 'Avoirdupois Ounces (oz)' },
];

const table = [
  ['1 Troy Oz', '31.1035 g', '20 dwt', '155.517 ct'],
  ['1 Carat', '0.2 g', '0.00643 oz t', '3.086 gr'],
  ['1 Tola', '11.664 g', '0.375 oz t', ''],
  ['1 Pennyweight', '1.555 g', '0.05 oz t', '7.776 ct'],
  ['1 Grain', '0.0648 g', '0.324 ct', ''],
];
---

<Layout title="Precious Metals Weight Converter — Troy Oz, Carats, Grams" description="Free Precious Metals & Gemstone Weight Converter. Convert troy ounces to grams, carats to grams, pennyweights to troy ounces. Ideal for gold, silver, and gemstone measurements." keywords="troy ounces to grams, carats to grams, gold weight converter, silver weight converter, precious metals converter, dwt to grams, tola to grams, gemstone weight">
  <div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">💎</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Precious Metals Converter</h1>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400 ml-2">NEW</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert between gold, silver & gemstone weight units</p>
      <ConverterBlogLinks />
    </div>

    <!-- Converter card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <!-- From -->
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input
            id="from-value"
            type="number"
            placeholder="Enter value"
            value="1"
            class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
          />
        </div>
      </div>

      <!-- Swap button -->
      <div class="flex justify-center my-3">
        <button id="swap-btn" aria-label="Swap units" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
          Swap
        </button>
      </div>

      <!-- To -->
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 2}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">
            0.03215
          </div>
        </div>
      </div>

      <!-- Formula -->
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">
        1 g = 0.03215 oz t
      </div>
    </div>

    <!-- Quick reference table -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Value</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Equivalent 1</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Equivalent 2</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Equivalent 3</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {table.map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                {row.map(cell => (
                  <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">How to Convert Precious Metal & Gemstone Weights</h2>
        <p class="text-gray-600 dark:text-gray-400">Precious metals like gold and silver use the troy weight system, which differs from the everyday avoirdupois system. A troy ounce (31.1035 g) is heavier than a regular ounce (28.3495 g). Gemstones use carats, where 1 carat equals exactly 0.2 grams.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Troy Ounces to Grams</h3>
        <p class="text-gray-600 dark:text-gray-400">Multiply troy ounces by 31.1035 to get grams. Gold and silver prices are always quoted per troy ounce. For example, if gold is $2,000/oz t, that's $2,000 per 31.1 grams.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Carats to Grams</h3>
        <p class="text-gray-600 dark:text-gray-400">Multiply carats by 0.2 to get grams (or divide grams by 0.2 to get carats). A 1-carat diamond weighs exactly 200 milligrams. The carat system was standardized in 1907.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Common Precious Metal Conversions</h3>
        <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1">
          <li>1 troy ounce = 31.1035 grams = 20 pennyweights = 480 grains</li>
          <li>1 carat = 0.2 grams = 200 milligrams</li>
          <li>1 tola (Indian gold unit) = 11.664 grams = 0.375 troy ounces</li>
          <li>1 pennyweight = 1.555 grams = 24 grains</li>
          <li>1 troy pound = 12 troy ounces = 373.242 grams</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Conversion factors to grams (base unit)
  const toGrams: Record<string, number> = {
    g: 1,
    kg: 1000,
    ozt: 31.1034768,    // Troy ounce
    ct: 0.2,            // Carat
    dwt: 1.55517384,    // Pennyweight
    gr: 0.06479891,     // Grain
    tola: 11.6638038,   // Tola (Indian)
    oz: 28.3495231,     // Avoirdupois ounce
  };

  function convert(val: number, from: string, to: string): number {
    if (from === to) return val;
    return val * toGrams[from] / toGrams[to];
  }

  function getFormula(from: string, to: string): string {
    if (from === to) return `1 ${from} = 1 ${from}`;
    const factor = convert(1, from, to);
    const f = factor < 0.001 ? factor.toExponential(4) : parseFloat(factor.toPrecision(6)).toString();
    return `1 ${from} = ${f} ${to}`;
  }

  const fromUnit = document.getElementById('from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('to-unit') as HTMLSelectElement;
  const fromVal = document.getElementById('from-value') as HTMLInputElement;
  const resultEl = document.getElementById('result')!;
  const formulaEl = document.getElementById('formula')!;
  const swapBtn = document.getElementById('swap-btn')!;

  function update() {
    const val = parseFloat(fromVal.value);
    if (isNaN(val)) { resultEl.textContent = '—'; return; }
    const result = convert(val, fromUnit.value, toUnit.value);
    const disp = result < 0.0001 || result > 1e9
      ? result.toExponential(4)
      : parseFloat(result.toPrecision(7)).toString();
    resultEl.textContent = disp;
    formulaEl.textContent = getFormula(fromUnit.value, toUnit.value);
  }

  fromVal.addEventListener('input', update);
  fromUnit.addEventListener('change', update);
  toUnit.addEventListener('change', update);
  swapBtn.addEventListener('click', () => {
    const tmp = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = tmp;
    update();
  });

  update();
</script>
