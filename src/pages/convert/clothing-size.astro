---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Clothing Size Converter — US, UK, EU, Asia" description="Convert clothing sizes between US, UK, EU, and Asian sizing. Covers tops, trousers waist, and letter sizes (XS to XXL)." keywords="clothing size converter, US to EU size, dress size, trouser waist size, XS S M L XL XXL, garment size chart, international clothing sizes">
  <div class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">👔</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Clothing Size Converter</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert clothing sizes across US, UK, EU, and Asian standards</p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-5">
      <button id="tab-tops" class="flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-amber-500 bg-amber-500 text-white transition-colors">Tops / Shirts</button>
      <button id="tab-trousers" class="flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:border-amber-400 transition-colors">Trousers / Waist</button>
    </div>

    <!-- Tops / Upper body -->
    <div id="section-tops" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm mb-6">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Tops / Shirts / Jackets</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Letter sizes with international equivalents</p>
      </div>

      <!-- Gender toggle -->
      <div class="px-6 pt-4 flex gap-2">
        <button id="tops-men" class="px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-amber-500 bg-amber-500 text-white">Men</button>
        <button id="tops-women" class="px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300">Women</button>
      </div>

      <div class="overflow-x-auto p-4">
        <table class="w-full text-sm" id="tops-table">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Letter</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇺🇸 US</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇬🇧 UK</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇪🇺 EU</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇯🇵 Asia</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Chest (cm)</th>
            </tr>
          </thead>
          <tbody id="tops-body" class="divide-y divide-gray-100 dark:divide-gray-800"></tbody>
        </table>
      </div>
    </div>

    <!-- Trousers / Waist -->
    <div id="section-trousers" class="hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm mb-6">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Trousers / Pants Waist Size</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Waist measurements with international equivalents</p>
      </div>

      <div class="px-6 pt-4 flex gap-2">
        <button id="trs-men" class="px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-amber-500 bg-amber-500 text-white">Men</button>
        <button id="trs-women" class="px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300">Women</button>
      </div>

      <div class="overflow-x-auto p-4">
        <table class="w-full text-sm" id="trousers-table">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Waist (in)</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Waist (cm)</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇺🇸 US</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇬🇧 UK</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">🇪🇺 EU</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Letter</th>
            </tr>
          </thead>
          <tbody id="trousers-body" class="divide-y divide-gray-100 dark:divide-gray-800"></tbody>
        </table>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="prose dark:prose-invert prose-sm max-w-none mt-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Understanding International Clothing Sizes</h2>
      <p class="text-gray-600 dark:text-gray-400">Clothing sizes vary significantly between countries. A US size 8 is a UK size 12 and an EU size 38. Asian sizes tend to run 1-2 sizes smaller than Western equivalents. Always check the specific brand's size chart when possible, as sizing can vary between manufacturers.</p>
      <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Letter Sizes</h3>
      <p class="text-gray-600 dark:text-gray-400">XS (Extra Small), S (Small), M (Medium), L (Large), XL (Extra Large), and XXL (Double Extra Large) are universal letter designations, but the actual measurements they correspond to differ between brands and regions.</p>
    </div>
  </div>
</Layout>

<script>
  // Men's tops data
  const menTops = [
    { letter: 'XS', us: '34', uk: '34', eu: '44', asia: 'S', chest: '86-89' },
    { letter: 'S', us: '36', uk: '36', eu: '46', asia: 'M', chest: '89-94' },
    { letter: 'M', us: '38-40', uk: '38-40', eu: '48-50', asia: 'L', chest: '94-99' },
    { letter: 'L', us: '42-44', uk: '42-44', eu: '52-54', asia: 'XL', chest: '99-104' },
    { letter: 'XL', us: '46-48', uk: '46-48', eu: '56-58', asia: 'XXL', chest: '104-112' },
    { letter: 'XXL', us: '50-52', uk: '50-52', eu: '60-62', asia: '3XL', chest: '112-119' },
  ];

  const womenTops = [
    { letter: 'XS', us: '0-2', uk: '4-6', eu: '32-34', asia: 'S', chest: '76-81' },
    { letter: 'S', us: '4-6', uk: '8-10', eu: '36-38', asia: 'M', chest: '81-86' },
    { letter: 'M', us: '8-10', uk: '12-14', eu: '40-42', asia: 'L', chest: '86-94' },
    { letter: 'L', us: '12-14', uk: '16-18', eu: '44-46', asia: 'XL', chest: '94-102' },
    { letter: 'XL', us: '16-18', uk: '20-22', eu: '48-50', asia: 'XXL', chest: '102-112' },
    { letter: 'XXL', us: '20-22', uk: '24-26', eu: '52-54', asia: '3XL', chest: '112-122' },
  ];

  // Men's trousers
  const menTrousers = [
    { waistIn: '28', waistCm: '71', us: '28', uk: '28', eu: '44', letter: 'XS' },
    { waistIn: '30', waistCm: '76', us: '30', uk: '30', eu: '46', letter: 'S' },
    { waistIn: '32', waistCm: '81', us: '32', uk: '32', eu: '48', letter: 'M' },
    { waistIn: '34', waistCm: '86', us: '34', uk: '34', eu: '50', letter: 'M/L' },
    { waistIn: '36', waistCm: '91', us: '36', uk: '36', eu: '52', letter: 'L' },
    { waistIn: '38', waistCm: '97', us: '38', uk: '38', eu: '54', letter: 'XL' },
    { waistIn: '40', waistCm: '102', us: '40', uk: '40', eu: '56', letter: 'XL' },
    { waistIn: '42', waistCm: '107', us: '42', uk: '42', eu: '58', letter: 'XXL' },
    { waistIn: '44', waistCm: '112', us: '44', uk: '44', eu: '60', letter: 'XXL' },
  ];

  const womenTrousers = [
    { waistIn: '24', waistCm: '61', us: '0', uk: '4', eu: '32', letter: 'XS' },
    { waistIn: '25', waistCm: '64', us: '2', uk: '6', eu: '34', letter: 'XS' },
    { waistIn: '26', waistCm: '66', us: '4', uk: '8', eu: '36', letter: 'S' },
    { waistIn: '27', waistCm: '69', us: '6', uk: '10', eu: '38', letter: 'S' },
    { waistIn: '28', waistCm: '71', us: '8', uk: '12', eu: '40', letter: 'M' },
    { waistIn: '29-30', waistCm: '74-76', us: '10', uk: '14', eu: '42', letter: 'M' },
    { waistIn: '31-32', waistCm: '79-81', us: '12', uk: '16', eu: '44', letter: 'L' },
    { waistIn: '33-34', waistCm: '84-86', us: '14', uk: '18', eu: '46', letter: 'L/XL' },
    { waistIn: '35-37', waistCm: '89-94', us: '16-18', uk: '20-22', eu: '48-50', letter: 'XL' },
    { waistIn: '38-40', waistCm: '97-102', us: '20-22', uk: '24-26', eu: '52-54', letter: 'XXL' },
  ];

  let topsMen = true;
  let trsMen = true;

  const active = 'px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-amber-500 bg-amber-500 text-white';
  const inactive = 'px-3 py-1.5 rounded-lg text-xs font-semibold border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300';

  function renderTops() {
    const data = topsMen ? menTops : womenTops;
    document.getElementById('tops-body')!.innerHTML = data.map(r => `
      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
        <td class="px-3 py-2 text-center font-bold text-amber-600 dark:text-amber-400">${r.letter}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.us}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.uk}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.eu}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.asia}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-500 dark:text-gray-400">${r.chest}</td>
      </tr>
    `).join('');
  }

  function renderTrousers() {
    const data = trsMen ? menTrousers : womenTrousers;
    document.getElementById('trousers-body')!.innerHTML = data.map(r => `
      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.waistIn}"</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.waistCm}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.us}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.uk}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${r.eu}</td>
        <td class="px-3 py-2 text-center font-bold text-amber-600 dark:text-amber-400">${r.letter}</td>
      </tr>
    `).join('');
  }

  // Tab switching
  const tabTops = document.getElementById('tab-tops')!;
  const tabTrs = document.getElementById('tab-trousers')!;
  const secTops = document.getElementById('section-tops')!;
  const secTrs = document.getElementById('section-trousers')!;
  const tabActive = 'flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-amber-500 bg-amber-500 text-white transition-colors';
  const tabInactive = 'flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:border-amber-400 transition-colors';

  tabTops.addEventListener('click', () => { tabTops.className = tabActive; tabTrs.className = tabInactive; secTops.classList.remove('hidden'); secTrs.classList.add('hidden'); });
  tabTrs.addEventListener('click', () => { tabTrs.className = tabActive; tabTops.className = tabInactive; secTrs.classList.remove('hidden'); secTops.classList.add('hidden'); });

  // Gender toggles
  document.getElementById('tops-men')!.addEventListener('click', () => { topsMen = true; document.getElementById('tops-men')!.className = active; document.getElementById('tops-women')!.className = inactive; renderTops(); });
  document.getElementById('tops-women')!.addEventListener('click', () => { topsMen = false; document.getElementById('tops-women')!.className = active; document.getElementById('tops-men')!.className = inactive; renderTops(); });
  document.getElementById('trs-men')!.addEventListener('click', () => { trsMen = true; document.getElementById('trs-men')!.className = active; document.getElementById('trs-women')!.className = inactive; renderTrousers(); });
  document.getElementById('trs-women')!.addEventListener('click', () => { trsMen = false; document.getElementById('trs-women')!.className = active; document.getElementById('trs-men')!.className = inactive; renderTrousers(); });

  renderTops();
  renderTrousers();
</script>
