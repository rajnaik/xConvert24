---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
const units = [
  { value: 'b', label: 'Bits (b)' },
  { value: 'B', label: 'Bytes (B)' },
  { value: 'KB', label: 'Kilobytes (KB)' },
  { value: 'MB', label: 'Megabytes (MB)' },
  { value: 'GB', label: 'Gigabytes (GB)' },
  { value: 'TB', label: 'Terabytes (TB)' },
  { value: 'PB', label: 'Petabytes (PB)' },
  { value: 'KiB', label: 'Kibibytes (KiB)' },
  { value: 'MiB', label: 'Mebibytes (MiB)' },
  { value: 'GiB', label: 'Gibibytes (GiB)' },
  { value: 'TiB', label: 'Tebibytes (TiB)' },
];
---
<Layout title="Data Storage Converter — MB to GB, TB to GB" description="Free online data storage converter. Convert between bytes, KB, MB, GB, TB, PB. Supports both SI (decimal) and binary (KiB, MiB, GiB) units." keywords="MB to GB, GB to TB, data storage converter, bytes to KB, TB to GB, file size converter, KiB to MB, digital storage units">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">💾</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Data Storage Converter</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between bytes, kilobytes, megabytes, gigabytes, terabytes and more</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i===4}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i===3}>{u.label}</option>)}
          </select>
          <div id="result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">1024</div>
        </div>
      </div>
      <div id="formula" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 GB = 1024 MB</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">SI vs Binary Units</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-800"><tr><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Unit (SI)</th><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Bytes</th><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Unit (Binary)</th><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Bytes</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 KB','1,000 B','1 KiB','1,024 B'],['1 MB','1,000,000 B','1 MiB','1,048,576 B'],['1 GB','10⁹ B','1 GiB','2³⁰ B'],['1 TB','10¹² B','1 TiB','2⁴⁰ B'],['1 PB','10¹⁵ B','1 PiB','2⁵⁰ B']].map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                {row.map(c => <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{c}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
<script>
  // In bytes
  const toBytes: Record<string,number> = {
    b: 0.125, B: 1,
    KB: 1e3, MB: 1e6, GB: 1e9, TB: 1e12, PB: 1e15,
    KiB: 1024, MiB: 1048576, GiB: 1073741824,
    TiB: 1099511627776
  };
  function fmt(n: number) { return n<0.0001||n>1e15?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toBytes[fu.value]/toBytes[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toBytes[fu.value]/toBytes[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
