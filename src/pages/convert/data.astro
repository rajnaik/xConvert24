---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'b', label: 'Bits (b)', mobileLabel: 'Bits' },
  { value: 'B', label: 'Bytes (B)', mobileLabel: 'B' },
  { value: 'KB', label: 'Kilobytes (KB)', mobileLabel: 'KB' },
  { value: 'MB', label: 'Megabytes (MB)', mobileLabel: 'MB' },
  { value: 'GB', label: 'Gigabytes (GB)', mobileLabel: 'GB' },
  { value: 'TB', label: 'Terabytes (TB)', mobileLabel: 'TB' },
  { value: 'PB', label: 'Petabytes (PB)', mobileLabel: 'PB' },
  { value: 'KiB', label: 'Kibibytes (KiB)', mobileLabel: 'KiB' },
  { value: 'MiB', label: 'Mebibytes (MiB)', mobileLabel: 'MiB' },
  { value: 'GiB', label: 'Gibibytes (GiB)', mobileLabel: 'GiB' },
  { value: 'TiB', label: 'Tebibytes (TiB)', mobileLabel: 'TiB' },
];
---
<Layout title="MB to GB Converter — Free & Accurate" description="Free Data Storage Converter. Convert MB to GB, TB to GB, and more. Accurate binary and decimal results. No sign-up." keywords="MB to GB, GB to TB, data storage converter, bytes to KB, TB to GB, file size converter, KiB to MB, digital storage units">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">💾</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Data Storage Converter — MB, GB, TB, Binary & Decimal</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between bytes, kilobytes, megabytes, gigabytes, terabytes and more</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i===4} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i===3} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">1024</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 GB = 1024 MB</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">SI vs Binary Units</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Unit (SI)</th><th class="px-4 py-2 text-left font-medium">Bytes</th><th class="px-4 py-2 text-left font-medium">Unit (Binary)</th><th class="px-4 py-2 text-left font-medium">Bytes</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 KB','1,000 B','1 KiB','1,024 B'],['1 MB','1,000,000 B','1 MiB','1,048,576 B'],['1 GB','10⁹ B','1 GiB','2³⁰ B'],['1 TB','10¹² B','1 TiB','2⁴⁰ B'],['1 PB','10¹⁵ B','1 PiB','2⁵⁰ B']].map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                {row.map(c => <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{c}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Understanding Data Storage Units</h2>
        <p class="text-gray-600 dark:text-gray-400">Data storage units measure digital information capacity. The confusion between SI decimal units (KB, MB, GB using powers of 1000) and binary units (KiB, MiB, GiB using powers of 1024) is one of the most common sources of misunderstanding in computing.</p>

        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">SI (Decimal)</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">1 GB = 1,000,000,000 bytes. Used by drive manufacturers.</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Binary (IEC)</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">1 GiB = 1,073,741,824 bytes. Used by operating systems.</p>
          </div>
        </div>

        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Common File Sizes</h2>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>A text email ≈ 10-50 KB</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>A high-res photo ≈ 3-8 MB</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>A 3-minute MP3 song ≈ 3-5 MB</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>A 1-hour HD video ≈ 1-3 GB</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>A modern video game ≈ 50-150 GB</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 TB = 1000 GB ≈ 250,000 photos or 500 hours of HD video</span>
          </li>
        </ul>

        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-2">Why Does My 1TB Drive Show Less Than 1000 GB?</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Your operating system uses binary math (1024-based), while drive manufacturers use decimal (1000-based). A 1 TB drive has 1,000,000,000,000 bytes, but your OS divides by 1024 three times, showing roughly 931 GiB instead of 1000 GB.</p>

        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-2">What Is the Difference Between Mbps and MBps?</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Mbps stands for megabits per second, while MBps means megabytes per second. Since 1 byte = 8 bits, divide Mbps by 8 to get MBps. A 100 Mbps internet connection delivers about 12.5 MBps of actual file download speed.</p>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many MB in a GB?", "acceptedAnswer": { "@type": "Answer", "text": "In decimal (SI) units, 1 GB = 1,000 MB. In binary units, 1 GiB = 1,024 MiB. Operating systems typically use binary." }},
        { "@type": "Question", "name": "What is the difference between GB and GiB?", "acceptedAnswer": { "@type": "Answer", "text": "GB (gigabyte) uses decimal math: 1 GB = 1,000,000,000 bytes. GiB (gibibyte) uses binary: 1 GiB = 1,073,741,824 bytes. This is why a 500 GB drive shows ~465 GiB in your OS." }},
        { "@type": "Question", "name": "How many GB in a TB?", "acceptedAnswer": { "@type": "Answer", "text": "1 TB (terabyte) equals 1,000 GB in decimal, or 1 TiB equals 1,024 GiB in binary." }}
      ]
    })} />
  </div>
</Layout>
<script>
  // In bytes
  const toBytes: Record<string,number> = {
    b: 0.125, B: 1,
    KB: 1e3, MB: 1e6, GB: 1e9, TB: 1e12, PB: 1e15,
    KiB: 1024, MiB: 1048576, GiB: 1073741824,
    TiB: 1099511627776
  };
  function fmt(n: number) { return n<0.0001||n>1e15?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toBytes[fu.value]/toBytes[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toBytes[fu.value]/toBytes[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
