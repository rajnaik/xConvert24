---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'pa', label: 'Pascal (Pa)', mobileLabel: 'Pa' },
  { value: 'kpa', label: 'Kilopascal (kPa)', mobileLabel: 'kPa' },
  { value: 'mpa', label: 'Megapascal (MPa)', mobileLabel: 'MPa' },
  { value: 'bar', label: 'Bar', mobileLabel: 'Bar' },
  { value: 'mbar', label: 'Millibar (mbar)', mobileLabel: 'mbar' },
  { value: 'psi', label: 'PSI (lb/in²)', mobileLabel: 'PSI' },
  { value: 'atm', label: 'Atmosphere (atm)', mobileLabel: 'Atm' },
  { value: 'torr', label: 'Torr (mmHg)', mobileLabel: 'Torr' },
  { value: 'inhg', label: 'Inches of Mercury (inHg)', mobileLabel: 'inHg' },
];
---
<Layout title="PSI to Bar Converter — Instant & Free" description="Instant Pressure Converter. Convert PSI to bar, kPa to atm, and more. Free, accurate results in seconds. No sign-up required." keywords="PSI to bar, atm to pascal, pressure converter, bar to PSI, mmHg to kPa, atmosphere to PSI, torr to pascal, pressure unit conversion">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">🔬</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Pressure Converter — PSI, Bar, kPa, atm</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of pressure</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===6} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===5} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">14.696</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 atm = 14.696 psi</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 atm','101,325 Pa / 1.01325 bar / 14.696 psi / 760 mmHg'],['1 bar','100,000 Pa / 0.986923 atm / 14.5038 psi'],['1 psi','6894.76 Pa / 0.0689476 bar / 0.068046 atm'],['1 kPa','1000 Pa / 0.01 bar / 0.145038 psi'],['Sea level pressure','1 atm / 101.325 kPa / 1013.25 mbar']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <!-- How to Convert Pressure -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How Do I Convert Pressure Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Pressure conversion is essential for automotive (tire pressure in PSI), weather (atmospheric pressure in mbar/hPa), diving (ATM), and industrial applications (bar/kPa). The SI unit is Pascal, but PSI, bar, and atm are far more common in everyday use.</p>

        <h3 class="text-lg font-light text-amber-600 dark:text-amber-400 mt-6 mb-1">How Do I Convert PSI to Bar?</h3>
        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Formula</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm font-mono">PSI ÷ 14.5038 = bar</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Example</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">32 PSI ÷ 14.5038 = 2.206 bar</p>
          </div>
        </div>

        <h3 class="text-lg font-light text-amber-600 dark:text-amber-400 mt-6 mb-1">Common Pressure Conversions</h3>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 atmosphere = 101,325 Pa = 14.696 PSI = 1.01325 bar</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 bar = 14.5038 PSI = 100,000 Pa</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Standard tire pressure: 30-35 PSI = 2.07-2.41 bar</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 Torr = 1 mmHg = 133.322 Pa</span>
          </li>
        </ul>

        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-2">What Tyre Pressure Should I Use?</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Check the sticker on your driver's door jamb or fuel filler cap for the manufacturer's recommendation. Most passenger cars use 30-35 PSI (2.1-2.4 bar). Under-inflation increases fuel consumption and tyre wear, while over-inflation reduces grip.</p>

        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-2">How Do I Convert PSI to Bar?</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Divide the PSI value by 14.504 to get bar, or multiply PSI by 0.0689. For example, 32 PSI × 0.0689 = 2.21 bar. European tyre gauges typically display bar, while US gauges show PSI.</p>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many PSI in 1 bar?", "acceptedAnswer": { "@type": "Answer", "text": "1 bar equals approximately 14.5038 PSI. This is a common conversion needed for tire pressure readings between European and US systems." }},
        { "@type": "Question", "name": "What is standard atmospheric pressure?", "acceptedAnswer": { "@type": "Answer", "text": "Standard atmospheric pressure at sea level is 1 atm, which equals 101,325 Pascals, 1.01325 bar, 14.696 PSI, or 760 mmHg (Torr)." }},
        { "@type": "Question", "name": "How do I convert kPa to PSI?", "acceptedAnswer": { "@type": "Answer", "text": "To convert kPa to PSI, divide the value by 6.89476. For example, 200 kPa ÷ 6.89476 = 29.01 PSI." }}
      ]
    })} />
  </div>
<!-- Report a bug · Suggest a feature -->
<div class="mt-6 flex items-center justify-center gap-4 flex-wrap">
  <a href="/report-bug?tool=Pressure+Converter" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 hover:underline font-medium">
    <span aria-hidden="true">🐛</span> Report a bug
  </a>
  <span class="text-gray-300 dark:text-gray-600">|</span>
  <a href="/suggest?title=Pressure+Converter" class="inline-flex items-center gap-1.5 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
    <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
  </a>
</div>
</Layout>
<script>
  // All in Pascal
  const toPa: Record<string,number> = {
    pa:1, kpa:1000, mpa:1e6, bar:100000, mbar:100,
    psi:6894.757293168, atm:101325, torr:133.322387415,
    inhg:3386.389
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toPa[fu.value]/toPa[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toPa[fu.value]/toPa[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
