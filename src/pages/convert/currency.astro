---
import Layout from '../../layouts/Layout.astro';
const currencies = [
  { value: 'USD', label: 'US Dollar (USD)', symbol: '$' },
  { value: 'EUR', label: 'Euro (EUR)', symbol: '€' },
  { value: 'GBP', label: 'British Pound (GBP)', symbol: '£' },
  { value: 'JPY', label: 'Japanese Yen (JPY)', symbol: '¥' },
  { value: 'AUD', label: 'Australian Dollar (AUD)', symbol: 'A$' },
  { value: 'CAD', label: 'Canadian Dollar (CAD)', symbol: 'C$' },
  { value: 'CHF', label: 'Swiss Franc (CHF)', symbol: 'Fr' },
  { value: 'CNY', label: 'Chinese Yuan (CNY)', symbol: '¥' },
  { value: 'INR', label: 'Indian Rupee (INR)', symbol: '₹' },
  { value: 'MXN', label: 'Mexican Peso (MXN)', symbol: 'MX$' },
  { value: 'BRL', label: 'Brazilian Real (BRL)', symbol: 'R$' },
  { value: 'KRW', label: 'South Korean Won (KRW)', symbol: '₩' },
  { value: 'SGD', label: 'Singapore Dollar (SGD)', symbol: 'S$' },
  { value: 'HKD', label: 'Hong Kong Dollar (HKD)', symbol: 'HK$' },
  { value: 'NOK', label: 'Norwegian Krone (NOK)', symbol: 'kr' },
  { value: 'SEK', label: 'Swedish Krona (SEK)', symbol: 'kr' },
  { value: 'NZD', label: 'New Zealand Dollar (NZD)', symbol: 'NZ$' },
];
---
<Layout title="Currency Converter" description="Convert between major world currencies using reference exchange rates.">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">💱</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Currency Converter</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between major world currencies</p>
    </div>

    <div class="mb-4 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-sm text-amber-700 dark:text-amber-400 flex items-start gap-2">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span>These are static reference rates for estimation purposes only. For live trading rates, use a financial service.</span>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {currencies.map(c => <option value={c.value}>{c.label}</option>)}
          </select>
          <input id="from-value" type="number" value="100" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {currencies.map((c, i) => <option value={c.value} selected={i===1}>{c.label}</option>)}
          </select>
          <div id="result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">92.00</div>
        </div>
      </div>
      <div id="formula" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 USD = 0.92 EUR (reference rate)</div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Reference Rates (vs USD)</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-800"><tr><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Currency</th><th class="px-4 py-3 text-left font-medium text-gray-600 dark:text-gray-400">Rate (per USD)</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800" id="rates-table"></tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
<script>
  // Reference rates relative to USD (approximate mid-market rates)
  const rates: Record<string,number> = {
    USD:1, EUR:0.92, GBP:0.79, JPY:149.50, AUD:1.53,
    CAD:1.36, CHF:0.88, CNY:7.24, INR:83.12, MXN:17.15,
    BRL:4.97, KRW:1325, SGD:1.34, HKD:7.82, NOK:10.56,
    SEK:10.42, NZD:1.63
  };

  // Populate reference table
  const tbody = document.getElementById('rates-table')!;
  Object.entries(rates).forEach(([code, rate]) => {
    const tr = document.createElement('tr');
    tr.className = 'hover:bg-gray-50 dark:hover:bg-gray-800/50';
    tr.innerHTML = `<td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-medium">${code}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">${rate}</td>`;
    tbody.appendChild(tr);
  });

  function convert(val: number, from: string, to: string) {
    return val / rates[from] * rates[to];
  }

  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;

  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    const res = convert(v, fu.value, tu.value);
    re.textContent = res.toFixed(2);
    const rate = convert(1, fu.value, tu.value);
    fo.textContent = `1 ${fu.value} = ${rate.toFixed(4)} ${tu.value} (reference rate)`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
