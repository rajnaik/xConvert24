---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'w', label: 'Watts (W)', mobileLabel: 'W' },
  { value: 'kw', label: 'Kilowatts (kW)', mobileLabel: 'kW' },
  { value: 'mw', label: 'Megawatts (MW)', mobileLabel: 'MW' },
  { value: 'hp', label: 'Horsepower (hp)', mobileLabel: 'HP' },
  { value: 'ps', label: 'Metric Horsepower (PS)', mobileLabel: 'PS' },
  { value: 'btuh', label: 'BTU per hour (BTU/hr)', mobileLabel: 'BTU/hr' },
  { value: 'calh', label: 'Calories per second (cal/s)', mobileLabel: 'cal/s' },
  { value: 'ft_lbs', label: 'Foot-pounds/min (ft·lbf/min)', mobileLabel: 'ft·lbf/min' },
];
---
<Layout title="Watts to HP Converter — Fast & Accurate" description="Free Power Converter. Convert watts to horsepower, kW to HP instantly. Accurate results with no sign-up or ads. Try it now!" keywords="watts to horsepower, kW to HP, power converter, horsepower to watts, HP to kW, BTU per hour, power unit conversion">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">🔋</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Power Converter — Watts, HP, kW, BTU/h</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of power</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===3} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===0} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">745.7</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 hp = 745.7 W</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 hp (US)','745.7 W / 0.7457 kW'],['1 PS (metric hp)','735.499 W'],['1 kW','1000 W / 1.341 hp'],['1 BTU/hr','0.29307 W'],['1 MW','1,000 kW / 1,341 hp']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many watts in a horsepower?", "acceptedAnswer": { "@type": "Answer", "text": "1 mechanical horsepower (hp) equals approximately 745.7 watts or 0.7457 kilowatts." }},
        { "@type": "Question", "name": "How do I convert kW to HP?", "acceptedAnswer": { "@type": "Answer", "text": "Multiply the kilowatt value by 1.341 to get horsepower. For example, 100 kW × 1.341 = 134.1 hp." }},
        { "@type": "Question", "name": "What is the difference between HP and PS?", "acceptedAnswer": { "@type": "Answer", "text": "HP (horsepower) is the US/UK unit (745.7 W), while PS (Pferdestärke) is the metric horsepower (735.5 W). 1 HP ≈ 1.014 PS." }}
      ]
    })} />
  </div>
</Layout>
<script>
  // All in Watts
  const toW: Record<string,number> = {
    w:1, kw:1000, mw:1e6, hp:745.69987158227022,
    ps:735.49875, btuh:0.29307107017222, calh:4.184,
    ft_lbs:0.02259696580552
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    re.textContent=fmt(v*toW[fu.value]/toW[tu.value]);
    fo.textContent=`1 ${fu.value} = ${fmt(toW[fu.value]/toW[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
