---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'mpg_us', label: 'MPG (US)' },
  { value: 'mpg_uk', label: 'MPG (UK/Imperial)' },
  { value: 'l100km', label: 'Liters per 100 km (L/100km)' },
  { value: 'kml', label: 'km per Liter (km/L)' },
  { value: 'mpl', label: 'Miles per Liter (mi/L)' },
];
---
<Layout title="MPG to L/100km Converter — Free & Instant" description="Fuel Economy Converter. Convert MPG to L/100km and km/L instantly. Free, accurate, and easy to use. No sign-up required." keywords="MPG to L/100km, fuel economy converter, L/100km to MPG, km per liter, miles per gallon, fuel efficiency, gas mileage converter">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">⛽</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Fuel Economy Converter — MPG, L/100km, km/L</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between fuel efficiency units</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="30" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u,i) => <option value={u.value} selected={i===2}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">7.84</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">30 MPG (US) = 7.84 L/100km</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">MPG (US)</th><th class="px-4 py-2 text-left font-medium">MPG (UK)</th><th class="px-4 py-2 text-left font-medium">L/100km</th><th class="px-4 py-2 text-left font-medium">km/L</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['20','24.0','11.76','8.50'],['25','30.0','9.41','10.63'],['30','36.1','7.84','12.75'],['35','42.1','6.72','14.88'],['40','48.1','5.88','17.00'],['50','60.1','4.70','21.25']].map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                {row.map(c => <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{c}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How do I convert MPG to L/100km?", "acceptedAnswer": { "@type": "Answer", "text": "Divide 235.215 by the MPG value. For example, 30 MPG = 235.215 ÷ 30 = 7.84 L/100km." }},
        { "@type": "Question", "name": "What is a good fuel economy in L/100km?", "acceptedAnswer": { "@type": "Answer", "text": "For petrol cars, 5-8 L/100km is considered good. For diesels, 4-6 L/100km. Hybrids can achieve 3-5 L/100km." }},
        { "@type": "Question", "name": "What is the difference between US MPG and UK MPG?", "acceptedAnswer": { "@type": "Answer", "text": "US gallons are smaller (3.785 liters) than UK/imperial gallons (4.546 liters), so UK MPG figures are always higher for the same vehicle." }}
      ]
    })} />
  </div>
</Layout>
<script>
  // Fuel economy conversions — note: L/100km is inverse to MPG
  // Convert everything through km/L as base
  // mpg_us * 1.60934 / 3.78541 = km/L
  const KML_FACTORS: Record<string, { toKml: (v: number) => number; fromKml: (v: number) => number }> = {
    mpg_us: {
      toKml: (v) => v * 1.6093440 / 3.7854118,
      fromKml: (v) => v * 3.7854118 / 1.6093440,
    },
    mpg_uk: {
      toKml: (v) => v * 1.6093440 / 4.5460900,
      fromKml: (v) => v * 4.5460900 / 1.6093440,
    },
    l100km: {
      toKml: (v) => 100 / v,
      fromKml: (v) => 100 / v,
    },
    kml: {
      toKml: (v) => v,
      fromKml: (v) => v,
    },
    mpl: {
      toKml: (v) => v * 1.6093440,
      fromKml: (v) => v / 1.6093440,
    },
  };

  function fmt(n: number) { return parseFloat(n.toPrecision(5)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)||v<=0){re.textContent='—';return;}
    const kml = KML_FACTORS[fu.value].toKml(v);
    const res = KML_FACTORS[tu.value].fromKml(kml);
    re.textContent=fmt(res);
    const kml1 = KML_FACTORS[fu.value].toKml(1);
    const res1 = KML_FACTORS[tu.value].fromKml(kml1);
    fo.textContent=`1 ${fu.value} = ${fmt(res1)} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
