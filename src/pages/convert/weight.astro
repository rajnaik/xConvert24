---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';

const units = [
  { value: 'kg', label: 'Kilograms (kg)', mobileLabel: 'Kgs' },
  { value: 'g', label: 'Grams (g)', mobileLabel: 'Grams' },
  { value: 'mg', label: 'Milligrams (mg)', mobileLabel: 'Mgs' },
  { value: 'lb', label: 'Pounds (lb)', mobileLabel: 'Lbs' },
  { value: 'oz', label: 'Ounces (oz)', mobileLabel: 'Oz' },
  { value: 'st', label: 'Stones (st)', mobileLabel: 'Stones' },
  { value: 't', label: 'Metric Tonnes (t)', mobileLabel: 'Tonnes' },
  { value: 'ton', label: 'Short Tons (ton)', mobileLabel: 'Tons' },
];

const table = [
  ['1 kg', '2.20462 lb', '1000 g', '35.274 oz'],
  ['1 lb', '0.453592 kg', '453.592 g', '16 oz'],
  ['1 stone', '6.35029 kg', '14 lb', ''],
  ['1 tonne', '1000 kg', '2204.62 lb', ''],
  ['1 oz', '28.3495 g', '0.0625 lb', ''],
];
---

<Layout title="KG to Lbs Converter — Instant & Accurate" description="Online Weight & Mass Converter. Convert kilograms to pounds, grams to ounces, and more instantly. Free, accurate, and easy to use. No sign-up required." keywords="kg to lbs, grams to ounces, weight converter, kilograms to pounds, oz to grams, stones to kg, mass converter, metric to imperial weight">
  <div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">⚖️</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Weight & Mass Converter — KG, Lbs, Grams, Ounces</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of weight and mass</p>
      <ConverterBlogLinks />
    </div>

    <!-- Converter card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 mb-6 shadow-sm overflow-hidden">
      <!-- From -->
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="from-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <input
            id="from-value"
            type="number"
            placeholder="Enter value"
            value="1"
            class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
          />
        </div>
      </div>

      <!-- Swap button -->
      <div class="flex justify-center my-3">
        <button id="swap-btn" aria-label="Swap units" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
          Swap
        </button>
      </div>

      <!-- To -->
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-2 sm:gap-3">
          <select id="to-unit" class="flex-1 min-w-0 h-12 sm:h-13 px-2 sm:px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 3} data-full={u.label} data-short={u.mobileLabel}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 min-w-0 h-12 sm:h-13 px-3 sm:px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">
            2.20462
          </div>
        </div>
      </div>

      <!-- Formula -->
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">
        1 kg = 2.20462 lb
      </div>
    </div>

    <!-- Quick reference table -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300">
            <tr>
              <th class="px-4 py-2 text-left font-medium">Value</th>
              <th class="px-4 py-2 text-left font-medium">Equivalent 1</th>
              <th class="px-4 py-2 text-left font-medium">Equivalent 2</th>
              <th class="px-4 py-2 text-left font-medium">Equivalent 3</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {table.map(row => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                {row.map(cell => (
                  <td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="not-prose text-xl font-light text-amber-600 dark:text-amber-400 border-l-4 border-amber-400 pl-3 mt-10 mb-3">How Do I Convert Weight Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Weight conversion is one of the most common unit conversions in daily life. Whether you're following a recipe from another country, shipping packages internationally, or tracking your fitness goals, knowing how to convert between kilograms, pounds, ounces, and grams is essential.</p>
        
        <h3 class="not-prose text-xl font-light text-amber-600 dark:text-amber-400 border-l-4 border-amber-400 pl-3 mt-10 mb-3">How Do I Convert Kilograms to Pounds?</h3>
        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Formula</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm font-mono">kg × 2.20462 = lbs</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Example</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">5 kg × 2.20462 = 11.02 lbs</p>
          </div>
        </div>
        <p class="text-gray-600 dark:text-gray-400">This conversion factor is based on the international avoirdupois pound definition where 1 lb = 0.45359237 kg exactly.</p>
        
        <h3 class="not-prose text-xl font-light text-amber-600 dark:text-amber-400 border-l-4 border-amber-400 pl-3 mt-10 mb-3">How Do I Convert Grams to Ounces?</h3>
        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Formula</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm font-mono">g ÷ 28.3495 = oz</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Example</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">100 g ÷ 28.3495 = 3.527 oz</p>
          </div>
        </div>
        <p class="text-gray-600 dark:text-gray-400">Ounces are commonly used in recipes in the US and UK for measuring ingredients.</p>
        
        <h3 class="not-prose text-xl font-light text-amber-600 dark:text-amber-400 border-l-4 border-amber-400 pl-3 mt-10 mb-3">Common Weight Conversions</h3>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 kilogram = 2.205 pounds = 35.274 ounces</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 pound = 0.4536 kilograms = 453.6 grams = 16 ounces</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 stone = 6.350 kilograms = 14 pounds</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 metric tonne = 1000 kilograms = 2204.6 pounds</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 ounce = 28.35 grams</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- FAQ Schema for AI/Search -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How many pounds in a kilogram?", "acceptedAnswer": { "@type": "Answer", "text": "1 kilogram equals approximately 2.20462 pounds." }},
      { "@type": "Question", "name": "How do I convert grams to ounces?", "acceptedAnswer": { "@type": "Answer", "text": "Divide the gram value by 28.3495 to get ounces. For example, 100 grams = 3.527 ounces." }},
      { "@type": "Question", "name": "What is a stone in kilograms?", "acceptedAnswer": { "@type": "Answer", "text": "1 stone equals 6.35029 kilograms or 14 pounds." }}
    ]
  })}></script>
</Layout>

<script>
  // Conversion factors to kilograms (base unit)
  const toKg: Record<string, number> = {
    kg: 1,
    g: 0.001,
    mg: 0.000001,
    lb: 0.45359237,
    oz: 0.028349523125,
    st: 6.35029318,
    t: 1000,
    ton: 907.18474,
  };

  function convert(val: number, from: string, to: string): number {
    if (from === to) return val;
    return val * toKg[from] / toKg[to];
  }

  function getFormula(from: string, to: string): string {
    if (from === to) return `1 ${from} = 1 ${from}`;
    const factor = convert(1, from, to);
    const f = factor < 0.001 ? factor.toExponential(4) : parseFloat(factor.toPrecision(6)).toString();
    return `1 ${from} = ${f} ${to}`;
  }

  const fromUnit = document.getElementById('from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('to-unit') as HTMLSelectElement;
  const fromVal = document.getElementById('from-value') as HTMLInputElement;
  const resultEl = document.getElementById('result')!;
  const formulaEl = document.getElementById('formula')!;
  const swapBtn = document.getElementById('swap-btn')!;

  function update() {
    const val = parseFloat(fromVal.value);
    if (isNaN(val)) { resultEl.textContent = '—'; return; }
    const result = convert(val, fromUnit.value, toUnit.value);
    const disp = result < 0.0001 || result > 1e9
      ? result.toExponential(4)
      : parseFloat(result.toPrecision(7)).toString();
    resultEl.textContent = disp;
    formulaEl.textContent = getFormula(fromUnit.value, toUnit.value);
  }

  fromVal.addEventListener('input', update);
  fromUnit.addEventListener('change', update);
  toUnit.addEventListener('change', update);
  swapBtn.addEventListener('click', () => {
    const tmp = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = tmp;
    update();
  });

  update();
</script>

<script is:inline>
  // Swap select option labels for mobile vs desktop
  (function() {
    var mql = window.matchMedia('(max-width: 639px)');
    function swapLabels(isMobile) {
      var selects = document.querySelectorAll('#from-unit, #to-unit');
      selects.forEach(function(sel) {
        var opts = sel.querySelectorAll('option');
        opts.forEach(function(opt) {
          opt.textContent = isMobile ? (opt.dataset.short || opt.dataset.full) : opt.dataset.full;
        });
      });
    }
    swapLabels(mql.matches);
    mql.addEventListener('change', function(e) { swapLabels(e.matches); });
  })();
</script>
