---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import ConverterBlogLinks from '../../components/ConverterBlogLinks.astro';
const units = [
  { value: 'm2', label: 'Square Meters (m²)' },
  { value: 'km2', label: 'Square Kilometers (km²)' },
  { value: 'cm2', label: 'Square Centimeters (cm²)' },
  { value: 'mm2', label: 'Square Millimeters (mm²)' },
  { value: 'ft2', label: 'Square Feet (ft²)' },
  { value: 'in2', label: 'Square Inches (in²)' },
  { value: 'yd2', label: 'Square Yards (yd²)' },
  { value: 'mi2', label: 'Square Miles (mi²)' },
  { value: 'ha', label: 'Hectares (ha)' },
  { value: 'ac', label: 'Acres (ac)' },
];
---
<Layout title="Square Meters to Feet Converter — Free & Fast" description="Free Online Area Converter. Easily switch between square feet, meters, acres, and more. Get instant, accurate results for all your area calculations. No ads." keywords="square meters to square feet, hectares to acres, area converter, m2 to ft2, acres to hectares, square miles to km2, land area conversion">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">📐</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Area Converter — m², ft², Hectares, Acres</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Convert between units of area</p>
      <ConverterBlogLinks />
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="mb-4">
        <label for="from-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map(u => <option value={u.value}>{u.label}</option>)}
          </select>
          <input id="from-value" type="number" value="1" class="flex-1 h-13 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
      <div class="flex justify-center my-3">
        <button id="swap-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 font-medium text-sm transition-colors border border-amber-200 dark:border-amber-800">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>Swap
        </button>
      </div>
      <div class="mb-4">
        <label for="to-unit" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">To</label>
        <div class="flex gap-3">
          <select id="to-unit" class="flex-1 h-13 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            {units.map((u, i) => <option value={u.value} selected={i === 4}>{u.label}</option>)}
          </select>
          <div id="result" role="status" aria-live="polite" aria-label="Conversion result" class="flex-1 h-13 px-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-amber-700 dark:text-amber-400 text-lg font-semibold flex items-center">10.7639</div>
        </div>
      </div>
      <div id="formula" aria-live="polite" class="mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400 font-mono">1 m² = 10.7639 ft²</div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800"><h2 class="font-semibold text-gray-900 dark:text-white">Quick Reference</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300"><tr><th class="px-4 py-2 text-left font-medium">Value</th><th class="px-4 py-2 text-left font-medium">Equivalent</th></tr></thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {[['1 m²','10.7639 ft²'],['1 ft²','0.092903 m²'],['1 hectare','10,000 m² / 2.47105 acres'],['1 acre','4046.86 m² / 0.404686 ha'],['1 km²','100 ha / 0.386102 mi²'],['1 mi²','2.58999 km²']].map(([a,b]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{a}</td><td class="px-4 py-3 text-gray-700 dark:text-gray-300 font-mono">{b}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- How to Convert Area -->
    <div class="mt-8 space-y-6">
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">How Do I Convert Area Units?</h2>
        <p class="text-gray-600 dark:text-gray-400">Area conversion is essential for real estate, agriculture, construction, and land surveying. The metric system uses square meters and hectares, while the imperial system uses square feet, acres, and square miles.</p>

        <h3 class="text-lg font-light text-amber-600 dark:text-amber-400 mt-6 mb-1">How Do I Convert Square Meters to Square Feet?</h3>
        <div class="not-prose grid gap-3 sm:grid-cols-2 my-6">
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Formula</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm font-mono">m² × 10.7639 = ft²</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mb-1">Example</p>
            <p class="text-gray-700 dark:text-gray-300 text-sm">150 m² × 10.7639 = 1,614.6 ft²</p>
          </div>
        </div>

        <h3 class="text-lg font-light text-amber-600 dark:text-amber-400 mt-6 mb-1">Common Area Conversions</h3>
        <ul class="not-prose space-y-2 my-6">
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 hectare = 10,000 m² = 2.471 acres</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 acre = 4,047 m² = 43,560 ft²</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>1 square mile = 640 acres = 2.59 km²</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="text-green-500 mt-0.5 shrink-0">▶</span>
            <span>Average house plot: 400-800 m² (4,300-8,600 ft²)</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many square feet in a square meter?", "acceptedAnswer": { "@type": "Answer", "text": "1 square meter equals approximately 10.764 square feet." }},
        { "@type": "Question", "name": "How many acres in a hectare?", "acceptedAnswer": { "@type": "Answer", "text": "1 hectare equals approximately 2.471 acres." }},
        { "@type": "Question", "name": "How do I convert square meters to square feet?", "acceptedAnswer": { "@type": "Answer", "text": "Multiply the square meter value by 10.764 to get square feet. For example, 50 m² × 10.764 = 538.2 ft²." }}
      ]
    })} />
  </div>
</Layout>
<script>
  const toM2: Record<string,number> = {
    m2:1, km2:1e6, cm2:1e-4, mm2:1e-6,
    ft2:0.09290304, in2:6.4516e-4, yd2:0.83612736,
    mi2:2589988.110336, ha:10000, ac:4046.8564224
  };
  function fmt(n: number) { return n<0.0001||n>1e9?n.toExponential(4):parseFloat(n.toPrecision(7)).toString(); }
  const fu=document.getElementById('from-unit') as HTMLSelectElement;
  const tu=document.getElementById('to-unit') as HTMLSelectElement;
  const fv=document.getElementById('from-value') as HTMLInputElement;
  const re=document.getElementById('result')!;
  const fo=document.getElementById('formula')!;
  function update(){
    const v=parseFloat(fv.value); if(isNaN(v)){re.textContent='—';return;}
    const r=v*toM2[fu.value]/toM2[tu.value];
    re.textContent=fmt(r);
    fo.textContent=`1 ${fu.value} = ${fmt(toM2[fu.value]/toM2[tu.value])} ${tu.value}`;
  }
  fv.addEventListener('input',update);fu.addEventListener('change',update);tu.addEventListener('change',update);
  document.getElementById('swap-btn')!.addEventListener('click',()=>{const t=fu.value;fu.value=tu.value;tu.value=t;update();});
  update();
</script>
