---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Shoe Size Converter — US, UK, EU, Asia" description="Convert shoe sizes between US, UK, EU, and Asian sizing for men and women. Free instant shoe size chart." keywords="shoe size converter, US to EU shoe size, UK shoe size, Asian shoe size, men shoe size, women shoe size chart">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">👟</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Shoe Size Converter</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Convert shoe sizes between US, UK, EU, and Asian systems for men and women</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <!-- Gender toggle -->
      <div class="flex gap-2 mb-5">
        <button id="btn-men" class="flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-amber-500 bg-amber-500 text-white transition-colors">Men</button>
        <button id="btn-women" class="flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:border-amber-400 transition-colors">Women</button>
      </div>

      <!-- From -->
      <div class="mb-4">
        <label for="from-region" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">From</label>
        <div class="flex gap-3">
          <select id="from-region" class="flex-1 h-12 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm">
            <option value="us">US</option>
            <option value="uk">UK</option>
            <option value="eu">EU</option>
            <option value="asia">Asia (JP/CN)</option>
          </select>
          <input id="from-size" type="number" step="0.5" min="1" max="50" value="10" class="flex-1 h-12 px-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>

      <!-- Results -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
        <div class="p-3 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-center">
          <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase mb-1">🇺🇸 US</div>
          <div id="res-us" class="text-xl font-bold text-blue-700 dark:text-blue-400 font-mono">10</div>
        </div>
        <div class="p-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-center">
          <div class="text-xs font-semibold text-red-600 dark:text-red-400 uppercase mb-1">🇬🇧 UK</div>
          <div id="res-uk" class="text-xl font-bold text-red-700 dark:text-red-400 font-mono">9.5</div>
        </div>
        <div class="p-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-center">
          <div class="text-xs font-semibold text-green-600 dark:text-green-400 uppercase mb-1">🇪🇺 EU</div>
          <div id="res-eu" class="text-xl font-bold text-green-700 dark:text-green-400 font-mono">44</div>
        </div>
        <div class="p-3 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-center">
          <div class="text-xs font-semibold text-amber-600 dark:text-amber-400 uppercase mb-1">🇯🇵 Asia</div>
          <div id="res-asia" class="text-xl font-bold text-amber-700 dark:text-amber-400 font-mono">28</div>
        </div>
      </div>
    </div>

    <!-- Size chart tables -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
        <h2 id="chart-title" class="font-semibold text-gray-900 dark:text-white">Men's Shoe Size Chart</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="size-chart">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">US</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">UK</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">EU</th>
              <th class="px-3 py-2 text-center font-medium text-gray-600 dark:text-gray-400">Asia (cm)</th>
            </tr>
          </thead>
          <tbody id="chart-body" class="divide-y divide-gray-100 dark:divide-gray-800"></tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Men's conversion: US size as base
  // US men → cm: cm = (US + 18) * 10 / 6.5 (approx)
  // Simplified lookup approach
  const menData = [
    { us: 6, uk: 5.5, eu: 39, asia: 24 },
    { us: 6.5, uk: 6, eu: 39.5, asia: 24.5 },
    { us: 7, uk: 6.5, eu: 40, asia: 25 },
    { us: 7.5, uk: 7, eu: 40.5, asia: 25.5 },
    { us: 8, uk: 7.5, eu: 41, asia: 26 },
    { us: 8.5, uk: 8, eu: 42, asia: 26.5 },
    { us: 9, uk: 8.5, eu: 42.5, asia: 27 },
    { us: 9.5, uk: 9, eu: 43, asia: 27.5 },
    { us: 10, uk: 9.5, eu: 44, asia: 28 },
    { us: 10.5, uk: 10, eu: 44.5, asia: 28.5 },
    { us: 11, uk: 10.5, eu: 45, asia: 29 },
    { us: 11.5, uk: 11, eu: 45.5, asia: 29.5 },
    { us: 12, uk: 11.5, eu: 46, asia: 30 },
    { us: 13, uk: 12.5, eu: 47, asia: 31 },
    { us: 14, uk: 13.5, eu: 48, asia: 32 },
  ];

  const womenData = [
    { us: 5, uk: 3, eu: 35.5, asia: 22 },
    { us: 5.5, uk: 3.5, eu: 36, asia: 22.5 },
    { us: 6, uk: 4, eu: 36.5, asia: 23 },
    { us: 6.5, uk: 4.5, eu: 37, asia: 23.5 },
    { us: 7, uk: 5, eu: 37.5, asia: 24 },
    { us: 7.5, uk: 5.5, eu: 38, asia: 24.5 },
    { us: 8, uk: 6, eu: 38.5, asia: 25 },
    { us: 8.5, uk: 6.5, eu: 39, asia: 25.5 },
    { us: 9, uk: 7, eu: 40, asia: 26 },
    { us: 9.5, uk: 7.5, eu: 40.5, asia: 26.5 },
    { us: 10, uk: 8, eu: 41, asia: 27 },
    { us: 10.5, uk: 8.5, eu: 42, asia: 27.5 },
    { us: 11, uk: 9, eu: 42.5, asia: 28 },
    { us: 12, uk: 10, eu: 44, asia: 29 },
  ];

  let isMen = true;
  const fromRegion = document.getElementById('from-region') as HTMLSelectElement;
  const fromSize = document.getElementById('from-size') as HTMLInputElement;
  const btnMen = document.getElementById('btn-men')!;
  const btnWomen = document.getElementById('btn-women')!;
  const chartBody = document.getElementById('chart-body')!;
  const chartTitle = document.getElementById('chart-title')!;

  function getData() { return isMen ? menData : womenData; }

  function convert() {
    const data = getData();
    const region = fromRegion.value;
    const val = parseFloat(fromSize.value);
    if (isNaN(val)) return;

    // Find closest match
    let closest = data[0];
    let minDiff = Infinity;
    data.forEach(row => {
      const diff = Math.abs((row as any)[region] - val);
      if (diff < minDiff) { minDiff = diff; closest = row; }
    });

    document.getElementById('res-us')!.textContent = closest.us.toString();
    document.getElementById('res-uk')!.textContent = closest.uk.toString();
    document.getElementById('res-eu')!.textContent = closest.eu.toString();
    document.getElementById('res-asia')!.textContent = closest.asia.toString();
  }

  function renderChart() {
    const data = getData();
    chartTitle.textContent = (isMen ? "Men's" : "Women's") + " Shoe Size Chart";
    chartBody.innerHTML = data.map(row => `
      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${row.us}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${row.uk}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${row.eu}</td>
        <td class="px-3 py-2 text-center font-mono text-gray-700 dark:text-gray-300">${row.asia}</td>
      </tr>
    `).join('');
  }

  function setGender(men: boolean) {
    isMen = men;
    const active = 'flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-amber-500 bg-amber-500 text-white transition-colors';
    const inactive = 'flex-1 py-2 px-4 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:border-amber-400 transition-colors';
    btnMen.className = men ? active : inactive;
    btnWomen.className = men ? inactive : active;
    convert();
    renderChart();
  }

  btnMen.addEventListener('click', () => setGender(true));
  btnWomen.addEventListener('click', () => setGender(false));
  fromRegion.addEventListener('change', convert);
  fromSize.addEventListener('input', convert);

  convert();
  renderChart();
</script>
