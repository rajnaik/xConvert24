---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="The page you're looking for doesn't exist on xConvert24.com.">
  <div class="flex flex-col items-center justify-center text-center py-16 lg:py-24">
    <!-- Big 404 -->
    <div class="relative mb-6">
      <span class="text-[10rem] lg:text-[14rem] font-black text-gray-100 dark:text-gray-800 leading-none select-none">404</span>
      <span class="absolute inset-0 flex items-center justify-center text-6xl lg:text-7xl">🔍</span>
    </div>

    <!-- Funny tagline -->
    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 dark:text-white mb-3">
      We couldn't convert this URL into a page
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-md mb-2">
      Looks like this unit of measurement hasn't been discovered yet.
    </p>
    <p class="text-sm text-gray-400 dark:text-gray-500 italic mb-8">
      "Error 404: measured in confusion, converted to nowhere."
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-600 transition-colors shadow-sm">
        ← Back to Home
      </a>
      <a href="/search" class="px-6 py-3 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-semibold hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors border border-gray-200 dark:border-gray-700">
        Search Converters
      </a>
    </div>

    <!-- Fun facts -->
    <div class="mt-12 p-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 max-w-sm text-left shadow-sm">
      <div class="text-xs font-semibold text-amber-600 dark:text-amber-400 uppercase tracking-wide mb-2">While you're here…</div>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        Did you know? 404 seconds = 6 minutes and 44 seconds. Also, 404 grams ≈ 0.89 pounds. 
        <span class="text-gray-400 dark:text-gray-500">Now you know two conversions for free.</span>
      </p>
    </div>
  </div>
</Layout>
