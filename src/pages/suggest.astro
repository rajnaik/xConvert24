---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Suggest a Conversion" description="Suggest a new converter or tool for xConvert24.com. Tell us what you need and we'll consider building it." keywords="suggest conversion, feature request, new tool, request converter, xConvert24 suggestion">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">💡</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Suggest a Conversion</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">What converter or tool would you like us to add? Your suggestions shape what we build next.</p>
      <a href="/suggestions" class="inline-flex items-center gap-1.5 mt-2 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
        ⭐ View & rate all suggestions →
      </a>
    </div>

    <!-- Suggestion form -->
    <div id="suggest-form-section" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <form id="suggest-form" class="space-y-5">
        <div>
          <label for="sug-title" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">What would you like us to add?</label>
          <input id="sug-title" type="text" required placeholder="e.g. Shoe size converter, Timezone converter, Percentage calculator…" class="w-full h-12 px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>

        <div>
          <label for="sug-category" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Category</label>
          <input id="sug-category" type="text" placeholder="e.g. Measurement, Finance, Health, Digital, Time…" class="w-full h-12 px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>

        <div>
          <label for="sug-desc" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Tell us more (optional)</label>
          <textarea id="sug-desc" rows="3" placeholder="What units should it include? What problem does it solve for you?" class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 resize-y"></textarea>
        </div>

        <button type="submit" class="w-full h-12 rounded-lg bg-amber-500 text-white font-semibold hover:bg-amber-600 transition-colors flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Submit Suggestion
        </button>
      </form>

      <!-- Success -->
      <div id="suggest-success" class="hidden text-center py-8">
        <div class="text-4xl mb-3">💡✅</div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Suggestion submitted!</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-4">Thank you — others can now vote on it.</p>
        <div class="flex justify-center gap-3">
          <button id="suggest-another" class="px-5 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-sm">Submit another</button>
          <a href="/suggestions" class="px-5 py-2 rounded-lg bg-amber-500 text-white font-medium hover:bg-amber-600 transition-colors text-sm">View all suggestions</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('suggest-form') as HTMLFormElement;
  const successEl = document.getElementById('suggest-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = (document.getElementById('sug-title') as HTMLInputElement).value.trim();
    const category = (document.getElementById('sug-category') as HTMLInputElement).value.trim();
    const description = (document.getElementById('sug-desc') as HTMLTextAreaElement).value.trim();
    if (!title) return;

    try {
      const res = await fetch('/api/suggestions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, category, description }),
      });
      if (res.ok) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        alert('Failed to submit. Please try again.');
      }
    } catch { alert('Network error. Please try again.'); }
  });

  document.getElementById('suggest-another')?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    successEl.classList.add('hidden');
  });
</script>
