---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Your Opinion — Should We Add Sign-On?" description="Share your opinion on xConvert24 features. Should we add email sign-on? Your voice shapes our platform's future." keywords="opinion, sign on, email login, xconvert24 features, user feedback">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">💬</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Your Opinion</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Help us shape the future of xConvert24.com. Your voice matters.</p>
    </div>

    <!-- Question Panel -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="flex items-start gap-3 mb-4">
        <span class="text-2xl">🤔</span>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Should www.xConvert24.com enable sign-on using an email?</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Currently, xConvert24 works without any account. We're considering adding optional email sign-on. What do you think?</p>
        </div>
      </div>

      <!-- Voting buttons -->
      <div id="vote-section" class="space-y-3 mt-6">
        <button id="vote-yes" class="w-full flex items-center gap-3 p-4 rounded-xl border-2 border-green-200 dark:border-green-800 hover:border-green-500 dark:hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/10 transition-all text-left">
          <span class="text-2xl">👍</span>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white">Yes, enable email sign-on</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">I'd like to log in and have a persistent profile</p>
          </div>
        </button>
        <button id="vote-no" class="w-full flex items-center gap-3 p-4 rounded-xl border-2 border-red-200 dark:border-red-800 hover:border-red-500 dark:hover:border-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-all text-left">
          <span class="text-2xl">👎</span>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white">No, keep it anonymous</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">I prefer using the site without creating an account</p>
          </div>
        </button>
        <button id="vote-maybe" class="w-full flex items-center gap-3 p-4 rounded-xl border-2 border-amber-200 dark:border-amber-800 hover:border-amber-500 dark:hover:border-amber-500 hover:bg-amber-50 dark:hover:bg-amber-900/10 transition-all text-left">
          <span class="text-2xl">🤷</span>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white">Maybe — only if it's optional</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">I'd try it if I could still use the site without signing in</p>
          </div>
        </button>
      </div>

      <!-- Success message (hidden by default) -->
      <div id="vote-success" class="hidden text-center py-6">
        <div class="text-4xl mb-3">✅</div>
        <p class="text-lg font-semibold text-gray-900 dark:text-white">Thank you for your opinion!</p>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Your response has been recorded. It helps us make better decisions.</p>
      </div>
    </div>

    <!-- Benefits Section -->
    <div class="bg-green-50 dark:bg-green-900/10 rounded-xl border border-green-200 dark:border-green-800 p-6 mb-6">
      <h2 class="text-sm font-semibold text-green-700 dark:text-green-400 uppercase tracking-wider mb-4 flex items-center gap-2">
        <span>✅</span> Benefits of Email Sign-On
      </h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Sync across devices</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Your ConvertCoins, bookmarks, and streak would follow you from phone to laptop</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Never lose your progress</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Clearing browser data or switching browsers won't reset your coins and streak</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Conversion history</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Review past conversions and quickly redo frequent ones</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Personalised experience</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Favourite converters and preferred units remembered automatically</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Community identity</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Your bug reports, feature suggestions, and votes tied to your profile</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Future features unlock</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Custom dashboards, shared lists, team workspaces, and coin redemption</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Risks Section -->
    <div class="bg-red-50 dark:bg-red-900/10 rounded-xl border border-red-200 dark:border-red-800 p-6 mb-6">
      <h2 class="text-sm font-semibold text-red-700 dark:text-red-400 uppercase tracking-wider mb-4 flex items-center gap-2">
        <span>⚠️</span> Potential Risks
      </h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <span class="text-red-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Email data stored</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Your email address would be stored on our servers (encrypted, never shared with third parties)</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-red-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Potential for spam</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Though we'd never send marketing emails — only transactional (password reset, etc.)</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-red-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Extra friction</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Having to remember a password or go through a login flow before using converters</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-red-600 mt-0.5">•</span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Data breach risk</p>
            <p class="text-xs text-gray-600 dark:text-gray-400">Any stored data is a potential target — though we'd use industry-standard security (bcrypt, HTTPS, etc.)</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Our promise -->
    <div class="bg-amber-50 dark:bg-amber-900/10 rounded-xl border border-amber-200 dark:border-amber-800 p-4">
      <p class="text-sm text-amber-800 dark:text-amber-200">
        <strong>🔒 Our promise:</strong> If we add sign-on, it will always be <strong>optional</strong>. The site will continue to work fully without an account. We'll never gate converter functionality behind a login.
      </p>
    </div>
  </div>
</Layout>

<script>
  function getUid(): string {
    let uid = localStorage.getItem('xconvert24-uid');
    if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem('xconvert24-uid', uid); }
    return uid;
  }

  const OPINION_KEY = 'xconvert24-opinion-signin';

  function checkAlreadyVoted() {
    const voted = localStorage.getItem(OPINION_KEY);
    if (voted) {
      showSuccess();
    }
  }

  function showSuccess() {
    document.getElementById('vote-section')!.classList.add('hidden');
    document.getElementById('vote-success')!.classList.remove('hidden');
  }

  async function submitVote(response: string) {
    const uid = getUid();
    try {
      await fetch('/api/opinions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          user_id: uid,
          question_id: 'email_signin_2025',
          response: response,
        }),
      });
    } catch {}
    localStorage.setItem(OPINION_KEY, response);
    showSuccess();
  }

  document.getElementById('vote-yes')!.addEventListener('click', () => submitVote('yes'));
  document.getElementById('vote-no')!.addEventListener('click', () => submitVote('no'));
  document.getElementById('vote-maybe')!.addEventListener('click', () => submitVote('maybe'));

  checkAlreadyVoted();
</script>
