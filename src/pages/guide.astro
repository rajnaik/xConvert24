---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { STATS } from '../data/siteStats';
---

<Layout title="How to Use xConvert24" description="Quick guide to using xConvert24. Learn to convert units, use calculators, search tools, and personalise your experience." keywords="how to use, user guide, help, tutorial, conversion guide, xConvert24 help">
  <div class="max-w-3xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">📖</span>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">How to Use xConvert24</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">A quick guide to get the most out of our converters and tools.</p>
    </div>

    <div class="space-y-8">
      <!-- Step 1: Converting units -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">1</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Converting Units</h2>
        </div>
        <ol class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11 list-decimal">
          <li>Pick a converter from the sidebar menu or the homepage grid (e.g. Weight, Length, Temperature).</li>
          <li>Select the <strong>"From"</strong> unit using the dropdown (e.g. Kilograms).</li>
          <li>Enter a number in the input field.</li>
          <li>Select the <strong>"To"</strong> unit (e.g. Pounds).</li>
          <li>The result appears instantly — no need to press a button.</li>
          <li>Click <strong>Swap</strong> to reverse the conversion direction.</li>
        </ol>
        <div class="mt-3 ml-11 p-3 bg-amber-50 dark:bg-amber-900/10 rounded-lg text-xs text-amber-700 dark:text-amber-400">
          💡 <strong>Tip:</strong> The formula is shown below the result so you can see exactly how the calculation works.
        </div>
      </div>

      <!-- Step 2: Using the search -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">2</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Finding What You Need</h2>
        </div>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• Use the <strong>search bar</strong> in the top header — type a unit name, abbreviation, or category (e.g. "kg", "mph", "loan").</li>
          <li>• A dropdown shows matching results instantly. Click one to jump there.</li>
          <li>• Press <kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded text-xs font-mono">/</kbd> on your keyboard to focus the search from anywhere on the site.</li>
          <li>• On mobile, tap the 🔍 icon in the header.</li>
          <li>• The sidebar has a collapsible <strong>treeview</strong> — click a category to expand or collapse it.</li>
        </ul>
      </div>

      <!-- Step 3: Tools -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">3</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Calculators & Tools</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 ml-11 mb-3">Beyond unit conversion, we have specialised calculators:</p>
        <div class="ml-11 grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-600 dark:text-gray-400">
          <div>🔭 <a href="/tools/calculator" class="text-amber-600 dark:text-amber-400 hover:underline">Scientific Calculator</a> — trig, log, powers</div>
          <div>🧍 <a href="/tools/bmi" class="text-amber-600 dark:text-amber-400 hover:underline">BMI Calculator</a> — body mass index</div>
          <div>🎨 <a href="/tools/color" class="text-amber-600 dark:text-amber-400 hover:underline">Color Picker</a> — RGB/HEX/HSL/CMYK</div>
          <div>🏦 <a href="/tools/loan" class="text-amber-600 dark:text-amber-400 hover:underline">Loan Calculator</a> — payments & amortization</div>
          <div>🍽️ <a href="/tools/tip" class="text-amber-600 dark:text-amber-400 hover:underline">Tip Calculator</a> — split bills</div>
          <div>🏷️ <a href="/tools/discount" class="text-amber-600 dark:text-amber-400 hover:underline">Discount Calculator</a> — sale prices</div>
          <div>🎂 <a href="/tools/age" class="text-amber-600 dark:text-amber-400 hover:underline">Age Calculator</a> — exact age from DOB</div>
          <div>📅 <a href="/tools/date-diff" class="text-amber-600 dark:text-amber-400 hover:underline">Date Difference</a> — days between dates</div>
          <div>🌍 <a href="/tools/clock" class="text-amber-600 dark:text-amber-400 hover:underline">World Clock</a> — 12 cities live</div>
        </div>
      </div>

      <!-- Step 4: No Signups — Your Identity -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">4</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">No Signups — Your Identity</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 ml-11 mb-3">xConvert24 never asks you to create an account. Instead, the first time you visit, a unique anonymous User ID is generated and stored in your browser's localStorage. This ID links your ConvertCoins balance, streaks, favourites, and votes to you — without an email, password, or any personal information.</p>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• <strong>How it works:</strong> Your User ID (e.g. <code class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded text-xs font-mono">u_m2k8f3x9ab</code>) is auto-generated on first visit and saved locally in your browser. All your activity is tied to this ID on our server.</li>
          <li>• <strong>Download your ID (🆔 button):</strong> In the footer toolbar, click the indigo <strong>🆔</strong> button to download a small text file containing your User ID. Keep this file safe — it's your backup if you ever clear your browser or switch devices.</li>
          <li>• <strong>Relink your ID (🔗 button):</strong> If you moved to a new device or cleared your browser data, click the green <strong>🔗</strong> button in the footer toolbar to restore your identity. You can either upload the text file you previously downloaded, or paste your User ID manually. Once confirmed, your browser is relinked to your existing account — restoring your coins, level, and history.</li>
          <li>• <strong>Clear everything (☢️ button):</strong> The red <strong>☢️</strong> button wipes all localStorage on this device (User ID, favourites, preferences). Use it to start completely fresh. This does <em>not</em> delete your server-side data — you can always relink later.</li>
        </ul>
        <!-- Functional buttons -->
        <div class="mt-4 ml-11 flex flex-wrap items-center gap-3">
          <button id="guide-nuke-btn" type="button" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-red-900/80 border border-red-500 text-red-200 text-sm font-medium cursor-pointer transition-all hover:bg-red-800 hover:border-red-400 hover:shadow-[0_0_8px_rgba(239,68,68,0.5)] active:scale-95" title="Clear all localStorage">
            <span aria-hidden="true">☢️</span> Nuke localStorage
          </button>
          <button id="guide-download-uid-btn" type="button" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-900/80 border border-indigo-500 text-indigo-200 text-sm font-medium cursor-pointer transition-all hover:bg-indigo-800 hover:border-indigo-400 hover:shadow-[0_0_8px_rgba(99,102,241,0.5)] active:scale-95" title="Download your User ID">
            <span aria-hidden="true">🆔</span> Download User ID
          </button>
          <button id="guide-relink-uid-btn" type="button" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald-900/80 border border-emerald-500 text-emerald-200 text-sm font-medium cursor-pointer transition-all hover:bg-emerald-800 hover:border-emerald-400 hover:shadow-[0_0_8px_rgba(16,185,129,0.5)] active:scale-95" title="Relink User ID">
            <span aria-hidden="true">🔗</span> Relink User ID
          </button>
        </div>

        <!-- Relink UID Modal (guide-local) -->
        <div id="guide-relink-modal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/60 backdrop-blur-sm">
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl p-6 w-full max-w-sm mx-4">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">🔗 Relink User ID</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Upload your previously downloaded UID file or paste it manually.</p>
            <label class="block mb-3">
              <span class="text-xs font-medium text-gray-700 dark:text-gray-300">Upload UID file</span>
              <input id="guide-relink-file" type="file" accept=".txt" class="mt-1 block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-emerald-50 file:text-emerald-700 dark:file:bg-emerald-900/30 dark:file:text-emerald-400 hover:file:bg-emerald-100 dark:hover:file:bg-emerald-900/50 file:cursor-pointer" />
            </label>
            <div class="flex items-center gap-2 mb-3">
              <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700"></div>
              <span class="text-xs text-gray-400">or</span>
              <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700"></div>
            </div>
            <label class="block mb-4">
              <span class="text-xs font-medium text-gray-700 dark:text-gray-300">Paste UID manually</span>
              <input id="guide-relink-input" type="text" placeholder="e.g. u_m2k8f3x9ab..." class="mt-1 block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            </label>
            <div class="flex gap-2">
              <button id="guide-relink-confirm" type="button" class="flex-1 py-2 px-4 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium transition-colors cursor-pointer">Relink</button>
              <button id="guide-relink-cancel" type="button" class="flex-1 py-2 px-4 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 text-sm font-medium transition-colors cursor-pointer">Cancel</button>
            </div>
          </div>
        </div>

        <div class="mt-3 ml-11 p-3 bg-amber-50 dark:bg-amber-900/10 rounded-lg text-xs text-amber-700 dark:text-amber-400">
          💡 <strong>Tip:</strong> Download your User ID right after your first visit. If you lose it and clear your browser, there's no way to recover your ConvertCoins balance.
        </div>
      </div>

      <!-- Step 5: Dark mode & bookmarks -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">5</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Personalization</h2>
        </div>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• <strong>Dark / Light mode:</strong> Click the 🌙/☀️ icon in the top-right. Your preference is remembered.</li>
          <li>• <strong>Bookmark pages:</strong> Click the 🔖 icon to save a converter for quick access. Bookmarks are stored in your browser.</li>
          <li>• <strong>Cookie preferences:</strong> Click the 🍪 icon in the bottom-left to manage analytics and marketing cookies.</li>
        </ul>
      </div>

      <!-- Step 6: Help improve xConvert24 -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">6</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Help Improve xConvert24.com</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 ml-11 mb-3">We build this site for you — your feedback shapes what comes next. Here's how you can help:</p>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• <strong>Suggest a new feature:</strong> Got an idea for a new converter or tool? Head to the <a href="/suggest" class="text-amber-600 dark:text-amber-400 hover:underline">Suggest a Feature</a> page and tell us what you'd like to see built.</li>
          <li>• <strong>Vote on suggestions:</strong> Browse features suggested by other users on the <a href="/suggestions" class="text-amber-600 dark:text-amber-400 hover:underline">Community Suggestions</a> page and rate the ones you'd find most useful. The highest-rated ideas get built first.</li>
          <li>• <strong>Share your opinion:</strong> We run polls on important decisions about the site's future. Visit the <a href="/opinion" class="text-amber-600 dark:text-amber-400 hover:underline">Opinion</a> page to cast your vote and help shape xConvert24.</li>
          <li>• <strong>Report a bug:</strong> Click the 🐛 icon in the header to go to the <a href="/report-bug" class="text-amber-600 dark:text-amber-400 hover:underline">Bug Report</a> page, or visit <a href="/vote-bugs" class="text-amber-600 dark:text-amber-400 hover:underline">Vote on Bug Fixes</a> to upvote bugs you want fixed first.</li>
        </ul>
        <div class="mt-3 ml-11 p-3 bg-amber-50 dark:bg-amber-900/10 rounded-lg text-xs text-amber-700 dark:text-amber-400">
          💡 <strong>Tip:</strong> You earn ConvertCoins for suggesting features, voting, and sharing your opinion — check your <a href="/profile" class="underline">Profile</a> to see your rewards.
        </div>
      </div>

      <!-- Step 7: Mobile & Home Screen -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">7</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Mobile Usage</h2>
        </div>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• Tap the ☰ <strong>hamburger menu</strong> (top-left) to open the navigation sidebar.</li>
          <li>• The site is fully responsive — all converters work on phones and tablets.</li>
          <li>• <a href="/install" class="inline-flex items-center gap-1.5 text-amber-600 dark:text-amber-400 hover:underline font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5m0 0l-2-2m2 2l2-2"/></svg>
              Add to Home Screen
            </a> — save xConvert24 to your iOS or Android home screen for instant app-like access. No install needed.</li>
        </ul>
      </div>

      <!-- Step 8: Chat Assistant -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 flex items-center justify-center text-sm font-bold">8</span>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Chat Assistant</h2>
        </div>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 ml-11">
          <li>• Click the 💬 <strong>chat icon</strong> in the top header to open the assistant.</li>
          <li>• Type a question in natural language — e.g. "How do I convert kg to pounds?" or "I need a loan calculator".</li>
          <li>• The assistant searches across all {STATS.unitsIndexed}+ units and tools and gives you direct links.</li>
          <li>• It also answers questions about how to use the site, dark mode, bug reporting, and more.</li>
          <li>• Click a suggested link to jump straight to that converter or tool.</li>
          <li>• Click the ✕ button or anywhere outside the panel to close it.</li>
          <li>• <strong>Tip:</strong> Try asking "help", "FAQ", "how do I use this site", or just type a unit name like "celsius" or "MPG".</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Guide page UID management scripts -->
  <script is:inline>
    // ─── Guide: Nuke localStorage Button ───────────────────────────────────
    (function() {
      var nukeBtn = document.getElementById('guide-nuke-btn');
      if (!nukeBtn) return;
      nukeBtn.addEventListener('click', function() {
        if (confirm('☢️ Nuke all localStorage? This cannot be undone.')) {
          localStorage.clear();
          nukeBtn.style.boxShadow = '0 0 20px rgba(239,68,68,0.8)';
          setTimeout(function() { nukeBtn.style.boxShadow = ''; }, 600);
          alert('💥 localStorage cleared.');
        }
      });
    })();
  </script>

  <script is:inline>
    // ─── Guide: Download User ID Button ────────────────────────────────────
    (function() {
      var dlBtn = document.getElementById('guide-download-uid-btn');
      if (!dlBtn) return;
      dlBtn.addEventListener('click', function() {
        var uid = localStorage.getItem('xconvert24-uid');
        if (!uid) {
          alert('No User ID found. Use the site a bit first so one gets generated.');
          return;
        }
        var blob = new Blob(['xConvert24 User ID\n' + uid + '\n'], { type: 'text/plain' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'xconvert24-uid.txt';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(a.href);
      });
    })();
  </script>

  <script is:inline>
    // ─── Guide: Relink User ID Button ──────────────────────────────────────
    (function() {
      var relinkBtn = document.getElementById('guide-relink-uid-btn');
      var modal = document.getElementById('guide-relink-modal');
      var fileInput = document.getElementById('guide-relink-file');
      var manualInput = document.getElementById('guide-relink-input');
      var confirmBtn = document.getElementById('guide-relink-confirm');
      var cancelBtn = document.getElementById('guide-relink-cancel');
      if (!relinkBtn || !modal) return;

      function openModal() { modal.classList.remove('hidden'); }
      function closeModal() {
        modal.classList.add('hidden');
        if (fileInput) fileInput.value = '';
        if (manualInput) manualInput.value = '';
      }

      relinkBtn.addEventListener('click', openModal);
      cancelBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
      });

      function extractUid(text) {
        var lines = text.trim().split('\n');
        for (var i = lines.length - 1; i >= 0; i--) {
          var line = lines[i].trim();
          if (line && line.toLowerCase() !== 'xconvert24 user id') return line;
        }
        return '';
      }

      if (fileInput) {
        fileInput.addEventListener('change', function() {
          var file = fileInput.files[0];
          if (!file) return;
          var reader = new FileReader();
          reader.onload = function(e) {
            var uid = extractUid(e.target.result);
            if (uid && manualInput) manualInput.value = uid;
          };
          reader.readAsText(file);
        });
      }

      confirmBtn.addEventListener('click', function() {
        var uid = (manualInput.value || '').trim();
        if (!uid) {
          alert('Please upload a file or enter a User ID.');
          return;
        }
        if (uid.length < 8) {
          alert('That doesn\'t look like a valid User ID (too short).');
          return;
        }
        if (confirm('Replace your current User ID with:\n\n' + uid + '\n\nThis will change your identity on this device.')) {
          localStorage.setItem('xconvert24-uid', uid);
          closeModal();
          alert('✅ User ID relinked successfully.');
        }
      });
    })();
  </script>
</Layout>
