---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="MB vs GB Explained Simply"
  description="Data storage units demystified. Understand MB, GB, TB and how they relate to everyday files, photos, and videos."
  keywords="MB vs GB, megabyte gigabyte, data storage units, how big is a GB, file size explained, storage capacity"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Data</span>
      </nav>

      <BlogCrossLinks title="MB vs GB Explained Simply" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-10">June 10, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>3 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        Kilobytes, megabytes, gigabytes, terabytes — data storage units can be confusing. Here is a plain-English guide to what they mean and how they relate to the files you use every day.
      </p>

      <!-- Section: The Scale -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">The Scale</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <div class="space-y-1 text-center font-mono text-sm">
          <p class="text-amber-700 dark:text-amber-400 font-bold text-lg">1 TB = 1,000 GB = 1,000,000 MB</p>
          <p class="text-gray-500 dark:text-gray-400">Each step up is roughly 1,000× larger</p>
        </div>
      </div>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>1 KB</strong> (kilobyte) = 1,000 bytes — a short text message</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>1 MB</strong> (megabyte) = 1,000 KB — a high-quality photo</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>1 GB</strong> (gigabyte) = 1,000 MB — about 250 songs</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>1 TB</strong> (terabyte) = 1,000 GB — about 500 hours of video</span>
        </li>
      </ul>

      <!-- Section: Real-World Examples -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Real-World File Sizes</h2>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">File Type</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Typical Size</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Text email</td>
              <td class="px-4 py-3 text-center font-mono">5-20 KB</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Smartphone photo</td>
              <td class="px-4 py-3 text-center font-mono">3-8 MB</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">MP3 song (4 min)</td>
              <td class="px-4 py-3 text-center font-mono">4-5 MB</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">HD movie (2 hrs)</td>
              <td class="px-4 py-3 text-center font-mono">4-5 GB</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">4K movie (2 hrs)</td>
              <td class="px-4 py-3 text-center font-mono">15-25 GB</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Video game (modern)</td>
              <td class="px-4 py-3 text-center font-mono">50-150 GB</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Data Plans -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Mobile Data Context</h2>
      <p>With a 5 GB mobile data plan, you can approximately:</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Browse 5,000 web pages</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Stream 5 hours of HD video</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Send 10,000 emails</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Listen to 100 hours of music streaming</span>
        </li>
      </ul>

      <!-- Section: Storage vs Speed -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Storage vs Speed: MB vs Mb</h2>
      <p>Watch out for capitalisation:</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>MB</strong> (capital B) = megabyte = storage size</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Mb</strong> (lowercase b) = megabit = speed measurement</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>8 megabits = 1 megabyte</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>So 100 Mbps internet downloads at ~12.5 MB per second</span>
        </li>
      </ul>

      <!-- Converter CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free data converter
          </p>
          <a
            href="/convert/data"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Converter →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
