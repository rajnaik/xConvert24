---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout title="Oven Temperature Guide: Celsius to Fahrenheit for Baking" description="Oven temperature conversion chart for baking. Celsius to Fahrenheit quick reference with gas mark equivalents." keywords="oven temperature, celsius to fahrenheit oven, baking temperature, gas mark conversion, oven conversion chart, cooking temperature, recipe temperature">
  <div class="max-w-3xl">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose">
        <a href="/blog" class="hover:text-amber-600">Blog</a> <span class="mx-1">›</span> <span class="text-gray-600 dark:text-gray-300">Temperature</span>
      </nav>
      <BlogCrossLinks title="Oven Temperature Guide: Celsius to Fahrenheit for Baking" />
      <p class="text-sm text-gray-400 mb-8">June 19, 2025 • 4 min read</p>

      <p>You have found a beautiful recipe online, but the oven temperature is in Celsius and yours displays Fahrenheit (or the other way around). This is one of the most common conversion problems in the kitchen. Here is your complete reference.</p>

      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Oven Temperature Chart</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Very low:</strong> 120°C = 250°F (Gas Mark 1/2)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Low:</strong> 150°C = 300°F (Gas Mark 2)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Moderate:</strong> 160°C = 325°F (Gas Mark 3)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Moderate:</strong> 180°C = 350°F (Gas Mark 4)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Moderately hot:</strong> 190°C = 375°F (Gas Mark 5)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Hot:</strong> 200°C = 400°F (Gas Mark 6)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Hot:</strong> 220°C = 425°F (Gas Mark 7)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Very hot:</strong> 230°C = 450°F (Gas Mark 8)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Extremely hot:</strong> 250°C = 480°F (Gas Mark 9)</span>
        </li>
      </ul>

      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">The Formula</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-5 my-6 not-prose">
        <p class="text-center text-lg font-mono font-bold text-amber-700 dark:text-amber-400">°F = (°C × 9/5) + 32</p>
        <p class="text-center text-lg font-mono font-bold text-amber-700 dark:text-amber-400 mt-1">°C = (°F - 32) × 5/9</p>
      </div>

      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Common Baking Temperatures</h2>
      <p>Most recipes fall into a few standard temperatures:</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Cookies:</strong> 180°C / 350°F — the most common baking temperature</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Cakes:</strong> 160-180°C / 325-350°F</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Bread:</strong> 200-230°C / 400-450°F</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Pizza:</strong> 220-250°C / 425-480°F (as hot as home ovens go)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Meringues:</strong> 100-120°C / 210-250°F (very low and slow)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Roast chicken:</strong> 200°C / 400°F</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Slow roast:</strong> 150°C / 300°F</span>
        </li>
      </ul>

      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Fan Oven Adjustment</h2>
      <p>If your recipe gives a temperature for a conventional oven but you have a fan (convection) oven, reduce the temperature by 20°C (or about 25°F). Fan ovens circulate hot air, cooking food faster and more evenly.</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Recipe says 200°C conventional = use 180°C fan</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Recipe says 180°C conventional = use 160°C fan</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Recipe says 400°F conventional = use 375°F fan</span>
        </li>
      </ul>

      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Tips for Accurate Oven Temperatures</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Get an oven thermometer</strong> — most ovens are off by 10-25°F from what the dial says</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Always preheat</strong> — give your oven at least 10-15 minutes to reach temperature</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Avoid opening the door</strong> — each opening drops temperature by 25°F (14°C)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Know your hot spots</strong> — rotate trays halfway through baking for even results</span>
        </li>
      </ul>

      <div class="border-t border-gray-200 dark:border-gray-800 mt-10 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Try It Now</h3>
        <a href="/convert/temperature" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">Open Temperature Converter →</a>
      </div>
    
      <div class="not-prose mt-8 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl">
        <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">🔗 Try our converter: <a href="/convert/temperature" class="text-amber-600 dark:text-amber-400 font-bold hover:underline">Open Converter →</a></p>
      </div>
    </article>
  </div>
</Layout>
