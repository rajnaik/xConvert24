---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="World Time Zones Explained"
  description="How time zones work, UTC offsets, daylight saving, and tips for scheduling across time zones."
  keywords="time zones explained, UTC offset, GMT, daylight saving time, world clock, time zone converter, international time"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Time</span>
      </nav>

      <BlogCrossLinks title="World Time Zones Explained" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-11">June 11, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>5 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        There are 24 primary time zones spanning the globe, but the reality is far messier — some zones are offset by 30 or 45 minutes, and daylight saving makes it all shift twice a year. Here is how it all works.
      </p>

      <!-- Section: The Basics -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">The Basics: UTC</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <p class="text-center text-xl font-mono font-bold text-amber-700 dark:text-amber-400">
          UTC = Coordinated Universal Time (the global reference)
        </p>
        <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-2">
          All time zones are defined as offsets from UTC (e.g., UTC+5:30)
        </p>
      </div>
      <p>UTC replaced GMT (Greenwich Mean Time) as the international standard. They refer to the same time, but UTC is more precisely defined using atomic clocks.</p>

      <!-- Section: Major Time Zones -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Major Time Zones</h2>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Zone</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">UTC Offset</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Major Cities</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">PST/PDT</td>
              <td class="px-4 py-3 text-center font-mono">-8/-7</td>
              <td class="px-4 py-3">Los Angeles, Vancouver</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">EST/EDT</td>
              <td class="px-4 py-3 text-center font-mono">-5/-4</td>
              <td class="px-4 py-3">New York, Toronto</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">GMT/BST</td>
              <td class="px-4 py-3 text-center font-mono">0/+1</td>
              <td class="px-4 py-3">London, Dublin</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">CET/CEST</td>
              <td class="px-4 py-3 text-center font-mono">+1/+2</td>
              <td class="px-4 py-3">Paris, Berlin</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">IST</td>
              <td class="px-4 py-3 text-center font-mono">+5:30</td>
              <td class="px-4 py-3">Mumbai, Delhi</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">CST (China)</td>
              <td class="px-4 py-3 text-center font-mono">+8</td>
              <td class="px-4 py-3">Beijing, Shanghai</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">JST</td>
              <td class="px-4 py-3 text-center font-mono">+9</td>
              <td class="px-4 py-3">Tokyo, Seoul</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">AEST/AEDT</td>
              <td class="px-4 py-3 text-center font-mono">+10/+11</td>
              <td class="px-4 py-3">Sydney, Melbourne</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Daylight Saving -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Daylight Saving Time</h2>
      <p>About 70 countries observe daylight saving time (DST), shifting clocks forward by one hour in spring and back in autumn:</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Northern hemisphere:</strong> Starts March/April, ends October/November</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Southern hemisphere:</strong> Starts September/October, ends March/April</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Countries that DON'T observe DST:</strong> Japan, China, India, most of Africa, most of Southeast Asia</span>
        </li>
      </ul>

      <!-- Section: Oddities -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Time Zone Oddities</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>India:</strong> One time zone for the entire country (UTC+5:30) despite spanning 2,000+ km east to west</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>China:</strong> One time zone (UTC+8) for a country wider than the continental US</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Nepal:</strong> UTC+5:45 — one of only a few countries with a 45-minute offset</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Kiribati:</strong> UTC+14 — the first place to ring in each new year</span>
        </li>
      </ul>

      <!-- Section: Tips -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Tips for Working Across Time Zones</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Always specify the time zone</strong> when scheduling ("3 PM EST" not just "3 PM")</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Use UTC for coordination</strong> — it never changes with DST</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>World clock apps</strong> let you see multiple zones at a glance</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Calendar apps</strong> automatically convert times when you specify a zone</span>
        </li>
      </ul>

      <!-- Converter CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free time zone tools
          </p>
          <a
            href="/tools/timezone"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Tool →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
