---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="Speed Limits Worldwide: mph vs km/h by Country"
  description="Speed limits worldwide in mph and km/h by country. See which system each country uses and the fastest legal highways."
  keywords="speed limits worldwide, mph vs km/h, speed limit by country, road speed conversion, highway speed limits, fastest speed limits, autobahn speed"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Speed</span>
      </nav>

      <BlogCrossLinks title="Speed Limits Worldwide: mph vs km/h by Country" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-08">June 8, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>5 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        Driving abroad means understanding different speed limit systems. Only a handful of countries use miles per hour — the rest of the world measures speed in kilometres per hour. Here is your guide to speed limits globally.
      </p>

      <!-- Section: The Conversion -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">The Conversion</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <p class="text-center text-xl font-mono font-bold text-amber-700 dark:text-amber-400">
          1 mph = 1.609 km/h | 1 km/h = 0.621 mph
        </p>
        <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-2">
          Quick trick: mph × 1.6 = km/h (or km/h ÷ 1.6 = mph)
        </p>
      </div>

      <!-- Section: Countries That Use mph -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Countries That Use mph</h2>
      <p>Only these nations measure road speed in miles per hour:</p>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>United States</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>United Kingdom</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Myanmar</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Liberia</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>Some Caribbean islands (Bahamas, Cayman Islands)</span>
        </li>
      </ul>
      <p>Every other country uses km/h on road signs.</p>

      <!-- Section: Highway Speed Limits Compared -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Highway Speed Limits Compared</h2>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Country / Road</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Limit</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Converted</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Germany (Autobahn)</td>
              <td class="px-4 py-3 text-center font-mono">No limit</td>
              <td class="px-4 py-3 text-center text-sm text-gray-500">Advisory 130 km/h (81 mph)</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Poland</td>
              <td class="px-4 py-3 text-center font-mono">140 km/h</td>
              <td class="px-4 py-3 text-center font-mono">87 mph</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">France</td>
              <td class="px-4 py-3 text-center font-mono">130 km/h</td>
              <td class="px-4 py-3 text-center font-mono">81 mph</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Italy</td>
              <td class="px-4 py-3 text-center font-mono">130 km/h</td>
              <td class="px-4 py-3 text-center font-mono">81 mph</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">UK</td>
              <td class="px-4 py-3 text-center font-mono">70 mph</td>
              <td class="px-4 py-3 text-center font-mono">113 km/h</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">USA (Texas toll road)</td>
              <td class="px-4 py-3 text-center font-mono">85 mph</td>
              <td class="px-4 py-3 text-center font-mono">137 km/h</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">USA (most interstates)</td>
              <td class="px-4 py-3 text-center font-mono">65-75 mph</td>
              <td class="px-4 py-3 text-center font-mono">105-121 km/h</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Australia (Northern Territory)</td>
              <td class="px-4 py-3 text-center font-mono">130 km/h</td>
              <td class="px-4 py-3 text-center font-mono">81 mph</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">UAE</td>
              <td class="px-4 py-3 text-center font-mono">140 km/h</td>
              <td class="px-4 py-3 text-center font-mono">87 mph</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Japan</td>
              <td class="px-4 py-3 text-center font-mono">100-120 km/h</td>
              <td class="px-4 py-3 text-center font-mono">62-75 mph</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Common Conversions -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Common Speed Limit Conversions</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>30 mph = 48 km/h (residential streets)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>50 km/h = 31 mph (city speed in metric countries)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>60 mph = 97 km/h</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>70 mph = 113 km/h</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>100 km/h = 62 mph</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>120 km/h = 75 mph</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span>130 km/h = 81 mph</span>
        </li>
      </ul>

      <!-- Section: Tips -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Tips for Driving in a Different System</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Most rental cars</strong> show both mph and km/h on the speedometer</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>GPS navigation</strong> can display speed in either unit — switch to match local signs</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Remember key anchors:</strong> 50 km/h in town, 100-130 km/h on highways</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Speed cameras abroad</strong> have zero tolerance for "I didn't understand the sign" excuses</span>
        </li>
      </ul>

      <!-- Converter CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free speed converter
          </p>
          <a
            href="/convert/speed"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Converter →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
