---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="Understanding Tyre Pressure: PSI, Bar & kPa"
  description="What your tyre pressure numbers mean and how to convert between PSI, Bar, and kPa. Includes recommended pressures."
  keywords="tyre pressure, PSI to bar, kPa conversion, tire pressure guide, recommended tyre pressure, PSI bar kPa"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Pressure</span>
      </nav>

      <BlogCrossLinks title="Understanding Tyre Pressure: PSI, Bar & kPa" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-09">June 9, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>4 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        Your car's door sticker says 32 PSI, the gauge at the petrol station reads Bar, and the manual mentions kPa. They all measure the same thing — just in different units. Here is how to make sense of tyre pressure.
      </p>

      <!-- Section: The Three Units -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">The Three Units</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <div class="space-y-2 text-center">
          <p class="text-lg font-mono font-bold text-amber-700 dark:text-amber-400">1 Bar = 14.504 PSI = 100 kPa</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">PSI (US/UK) | Bar (Europe) | kPa (Australia/Science)</p>
        </div>
      </div>

      <!-- Section: Quick Conversions -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Quick Conversions</h2>
      <ul>
        <li><strong>PSI to Bar:</strong> divide by 14.5 (or roughly ÷ 15 for mental math)</li>
        <li><strong>Bar to PSI:</strong> multiply by 14.5</li>
        <li><strong>PSI to kPa:</strong> multiply by 6.895</li>
        <li><strong>Bar to kPa:</strong> multiply by 100</li>
      </ul>

      <!-- Section: Common Tyre Pressures -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Common Tyre Pressures</h2>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Vehicle Type</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">PSI</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Bar</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">kPa</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Small car</td>
              <td class="px-4 py-3 text-center font-mono">30</td>
              <td class="px-4 py-3 text-center font-mono">2.1</td>
              <td class="px-4 py-3 text-center font-mono">207</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Sedan</td>
              <td class="px-4 py-3 text-center font-mono">32</td>
              <td class="px-4 py-3 text-center font-mono">2.2</td>
              <td class="px-4 py-3 text-center font-mono">220</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">SUV</td>
              <td class="px-4 py-3 text-center font-mono">35</td>
              <td class="px-4 py-3 text-center font-mono">2.4</td>
              <td class="px-4 py-3 text-center font-mono">241</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Sports car</td>
              <td class="px-4 py-3 text-center font-mono">36</td>
              <td class="px-4 py-3 text-center font-mono">2.5</td>
              <td class="px-4 py-3 text-center font-mono">248</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Bicycle</td>
              <td class="px-4 py-3 text-center font-mono">80-130</td>
              <td class="px-4 py-3 text-center font-mono">5.5-9.0</td>
              <td class="px-4 py-3 text-center font-mono">552-896</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Why It Matters -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Why Correct Pressure Matters</h2>
      <ul>
        <li><strong>Underinflated:</strong> More fuel consumption, uneven wear on edges, overheating risk</li>
        <li><strong>Overinflated:</strong> Harsh ride, less grip, wear on centre of tread</li>
        <li><strong>Just right:</strong> Best fuel economy, even wear, proper handling</li>
      </ul>
      <p>Check your tyre pressure monthly and always when tyres are cold (before driving). Heat from driving increases pressure readings by 2-4 PSI.</p>

      <!-- Section: Where to Find Your Number -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-1">Where to Find Your Recommended Pressure</h2>
      <ul>
        <li>Driver's door jamb sticker</li>
        <li>Fuel filler cap (some vehicles)</li>
        <li>Owner's manual</li>
        <li>NOT on the tyre sidewall — that number is the maximum, not the recommended pressure</li>
      </ul>

      <!-- Converter CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free pressure converter
          </p>
          <a
            href="/convert/pressure"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Converter →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
