---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="How Much is 1TB of Storage?"
  description="Putting terabytes in real-world perspective. See how many photos, songs, and movies fit in 1TB."
  keywords="1TB storage, terabyte explained, how much is 1TB, storage capacity, photos per TB, movies per TB"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Data</span>
      </nav>

      <BlogCrossLinks title="How Much is 1TB of Storage?" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-16">June 16, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>3 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        "1TB" sounds like a lot — but is it enough for you? Here is what a terabyte actually holds in real-world terms, from photos to games to 4K movies.
      </p>

      <!-- Section: What 1TB Holds -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">What 1TB Actually Holds</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <p class="text-center text-xl font-mono font-bold text-amber-700 dark:text-amber-400">
          1 TB = 1,000 GB = 1,000,000 MB
        </p>
      </div>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Content</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Fits in 1TB</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Smartphone photos (12MP)</td>
              <td class="px-4 py-3 text-center font-mono">~250,000</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">MP3 songs</td>
              <td class="px-4 py-3 text-center font-mono">~200,000</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">HD movies (1080p)</td>
              <td class="px-4 py-3 text-center font-mono">~200</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">4K movies</td>
              <td class="px-4 py-3 text-center font-mono">~40-50</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Word documents</td>
              <td class="px-4 py-3 text-center font-mono">~6.5 million</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Modern video games</td>
              <td class="px-4 py-3 text-center font-mono">~10-20</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Do You Need 1TB? -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Do You Need 1TB?</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Light user</strong> (documents, email, browsing): 256 GB is plenty</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Average user</strong> (photos, some games, streaming): 512 GB works well</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Heavy user</strong> (video editing, large game library, 4K content): 1-2 TB recommended</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Professional</strong> (video production, photography): 2-4+ TB</span>
        </li>
      </ul>

      <!-- Section: Why Your Drive Shows Less -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Why Your 1TB Drive Shows 931 GB</h2>
      <p>Drive manufacturers use decimal (1 TB = 1,000,000,000,000 bytes), but your operating system uses binary (1 TB = 1,099,511,627,776 bytes). The difference means a "1TB" drive shows approximately 931 GB in your file manager. You are not missing any storage — it is just a measurement discrepancy.</p>

      <!-- Section: Storage Costs -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">How Storage Costs Have Fallen</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>1980:</strong> 1 GB cost roughly $100,000</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>2000:</strong> 1 GB cost roughly $10</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>2010:</strong> 1 GB cost roughly $0.10</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Today:</strong> 1 GB costs less than $0.02 (HDD) or $0.05 (SSD)</span>
        </li>
      </ul>

      <!-- Converter CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free data converter
          </p>
          <a
            href="/convert/data"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Converter →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
