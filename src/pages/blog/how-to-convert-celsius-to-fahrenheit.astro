---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout
  title="How to Convert Celsius to Fahrenheit (Formula + Quick Tricks)"
  description="Celsius to Fahrenheit formula, mental math shortcuts, and a temperature chart. Convert any temperature in seconds."
  keywords="celsius to fahrenheit, fahrenheit to celsius, temperature conversion formula, C to F, how to convert temperature"
>
  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Temperature</span>
      </nav>

      <BlogCrossLinks title="How to Convert Celsius to Fahrenheit" />

      <!-- Article Meta -->
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2025-06-04">June 4, 2025</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>4 min read</span>
      </div>

      <!-- Lead Paragraph -->
      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">
        Whether you're travelling to the US, following a recipe, or just checking the weather, knowing how to convert between Celsius and Fahrenheit is a life skill. Here's everything you need.
      </p>

      <!-- Section: The Formula -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">The Formula</h2>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <p class="text-center text-xl font-mono font-bold text-amber-700 dark:text-amber-400">
          °F = (°C × 9/5) + 32
        </p>
        <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-2">
          Or equivalently: °F = (°C × 1.8) + 32
        </p>
      </div>

      <!-- Section: Quick Mental Math Trick -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Quick Mental Math Trick</h2>
      <p>Don't have a calculator? Use this shortcut that gets you within 1-2 degrees:</p>
      <ol>
        <li><strong>Double</strong> the Celsius number</li>
        <li><strong>Subtract 10%</strong> of that result</li>
        <li><strong>Add 32</strong></li>
      </ol>
      <p>
        <strong>Example:</strong> 25°C → 25×2 = 50 → 50−5 = 45 → 45+32 = <strong>77°F</strong> ✓
      </p>

      <!-- Section: Fahrenheit to Celsius -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Going the Other Way: Fahrenheit to Celsius</h2>
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-6 my-6 not-prose shadow-sm">
        <p class="text-center text-xl font-mono font-bold text-blue-700 dark:text-blue-400">
          °C = (°F − 32) × 5/9
        </p>
      </div>
      <p>
        <strong>Example:</strong> 98.6°F → (98.6−32) × 5/9 = 66.6 × 0.556 = <strong>37°C</strong> (body temperature)
      </p>

      <!-- Section: Common Temperatures Reference -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Common Temperatures Reference</h2>
      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Description</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">°C</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">°F</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Water freezes</td>
              <td class="px-4 py-3 text-center font-mono">0</td>
              <td class="px-4 py-3 text-center font-mono">32</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Cool room</td>
              <td class="px-4 py-3 text-center font-mono">18</td>
              <td class="px-4 py-3 text-center font-mono">64</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Comfortable room</td>
              <td class="px-4 py-3 text-center font-mono">22</td>
              <td class="px-4 py-3 text-center font-mono">72</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Hot day</td>
              <td class="px-4 py-3 text-center font-mono">35</td>
              <td class="px-4 py-3 text-center font-mono">95</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Body temperature</td>
              <td class="px-4 py-3 text-center font-mono">37</td>
              <td class="px-4 py-3 text-center font-mono">98.6</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Fever</td>
              <td class="px-4 py-3 text-center font-mono">39</td>
              <td class="px-4 py-3 text-center font-mono">102</td>
            </tr>
            <tr class="bg-white dark:bg-gray-900">
              <td class="px-4 py-3">Water boils</td>
              <td class="px-4 py-3 text-center font-mono">100</td>
              <td class="px-4 py-3 text-center font-mono">212</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="px-4 py-3">Oven (moderate)</td>
              <td class="px-4 py-3 text-center font-mono">180</td>
              <td class="px-4 py-3 text-center font-mono">356</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section: Why Two Systems? -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Why Two Systems?</h2>
      <p>
        Celsius (also called Centigrade) is based on water: 0° = freezing, 100° = boiling. It's used by every country except the US, Liberia, and Myanmar.
      </p>
      <p>
        Fahrenheit was created earlier (1724) by Daniel Fahrenheit. In his scale, 0° was the coldest temperature he could create in a lab, and 96° was body temperature (later refined to 98.6°).
      </p>

      <!-- Section: When Does It Matter? -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">When Does It Matter?</h2>
      <ul class="not-prose space-y-2 my-4">
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Cooking:</strong> US recipes use °F, European ones use °C</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Weather:</strong> "It's 100°F" sounds extreme to a European (it's 38°C)</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Medicine:</strong> A fever is 38°C / 100.4°F — know both</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
          <span class="text-green-500 mt-0.5 shrink-0">▶</span>
          <span><strong>Science:</strong> Always Celsius (or Kelvin)</span>
        </li>
      </ul>

      <!-- Section: Try It Now -->
      <h2 class="flex items-center gap-3 border-l-4 border-amber-400 pl-4">Try It Now</h2>
      <p>
        Use our <a href="/convert/temperature" class="text-amber-600 dark:text-amber-400 font-semibold hover:underline">Temperature Converter</a> for instant, accurate conversions between Celsius, Fahrenheit, and Kelvin.
      </p>

      <!-- Related Articles -->
      <aside class="border-t border-gray-200 dark:border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">
          Related Articles
        </h3>
        <div class="grid gap-3">
          <a
            href="/blog/kg-to-lbs-conversion-guide"
            class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group"
          >
            <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
              Kilograms to Pounds: The Complete Conversion Guide
            </span>
          </a>
          <a
            href="/blog/metric-vs-imperial-which-countries"
            class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group"
          >
            <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
              Metric vs Imperial: Which Countries Use Which System?
            </span>
          </a>
        </div>
      </aside>

      <!-- Converter CTA -->
      <div class="not-prose mt-8 p-5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
            🔗 Try our free temperature converter
          </p>
          <a
            href="/convert/temperature"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Converter →
          </a>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">
          ← Back to all articles
        </a>
      </div>
    </article>
  </div>
</Layout>
