---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'how-to-convert-celsius-to-fahrenheit',
    title: 'How to Convert Celsius to Fahrenheit (With Quick Mental Math)',
    excerpt: 'Learn the formula, shortcuts, and when you need each scale. Plus a handy chart for common temperatures.',
    date: 'June 4, 2025',
    readTime: '4 min',
    category: 'Temperature',
    icon: '🌡️',
  },
  {
    slug: 'kg-to-lbs-conversion-guide',
    title: 'Kilograms to Pounds: The Complete Conversion Guide',
    excerpt: 'Everything you need to know about converting kg to lbs — formulas, shortcuts, charts, and real-world examples.',
    date: 'June 4, 2025',
    readTime: '5 min',
    category: 'Weight',
    icon: '⚖️',
  },
  {
    slug: 'metric-vs-imperial-which-countries',
    title: 'Metric vs Imperial: Which Countries Use Which System?',
    excerpt: 'Only 3 countries still officially use the imperial system. Here\'s the full breakdown and why it matters for travellers.',
    date: 'June 4, 2025',
    readTime: '6 min',
    category: 'General',
    icon: '🌍',
  },
  {
    slug: 'tipping-guide-around-the-world',
    title: 'Tipping Etiquette Around the World: A Complete Guide',
    excerpt: 'From 20% in the US to "don\'t tip" in Japan. Know the customs before you travel.',
    date: 'June 4, 2025',
    readTime: '5 min',
    category: 'Finance',
    icon: '💰',
  },
  {
    slug: 'understanding-cryptocurrency-market-cap',
    title: 'What is Crypto Market Cap and Why Does It Matter?',
    excerpt: 'Market cap explained simply — how it\'s calculated, what it tells you, and why price alone is misleading.',
    date: 'June 4, 2025',
    readTime: '4 min',
    category: 'Crypto',
    icon: '₿',
  },
];
---

<Layout title="Blog — Conversion Tips, Guides & Insights" description="Helpful articles about unit conversion, measurement systems, currency exchange, crypto, and everyday calculation tips." keywords="conversion blog, unit converter tips, metric imperial guide, currency exchange explained, crypto market cap">
  <div class="max-w-3xl">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Blog</h1>
      <p class="text-gray-500 dark:text-gray-400">Tips, guides, and insights about conversions, measurements, and money.</p>
    </div>

    <div class="space-y-4">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="block bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 shadow-sm hover:border-amber-400 dark:hover:border-amber-500 hover:shadow-md transition-all group">
          <div class="flex items-start gap-4">
            <span class="text-2xl shrink-0 mt-0.5">{post.icon}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">{post.category}</span>
                <span class="text-xs text-gray-400">{post.date}</span>
                <span class="text-xs text-gray-400">• {post.readTime}</span>
              </div>
              <h2 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors mb-1">{post.title}</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">{post.excerpt}</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-amber-500 transition-colors shrink-0 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
