---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Aspect Ratio Calculator — Screen Ratios" description="Free aspect ratio calculator. Find ratios from dimensions, calculate missing values, and browse common screen ratios instantly." keywords="aspect ratio calculator, 16:9, screen ratio, resolution calculator, image ratio">
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is 16:9 aspect ratio in pixels?","acceptedAnswer":{"@type":"Answer","text":"Common 16:9 resolutions include 1920×1080 (Full HD), 2560×1440 (2K), and 3840×2160 (4K). Any width × (width÷16×9) gives a 16:9 dimension."}},{"@type":"Question","name":"How do I find the aspect ratio of an image?","acceptedAnswer":{"@type":"Answer","text":"Divide both width and height by their greatest common divisor. For example, 1920÷120=16, 1080÷120=9, so it's 16:9."}},{"@type":"Question","name":"What aspect ratio is best for YouTube?","acceptedAnswer":{"@type":"Answer","text":"YouTube recommends 16:9 (landscape) for standard videos. For Shorts, use 9:16 (vertical/portrait)."}}]}</script>
  <div class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">📐</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Aspect Ratio Calculator — Find & Calculate Ratios</h1>
        <span class="ml-2 px-2 py-0.5 text-xs font-semibold bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 rounded-full">🧪 Experimental</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Find simplified ratios from dimensions or calculate missing dimensions from a ratio.</p>
    </div>

    <!-- Calculator -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Find Ratio from Dimensions</h2>
      <div class="flex items-end gap-3 mb-4">
        <div class="flex-1">
          <label for="dim-w" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Width</label>
          <input id="dim-w" type="number" min="1" placeholder="1920" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <span class="text-gray-400 dark:text-gray-500 text-lg font-bold pb-2">×</span>
        <div class="flex-1">
          <label for="dim-h" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Height</label>
          <input id="dim-h" type="number" min="1" placeholder="1080" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <span class="text-gray-400 dark:text-gray-500 text-lg font-bold pb-2">=</span>
        <div class="flex-1">
          <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Ratio</label>
          <div id="ratio-result" class="w-full px-3 py-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-300 font-bold text-sm text-center min-h-[38px] flex items-center justify-center">—</div>
        </div>
      </div>

      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4 mt-8">Calculate Dimension from Ratio</h2>
      <div class="flex items-end gap-3 mb-4">
        <div class="flex-1">
          <label for="ratio-x" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Ratio W</label>
          <input id="ratio-x" type="number" min="1" value="16" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <span class="text-gray-400 dark:text-gray-500 text-lg font-bold pb-2">:</span>
        <div class="flex-1">
          <label for="ratio-y" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Ratio H</label>
          <input id="ratio-y" type="number" min="1" value="9" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <span class="text-gray-400 dark:text-gray-500 text-lg font-bold pb-2">→</span>
        <div class="flex-1">
          <label for="calc-w" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Width</label>
          <input id="calc-w" type="number" min="1" placeholder="1920" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <span class="text-gray-400 dark:text-gray-500 text-lg font-bold pb-2">×</span>
        <div class="flex-1">
          <label for="calc-h" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Height</label>
          <input id="calc-h" type="number" min="1" placeholder="1080" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>
    </div>

    <!-- Presets -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Quick Presets</h2>
      <div id="presets" class="flex flex-wrap gap-2"></div>
    </div>

    <!-- Common Ratios -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Common Aspect Ratios</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="common-ratios"></div>
    </div>

    <!-- Report a bug · Suggest a feature -->
<div class="mt-6 flex items-center justify-center gap-4 flex-wrap">
  <a href="/report-bug?tool=Aspect+Ratio+Calculator" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 hover:underline font-medium">
    <span aria-hidden="true">🐛</span> Report a bug
  </a>
  <span class="text-gray-300 dark:text-gray-600">|</span>
  <a href="/suggest?title=Aspect+Ratio+Calculator" class="inline-flex items-center gap-1.5 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
    <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
  </a>
</div>
  </div>

  <script is:inline>
  (function() {
    function gcd(a, b) { return b === 0 ? a : gcd(b, a % b); }

    const dimW = document.getElementById('dim-w');
    const dimH = document.getElementById('dim-h');
    const ratioResult = document.getElementById('ratio-result');
    const ratioX = document.getElementById('ratio-x');
    const ratioY = document.getElementById('ratio-y');
    const calcW = document.getElementById('calc-w');
    const calcH = document.getElementById('calc-h');

    function updateRatio() {
      const w = parseInt(dimW.value);
      const h = parseInt(dimH.value);
      if (!w || !h || w <= 0 || h <= 0) { ratioResult.textContent = '—'; return; }
      const d = gcd(w, h);
      ratioResult.textContent = (w / d) + ':' + (h / d);
    }

    function calcFromRatio() {
      const rx = parseFloat(ratioX.value);
      const ry = parseFloat(ratioY.value);
      if (!rx || !ry) return;

      const w = parseFloat(calcW.value);
      const h = parseFloat(calcH.value);

      if (w && !h) {
        calcH.value = Math.round(w * ry / rx);
      } else if (h && !w) {
        calcW.value = Math.round(h * rx / ry);
      }
    }

    dimW.addEventListener('input', updateRatio);
    dimH.addEventListener('input', updateRatio);
    calcW.addEventListener('input', () => { calcH.value = ''; calcFromRatio(); });
    calcH.addEventListener('input', () => { calcW.value = ''; calcFromRatio(); });
    ratioX.addEventListener('input', calcFromRatio);
    ratioY.addEventListener('input', calcFromRatio);

    // Presets
    const presets = [
      { name: '1080p', w: 1920, h: 1080 },
      { name: '720p', w: 1280, h: 720 },
      { name: '4K UHD', w: 3840, h: 2160 },
      { name: '2K QHD', w: 2560, h: 1440 },
      { name: 'iPhone 15', w: 1179, h: 2556 },
      { name: 'iPad', w: 2048, h: 2732 },
      { name: 'Instagram', w: 1080, h: 1080 },
      { name: 'Twitter Banner', w: 1500, h: 500 },
      { name: 'Ultrawide', w: 3440, h: 1440 },
      { name: 'Cinema 4K', w: 4096, h: 2160 },
    ];

    const presetsEl = document.getElementById('presets');
    presets.forEach(p => {
      const btn = document.createElement('button');
      btn.className = 'px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-300 transition-colors border border-gray-200 dark:border-gray-700';
      btn.textContent = p.name + ' (' + p.w + '×' + p.h + ')';
      btn.addEventListener('click', () => {
        dimW.value = p.w;
        dimH.value = p.h;
        updateRatio();
      });
      presetsEl.appendChild(btn);
    });

    // Common ratios
    const commonRatios = [
      { ratio: '16:9', desc: 'Widescreen TV, YouTube', examples: '1920×1080, 2560×1440' },
      { ratio: '4:3', desc: 'Classic TV, Presentations', examples: '1024×768, 1600×1200' },
      { ratio: '21:9', desc: 'Ultrawide Monitors', examples: '2560×1080, 3440×1440' },
      { ratio: '1:1', desc: 'Square, Instagram Posts', examples: '1080×1080, 500×500' },
      { ratio: '3:2', desc: 'DSLR Photos, Surface', examples: '1440×960, 3000×2000' },
      { ratio: '9:16', desc: 'Phone Portrait, Stories', examples: '1080×1920, 1179×2556' },
    ];

    const ratiosEl = document.getElementById('common-ratios');
    commonRatios.forEach(r => {
      const el = document.createElement('div');
      el.className = 'p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700';
      el.innerHTML = '<div class="font-bold text-amber-600 dark:text-amber-400 text-lg">' + r.ratio + '</div><div class="text-xs text-gray-600 dark:text-gray-400 mt-1">' + r.desc + '</div><div class="text-xs text-gray-400 dark:text-gray-500 mt-1 font-mono">' + r.examples + '</div>';
      ratiosEl.appendChild(el);
    });
  })();
  </script>

    <div class="mt-8 prose prose-sm dark:prose-invert max-w-none">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">About Aspect Ratios</h2>
      <p class="text-gray-600 dark:text-gray-400">Aspect ratio is the proportional relationship between width and height. Common ratios include 16:9 (widescreen TV/monitors), 4:3 (classic TV), 1:1 (Instagram square), and 9:16 (mobile stories). Getting the aspect ratio right prevents stretched or cropped images and videos.</p>
      <p class="text-gray-600 dark:text-gray-400">Enter width and height to calculate the ratio, or enter a ratio and one dimension to find the other. Essential for video editing, web design, photography, and responsive layouts.</p>
    </div>
</Layout>
