---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Age Calculator" description="Calculate exact age in years, months, weeks and days from a date of birth. Find how many days until your next birthday.">
  <div class="max-w-2xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🎂</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Age Calculator</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Find your exact age in years, months, weeks, days and more</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
        <div>
          <label for="dob" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Date of Birth</label>
          <input id="dob" type="date"
            class="w-full h-12 px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-base focus:outline-none focus:ring-2 focus:ring-amber-500"
            style="color-scheme: light dark"/>
        </div>
        <div>
          <label for="calc-date" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Calculate Age On</label>
          <div class="flex gap-2">
            <input id="calc-date" type="date"
              class="flex-1 h-12 px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-base focus:outline-none focus:ring-2 focus:ring-amber-500"
              style="color-scheme: light dark"/>
            <button id="use-today" class="px-3 h-12 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 text-xs font-semibold border border-amber-200 dark:border-amber-800 hover:bg-amber-100 transition-colors whitespace-nowrap">Today</button>
          </div>
        </div>
      </div>

      <!-- Main result -->
      <div id="age-result" class="p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 mb-5 text-center">
        <div class="text-sm text-amber-600 dark:text-amber-400 font-medium mb-2">Your Age</div>
        <div id="age-main" class="text-4xl font-bold text-amber-700 dark:text-amber-400">—</div>
        <div id="age-detail" class="text-sm text-amber-600/80 dark:text-amber-400/70 mt-1">—</div>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 text-center">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Total Months</div>
          <div id="stat-months" class="text-2xl font-bold text-gray-900 dark:text-white font-mono">—</div>
        </div>
        <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 text-center">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Total Weeks</div>
          <div id="stat-weeks" class="text-2xl font-bold text-gray-900 dark:text-white font-mono">—</div>
        </div>
        <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 text-center">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Total Days</div>
          <div id="stat-days" class="text-2xl font-bold text-gray-900 dark:text-white font-mono">—</div>
        </div>
        <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 text-center">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Total Hours</div>
          <div id="stat-hours" class="text-2xl font-bold text-gray-900 dark:text-white font-mono">—</div>
        </div>
      </div>
    </div>

    <!-- Birthday countdown -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-4">🎉 Next Birthday</h2>
      <div id="birthday-info" class="text-gray-500 dark:text-gray-400 text-sm">Enter your date of birth above</div>
    </div>
  </div>
</Layout>

<script>
  // Set default dates
  const dobEl = document.getElementById('dob') as HTMLInputElement;
  const calcDateEl = document.getElementById('calc-date') as HTMLInputElement;

  const today = new Date();
  const todayStr = today.toISOString().split('T')[0];
  calcDateEl.value = todayStr;
  // Default DOB: 30 years ago
  const defaultDob = new Date(today.getFullYear() - 30, today.getMonth(), today.getDate());
  dobEl.value = defaultDob.toISOString().split('T')[0];

  document.getElementById('use-today')?.addEventListener('click', () => {
    calcDateEl.value = todayStr;
    calculate();
  });

  function calculate() {
    const dob = new Date(dobEl.value);
    const on = new Date(calcDateEl.value);
    if (isNaN(dob.getTime()) || isNaN(on.getTime())) return;
    if (dob > on) {
      document.getElementById('age-main')!.textContent = '—';
      document.getElementById('age-detail')!.textContent = 'Date of birth is in the future';
      return;
    }

    // Calculate exact age
    let years = on.getFullYear() - dob.getFullYear();
    let months = on.getMonth() - dob.getMonth();
    let days = on.getDate() - dob.getDate();

    if (days < 0) {
      months--;
      const prevMonth = new Date(on.getFullYear(), on.getMonth(), 0);
      days += prevMonth.getDate();
    }
    if (months < 0) { years--; months += 12; }

    document.getElementById('age-main')!.textContent = `${years} year${years !== 1 ? 's' : ''}`;
    document.getElementById('age-detail')!.textContent = `${months} month${months !== 1 ? 's' : ''} and ${days} day${days !== 1 ? 's' : ''}`;

    // Stats
    const diffMs = on.getTime() - dob.getTime();
    const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    const totalWeeks = Math.floor(totalDays / 7);
    const totalMonths = years * 12 + months;
    const totalHours = totalDays * 24;

    document.getElementById('stat-months')!.textContent = totalMonths.toLocaleString();
    document.getElementById('stat-weeks')!.textContent = totalWeeks.toLocaleString();
    document.getElementById('stat-days')!.textContent = totalDays.toLocaleString();
    document.getElementById('stat-hours')!.textContent = totalHours.toLocaleString();

    // Next birthday
    const bdayThis = new Date(on.getFullYear(), dob.getMonth(), dob.getDate());
    let nextBday = bdayThis;
    if (bdayThis <= on) nextBday = new Date(on.getFullYear() + 1, dob.getMonth(), dob.getDate());
    const daysUntil = Math.round((nextBday.getTime() - on.getTime()) / (1000 * 60 * 60 * 24));
    const bdayStr = nextBday.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    const bdayInfo = document.getElementById('birthday-info')!;

    if (daysUntil === 0) {
      bdayInfo.innerHTML = `<div class="text-2xl font-bold text-amber-600 dark:text-amber-400">🎉 Happy Birthday!</div><div class="text-sm text-gray-500 mt-1">Today is your birthday</div>`;
    } else {
      bdayInfo.innerHTML = `
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="text-gray-700 dark:text-gray-300 font-medium">${bdayStr}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Your next birthday</div>
          </div>
          <div class="shrink-0 text-right">
            <div class="text-3xl font-bold text-amber-600 dark:text-amber-400">${daysUntil}</div>
            <div class="text-xs text-gray-500">days away</div>
          </div>
        </div>`;
    }
  }

  dobEl.addEventListener('input', calculate);
  calcDateEl.addEventListener('input', calculate);
  calculate();
</script>
