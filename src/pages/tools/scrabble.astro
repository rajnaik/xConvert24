"bring","broad","broke","brown","brush","buddy","build","built","bunch","burst","buyer","cabin","cable","canon","carry","catch","cause","chain","chair","chaos","charm","chart","chase","cheap","check","cheek","chess","chest","chief","child","china","chose","chunk","civil","claim","clash","class","clean","clear","clerk","click","cliff","climb","cling","clock","clone","close","cloth","cloud","coach","coast","color","comet","comic","coral","could","count","court","cover","crack","craft","crash","crazy","cream","creek","crime","cross","crowd","cruel","crush","curve","cycle","daily","dance","death","debug","debut","delay","delta","dense","depth","derby","devil","diary","dirty","donor","doubt","dough","draft","drain","drama","drank","drawn","dream","dress","dried","drift","drill","drink","drive","drops","drove","drunk","dryer","dying","eager","early","earth","eight","elect","elite","email","empty","ended","enemy","enjoy","enter","entry","equal","error","essay","event","every","exact","exams","exist","extra","faint","faith","false","fancy","fatal","fault","feast","fence","fewer","fiber","field","fifth","fifty","fight","final","first","fixed","flame","flash","flesh","float","flock","flood","floor","flour","fluid","flush","focal","focus","force","forge","forth","found","forum","frame","frank","fraud","fresh","front","frost","fruit","fully","funny","gamma","genre","ghost","giant","given","glass","globe","gloom","glory","glove","grace","grade","grain","grand","grant","graph","grasp","grass","grave","great","green","greet","grief","gross","group","grove","grown","guard","guess","guest","guide","guilt","quote","label","large","laser","later","laugh","layer","learn","least","leave","legal","lemon","level","light","limit","linen","liver","logic","loose","lover","lower","lucky","lunch","magic","major","maker","manor","march","match","maybe","mayor","medal","media","mercy","merit","metal","meter","might","minor","minus","mixed","model","money","month","moral","motor","mount","mouse","mouth","moved","movie","music","nerve","never","newly","night","noble","noise","north","noted","novel","nurse","occur","ocean","offer","often","olive","onset","opera","orbit","order","organ","other","outer","owner","oxide","paint","panel","panic","paper","party","patch","pause","peace","pearl","penny","phase","phone","photo","piano","piece","pilot","pitch","pixel","pizza","place","plain","plane","plant","plate","plaza","plead","pluck","point","pound","power","press","price","pride","prime","print","prior","prize","probe","prone","proof","proud","prove","psalm","pulse","punch","pupil","purse","queen","query","quest","queue","quick","quiet","quite","quota","radar","radio","raise","rally","ranch","range","rapid","ratio","reach","realm","rebel","refer","reign","relax","reply","rider","ridge","rifle","right","rigid","river","robot","rocky","roman","rough","round","route","royal","rugby","ruler","rural","sadly","saint","salad","sales","sauce","scale","scare","scene","scope","score","sense","serve","seven","shade","shaft","shake","shall","shame","shape","share","shark","sharp","shave","sheep","sheer","sheet","shelf","shell","shift","shine","shirt","shock","shoot","shore","short","shout","shown","sight","since","sixth","sixty","skill","skull","slash","slave","sleep","slice","slide","slope","small","smart","smell","smile","smoke","snake","solar","solid","solve","sorry","sound","south","space","spare","speak","speed","spell","spend","spent","spill","spine","spite","split","spoke","spoon","sport","spray","squad","stack","staff","stage","stain","stake","stall","stamp","stand","stare","stark","start","state","steak","steal","steam","steel","steep","steer","stick","stiff","still","stock","stone","stood","store","storm","story","stove","stuff","style","sugar","suite","sunny","super","surge","swamp","swear","sweep","sweet","swept","swift","swing","sword","sworn","swung","table","taste","teach","teeth","tempo","thank","theft","their","theme","there","thick","thing","think","third","those","three","threw","throw","thumb","tiger","tight","tired","title","today","token","tooth","topic","total","touch","tough","towel","tower","trace","track","trade","trail","train","trait","trash","treat","trend","trial","tribe","trick","troop","truck","truly","trunk","trust","truth","tutor","twice","twist","ultra","uncle","under","unify","union","unite","unity","until","upper","upset","urban","usage","usual","valid","value","valve","venue","verse","video","villa","viral","virus","visit","vital","vivid","vocal","voice","voter","wagon","waste","watch","water","weave","weigh","weird","whale","wheat","wheel","where","which","while","white","whole","whose","wider","woman","women","world","worry","worse","worst","worth","would","wound","write","wrong","wrote","yacht","young","youth"].filter(w => w.length >= 2 && w.length <= 7);

  function wordScore(word: string): number {
    return word.split('').reduce((sum, ch) => sum + (scores[ch.toUpperCase()] || 0), 0);
  }

  function canMake(word: string, tiles: string): boolean {
    const available = tiles.toUpperCase().split('');
    const blanks = available.filter(t => t === '?').length;
    const tileCount: Record<string, number> = {};
    available.filter(t => t !== '?').forEach(t => { tileCount[t] = (tileCount[t] || 0) + 1; });

    let blanksNeeded = 0;
    for (const ch of word.toUpperCase()) {
      if (tileCount[ch] && tileCount[ch] > 0) {
        tileCount[ch]--;
      } else {
        blanksNeeded++;
        if (blanksNeeded > blanks) return false;
      }
    }
    return true;
  }

  function solve() {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim();
    const minLen = parseInt((document.getElementById('min-len') as HTMLSelectElement).value);
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement).value;
    const resultsEl = document.getElementById('results')!;

    if (!tiles || tiles.length < 2) {
      resultsEl.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm italic">Enter at least 2 tiles</div>';
      return;
    }

    let found = WORDS.filter(w => w.length >= minLen && w.length <= tiles.length && canMake(w, tiles));

    if (sortBy === 'score') found.sort((a, b) => wordScore(b) - wordScore(a));
    else if (sortBy === 'length') found.sort((a, b) => b.length - a.length || wordScore(b) - wordScore(a));
    else found.sort((a, b) => a.localeCompare(b));

    if (!found.length) {
      resultsEl.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm italic">No words found with those tiles</div>';
      return;
    }

    resultsEl.innerHTML = `
      <div class="text-xs text-gray-400 mb-3">${found.length} words found</div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-80 overflow-y-auto">
        ${found.slice(0, 100).map(w => `
          <div class="flex items-center justify-between px-3 py-2 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <span class="font-mono font-semibold text-sm text-gray-900 dark:text-white uppercase tracking-wider">${w}</span>
            <span class="text-xs font-bold text-amber-600 dark:text-amber-400">${wordScore(w)} pts</span>
          </div>
        `).join('')}
      </div>
      ${found.length > 100 ? '<div class="mt-2 text-xs text-gray-400 text-center">Showing top 100 of ' + found.length + '</div>' : ''}
    `;
  }

  document.getElementById('solve-btn')!.addEventListener('click', solve);
  document.getElementById('tiles')!.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') solve(); });
  document.getElementById('min-len')!.addEventListener('change', solve);
  document.getElementById('sort-by')!.addEventListener('change', solve);

  // Render tile scores reference
  const scoresEl = document.getElementById('tile-scores')!;
  scoresEl.innerHTML = Object.entries(scores).map(([letter, pts]) =>
    `<div class="w-8 h-10 bg-amber-100 dark:bg-amber-900/30 rounded flex flex-col items-center justify-center">
      <span class="text-xs font-bold text-gray-900 dark:text-white">${letter}</span>
      <span class="text-[9px] text-amber-600 dark:text-amber-400">${pts}</span>
    </div>`
  ).join('');
</script>
