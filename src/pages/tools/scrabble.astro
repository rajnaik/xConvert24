        <div class="flex flex-wrap gap-1.5">
          ${twoLetters.map(w => `<span data-achieve-word="${w}" class="inline-block px-1.5 py-0.5 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded font-mono font-semibold uppercase text-amber-700 dark:text-amber-300 cursor-pointer hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-all">${w}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${wordScore(w)}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">${twoLetters.length} words total</p>
      `;
      applyAchievements(twoLetterEl);
      bindAchievementClicks(twoLetterEl);
    }

    // Three-Letter Words (top 30 by score)
    const threeLetterEl = document.getElementById('three-letter-words');
    if (threeLetterEl) {
      const threeLetters = WORDS.filter(w => w.length === 3)
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 30);
      threeLetterEl.innerHTML = `
        <div class="flex flex-wrap gap-1.5">
          ${threeLetters.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded font-mono font-semibold uppercase text-blue-700 dark:text-blue-300 cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">Top 30 by score</p>
      `;
      applyAchievements(threeLetterEl);
      bindAchievementClicks(threeLetterEl);
    }

    // Q Without U
    const qNoUEl = document.getElementById('q-without-u');
    if (qNoUEl) {
      const qNoU = WORDS.filter(w => w.includes('q') && !w.includes('u'))
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score);
      if (qNoU.length) {
        qNoUEl.innerHTML = `
          <div class="flex flex-wrap gap-1.5">
            ${qNoU.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded font-mono font-semibold uppercase text-purple-700 dark:text-purple-300 cursor-pointer hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
          </div>
          <p class="mt-2 text-xs text-gray-400">${qNoU.length} words — memorise these!</p>
        `;
        applyAchievements(qNoUEl);
        bindAchievementClicks(qNoUEl);
      } else {
        qNoUEl.innerHTML = '<p class="text-xs text-gray-400">None found in dictionary</p>';
      }
    }
  }

  // Wait for dictionary then populate panels
  const panelInterval = setInterval(() => {
    if (dictionaryLoaded) {
      clearInterval(panelInterval);
      populateReferencePanels();
      initRareLetterTabs();
    }
  }, 200);

  // ── Rare Letter Tabs ──────────────────────────────────────────────────────
  function initRareLetterTabs() {
    const tabs = document.querySelectorAll('.rare-tab');
    const resultsEl = document.getElementById('rare-letter-results');
    if (!tabs.length || !resultsEl) return;

    function showRareLetter(letter: string) {
      const words = WORDS.filter(w => w.includes(letter))
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 40);

      const colors: Record<string, { bg: string; border: string; text: string }> = {
        q: { bg: 'bg-purple-50 dark:bg-purple-900/20', border: 'border-purple-200 dark:border-purple-800', text: 'text-purple-700 dark:text-purple-300' },
        z: { bg: 'bg-red-50 dark:bg-red-900/20', border: 'border-red-200 dark:border-red-800', text: 'text-red-700 dark:text-red-300' },
        x: { bg: 'bg-orange-50 dark:bg-orange-900/20', border: 'border-orange-200 dark:border-orange-800', text: 'text-orange-700 dark:text-orange-300' },
        j: { bg: 'bg-emerald-50 dark:bg-emerald-900/20', border: 'border-emerald-200 dark:border-emerald-800', text: 'text-emerald-700 dark:text-emerald-300' },
      };
      const c = colors[letter] || colors.q;

      resultsEl.innerHTML = `
        <div class="flex flex-wrap gap-1.5">
          ${words.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 ${c.bg} border ${c.border} rounded font-mono font-semibold uppercase ${c.text} cursor-pointer hover:opacity-80 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">Top 40 words containing "${letter.toUpperCase()}" by score</p>
      `;
      applyAchievements(resultsEl);
      bindAchievementClicks(resultsEl);

      // Update tab styles
      tabs.forEach(tab => {
        const t = tab as HTMLElement;
        if (t.dataset.rare === letter) {
          t.className = 'rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold ' + c.bg + ' ' + c.text + ' border ' + c.border;
        } else {
          t.className = 'rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700';
        }
      });
    }

    // Default to Q
    showRareLetter('q');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const letter = (tab as HTMLElement).dataset.rare!;
        showRareLetter(letter);
      });
