---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Free Scrabble Word Finder — Solve Any Rack" description="Free Scrabble word finder and solver. Enter your tiles, find the highest-scoring words instantly from 74,000+ SOWPODS words. No sign-up needed." keywords="scrabble word finder, scrabble cheat, scrabble solver, scrabble tiles, word finder, scrabble word solver, scrabble helper, scrabble dictionary, scrabble find, anagram solver, words with friends cheat, scrabble word, highest scoring scrabble words, scrabble rack solver">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What dictionary does this Scrabble word finder use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This tool uses the SOWPODS dictionary — the international Scrabble word list used in official tournaments outside North America. It contains over 74,000 valid words between 2 and 7 letters long."
        }
      },
      {
        "@type": "Question",
        "name": "How are Scrabble tile scores calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each letter tile has a fixed point value. Common letters like E, A, I, O score 1 point, while rare letters like Q and Z score 10 points. The word score is the sum of all individual tile values. Blank tiles (wildcards) score 0 points."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use blank tiles or wildcards?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Enter a question mark (?) for each blank tile in your rack — up to 2 wildcards are supported. The solver will treat each as any letter and find all possible words, though blank tiles contribute 0 points to the word score."
        }
      },
      {
        "@type": "Question",
        "name": "Does this work for Words With Friends too?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. While Words With Friends uses a slightly different dictionary and scoring system, the SOWPODS word list covers virtually all valid WWF words. The tile scores shown are for standard Scrabble — WWF scores differ slightly for some letters."
        }
      }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Free Scrabble Word Finder",
    "url": "https://www.xconvert24.com/tools/scrabble",
    "description": "Enter your Scrabble tiles and instantly find the highest-scoring words. Free Scrabble word solver with dictionary lookup, achievements, and tile probability calculator.",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "browserRequirements": "Requires JavaScript"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Use the Scrabble Word Finder",
    "description": "Find the highest-scoring Scrabble words from your rack in 3 simple steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter your tiles", "text": "Type your Scrabble rack letters into the input field. Use ? for blank tiles." },
      { "@type": "HowToStep", "position": 2, "name": "Find words instantly", "text": "Results appear automatically as you type. The solver searches 74,000+ words from the SOWPODS Scrabble dictionary." },
      { "@type": "HowToStep", "position": 3, "name": "Click to collect achievements", "text": "Click any word to add it to your achievements, copy it to clipboard, and see your rack leave analysis." }
    ]
  })} />
  <style is:inline>
    [id^="section-"] {
      scroll-margin-top: 35px;
    }
    .scrabble-tile {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }
    .scrabble-tile:hover {
      transform: scale(2) rotate(-3deg) translateY(-4px);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), inset 0 -2px 0 rgba(0,0,0,0.1), 0 8px 20px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.2) !important;
      z-index: 10;
      position: relative;
    }
    .scrabble-tile.tile-highlighted {
      animation: tile-glow 1.2s ease-in-out infinite alternate;
    }
    @keyframes tile-glow {
      0% { outline-color: #f59e0b; transform: scale(1); }
      100% { outline-color: #dc2626; transform: scale(1.08); }
    }
    /* Mobile: smaller tiles */
    @media (max-width: 639px) {
      .scrabble-tile {
        width: 48px !important;
        height: 48px !important;
      }
      .scrabble-tile .text-6xl {
        font-size: 1.5rem !important;
      }
      .scrabble-tile .text-lg {
        font-size: 0.6rem !important;
        bottom: 4px !important;
        right: 4px !important;
      }
    }
  </style>
  <div class="max-w-5xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🔤</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Scrabble Word Finder & Solver</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">The ultimate <strong>Scrabble word finder</strong> — enter your <strong>Scrabble tiles</strong> and instantly discover the highest-scoring words from the SOWPODS <strong>Scrabble dictionary</strong>. Use this <strong>Scrabble helper</strong> as a <strong>word finder</strong>, rack analyzer, and tile probability tracker. Works for Words With Friends too.</p>
      <span class="inline-block mt-2 px-2 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400 text-xs font-medium">🧪 Experimental</span>
      <!-- Quick nav icons -->
      <div class="flex flex-wrap gap-2 mt-3">
        <a href="#section-tile-scores" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Tile Scores">🎯 Scores</a>
        <a href="#section-two-letter" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Top 2-Letter Words">2️⃣ 2-Letter</a>
        <a href="#section-three-letter" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Top 3-Letter Words">3️⃣ 3-Letter</a>
        <a href="#section-rare-letters" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-purple-100 dark:hover:bg-purple-900/30 hover:text-purple-700 dark:hover:text-purple-400 transition-colors" title="Rare Letters (Q, Z, X, J)">💎 Rare</a>
        <a href="#section-probability" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Tile Bag Probability">🎲 Probability</a>
        <a href="#section-rack-leave" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Rack Leave Analyzer">🧮 Rack Leave</a>
        <a href="#section-best-opening" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors" title="Best Opening Moves">🏆 Openers</a>
      </div>
    </div>

    <!-- Two-column layout: Input + Saved Words -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6 mb-6">
      <!-- Left: Input & Results -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 sm:p-6 shadow-sm">
        <!-- Input -->
        <div class="mb-4">
          <label for="tiles" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Your Scrabble Tiles</label>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 relative">
            <input id="tiles" type="text" maxlength="15" placeholder="e.g. AERTBLS" inputmode="text" autocapitalize="characters" class="flex-1 h-12 sm:h-14 px-3 sm:px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-xl sm:text-2xl font-mono uppercase tracking-widest focus:outline-none focus:ring-2 focus:ring-amber-500" autocomplete="off"/>
            <button id="solve-btn" class="h-12 sm:h-14 px-6 rounded-lg bg-amber-500 text-white font-semibold hover:bg-amber-600 transition-colors text-base sm:text-lg">Find Words</button>
            <!-- Hint bubble (hidden on mobile, shown on desktop) -->
            <div id="hint-bubble" class="hidden sm:block absolute top-1/2 -translate-y-1/2 right-full mr-3 opacity-0 transition-all duration-300 z-20">
              <div class="relative bg-orange-500 text-white text-sm font-semibold px-4 py-2 rounded-full shadow-lg whitespace-nowrap">
                Enter your letters here
                <div class="absolute top-1/2 -translate-y-1/2 -right-2 w-4 h-4 bg-orange-500 rotate-45"></div>
              </div>
            </div>
          </div>
          <p class="mt-2 text-xs text-gray-400">Use ? for blank tiles (up to 2 wildcards supported). Results appear as you type.</p>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 mb-4 items-end">
          <div>
            <label for="dictionary" class="text-xs text-gray-500 dark:text-gray-400">Dictionary</label>
            <select id="dictionary" class="h-8 px-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-sm text-gray-900 dark:text-gray-100">
              <option value="sowpods">SOWPODS (International)</option>
              <option value="twl">TWL / NASPA / WOW (US/Canada)</option>
            </select>
          </div>
          <div>
            <label for="min-len" class="text-xs text-gray-500 dark:text-gray-400">Min length</label>
            <select id="min-len" class="h-8 px-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-sm text-gray-900 dark:text-gray-100">
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>
          <div>
            <label for="starts-with" class="text-xs text-gray-500 dark:text-gray-400">Starts with</label>
            <input id="starts-with" type="text" maxlength="3" placeholder="e.g. QU" class="h-8 w-12 px-1.5 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-sm text-gray-900 dark:text-gray-100 uppercase font-mono text-left" autocomplete="off"/>
          </div>
          <div>
            <label for="ends-with" class="text-xs text-gray-500 dark:text-gray-400">Ends with</label>
            <input id="ends-with" type="text" maxlength="3" placeholder="e.g. ED" class="h-8 w-12 px-1.5 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-sm text-gray-900 dark:text-gray-100 uppercase font-mono text-right" autocomplete="off"/>
          </div>
          <div>
            <label for="sort-by" class="text-xs text-gray-500 dark:text-gray-400">Sort by</label>
            <select id="sort-by" class="h-8 px-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-sm text-gray-900 dark:text-gray-100">
              <option value="score">Highest Score</option>
              <option value="length">Longest First</option>
              <option value="alpha">A–Z</option>
            </select>
          </div>
        </div>

        <!-- Results -->
        <div id="results" class="min-h-[100px]">
          <div class="text-center py-8 text-gray-400 dark:text-gray-500 text-sm italic">Enter your tiles above and click Find Words</div>
        </div>
        <!-- High-Scoring Words Panel (persists across searches) -->
        <div id="high-scoring-panel" class="hidden"></div>
      </div>

      <!-- Right: Saved Words (Achievements) -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm h-fit lg:sticky lg:top-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2">
            <span aria-hidden="true">👑</span> Saved Words
          </h2>
          <div class="flex items-center gap-2">
            <button id="download-saved-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors opacity-30" title="Download saved words" aria-label="Download saved words">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3"/></svg>
            </button>
            <span id="saved-count" class="text-xs text-gray-400">0</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Click any word in results or reference panels to save it here.</p>
        <div id="saved-words-list" class="max-h-[400px] overflow-y-auto">
          <p id="saved-empty" class="text-sm text-gray-400 dark:text-gray-500 text-center py-4 italic">No saved words yet. Click any word to collect it.</p>
        </div>
      </div>
    </div>

    <!-- Score reference -->
    <div id="section-tile-scores" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 id="tile-scores-heading" class="font-semibold text-gray-900 dark:text-white mb-3">Scrabble Tile Scores</h2>
      <div class="grid grid-cols-4 sm:grid-cols-6 gap-2" id="tile-scores">
      </div>
    </div>

    <!-- Quick Reference Panels -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
      <!-- Two-Letter Words -->
      <div id="section-two-letter" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
          <span aria-hidden="true">🔤</span> Two-Letter Scrabble Words
        </h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">All valid 2-letter words from the Scrabble dictionary (SOWPODS)</p>
        <p class="text-xs text-emerald-600 dark:text-emerald-400 mb-3 font-medium">🏅 Add to your achievements (click the words)</p>
        <div id="two-letter-words" class="text-xs text-gray-600 dark:text-gray-400 italic">Loading dictionary…</div>
      </div>

      <!-- Three-Letter Words (Top Scoring) -->
      <div id="section-three-letter" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
          <span aria-hidden="true">🏆</span> Top 3-Letter Scrabble Words
        </h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Highest-scoring 3-letter words in the Scrabble word finder</p>
        <p class="text-xs text-emerald-600 dark:text-emerald-400 mb-3 font-medium">🏅 Add to your achievements (click the words)</p>
        <div id="three-letter-words" class="text-xs text-gray-600 dark:text-gray-400 italic">Loading dictionary…</div>
      </div>

      <!-- Q Without U -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
        <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
          <span aria-hidden="true">🅀</span> Q Without U — Scrabble Cheat Words
        </h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Legal Scrabble words with Q but no U</p>
        <p class="text-xs text-emerald-600 dark:text-emerald-400 mb-3 font-medium">🏅 Add to your achievements (click the words)</p>
        <div id="q-without-u" class="text-xs text-gray-600 dark:text-gray-400 italic">Loading dictionary…</div>
      </div>
    </div>

    <!-- Words with Rare Letters (Tabbed) -->
    <div id="section-rare-letters" class="mt-6 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
        <span aria-hidden="true">💎</span> Scrabble Words with Rare Letters
      </h2>
      <p class="text-xs text-emerald-600 dark:text-emerald-400 mb-3 font-medium">🏅 Add to your achievements (click the words)</p>
      <div class="flex gap-2 mb-4" id="rare-tabs">
        <button data-rare="q" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 border border-purple-200 dark:border-purple-800">Q</button>
        <button data-rare="z" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700">Z</button>
        <button data-rare="x" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700">X</button>
        <button data-rare="j" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700">J</button>
      </div>
      <div id="rare-letter-results" class="text-xs text-gray-600 dark:text-gray-400 italic">Loading dictionary…</div>
    </div>

    <!-- Tile Probability Calculator -->
    <div id="section-probability" class="mt-6 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
        <span aria-hidden="true">🎲</span> Tile Bag Probability
      </h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Play the words your opponent played and pick the word — the Tile Bag Probability Tracker will automatically manage probability.</p>
      <div id="tile-probability" class="space-y-2">
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-3 text-center">
            <label for="tiles-in-bag" class="text-xs text-gray-500 block mb-1">In bag</label>
            <input id="tiles-in-bag" type="number" min="0" max="100" value="100" class="w-full text-center text-2xl font-bold text-gray-900 dark:text-white bg-transparent border-none outline-none focus:ring-0 p-0" />
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-amber-600 dark:text-amber-400" id="prob-your-rack">0</div>
            <div class="text-xs text-gray-500">Your rack</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-3 text-center">
            <label for="tiles-played" class="text-xs text-gray-500 block mb-1">Played</label>
            <input id="tiles-played" type="number" min="0" max="86" value="0" class="w-full text-center text-2xl font-bold text-rose-600 dark:text-rose-400 bg-transparent border-none outline-none focus:ring-0 p-0" />
          </div>
        </div>
        <div id="prob-draw-chances" class="mt-3 text-xs text-gray-500 dark:text-gray-400 italic">Enter your rack letters in the solver above ↑ to see draw probabilities</div>
      </div>
    </div>

    <!-- Rack Leave Analyzer -->
    <div id="section-rack-leave" class="mt-6 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
        <span aria-hidden="true">🧠</span> Rack Leave Analyzer
      </h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Click a word in your results to see what tiles remain on your rack — and how good that "leave" is for your next turn.</p>
      <div id="rack-leave-panel">
        <div class="text-xs text-gray-400 italic">Find words first, then click one to analyze your leave</div>
      </div>
    </div>

    <!-- Best Opening Moves -->
    <div id="section-best-opening" class="mt-6 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-start gap-2">
        <span aria-hidden="true">🚀</span> Best Opening Moves
      </h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">The highest-scoring first moves from your rack. Opening plays go through the centre star (H8) and score double word.</p>
      <div id="best-opening-panel">
        <div class="text-xs text-gray-400 italic">Enter your tiles above ↑ to see your best opening plays</div>
      </div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-2xl w-full max-w-sm mx-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Edit Saved Word</h3>
          <button id="edit-modal-close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="mb-3">
          <div id="edit-word-display" class="text-2xl font-mono font-bold text-amber-600 dark:text-amber-400 uppercase tracking-wider"></div>
          <div id="edit-word-score" class="text-xs text-gray-500 mt-1"></div>
        </div>
        <div class="space-y-4">
          <!-- Star Rating (hidden but kept for DOM references) -->
          <div class="hidden">
            <div id="star-rating" class="flex gap-2">
              <button data-star="1" class="star-btn w-10 h-10 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-lg">👍</button>
              <button data-star="2" class="star-btn w-10 h-10 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-lg">🔹</button>
              <button data-star="3" class="star-btn w-10 h-10 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-lg">⭐</button>
              <button data-star="4" class="star-btn w-10 h-10 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-lg">🪄</button>
              <button data-star="5" class="star-btn w-10 h-10 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-lg">🎯</button>
            </div>
          </div>
          <!-- Meaning / Note -->
          <div>
            <label for="edit-comment" class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Meaning / Note</label>
            <textarea id="edit-comment" rows="3" placeholder="e.g. (noun) a type of plant..." class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500 resize-none"></textarea>
          </div>
          <!-- Datetime (hidden) -->
          <div class="hidden">
            <input id="edit-datetime" type="datetime-local" class="w-full h-10 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm" style="color-scheme: light dark"/>
          </div>
        </div>
        <div class="flex gap-2 mt-5">
          <button id="edit-save-btn" class="flex-1 h-10 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors text-sm">Save</button>
          <button id="edit-cancel-btn" class="flex-1 h-10 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 font-semibold rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Related Blog Posts -->
    <div class="mt-10 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <span aria-hidden="true">📝</span> Related Articles
      </h2>
      <ul class="space-y-3">
        <li>
          <a href="/blog/scrabble-history-origins-great-depression" class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
            <span class="shrink-0 text-base" aria-hidden="true">🏛️</span>
            <span>The History of Scrabble: From the Great Depression to Global Phenomenon</span>
          </a>
        </li>
        <li>
          <a href="/blog/scrabble-tile-strategy-letters-scoring" class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
            <span class="shrink-0 text-base" aria-hidden="true">🎯</span>
            <span>Scrabble Tile Strategy: Letter Values, Rack Management & Scoring Tips</span>
          </a>
        </li>
        <li>
          <a href="/blog/scrabble-dictionaries-languages-weird-words" class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
            <span class="shrink-0 text-base" aria-hidden="true">📖</span>
            <span>Scrabble Dictionaries: Languages, Weird Words & What Counts</span>
          </a>
        </li>
        <li>
          <a href="/blog/competitive-scrabble-tournament-world" class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
            <span class="shrink-0 text-base" aria-hidden="true">🏆</span>
            <span>Inside Competitive Scrabble: Tournaments, Records & the Mental Game</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Report a bug · Suggest a feature -->
    <div class="mt-6 flex items-center justify-center gap-4 flex-wrap">
      <a href="/report-bug?tool=Free+Scrabble+Word+Finder" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 hover:underline font-medium">
        <span aria-hidden="true">🐛</span> Report a bug
      </a>
      <span class="text-gray-300 dark:text-gray-600">|</span>
      <a href="/suggest?title=Free+Scrabble+Word+Finder" class="inline-flex items-center gap-1.5 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
        <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
      </a>
    </div>
  </div>
</Layout>

<script>
  // Scrabble tile scores
  const scores: Record<string, number> = {
    A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,
    N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10
  };

  // SOWPODS dictionary (2-7 letter words) — loaded from static JSON
  let WORDS: string[] = [];
  let SOWPODS: string[] = [];
  let TWL: string[] = [];
  let dictionaryLoaded = false;
  let currentDict = localStorage.getItem('scbDictionary') || 'sowpods';

  async function loadDictionary() {
    try {
      const [sowRes, twlRes] = await Promise.all([
        fetch('/data/sowpods-2-7.json'),
        fetch('/data/twl06-2-7.json'),
      ]);
      if (!sowRes.ok) throw new Error('Failed to load SOWPODS');
      SOWPODS = await sowRes.json();
      TWL = twlRes.ok ? await twlRes.json() : SOWPODS;
      WORDS = currentDict === 'twl' ? TWL : SOWPODS;
      dictionaryLoaded = true;

      // Set the dropdown to match saved preference
      (document.getElementById('dictionary') as HTMLSelectElement).value = currentDict;
      // Update UI to show dictionary is ready + high scoring words
      const resultsEl = document.getElementById('results')!;
      const highScoringPanel = document.getElementById('high-scoring-panel')!;
      if (resultsEl.querySelector('.text-sm.italic')) {
        // Find top scoring words by length
        function topByLen(len: number, count: number): {word: string, score: number}[] {
          return WORDS
            .filter(w => w.length === len)
            .map(w => ({ word: w, score: w.split('').reduce((s, c) => s + (scores[c.toUpperCase()] || 0), 0) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, count);
        }
        const top2 = topByLen(2, 5);
        const top3 = topByLen(3, 5);
        const top4 = topByLen(4, 5);
        const top5 = topByLen(5, 5);

        function renderRow(words: {word: string, score: number}[]): string {
          return words.map(w => {
            return `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-100 dark:bg-gray-800 font-mono relative cursor-pointer hover:ring-2 hover:ring-amber-400 transition-all" data-achieve-word="${w.word}">
              <span class="font-bold text-gray-900 dark:text-white uppercase" style="font-size:0.85rem">${w.word}</span>
              <span class="text-amber-600 dark:text-amber-400" style="font-size:0.7rem">${w.score}</span>
            </span>`;
          }).join(' ');
        }

        resultsEl.innerHTML = `
          <div class="text-center py-4 text-gray-400 dark:text-gray-500 text-sm italic mb-4">${currentDict === 'twl' ? 'NWL/TWL' : 'SOWPODS'} dictionary loaded (${WORDS.length.toLocaleString()} words). Enter your tiles and click Find Words</div>`;

        highScoringPanel.innerHTML = `
          <div class="text-center mb-3 mt-4">
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-amber-700 dark:text-amber-400">
              <span>🏆</span> High-Scoring Words by Length
            </span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
              <thead class="bg-gray-100 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300 w-32">Length</th>
                  <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Highest Scoring Words</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                <tr class="bg-white dark:bg-gray-900">
                  <td class="px-4 py-3 font-bold text-amber-600 dark:text-amber-400 text-base">2-letter</td>
                  <td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top2)}</div></td>
                </tr>
                <tr class="bg-gray-50 dark:bg-gray-800/50">
                  <td class="px-4 py-3 font-bold text-amber-600 dark:text-amber-400 text-base">3-letter</td>
                  <td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top3)}</div></td>
                </tr>
                <tr class="bg-white dark:bg-gray-900">
                  <td class="px-4 py-3 font-bold text-amber-600 dark:text-amber-400 text-base">4-letter</td>
                  <td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top4)}</div></td>
                </tr>
                <tr class="bg-gray-50 dark:bg-gray-800/50">
                  <td class="px-4 py-3 font-bold text-amber-600 dark:text-amber-400 text-base">5-letter</td>
                  <td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top5)}</div></td>
                </tr>
              </tbody>
            </table>
          </div>`;
        highScoringPanel.classList.remove('hidden');
        // Apply achievement decorations and bind clicks
        applyAchievements(highScoringPanel);
        bindAchievementClicks(highScoringPanel);
      }
    } catch {
      // Fallback: use a minimal built-in list
      WORDS = ["quiz","quizzes","qi","qat","ax","ox","za","zo","xi","xu","aa","ab","ad","ae","ag","ah","ai","al","am","an","ar","as","at","aw","ay","ba","be","bi","bo","by"];
      dictionaryLoaded = true;
    }
  }

  loadDictionary();

  // Hint bubble: show after 1s on desktop, hide on input focus
  setTimeout(() => {
    const bubble = document.getElementById('hint-bubble');
    if (bubble && window.innerWidth >= 640) {
      requestAnimationFrame(() => { bubble.classList.remove('opacity-0'); bubble.classList.add('opacity-100'); });
    }
  }, 1000);
  document.getElementById('tiles')!.addEventListener('focus', () => {
    const bubble = document.getElementById('hint-bubble');
    if (bubble) {
      bubble.classList.add('opacity-0');
      setTimeout(() => bubble.classList.add('hidden'), 300);
    }
  }, { once: true });

  function wordScore(word: string): number {
    return word.split('').reduce((sum, ch) => sum + (scores[ch.toUpperCase()] || 0), 0);
  }

  function canMake(word: string, tiles: string): boolean {
    const available = tiles.toUpperCase().split('');
    const blanks = available.filter(t => t === '?').length;
    const tileCount: Record<string, number> = {};
    available.filter(t => t !== '?').forEach(t => { tileCount[t] = (tileCount[t] || 0) + 1; });

    let blanksNeeded = 0;
    for (const ch of word.toUpperCase()) {
      if (tileCount[ch] && tileCount[ch] > 0) {
        tileCount[ch]--;
      } else {
        blanksNeeded++;
        if (blanksNeeded > blanks) return false;
      }
    }
    return true;
  }

  function solve() {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim();
    const minLen = parseInt((document.getElementById('min-len') as HTMLSelectElement).value);
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement).value;
    const startsWith = (document.getElementById('starts-with') as HTMLInputElement).value.trim().toLowerCase();
    const endsWith = (document.getElementById('ends-with') as HTMLInputElement).value.trim().toLowerCase();
    const resultsEl = document.getElementById('results')!;

    if (!dictionaryLoaded) {
      resultsEl.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm italic">Loading dictionary… please wait</div>';
      return;
    }

    if (!tiles || tiles.length < 2) {
      resultsEl.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm italic">Enter at least 2 tiles</div>';
      return;
    }

    let found = WORDS.filter(w => {
      if (w.length < minLen || w.length > tiles.length) return false;
      if (startsWith && !w.startsWith(startsWith)) return false;
      if (endsWith && !w.endsWith(endsWith)) return false;
      return canMake(w, tiles);
    });

    if (sortBy === 'score') found.sort((a, b) => wordScore(b) - wordScore(a));
    else if (sortBy === 'length') found.sort((a, b) => b.length - a.length || wordScore(b) - wordScore(a));
    else found.sort((a, b) => a.localeCompare(b));

    if (!found.length) {
      resultsEl.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm italic">No words found with those tiles</div>';
      return;
    }

    const achievements = getAchievedWords();

    resultsEl.innerHTML = `
      <div class="text-xs text-gray-400 mb-3">${found.length} words found — click to add to achievements and copy to clipboard</div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-80 overflow-y-auto p-1">
        ${found.slice(0, 100).map(w => {
          const isAchieved = achievements.includes(w);
          const achievedClass = isAchieved ? 'ring-2 ring-emerald-500' : '';
          const tiara = isAchieved ? '<span class="achievement-tiara absolute -top-2 -left-1 text-xs">👑</span>' : '';
          const rareLetters = ['q','z','x','j'];
          const rareMatch = rareLetters.filter(l => w.includes(l));
          const rareIcon = rareMatch.length ? `<span class="absolute -top-2 -right-1 text-xs" title="Contains rare letter: ${rareMatch.join(', ').toUpperCase()}">💎</span>` : '';
          return `
          <div class="relative flex items-center justify-between px-3 py-2.5 bg-gray-50 dark:bg-gray-800 rounded-lg cursor-pointer hover:ring-2 hover:ring-amber-400 transition-all ${achievedClass}" data-achieve-word="${w}" data-highlight-word="${w}">
            ${tiara}${rareIcon}
            <span class="font-mono font-semibold text-gray-900 dark:text-white uppercase tracking-wider" style="font-size:0.65rem">${w}</span>
            <div class="flex items-center gap-1">
              <span class="text-green-600 dark:text-green-400" style="font-size:0.5rem" title="Valid in SOWPODS dictionary">✓</span>
              <span class="font-bold text-amber-600 dark:text-amber-400" style="font-size:0.6rem">${wordScore(w)} pts</span>
            </div>
          </div>`;
        }).join('')}
      </div>
      ${found.length > 100 ? '<div class="mt-2 text-xs text-gray-400 text-center">Showing top 100 of ' + found.length + '</div>' : ''}
    `;

    // Bind word click — toggle achievement + highlight tiles + update probability + analyze leave
    resultsEl.querySelectorAll('[data-achieve-word]').forEach(el => {
      el.addEventListener('click', (e) => {
        const word = (el as HTMLElement).dataset.achieveWord!;
        toggleAchievement(word, el as HTMLElement);
        highlightTiles(word);
        onWordPlayed(word.length);
        analyzeLeave(word);
      });
    });
  }

  // ── Render Saved Words ────────────────────────────────────────────────────
  // ── Download Saved Words ──────────────────────────────────────────────────
  const downloadBtn = document.getElementById('download-saved-btn')!;

  function updateDownloadBtnVisibility() {
    const achievements = getAchievements();
    if (achievements.length > 0) {
      downloadBtn.classList.remove('opacity-30');
      downloadBtn.classList.add('opacity-100');
      downloadBtn.removeAttribute('disabled');
    } else {
      downloadBtn.classList.add('opacity-30');
      downloadBtn.classList.remove('opacity-100');
      downloadBtn.setAttribute('disabled', 'true');
    }
  }

  let savedWordsPage = 0;

  function renderSavedWords() {
    const achievements = getAchievements();
    const listEl = document.getElementById('saved-words-list')!;
    const countEl = document.getElementById('saved-count')!;

    countEl.textContent = `${achievements.length}`;
    updateDownloadBtnVisibility();

    if (!achievements.length) {
      savedWordsPage = 0;
      listEl.innerHTML = '<p id="saved-empty" class="text-sm text-gray-400 dark:text-gray-500 text-center py-4 italic">No saved words yet. Click any word to collect it.</p>';
      return;
    }

    // Clamp page to valid range
    if (savedWordsPage >= achievements.length) savedWordsPage = achievements.length - 1;
    if (savedWordsPage < 0) savedWordsPage = 0;

    const a = achievements[savedWordsPage];
    const idx = savedWordsPage;

    listEl.innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <button id="saved-prev-btn" class="p-1.5 rounded-lg transition-colors ${idx === 0 ? 'text-gray-300 dark:text-gray-600 cursor-not-allowed' : 'text-gray-500 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 cursor-pointer'}" ${idx === 0 ? 'disabled' : ''} title="Previous word" aria-label="Previous saved word">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-400 font-mono">${idx + 1} / ${achievements.length}</span>
        <button id="saved-next-btn" class="p-1.5 rounded-lg transition-colors ${idx === achievements.length - 1 ? 'text-gray-300 dark:text-gray-600 cursor-not-allowed' : 'text-gray-500 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 cursor-pointer'}" ${idx === achievements.length - 1 ? 'disabled' : ''} title="Next word" aria-label="Next saved word">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
      <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="text-lg">👑</span>
            <span class="font-mono font-bold text-lg text-gray-900 dark:text-white uppercase tracking-wider">${escapeHtml(a.word)}</span>
          </div>
          <span class="text-sm font-bold text-amber-600 dark:text-amber-400">${wordScore(a.word)} pts</span>
        </div>
        ${a.meaning ? `<p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">${escapeHtml(a.meaning)}</p>` : '<p class="text-xs text-gray-400 italic mt-1">No meaning saved</p>'}
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
          <button class="edit-achievement-btn flex-1 py-1.5 text-xs text-center text-gray-500 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 rounded transition-colors" data-idx="${idx}" title="Edit meaning">
            ✏️ Edit
          </button>
          <button class="delete-achievement-btn flex-1 py-1.5 text-xs text-center text-gray-500 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded transition-colors" data-idx="${idx}" title="Delete">
            🗑️ Delete
          </button>
        </div>
      </div>`;

    // Bind nav buttons
    document.getElementById('saved-prev-btn')?.addEventListener('click', () => {
      if (savedWordsPage > 0) { savedWordsPage--; renderSavedWords(); }
    });
    document.getElementById('saved-next-btn')?.addEventListener('click', () => {
      if (savedWordsPage < achievements.length - 1) { savedWordsPage++; renderSavedWords(); }
    });

    // Bind edit button
    listEl.querySelectorAll('.edit-achievement-btn').forEach(btn => {
      btn.addEventListener('click', () => openEditModal(parseInt((btn as HTMLElement).dataset.idx!)));
    });

    // Bind delete button
    listEl.querySelectorAll('.delete-achievement-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        let achievements = getAchievements();
        const removed = achievements[idx];
        achievements.splice(idx, 1);
        saveAchievements(achievements);
        renderSavedWords();
        // Remove achievement styling from any visible word elements
        document.querySelectorAll(`[data-achieve-word="${removed?.word}"]`).forEach(el => {
          el.classList.remove('ring-2', 'ring-emerald-500');
          const tiara = el.querySelector('.achievement-tiara');
          if (tiara) tiara.remove();
        });
      });
    });
  }

  downloadBtn.addEventListener('click', () => {
    const uid = localStorage.getItem('xconvert24-uid') || 'anonymous';
    const scoredWords = JSON.parse(localStorage.getItem('scbScoredWords') || '[]');
    const achievements = getAchievements();
    const exportData = {
      version: 2,
      exportedAt: new Date().toISOString(),
      userId: uid,
      scoredWords: scoredWords,
      achievements: achievements,
    };
    const json = JSON.stringify(exportData, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `scrabble-words-${uid.slice(0, 8)}-${new Date().toISOString().slice(0, 10)}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // ── Edit Modal ────────────────────────────────────────────────────────────
  let editingIdx = -1;
  let editingStar = 3;
  const editModal = document.getElementById('edit-modal')!;
  const editWordDisplay = document.getElementById('edit-word-display')!;
  const editWordScore = document.getElementById('edit-word-score')!;
  const editComment = document.getElementById('edit-comment') as HTMLTextAreaElement;
  const editDatetime = document.getElementById('edit-datetime') as HTMLInputElement;

  function openEditModal(idx: number) {
    const achievements = getAchievements();
    if (idx < 0 || idx >= achievements.length) return;
    const a = achievements[idx];
    editingIdx = idx;
    editingStar = 3; // default

    editWordDisplay.textContent = a.word;
    editWordScore.textContent = `${wordScore(a.word)} pts`;
    editComment.value = a.meaning || '';
    editDatetime.value = new Date().toISOString().slice(0, 16);
    updateStarUI();

    // Highlight the word's tiles
    highlightTiles(a.word);

    editModal.classList.remove('hidden');
    editModal.classList.add('flex');
  }

  function closeEditModal() {
    editModal.classList.add('hidden');
    editModal.classList.remove('flex');
    editingIdx = -1;
    // Clear tile highlights
    highlightTiles('');
  }

  function updateStarUI() {
    document.querySelectorAll('.star-btn').forEach(btn => {
      const val = parseInt((btn as HTMLElement).dataset.star!);
      if (val === editingStar) {
        (btn as HTMLElement).classList.add('ring-2', 'ring-amber-500', 'bg-amber-50', 'dark:bg-amber-900/30');
      } else {
        (btn as HTMLElement).classList.remove('ring-2', 'ring-amber-500', 'bg-amber-50', 'dark:bg-amber-900/30');
      }
    });
  }

  // Star button clicks
  document.querySelectorAll('.star-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      editingStar = parseInt((btn as HTMLElement).dataset.star!);
      updateStarUI();
    });
  });

  // Save edit
  document.getElementById('edit-save-btn')!.addEventListener('click', () => {
    const achievements = getAchievements();
    if (editingIdx < 0 || editingIdx >= achievements.length) return;
    achievements[editingIdx].meaning = editComment.value.trim();
    saveAchievements(achievements);
    closeEditModal();
    renderSavedWords();
  });

  // Cancel / close
  document.getElementById('edit-cancel-btn')!.addEventListener('click', closeEditModal);
  document.getElementById('edit-modal-close')!.addEventListener('click', closeEditModal);

  // ── Helpers ───────────────────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatDateTime(dt: string): string {
    try {
      const d = new Date(dt);
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch { return dt; }
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  document.getElementById('solve-btn')!.addEventListener('click', solve);
  document.getElementById('tiles')!.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') solve(); });
  document.getElementById('min-len')!.addEventListener('change', solve);
  document.getElementById('sort-by')!.addEventListener('change', solve);
  document.getElementById('starts-with')!.addEventListener('input', () => { if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve(); });
  document.getElementById('ends-with')!.addEventListener('input', () => { if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve(); });
  document.getElementById('dictionary')!.addEventListener('change', () => {
    const dict = (document.getElementById('dictionary') as HTMLSelectElement).value;
    currentDict = dict;
    WORDS = dict === 'twl' ? TWL : SOWPODS;
    localStorage.setItem('scbDictionary', dict);
    // Re-run search if tiles are entered
    if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve();
    // Update reference panels with new dictionary
    populateReferencePanels();
  });

  // ── Instant Search (debounced) ────────────────────────────────────────────
  let solveTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('tiles')!.addEventListener('input', () => {
    if (solveTimer) clearTimeout(solveTimer);
    solveTimer = setTimeout(() => {
      const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim();
      if (tiles.length >= 2) solve();
    }, 300);
  });

  // Render tile scores reference — styled like classic wooden Scrabble tiles
  const scoresEl = document.getElementById('tile-scores')!;

  // Generate random wood grain/scratch marks for each tile
  function randomGrainSVG(): string {
    const marks: string[] = [];
    const gradId = 'g' + Math.random().toString(36).slice(2, 8);

    marks.push(`<defs>
      <linearGradient id="${gradId}" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="rgba(40,20,5,0.02)" />
        <stop offset="25%" stop-color="rgba(40,20,5,0.3)" />
        <stop offset="50%" stop-color="rgba(40,20,5,0.35)" />
        <stop offset="75%" stop-color="rgba(40,20,5,0.3)" />
        <stop offset="100%" stop-color="rgba(40,20,5,0.02)" />
      </linearGradient>
    </defs>`);

    // 5-8 wavy diagonal grain curves with big perpendicular oscillation
    const numGrains = 5 + Math.floor(Math.random() * 4);
    for (let i = 0; i < numGrains; i++) {
      const spread = (i / numGrains) * 80;
      // Start and end along diagonal
      const sx = -10 + spread * 0.6 + Math.random() * 8;
      const sy = -10 + spread * 0.4 + Math.random() * 8;
      const ex = sx + 60 + Math.random() * 30;
      const ey = sy + 60 + Math.random() * 30;

      // Big wavy oscillation perpendicular to diagonal (±15-25px)
      const wave1 = (Math.random() > 0.5 ? 1 : -1) * (15 + Math.random() * 12);
      const wave2 = (Math.random() > 0.5 ? 1 : -1) * (15 + Math.random() * 12);
      const wave3 = (Math.random() > 0.5 ? 1 : -1) * (12 + Math.random() * 10);

      // Control points offset perpendicular to the diagonal
      const midX = (sx + ex) / 2;
      const midY = (sy + ey) / 2;
      const cp1x = sx + (ex - sx) * 0.25 + wave1;
      const cp1y = sy + (ey - sy) * 0.25 - wave1;
      const cp2x = midX + wave2;
      const cp2y = midY - wave2;
      const cp3x = sx + (ex - sx) * 0.75 + wave3;
      const cp3y = sy + (ey - sy) * 0.75 - wave3;

      const width = 1 + Math.random() * 2;
      const opacity = 0.15 + Math.random() * 0.2;

      marks.push(`<path d="M${sx},${sy} C${cp1x},${cp1y} ${cp2x},${cp2y} ${midX},${midY} S${cp3x},${cp3y} ${ex},${ey}" fill="none" stroke="url(#${gradId})" stroke-width="${width}" stroke-linecap="round" opacity="${opacity}"/>`);
    }

    // 2-3 thinner wavy wisps
    const numWisps = 2 + Math.floor(Math.random() * 2);
    for (let i = 0; i < numWisps; i++) {
      const offset = 5 + Math.random() * 70;
      const sx = Math.random() * 15;
      const sy = offset * 0.5;
      const ex = 75 + Math.random() * 15;
      const ey = sy + 55 + Math.random() * 20;
      const w1 = (Math.random() > 0.5 ? 1 : -1) * (12 + Math.random() * 15);
      const w2 = (Math.random() > 0.5 ? 1 : -1) * (12 + Math.random() * 15);
      const cp1x = sx + (ex - sx) * 0.33 + w1;
      const cp1y = sy + (ey - sy) * 0.33 - w1;
      const cp2x = sx + (ex - sx) * 0.66 + w2;
      const cp2y = sy + (ey - sy) * 0.66 - w2;
      marks.push(`<path d="M${sx},${sy} C${cp1x},${cp1y} ${cp2x},${cp2y} ${ex},${ey}" fill="none" stroke="rgba(35,18,5,${0.12 + Math.random() * 0.15})" stroke-width="${0.6 + Math.random() * 1}" stroke-linecap="round"/>`);
    }

    // Knots — only ~30% of tiles get a prominent knot
    if (Math.random() > 0.7) {
      const cx = 15 + Math.random() * 60;
      const cy = 15 + Math.random() * 60;
      const size = 6 + Math.random() * 10;
      const rot = 30 + Math.random() * 30;
      const knotOpacity = 0.2 + Math.random() * 0.15;
      // Outer ring
      marks.push(`<ellipse cx="${cx}" cy="${cy}" rx="${size}" ry="${size * 0.6}" fill="rgba(50,25,8,${knotOpacity * 0.3})" stroke="rgba(40,20,5,${knotOpacity})" stroke-width="1.5" transform="rotate(${rot} ${cx} ${cy})"/>`);
      // Inner ring
      marks.push(`<ellipse cx="${cx}" cy="${cy}" rx="${size * 0.5}" ry="${size * 0.3}" fill="rgba(60,30,10,${knotOpacity * 0.4})" stroke="rgba(35,18,5,${knotOpacity * 0.8})" stroke-width="1" transform="rotate(${rot} ${cx} ${cy})"/>`);
      // Center dot
      marks.push(`<circle cx="${cx}" cy="${cy}" r="${1 + Math.random() * 1.5}" fill="rgba(40,20,5,${knotOpacity * 0.6})"/>`);
      // Grain lines wrapping around knot
      for (let k = 0; k < 3; k++) {
        const kAngle = rot + (-20 + k * 20);
        const kRad = (kAngle * Math.PI) / 180;
        const kDist = size + 3 + Math.random() * 5;
        const ksx = cx + Math.cos(kRad - 0.8) * kDist;
        const ksy = cy + Math.sin(kRad - 0.8) * kDist;
        const kex = cx + Math.cos(kRad + 0.8) * kDist;
        const key = cy + Math.sin(kRad + 0.8) * kDist;
        const kcx = cx + Math.cos(kRad) * (kDist + 5 + Math.random() * 4);
        const kcy = cy + Math.sin(kRad) * (kDist + 5 + Math.random() * 4);
        marks.push(`<path d="M${ksx},${ksy} Q${kcx},${kcy} ${kex},${key}" fill="none" stroke="rgba(40,20,5,${0.1 + Math.random() * 0.1})" stroke-width="${0.6 + Math.random() * 0.8}" stroke-linecap="round"/>`);
      }
    } else if (Math.random() > 0.5) {
      // Smaller subtle knot on some other tiles
      const cx = 20 + Math.random() * 50;
      const cy = 20 + Math.random() * 50;
      const rx = 4 + Math.random() * 6;
      const ry = 2.5 + Math.random() * 4;
      marks.push(`<ellipse cx="${cx}" cy="${cy}" rx="${rx}" ry="${ry}" fill="none" stroke="rgba(45,22,5,${0.12 + Math.random() * 0.1})" stroke-width="1.2" transform="rotate(${40 + Math.random() * 15} ${cx} ${cy})"/>`);
    }

    return `<svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">${marks.join('')}</svg>`;
  }

  scoresEl.innerHTML = Object.entries(scores).map(([letter, pts]) =>
    `<div class="scrabble-tile w-[90px] h-[90px] mx-[2px] rounded-lg flex flex-col items-center justify-center cursor-default select-none relative overflow-hidden" data-letter="${letter}"
          style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), inset 2px 0 3px rgba(0,0,0,0.03), inset -2px 0 3px rgba(0,0,0,0.03), 0 4px 8px rgba(0,0,0,0.2), 0 2px 4px rgba(0,0,0,0.12); border: 2px solid #c4a882;">
      ${randomGrainSVG()}
      <span class="text-6xl font-black text-gray-900 leading-none relative z-[1]" style="font-family: 'Arial Black', 'Helvetica Neue', sans-serif; text-shadow: none;">${letter}</span>
      <span class="text-lg font-bold text-gray-900 absolute bottom-2 right-3 leading-none z-[1]" style="font-family: 'Arial Black', 'Helvetica Neue', sans-serif;">${pts}</span>
    </div>`
  ).join('');

  // ── Highlight tiles for a word ────────────────────────────────────────────
  function highlightTiles(word: string) {
    const heading = document.getElementById('tile-scores-heading')!;

    // Reset all tiles
    document.querySelectorAll('.scrabble-tile').forEach(tile => {
      (tile as HTMLElement).style.outline = '';
      (tile as HTMLElement).style.outlineOffset = '';
      tile.classList.remove('tile-highlighted');
    });

    if (!word) {
      heading.textContent = 'Tile Scores';
      return;
    }

    // Update heading with the word's score
    const score = wordScore(word);
    heading.innerHTML = `Tile Scores = <span class="text-amber-600 dark:text-amber-400">${score} pts</span> <span class="text-sm font-normal text-gray-400">(${word.toUpperCase()})</span>`;

    // Count letters in the word
    const letterCounts: Record<string, number> = {};
    for (const ch of word.toUpperCase()) {
      letterCounts[ch] = (letterCounts[ch] || 0) + 1;
    }

    // Highlight matching tiles
    const highlighted = new Set<string>();
    document.querySelectorAll('.scrabble-tile').forEach(tile => {
      const letter = (tile as HTMLElement).dataset.letter!;
      if (letterCounts[letter] && letterCounts[letter] > 0) {
        (tile as HTMLElement).style.outline = '4px solid #f59e0b';
        (tile as HTMLElement).style.outlineOffset = '2px';
        tile.classList.add('tile-highlighted');
        highlighted.add(letter);
      }
    });

    // Scroll tile scores into view if not visible
    if (highlighted.size > 0) {
      scoresEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  // ── Achievements System ─────────────────────────────────────────────────
  const ACHIEVEMENTS_KEY = 'scbAchievements';

  interface Achievement {
    word: string;
    meaning: string;
  }

  function getAchievements(): Achievement[] {
    try {
      const data = JSON.parse(localStorage.getItem(ACHIEVEMENTS_KEY) || '[]');
      // Migrate old format (string[]) to new format ({word, meaning}[])
      if (data.length > 0 && typeof data[0] === 'string') {
        const migrated = data.map((w: string) => ({ word: w, meaning: '' })).reverse();
        localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(migrated));
        return migrated;
      }
      // Migrate old order (oldest-first) to new order (newest-first)
      if (data.length > 0 && !localStorage.getItem('scbAchievements_v2')) {
        data.reverse();
        localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(data));
        localStorage.setItem('scbAchievements_v2', '1');
        return data;
      }
      return data;
    } catch { return []; }
  }

  function getAchievedWords(): string[] {
    return getAchievements().map(a => a.word);
  }

  function saveAchievements(achievements: Achievement[]) {
    localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(achievements));
    // Sync to server in background
    const uid = localStorage.getItem('xconvert24-uid');
    if (uid) {
      fetch('/api/scrabble-sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uid, achievements, dictionary: currentDict }),
      }).catch(() => {});
    }
  }

  async function fetchMeaning(word: string): Promise<string> {
    try {
      const res = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
      if (!res.ok) return '';
      const data = await res.json();
      const meaning = data[0]?.meanings?.[0];
      const def = meaning?.definitions?.[0]?.definition || '';
      const pos = meaning?.partOfSpeech || '';
      return pos ? `(${pos}) ${def}` : def;
    } catch { return ''; }
  }

  function toggleAchievement(word: string, el: HTMLElement) {
    let achievements = getAchievements();
    const exists = achievements.find(a => a.word === word);
    if (exists) {
      // Remove achievement
      achievements = achievements.filter(a => a.word !== word);
      el.classList.remove('ring-2', 'ring-emerald-500');
      const tiara = el.querySelector('.achievement-tiara');
      if (tiara) tiara.remove();
    } else {
      // Add achievement (fetch meaning async)
      achievements.unshift({ word, meaning: '' });
      el.classList.add('ring-2', 'ring-emerald-500');
      if (!el.querySelector('.achievement-tiara')) {
        const tiara = document.createElement('span');
        tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
        tiara.textContent = '👑';
        el.style.position = 'relative';
        el.appendChild(tiara);
      }
      // Copy word to clipboard
      navigator.clipboard.writeText(word.toUpperCase()).catch(() => {});
      // Reset carousel to show newest word
      savedWordsPage = 0;
      // Fetch and save meaning in background
      fetchMeaning(word).then(meaning => {
        const updated = getAchievements();
        const entry = updated.find(a => a.word === word);
        if (entry) {
          entry.meaning = meaning;
          saveAchievements(updated);
          renderSavedWords();
        }
      });
    }
    saveAchievements(achievements);
    renderSavedWords();
  }

  function applyAchievements(container: HTMLElement) {
    const achievedWords = getAchievedWords();
    container.querySelectorAll('[data-achieve-word]').forEach(el => {
      const word = (el as HTMLElement).dataset.achieveWord!;
      if (achievedWords.includes(word)) {
        el.classList.add('ring-2', 'ring-emerald-500');
        if (!el.querySelector('.achievement-tiara')) {
          const tiara = document.createElement('span');
          tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
          tiara.textContent = '👑';
          (el as HTMLElement).style.position = 'relative';
          el.appendChild(tiara);
        }
      }
    });
  }

  function bindAchievementClicks(container: HTMLElement) {
    container.querySelectorAll('[data-achieve-word]').forEach(el => {
      el.addEventListener('click', () => {
        const word = (el as HTMLElement).dataset.achieveWord!;
        toggleAchievement(word, el as HTMLElement);
      });
    });
  }

  // Render saved words on load (after achievements system is defined)
  renderSavedWords();

  // Restore from server if localStorage is empty (e.g. after nuke + relink)
  (function syncFromServer() {
    const uid = localStorage.getItem('xconvert24-uid');
    if (!uid) return;
    const local = getAchievements();
    // Only restore from server if local is empty (nuke scenario)
    if (local.length === 0) {
      fetch(`/api/scrabble-sync?uid=${encodeURIComponent(uid)}`)
        .then(r => r.json())
        .then(data => {
          if (data.achievements && data.achievements.length > 0) {
            localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(data.achievements));
            localStorage.setItem('scbAchievements_v2', '1');
            if (data.dictionary) {
              localStorage.setItem('scbDictionary', data.dictionary);
              currentDict = data.dictionary;
              WORDS = data.dictionary === 'twl' ? TWL : SOWPODS;
              (document.getElementById('dictionary') as HTMLSelectElement).value = data.dictionary;
            }
            savedWordsPage = 0;
            renderSavedWords();
          }
        })
        .catch(() => {});
    }
  })();

  // ── Populate Reference Panels (after dictionary loads) ────────────────────
  function populateReferencePanels() {
    if (!dictionaryLoaded) return;

    // Two-Letter Words
    const twoLetterEl = document.getElementById('two-letter-words');
    if (twoLetterEl) {
      const twoLetters = WORDS.filter(w => w.length === 2).sort();
      twoLetterEl.innerHTML = `
        <div class="flex flex-wrap gap-1.5">
          ${twoLetters.map(w => `<span data-achieve-word="${w}" class="inline-block px-1.5 py-0.5 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded font-mono font-semibold uppercase text-amber-700 dark:text-amber-300 cursor-pointer hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-all">${w}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${wordScore(w)}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">${twoLetters.length} words total</p>
      `;
      applyAchievements(twoLetterEl);
      bindAchievementClicks(twoLetterEl);
    }

    // Three-Letter Words (top 30 by score)
    const threeLetterEl = document.getElementById('three-letter-words');
    if (threeLetterEl) {
      const threeLetters = WORDS.filter(w => w.length === 3)
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 30);
      threeLetterEl.innerHTML = `
        <div class="flex flex-wrap gap-1.5">
          ${threeLetters.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded font-mono font-semibold uppercase text-blue-700 dark:text-blue-300 cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">Top 30 by score</p>
      `;
      applyAchievements(threeLetterEl);
      bindAchievementClicks(threeLetterEl);
    }

    // Q Without U
    const qNoUEl = document.getElementById('q-without-u');
    if (qNoUEl) {
      const qNoU = WORDS.filter(w => w.includes('q') && !w.includes('u'))
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score);
      if (qNoU.length) {
        qNoUEl.innerHTML = `
          <div class="flex flex-wrap gap-1.5">
            ${qNoU.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded font-mono font-semibold uppercase text-purple-700 dark:text-purple-300 cursor-pointer hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
          </div>
          <p class="mt-2 text-xs text-gray-400">${qNoU.length} words — memorise these!</p>
        `;
        applyAchievements(qNoUEl);
        bindAchievementClicks(qNoUEl);
      } else {
        qNoUEl.innerHTML = '<p class="text-xs text-gray-400">None found in dictionary</p>';
      }
    }
  }

  // Wait for dictionary then populate panels
  const panelInterval = setInterval(() => {
    if (dictionaryLoaded) {
      clearInterval(panelInterval);
      populateReferencePanels();
      initRareLetterTabs();
    }
  }, 200);

  // ── Rare Letter Tabs ──────────────────────────────────────────────────────
  function initRareLetterTabs() {
    const tabs = document.querySelectorAll('.rare-tab');
    const resultsEl = document.getElementById('rare-letter-results');
    if (!tabs.length || !resultsEl) return;

    function showRareLetter(letter: string) {
      const words = WORDS.filter(w => w.includes(letter))
        .map(w => ({ word: w, score: wordScore(w) }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 40);

      const colors: Record<string, { bg: string; border: string; text: string }> = {
        q: { bg: 'bg-purple-50 dark:bg-purple-900/20', border: 'border-purple-200 dark:border-purple-800', text: 'text-purple-700 dark:text-purple-300' },
        z: { bg: 'bg-red-50 dark:bg-red-900/20', border: 'border-red-200 dark:border-red-800', text: 'text-red-700 dark:text-red-300' },
        x: { bg: 'bg-orange-50 dark:bg-orange-900/20', border: 'border-orange-200 dark:border-orange-800', text: 'text-orange-700 dark:text-orange-300' },
        j: { bg: 'bg-emerald-50 dark:bg-emerald-900/20', border: 'border-emerald-200 dark:border-emerald-800', text: 'text-emerald-700 dark:text-emerald-300' },
      };
      const c = colors[letter] || colors.q;

      resultsEl.innerHTML = `
        <div class="flex flex-wrap gap-1.5">
          ${words.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 ${c.bg} border ${c.border} rounded font-mono font-semibold uppercase ${c.text} cursor-pointer hover:opacity-80 transition-all">${w.word}<sup class="ml-0.5 text-gray-400" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}
        </div>
        <p class="mt-2 text-xs text-gray-400">Top 40 words containing "${letter.toUpperCase()}" by score</p>
      `;
      applyAchievements(resultsEl);
      bindAchievementClicks(resultsEl);

      // Update tab styles
      tabs.forEach(tab => {
        const t = tab as HTMLElement;
        if (t.dataset.rare === letter) {
          t.className = 'rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold ' + c.bg + ' ' + c.text + ' border ' + c.border;
        } else {
          t.className = 'rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700';
        }
      });
    }

    // Default to Q
    showRareLetter('q');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const letter = (tab as HTMLElement).dataset.rare!;
        showRareLetter(letter);
      });
    });
  }

  // ── Tile Probability Calculator ─────────────────────────────────────────
  const FULL_BAG: Record<string, number> = {
    A:9,B:2,C:2,D:4,E:12,F:2,G:3,H:2,I:9,J:1,K:1,L:4,M:2,
    N:6,O:8,P:2,Q:1,R:6,S:4,T:6,U:4,V:2,W:2,X:1,Y:2,Z:1,'?':2
  };
  const TOTAL_TILES = 100;
  const PROB_STORAGE_KEY = 'scbTileProb';

  // Load saved state
  function loadProbState(): { inBag: number; played: number } {
    try {
      const saved = JSON.parse(localStorage.getItem(PROB_STORAGE_KEY) || '{}');
      return { inBag: saved.inBag ?? 100, played: saved.played ?? 0 };
    } catch { return { inBag: 100, played: 0 }; }
  }

  function saveProbState(inBag: number, played: number) {
    localStorage.setItem(PROB_STORAGE_KEY, JSON.stringify({ inBag, played }));
  }

  // Init inputs from localStorage
  const probState = loadProbState();
  const inBagInput = document.getElementById('tiles-in-bag') as HTMLInputElement;
  const playedInput = document.getElementById('tiles-played') as HTMLInputElement;
  inBagInput.value = String(probState.inBag);
  playedInput.value = String(probState.played);

  function updateProbability() {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    const inBag = parseInt(inBagInput.value) || 0;
    const tilesPlayed = parseInt(playedInput.value) || 0;
    const rackEl = document.getElementById('prob-your-rack');
    const chancesEl = document.getElementById('prob-draw-chances');
    if (!rackEl || !chancesEl) return;

    const rackCount = tiles.length;
    rackEl.textContent = String(rackCount);

    // Save state
    saveProbState(inBag, tilesPlayed);

    if (rackCount === 0 || inBag === 0) {
      chancesEl.innerHTML = '<span class="italic">Enter your rack letters in the solver above ↑ to see draw probabilities</span>';
      return;
    }

    // Calculate remaining bag (subtract your rack tiles from full bag)
    const bag = { ...FULL_BAG };
    for (const ch of tiles) {
      const key = ch === '?' ? '?' : ch;
      if (bag[key] && bag[key] > 0) bag[key]--;
    }

    // Use the user-configured "in bag" value for probability denominator
    const remaining = Math.max(0, inBag);

    // Show probability of drawing key tiles
    const keyTiles = ['S','E','R','T','N','?','Z','Q','X','J'];
    const rows = keyTiles
      .filter(t => bag[t] > 0)
      .map(t => {
        const count = bag[t];
        const pct = remaining > 0 ? ((count / remaining) * 100).toFixed(1) : '0.0';
        const label = t === '?' ? 'Blank' : t;
        return `<div class="flex items-center justify-between"><span class="font-mono font-semibold">${label}</span><span>${count} left — <strong class="text-amber-600 dark:text-amber-400">${pct}%</strong> chance</span></div>`;
      });

    chancesEl.innerHTML = `
      <div class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-2">Draw probability (next tile from bag of ${remaining}):</div>
      <div class="space-y-1 text-xs text-gray-600 dark:text-gray-400">${rows.join('')}</div>
    `;
  }

  // When user plays a word (saves it), auto-increment "played" by word length and decrement "in bag"
  function onWordPlayed(wordLength: number) {
    const currentPlayed = parseInt(playedInput.value) || 0;
    const currentInBag = parseInt(inBagInput.value) || 0;
    playedInput.value = String(currentPlayed + wordLength);
    inBagInput.value = String(Math.max(0, currentInBag - wordLength));
    updateProbability();
  }

  // Update probability when tiles change or bag/played values change
  document.getElementById('tiles')!.addEventListener('input', updateProbability);
  inBagInput.addEventListener('input', updateProbability);
  playedInput.addEventListener('input', updateProbability);
  updateProbability();

  // ── Rack Leave Analyzer ─────────────────────────────────────────────────
  function analyzeLeave(playedWord: string) {
    const panel = document.getElementById('rack-leave-panel');
    if (!panel) return;

    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    if (!tiles || tiles.length < 2) {
      panel.innerHTML = '<div class="text-xs text-gray-400 italic">Enter your rack tiles first</div>';
      return;
    }

    // Calculate remaining tiles after playing the word
    const available = tiles.split('');
    const wordLetters = playedWord.toUpperCase().split('');
    const leave: string[] = [...available];

    for (const ch of wordLetters) {
      const idx = leave.indexOf(ch);
      if (idx !== -1) {
        leave.splice(idx, 1);
      } else {
        // Used a blank
        const blankIdx = leave.indexOf('?');
        if (blankIdx !== -1) leave.splice(blankIdx, 1);
      }
    }

    if (leave.length === 0) {
      panel.innerHTML = `
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3">
          <div class="text-sm font-semibold text-green-700 dark:text-green-300">🎯 Bingo! You used all your tiles</div>
          <div class="text-xs text-green-600 dark:text-green-400 mt-1">+50 bonus points in a real game</div>
        </div>
      `;
      return;
    }

    // Analyze leave quality
    const vowels = leave.filter(l => 'AEIOU'.includes(l)).length;
    const consonants = leave.filter(l => l !== '?' && !'AEIOU'.includes(l)).length;
    const blanks = leave.filter(l => l === '?').length;
    const hasS = leave.includes('S');
    const highValue = leave.filter(l => (scores[l] || 0) >= 4);
    const leaveScore = leave.reduce((sum, l) => sum + (scores[l] || 0), 0);

    // Quality scoring (0-100)
    let quality = 50;

    // Vowel/consonant balance (ideal ~40% vowels for 7 tiles, ~33% for fewer)
    const ratio = leave.length > 0 ? vowels / leave.length : 0;
    if (ratio >= 0.3 && ratio <= 0.5) quality += 15;
    else if (ratio === 0 || ratio >= 0.7) quality -= 20;
    else quality -= 5;

    // Keeping an S is great
    if (hasS) quality += 12;

    // Blanks are the best tiles to keep
    quality += blanks * 15;

    // Common letters (E, R, S, T, N) are good to keep
    const commonTiles = leave.filter(l => 'ERSTNA'.includes(l)).length;
    quality += commonTiles * 3;

    // High-value tiles with no vowels is bad (hard to use)
    if (highValue.length > 0 && vowels === 0) quality -= 15;

    // Duplicate letters are bad
    const counts: Record<string, number> = {};
    leave.forEach(l => { counts[l] = (counts[l] || 0) + 1; });
    const dupes = Object.values(counts).filter(c => c > 1).length;
    quality -= dupes * 8;

    // Cap at 0-100
    quality = Math.max(0, Math.min(100, quality));

    // Quality label
    let qualityLabel: string;
    let qualityColor: string;
    if (quality >= 75) { qualityLabel = 'Excellent'; qualityColor = 'text-green-600 dark:text-green-400'; }
    else if (quality >= 55) { qualityLabel = 'Good'; qualityColor = 'text-blue-600 dark:text-blue-400'; }
    else if (quality >= 35) { qualityLabel = 'Fair'; qualityColor = 'text-amber-600 dark:text-amber-400'; }
    else { qualityLabel = 'Poor'; qualityColor = 'text-red-600 dark:text-red-400'; }

    // Advice
    const advice: string[] = [];
    if (vowels === 0) advice.push('⚠️ No vowels — you may struggle next turn');
    if (ratio >= 0.7) advice.push('⚠️ Too many vowels — consider playing more');
    if (hasS) advice.push('✓ Keeping S is great for plurals and hooks');
    if (blanks > 0) advice.push('✓ Blank tiles give maximum flexibility');
    if (dupes > 0) advice.push('⚠️ Duplicate letters reduce your options');
    if (highValue.length >= 2) advice.push('💡 Multiple high-value tiles — try to play one next turn');

    panel.innerHTML = `
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="text-sm font-medium text-gray-700 dark:text-gray-300">After playing <span class="font-mono font-bold uppercase text-amber-600 dark:text-amber-400">${playedWord}</span>, your leave is:</div>
        </div>
        <div class="flex items-center gap-2">
          ${leave.map(l => `<span class="inline-flex items-center justify-center w-8 h-8 rounded bg-amber-100 dark:bg-amber-900/30 border border-amber-300 dark:border-amber-700 font-mono font-bold text-amber-800 dark:text-amber-200 text-sm">${l === '?' ? '★' : l}</span>`).join('')}
          <span class="ml-2 text-xs text-gray-400">(${leaveScore} pts in hand)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
            <div class="h-full rounded-full ${quality >= 75 ? 'bg-green-500' : quality >= 55 ? 'bg-blue-500' : quality >= 35 ? 'bg-amber-500' : 'bg-red-500'}" style="width:${quality}%"></div>
          </div>
          <span class="text-sm font-semibold ${qualityColor}">${qualityLabel}</span>
          <span class="text-xs text-gray-400">${quality}/100</span>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1">
          <div>Vowels: ${vowels} · Consonants: ${consonants}${blanks ? ' · Blanks: ' + blanks : ''}</div>
          ${advice.length ? '<div class="mt-1 space-y-0.5">' + advice.map(a => `<div>${a}</div>`).join('') + '</div>' : ''}
        </div>
      </div>
    `;
  }

  // Hook into achievement click to also analyze leave

  // ── Best Opening Moves ────────────────────────────────────────────────────
  function updateBestOpeners() {
    const panel = document.getElementById('best-opening-panel');
    if (!panel || !dictionaryLoaded) return;

    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim();
    if (!tiles || tiles.length < 2) {
      panel.innerHTML = '<div class="text-xs text-gray-400 italic">Enter your tiles above ↑ to see your best opening plays</div>';
      return;
    }

    // Find all words playable from rack (opening = use tiles only, no board)
    const playable = WORDS
      .filter(w => w.length >= 2 && w.length <= tiles.length && canMake(w, tiles))
      .map(w => {
        // Opening move bonus: double word score (all letters go through centre star)
        const baseScore = wordScore(w);
        const openingScore = baseScore * 2;
        return { word: w, baseScore, openingScore };
      })
      .sort((a, b) => b.openingScore - a.openingScore)
      .slice(0, 10);

    if (!playable.length) {
      panel.innerHTML = '<div class="text-xs text-gray-400 italic">No valid opening words from these tiles</div>';
      return;
    }

    // Check if any are 7-letter (bingo = +50 bonus)
    const hasBingo = playable.some(w => w.word.length === tiles.length && tiles.length === 7);

    panel.innerHTML = `
      <div class="space-y-1.5">
        ${playable.map((w, i) => {
          const isBingo = w.word.length === tiles.length && tiles.length === 7;
          const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
          const bingoBonus = isBingo ? ' <span class="text-green-600 dark:text-green-400 font-semibold">+50 bingo!</span>' : '';
          const totalScore = isBingo ? w.openingScore + 50 : w.openingScore;
          return `
            <div class="flex items-center justify-between px-3 py-2 bg-gray-50 dark:bg-gray-800 rounded-lg">
              <div class="flex items-center gap-2">
                ${medal ? `<span class="text-sm">${medal}</span>` : `<span class="text-xs text-gray-400 w-5">${i + 1}.</span>`}
                <span class="font-mono font-bold uppercase text-gray-900 dark:text-white text-sm">${w.word}</span>
                <span class="text-xs text-gray-400">(${w.word.length} letters)</span>
              </div>
              <div class="text-right">
                <span class="font-bold text-amber-600 dark:text-amber-400 text-sm">${totalScore} pts</span>${bingoBonus}
                <div class="text-xs text-gray-400">${w.baseScore} × 2 DWS</div>
              </div>
            </div>`;
        }).join('')}
      </div>
      ${hasBingo ? '<div class="mt-2 text-xs text-green-600 dark:text-green-400 font-medium">🎯 You have a bingo! Using all 7 tiles earns +50 bonus.</div>' : ''}
      <div class="mt-3 text-xs text-gray-400">DWS = Double Word Score (centre star bonus on opening move)</div>
    `;
  }

  // Update best openers when tiles change
  document.getElementById('tiles')!.addEventListener('input', updateBestOpeners);
  document.getElementById('solve-btn')!.addEventListener('click', updateBestOpeners);

  // ── Word Definitions (click to lookup) ────────────────────────────────────
  async function showDefinition(target: HTMLElement, word: string) {
    // Check if definition tooltip already showing
    const existing = target.querySelector('.word-def-tooltip');
    if (existing) { existing.remove(); return; }

    // Remove any other tooltips
    document.querySelectorAll('.word-def-tooltip').forEach(t => t.remove());

    // Show loading
    const tooltip = document.createElement('div');
    tooltip.className = 'word-def-tooltip absolute left-0 -bottom-1 translate-y-full z-10 p-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg text-xs text-gray-700 dark:text-gray-300';
    tooltip.style.minWidth = '200px';
    tooltip.style.width = 'max-content';
    tooltip.style.maxWidth = '280px';
    tooltip.textContent = 'Looking up…';
    target.style.position = 'relative';
    target.appendChild(tooltip);

    try {
      const res = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
      if (!res.ok) throw new Error('not found');
      const data = await res.json();
      const meaning = data[0]?.meanings?.[0];
      const def = meaning?.definitions?.[0]?.definition || 'No definition available';
      const partOfSpeech = meaning?.partOfSpeech || '';
      tooltip.innerHTML = `<span class="font-semibold text-amber-600 dark:text-amber-400 uppercase">${word}</span> <span class="italic text-gray-400">(${partOfSpeech})</span><br/>${def}`;
    } catch {
      tooltip.innerHTML = `<span class="font-semibold uppercase">${word}</span> — <span class="italic text-gray-400">No definition found</span>`;
    }

    // Auto-dismiss after 8 seconds
    setTimeout(() => { tooltip.remove(); }, 8000);
  }

  // Definitions on solver results
  document.getElementById('results')!.addEventListener('click', async (e) => {
    const target = (e.target as HTMLElement).closest('[data-highlight-word]') as HTMLElement | null;
    if (!target) return;
    showDefinition(target, target.dataset.highlightWord!);
  });

  // Definitions on reference panels (two-letter, three-letter, q-without-u, rare letters)
  ['two-letter-words', 'three-letter-words', 'q-without-u', 'rare-letter-results'].forEach(id => {
    const container = document.getElementById(id);
    if (container) {
      container.addEventListener('click', async (e) => {
        const target = (e.target as HTMLElement).closest('[data-achieve-word]') as HTMLElement | null;
        if (!target) return;
        showDefinition(target, target.dataset.achieveWord!);
      });
    }
  });
</script>
