  // ── Tile Probability Calculator ─────────────────────────────────────────
  const FULL_BAG: Record<string, number> = {
    A:9,B:2,C:2,D:4,E:12,F:2,G:3,H:2,I:9,J:1,K:1,L:4,M:2,
    N:6,O:8,P:2,Q:1,R:6,S:4,T:6,U:4,V:2,W:2,X:1,Y:2,Z:1,'?':2
  };
  const TOTAL_TILES = 100;
  const PROB_STORAGE_KEY = 'scbTileProb';

  // Load saved state
  function loadProbState(): { inBag: number; played: number } {
    try {
      const saved = JSON.parse(localStorage.getItem(PROB_STORAGE_KEY) || '{}');
      return { inBag: saved.inBag ?? 100, played: saved.played ?? 0 };
    } catch { return { inBag: 100, played: 0 }; }
  }

  function saveProbState(inBag: number, played: number) {
    localStorage.setItem(PROB_STORAGE_KEY, JSON.stringify({ inBag, played }));
  }

  // Init inputs from localStorage
  const probState = loadProbState();
  const inBagInput = document.getElementById('tiles-in-bag') as HTMLInputElement;
  const playedInput = document.getElementById('tiles-played') as HTMLInputElement;
  inBagInput.value = String(probState.inBag);
  playedInput.value = String(probState.played);

  function updateProbability() {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    const inBag = parseInt(inBagInput.value) || 0;
    const tilesPlayed = parseInt(playedInput.value) || 0;
    const rackEl = document.getElementById('prob-your-rack');
    const chancesEl = document.getElementById('prob-draw-chances');
    if (!rackEl || !chancesEl) return;

    const rackCount = tiles.length;
    rackEl.textContent = String(rackCount);

    // Save state
    saveProbState(inBag, tilesPlayed);

    if (rackCount === 0 || inBag === 0) {
      chancesEl.innerHTML = '<span class="italic">Enter your rack letters in the solver above ↑ to see draw probabilities</span>';
      return;
    }

    // Calculate remaining bag (subtract your rack tiles from full bag)
    const bag = { ...FULL_BAG };
    for (const ch of tiles) {
      const key = ch === '?' ? '?' : ch;
      if (bag[key] && bag[key] > 0) bag[key]--;
    }

    // Use the user-configured "in bag" value for probability denominator
    const remaining = Math.max(0, inBag);

    // Show probability of drawing key tiles
    const keyTiles = ['S','E','R','T','N','?','Z','Q','X','J'];
    const rows = keyTiles
      .filter(t => bag[t] > 0)
      .map(t => {
        const count = bag[t];
        const pct = remaining > 0 ? ((count / remaining) * 100).toFixed(1) : '0.0';
        const label = t === '?' ? 'Blank' : t;
        return `<div class="flex items-center justify-between"><span class="font-mono font-semibold">${label}</span><span>${count} left — <strong class="text-amber-600 dark:text-amber-400">${pct}%</strong> chance</span></div>`;
      });

    chancesEl.innerHTML = `
      <div class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-2">Draw probability (next tile from bag of ${remaining}):</div>
      <div class="space-y-1 text-xs text-gray-600 dark:text-gray-400">${rows.join('')}</div>
    `;
  }

  // When user plays a word (saves it), auto-increment "played" by word length and decrement "in bag"
  function onWordPlayed(wordLength: number) {
    const currentPlayed = parseInt(playedInput.value) || 0;
    const currentInBag = parseInt(inBagInput.value) || 0;
    playedInput.value = String(currentPlayed + wordLength);
    inBagInput.value = String(Math.max(0, currentInBag - wordLength));
    updateProbability();
  }

  // Update probability when tiles change or bag/played values change
  document.getElementById('tiles')!.addEventListener('input', updateProbability);
  inBagInput.addEventListener('input', updateProbability);
  playedInput.addEventListener('input', updateProbability);
  updateProbability();

  // ── Rack Leave Analyzer ─────────────────────────────────────────────────
  function analyzeLeave(playedWord: string) {
    const panel = document.getElementById('rack-leave-panel');
    if (!panel) return;

    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    if (!tiles || tiles.length < 2) {
      panel.innerHTML = '<div class="text-xs text-gray-400 italic">Enter your rack tiles first</div>';
      return;
    }

    // Calculate remaining tiles after playing the word
    const available = tiles.split('');
    const wordLetters = playedWord.toUpperCase().split('');
    const leave: string[] = [...available];

    for (const ch of wordLetters) {
      const idx = leave.indexOf(ch);
      if (idx !== -1) {
        leave.splice(idx, 1);
      } else {
        // Used a blank
        const blankIdx = leave.indexOf('?');
        if (blankIdx !== -1) leave.splice(blankIdx, 1);
      }
    }

    if (leave.length === 0) {
      panel.innerHTML = `
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3">
          <div class="text-sm font-semibold text-green-700 dark:text-green-300">🎯 Bingo! You used all your tiles</div>
          <div class="text-xs text-green-600 dark:text-green-400 mt-1">+50 bonus points in a real game</div>
        </div>
      `;
      return;
    }

    // Analyze leave quality
    const vowels = leave.filter(l => 'AEIOU'.includes(l)).length;
    const consonants = leave.filter(l => l !== '?' && !'AEIOU'.includes(l)).length;
    const blanks = leave.filter(l => l === '?').length;
    const hasS = leave.includes('S');
    const highValue = leave.filter(l => (scores[l] || 0) >= 4);
    const leaveScore = leave.reduce((sum, l) => sum + (scores[l] || 0), 0);

    // Quality scoring (0-100)
    let quality = 50;

    // Vowel/consonant balance (ideal ~40% vowels for 7 tiles, ~33% for fewer)
    const ratio = leave.length > 0 ? vowels / leave.length : 0;
    if (ratio >= 0.3 && ratio <= 0.5) quality += 15;
    else if (ratio === 0 || ratio >= 0.7) quality -= 20;
    else quality -= 5;

    // Keeping an S is great
    if (hasS) quality += 12;

    // Blanks are the best tiles to keep
    quality += blanks * 15;

    // Common letters (E, R, S, T, N) are good to keep
    const commonTiles = leave.filter(l => 'ERSTNA'.includes(l)).length;
    quality += commonTiles * 3;

    // High-value tiles with no vowels is bad (hard to use)
    if (highValue.length > 0 && vowels === 0) quality -= 15;

    // Duplicate letters are bad
    const counts: Record<string, number> = {};
    leave.forEach(l => { counts[l] = (counts[l] || 0) + 1; });
    const dupes = Object.values(counts).filter(c => c > 1).length;
    quality -= dupes * 8;

    // Cap at 0-100
    quality = Math.max(0, Math.min(100, quality));

    // Quality label
    let qualityLabel: string;
    let qualityColor: string;
    if (quality >= 75) { qualityLabel = 'Excellent'; qualityColor = 'text-green-600 dark:text-green-400'; }
    else if (quality >= 55) { qualityLabel = 'Good'; qualityColor = 'text-blue-600 dark:text-blue-400'; }
    else if (quality >= 35) { qualityLabel = 'Fair'; qualityColor = 'text-amber-600 dark:text-amber-400'; }
    else { qualityLabel = 'Poor'; qualityColor = 'text-red-600 dark:text-red-400'; }

    // Advice
    const advice: string[] = [];
    if (vowels === 0) advice.push('⚠️ No vowels — you may struggle next turn');
    if (ratio >= 0.7) advice.push('⚠️ Too many vowels — consider playing more');
    if (hasS) advice.push('✓ Keeping S is great for plurals and hooks');
    if (blanks > 0) advice.push('✓ Blank tiles give maximum flexibility');
    if (dupes > 0) advice.push('⚠️ Duplicate letters reduce your options');
    if (highValue.length >= 2) advice.push('💡 Multiple high-value tiles — try to play one next turn');

    panel.innerHTML = `
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="text-sm font-medium text-gray-700 dark:text-gray-300">After playing <span class="font-mono font-bold uppercase text-amber-600 dark:text-amber-400">${playedWord}</span>, your leave is:</div>
        </div>
        <div class="flex items-center gap-2">
          ${leave.map(l => `<span class="inline-flex items-center justify-center w-8 h-8 rounded bg-amber-100 dark:bg-amber-900/30 border border-amber-300 dark:border-amber-700 font-mono font-bold text-amber-800 dark:text-amber-200 text-sm">${l === '?' ? '★' : l}</span>`).join('')}
          <span class="ml-2 text-xs text-gray-400">(${leaveScore} pts in hand)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
            <div class="h-full rounded-full ${quality >= 75 ? 'bg-green-500' : quality >= 55 ? 'bg-blue-500' : quality >= 35 ? 'bg-amber-500' : 'bg-red-500'}" style="width:${quality}%"></div>
          </div>
          <span class="text-sm font-semibold ${qualityColor}">${qualityLabel}</span>
          <span class="text-xs text-gray-400">${quality}/100</span>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1">
          <div>Vowels: ${vowels} · Consonants: ${consonants}${blanks ? ' · Blanks: ' + blanks : ''}</div>
          ${advice.length ? '<div class="mt-1 space-y-0.5">' + advice.map(a => `<div>${a}</div>`).join('') + '</div>' : ''}
        </div>
      </div>
    `;
  }

  // Hook into achievement click to also analyze leave

  // ── Word Definitions (click to lookup) ────────────────────────────────────
  async function showDefinition(target: HTMLElement, word: string) {
    // Check if definition tooltip already showing
    const existing = target.querySelector('.word-def-tooltip');
    if (existing) { existing.remove(); return; }

    // Remove any other tooltips
    document.querySelectorAll('.word-def-tooltip').forEach(t => t.remove());

    // Show loading
    const tooltip = document.createElement('div');
    tooltip.className = 'word-def-tooltip absolute left-0 right-0 -bottom-1 translate-y-full z-10 p-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg text-xs text-gray-700 dark:text-gray-300';
    tooltip.textContent = 'Looking up…';
    target.style.position = 'relative';
    target.appendChild(tooltip);

    try {
      const res = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
      if (!res.ok) throw new Error('not found');
      const data = await res.json();
      const meaning = data[0]?.meanings?.[0];
      const def = meaning?.definitions?.[0]?.definition || 'No definition available';
      const partOfSpeech = meaning?.partOfSpeech || '';
      tooltip.innerHTML = `<span class="font-semibold text-amber-600 dark:text-amber-400 uppercase">${word}</span> <span class="italic text-gray-400">(${partOfSpeech})</span><br/>${def}`;
    } catch {
      tooltip.innerHTML = `<span class="font-semibold uppercase">${word}</span> — <span class="italic text-gray-400">No definition found</span>`;
    }

    // Auto-dismiss after 8 seconds
    setTimeout(() => { tooltip.remove(); }, 8000);
  }

  // Definitions on solver results
  document.getElementById('results')!.addEventListener('click', async (e) => {
    const target = (e.target as HTMLElement).closest('[data-highlight-word]') as HTMLElement | null;
    if (!target) return;
    showDefinition(target, target.dataset.highlightWord!);
  });

  // Definitions on reference panels (two-letter, three-letter, q-without-u, rare letters)
  ['two-letter-words', 'three-letter-words', 'q-without-u', 'rare-letter-results'].forEach(id => {
    const container = document.getElementById(id);
    if (container) {
      container.addEventListener('click', async (e) => {
        const target = (e.target as HTMLElement).closest('[data-achieve-word]') as HTMLElement | null;
        if (!target) return;
        showDefinition(target, target.dataset.achieveWord!);
      });
    }
  });
</script>
