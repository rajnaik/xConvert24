  document.getElementById('edit-cancel-btn')!.addEventListener('click', closeEditModal);
  document.getElementById('edit-modal-close')!.addEventListener('click', closeEditModal);

  // ── Helpers ───────────────────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatDateTime(dt: string): string {
    try {
      const d = new Date(dt);
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch { return dt; }
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  document.getElementById('solve-btn')!.addEventListener('click', solve);
  document.getElementById('tiles')!.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') solve(); });
  document.getElementById('min-len')!.addEventListener('change', solve);
  document.getElementById('sort-by')!.addEventListener('change', solve);

  // ── Instant Search (debounced) ────────────────────────────────────────────
  let solveTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('tiles')!.addEventListener('input', () => {
    if (solveTimer) clearTimeout(solveTimer);
    solveTimer = setTimeout(() => {
