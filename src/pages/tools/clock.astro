---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="World Clock — Current Time in Major Cities Worldwide" description="Free World Clock. See live times in 12+ cities worldwide. Add, remove cities, auto-updates every second. No sign-up needed." keywords="world clock, current time, time in London, time in New York, time in Tokyo, international clock, city time zones, GMT time">
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
    .font-digital { font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
  </style>
  <div class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2"><span class="text-3xl">🌍</span><h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free World Clock — Live Times in 12+ Cities</h1></div>
      <p class="text-gray-500 dark:text-gray-400">Current time in major cities worldwide — updates every second</p>
    </div>

    <!-- Add city -->
    <div class="mb-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 shadow-sm">
      <div class="flex gap-2">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input id="city-search" type="text" placeholder="Search and add a city…" autocomplete="off"
            class="w-full h-10 pl-9 pr-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <button id="reset-btn" class="px-3 h-10 rounded-lg text-xs font-medium text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:border-amber-400 hover:text-amber-600 transition-colors" title="Reset to defaults">
          Reset
        </button>
      </div>
      <!-- Search results dropdown -->
      <div id="city-dropdown" class="hidden mt-2 max-h-40 overflow-y-auto bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg"></div>
    </div>

    <!-- Display mode toggle -->
    <div class="mb-5 flex items-center gap-4">
      <label class="inline-flex items-center gap-2 cursor-pointer">
        <input type="radio" name="clock-mode" value="digital" id="mode-digital" class="w-4 h-4 text-amber-500 focus:ring-amber-500 border-gray-300 dark:border-gray-600 dark:bg-gray-800"/>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Digital</span>
      </label>
      <label class="inline-flex items-center gap-2 cursor-pointer">
        <input type="radio" name="clock-mode" value="analog" id="mode-analog" class="w-4 h-4 text-amber-500 focus:ring-amber-500 border-gray-300 dark:border-gray-600 dark:bg-gray-800"/>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Analog</span>
      </label>
    </div>

    <!-- Clocks grid -->
    <div id="clocks-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Populated by JS -->
    </div>

    <!-- Suggest a feature -->
    <div class="mt-6 text-center">
      <a href="/suggest?title=World+Clock" class="inline-flex items-center gap-2 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
        <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
      </a>
    </div>
  </div>
</Layout>

<script>
  const STORAGE_KEY = 'xconvert24-world-clock-cities';
  const MODE_STORAGE_KEY = 'xconvert24-world-clock-mode';

  // Clock display mode
  function getClockMode(): 'digital' | 'analog' {
    try {
      const stored = localStorage.getItem(MODE_STORAGE_KEY);
      if (stored === 'analog') return 'analog';
    } catch {}
    return 'digital';
  }

  function saveClockMode(mode: 'digital' | 'analog') {
    localStorage.setItem(MODE_STORAGE_KEY, mode);
  }

  let clockMode = getClockMode();

  // Set initial radio button state
  const modeDigitalRadio = document.getElementById('mode-digital') as HTMLInputElement;
  const modeAnalogRadio = document.getElementById('mode-analog') as HTMLInputElement;
  if (clockMode === 'analog') {
    modeAnalogRadio.checked = true;
  } else {
    modeDigitalRadio.checked = true;
  }

  // Listen for mode changes
  modeDigitalRadio.addEventListener('change', () => {
    if (modeDigitalRadio.checked) {
      clockMode = 'digital';
      saveClockMode('digital');
      renderClocks();
    }
  });
  modeAnalogRadio.addEventListener('change', () => {
    if (modeAnalogRadio.checked) {
      clockMode = 'analog';
      saveClockMode('analog');
      renderClocks();
    }
  });

  // All available cities
  const allCities = [
    { id: 'new_york', name: 'New York', tz: 'America/New_York', flag: '🇺🇸' },
    { id: 'los_angeles', name: 'Los Angeles', tz: 'America/Los_Angeles', flag: '🇺🇸' },
    { id: 'chicago', name: 'Chicago', tz: 'America/Chicago', flag: '🇺🇸' },
    { id: 'toronto', name: 'Toronto', tz: 'America/Toronto', flag: '🇨🇦' },
    { id: 'vancouver', name: 'Vancouver', tz: 'America/Vancouver', flag: '🇨🇦' },
    { id: 'mexico_city', name: 'Mexico City', tz: 'America/Mexico_City', flag: '🇲🇽' },
    { id: 'sao_paulo', name: 'São Paulo', tz: 'America/Sao_Paulo', flag: '🇧🇷' },
    { id: 'buenos_aires', name: 'Buenos Aires', tz: 'America/Argentina/Buenos_Aires', flag: '🇦🇷' },
    { id: 'london', name: 'London', tz: 'Europe/London', flag: '🇬🇧' },
    { id: 'paris', name: 'Paris', tz: 'Europe/Paris', flag: '🇫🇷' },
    { id: 'berlin', name: 'Berlin', tz: 'Europe/Berlin', flag: '🇩🇪' },
    { id: 'madrid', name: 'Madrid', tz: 'Europe/Madrid', flag: '🇪🇸' },
    { id: 'rome', name: 'Rome', tz: 'Europe/Rome', flag: '🇮🇹' },
    { id: 'amsterdam', name: 'Amsterdam', tz: 'Europe/Amsterdam', flag: '🇳🇱' },
    { id: 'zurich', name: 'Zurich', tz: 'Europe/Zurich', flag: '🇨🇭' },
    { id: 'moscow', name: 'Moscow', tz: 'Europe/Moscow', flag: '🇷🇺' },
    { id: 'istanbul', name: 'Istanbul', tz: 'Europe/Istanbul', flag: '🇹🇷' },
    { id: 'dubai', name: 'Dubai', tz: 'Asia/Dubai', flag: '🇦🇪' },
    { id: 'riyadh', name: 'Riyadh', tz: 'Asia/Riyadh', flag: '🇸🇦' },
    { id: 'new_delhi', name: 'New Delhi', tz: 'Asia/Kolkata', flag: '🇮🇳' },
    { id: 'mumbai', name: 'Mumbai', tz: 'Asia/Kolkata', flag: '🇮🇳' },
    { id: 'bangkok', name: 'Bangkok', tz: 'Asia/Bangkok', flag: '🇹🇭' },
    { id: 'singapore', name: 'Singapore', tz: 'Asia/Singapore', flag: '🇸🇬' },
    { id: 'hong_kong', name: 'Hong Kong', tz: 'Asia/Hong_Kong', flag: '🇭🇰' },
    { id: 'shanghai', name: 'Shanghai', tz: 'Asia/Shanghai', flag: '🇨🇳' },
    { id: 'beijing', name: 'Beijing', tz: 'Asia/Shanghai', flag: '🇨🇳' },
    { id: 'tokyo', name: 'Tokyo', tz: 'Asia/Tokyo', flag: '🇯🇵' },
    { id: 'seoul', name: 'Seoul', tz: 'Asia/Seoul', flag: '🇰🇷' },
    { id: 'sydney', name: 'Sydney', tz: 'Australia/Sydney', flag: '🇦🇺' },
    { id: 'melbourne', name: 'Melbourne', tz: 'Australia/Melbourne', flag: '🇦🇺' },
    { id: 'auckland', name: 'Auckland', tz: 'Pacific/Auckland', flag: '🇳🇿' },
    { id: 'cairo', name: 'Cairo', tz: 'Africa/Cairo', flag: '🇪🇬' },
    { id: 'johannesburg', name: 'Johannesburg', tz: 'Africa/Johannesburg', flag: '🇿🇦' },
    { id: 'lagos', name: 'Lagos', tz: 'Africa/Lagos', flag: '🇳🇬' },
    { id: 'nairobi', name: 'Nairobi', tz: 'Africa/Nairobi', flag: '🇰🇪' },
  ];

  const defaultCityIds = ['new_york', 'london', 'paris', 'toronto', 'tokyo', 'new_delhi', 'melbourne'];

  // State
  function getSelectedIds(): string[] {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) return JSON.parse(stored);
    } catch {}
    return [...defaultCityIds];
  }

  function saveSelectedIds(ids: string[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
  }

  let selectedIds = getSelectedIds();

  // Elements
  const grid = document.getElementById('clocks-grid')!;
  const searchInput = document.getElementById('city-search') as HTMLInputElement;
  const dropdown = document.getElementById('city-dropdown')!;
  const resetBtn = document.getElementById('reset-btn')!;

  function getSelectedCities() {
    return selectedIds.map(id => allCities.find(c => c.id === id)).filter(Boolean) as typeof allCities;
  }

  function renderClocks() {
    const cities = getSelectedCities();
    if (clockMode === 'analog') {
      grid.innerHTML = cities.map(city => `
        <div class="clock-card relative bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 shadow-sm hover:border-amber-400 dark:hover:border-amber-500 transition-colors" data-city-id="${city.id}">
          <button class="remove-city absolute top-3 right-3 w-7 h-7 rounded-full bg-red-100 dark:bg-red-900/30 text-red-500 hover:bg-red-200 dark:hover:bg-red-900/50 flex items-center justify-center transition-colors" data-remove="${city.id}" aria-label="Remove ${city.name}" title="Remove">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
          <div class="flex items-center gap-2 mb-2 pr-10">
            <span class="text-xl" aria-hidden="true">${city.flag}</span>
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">${city.name}</span>
            <span class="text-xs text-gray-400 dark:text-gray-500 font-mono ml-auto" id="tz-${city.id}"></span>
          </div>
          <div class="flex justify-center">
            <canvas id="analog-${city.id}" width="120" height="120" class="block"></canvas>
          </div>
          <div id="date-${city.id}" class="text-xs text-gray-500 dark:text-gray-400 mt-2 text-center">---</div>
        </div>
      `).join('');
    } else {
      grid.innerHTML = cities.map(city => `
        <div class="clock-card relative bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 shadow-sm hover:border-amber-400 dark:hover:border-amber-500 transition-colors" data-city-id="${city.id}">
          <button class="remove-city absolute top-3 right-3 w-7 h-7 rounded-full bg-red-100 dark:bg-red-900/30 text-red-500 hover:bg-red-200 dark:hover:bg-red-900/50 flex items-center justify-center transition-colors" data-remove="${city.id}" aria-label="Remove ${city.name}" title="Remove">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
          <div class="flex items-center gap-2 mb-2 pr-10">
            <span class="text-xl" aria-hidden="true">${city.flag}</span>
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">${city.name}</span>
            <span class="text-xs text-gray-400 dark:text-gray-500 font-mono ml-auto" id="tz-${city.id}"></span>
          </div>
          <div id="time-${city.id}" class="text-3xl font-bold text-gray-900 dark:text-white font-digital tracking-tight">--:--:--</div>
          <div id="date-${city.id}" class="text-xs text-gray-500 dark:text-gray-400 mt-1">---</div>
        </div>
      `).join('');
    }

    // Attach remove handlers
    grid.querySelectorAll('.remove-city').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.remove!;
        selectedIds = selectedIds.filter(i => i !== id);
        saveSelectedIds(selectedIds);
        renderClocks();
      });
    });

    updateClocks();
  }

  function drawAnalogClock(canvasId: string, tz: string) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const now = new Date();
    const timeStr = now.toLocaleTimeString('en-US', { timeZone: tz, hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const [h, m, s] = timeStr.split(':').map(Number);

    const size = canvas.width;
    const center = size / 2;
    const radius = center - 8;

    ctx.clearRect(0, 0, size, size);

    // Face
    ctx.beginPath();
    ctx.arc(center, center, radius, 0, 2 * Math.PI);
    ctx.fillStyle = document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff';
    ctx.fill();
    ctx.strokeStyle = document.documentElement.classList.contains('dark') ? '#4b5563' : '#d1d5db';
    ctx.lineWidth = 2;
    ctx.stroke();

    // Hour markers
    for (let i = 0; i < 12; i++) {
      const angle = (i * Math.PI) / 6 - Math.PI / 2;
      const markerStart = radius - 8;
      const markerEnd = radius - 2;
      ctx.beginPath();
      ctx.moveTo(center + markerStart * Math.cos(angle), center + markerStart * Math.sin(angle));
      ctx.lineTo(center + markerEnd * Math.cos(angle), center + markerEnd * Math.sin(angle));
      ctx.strokeStyle = document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280';
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // Hour hand
    const hourAngle = ((h % 12) + m / 60) * (Math.PI / 6) - Math.PI / 2;
    ctx.beginPath();
    ctx.moveTo(center, center);
    ctx.lineTo(center + (radius * 0.5) * Math.cos(hourAngle), center + (radius * 0.5) * Math.sin(hourAngle));
    ctx.strokeStyle = document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827';
    ctx.lineWidth = 3;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Minute hand
    const minAngle = (m + s / 60) * (Math.PI / 30) - Math.PI / 2;
    ctx.beginPath();
    ctx.moveTo(center, center);
    ctx.lineTo(center + (radius * 0.7) * Math.cos(minAngle), center + (radius * 0.7) * Math.sin(minAngle));
    ctx.strokeStyle = document.documentElement.classList.contains('dark') ? '#d1d5db' : '#374151';
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Second hand
    const secAngle = s * (Math.PI / 30) - Math.PI / 2;
    ctx.beginPath();
    ctx.moveTo(center, center);
    ctx.lineTo(center + (radius * 0.75) * Math.cos(secAngle), center + (radius * 0.75) * Math.sin(secAngle));
    ctx.strokeStyle = '#d97706';
    ctx.lineWidth = 1;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Center dot
    ctx.beginPath();
    ctx.arc(center, center, 3, 0, 2 * Math.PI);
    ctx.fillStyle = '#d97706';
    ctx.fill();
  }

  function updateClocks() {
    const now = new Date();
    getSelectedCities().forEach(({ id, tz }) => {
      const dateEl = document.getElementById(`date-${id}`);
      const tzEl = document.getElementById(`tz-${id}`);

      const dateStr = now.toLocaleDateString('en-US', { timeZone: tz, weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
      const tzAbbr = now.toLocaleTimeString('en-US', { timeZone: tz, timeZoneName: 'short' }).split(' ').pop() || '';

      if (dateEl) dateEl.textContent = dateStr;
      if (tzEl) tzEl.textContent = tzAbbr;

      if (clockMode === 'analog') {
        drawAnalogClock(`analog-${id}`, tz);
      } else {
        const timeEl = document.getElementById(`time-${id}`);
        if (timeEl) {
          const timeStr = now.toLocaleTimeString('en-US', { timeZone: tz, hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
          timeEl.textContent = timeStr;
        }
      }
    });
  }

  // Search & add
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    if (!q) { dropdown.classList.add('hidden'); return; }

    const available = allCities.filter(c => !selectedIds.includes(c.id) && c.name.toLowerCase().includes(q));
    if (!available.length) {
      dropdown.innerHTML = '<div class="px-3 py-2 text-sm text-gray-400 text-center">No cities found</div>';
    } else {
      dropdown.innerHTML = available.slice(0, 8).map(c => `
        <button class="add-city-btn w-full flex items-center gap-2 px-3 py-2.5 text-left text-sm hover:bg-amber-50 dark:hover:bg-amber-900/10 transition-colors" data-add="${c.id}">
          <span>${c.flag}</span>
          <span class="font-medium text-gray-900 dark:text-white">${c.name}</span>
          <span class="text-xs text-gray-400 ml-auto">${c.tz.split('/').pop()?.replace(/_/g, ' ')}</span>
        </button>
      `).join('');

      dropdown.querySelectorAll('.add-city-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.add!;
          selectedIds.push(id);
          saveSelectedIds(selectedIds);
          searchInput.value = '';
          dropdown.classList.add('hidden');
          renderClocks();
        });
      });
    }
    dropdown.classList.remove('hidden');
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#city-search') && !(e.target as Element).closest('#city-dropdown')) {
      dropdown.classList.add('hidden');
    }
  });

  // Reset to defaults
  resetBtn.addEventListener('click', () => {
    selectedIds = [...defaultCityIds];
    saveSelectedIds(selectedIds);
    renderClocks();
  });

  // Init
  renderClocks();
  setInterval(updateClocks, 1000);
</script>
