---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Reminder — Set Countdown Reminders" description="Free online reminder tool. Set countdown timers with custom messages and get notified when time's up. No app needed." keywords="reminder, countdown timer, set reminder, notification, timer, online reminder, pomodoro">
  <div class="max-w-md mx-auto">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🔔</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Online Reminder — Set Countdown Timers</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Set a countdown timer with a custom message</p>
    </div>

    <!-- Set reminder -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <!-- Quick presets -->
      <div class="mb-4">
        <label class="block text-xs text-gray-500 dark:text-gray-400 mb-2">Quick Set</label>
        <div class="flex flex-wrap gap-2">
          {[
            { label: '1 min', m: 1 },
            { label: '5 min', m: 5 },
            { label: '10 min', m: 10 },
            { label: '15 min', m: 15 },
            { label: '25 min', m: 25 },
            { label: '30 min', m: 30 },
            { label: '45 min', m: 45 },
            { label: '1 hr', m: 60 },
            { label: '2 hr', m: 120 },
          ].map(p => (
            <button data-minutes={p.m} class="preset-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:border-amber-400 hover:text-amber-600 transition-colors">{p.label}</button>
          ))}
        </div>
      </div>

      <!-- Custom time -->
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div>
          <label for="rem-hrs" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Hours</label>
          <input id="rem-hrs" type="number" min="0" max="23" value="0" class="w-full h-12 px-3 text-center bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg font-mono focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <div>
          <label for="rem-min" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Minutes</label>
          <input id="rem-min" type="number" min="0" max="59" value="5" class="w-full h-12 px-3 text-center bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg font-mono focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
        <div>
          <label for="rem-sec" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Seconds</label>
          <input id="rem-sec" type="number" min="0" max="59" value="0" class="w-full h-12 px-3 text-center bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-lg font-mono focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        </div>
      </div>

      <!-- Message -->
      <div class="mb-4">
        <label for="rem-msg" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Reminder Message</label>
        <input id="rem-msg" type="text" placeholder="e.g. Take a break, Check the oven…" class="w-full h-11 px-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"/>
      </div>

      <!-- Start button -->
      <button id="rem-start" class="w-full h-12 rounded-lg bg-amber-500 text-white font-semibold text-sm hover:bg-amber-600 transition-colors">
        ▶ Start Reminder
      </button>
    </div>

    <!-- Active countdown -->
    <div id="rem-active" class="hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm text-center">
      <div class="text-xs text-gray-400 uppercase tracking-wider mb-2">Time Remaining</div>
      <div id="rem-countdown" class="text-5xl font-mono font-bold text-amber-600 dark:text-amber-400 mb-2">00:05:00</div>
      <div id="rem-message" class="text-sm text-gray-500 dark:text-gray-400 mb-4 italic"></div>
      <!-- Progress bar -->
      <div class="h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden mb-4">
        <div id="rem-progress" class="h-full bg-amber-500 transition-all duration-1000 rounded-full" style="width:100%"></div>
      </div>
      <div class="flex justify-center gap-3">
        <button id="rem-pause" class="px-5 py-2 rounded-lg bg-gray-200 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors">⏸ Pause</button>
        <button id="rem-cancel" class="px-5 py-2 rounded-lg bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 font-medium text-sm hover:bg-red-200 dark:hover:bg-red-900/40 transition-colors">✕ Cancel</button>
      </div>
    </div>

    <!-- Notification modal -->
    <div id="rem-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 max-w-sm w-full mx-4 text-center shadow-2xl border border-gray-200 dark:border-gray-700">
        <div class="text-6xl mb-4">🔔</div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Reminder!</h2>
        <p id="rem-modal-msg" class="text-gray-500 dark:text-gray-400 mb-6">Time's up</p>
        <button id="rem-dismiss" class="px-8 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-600 transition-colors text-lg">
          Got it
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  let totalSeconds = 0;
  let remaining = 0;
  let paused = false;
  let intervalId: ReturnType<typeof setInterval> | null = null;
  let audioCtx: AudioContext | null = null;

  const hrsEl = document.getElementById('rem-hrs') as HTMLInputElement;
  const minEl = document.getElementById('rem-min') as HTMLInputElement;
  const secEl = document.getElementById('rem-sec') as HTMLInputElement;
  const msgEl = document.getElementById('rem-msg') as HTMLInputElement;
  const startBtn = document.getElementById('rem-start')!;
  const activeEl = document.getElementById('rem-active')!;
  const countdownEl = document.getElementById('rem-countdown')!;
  const messageEl = document.getElementById('rem-message')!;
  const progressEl = document.getElementById('rem-progress') as HTMLElement;
  const pauseBtn = document.getElementById('rem-pause')!;
  const cancelBtn = document.getElementById('rem-cancel')!;
  const modal = document.getElementById('rem-modal')!;
  const modalMsg = document.getElementById('rem-modal-msg')!;
  const dismissBtn = document.getElementById('rem-dismiss')!;

  function formatCountdown(secs: number): string {
    const h = Math.floor(secs / 3600);
    const m = Math.floor((secs % 3600) / 60);
    const s = secs % 60;
    return `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  }

  function startReminder() {
    const hrs = parseInt(hrsEl.value) || 0;
    const min = parseInt(minEl.value) || 0;
    const sec = parseInt(secEl.value) || 0;
    totalSeconds = hrs * 3600 + min * 60 + sec;
    if (totalSeconds <= 0) return;

    remaining = totalSeconds;
    paused = false;
    messageEl.textContent = msgEl.value.trim() || '';
    activeEl.classList.remove('hidden');
    pauseBtn.textContent = '⏸ Pause';
    updateDisplay();

    intervalId = setInterval(() => {
      if (paused) return;
      remaining--;
      updateDisplay();
      if (remaining <= 0) {
        clearInterval(intervalId!);
        intervalId = null;
        triggerNotification();
      }
    }, 1000);
  }

  function updateDisplay() {
    countdownEl.textContent = formatCountdown(remaining);
    const pct = totalSeconds > 0 ? (remaining / totalSeconds) * 100 : 0;
    progressEl.style.width = pct + '%';
  }

  function triggerNotification() {
    activeEl.classList.add('hidden');
    modalMsg.textContent = msgEl.value.trim() || "Time's up!";
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    playNotification();
    // Browser notification
    if (Notification.permission === 'granted') {
      new Notification('xConvert24 Reminder', { body: msgEl.value.trim() || "Time's up!" });
    }
  }

  function playNotification() {
    try {
      audioCtx = new AudioContext();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 600;
      gain.gain.value = 0.2;
      osc.connect(gain).connect(audioCtx.destination);
      osc.start();
      setTimeout(() => { osc.frequency.value = 800; }, 200);
      setTimeout(() => { osc.frequency.value = 600; }, 400);
      setTimeout(() => { osc.frequency.value = 800; }, 600);
      setTimeout(() => { osc.stop(); audioCtx?.close(); audioCtx = null; }, 1000);
    } catch {}
  }

  startBtn.addEventListener('click', startReminder);

  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? '▶ Resume' : '⏸ Pause';
  });

  cancelBtn.addEventListener('click', () => {
    if (intervalId) clearInterval(intervalId);
    intervalId = null;
    activeEl.classList.add('hidden');
  });

  dismissBtn.addEventListener('click', () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  });

  // Quick presets
  document.querySelectorAll('[data-minutes]').forEach(btn => {
    btn.addEventListener('click', () => {
      const m = parseInt((btn as HTMLElement).dataset.minutes!);
      hrsEl.value = Math.floor(m / 60).toString();
      minEl.value = (m % 60).toString();
      secEl.value = '0';
    });
  });

  // Request notification permission
  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }
</script>
