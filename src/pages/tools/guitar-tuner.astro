---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Guitar Tuner — Chromatic Tuner with Microphone" description="Free online guitar tuner with real-time pitch detection. Uses your mic to show frequency, cents deviation, and waveform." keywords="guitar tuner, online tuner, chromatic tuner, pitch detection, tune guitar, frequency detector, hz tuner, microphone tuner, standard tuning">
  <div class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">🎸</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Free Online Guitar Tuner — Real-Time Pitch Detection</h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Chromatic tuner with real-time pitch detection. Enable your microphone to start tuning.</p>
    </div>

    <!-- Microphone permission -->
    <div id="mic-prompt" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-8 mb-6 shadow-sm text-center">
      <div class="text-5xl mb-4">🎤</div>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Enable Microphone</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 max-w-md mx-auto">Allow microphone access so the tuner can listen to your instrument and detect pitch in real-time. Audio is processed locally — nothing leaves your device.</p>
      <button id="enable-mic" class="px-6 py-3 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-lg transition-colors text-sm inline-flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
        Enable Microphone
      </button>
      <p id="mic-error" class="hidden mt-3 text-xs text-red-500"></p>
    </div>

    <!-- Tuner (hidden until mic active) -->
    <div id="tuner-panel" class="hidden">
      <!-- Main display -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-4 shadow-sm">
        <!-- Note display -->
        <div class="text-center mb-4">
          <div id="note-display" class="text-7xl font-black text-gray-900 dark:text-white tracking-tight leading-none mb-1">—</div>
          <div id="octave-display" class="text-lg font-semibold text-gray-500 dark:text-gray-400">Octave —</div>
        </div>

        <!-- Cents meter -->
        <div class="relative h-12 mb-4">
          <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
            <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-green-500"></div>
          </div>
          <!-- Cent markers -->
          <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex justify-between px-2 text-[9px] text-gray-400">
            <span>-50¢</span><span>-25¢</span><span class="text-green-500 font-bold">0</span><span>+25¢</span><span>+50¢</span>
          </div>
          <!-- Needle -->
          <div id="cents-needle" class="absolute top-1/2 -translate-y-1/2 w-1 h-8 bg-amber-500 rounded-full shadow-lg transition-all duration-100" style="left: 50%;"></div>
        </div>

        <!-- Frequency & volume -->
        <div class="flex items-center justify-center gap-8 text-center">
          <div>
            <p class="text-2xl font-bold font-mono text-gray-900 dark:text-white" id="freq-display">— Hz</p>
            <p class="text-xs text-gray-400">Frequency</p>
          </div>
          <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
          <div>
            <p class="text-2xl font-bold font-mono text-gray-900 dark:text-white" id="cents-display">— ¢</p>
            <p class="text-xs text-gray-400">Cents</p>
          </div>
          <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
          <div>
            <p class="text-2xl font-bold font-mono text-gray-900 dark:text-white" id="db-display">— dB</p>
            <p class="text-xs text-gray-400">Volume</p>
          </div>
        </div>

        <!-- In-tune indicator -->
        <div id="tune-status" class="mt-4 text-center">
          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">Listening...</span>
        </div>
      </div>

      <!-- Waveform visualization -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 mb-4 shadow-sm">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Waveform</h3>
          <button id="stop-mic" class="text-xs text-red-500 hover:text-red-600 font-medium">⏹ Stop</button>
        </div>
        <canvas id="waveform" class="w-full rounded-lg" height="120" style="background: #0f172a;"></canvas>
      </div>

      <!-- Reference notes (standard tuning) -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 mb-6 shadow-sm">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Standard Guitar Tuning (E A D G B E)</h3>
        <div class="grid grid-cols-6 gap-2">
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="82.41">
            <span class="text-lg font-bold text-gray-900 dark:text-white">E2</span>
            <span class="text-[10px] text-gray-400">82.4 Hz</span>
            <span class="text-[10px] text-gray-500">6th string</span>
          </button>
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="110.00">
            <span class="text-lg font-bold text-gray-900 dark:text-white">A2</span>
            <span class="text-[10px] text-gray-400">110.0 Hz</span>
            <span class="text-[10px] text-gray-500">5th string</span>
          </button>
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="146.83">
            <span class="text-lg font-bold text-gray-900 dark:text-white">D3</span>
            <span class="text-[10px] text-gray-400">146.8 Hz</span>
            <span class="text-[10px] text-gray-500">4th string</span>
          </button>
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="196.00">
            <span class="text-lg font-bold text-gray-900 dark:text-white">G3</span>
            <span class="text-[10px] text-gray-400">196.0 Hz</span>
            <span class="text-[10px] text-gray-500">3rd string</span>
          </button>
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="246.94">
            <span class="text-lg font-bold text-gray-900 dark:text-white">B3</span>
            <span class="text-[10px] text-gray-400">246.9 Hz</span>
            <span class="text-[10px] text-gray-500">2nd string</span>
          </button>
          <button class="ref-note-btn flex flex-col items-center gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-amber-400 dark:hover:border-amber-500 transition-colors cursor-pointer" data-freq="329.63">
            <span class="text-lg font-bold text-gray-900 dark:text-white">E4</span>
            <span class="text-[10px] text-gray-400">329.6 Hz</span>
            <span class="text-[10px] text-gray-500">1st string</span>
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-3 text-center">Click a note to play its reference tone through your speakers</p>
      </div>

      <!-- Info -->
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">How It Works</h2>
        <p class="text-gray-600 dark:text-gray-400">This tuner uses the <strong>Web Audio API</strong> to capture audio from your microphone, then applies <strong>autocorrelation pitch detection</strong> to find the fundamental frequency of the sound.</p>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Understanding the Display</h3>
        <ul class="text-gray-600 dark:text-gray-400 text-sm">
          <li><strong>Note</strong> — The nearest musical note (A, B, C, D, E, F, G with sharps/flats)</li>
          <li><strong>Octave</strong> — Which octave the note is in (guitar ranges from octave 2 to 5)</li>
          <li><strong>Frequency (Hz)</strong> — Exact cycles per second of the detected pitch</li>
          <li><strong>Cents (¢)</strong> — How far off from perfect tuning. ±5¢ is in tune, ±10-50¢ needs adjustment</li>
          <li><strong>Volume (dB)</strong> — Signal strength in decibels relative to full scale (dBFS)</li>
          <li><strong>Waveform</strong> — Real-time visualization of the sound wave pattern</li>
        </ul>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200">Tips</h3>
        <ul class="text-gray-600 dark:text-gray-400 text-sm">
          <li>Pluck one string at a time for best results</li>
          <li>Let the note ring — the tuner needs ~0.5 seconds to lock onto pitch</li>
          <li>Reduce background noise for more accurate detection</li>
          <li>The needle should stay centered (green zone) when in tune</li>
          <li>A4 = 440 Hz is the standard concert pitch reference</li>
        </ul>
      </div>
    </div>

    <!-- Suggest a feature -->
    <div class="mt-6 text-center">
      <a href="/suggest?title=Guitar+Tuner" class="inline-flex items-center gap-2 text-sm text-amber-600 dark:text-amber-400 hover:underline font-medium">
        <span aria-hidden="true">💡</span> Suggest a new feature for this tool →
      </a>
    </div>
  </div>
</Layout>

<script>
  const NOTE_NAMES = ['C', 'C♯', 'D', 'D♯', 'E', 'F', 'F♯', 'G', 'G♯', 'A', 'A♯', 'B'];
  const A4 = 440;

  let audioContext: AudioContext | null = null;
  let analyser: AnalyserNode | null = null;
  let mediaStream: MediaStream | null = null;
  let animFrameId: number | null = null;
  let isRunning = false;

  const micPrompt = document.getElementById('mic-prompt')!;
  const tunerPanel = document.getElementById('tuner-panel')!;
  const enableBtn = document.getElementById('enable-mic')!;
  const stopBtn = document.getElementById('stop-mic')!;
  const micError = document.getElementById('mic-error')!;
  const noteDisplay = document.getElementById('note-display')!;
  const octaveDisplay = document.getElementById('octave-display')!;
  const freqDisplay = document.getElementById('freq-display')!;
  const centsDisplay = document.getElementById('cents-display')!;
  const dbDisplay = document.getElementById('db-display')!;
  const centsNeedle = document.getElementById('cents-needle')!;
  const tuneStatus = document.getElementById('tune-status')!;
  const waveformCanvas = document.getElementById('waveform') as HTMLCanvasElement;
  const wfCtx = waveformCanvas.getContext('2d')!;

  // Enable microphone
  enableBtn.addEventListener('click', async () => {
    try {
      mediaStream = await navigator.mediaDevices.getUserMedia({ audio: { noiseSuppression: true, echoCancellation: false } });
      audioContext = new AudioContext();
      const source = audioContext.createMediaStreamSource(mediaStream);

      analyser = audioContext.createAnalyser();
      analyser.fftSize = 4096;
      analyser.smoothingTimeConstant = 0.8;
      source.connect(analyser);

      micPrompt.classList.add('hidden');
      tunerPanel.classList.remove('hidden');
      isRunning = true;
      detect();
    } catch (err: any) {
      micError.textContent = 'Microphone access denied: ' + (err.message || 'Please allow mic access in your browser settings.');
      micError.classList.remove('hidden');
    }
  });

  // Stop
  stopBtn.addEventListener('click', () => {
    isRunning = false;
    if (animFrameId) cancelAnimationFrame(animFrameId);
    if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
    if (audioContext) audioContext.close();
    tunerPanel.classList.add('hidden');
    micPrompt.classList.remove('hidden');
  });

  // Reference tone playback
  document.querySelectorAll('.ref-note-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const freq = parseFloat((btn as HTMLElement).dataset.freq || '440');
      playTone(freq, 1.5);
    });
  });

  function playTone(freq: number, duration: number) {
    const ctx = new AudioContext();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'sine';
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start();
    osc.stop(ctx.currentTime + duration);
    setTimeout(() => ctx.close(), (duration + 0.1) * 1000);
  }

  // Pitch detection loop
  function detect() {
    if (!isRunning || !analyser) return;

    const bufferLength = analyser.fftSize;
    const buffer = new Float32Array(bufferLength);
    analyser.getFloatTimeDomainData(buffer);

    // Calculate RMS volume (dBFS)
    let rms = 0;
    for (let i = 0; i < bufferLength; i++) rms += buffer[i] * buffer[i];
    rms = Math.sqrt(rms / bufferLength);
    const db = 20 * Math.log10(rms + 0.0001);
    dbDisplay.textContent = db > -80 ? db.toFixed(0) + ' dB' : '— dB';

    // Draw waveform
    drawWaveform(buffer);

    // Pitch detection (autocorrelation)
    const frequency = autoCorrelate(buffer, audioContext!.sampleRate);

    if (frequency > 0 && db > -50) {
      // Determine note
      const noteNum = 12 * (Math.log2(frequency / A4));
      const roundedNote = Math.round(noteNum);
      const cents = (noteNum - roundedNote) * 100;

      const noteIndex = ((roundedNote % 12) + 12) % 12;
      const octave = Math.floor((roundedNote + 69) / 12) - 1;
      const noteName = NOTE_NAMES[noteIndex];

      noteDisplay.textContent = noteName;
      octaveDisplay.textContent = `Octave ${octave}`;
      freqDisplay.textContent = frequency.toFixed(1) + ' Hz';
      centsDisplay.textContent = (cents >= 0 ? '+' : '') + cents.toFixed(0) + ' ¢';

      // Position needle (50% = center, range ±50 cents)
      const needlePos = 50 + (cents / 50) * 45; // clamp roughly
      centsNeedle.style.left = Math.max(5, Math.min(95, needlePos)) + '%';

      // Color the needle based on accuracy
      const absCents = Math.abs(cents);
      if (absCents < 5) {
        centsNeedle.className = 'absolute top-1/2 -translate-y-1/2 w-1.5 h-8 bg-green-500 rounded-full shadow-lg transition-all duration-100';
        tuneStatus.innerHTML = '<span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400">✓ In Tune!</span>';
      } else if (absCents < 15) {
        centsNeedle.className = 'absolute top-1/2 -translate-y-1/2 w-1 h-8 bg-amber-500 rounded-full shadow-lg transition-all duration-100';
        tuneStatus.innerHTML = '<span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">' + (cents > 0 ? '↓ Tune down slightly' : '↑ Tune up slightly') + '</span>';
      } else {
        centsNeedle.className = 'absolute top-1/2 -translate-y-1/2 w-1 h-8 bg-red-500 rounded-full shadow-lg transition-all duration-100';
        tuneStatus.innerHTML = '<span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400">' + (cents > 0 ? '↓ Too sharp — tune down' : '↑ Too flat — tune up') + '</span>';
      }
    } else {
      // No pitch detected
      if (db < -50) {
        noteDisplay.textContent = '—';
        octaveDisplay.textContent = 'Octave —';
        freqDisplay.textContent = '— Hz';
        centsDisplay.textContent = '— ¢';
        centsNeedle.style.left = '50%';
        tuneStatus.innerHTML = '<span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">Listening... play a note</span>';
      }
    }

    animFrameId = requestAnimationFrame(detect);
  }

  // Autocorrelation pitch detection
  function autoCorrelate(buffer: Float32Array, sampleRate: number): number {
    const SIZE = buffer.length;
    let rms = 0;
    for (let i = 0; i < SIZE; i++) rms += buffer[i] * buffer[i];
    rms = Math.sqrt(rms / SIZE);
    if (rms < 0.01) return -1; // too quiet

    // Trim silence from start/end
    let r1 = 0, r2 = SIZE - 1;
    const threshold = 0.2;
    for (let i = 0; i < SIZE / 2; i++) { if (Math.abs(buffer[i]) < threshold) { r1 = i; break; } }
    for (let i = 1; i < SIZE / 2; i++) { if (Math.abs(buffer[SIZE - i]) < threshold) { r2 = SIZE - i; break; } }

    const trimmed = buffer.slice(r1, r2);
    const trimSize = trimmed.length;

    // Autocorrelation
    const corr = new Float32Array(trimSize);
    for (let lag = 0; lag < trimSize; lag++) {
      let sum = 0;
      for (let i = 0; i < trimSize - lag; i++) sum += trimmed[i] * trimmed[i + lag];
      corr[lag] = sum;
    }

    // Find first dip then next peak
    let d = 0;
    while (d < trimSize && corr[d] > corr[d + 1]) d++;
    let maxVal = -1, maxPos = -1;
    for (let i = d; i < trimSize; i++) {
      if (corr[i] > maxVal) { maxVal = corr[i]; maxPos = i; }
    }

    if (maxPos <= 0) return -1;

    // Parabolic interpolation for sub-sample accuracy
    const y1 = corr[maxPos - 1] || 0;
    const y2 = corr[maxPos];
    const y3 = corr[maxPos + 1] || 0;
    const shift = (y3 - y1) / (2 * (2 * y2 - y1 - y3));
    const refinedPos = maxPos + (isFinite(shift) ? shift : 0);

    return sampleRate / refinedPos;
  }

  // Waveform drawing
  function drawWaveform(buffer: Float32Array) {
    const dpr = window.devicePixelRatio || 1;
    const rect = waveformCanvas.getBoundingClientRect();
    waveformCanvas.width = rect.width * dpr;
    waveformCanvas.height = 120 * dpr;
    wfCtx.scale(dpr, dpr);

    const width = rect.width;
    const height = 120;

    wfCtx.fillStyle = '#0f172a';
    wfCtx.fillRect(0, 0, width, height);

    // Center line
    wfCtx.strokeStyle = 'rgba(100,116,139,0.3)';
    wfCtx.lineWidth = 0.5;
    wfCtx.beginPath();
    wfCtx.moveTo(0, height / 2);
    wfCtx.lineTo(width, height / 2);
    wfCtx.stroke();

    // Waveform
    wfCtx.strokeStyle = '#f59e0b';
    wfCtx.lineWidth = 1.5;
    wfCtx.beginPath();

    const step = Math.ceil(buffer.length / width);
    for (let i = 0; i < width; i++) {
      const idx = i * step;
      const val = buffer[idx] || 0;
      const y = (1 - val) * height / 2;
      if (i === 0) wfCtx.moveTo(i, y);
      else wfCtx.lineTo(i, y);
    }
    wfCtx.stroke();

    // Glow effect
    wfCtx.strokeStyle = 'rgba(245,158,11,0.3)';
    wfCtx.lineWidth = 4;
    wfCtx.beginPath();
    for (let i = 0; i < width; i++) {
      const idx = i * step;
      const val = buffer[idx] || 0;
      const y = (1 - val) * height / 2;
      if (i === 0) wfCtx.moveTo(i, y);
      else wfCtx.lineTo(i, y);
    }
    wfCtx.stroke();
  }
</script>
