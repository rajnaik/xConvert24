---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Password Generator — Strong Random Passwords" description="Generate strong, random passwords instantly. Customize length, character types, and generate multiple passwords at once with strength meter." keywords="password generator, random password, strong password, secure password, password creator">
  <div class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">🔐</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Password Generator</h1>
        <span class="ml-2 px-2 py-0.5 text-xs font-semibold bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 rounded-full">🧪 Experimental</span>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Generate strong, random passwords with customizable options.</p>
    </div>

    <!-- Generator Controls -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <!-- Password Display -->
      <div class="flex items-center gap-2 mb-4">
        <div id="password-display" class="flex-1 px-4 py-3 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 font-mono text-lg text-gray-900 dark:text-white break-all min-h-[50px] flex items-center select-all">Click Generate</div>
        <button id="copy-btn" class="shrink-0 px-3 py-3 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 text-gray-600 dark:text-gray-300 hover:text-amber-700 dark:hover:text-amber-300 transition-colors border border-gray-200 dark:border-gray-700" title="Copy to clipboard">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>

      <!-- Strength Meter -->
      <div class="mb-6">
        <div class="flex justify-between items-center mb-1">
          <span class="text-xs text-gray-500 dark:text-gray-400">Strength</span>
          <span id="strength-label" class="text-xs font-semibold text-gray-500">—</span>
        </div>
        <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
          <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%;"></div>
        </div>
      </div>

      <!-- Length Slider -->
      <div class="mb-5">
        <div class="flex justify-between items-center mb-2">
          <label for="pw-length" class="text-sm font-medium text-gray-700 dark:text-gray-300">Length</label>
          <span id="pw-length-val" class="text-sm font-mono font-bold text-amber-600 dark:text-amber-400">16</span>
        </div>
        <input id="pw-length" type="range" min="8" max="64" value="16" class="w-full h-2 rounded-full accent-amber-500 cursor-pointer"/>
        <div class="flex justify-between text-xs text-gray-400 mt-1"><span>8</span><span>64</span></div>
      </div>

      <!-- Character Options -->
      <div class="grid grid-cols-2 gap-3 mb-5">
        <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 cursor-pointer hover:border-amber-300 dark:hover:border-amber-700 transition-colors">
          <input type="checkbox" id="opt-upper" checked class="w-4 h-4 rounded text-amber-500 focus:ring-amber-500 border-gray-300"/>
          <span class="text-sm text-gray-700 dark:text-gray-300">Uppercase (A-Z)</span>
        </label>
        <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 cursor-pointer hover:border-amber-300 dark:hover:border-amber-700 transition-colors">
          <input type="checkbox" id="opt-lower" checked class="w-4 h-4 rounded text-amber-500 focus:ring-amber-500 border-gray-300"/>
          <span class="text-sm text-gray-700 dark:text-gray-300">Lowercase (a-z)</span>
        </label>
        <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 cursor-pointer hover:border-amber-300 dark:hover:border-amber-700 transition-colors">
          <input type="checkbox" id="opt-numbers" checked class="w-4 h-4 rounded text-amber-500 focus:ring-amber-500 border-gray-300"/>
          <span class="text-sm text-gray-700 dark:text-gray-300">Numbers (0-9)</span>
        </label>
        <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 cursor-pointer hover:border-amber-300 dark:hover:border-amber-700 transition-colors">
          <input type="checkbox" id="opt-symbols" checked class="w-4 h-4 rounded text-amber-500 focus:ring-amber-500 border-gray-300"/>
          <span class="text-sm text-gray-700 dark:text-gray-300">Symbols (!@#$...)</span>
        </label>
      </div>

      <!-- Generate Single -->
      <button id="generate-btn" class="w-full mb-4 px-4 py-2.5 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-lg transition-colors text-sm">
        Generate Password
      </button>

      <!-- Multi-generate controls -->
      <div class="border-t border-gray-100 dark:border-gray-800 pt-4">
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Generate multiple</span>
          <div class="flex items-center gap-1">
            <button id="multi-minus" class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold text-lg border border-gray-200 dark:border-gray-700 transition-colors">−</button>
            <input id="multi-count" type="number" min="1" max="50" value="5" class="w-14 h-8 text-center text-sm font-mono font-bold text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"/>
            <button id="multi-plus" class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold text-lg border border-gray-200 dark:border-gray-700 transition-colors">+</button>
          </div>
        </div>
        <button id="generate-multi-btn" class="w-full mt-3 px-4 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 font-semibold rounded-lg transition-colors text-sm">
          Generate Multiple Passwords
        </button>
      </div>
    </div>

    <!-- Multi Password List -->
    <div id="multi-passwords" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm hidden">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Generated Passwords</h2>
        <button id="download-passwords" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-semibold rounded-lg transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download .txt
        </button>
      </div>
      <div id="pw-list" class="space-y-2"></div>
    </div>
  </div>

  <script is:inline>
  (function() {
    var UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    var LOWER = 'abcdefghijklmnopqrstuvwxyz';
    var NUMBERS = '0123456789';
    var SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    var display = document.getElementById('password-display');
    var copyBtn = document.getElementById('copy-btn');
    var lengthSlider = document.getElementById('pw-length');
    var lengthVal = document.getElementById('pw-length-val');
    var optUpper = document.getElementById('opt-upper');
    var optLower = document.getElementById('opt-lower');
    var optNumbers = document.getElementById('opt-numbers');
    var optSymbols = document.getElementById('opt-symbols');
    var generateBtn = document.getElementById('generate-btn');
    var generateMultiBtn = document.getElementById('generate-multi-btn');
    var multiCount = document.getElementById('multi-count');
    var multiMinus = document.getElementById('multi-minus');
    var multiPlus = document.getElementById('multi-plus');
    var strengthBar = document.getElementById('strength-bar');
    var strengthLabel = document.getElementById('strength-label');
    var multiSection = document.getElementById('multi-passwords');
    var pwList = document.getElementById('pw-list');
    var downloadBtn = document.getElementById('download-passwords');

    lengthSlider.addEventListener('input', function() { lengthVal.textContent = lengthSlider.value; });

    // Multi count ± buttons
    multiMinus.addEventListener('click', function() {
      var v = parseInt(multiCount.value) || 5;
      multiCount.value = Math.max(1, v - 1);
    });
    multiPlus.addEventListener('click', function() {
      var v = parseInt(multiCount.value) || 5;
      multiCount.value = Math.min(50, v + 1);
    });

    function getCharset() {
      var chars = '';
      if (optUpper.checked) chars += UPPER;
      if (optLower.checked) chars += LOWER;
      if (optNumbers.checked) chars += NUMBERS;
      if (optSymbols.checked) chars += SYMBOLS;
      return chars;
    }

    function generatePassword() {
      var chars = getCharset();
      if (!chars) return 'Select at least one option';
      var len = parseInt(lengthSlider.value);
      var arr = new Uint32Array(len);
      crypto.getRandomValues(arr);
      var pw = '';
      for (var i = 0; i < len; i++) {
        pw += chars[arr[i] % chars.length];
      }
      return pw;
    }

    function calcStrength(pw) {
      var score = 0;
      if (pw.length >= 12) score++;
      if (pw.length >= 16) score++;
      if (pw.length >= 24) score++;
      if (/[A-Z]/.test(pw)) score++;
      if (/[a-z]/.test(pw)) score++;
      if (/[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;

      if (score <= 2) return { label: 'Weak', pct: 25, color: 'bg-red-500', textColor: 'text-red-500' };
      if (score <= 4) return { label: 'Fair', pct: 50, color: 'bg-yellow-500', textColor: 'text-yellow-500' };
      if (score <= 5) return { label: 'Strong', pct: 75, color: 'bg-green-500', textColor: 'text-green-500' };
      return { label: 'Very Strong', pct: 100, color: 'bg-emerald-500', textColor: 'text-emerald-500' };
    }

    function updateDisplay(pw) {
      display.textContent = pw;
      var strength = calcStrength(pw);
      strengthBar.style.width = strength.pct + '%';
      strengthBar.className = 'h-full rounded-full transition-all duration-300 ' + strength.color;
      strengthLabel.textContent = strength.label;
      strengthLabel.className = 'text-xs font-semibold ' + strength.textColor;
    }

    generateBtn.addEventListener('click', function() {
      updateDisplay(generatePassword());
    });

    var generatedPasswords = [];

    generateMultiBtn.addEventListener('click', function() {
      var count = Math.max(1, Math.min(50, parseInt(multiCount.value) || 5));
      multiSection.classList.remove('hidden');
      pwList.innerHTML = '';
      generatedPasswords = [];
      for (var i = 0; i < count; i++) {
        var pw = generatePassword();
        generatedPasswords.push(pw);
        var row = document.createElement('div');
        row.className = 'flex items-center gap-2 p-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700';
        row.innerHTML = '<span class="shrink-0 w-6 text-xs text-gray-400 font-mono text-right">' + (i + 1) + '.</span>' +
          '<span class="flex-1 font-mono text-sm text-gray-900 dark:text-white break-all select-all">' + pw + '</span>' +
          '<button class="shrink-0 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700 hover:bg-amber-200 dark:hover:bg-amber-900/30 text-gray-600 dark:text-gray-300 transition-colors copy-row-btn">Copy</button>';
        row.querySelector('.copy-row-btn').addEventListener('click', (function(password, btn) {
          return function() {
            navigator.clipboard.writeText(password).then(function() { btn.textContent = 'Copied!'; setTimeout(function() { btn.textContent = 'Copy'; }, 1500); });
          };
        })(pw, row.querySelector('.copy-row-btn')));
        pwList.appendChild(row);
      }
      updateDisplay(generatedPasswords[0]);
    });

    // Download passwords as .txt
    downloadBtn.addEventListener('click', function() {
      if (!generatedPasswords.length) return;
      var content = 'Generated Passwords — xConvert24.com\n';
      content += '═'.repeat(40) + '\n\n';
      generatedPasswords.forEach(function(pw, i) {
        content += (i + 1) + '. ' + pw + '\n';
      });
      content += '\n' + '═'.repeat(40) + '\n';
      content += 'Generated: ' + new Date().toLocaleString() + '\n';
      content += 'Length: ' + lengthSlider.value + ' characters\n';
      var blob = new Blob([content], { type: 'text/plain' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'passwords-xconvert24.txt';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    copyBtn.addEventListener('click', function() {
      var pw = display.textContent;
      if (!pw || pw === 'Click Generate') return;
      navigator.clipboard.writeText(pw).then(function() {
        copyBtn.innerHTML = '<svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(function() {
          copyBtn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
        }, 1500);
      });
    });

    // Generate one on load
    updateDisplay(generatePassword());
  })();
  </script>
</Layout>
