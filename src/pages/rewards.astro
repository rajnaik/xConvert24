---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="ConvertCoins — Earn Rewards on xConvert24" description="Learn how to earn ConvertCoins on xConvert24.com. Complete activities to earn coins, level up, maintain streaks, and build your balance. Understand how your wallet works and how to keep your coins safe." keywords="convertcoins, rewards, gamification, earn coins, streak, xconvert24 rewards, loyalty points">
  <div class="max-w-3xl">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">🪙</span>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">ConvertCoins</h1>
          <p class="text-sm text-amber-600 dark:text-amber-400 font-medium">Earn rewards for using xConvert24</p>
        </div>
      </div>
      <p class="text-gray-500 dark:text-gray-400">Every time you convert, explore, or contribute — you earn ConvertCoins. Track your balance, maintain streaks, and level up.</p>
    </div>

    <!-- Quick stats (loads from profile) -->
    <div class="grid grid-cols-3 gap-3 mb-8">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-amber-500" id="r-coins">—</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">🪙 Your Coins</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-orange-500" id="r-streak">—</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">🔥 Day Streak</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center shadow-sm">
        <p class="text-3xl font-bold text-purple-500" id="r-level">—</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">⭐ Level</p>
      </div>
    </div>

    <!-- How to Earn - Full table -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <span>📋</span> How to Earn ConvertCoins
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-gray-800">
              <th class="text-left py-2 px-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Activity</th>
              <th class="text-center py-2 px-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Coins</th>
              <th class="text-left py-2 px-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">How</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50 dark:divide-gray-800">
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">📐 First Conversion</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+5 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Complete your first conversion each day</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">📅 Daily Visit</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+5 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Visit the site once per day</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🔄 Multi-Converter</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+10 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Use 3 or more different converters in one session</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🔥 7-Day Streak</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 rounded-full text-xs font-bold">+50 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Visit 7 consecutive days</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🔥 30-Day Streak</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-full text-xs font-bold">+200 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Visit 30 consecutive days</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">📱 Add to Home Screen</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded-full text-xs font-bold">+100 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Install xConvert24 on your home screen</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🐛 Bug Report</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+25 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Report a valid bug that gets confirmed</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">💡 Feature Suggestion</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+30 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Submit a suggestion rated 4+ stars by community</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">📖 Read a Blog Post</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+5 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Read a blog post to the end</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">📤 Share</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+5 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Share a converter or tool link</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🔗 Refer a Friend</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+20 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Refer someone who visits and uses a converter</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">🧠 Quiz Correct</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+10 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Answer a conversion quiz correctly</td>
            </tr>
            <tr>
              <td class="py-3 px-3 font-medium text-gray-900 dark:text-white">⭐ Favourite 5 Tools</td>
              <td class="py-3 px-3 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-bold">+15 🪙</span></td>
              <td class="py-3 px-3 text-xs text-gray-500 dark:text-gray-400">Add 5 converters to your favourites</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Leveling system -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
        <span>⭐</span> Level System
      </h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Every <strong>500 coins earned</strong> (lifetime total) levels you up. Your level reflects your overall contribution to the xConvert24 community.</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="text-center p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <p class="text-lg font-bold text-gray-400">Level 1</p>
          <p class="text-xs text-gray-500">0–499 coins</p>
          <p class="text-xs mt-1">🌱 Newcomer</p>
        </div>
        <div class="text-center p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <p class="text-lg font-bold text-amber-500">Level 5</p>
          <p class="text-xs text-gray-500">2000–2499 coins</p>
          <p class="text-xs mt-1">⭐ Regular</p>
        </div>
        <div class="text-center p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <p class="text-lg font-bold text-purple-500">Level 10</p>
          <p class="text-xs text-gray-500">4500–4999 coins</p>
          <p class="text-xs mt-1">💎 Power User</p>
        </div>
        <div class="text-center p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <p class="text-lg font-bold text-red-500">Level 20+</p>
          <p class="text-xs text-gray-500">10000+ coins</p>
          <p class="text-xs mt-1">🏆 Legend</p>
        </div>
      </div>
    </div>

    <!-- ⚠️ Wallet / Coins Safety section -->
    <div class="bg-red-50 dark:bg-red-900/10 rounded-xl border border-red-200 dark:border-red-800 p-6 mb-6">
      <h2 class="text-lg font-bold text-red-800 dark:text-red-200 mb-3 flex items-center gap-2">
        <span>⚠️</span> Important: How Your Coins Are Stored
      </h2>
      <div class="space-y-3 text-sm text-red-700 dark:text-red-300">
        <p><strong>Your ConvertCoins are tied to your browser's unique wallet ID.</strong> This ID is stored locally in your browser (localStorage) and linked to your balance on xConvert24.com's server.</p>

        <div class="bg-white dark:bg-gray-900 rounded-lg p-4 border border-red-100 dark:border-red-900">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">How it works:</h3>
          <ol class="space-y-2 text-xs text-gray-700 dark:text-gray-300 list-decimal list-inside">
            <li>When you first visit xConvert24.com, a unique anonymous wallet ID is generated (e.g., <code class="px-1 py-0.5 bg-gray-100 dark:bg-gray-800 rounded text-xs">u_m2k8f3x9ab</code>)</li>
            <li>This ID is saved in your browser's localStorage under the key <code class="px-1 py-0.5 bg-gray-100 dark:bg-gray-800 rounded text-xs">xconvert24-uid</code></li>
            <li>Your coin balance, streak, and level are stored on our server linked to this ID</li>
            <li>Every time you earn coins, we update the server with your wallet ID</li>
          </ol>
        </div>

        <div class="bg-red-100 dark:bg-red-900/30 rounded-lg p-4 border border-red-200 dark:border-red-800">
          <h3 class="font-bold text-red-900 dark:text-red-100 mb-2">🚨 How you could LOSE your coins:</h3>
          <ul class="space-y-1.5 text-xs">
            <li>❌ <strong>Clearing browser data / cookies</strong> — this deletes your wallet ID</li>
            <li>❌ <strong>Using a different browser</strong> — each browser has its own wallet</li>
            <li>❌ <strong>Using Incognito/Private mode</strong> — localStorage is cleared on close</li>
            <li>❌ <strong>Reinstalling your browser</strong> — wipes all local data</li>
            <li>❌ <strong>Factory resetting your device</strong> — everything is gone</li>
          </ul>
        </div>

        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 border border-green-200 dark:border-green-800">
          <h3 class="font-bold text-green-900 dark:text-green-100 mb-2">✅ How to protect your coins:</h3>
          <ul class="space-y-1.5 text-xs text-green-800 dark:text-green-300">
            <li>✓ <strong>Save your wallet ID</strong> — find it on your <a href="/profile" class="underline font-semibold">Profile page</a> and write it down</li>
            <li>✓ <strong>Use the same browser</strong> — always use the same browser on the same device</li>
            <li>✓ <strong>Add to Home Screen</strong> — the installed app preserves your data better</li>
            <li>✓ <strong>Don't clear site data</strong> — avoid clearing localStorage for xconvert24.com</li>
          </ul>
        </div>

        <p class="text-xs text-red-600 dark:text-red-400 italic">We cannot recover coins if your wallet ID is lost. There is no email/password login — the system is anonymous by design for your privacy.</p>
      </div>
    </div>

    <!-- Your wallet ID -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">🔑 Your Wallet ID</h2>
      <div class="flex items-center gap-3">
        <code id="wallet-id" class="flex-1 px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm font-mono text-gray-900 dark:text-gray-100 select-all border border-gray-200 dark:border-gray-700">Loading...</code>
        <button id="copy-wallet" class="px-3 py-3 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition-colors text-sm font-semibold" title="Copy wallet ID">📋</button>
      </div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Save this somewhere safe. If you lose access to this browser, this is the only way to recover your coins (contact support with this ID).</p>
    </div>

    <!-- Recover / Re-link wallet -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 mb-6 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">🔄 Recover Your Wallet</h2>
      <p class="text-xs text-gray-600 dark:text-gray-400 mb-3">Cleared your browser data or switched devices? If you saved your wallet ID, paste it below to re-link your coins to this browser.</p>
      <div class="flex gap-2">
        <input id="recover-input" type="text" placeholder="Paste your wallet ID here (e.g., u_m2k8f3x9ab)" class="flex-1 h-10 px-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm font-mono text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
        <button id="recover-btn" class="px-4 h-10 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors text-sm">Recover</button>
      </div>
      <div id="recover-status" class="mt-2 text-xs hidden"></div>
    </div>

    <!-- CTA -->
    <div class="flex flex-wrap gap-3">
      <a href="/profile" class="px-5 py-2.5 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors text-sm">View My Profile →</a>
      <a href="/search" class="px-5 py-2.5 bg-gray-200 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-semibold rounded-lg hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors text-sm">Start Earning — Browse Converters</a>
    </div>
  </div>
</Layout>

<script>
  function getUid(): string {
    let uid = localStorage.getItem('xconvert24-uid');
    if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem('xconvert24-uid', uid); }
    return uid;
  }

  // Show wallet ID
  let uid = getUid();
  document.getElementById('wallet-id')!.textContent = uid;

  // Copy button
  document.getElementById('copy-wallet')!.addEventListener('click', () => {
    navigator.clipboard.writeText(uid).then(() => {
      const btn = document.getElementById('copy-wallet')!;
      btn.textContent = '✓';
      setTimeout(() => { btn.textContent = '📋'; }, 2000);
    });
  });

  // Recovery: re-link a saved wallet ID to this browser
  document.getElementById('recover-btn')!.addEventListener('click', async () => {
    const input = document.getElementById('recover-input') as HTMLInputElement;
    const status = document.getElementById('recover-status')!;
    const walletId = input.value.trim();

    if (!walletId || walletId.length < 5) {
      status.textContent = '❌ Please enter a valid wallet ID.';
      status.className = 'mt-2 text-xs text-red-600 dark:text-red-400';
      status.classList.remove('hidden');
      return;
    }

    // Verify the wallet ID exists on the server
    try {
      const res = await fetch(`/api/coins?uid=${walletId}`);
      if (!res.ok) throw new Error('API error');
      const data = await res.json();

      if (data.coins === 0 && data.streak === 0 && data.level === 1 && !data.total_earned) {
        // No data found for this ID — might be invalid or truly empty
        status.innerHTML = '⚠️ No coin history found for this ID. If this is correct (new account), it has been linked. If you expected coins, double-check the ID.';
        status.className = 'mt-2 text-xs text-amber-600 dark:text-amber-400';
        status.classList.remove('hidden');
      } else {
        status.innerHTML = `✅ <strong>Wallet recovered!</strong> Found ${data.coins} coins, Level ${data.level}, ${data.streak}-day streak. This browser is now linked to your wallet.`;
        status.className = 'mt-2 text-xs text-green-600 dark:text-green-400';
        status.classList.remove('hidden');
      }

      // Re-link: save the recovered ID to localStorage
      localStorage.setItem('xconvert24-uid', walletId);
      uid = walletId;
      document.getElementById('wallet-id')!.textContent = walletId;

      // Refresh stats display
      document.getElementById('r-coins')!.textContent = (data.coins || 0).toString();
      document.getElementById('r-streak')!.textContent = (data.streak || 0).toString();
      document.getElementById('r-level')!.textContent = (data.level || 1).toString();
    } catch (e) {
      status.textContent = '❌ Could not verify this wallet ID. Please check your connection and try again.';
      status.className = 'mt-2 text-xs text-red-600 dark:text-red-400';
      status.classList.remove('hidden');
    }
  });

  // Load stats
  fetch(`/api/coins?uid=${uid}`)
    .then(r => r.json())
    .then(data => {
      document.getElementById('r-coins')!.textContent = (data.coins || 0).toString();
      document.getElementById('r-streak')!.textContent = (data.streak || 0).toString();
      document.getElementById('r-level')!.textContent = (data.level || 1).toString();
    })
    .catch(() => {});
</script>
