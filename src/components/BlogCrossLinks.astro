---
/**
 * BlogCrossLinks — renders converter icon links next to blog title and a favourite heart.
 * Uses a static map derived from the CrossLinks DB table for reliable rendering.
 */

interface Props {
  title: string;
}

const { title } = Astro.props;
const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');

// Converter metadata
const converters: Record<string, { href: string; icon: string }> = {
  'Weight': { href: '/convert/weight', icon: '⚖️' },
  'Length': { href: '/convert/length', icon: '📏' },
  'Temperature': { href: '/convert/temperature', icon: '🌡️' },
  'Area': { href: '/convert/area', icon: '📐' },
  'Volume': { href: '/convert/volume', icon: '🧪' },
  'Speed': { href: '/convert/speed', icon: '💨' },
  'Data Storage': { href: '/convert/data', icon: '💾' },
  'Energy': { href: '/convert/energy', icon: '⚡' },
  'Pressure': { href: '/convert/pressure', icon: '🔬' },
  'Power': { href: '/convert/power', icon: '🔋' },
  'Fuel Economy': { href: '/convert/fuel', icon: '⛽' },
  'Time': { href: '/convert/time', icon: '⏱️' },
  'Cooking': { href: '/convert/cooking', icon: '🍳' },
  'Number Base': { href: '/convert/base', icon: '🧮' },
  'Currency': { href: '/convert/currency', icon: '💱' },
  'Precious Metals': { href: '/convert/precious-metals', icon: '💎' },
  'Shoe Size': { href: '/convert/shoe-size', icon: '👟' },
  'Clothing Size': { href: '/convert/clothing-size', icon: '👔' },
  'Oven Temperature': { href: '/convert/oven-temperature', icon: '🔥' },
  'Running Pace': { href: '/convert/running-pace', icon: '🏃' },
  'Cycling Speed': { href: '/convert/cycling-speed', icon: '🚴' },
  'Body Weight %': { href: '/convert/body-weight-percentage', icon: '📊' },
};

// Static cross-link map: slug → converter names (derived from CrossLinks table)
const crossLinks: Record<string, string[]> = {
  'how-to-convert-celsius-to-fahrenheit': ['Temperature'],
  'how-to-convert-kg-to-lbs': ['Weight'],
  'how-tall-is-6-feet-in-cm': ['Length'],
  'cups-to-ml-baking-conversion': ['Volume', 'Cooking'],
  'speed-limits-around-the-world': ['Speed'],
  'understanding-tire-pressure-psi': ['Pressure'],
  'mb-vs-gb-explained-simply': ['Data Storage'],
  'world-time-zones-explained': ['Time'],
  'horsepower-vs-kilowatts-cars': ['Power'],
  'driving-distances-km-vs-miles': ['Length', 'Speed'],
  'calories-vs-kilocalories': ['Energy'],
  'gold-weight-troy-ounces': ['Weight', 'Precious Metals'],
  'how-much-is-1tb-of-storage': ['Data Storage'],
  'mortgage-vs-rent-calculator-guide': ['Currency'],
  'oven-temperatures-celsius-fahrenheit': ['Temperature', 'Cooking'],
  'internet-speed-mbps-explained': ['Data Storage', 'Speed'],
  'healthy-weight-loss-rate-per-week': ['Weight'],
  'fever-temperature-what-is-normal': ['Temperature'],
  'binary-vs-decimal-storage-confusion': ['Data Storage'],
  'best-time-to-exchange-currency': ['Currency'],
  'understanding-cryptocurrency-basics': ['Currency'],
  'feet-and-inches-to-cm-height': ['Length'],
  'how-many-days-until-christmas': ['Time'],
  'how-many-liters-in-a-gallon': ['Volume'],
  'body-weight-metric-vs-imperial': ['Weight'],
  'wind-speed-knots-to-mph': ['Speed'],
  'fuel-economy-mpg-vs-l100km': ['Fuel Economy'],
  'what-is-a-stone-in-weight': ['Weight'],
  'room-measurements-meters-to-feet': ['Length', 'Area'],
  'tablespoon-to-ml-medicine': ['Volume', 'Cooking'],
  'rgb-vs-cmyk-when-to-use': ['Number Base'],
  'how-far-is-a-nautical-mile': ['Length', 'Speed'],
  'bmi-limitations-muscle-vs-fat': ['Weight'],
  'compound-interest-explained': ['Currency'],
  'miles-to-kilometers-running': ['Length', 'Speed'],
  'age-calculator-exact-days-alive': ['Time'],
  'baby-weight-conversion-chart': ['Weight'],
  'pomodoro-technique-timer-guide': ['Time'],
  'us-vs-uk-pint-difference': ['Volume'],
  'luggage-weight-kg-to-lbs': ['Weight'],
  'what-is-mach-speed': ['Speed'],
  'weather-temperature-conversion-travel': ['Temperature'],
  'hex-color-codes-explained': ['Number Base'],
  'understanding-millimeters-in-engineering': ['Length'],
  'what-is-kelvin-temperature': ['Temperature'],
  'water-intake-liters-per-day': ['Volume'],
  'bmi-what-is-a-healthy-weight': ['Weight'],
  'grams-to-ounces-for-cooking': ['Weight', 'Cooking'],
  'freezing-and-boiling-points-all-scales': ['Temperature'],
  'how-exchange-rates-work': ['Currency'],
  'why-world-uses-different-units': ['Weight', 'Length', 'Temperature'],
  'what-are-satoshis': ['Currency'],
  'bitcoin-halving-explained': ['Currency'],
  'understanding-bitcoin-supply': ['Currency'],
  'bitcoin-vs-gold': ['Currency', 'Weight', 'Precious Metals'],
};

const linked = (crossLinks[slug] || []).map(name => ({ name, ...converters[name] })).filter(c => c.href);
---

<div class="flex items-center gap-3 flex-wrap mb-2 not-prose">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{title}</h1>

  {linked.length > 0 && (
    <div class="flex items-center gap-1.5 shrink-0">
      {linked.map(conv => (
        <a href={conv.href} class="inline-flex items-center gap-1 px-2 py-1 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg text-xs text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-colors" title={`${conv.name} Converter`}>
          <span aria-hidden="true">{conv.icon}</span>
          <span class="hidden sm:inline">{conv.name}</span>
        </a>
      ))}
    </div>
  )}

  <button id="blog-fav-btn" class="ml-auto shrink-0 p-2 rounded-lg text-gray-300 dark:text-gray-600 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="Add to favourites" title="Add to favourites">
    <svg id="blog-fav-outline" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
    <svg id="blog-fav-filled" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
  </button>
</div>

<script>
  (function() {
    const FAV_KEY = 'xconvert24-favourites';
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const title = document.querySelector('h1')?.textContent?.trim() || '';
    const btn = document.getElementById('blog-fav-btn');
    const outline = document.getElementById('blog-fav-outline');
    const filled = document.getElementById('blog-fav-filled');
    if (!btn) return;

    function getFavs() { try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; } }
    function isFav() { return getFavs().some(function(f) { return f.href === path; }); }

    function render() {
      if (isFav()) {
        outline.classList.add('hidden'); filled.classList.remove('hidden');
        btn.classList.add('text-red-500', 'bg-red-50', 'dark:bg-red-900/20');
        btn.classList.remove('text-gray-300', 'dark:text-gray-600');
        btn.setAttribute('title', '❤️ In favourites — click to remove');
      } else {
        outline.classList.remove('hidden'); filled.classList.add('hidden');
        btn.classList.remove('text-red-500', 'bg-red-50', 'dark:bg-red-900/20');
        btn.classList.add('text-gray-300', 'dark:text-gray-600');
        btn.setAttribute('title', 'Add to favourites');
      }
    }

    btn.addEventListener('click', function() {
      var favs = getFavs();
      if (isFav()) { favs = favs.filter(function(f) { return f.href !== path; }); }
      else { favs.unshift({ name: title, href: path, category: 'Blog', addedAt: Date.now() }); }
      localStorage.setItem(FAV_KEY, JSON.stringify(favs));
      render();
    });
    render();
  })();
</script>
