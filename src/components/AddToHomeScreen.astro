---
/**
 * Global "Add to Home Screen" inline banner.
 * Shows immediately on non-home pages.
 * - Dismissible permanently via localStorage
 * - Never shows if already installed or dismissed
 */
---

<!-- Add to Home Screen panel (delayed, non-intrusive — sticky sidebar companion) -->
<div
  class="a2hs-banner hidden opacity-0 translate-y-4 transition-all duration-700 ease-out w-full"
  role="complementary"
  aria-label="Install xConvert24 on your home screen"
>
  <a href="/install" class="block bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-lg overflow-hidden hover:border-amber-400 dark:hover:border-amber-500 transition-all hover:shadow-xl no-underline">
    <!-- Phone illustration with instructions -->
    <div class="bg-gradient-to-b from-gray-900 to-gray-800 p-4 flex justify-center">
      <div class="relative w-36 h-56 bg-black rounded-[24px] border-[3px] border-gray-600 shadow-2xl overflow-hidden">
        <!-- Notch -->
        <div class="absolute top-1 left-1/2 -translate-x-1/2 w-14 h-1.5 bg-gray-800 rounded-full z-10"></div>
        <!-- Screen content -->
        <div class="absolute inset-1.5 bg-gradient-to-b from-blue-50 to-white rounded-[18px] flex flex-col items-center pt-5 px-2.5 pb-2">
          <!-- Step 1 -->
          <div class="flex items-center gap-1.5 mb-2.5 w-full">
            <div class="w-4 h-4 rounded-full bg-amber-500 text-white flex items-center justify-center text-[8px] font-bold shrink-0">1</div>
            <p class="text-[8px] text-gray-700 leading-tight">Open in <strong>Safari</strong> or <strong>Chrome</strong></p>
          </div>
          <!-- Step 2 -->
          <div class="flex items-center gap-1.5 mb-2.5 w-full">
            <div class="w-4 h-4 rounded-full bg-amber-500 text-white flex items-center justify-center text-[8px] font-bold shrink-0">2</div>
            <div class="flex items-center gap-0.5">
              <p class="text-[8px] text-gray-700 leading-tight">Tap</p>
              <svg class="w-3 h-3 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              <p class="text-[8px] text-gray-700 leading-tight"><strong>Share</strong></p>
            </div>
          </div>
          <!-- Step 3 -->
          <div class="flex items-center gap-1.5 mb-3 w-full">
            <div class="w-4 h-4 rounded-full bg-amber-500 text-white flex items-center justify-center text-[8px] font-bold shrink-0">3</div>
            <div class="flex items-center gap-0.5">
              <svg class="w-3 h-3 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              <p class="text-[8px] text-gray-700 leading-tight"><strong>Add to Home Screen</strong></p>
            </div>
          </div>
          <!-- App icon result -->
          <div class="flex flex-col items-center mt-auto mb-1">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-md border border-amber-500 mb-0.5">
              <span class="text-white text-[7px] font-bold">x24</span>
            </div>
            <p class="text-[7px] text-gray-600 font-semibold">xConvert24</p>
            <div class="text-amber-500 animate-bounce mt-0.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </div>
          </div>
        </div>
        <!-- Home bar -->
        <div class="absolute bottom-1 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-gray-600 rounded-full"></div>
      </div>
    </div>
    <!-- CTA text -->
    <div class="p-3 text-center">
      <p class="text-sm font-bold text-gray-900 dark:text-white">📱 Add to Home Screen</p>
      <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-0.5">Tap for full guide</p>
    </div>
  </a>
  <button class="a2hs-dismiss block w-full mt-1.5 text-[10px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-center">Dismiss</button>
</div>

<script is:inline>
  // Add to Home Screen — always visible on non-home pages.
  // Dismissible permanently via localStorage. Never shows if already installed.
  (function() {
    if (window.__a2hsInit) return;
    window.__a2hsInit = true;

    var DISMISS_KEY = 'xconvert24-install-dismissed';
    var INSTALLED_KEY = 'xconvert24-a2hs-installed';

    // Never show if running as installed PWA
    var isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator).standalone === true;
    if (isStandalone) return;

    // Never show if permanently dismissed or already installed
    if (localStorage.getItem(DISMISS_KEY)) return;
    if (localStorage.getItem(INSTALLED_KEY)) return;

    var banners = document.querySelectorAll('.a2hs-banner');
    if (!banners.length) return;

    // Show all banner instances (mobile + desktop)
    banners.forEach(function(banner) {
      banner.classList.remove('hidden');
      void banner.offsetWidth; // trigger reflow
      banner.classList.remove('opacity-0', 'translate-y-4');
      banner.classList.add('opacity-100', 'translate-y-0');
    });

    // Dismiss permanently (any dismiss button)
    document.querySelectorAll('.a2hs-dismiss').forEach(function(btn) {
      btn.addEventListener('click', function() {
        localStorage.setItem(DISMISS_KEY, '1');
        banners.forEach(function(banner) {
          banner.classList.add('opacity-0', 'translate-y-4');
          banner.classList.remove('opacity-100', 'translate-y-0');
          setTimeout(function() { banner.classList.add('hidden'); }, 700);
        });
      });
    });

    // Hide permanently once user installs
    window.matchMedia('(display-mode: standalone)').addEventListener('change', function(e) {
      if (e.matches) {
        banners.forEach(function(banner) { banner.classList.add('hidden'); });
        localStorage.setItem(INSTALLED_KEY, '1');
      }
    });

    window.addEventListener('appinstalled', function() {
      banners.forEach(function(banner) { banner.classList.add('hidden'); });
      localStorage.setItem(INSTALLED_KEY, '1');
    });
  })();
</script>
