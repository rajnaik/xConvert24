---
import { searchIndex } from '../data/searchIndex';
const indexJson = JSON.stringify(searchIndex);
---

<!-- Live search widget — visible site-wide in the header -->
<div class="relative" id="live-search-wrapper">
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input
      id="live-search-input"
      type="search"
      placeholder="Search units & tools…"
      autocomplete="off"
      class="h-9 w-56 lg:w-72 pl-9 pr-8 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:bg-white dark:focus:bg-gray-900 focus:w-80 transition-all duration-200"
      aria-label="Search converters and units"
      aria-controls="live-search-results"
      aria-expanded="false"
      role="combobox"
      aria-haspopup="listbox"
    />
    <!-- Clear button -->
    <button id="live-search-clear" class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-0.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" aria-label="Clear search">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Dropdown results -->
  <div
    id="live-search-results"
    role="listbox"
    class="hidden absolute top-full left-0 right-0 mt-2 w-80 max-h-96 overflow-y-auto bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl z-50"
  >
    <!-- Results populated by JS -->
    <div id="live-search-list" class="py-1"></div>
    <!-- Footer -->
    <div id="live-search-footer" class="hidden border-t border-gray-100 dark:border-gray-800 px-3 py-2">
      <a href="/search" class="flex items-center gap-1.5 text-xs text-amber-600 dark:text-amber-400 hover:underline font-medium">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        View all results on search page
      </a>
    </div>
  </div>
</div>

<script define:vars={{ indexJson }}>
  const index = JSON.parse(indexJson);
  const input = document.getElementById('live-search-input');
  const wrapper = document.getElementById('live-search-wrapper');
  const dropdown = document.getElementById('live-search-results');
  const list = document.getElementById('live-search-list');
  const footer = document.getElementById('live-search-footer');
  const clearBtn = document.getElementById('live-search-clear');

  let activeIdx = -1;

  function score(entry, q) {
    const lq = q.toLowerCase();
    const name = entry.name.toLowerCase();
    const cat = entry.category.toLowerCase();
    const aliases = entry.aliases.map(a => a.toLowerCase());

    if (name === lq) return 100;
    if (name.startsWith(lq)) return 90;
    if (aliases.some(a => a === lq)) return 85;
    if (aliases.some(a => a.startsWith(lq))) return 75;
    if (name.includes(lq)) return 60;
    if (cat.includes(lq)) return 50;
    if (aliases.some(a => a.includes(lq))) return 40;
    return 0;
  }

  function highlight(text, q) {
    if (!q) return text;
    const escaped = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark class="bg-amber-200 dark:bg-amber-700/50 text-inherit rounded px-0.5">$1</mark>');
  }

  function search(q) {
    if (!q.trim()) {
      hide();
      return;
    }
    const results = index
      .map(e => ({ ...e, _score: score(e, q) }))
      .filter(e => e._score > 0)
      .sort((a, b) => b._score - a._score)
      .slice(0, 12);

    if (results.length === 0) {
      list.innerHTML = '<div class="px-4 py-6 text-center text-sm text-gray-400 dark:text-gray-500">No results found</div>';
      footer.classList.add('hidden');
      show();
      return;
    }

    const typeIcons = { category: '📂', unit: '📐', tool: '🛠️' };
    const typeBadgeClasses = {
      category: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400',
      unit: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
      tool: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    };

    list.innerHTML = results.map((r, i) => {
      const matchedAlias = r.aliases.find(a => a.toLowerCase().includes(q.toLowerCase()) && a.toLowerCase() !== r.name.toLowerCase());
      const aliasHint = matchedAlias ? `<span class="text-xs text-gray-400 ml-1.5">→ ${matchedAlias}</span>` : '';
      return `
        <a href="${r.href}" class="live-result flex items-center gap-3 px-3 py-2.5 hover:bg-amber-50 dark:hover:bg-amber-900/10 transition-colors cursor-pointer ${i === activeIdx ? 'bg-amber-50 dark:bg-amber-900/10' : ''}" role="option" data-index="${i}">
          <span class="text-sm shrink-0" aria-hidden="true">${r.categoryIcon}</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-gray-900 dark:text-white truncate">${highlight(r.name, q)}${aliasHint}</div>
            <div class="text-xs text-gray-400 dark:text-gray-500">${r.category}</div>
          </div>
          <span class="shrink-0 text-xs px-1.5 py-0.5 rounded-full font-medium ${typeBadgeClasses[r.type]}">${r.type}</span>
        </a>
      `;
    }).join('');

    footer.classList.remove('hidden');
    // Update the "view all" link with query
    const viewAllLink = footer.querySelector('a');
    if (viewAllLink) viewAllLink.href = `/search?q=${encodeURIComponent(q)}`;
    show();
  }

  function show() {
    dropdown.classList.remove('hidden');
    input.setAttribute('aria-expanded', 'true');
  }

  function hide() {
    dropdown.classList.add('hidden');
    input.setAttribute('aria-expanded', 'false');
    activeIdx = -1;
  }

  function setActive(idx) {
    const items = list.querySelectorAll('.live-result');
    items.forEach((el, i) => {
      if (i === idx) el.classList.add('bg-amber-50', 'dark:bg-amber-900/10');
      else el.classList.remove('bg-amber-50', 'dark:bg-amber-900/10');
    });
    activeIdx = idx;
    if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
  }

  // Events
  input.addEventListener('input', (e) => {
    const q = e.target.value;
    clearBtn.classList.toggle('hidden', !q);
    activeIdx = -1;
    search(q);
  });

  input.addEventListener('focus', () => {
    if (input.value.trim()) search(input.value);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.classList.add('hidden');
    hide();
    input.focus();
  });

  // Keyboard nav
  input.addEventListener('keydown', (e) => {
    const items = list.querySelectorAll('.live-result');
    const count = items.length;
    if (!count) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive((activeIdx + 1) % count);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIdx <= 0 ? count - 1 : activeIdx - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIdx >= 0 && items[activeIdx]) {
        window.location.href = items[activeIdx].getAttribute('href');
      } else if (input.value.trim()) {
        window.location.href = '/search?q=' + encodeURIComponent(input.value);
      }
    } else if (e.key === 'Escape') {
      hide();
      input.blur();
    }
  });

  // Click outside to close
  document.addEventListener('click', (e) => {
    if (!wrapper.contains(e.target)) hide();
  });

  // Keyboard shortcut: "/" to focus search
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      input.focus();
    }
  });
</script>
