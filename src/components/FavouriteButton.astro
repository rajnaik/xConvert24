---
/**
 * Favourite heart button — include on any converter/tool page.
 * Props:
 *   name: display name (e.g. "Weight Converter")
 *   href: page path (e.g. "/convert/weight")
 *   category: category label (e.g. "Measurements")
 */
interface Props {
  name: string;
  href: string;
  category?: string;
}
const { name, href, category = '' } = Astro.props;
---

<button
  class="fav-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors"
  data-fav-name={name}
  data-fav-href={href}
  data-fav-category={category}
  aria-label={`Add ${name} to favourites`}
>
  <svg class="fav-icon-empty w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
  </svg>
  <svg class="fav-icon-filled w-4 h-4 text-red-500 hidden" fill="currentColor" viewBox="0 0 24 24">
    <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
  </svg>
  <span class="fav-text">Add to Favourites</span>
</button>
