      { label: 'Bubbles',          href: '/tools/crypto-bubbles', icon: '🫧' },
    ],
  },
  {
    id: 'food-health',
    label: 'Food & Health',
    icon: '🍳',
    items: [
      { label: 'Cooking',        href: '/convert/cooking', icon: '🍳' },
      { label: 'Oven Temperature', href: '/convert/oven-temperature', icon: '🔥', isNew: true },
      { label: 'BMI Calculator', href: '/tools/bmi',       icon: '🧍' },
      { label: 'Body Weight %',  href: '/convert/body-weight-percentage', icon: '🏋️', isNew: true },
    ],
  },
