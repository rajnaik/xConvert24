---
const currentPath = Astro.url.pathname;

const nav = [
  {
    id: 'measurements',
    label: 'Measurements',
    icon: '📏',
    items: [
      { label: 'Weight',      href: '/convert/weight',      icon: '⚖️' },
      { label: 'Length',      href: '/convert/length',      icon: '📏' },
      { label: 'Temperature', href: '/convert/temperature', icon: '🌡️' },
      { label: 'Area',        href: '/convert/area',        icon: '🗺️' },
      { label: 'Volume',      href: '/convert/volume',      icon: '🧪' },
      { label: 'Speed',       href: '/convert/speed',       icon: '🚀' },
      { label: 'Running Pace', href: '/convert/running-pace', icon: '🏃', isNew: true },
      { label: 'Cycling Speed', href: '/convert/cycling-speed', icon: '🚴', isNew: true },
      { label: 'Angle',       href: '/convert/angle',       icon: '📐' },
      { label: 'Frequency',   href: '/convert/frequency',   icon: '〰️' },
      { label: 'Precious Metals', href: '/convert/precious-metals', icon: '💎', isNew: true },
      { label: 'Online Ruler', href: '/tools/ruler',        icon: '📐' },
