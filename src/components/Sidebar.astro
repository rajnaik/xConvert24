    label: 'Experimental',
    icon: '🧪',
    items: [
      { label: 'Scrabble Solver',    href: '/tools/scrabble',       icon: '🔤' },
      { label: 'Morse Code',         href: '/tools/morse',          icon: '📡' },
      { label: 'Aspect Ratio',       href: '/tools/aspect-ratio',   icon: '🖥️' },
      { label: 'Epoch Converter',    href: '/tools/epoch',          icon: '⏳' },
      { label: 'Password Generator', href: '/tools/password',       icon: '🔑' },
