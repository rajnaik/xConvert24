    ],
  },
  {
    id: 'map-tools',
    label: 'Map Tools (Beta)',
    icon: '🗺️',
    items: [
      { label: 'Map Tools (Beta)', href: '/tools/distance-map', icon: '📍' },
    ],
  },
  {
    id: 'beta-plays',
    label: 'Beta Plays',
    icon: '🧬',
    items: [
      { label: 'Contagion Tracker', href: '/tools/contagion', icon: '🦠' },
    ],
  },
