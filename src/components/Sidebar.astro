      { label: 'World Clock',     href: '/tools/clock',       icon: '🌍' },
      { label: 'Stopwatch',       href: '/tools/stopwatch',   icon: '⏱️' },
      { label: 'Alarm',           href: '/tools/alarm',       icon: '⏰' },
      { label: 'Reminder',        href: '/tools/reminder',    icon: '🔔' },
      { label: 'Age Calculator',  href: '/tools/age',         icon: '🎂' },
      { label: 'Date Difference', href: '/tools/date-diff',   icon: '📅' },
