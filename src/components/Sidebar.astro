];

// Work out which category is active so we can pre-expand it
const activeCategory = nav.find(section =>
  section.items.some(item => currentPath === item.href || currentPath === item.href + '/')
)?.id ?? null;
---

<!-- Mobile overlay backdrop -->
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/50 z-30 lg:hidden hidden" aria-hidden="true"></div>

<!-- Sidebar -->
<aside
  id="sidebar"
  class="fixed top-0 left-0 h-full w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 z-40 flex flex-col transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out pointer-events-none lg:pointer-events-auto invisible lg:visible"
  aria-label="Main navigation"
>
  <!-- Header: logo + close -->
  <div class="flex items-center justify-between h-16 px-4 border-b border-gray-200 dark:border-gray-800 shrink-0">
    <a href="/" class="flex items-center gap-1.5" aria-label="xConvert24.com home">
      <svg width="298" height="77" viewBox="0 0 280 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="sb-bg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#4a3f5c"/>
            <stop offset="100%" stop-color="#d97706"/>
          </linearGradient>
          <linearGradient id="sb-text" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fcd34d"/>
            <stop offset="100%" stop-color="#d97706"/>
          </linearGradient>
        </defs>
        <rect x="2" y="4" width="40" height="40" rx="10" fill="url(#sb-bg)"/>
        <path d="M12 36 L22 26 M22 26 L22 32 M22 26 L16 26" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M32 12 L22 22 M22 22 L22 16 M22 22 L28 22" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="50" y="33" font-family="Inter, system-ui, sans-serif" font-size="26" font-weight="700" fill="url(#sb-text)" letter-spacing="-0.5">xConvert24</text>
      </svg>
    </a>
    <button id="sidebar-close" class="lg:hidden p-1.5 rounded-md text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="Close menu">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Search -->
  <div class="px-3 py-3 shrink-0">
    <form action="/search" method="get" role="search">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="sidebar-search"
          type="search"
          name="q"
          placeholder="Search converters..."
          autocomplete="off"
          class="w-full pl-9 pr-3 py-2 text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent"
          aria-label="Search converters"
        />
      </div>
    </form>
  </div>

  <!-- Treeview nav -->
  <nav class="flex-1 overflow-y-auto px-2 pb-6" id="sidebar-nav" aria-label="Converters navigation">

    <!-- Browse all link -->
    <div class="mb-1">
      <a href="/search" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Browse all converters
      </a>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-100 dark:border-gray-800 mb-2"></div>

    <!-- Tree -->
    <ul class="space-y-0.5" role="tree" aria-label="Converter categories">
      {nav.map((section) => {
        const hasActive = section.items.some(item => currentPath === item.href || currentPath === item.href + '/');
        // On mobile: only expand active category. On desktop: JS expands all after load.
        const isExpanded = hasActive;
        return (
          <li role="treeitem" aria-expanded={isExpanded} class="tree-node" data-id={section.id}>

            <!-- Category toggle button -->
            <button
              class:list={[
                'tree-toggle w-full flex items-center gap-2 px-2 py-2 rounded-lg text-sm font-semibold transition-colors select-none',
                hasActive
                  ? 'text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20'
                  : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800',
              ]}
              aria-expanded={isExpanded}
              aria-controls={`tree-children-${section.id}`}
              data-target={section.id}
            >
              {/* Chevron */}
              <svg
                class:list={['tree-chevron w-3.5 h-3.5 shrink-0 transition-transform duration-200 text-gray-400 dark:text-gray-500', isExpanded ? 'rotate-90' : '']}
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              {/* Category icon */}
              <span class="text-base leading-none w-5 text-center shrink-0" aria-hidden="true">{section.icon}</span>
              {/* Label */}
              <span class="flex-1 text-left">{section.label}</span>
              {/* Item count badge */}
              <span class="shrink-0 text-xs text-gray-400 dark:text-gray-500 tabular-nums">{section.items.length}</span>
            </button>

            <!-- Children list -->
            <ul
              id={`tree-children-${section.id}`}
              role="group"
              class:list={[
                'tree-children overflow-hidden transition-all duration-200',
                isExpanded ? 'max-h-96 opacity-100' : 'max-h-0 opacity-0',
              ]}
              data-expanded={isExpanded ? 'true' : 'false'}
            >
              {/* Vertical guide line + children */}
              <div class="relative ml-3.5 pl-3.5 border-l-2 border-gray-100 dark:border-gray-800 mt-0.5 mb-1 space-y-0.5">
                {section.items.map((item) => {
                  const isActive = currentPath === item.href || currentPath === item.href + '/';
                  return (
                    <li role="treeitem" class="nav-item" data-label={item.label.toLowerCase()}>
                      <a
                        href={item.href}
                        class:list={[
                          'flex items-center gap-2.5 px-2.5 py-1.5 rounded-lg text-sm transition-colors',
                          isActive
                            ? 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-semibold'
                            : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-gray-100 font-medium',
                        ]}
                        aria-current={isActive ? 'page' : undefined}
                      >
                        <span class="text-sm leading-none w-4 text-center shrink-0" aria-hidden="true">{item.icon}</span>
                        {item.label}
                        {item.isNew && (
                          <span class="ml-auto inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-orange-500 text-white shadow-sm">NEW</span>
                        )}
                        {isActive && !item.isNew && (
                          <span class="ml-auto w-1.5 h-1.5 rounded-full bg-amber-500 shrink-0" aria-hidden="true"></span>
                        )}
                      </a>
                    </li>
                  );
                })}
              </div>
            </ul>
          </li>
        );
      })}
    </ul>

    <!-- Tag Cloud (dynamic: favourites first, then by visits) -->
    <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800 px-1">
      <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 px-2">Popular</div>
      <div id="tag-cloud" class="flex flex-wrap gap-1.5 px-1 min-h-[80px]">
        <!-- Populated by JS -->
      </div>
    </div>
  </nav>
</aside>

<script>
  // ── Tag cloud: global favourite counts first, then visit popularity ─────
  (function() {
    var cloudEl = document.getElementById('tag-cloud');
    if (!cloudEl) return;

    // Labels for each path
    var labels = {
      '/convert/weight': 'kg to lbs', '/convert/length': 'km to miles',
      '/convert/temperature': '°C to °F', '/convert/currency': 'USD to EUR',
      '/tools/bmi': 'BMI', '/tools/calculator': 'Calculator',
      '/convert/cooking': 'cups to ml', '/tools/loan': 'Loan',
      '/convert/volume': 'liters to gal', '/tools/color': 'Color',
      '/convert/speed': 'mph to km/h', '/convert/data': 'MB to GB',
      '/tools/tip': 'Tip', '/tools/discount': 'Discount',
      '/tools/clock': 'World Clock', '/tools/age': 'Age',
      '/convert/area': 'acres', '/convert/energy': 'Energy',
      '/convert/pressure': 'PSI to bar', '/convert/power': 'kW to HP',
      '/convert/fuel': 'MPG', '/convert/base': 'Binary',
      '/convert/frequency': 'Hz to MHz', '/convert/angle': 'Radians',
      '/convert/roman': 'Roman', '/convert/time': 'Time',
      '/tools/date-diff': 'Date Diff', '/tools/stopwatch': 'Stopwatch',
      '/tools/alarm': 'Alarm', '/tools/reminder': 'Reminder',
    };

    // Base visit popularity (fallback if API fails)
    var visitWeights = {
      '/convert/weight': 95, '/convert/length': 90, '/convert/temperature': 88,
      '/convert/currency': 85, '/tools/bmi': 78, '/tools/calculator': 75,
      '/convert/cooking': 72, '/tools/loan': 72, '/convert/volume': 70,
      '/tools/color': 70, '/convert/speed': 68, '/convert/data': 65,
      '/tools/tip': 62, '/tools/discount': 58, '/tools/clock': 55,
      '/tools/age': 52, '/convert/area': 50, '/convert/energy': 50,
      '/convert/pressure': 48, '/convert/power': 45, '/convert/fuel': 42,
      '/convert/base': 40, '/convert/frequency': 38, '/convert/angle': 35,
      '/convert/roman': 30, '/convert/time': 60, '/tools/date-diff': 48,
      '/tools/stopwatch': 45, '/tools/alarm': 40, '/tools/reminder': 38,
    };

    function renderCloud(favCounts) {
      // Merge: favourite count weight (normalized to 0-100) + visit weight
      // Favourite counts are primary, visit weights are secondary (tiebreaker)
      var maxFavCount = Math.max(1, Math.max.apply(null, Object.values(favCounts).concat([1])));

      var tags = Object.keys(labels).map(function(href) {
        var favCount = favCounts[href] || 0;
        var favScore = (favCount / maxFavCount) * 60; // 0-60 from favourites
        var visitScore = ((visitWeights[href] || 30) / 100) * 40; // 0-40 from visits
        var weight = Math.round(favScore + visitScore);
        return { label: labels[href], href: href, weight: weight, favCount: favCount };
      });

      // Sort by weight descending
      tags.sort(function(a, b) { return b.weight - a.weight; });
      tags = tags.slice(0, 20);

      cloudEl.innerHTML = tags.map(function(tag) {
        var minSize = 10, maxSize = 16;
        var size = minSize + (tag.weight / 100) * (maxSize - minSize);
        var opacity = 0.5 + (tag.weight / 100) * 0.5;
        var isHot = tag.favCount > (maxFavCount * 0.5);
        var classes = isHot
          ? 'bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 hover:bg-red-100 dark:hover:bg-red-900/30'
          : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400';
        var heart = isHot ? '❤️ ' : '';
        return '<a href="' + tag.href + '" class="inline-block px-2 py-0.5 rounded-full ' + classes + ' transition-colors leading-snug" style="font-size:' + size + 'px;opacity:' + opacity + ';" title="' + tag.label + ' — ' + tag.favCount + ' favourites">' + heart + tag.label + '</a>';
      }).join('');
    }

    // Render immediately with visit weights (no flash)
    renderCloud({});

    // Then try to enhance with real favourite data (no layout shift)
    if (window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1') {
      fetch('/api/favourites').then(function(res) { return res.json(); }).then(function(data) {
        var counts = {};
        (data.counts || []).forEach(function(r) { counts[r.href] = r.count; });
        renderCloud(counts);
      }).catch(function() {
        // Already rendered with fallback, do nothing
      });
    }
  })();
</script>

<script>
  // ── Treeview toggle ────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.tree-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.target!;
      const node = document.querySelector<HTMLElement>(`.tree-node[data-id="${id}"]`);
      const children = document.getElementById(`tree-children-${id}`);
      const chevron = btn.querySelector<SVGElement>('.tree-chevron');
      if (!node || !children) return;

      const isOpen = children.dataset.expanded === 'true';

      if (isOpen) {
        // Collapse
        children.style.maxHeight = children.scrollHeight + 'px';
        requestAnimationFrame(() => {
          children.style.maxHeight = '0';
          children.style.opacity = '0';
        });
        children.dataset.expanded = 'false';
        btn.setAttribute('aria-expanded', 'false');
        node.setAttribute('aria-expanded', 'false');
        chevron?.classList.remove('rotate-90');
      } else {
        // Expand
        children.style.maxHeight = '0';
        children.style.opacity = '0';
        requestAnimationFrame(() => {
          children.style.maxHeight = children.scrollHeight + 'px';
          children.style.opacity = '1';
        });
        children.dataset.expanded = 'true';
        btn.setAttribute('aria-expanded', 'true');
        node.setAttribute('aria-expanded', 'true');
        chevron?.classList.add('rotate-90');
      }
    });

    // Keyboard: space/enter toggle, arrow keys navigate
    btn.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        btn.click();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        const id = btn.dataset.target!;
        const children = document.getElementById(`tree-children-${id}`);
        if (children?.dataset.expanded !== 'true') btn.click();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        const id = btn.dataset.target!;
        const children = document.getElementById(`tree-children-${id}`);
        if (children?.dataset.expanded === 'true') btn.click();
      }
    });
  });

  // ── Desktop: expand all categories (mobile starts collapsed) ────────────
  function expandAllCategories() {
    document.querySelectorAll<HTMLElement>('.tree-children').forEach(children => {
      if (children.dataset.expanded !== 'true') {
        children.style.maxHeight = children.scrollHeight + 'px';
        children.style.opacity = '1';
        children.dataset.expanded = 'true';
        const id = children.id.replace('tree-children-', '');
        const btn = document.querySelector<HTMLButtonElement>(`.tree-toggle[data-target="${id}"]`);
        const node = document.querySelector<HTMLElement>(`.tree-node[data-id="${id}"]`);
        const chevron = btn?.querySelector<SVGElement>('.tree-chevron');
        btn?.setAttribute('aria-expanded', 'true');
        node?.setAttribute('aria-expanded', 'true');
        chevron?.classList.add('rotate-90');
      }
    });
  }

  // On desktop (lg: ≥ 1024px), expand all categories immediately
  const lgMql = window.matchMedia('(min-width: 1024px)');
  if (lgMql.matches) expandAllCategories();
  lgMql.addEventListener('change', (e) => { if (e.matches) expandAllCategories(); });

  // ── Mobile sidebar ─────────────────────────────────────────────────────────
  const backdrop = document.getElementById('sidebar-backdrop');
  const sidebar  = document.getElementById('sidebar');
  const closeBtn = document.getElementById('sidebar-close');
  const hamburger = document.getElementById('hamburger-btn');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    sidebar?.classList.remove('pointer-events-none');
    sidebar?.classList.remove('invisible');
    sidebar?.classList.add('pointer-events-auto');
    sidebar?.classList.add('visible');
    backdrop?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    sidebar?.classList.remove('pointer-events-auto');
    sidebar?.classList.remove('visible');
    sidebar?.classList.add('pointer-events-none');
    sidebar?.classList.add('invisible');
    backdrop?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  backdrop?.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });

  // Scroll active item into view on desktop
  const activeLink = document.querySelector<HTMLAnchorElement>('[aria-current="page"]');
  if (activeLink) {
    activeLink.scrollIntoView({ block: 'nearest' });
  }
</script>
