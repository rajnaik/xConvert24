    icon: '⚡',
    items: [
      { label: 'Energy',       href: '/convert/energy',   icon: '⚡' },
      { label: 'Pressure',     href: '/convert/pressure', icon: '🔩' },
      { label: 'Power',        href: '/convert/power',    icon: '🔋' },
      { label: 'Fuel Economy', href: '/convert/fuel',     icon: '⛽' },
    ],
  },
