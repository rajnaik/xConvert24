      { label: 'Image Editor',     href: '/tools/image-editor',    icon: '🎨' },
      { label: 'Audio Converter',  href: '/tools/audio-converter', icon: '🎵' },
      { label: 'Video Converter',  href: '/tools/video-converter', icon: '🎥' },
      { label: 'Audio Formats',    href: '/tools/audio-formats',   icon: '📖' },
