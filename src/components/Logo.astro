---
interface Props {
  size?: 'sm' | 'md' | 'lg';
}
const { size = 'md' } = Astro.props;
const widths = { sm: 110, md: 140, lg: 180 };
const heights = { sm: 28, md: 36, lg: 46 };
const w = widths[size];
const h = heights[size];
---
<a href="/" class="inline-flex items-center gap-2 no-underline" aria-label="xConvert24.com home">
  <svg width={w} height={h} viewBox="0 0 280 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id="logo-bg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#4a3f5c"/>
        <stop offset="100%" stop-color="#d97706"/>
      </linearGradient>
      <linearGradient id="logo-text" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#fcd34d"/>
        <stop offset="100%" stop-color="#d97706"/>
      </linearGradient>
    </defs>
    <!-- Rounded square icon with gradient background -->
    <rect x="2" y="4" width="40" height="40" rx="10" fill="url(#logo-bg)"/>
    <!-- Arrow 1: bottom-left pointing up-right (↗) converging to center -->
    <path d="M12 36 L22 26 M22 26 L22 32 M22 26 L16 26" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <!-- Arrow 2: top-right pointing down-left (↙) converging to center -->
    <path d="M32 12 L22 22 M22 22 L22 16 M22 22 L28 22" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <!-- Text -->
    <text x="50" y="33" font-family="Inter, system-ui, sans-serif" font-size="26" font-weight="700" fill="url(#logo-text)" letter-spacing="-0.5">xConvert24</text>
  </svg>
</a>
