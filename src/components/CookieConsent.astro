---
/**
 * Cookie Consent Banner
 * - Compatible with Google Tag Manager (GTM) consent mode v2
 * - Stores preferences in a cookie with 30-day expiry
 * - Categories: necessary (always on), analytics, marketing
 * - Fires dataLayer consent_update events for GTM
 */
---

<!-- Cookie Consent Banner -->
<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 hidden"
  role="dialog"
  aria-label="Cookie consent"
  aria-modal="false"
>
  <div class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 shadow-2xl">
    <div class="max-w-5xl mx-auto px-4 py-5 lg:px-8">
      <!-- Main banner -->
      <div id="banner-main">
        <div class="flex flex-col lg:flex-row lg:items-center gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-lg" aria-hidden="true">🍪</span>
              <h2 class="text-sm font-semibold text-gray-900 dark:text-white">We value your privacy</h2>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
              We use cookies to enhance your experience, analyse site traffic, and for marketing purposes. You can choose which cookies to accept. 
              <a href="/cookies" class="text-amber-600 dark:text-amber-400 hover:underline">Learn more</a>
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-2 shrink-0">
            <button id="cookie-manage-btn" class="px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
              Manage Preferences
            </button>
            <button id="cookie-reject-btn" class="px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
              Reject All
            </button>
            <button id="cookie-accept-btn" class="px-5 py-2.5 text-sm font-semibold text-white bg-amber-500 rounded-lg hover:bg-amber-600 transition-colors">
              Accept All
            </button>
          </div>
        </div>
      </div>

      <!-- Preferences panel (hidden by default) -->
      <div id="banner-preferences" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Cookie Preferences</h2>
          <button id="cookie-back-btn" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors">← Back</button>
        </div>

        <!-- Cookie categories -->
        <div class="space-y-3 mb-5">
          <!-- Necessary (always on) -->
          <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700">
            <div>
              <div class="text-sm font-medium text-gray-900 dark:text-white">Essential Cookies</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Required for the site to function (theme, bookmarks). Cannot be disabled.</div>
            </div>
            <div class="shrink-0 ml-4">
              <span class="px-2 py-0.5 text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded-full">Always on</span>
            </div>
          </div>

          <!-- Analytics -->
          <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700">
            <div>
              <div class="text-sm font-medium text-gray-900 dark:text-white">Analytics Cookies</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Help us understand how visitors use the site (Google Analytics). Anonymised data.</div>
            </div>
            <div class="shrink-0 ml-4">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="consent-analytics" class="sr-only peer" checked />
                <div class="w-9 h-5 bg-gray-300 peer-focus:ring-2 peer-focus:ring-amber-500 dark:bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-amber-500"></div>
              </label>
            </div>
          </div>

          <!-- Marketing -->
          <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700">
            <div>
              <div class="text-sm font-medium text-gray-900 dark:text-white">Marketing Cookies</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Used to deliver relevant ads and track campaigns across sites.</div>
            </div>
            <div class="shrink-0 ml-4">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="consent-marketing" class="sr-only peer" />
                <div class="w-9 h-5 bg-gray-300 peer-focus:ring-2 peer-focus:ring-amber-500 dark:bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-amber-500"></div>
              </label>
            </div>
          </div>
        </div>

        <!-- Save preferences -->
        <div class="flex items-center justify-end gap-2">
          <button id="cookie-save-btn" class="px-5 py-2.5 text-sm font-semibold text-white bg-amber-500 rounded-lg hover:bg-amber-600 transition-colors">
            Save Preferences
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Small "manage cookies" trigger (visible after consent is given) -->
<button
  id="cookie-settings-trigger"
  class="fixed bottom-4 left-4 z-40 hidden w-10 h-10 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-full shadow-lg flex items-center justify-center text-lg hover:scale-110 transition-transform"
  aria-label="Manage cookie settings"
  title="Cookie settings"
>🍪</button>

<script is:inline>
(function() {
  // ─── GTM Consent Mode v2 ───────────────────────────────────────────────
  // gtag and dataLayer already defined in <head>

  // ─── Cookie helpers ────────────────────────────────────────────────────
  var COOKIE_NAME = 'xc24_consent';
  var COOKIE_DAYS = 30;

  function setCookie(value) {
    var d = new Date();
    d.setTime(d.getTime() + COOKIE_DAYS * 24 * 60 * 60 * 1000);
    document.cookie = COOKIE_NAME + '=' + encodeURIComponent(JSON.stringify(value)) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  function getCookie() {
    var match = document.cookie.match(new RegExp('(^| )' + COOKIE_NAME + '=([^;]+)'));
    if (match) {
      try { return JSON.parse(decodeURIComponent(match[2])); } catch(e) {}
    }
    return null;
  }

  // ─── Apply consent ─────────────────────────────────────────────────────
  function applyConsent(prefs) {
    gtag('consent', 'update', {
      'analytics_storage': prefs.analytics ? 'granted' : 'denied',
      'ad_storage': prefs.marketing ? 'granted' : 'denied',
      'ad_user_data': prefs.marketing ? 'granted' : 'denied',
      'ad_personalization': prefs.marketing ? 'granted' : 'denied',
      'personalization_storage': prefs.marketing ? 'granted' : 'denied',
    });

    // Push custom event for GTM triggers
    dataLayer.push({
      'event': 'consent_update',
      'consent_analytics': prefs.analytics,
      'consent_marketing': prefs.marketing,
    });
  }

  // ─── UI Elements ──────────────────────────────────────────────────────
  var banner = document.getElementById('cookie-banner');
  var mainPanel = document.getElementById('banner-main');
  var prefsPanel = document.getElementById('banner-preferences');
  var acceptBtn = document.getElementById('cookie-accept-btn');
  var rejectBtn = document.getElementById('cookie-reject-btn');
  var manageBtn = document.getElementById('cookie-manage-btn');
  var backBtn = document.getElementById('cookie-back-btn');
  var saveBtn = document.getElementById('cookie-save-btn');
  var trigger = document.getElementById('cookie-settings-trigger');
  var analyticsCheckbox = document.getElementById('consent-analytics');
  var marketingCheckbox = document.getElementById('consent-marketing');

  function showBanner() {
    banner.classList.remove('hidden');
    mainPanel.classList.remove('hidden');
    prefsPanel.classList.add('hidden');
    trigger.classList.add('hidden');
  }

  function hideBanner() {
    banner.classList.add('hidden');
    trigger.classList.remove('hidden');
    trigger.style.display = 'flex';
  }

  function showPrefs() {
    mainPanel.classList.add('hidden');
    prefsPanel.classList.remove('hidden');
  }

  function showMain() {
    prefsPanel.classList.add('hidden');
    mainPanel.classList.remove('hidden');
  }

  // ─── Actions ───────────────────────────────────────────────────────────
  function acceptAll() {
    var prefs = { analytics: true, marketing: true, timestamp: Date.now() };
    setCookie(prefs);
    applyConsent(prefs);
    hideBanner();
  }

  function rejectAll() {
    var prefs = { analytics: false, marketing: false, timestamp: Date.now() };
    setCookie(prefs);
    applyConsent(prefs);
    hideBanner();
  }

  function savePrefs() {
    var prefs = {
      analytics: analyticsCheckbox.checked,
      marketing: marketingCheckbox.checked,
      timestamp: Date.now(),
    };
    setCookie(prefs);
    applyConsent(prefs);
    hideBanner();
  }

  // ─── Event listeners ───────────────────────────────────────────────────
  acceptBtn.addEventListener('click', acceptAll);
  rejectBtn.addEventListener('click', rejectAll);
  manageBtn.addEventListener('click', showPrefs);
  backBtn.addEventListener('click', showMain);
  saveBtn.addEventListener('click', savePrefs);
  trigger.addEventListener('click', showBanner);

  // ─── Init: check if consent already given ──────────────────────────────
  var existing = getCookie();
  if (existing) {
    // Consent already stored — apply it silently
    applyConsent(existing);
    // Set checkbox states
    analyticsCheckbox.checked = !!existing.analytics;
    marketingCheckbox.checked = !!existing.marketing;
    // Show the small trigger button
    trigger.classList.remove('hidden');
    trigger.style.display = 'flex';
  } else {
    // No consent yet — show banner
    showBanner();
  }
})();
</script>
