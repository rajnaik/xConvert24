      // ─── Favourites system ─────────────────────────────────────────────────
      (function() {
        var FAV_KEY = 'xconvert24-favourites';
        var path = window.location.pathname.replace(/\/$/, '') || '/';

        function getFavs() {
          try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch(e) { return []; }
        }
        function saveFavs(favs) { localStorage.setItem(FAV_KEY, JSON.stringify(favs)); }
        function isFav() { return getFavs().some(function(f) { return f.href === path; }); }

        // Update badge count
        var badge = document.getElementById('fav-badge');
        var count = getFavs().length;
        if (badge && count > 0) {
          badge.textContent = count.toString();
          badge.classList.remove('hidden');
          badge.style.display = 'flex';
        }

        // Only inject heart button on converter/tool pages
        if (!/^\/(convert|tools)\//.test(path)) return;

        // Find the page header (first h1)
        var h1 = document.querySelector('main h1');
        if (!h1) return;
        var headerDiv = h1.closest('.flex') || h1.parentElement;
        if (!headerDiv) return;

        var pageName = h1.textContent.trim();
        var isFavourite = isFav();

        // Create heart button
        var btn = document.createElement('button');
        btn.className = 'ml-auto shrink-0 p-2 rounded-lg transition-colors ' + (isFavourite ? 'text-red-500 bg-red-50 dark:bg-red-900/20' : 'text-red-300 dark:text-red-800 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20');
        btn.setAttribute('aria-label', isFavourite ? 'Remove from favourites' : 'Add to favourites');
        btn.setAttribute('title', isFavourite ? '❤️ In your favourites — click to remove' : '🤍 Add to favourites');
        btn.innerHTML = isFavourite
          ? '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>'
          : '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>';

        btn.addEventListener('click', function() {
          var favs = getFavs();
          if (isFav()) {
            // Remove
            favs = favs.filter(function(f) { return f.href !== path; });
            saveFavs(favs);
            btn.className = 'ml-auto shrink-0 p-2 rounded-lg transition-colors text-red-300 dark:text-red-800 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20';
            btn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>';
            btn.setAttribute('title', '🤍 Add to favourites');
            // GA event + API
            if (typeof gtag === 'function') gtag('event', 'remove_favourite', { page_title: pageName, page_path: path });
            fetch('/api/favourites', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ href: path, action: 'remove' }) }).catch(function(){});
          } else {
            // Add
            var category = '';
            var catEl = document.querySelector('[data-section] .px-2.py-1\\.5');
            if (catEl) category = catEl.textContent.trim();
            favs.unshift({ name: pageName, href: path, category: category, addedAt: Date.now() });
            saveFavs(favs);
            btn.className = 'ml-auto shrink-0 p-2 rounded-lg transition-colors text-red-500 bg-red-50 dark:bg-red-900/20';
            btn.innerHTML = '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>';
            btn.setAttribute('title', '❤️ In your favourites — click to remove');
            // GA event + API
            if (typeof gtag === 'function') gtag('event', 'add_favourite', { page_title: pageName, page_path: path, category: category });
            fetch('/api/favourites', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ href: path, action: 'add' }) }).catch(function(){});

            // Auto-publish favourites so it appears in "What Others Are Adding"
            var uid = localStorage.getItem('xconvert24-uid') || '';
            if (uid) {
              var allNames = favs.map(function(f) { return f.name; });
              fetch('/api/favourites', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ user_id: uid, items: allNames, hidden: false }) }).catch(function(){});
            }

            // Check favourite_5 milestone
            if (favs.length >= 5 && !localStorage.getItem('xc-coin-favourite_5')) {
              var t = new Date().toISOString().split('T')[0];
              localStorage.setItem('xc-coin-favourite_5', t);
              var u = localStorage.getItem('xconvert24-uid') || '';
              if (u) {
                fetch('/api/coins', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ uid: u, activity: 'favourite_5' }) }).catch(function(){});
                // Record in rewards_granted table
                fetch('/api/rewards-granted', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ user_id: u, activity: 'favourite_5', coins: 10 }) }).catch(function(){});
                // Emit event
                fetch('/api/events', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_type: 'favourite_5_achieved', payload: { user_id: u, count: favs.length } }) }).catch(function(){});
              }
              // Log reward
              var rk = 'xconvert24-rewards-log'; var rw = []; try { rw = JSON.parse(localStorage.getItem(rk) || '[]'); } catch(e) {}
              rw.unshift({ activity: 'favourite_5', description: 'Added 5 items to favourites', coins: 10, date: new Date().toISOString() });
              localStorage.setItem(rk, JSON.stringify(rw.slice(0, 100)));
            }
          }
          // Update badge
          var newCount = getFavs().length;
          if (badge) {
            badge.textContent = newCount.toString();
            if (newCount > 0) { badge.classList.remove('hidden'); badge.style.display = 'flex'; }
            else { badge.classList.add('hidden'); }
          }
        });

        headerDiv.style.display = 'flex';
        headerDiv.style.alignItems = 'center';
        headerDiv.appendChild(btn);
      })();
    </script>

    <script is:inline>
      // Bookmark functionality with dropdown
      (function() {
        var btn = document.getElementById('bookmark-btn');
        var outline = document.getElementById('bookmark-outline');
        var filled = document.getElementById('bookmark-filled');
        var dropdown = document.getElementById('bookmark-dropdown');
        var wrapper = document.getElementById('bookmark-wrapper');
        var listEl = document.getElementById('bookmark-list');
        var countEl = document.getElementById('bookmark-count');
        var actionEl = document.getElementById('bookmark-action');
        var key = 'xconvert-bookmarks';
        var path = window.location.pathname;
        var title = document.title.split(' | ')[0];
        var isOpen = false;

        function getBookmarks() {
          try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch(e) { return []; }
        }

        function isBookmarked() {
          return getBookmarks().some(function(b) { return b.path === path; });
        }

        function addBookmark() {
          var bookmarks = getBookmarks();
          if (!bookmarks.some(function(b) { return b.path === path; })) {
            bookmarks.unshift({ path: path, title: title, date: new Date().toLocaleDateString() });
            localStorage.setItem(key, JSON.stringify(bookmarks));
          }
        }

        function removeBookmark() {
          var bookmarks = getBookmarks().filter(function(b) { return b.path !== path; });
          localStorage.setItem(key, JSON.stringify(bookmarks));
        }

        function renderIcon() {
          if (isBookmarked()) {
            outline.classList.add('hidden');
            filled.classList.remove('hidden');
          } else {
            outline.classList.remove('hidden');
            filled.classList.add('hidden');
          }
        }

        function renderDropdown() {
          var bookmarks = getBookmarks();
          countEl.textContent = bookmarks.length + ' saved';

          if (bookmarks.length === 0) {
            listEl.innerHTML = '<div class="px-4 py-3 text-sm text-gray-400 dark:text-gray-500 italic">No bookmarks yet</div>';
          } else {
            listEl.innerHTML = bookmarks.map(function(b) {
              return '<a href="' + b.path + '" class="flex items-center justify-between px-4 py-2.5 hover:bg-amber-50 dark:hover:bg-amber-900/10 transition-colors">' +
                '<span class="text-sm text-gray-700 dark:text-gray-300 truncate">' + b.title + '</span>' +
                '<button data-remove="' + b.path + '" class="shrink-0 ml-2 text-gray-300 dark:text-gray-600 hover:text-red-500 transition-colors" aria-label="Remove bookmark" onclick="event.preventDefault();event.stopPropagation();">' +
                '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
                '</button></a>';
            }).join('');

            // Attach remove handlers
            listEl.querySelectorAll('[data-remove]').forEach(function(el) {
              el.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var p = el.getAttribute('data-remove');
                var bm = getBookmarks().filter(function(b) { return b.path !== p; });
                localStorage.setItem(key, JSON.stringify(bm));
                renderIcon();
                renderDropdown();
              });
            });
          }

          // Action text
          if (isBookmarked()) {
            actionEl.innerHTML = '✓ This page is bookmarked. <button id="bm-remove-current" class="text-red-500 hover:underline">Remove</button>';
            var removeBtn = document.getElementById('bm-remove-current');
            if (removeBtn) removeBtn.addEventListener('click', function() { removeBookmark(); renderIcon(); renderDropdown(); });
          } else {
            actionEl.innerHTML = '<button id="bm-add-current" class="text-amber-600 dark:text-amber-400 hover:underline font-medium">+ Bookmark this page</button>';
            var addBtn = document.getElementById('bm-add-current');
            if (addBtn) addBtn.addEventListener('click', function() { addBookmark(); renderIcon(); renderDropdown(); });
          }
        }

        function toggleDropdown() {
          isOpen = !isOpen;
          if (isOpen) {
            renderDropdown();
            dropdown.classList.remove('hidden');
          } else {
            dropdown.classList.add('hidden');
          }
        }

        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          toggleDropdown();
        });

        // Close on outside click
        document.addEventListener('click', function(e) {
          if (!wrapper.contains(e.target) && isOpen) {
            isOpen = false;
            dropdown.classList.add('hidden');
          }
        });

        renderIcon();
      })();
    </script>

    <!-- ConvertCoins tracker — awards coins for user activities -->
    <script is:inline>
    (function() {
      var UID_KEY = 'xconvert24-uid';
      var COIN_PREFIX = 'xc-coin-';

      function getUid() {
        var uid = localStorage.getItem(UID_KEY);
        if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem(UID_KEY, uid); }
        return uid;
      }

      function earnCoins(activity) {
        var uid = getUid();
        fetch('/api/coins', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ uid: uid, activity: activity })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.success) updateBadge(data);
        }).catch(function() {});
      }

      function updateBadge(data) {
        var el = document.getElementById('coins-count');
        var flame = document.getElementById('streak-flame');
        if (el && data.coins !== undefined) el.textContent = data.coins.toString();
        if (flame && data.streak && data.streak >= 3) flame.classList.remove('hidden');
      }

      // Load current balance
      var uid = getUid();
      fetch('/api/coins?uid=' + uid).then(function(r) { return r.json(); }).then(function(data) {
        updateBadge(data);
      }).catch(function() {});

      // Prevent duplicate awards per session/day
      var today = new Date().toISOString().split('T')[0];
      function awardedToday(key) { return localStorage.getItem(COIN_PREFIX + key) === today; }
      function markAwarded(key) { localStorage.setItem(COIN_PREFIX + key, today); }

      var path = window.location.pathname;

      // 1. Daily visit — award once per day
      if (!awardedToday('daily_visit')) {
        markAwarded('daily_visit');
        earnCoins('daily_visit');
      }

      // 2. First conversion of the day — detect converter pages
      if (/^\/convert\//.test(path) && !awardedToday('first_conversion')) {
        markAwarded('first_conversion');
        earnCoins('first_conversion');
      }

      // 3. Multi-converter: track unique converters in session, award at 3
      if (/^\/convert\//.test(path)) {
        var sessionConverters = JSON.parse(sessionStorage.getItem('xc-session-converters') || '[]');
        if (sessionConverters.indexOf(path) === -1) sessionConverters.push(path);
        sessionStorage.setItem('xc-session-converters', JSON.stringify(sessionConverters));
        if (sessionConverters.length >= 3 && !awardedToday('multi_converter')) {
          markAwarded('multi_converter');
          earnCoins('multi_converter');
        }
      }

      // 4. Blog read
      if (/^\/blog\/[^/]+/.test(path) && !awardedToday('blog_read_' + path)) {
        markAwarded('blog_read_' + path);
        earnCoins('blog_read');
      }

      // 5. Tool usage (crypto, cooking, etc.)
      if (/^\/tools\/crypto/.test(path) && !awardedToday('crypto_use')) {
        markAwarded('crypto_use');
        earnCoins('crypto_use');
      }
      if (path === '/convert/cooking' && !awardedToday('cooking_convert')) {
        markAwarded('cooking_convert');
        earnCoins('cooking_convert');
      }
      if (/^\/tools\/(loan|tip|discount)/.test(path) && !awardedToday('finance_use')) {
        markAwarded('finance_use');
        earnCoins('finance_use');
      }
      if (/^\/convert\/(shoe-size|clothing-size)/.test(path) && !awardedToday('fashion_convert')) {
        markAwarded('fashion_convert');
        earnCoins('fashion_convert');
      }

      // 6. Bookmark a page — award coins for bookmarking
      var bookmarkBtn = document.getElementById('bookmark-btn');
      if (bookmarkBtn) {
        bookmarkBtn.addEventListener('click', function() {
          if (!awardedToday('bookmark_' + path)) {
            markAwarded('bookmark_' + path);
            earnCoins('bookmark_page');
            logReward('bookmark_page', 'Bookmarked: ' + document.title.split(' | ')[0], 5);
          }
        });
      }

      // 7. Report a bug — listen for bug form submission
      if (path === '/report-bug') {
        var bugForm = document.querySelector('form');
        if (bugForm) {
          bugForm.addEventListener('submit', function() {
            if (!awardedToday('report_bug')) {
              markAwarded('report_bug');
              earnCoins('report_bug');
              logReward('report_bug', 'Reported a bug', 25);
            }
          });
        }
      }

      // 8. Vote on a bug
      document.addEventListener('click', function(e) {
        var voteBtn = e.target.closest('[data-vote-bug]');
        if (voteBtn) {
          var bugId = voteBtn.getAttribute('data-vote-bug') || 'unknown';
          var key = 'vote_bug_' + bugId;
          if (!localStorage.getItem(COIN_PREFIX + key)) {
            localStorage.setItem(COIN_PREFIX + key, today);
            earnCoins('vote_bug');
            logReward('vote_bug', 'Voted on bug #' + bugId, 3);
          }
        }
      });

      // 9. Suggest a feature
      if (path === '/suggest') {
        var sugForm = document.querySelector('form');
        if (sugForm) {
          sugForm.addEventListener('submit', function() {
            if (!awardedToday('suggest_feature')) {
              markAwarded('suggest_feature');
              earnCoins('suggest_feature');
              logReward('suggest_feature', 'Suggested a feature', 10);
            }
          });
        }
      }

      // 10. Vote/rate a suggestion
      document.addEventListener('click', function(e) {
        var rateBtn = e.target.closest('[data-rate-suggestion]');
        if (rateBtn) {
          var sugId = rateBtn.getAttribute('data-rate-suggestion') || 'unknown';
          var key = 'rate_sug_' + sugId;
          if (!localStorage.getItem(COIN_PREFIX + key)) {
            localStorage.setItem(COIN_PREFIX + key, today);
            earnCoins('vote_suggestion');
            logReward('vote_suggestion', 'Rated a suggestion', 3);
          }
        }
      });

      // 11. Crypto watchlist — creating a list and adding coins
      document.addEventListener('click', function(e) {
        var addCoin = e.target.closest('[data-add-crypto]');
        if (addCoin) {
          var coin = addCoin.getAttribute('data-add-crypto') || 'unknown';
          var key = 'crypto_add_' + coin;
          if (!localStorage.getItem(COIN_PREFIX + key)) {
            localStorage.setItem(COIN_PREFIX + key, today);
            earnCoins('crypto_watchlist');
            logReward('crypto_watchlist', 'Added ' + coin + ' to watchlist', 2);
          }
        }
      });

      // 12. Add to favourites
      document.addEventListener('click', function(e) {
        var favBtn = e.target.closest('[data-add-favourite]');
        if (favBtn) {
          var favItem = favBtn.getAttribute('data-add-favourite') || path;
          var key = 'fav_' + favItem;
          if (!localStorage.getItem(COIN_PREFIX + key)) {
            localStorage.setItem(COIN_PREFIX + key, today);
            earnCoins('add_favourite');
            logReward('add_favourite', 'Added to favourites: ' + favItem, 3);

            // Check if user has reached 5 favourites → award milestone
            try {
              var favs = JSON.parse(localStorage.getItem('xconvert24-favourites') || '[]');
              if (favs.length >= 5 && !localStorage.getItem(COIN_PREFIX + 'favourite_5')) {
                localStorage.setItem(COIN_PREFIX + 'favourite_5', today);
                earnCoins('favourite_5');
                logReward('favourite_5', 'Added 5 items to favourites', 10);
              }
            } catch(ex) {}
          }
        }
      });

      // --- Reward logging to localStorage ---
      function logReward(activity, description, coins) {
        var REWARDS_KEY = 'xconvert24-rewards-log';
        var rewards = [];
        try { rewards = JSON.parse(localStorage.getItem(REWARDS_KEY) || '[]'); } catch(e) { rewards = []; }
        rewards.unshift({
          activity: activity,
          description: description,
          coins: coins,
          date: new Date().toISOString()
        });
        // Keep max 100 entries
        if (rewards.length > 100) rewards = rewards.slice(0, 100);
        localStorage.setItem(REWARDS_KEY, JSON.stringify(rewards));
      }

      // Log page-based rewards that fire above
      if (/^\/convert\//.test(path) && localStorage.getItem(COIN_PREFIX + 'first_conversion') === today) {
        logReward('first_conversion', 'First conversion: ' + path.replace('/convert/', ''), 5);
      }
      if (/^\/blog\/[^/]+/.test(path)) {
        logReward('blog_read', 'Read: ' + document.title.split(' | ')[0], 5);
      }

      // 6. Streak check — award streak_7 and streak_30
      fetch('/api/coins?uid=' + uid).then(function(r) { return r.json(); }).then(function(data) {
        if (data.streak >= 7 && !awardedToday('streak_7')) { markAwarded('streak_7'); earnCoins('streak_7'); }
        if (data.streak >= 30 && !awardedToday('streak_30')) { markAwarded('streak_30'); earnCoins('streak_30'); }
      }).catch(function() {});
    })();
    </script>

    <!-- Analytics tracker — captures user interactions with UserID + DateTime -->
    <script is:inline>
    (function() {
      var UID_KEY = 'xconvert24-uid';
      function getUid() {
        var uid = localStorage.getItem(UID_KEY);
        if (!uid) { uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); localStorage.setItem(UID_KEY, uid); }
        return uid;
      }

      function track(event, page, metadata) {
        var uid = getUid();
        fetch('/api/analytics', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: uid, event: event, page: page || window.location.pathname, metadata: metadata || null })
        }).catch(function() {});
      }

      var path = window.location.pathname;

      // --- Page view tracking ---
      // Converter clicks
      if (/^\/convert\//.test(path)) {
        track('converter_view', path, path.replace('/convert/', ''));
      }
      // Tool/utility clicks
      if (/^\/tools\//.test(path)) {
        track('tool_view', path, path.replace('/tools/', ''));
      }
      // Blog clicks
      if (/^\/blog\/[^/]+/.test(path)) {
        track('blog_view', path);
      }
      // Profile view
      if (path === '/profile') {
        track('profile_view', path);
      }
      // Favourites view
      if (path === '/favourites') {
        track('favourites_view', path);
      }
      // Opinion view
      if (path === '/opinion') {
        track('opinion_view', path);
      }

      // --- Click tracking via event delegation ---
      document.addEventListener('click', function(e) {
        var el = e.target;

        // Bug report submit
        if (path === '/report-bug' && el.closest('button[type="submit"], input[type="submit"]')) {
          track('bug_report_submit', path);
        }

        // Bug vote
        var voteBtn = el.closest('[data-vote-bug], .vote-btn, [id*="vote"]');
        if (path === '/vote-bugs' && voteBtn) {
          var bugId = voteBtn.getAttribute('data-vote-bug') || voteBtn.getAttribute('data-id') || '';
          track('bug_vote', path, bugId);
        }

        // Suggest feature submit
        if (path === '/suggest' && el.closest('button[type="submit"], input[type="submit"]')) {
          track('feature_suggest_submit', path);
        }

        // Suggestion vote/rate
        var rateBtn = el.closest('[data-rate-suggestion], .star-btn, [data-sug-id]');
        if (path === '/suggestions' && rateBtn) {
          var sugId = rateBtn.getAttribute('data-rate-suggestion') || rateBtn.getAttribute('data-sug-id') || '';
          track('suggestion_vote', path, sugId);
        }

        // Opinion vote
        if (path === '/opinion' && el.closest('#vote-yes, #vote-no, #vote-maybe')) {
          var response = '';
          if (el.closest('#vote-yes')) response = 'yes';
          else if (el.closest('#vote-no')) response = 'no';
          else if (el.closest('#vote-maybe')) response = 'maybe';
          track('opinion_vote', path, response);
        }

        // Bookmark click
        if (el.closest('#bookmark-btn')) {
          track('bookmark_click', path);
        }

        // Favourite add
        if (el.closest('[data-add-favourite]')) {
          track('favourite_add', path, el.closest('[data-add-favourite]').getAttribute('data-add-favourite'));
        }

        // Crypto watchlist add
        if (el.closest('[data-add-crypto]')) {
          track('crypto_add', path, el.closest('[data-add-crypto]').getAttribute('data-add-crypto'));
        }
      });
    })();
    </script>

    <!-- Global click tracker — captures ALL interactive element clicks to /api/clicks -->
    <script is:inline>
    (function() {
      // Skip admin pages entirely
      if (window.location.pathname.startsWith('/admin')) return;

      var UID_KEY = 'xconvert24-uid';
      function getUid() {
        var uid = localStorage.getItem(UID_KEY);
        if (!uid) {
          uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
          localStorage.setItem(UID_KEY, uid);
        }
        return uid;
      }

      // Describe the clicked element as meaningfully as possible
      function describeElement(el) {
        return el.getAttribute('aria-label')
          || el.getAttribute('data-track')
          || el.getAttribute('title')
          || (el.textContent || '').trim().slice(0, 60)
          || el.getAttribute('id')
          || el.getAttribute('name')
          || el.tagName.toLowerCase();
      }

      // Selectors for interactive elements
      var INTERACTIVE = 'a, button, [role="button"], input[type="submit"], input[type="button"], [data-track], summary, [onclick]';

      document.addEventListener('click', function(e) {
        var el = e.target.closest(INTERACTIVE);
        if (!el) return;

        // Skip if inside an admin-only component
        if (el.closest('[data-admin]')) return;

        var uid = getUid();
        var pageUrl = window.location.pathname + window.location.search;
        var element = describeElement(el);

        var payload = JSON.stringify({
          user_id: uid,
          ui_element: element,
          url: pageUrl
        });

        // Use sendBeacon for non-blocking fire-and-forget (doesn't delay navigation)
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/clicks', new Blob([payload], { type: 'application/json' }));
        } else {
          fetch('/api/clicks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true
          }).catch(function() {});
        }
      });
    })();
    </script>
  </body>
</html>
