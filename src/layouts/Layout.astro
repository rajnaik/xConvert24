---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Free online unit converters and calculators. Convert weight, length, temperature, currency, and more.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | xConvert.com</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | xConvert.com`} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#f59e0b" />
    <script is:inline>
      // Prevent flash of wrong theme
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen">
    <!-- Sidebar -->
    <Sidebar />

    <!-- Main layout wrapper -->
    <div class="lg:pl-64 flex flex-col min-h-screen">
      <!-- Top header -->
      <header class="sticky top-0 z-20 h-16 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800 flex items-center justify-between px-4 lg:px-6">
        <!-- Hamburger (mobile) -->
        <button
          id="hamburger-btn"
          class="lg:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Logo (mobile only - desktop shows in sidebar) -->
        <a href="/" class="lg:hidden flex items-center" aria-label="xConvert.com">
          <svg width="105" height="28" viewBox="0 0 145 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="hdr-gold" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#fbbf24"/>
                <stop offset="100%" stop-color="#d97706"/>
              </linearGradient>
              <linearGradient id="hdr-text" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fcd34d"/>
                <stop offset="100%" stop-color="#d97706"/>
              </linearGradient>
            </defs>
            <line x1="4" y1="34" x2="24" y2="8" stroke="url(#hdr-gold)" stroke-width="3.5" stroke-linecap="round"/>
            <polyline points="14,8 24,8 24,18" stroke="url(#hdr-gold)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <line x1="4" y1="8" x2="24" y2="34" stroke="url(#hdr-gold)" stroke-width="3.5" stroke-linecap="round"/>
            <polyline points="14,34 24,34 24,24" stroke="url(#hdr-gold)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <text x="31" y="29" font-family="Inter, system-ui, sans-serif" font-size="20" font-weight="700" fill="url(#hdr-text)" letter-spacing="-0.5">xConvert.com</text>
          </svg>
        </a>

        <!-- Right side: search + theme toggle -->
        <div class="flex items-center gap-2 ml-auto">
          <!-- Search bar (desktop) -->
          <form action="/search" method="get" class="hidden md:flex items-center" role="search">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
              <input
                type="search"
                name="q"
                placeholder="Search converters…"
                class="h-9 w-52 pl-9 pr-3 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:bg-white dark:focus:bg-gray-900 transition-colors"
                aria-label="Search converters"
              />
            </div>
          </form>
          <!-- Search icon (mobile) -->
          <a href="/search" class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label="Search">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </a>
          <ThemeToggle />
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 p-4 lg:p-8 max-w-5xl w-full mx-auto">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-gray-200 dark:border-gray-800 py-6 px-4 lg:px-8 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>© {new Date().getFullYear()} xConvert.com — Free online unit converters &amp; calculators</p>
      </footer>
    </div>
  </body>
</html>
