---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Contact xSoft Ltd — Start Your Software Project Today" description="Get in touch with xSoft Ltd. We'll respond within 24 hours with a clear plan for your AI chatbot, web application, or Chrome extension project." keywords="contact xSoft, hire developer, AI chatbot quote, web development enquiry">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact xSoft Ltd",
    "url": "https://www.xsoftlimited.com/contact/",
    "mainEntity": {
      "@type": "Organization",
      "name": "xSoft Ltd",
      "email": "info@xsoftlimited.com",
      "contactPoint": { "@type": "ContactPoint", "contactType": "sales", "email": "info@xsoftlimited.com" }
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How quickly will xSoft respond to my enquiry?", "acceptedAnswer": { "@type": "Answer", "text": "We respond within 24 hours on weekdays, usually much faster. You'll receive honest feedback on whether we can help and a clear outline of next steps." }},
      { "@type": "Question", "name": "Can I book a call instead of filling out a form?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You can book a free 15-minute discovery call directly via our Calendly widget on the contact page. A Google Meet link is automatically included." }},
      { "@type": "Question", "name": "What information should I include in my enquiry?", "acceptedAnswer": { "@type": "Answer", "text": "Tell us what you're trying to build, who it's for, and any constraints (timeline, budget, tech preferences). The more context you provide, the more useful our initial response will be." }}
    ]
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Contact</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">Let's build something great</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Tell us about your project. We'll get back within 24 hours with honest feedback on whether we can help — and what it would cost.</p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Form -->
        <div class="lg:col-span-2">
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm text-gray-300 mb-2">Your Name</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" placeholder="Jane Smith" />
              </div>
              <div>
                <label for="email" class="block text-sm text-gray-300 mb-2">Email Address</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" placeholder="jane@company.com" />
              </div>
            </div>

            <div>
              <label for="phone" class="block text-sm text-gray-300 mb-2">Phone Number <span class="text-gray-500">(optional — we'll call you back)</span></label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" placeholder="+44 7xxx xxx xxx" />
            </div>

            <div>
              <label for="service" class="block text-sm text-gray-300 mb-2">What do you need?</label>
              <select id="service" name="service" class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors">
                <option value="ai-chatbot">AI Chatbot</option>
                <option value="web-development">Web Development</option>
                <option value="chrome-extension">Chrome Extension</option>
                <option value="seo">SEO & Content</option>
                <option value="other">Something Else</option>
              </select>
            </div>

            <div>
              <label for="timeline" class="block text-sm text-gray-300 mb-2">Delivery Timeline</label>
              <select id="timeline" name="timeline" class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors">
                <option value="1-2 weeks">1–2 weeks</option>
                <option value="2-4 weeks">2–4 weeks</option>
                <option value="1-2 months">1–2 months</option>
                <option value="3+ months">3+ months</option>
                <option value="flexible">Flexible / not sure</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm text-gray-300 mb-2">Tell us about your project</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors resize-none" placeholder="Describe what you're trying to build, who it's for, and any constraints (timeline, budget, tech preferences)..."></textarea>
            </div>

            <button type="submit" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all hover:shadow-xl hover:shadow-indigo-500/25 hover:-translate-y-0.5">
              Send Message →
            </button>
            <p class="mt-3 text-xs text-gray-500">Every project is quoted individually. We'll provide a clear estimate within 24 hours of your enquiry.</p>
          </form>

          <div id="form-success" class="hidden mt-6 p-5 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
            <p class="text-emerald-400 font-semibold">Message sent!</p>
            <p class="text-sm text-gray-300 mt-1">We'll get back to you within 24 hours.</p>
          </div>

          <!-- Calendly inline widget -->
          <div class="mt-10 pt-8 border-t border-gray-800">
            <h2 class="text-lg font-semibold text-white mb-2">Or book a call directly</h2>
            <p class="text-sm text-gray-400 mb-4">Pick a 15-minute slot that works for you — no forms, no waiting.</p>
            <div class="rounded-xl overflow-hidden border border-gray-800 bg-gray-900/50" style="min-height: 630px;">
              <div class="calendly-inline-widget" data-url="https://calendly.com/raj007/15min?hide_gdpr_banner=1&background_color=0f172a&text_color=e2e8f0&primary_color=6366f1" style="min-width:100%;height:630px;"></div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Book a Call -->
          <div class="p-5 rounded-xl border border-indigo-500/30 bg-indigo-950/10">
            <h3 class="text-sm font-semibold text-white mb-2">Prefer to talk?</h3>
            <p class="text-xs text-gray-400 mb-3">Book a free 15-minute discovery call.</p>
            <a href="https://calendly.com/raj007/15min" target="_blank" rel="noopener" class="block text-center px-4 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-all">
              Book a Call →
            </a>
          </div>

          <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/50">
            <h3 class="text-sm font-semibold text-white mb-3">Direct Email</h3>
            <a href="mailto:info@xsoftlimited.com" class="text-indigo-400 hover:underline text-sm">info@xsoftlimited.com</a>
          </div>

          <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/50">
            <h3 class="text-sm font-semibold text-white mb-3">Response Time</h3>
            <p class="text-sm text-gray-400">Within 24 hours on weekdays. Usually much faster.</p>
          </div>

          <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/50">
            <h3 class="text-sm font-semibold text-white mb-3">What happens next?</h3>
            <div class="space-y-3">
              <div class="flex items-start gap-2">
                <span class="shrink-0 w-5 h-5 rounded-full bg-indigo-900/50 border border-indigo-500/40 flex items-center justify-center text-xs text-indigo-300 font-bold">1</span>
                <p class="text-xs text-gray-400">We read your message and assess fit</p>
              </div>
              <div class="flex items-start gap-2">
                <span class="shrink-0 w-5 h-5 rounded-full bg-indigo-900/50 border border-indigo-500/40 flex items-center justify-center text-xs text-indigo-300 font-bold">2</span>
                <p class="text-xs text-gray-400">15-minute call to discuss requirements</p>
              </div>
              <div class="flex items-start gap-2">
                <span class="shrink-0 w-5 h-5 rounded-full bg-indigo-900/50 border border-indigo-500/40 flex items-center justify-center text-xs text-indigo-300 font-bold">3</span>
                <p class="text-xs text-gray-400">Written proposal with timeline & cost</p>
              </div>
              <div class="flex items-start gap-2">
                <span class="shrink-0 w-5 h-5 rounded-full bg-indigo-900/50 border border-indigo-500/40 flex items-center justify-center text-xs text-indigo-300 font-bold">4</span>
                <p class="text-xs text-gray-400">If you say go — we start within a week</p>
              </div>
            </div>
          </div>

          <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/50">
            <h3 class="text-sm font-semibold text-white mb-3">Company</h3>
            <p class="text-xs text-gray-400">xSoft Ltd</p>
            <p class="text-xs text-gray-400">Company No. 17308915</p>
            <p class="text-xs text-gray-400">England & Wales</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script is:inline>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const data = new FormData(form);
      const payload = {
        name: data.get('name'),
        email: data.get('email'),
        phone: data.get('phone'),
        service: data.get('service'),
        timeline: data.get('timeline'),
        message: data.get('message'),
      };

      try {
        const res = await fetch('/api/contact/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          document.getElementById('form-success')?.classList.remove('hidden');
          form.reset();
        } else {
          const err = await res.json();
          alert(err.error || 'Something went wrong. Please try again.');
        }
      } catch {
        alert('Network error. Please email info@xsoftlimited.com directly.');
      } finally {
        btn.textContent = originalText;
        btn.disabled = false;
      }
    });
  </script>

  <!-- Calendly widget script -->
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

</Layout>
