---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="Services — xSoft Ltd | AI Chatbots, Web Dev, Extensions, SEO" description="Full-stack software services: AI chatbots with RAG, high-performance web apps, Chrome extensions, and technical SEO. Enterprise infrastructure, startup speed." keywords="AI chatbot development, web development, Chrome extension, SEO consultancy, Cloudflare Workers, RAG">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "provider": { "@type": "Organization", "name": "xSoft Ltd", "url": "https://www.xsoftlimited.com" },
    "serviceType": "Software Development",
    "areaServed": "Worldwide",
    "description": "AI chatbot development, web applications, Chrome extensions, and SEO services."
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an AI chatbot cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our standard rate is £1,000 per week of development. A typical AI chatbot project takes 2-4 weeks, so the total cost ranges from £2,000 to £4,000. This includes training, deployment, testing, and 30 days of post-launch support." }},
      { "@type": "Question", "name": "How long does it take to build a website?", "acceptedAnswer": { "@type": "Answer", "text": "Most websites ship within 2-4 weeks. Complex platforms with multiple integrations may take 6-8 weeks. You see working progress every week via staging demos." }},
      { "@type": "Question", "name": "What technology stack do you use?", "acceptedAnswer": { "@type": "Answer", "text": "We build on Cloudflare Workers (edge computing), Astro (web framework), D1 (database), KV (caching), Workers AI (machine learning), Vectorize (RAG/semantic search), and Tailwind CSS. This stack delivers sub-100ms response times globally." }},
      { "@type": "Question", "name": "Do you offer ongoing support after launch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every project includes 30 days of free post-launch support. After that, we offer an optional retainer at £100/month for ongoing maintenance, priority bug fixes, and minor changes." }},
      { "@type": "Question", "name": "Can you build Chrome extensions?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build Manifest V3 Chrome extensions with full Chrome Web Store submission support, including screenshots, descriptions, privacy policy compliance, and analytics integration." }}
    ]
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Our Services</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">Everything you need to go digital</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">From AI chatbots that answer your customers at 3am, to websites that load in under a second — we build the tech, you grow the business.</p>
    </div>
  </section>

  <!-- AI Chatbots -->
  <section id="ai-chatbots" class="py-12 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0">
              <span class="text-xl">🤖</span>
            </div>
            <h2 class="text-3xl font-bold text-white">AI Chatbots</h2>
          </div>
          <p class="mt-4 text-gray-400 leading-relaxed">Custom AI assistants trained on your business data. They answer customer questions accurately, 24 hours a day, 365 days a year — without you lifting a finger.</p>

          <div class="mt-8 space-y-4">
            <div class="p-4 rounded-xl border border-indigo-500/20 bg-indigo-950/10">
              <p class="text-sm text-gray-300"><span class="text-indigo-400 font-semibold">RAG-powered accuracy:</span> Your chatbot answers from your actual documents, FAQs, and product info — not hallucinated nonsense.</p>
            </div>
            <div class="p-4 rounded-xl border border-indigo-500/20 bg-indigo-950/10">
              <p class="text-sm text-gray-300"><span class="text-indigo-400 font-semibold">Vector embeddings & semantic search:</span> Your content is embedded into a vector database (Cloudflare Vectorize). Users ask natural-language questions and the AI finds contextually relevant answers — not just keyword matches.</p>
            </div>
            <div class="p-4 rounded-xl border border-indigo-500/20 bg-indigo-950/10">
              <p class="text-sm text-gray-300"><span class="text-indigo-400 font-semibold">Edge deployment:</span> Responses in under 200ms worldwide via Cloudflare's global network. No cold starts.</p>
            </div>
            <div class="p-4 rounded-xl border border-indigo-500/20 bg-indigo-950/10">
              <p class="text-sm text-gray-300"><span class="text-indigo-400 font-semibold">Human handoff:</span> When the conversation needs a real person, the bot seamlessly transfers with full context.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-xs text-gray-500 uppercase tracking-wider mb-4">Pricing</p>
          <p class="text-sm text-white">£1,000<span class="text-gray-400 font-normal">/week</span></p>
          <p class="mt-2 text-sm text-gray-400">Typical project: 2–4 weeks. Includes training, deployment, and testing.</p>
          <div class="mt-6 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500 mb-3">What's included:</p>
            <ul class="space-y-2 text-sm text-gray-300">
              <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Custom AI model configuration</li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Knowledge base ingestion (your docs/FAQs)</li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Website widget integration</li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Admin dashboard for conversations</li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> 30 days post-launch support</li>
            </ul>
          </div>
          <a href="/contact/" class="mt-6 block text-center px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">Get Started →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Web Development -->
  <section id="web-development" class="py-12 border-t border-gray-800/50 bg-gray-900/20 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-xs text-gray-500 uppercase tracking-wider mb-4">Tech Stack</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="p-3 rounded-lg border border-gray-700 text-center">
              <p class="text-sm font-semibold text-white">Astro</p>
              <p class="text-xs text-gray-400">Framework</p>
            </div>
            <div class="p-3 rounded-lg border border-gray-700 text-center">
              <p class="text-sm font-semibold text-white">Cloudflare</p>
              <p class="text-xs text-gray-400">Hosting</p>
            </div>
            <div class="p-3 rounded-lg border border-gray-700 text-center">
              <p class="text-sm font-semibold text-white">D1 + KV</p>
              <p class="text-xs text-gray-400">Database</p>
            </div>
            <div class="p-3 rounded-lg border border-gray-700 text-center">
              <p class="text-sm font-semibold text-white">Tailwind</p>
              <p class="text-xs text-gray-400">Styling</p>
            </div>
          </div>
          <div class="mt-6 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500 mb-3">Live examples:</p>
            <ul class="space-y-2 text-sm">
              <li><a href="https://www.scrabblewordsfinder.com/" target="_blank" rel="noopener" class="text-blue-400 hover:underline">ScrabbleWordsFinder.com</a> — 1000+ pages, AI chat, games</li>
              <li><a href="https://www.xconvert24.com/" target="_blank" rel="noopener" class="text-blue-400 hover:underline">xConvert24.com</a> — 60+ tools and converters</li>
            </ul>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0">
              <span class="text-xl">🌐</span>
            </div>
            <h2 class="text-3xl font-bold text-white">Web Development</h2>
          </div>
          <p class="mt-4 text-gray-400 leading-relaxed">High-performance websites and web applications. Server-side rendered for SEO, edge-deployed for speed, designed for conversion.</p>

          <div class="mt-8 space-y-4">
            <div class="p-4 rounded-xl border border-blue-500/20 bg-blue-950/10">
              <p class="text-sm text-gray-300"><span class="text-blue-400 font-semibold">Sub-100ms TTFB:</span> Your site loads before the competition's even starts. Edge computing means every visitor gets a fast experience.</p>
            </div>
            <div class="p-4 rounded-xl border border-blue-500/20 bg-blue-950/10">
              <p class="text-sm text-gray-300"><span class="text-blue-400 font-semibold">SEO-first architecture:</span> Structured data, semantic HTML, optimized meta tags, and automated sitemaps from day one.</p>
            </div>
            <div class="p-4 rounded-xl border border-blue-500/20 bg-blue-950/10">
              <p class="text-sm text-gray-300"><span class="text-blue-400 font-semibold">Admin included:</span> Every site comes with a custom admin dashboard — manage content, view analytics, handle emails.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chrome Extensions -->
  <section id="chrome-extensions" class="py-12 border-t border-gray-800/50 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center shrink-0">
              <span class="text-xl">🧩</span>
            </div>
            <h2 class="text-3xl font-bold text-white">Chrome Extensions</h2>
          </div>
          <p class="mt-4 text-gray-400 leading-relaxed">Browser extensions that solve real problems. From automation tools to productivity enhancers — built, tested, and published on the Chrome Web Store.</p>

          <div class="mt-8 space-y-4">
            <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
              <p class="text-sm text-gray-300"><span class="text-cyan-400 font-semibold">Manifest V3:</span> Built on the latest Chrome extension platform for security, performance, and future-proofing.</p>
            </div>
            <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
              <p class="text-sm text-gray-300"><span class="text-cyan-400 font-semibold">Store publishing:</span> We handle the entire submission process — screenshots, descriptions, privacy policy, review compliance.</p>
            </div>
            <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
              <p class="text-sm text-gray-300"><span class="text-cyan-400 font-semibold">Analytics included:</span> Track installs, active users, and engagement with GA4 Measurement Protocol integration.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-xs text-gray-500 uppercase tracking-wider mb-4">Capabilities</p>
          <div class="space-y-3">
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700">
              <span class="text-cyan-400">⚡</span>
              <span class="text-sm text-gray-300">DOM manipulation & automation</span>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700">
              <span class="text-cyan-400">💾</span>
              <span class="text-sm text-gray-300">Local storage & sync across devices</span>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700">
              <span class="text-cyan-400">🔔</span>
              <span class="text-sm text-gray-300">Notifications & scheduled tasks</span>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700">
              <span class="text-cyan-400">🌐</span>
              <span class="text-sm text-gray-300">API integrations & web requests</span>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700">
              <span class="text-cyan-400">🎨</span>
              <span class="text-sm text-gray-300">Custom popup & options UI</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO -->
  <section id="seo" class="py-12 border-t border-gray-800/50 bg-gray-900/20 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
            <span class="text-xl">📈</span>
          </div>
          <h2 class="text-3xl font-bold text-white">SEO & Content Strategy</h2>
        </div>
        <p class="mt-4 text-gray-400 max-w-2xl mx-auto">Technical SEO audits, structured data, AI-powered content generation at scale, and indexing strategies that get your pages ranking. We don't just optimise — we build entire content ecosystems that compound over time.</p>
      </div>

      <!-- Results callout -->
      <div class="mb-10 p-5 rounded-xl border border-emerald-500/30 bg-emerald-950/20">
        <p class="text-sm font-semibold text-emerald-400 uppercase tracking-wider mb-2">📊 Proven Results</p>
        <p class="text-sm text-gray-300">On ScrabbleWordsFinder.com, we grew from 0 to <span class="text-white font-medium">744 indexed pages</span> within 8 weeks of launch — across 15+ content categories with automated quality scoring, E-E-A-T signals, and topical cluster architecture. Every page includes structured data, internal cross-links, and author attribution.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Technical SEO</p>
          <p class="text-xs text-gray-400">Core Web Vitals optimisation, structured data (JSON-LD), canonical URLs, XML sitemaps, robots.txt, crawl budget management, and mobile-first indexing compliance.</p>
        </div>
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Content at Scale</p>
          <p class="text-xs text-gray-400">AI-assisted content generation with human editorial oversight. We've deployed 1000+ SEO-optimized pages on a single site — each with unique content, visual blocks, and FAQ schemas.</p>
        </div>
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Index Monitoring</p>
          <p class="text-xs text-gray-400">Google Search Console integration, automated index status tracking, bulk re-submission workflows, and daily crawl error monitoring with alerting.</p>
        </div>
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Rich Snippets</p>
          <p class="text-xs text-gray-400">FAQPage, HowTo, Article, Organization, BreadcrumbList, and WebApplication schemas. Tested with Google's Rich Results validator before deploy.</p>
        </div>
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Topical Clusters</p>
          <p class="text-xs text-gray-400">Category landing pages, internal cross-linking automation, pillar content strategy, and inbound link injection between related articles to boost authority.</p>
        </div>
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-2">Edge Performance</p>
          <p class="text-xs text-gray-400">TTFB under 100ms globally via Cloudflare edge, Brotli compression, lazy loading, preconnect hints, and aggressive caching for maximum PageSpeed scores.</p>
        </div>
      </div>

      <!-- Additional content: what's included -->
      <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="p-5 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-3">What an SEO engagement looks like:</p>
          <div class="space-y-2 text-xs text-gray-400">
            <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5 shrink-0">1.</span> <span>Full technical audit — crawl errors, broken links, missing schemas, speed issues</span></div>
            <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5 shrink-0">2.</span> <span>Keyword research & content gap analysis against competitors</span></div>
            <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5 shrink-0">3.</span> <span>Content architecture plan — categories, clusters, internal linking map</span></div>
            <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5 shrink-0">4.</span> <span>Implementation — structured data, meta tags, sitemaps, content generation</span></div>
            <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5 shrink-0">5.</span> <span>Monitoring — weekly index checks, GSC integration, ranking tracking</span></div>
          </div>
        </div>
        <div class="p-5 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-3">Tools & techniques we use:</p>
          <div class="flex flex-wrap gap-2 text-xs">
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">Google Search Console</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">JSON-LD Schemas</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">Automated Sitemaps</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">Python Scripts</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">Playwright Audits</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">AI Content Gen</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">Cloudflare Analytics</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">PageSpeed Insights</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">E-E-A-T Signals</span>
            <span class="px-2 py-1 rounded bg-gray-700 text-gray-300">llms.txt</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Delivery -->
  <section class="py-12 border-t border-gray-800/50 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center shrink-0">
          <span class="text-xl">🚀</span>
        </div>
        <h2 class="text-3xl font-bold text-white">Delivery</h2>
      </div>
      <p class="text-gray-400 leading-relaxed mb-8">Once the project is specced out and agreed, we follow clearly defined milestones. You'll know exactly what's being built, when it'll be ready, and what each milestone delivers.</p>

      <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
        <div class="p-4 rounded-xl border border-purple-500/20 bg-purple-950/10 text-center min-w-[140px]">
          <p class="text-2xl font-bold text-purple-400">Spec</p>
          <p class="text-xs text-gray-400 mt-1">Requirements & scope agreed</p>
        </div>
        <span class="text-emerald-400 text-2xl font-bold hidden sm:block">→</span>
        <div class="p-4 rounded-xl border border-purple-500/20 bg-purple-950/10 text-center min-w-[140px]">
          <p class="text-2xl font-bold text-purple-400">Build</p>
          <p class="text-xs text-gray-400 mt-1">Development against milestones</p>
        </div>
        <span class="text-emerald-400 text-2xl font-bold hidden sm:block">→</span>
        <div class="p-4 rounded-xl border border-purple-500/20 bg-purple-950/10 text-center min-w-[140px]">
          <p class="text-2xl font-bold text-purple-400">QA</p>
          <p class="text-xs text-gray-400 mt-1">Testing & quality sign-off</p>
        </div>
        <span class="text-emerald-400 text-2xl font-bold hidden sm:block">→</span>
        <div class="p-4 rounded-xl border border-purple-500/20 bg-purple-950/10 text-center min-w-[140px]">
          <p class="text-2xl font-bold text-purple-400">Handover</p>
          <p class="text-xs text-gray-400 mt-1">Launch, docs & support begins</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">Weekly demos</p>
          <p class="text-xs text-gray-400">Every Friday you see what's been built. Feedback gets incorporated the following week.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">Staging environment</p>
          <p class="text-xs text-gray-400">A live preview URL from day one. Test on real devices before anything goes to production.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">Documentation included</p>
          <p class="text-xs text-gray-400">Every project ships with admin guides, API docs, and architecture notes. No knowledge lock-in.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">30 days post-launch support</p>
          <p class="text-xs text-gray-400">Bug fixes and minor tweaks covered for a full month after delivery. No extra charge.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-12 border-t border-gray-800/50 bg-gray-900/20 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center shrink-0">
          <span class="text-xl">💷</span>
        </div>
        <h2 class="text-3xl font-bold text-white">Pricing</h2>
      </div>
      <p class="text-gray-400 leading-relaxed mb-8">Simple, transparent pricing. For a standard project of 2–4 weeks, we charge £1,000 per week of development. Once the project is signed off for quality and handed over, the first 30 days of support are free — then you can opt for a retainer at £100/month for ongoing maintenance.</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
        <div class="p-6 rounded-2xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm uppercase tracking-wider mb-2">Development</p>
          <p class="text-2xl font-bold text-white">£1,000<span class="text-sm text-gray-400 font-normal">/week</span></p>
          <p class="text-xs text-gray-400 mt-2">Full-time focus on your project. Design, development, testing, and deployment included.</p>
        </div>
        <div class="p-6 rounded-2xl border border-emerald-500/30 bg-emerald-950/10">
