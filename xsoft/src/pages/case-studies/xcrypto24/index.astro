---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
export const prerender = true;
---

<Layout title="Case Study: xCrypto24 — Real-Time Cryptocurrency Platform | xSoft Ltd" description="How we built a crypto tracking platform with live prices, bubble charts, portfolio tools, and top 100 coin data on Cloudflare." keywords="xCrypto24, cryptocurrency tracker, crypto bubble chart, real-time prices, Cloudflare Workers, case study">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Case Study: xCrypto24 — Real-Time Cryptocurrency Tracking Platform",
    "description": "How xSoft built a real-time crypto tracking platform with live data, charts, and portfolio tools.",
    "datePublished": "2026-07-15",
    "author": { "@type": "Organization", "name": "xSoft Ltd", "url": "https://www.xsoftlimited.com" },
    "publisher": { "@type": "Organization", "name": "xSoft Ltd", "logo": { "@type": "ImageObject", "url": "https://www.xsoftlimited.com/social-card.svg" } }
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50 bg-gradient-to-b from-emerald-950/10 to-transparent">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
        <a href="/case-studies/" class="hover:text-indigo-400 transition-colors">← Case Studies</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">xCrypto24</span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Real-time Data</span>
        <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Crypto</span>
        <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Charts</span>
        <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Portfolio</span>
      </div>

      <h1 class="animate-fade-in-up text-3xl sm:text-4xl lg:text-5xl font-black text-white">xCrypto24.com <span class="ml-2 px-3 py-1 rounded-lg text-sm bg-orange-500/20 text-orange-400 border border-orange-500/30 align-middle font-semibold">Beta</span></h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl leading-relaxed">
        A real-time cryptocurrency tracking and analytics platform featuring live price feeds, interactive bubble charts, portfolio management, market heatmaps, and detailed coin data for the top 100 cryptocurrencies.
      </p>

      <div class="animate-fade-in-delay-2 mt-6">
        <a href="https://www.xconvert24.com/tools/crypto-coins/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold transition-all">
          View Live Platform ↗
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-gray-800/50 bg-gray-900/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl font-black text-emerald-400">100+</p>
          <p class="text-xs text-gray-400 mt-1">Coins Tracked</p>
        </div>
        <div>
          <p class="text-2xl font-black text-emerald-400">Live</p>
          <p class="text-xs text-gray-400 mt-1">Price Feeds</p>
        </div>
        <div>
          <p class="text-2xl font-black text-emerald-400">5s</p>
          <p class="text-xs text-gray-400 mt-1">Refresh Rate</p>
        </div>
        <div>
          <p class="text-2xl font-black text-emerald-400">Global</p>
          <p class="text-xs text-gray-400 mt-1">Edge Deployed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <h2 class="text-xl font-light text-emerald-500 mt-10 mb-4 border-l-4 border-emerald-400 pl-4">The Challenge</h2>
      <p class="text-gray-300 leading-relaxed mb-4">Build a cryptocurrency data platform that provides real-time market information in an engaging visual format — without requiring API keys from users, maintaining fast load times despite constantly-updating data, and offering portfolio tracking that works entirely client-side with no sign-up friction.</p>

      <!-- Features -->
      <h2 class="text-xl font-light text-emerald-500 mt-14 mb-4 border-l-4 border-emerald-400 pl-4">Core Features</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-1">📊 Top 100 Coins Table</p>
          <p class="text-xs text-gray-400">Real-time prices, 24h change, market cap, volume, and sparkline charts for the top 100 cryptocurrencies by market capitalization.</p>
        </div>
        <div class="p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-1">🫧 Crypto Bubbles</p>
          <p class="text-xs text-gray-400">Interactive bubble chart visualization where size represents market cap and color represents 24h price movement. Hover for details.</p>
        </div>
        <div class="p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-1">💼 Portfolio Tracker</p>
          <p class="text-xs text-gray-400">Add holdings, track P&L in real-time. All data stored in localStorage — zero sign-up, zero data sent to servers.</p>
        </div>
        <div class="p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
          <p class="text-emerald-400 font-semibold text-sm mb-1">🔥 Market Heatmap</p>
          <p class="text-xs text-gray-400">Visual heatmap showing gainers and losers at a glance. Color intensity maps to percentage change magnitude.</p>
        </div>
      </div>

      <!-- Architecture -->
      <h2 class="text-xl font-light text-emerald-500 mt-14 mb-4 border-l-4 border-emerald-400 pl-4">Architecture</h2>

      <div class="my-6 p-5 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
        <p class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-2">💡 Data Flow</p>
        <p class="text-sm text-gray-300 leading-relaxed">Price data is fetched server-side via Cloudflare Workers, cached in KV with a 30-second TTL, and served to clients as pre-rendered HTML with hydration for real-time updates. This architecture ensures fast initial loads (data is in the HTML) while still providing live updates via client-side polling every 5 seconds.</p>
      </div>

      <div class="my-8 p-5 rounded-xl border border-purple-500/30 bg-purple-950/10">
        <p class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-3">🧩 Technical Decisions</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">1</span>
            <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Server-side data fetch:</span> Avoids CORS issues and keeps API keys secure. Users never see raw API calls.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">2</span>
            <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">KV caching layer:</span> 30-second TTL prevents API rate limiting while keeping data fresh enough for casual tracking.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">3</span>
            <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Client-side portfolio:</span> localStorage-only means zero privacy concerns, instant access, and no backend complexity for user data.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">4</span>
            <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">CSS-only charts:</span> Bubble charts and heatmaps rendered with pure CSS/SVG — no heavy charting libraries bloating the bundle.</p>
          </div>
        </div>
      </div>

      <!-- Data Sources -->
      <h2 class="text-xl font-light text-emerald-500 mt-14 mb-4 border-l-4 border-emerald-400 pl-4">Data & APIs</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📡 Price Data</p>
          <p class="text-xs text-gray-400">CoinGecko API for real-time prices, market cap, volume, and historical data.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📈 Sparklines</p>
          <p class="text-xs text-gray-400">7-day price history rendered as inline SVG sparklines in the coin table.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">🌐 Global Stats</p>
          <p class="text-xs text-gray-400">Total market cap, 24h volume, BTC dominance, and active cryptocurrencies count.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">💱 Currency Support</p>
          <p class="text-xs text-gray-400">Display prices in USD, GBP, EUR, and other fiat currencies.</p>
        </div>
      </div>

      <!-- Tech Stack -->
      <h2 class="text-xl font-light text-emerald-500 mt-14 mb-4 border-l-4 border-emerald-400 pl-4">Technology Stack</h2>
      <div class="my-6 flex flex-wrap gap-3">
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Astro 6.x</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Cloudflare Workers</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">KV Store</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">CoinGecko API</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Tailwind CSS 4</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">TypeScript</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">SVG Charts</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">localStorage</span>
      </div>

      <!-- Links -->
      <h2 class="text-xl font-light text-emerald-500 mt-14 mb-4 border-l-4 border-emerald-400 pl-4">Explore</h2>
      <div class="my-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="https://www.xconvert24.com/tools/crypto-coins/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-emerald-500/50 hover:bg-emerald-950/10 transition-all group">
          <span class="text-emerald-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-emerald-400">Top 100 Crypto Coins</span>
        </a>
        <a href="https://www.xconvert24.com/tools/crypto-bubbles/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-emerald-500/50 hover:bg-emerald-950/10 transition-all group">
          <span class="text-emerald-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-emerald-400">Crypto Bubbles Chart</span>
        </a>
      </div>

      <!-- CTA -->
      <div class="mt-16 p-6 rounded-2xl bg-gradient-to-r from-indigo-950/30 to-blue-950/20 border border-indigo-500/30 text-center">
        <h3 class="text-xl font-bold text-white">Need a real-time data platform?</h3>
        <p class="mt-2 text-sm text-gray-400">We build live data dashboards, API integrations, and interactive visualizations.</p>
        <a href="/contact/" class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">
          Start a Conversation →
        </a>
      </div>

    </div>
  </section>

</Layout>
