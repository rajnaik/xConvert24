---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
export const prerender = true;
---

<Layout title="Case Study: ScrabbleWordsFinder — AI Word Game Platform | xSoft Ltd" description="How we built a full-stack Scrabble platform with AI chatbot, 1000+ pages, 6 games, world rankings, and daily challenges. Cloudflare Workers, D1, Vectorize." keywords="ScrabbleWordsFinder, AI chatbot case study, Cloudflare Workers, word game platform, RAG chatbot, SEO at scale">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Case Study: ScrabbleWordsFinder — AI-Powered Word Game Platform",
    "description": "How xSoft built a full-stack Scrabble platform with AI chatbot, 1000+ pages, 6 games, and world rankings.",
    "datePublished": "2026-07-15",
    "author": { "@type": "Organization", "name": "xSoft Ltd", "url": "https://www.xsoftlimited.com" },
    "publisher": { "@type": "Organization", "name": "xSoft Ltd", "logo": { "@type": "ImageObject", "url": "https://www.xsoftlimited.com/social-card.svg" } }
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50 bg-gradient-to-b from-amber-950/10 to-transparent">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
        <a href="/case-studies/" class="hover:text-indigo-400 transition-colors">← Case Studies</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">ScrabbleWordsFinder</span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">AI Chatbot</span>
        <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">Full-Stack</span>
        <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">1000+ Pages</span>
        <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">Games</span>
        <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">SEO</span>
      </div>

      <h1 class="animate-fade-in-up text-3xl sm:text-4xl lg:text-5xl font-black text-white">ScrabbleWordsFinder.com</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl leading-relaxed">
        A comprehensive word game platform featuring an AI coaching chatbot, real-time word solver, interactive games, world rankings, and over 1,000 SEO-optimized pages — all built on Cloudflare's edge infrastructure.
      </p>

      <div class="animate-fade-in-delay-2 mt-6">
        <a href="https://www.scrabblewordsfinder.com/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-amber-600 hover:bg-amber-500 text-white text-sm font-semibold transition-all">
          Visit Live Site ↗
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-gray-800/50 bg-gray-900/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl font-black text-amber-400">1,000+</p>
          <p class="text-xs text-gray-400 mt-1">Blog Pages</p>
        </div>
        <div>
          <p class="text-2xl font-black text-amber-400">6</p>
          <p class="text-xs text-gray-400 mt-1">Interactive Games</p>
        </div>
        <div>
          <p class="text-2xl font-black text-amber-400">130+</p>
          <p class="text-xs text-gray-400 mt-1">Ranked Players</p>
        </div>
        <div>
          <p class="text-2xl font-black text-amber-400">&lt;150ms</p>
          <p class="text-xs text-gray-400 mt-1">Avg Response</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- The Challenge -->
      <h2 class="text-xl font-light text-amber-600 mt-10 mb-4 border-l-4 border-amber-400 pl-4">The Challenge</h2>
      <p class="text-gray-300 leading-relaxed mb-4">Build a word game platform that could compete with established tools like WordFinder and Collins Dictionary — but differentiated through AI coaching, interactive games, and deep competitive Scrabble content. The site needed to:</p>
      <div class="my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">⚡ Real-time solving</p>
          <p class="text-xs text-gray-400">Solve any rack against 280,000+ words in under 100ms with live results as you type.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">🤖 AI coaching</p>
          <p class="text-xs text-gray-400">An AI chatbot that could answer Scrabble strategy questions using actual game knowledge.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">📈 SEO at scale</p>
          <p class="text-xs text-gray-400">1,000+ unique content pages targeting long-tail keywords across dozens of categories.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">🎮 Engagement</p>
          <p class="text-xs text-gray-400">Daily challenges, multiplayer-ready games, and a progression system to keep users returning.</p>
        </div>
      </div>

      <!-- The Solution -->
      <h2 class="text-xl font-light text-amber-600 mt-14 mb-4 border-l-4 border-amber-400 pl-4">What We Built</h2>

      <!-- AI Chatbot -->
      <div class="my-8 p-6 rounded-2xl border-2 border-indigo-500/30 bg-gradient-to-r from-indigo-950/20 to-blue-950/10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">🤖</span>
          <h3 class="text-lg font-semibold text-white">Lex — AI Scrabble Coach</h3>
        </div>
        <p class="text-sm text-gray-300 leading-relaxed mb-4">A RAG-powered chatbot that answers Scrabble strategy questions using the site's own blog content as its knowledge base. Built on Cloudflare Workers AI with Vectorize for semantic search.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Model</p>
            <p class="text-sm text-indigo-400 font-semibold">Llama 3 (8B)</p>
          </div>
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Knowledge Base</p>
            <p class="text-sm text-indigo-400 font-semibold">1000+ articles</p>
          </div>
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Vector Index</p>
            <p class="text-sm text-indigo-400 font-semibold">Vectorize RAG</p>
          </div>
        </div>
      </div>

      <!-- Word Solver -->
      <div class="my-8 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🔍 Real-Time Word Solver</p>
        <p class="text-sm text-gray-300 leading-relaxed">Client-side dictionary loading (SOWPODS + TWL06) with instant solving as you type. Displays Scrabble scores, tile probability, rack leave analysis, and best opening moves — all updating automatically with zero page reloads.</p>
      </div>

      <!-- Games -->
      <h3 class="text-lg font-semibold text-white mt-10 mb-4">Interactive Games</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 my-6">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">⏱️ 60-Second Challenge</p>
          <p class="text-xs text-gray-400">Find as many words as possible from a random rack in 60 seconds.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">🐄 Cows & Bulls</p>
          <p class="text-xs text-gray-400">Mastermind-style word deduction with coloured tile feedback.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">📅 Daily Rack</p>
          <p class="text-xs text-gray-400">Same rack for everyone, daily leaderboard competition.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">🔀 Daily Anagram</p>
          <p class="text-xs text-gray-400">Unscramble the word of the day with hints.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">🧠 Word Quiz</p>
          <p class="text-xs text-gray-400">Knowledge quiz with AI coaching feedback.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <p class="text-purple-400 font-semibold text-sm mb-1">💎 Diamond Hunt</p>
          <p class="text-xs text-gray-400">Find hidden diamonds across the site for badges.</p>
        </div>
      </div>

      <!-- World Rankings -->
      <div class="my-8 p-5 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
        <p class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-2">🏆 World Rankings Database</p>
        <p class="text-sm text-gray-300 leading-relaxed">A living database tracking 130+ competitive Scrabble players with monthly snapshots, rating changes, country statistics, and individual player profile pages. Includes tournament history for WSC, WESPAC, NSC, JWSC, WYSC, and World Cup events with linked champions tables.</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href="https://www.scrabblewordsfinder.com/world-rankings/" target="_blank" rel="noopener" class="text-xs text-cyan-400 hover:underline">World Rankings →</a>
          <a href="https://www.scrabblewordsfinder.com/blog/world-scrabble-championship/" target="_blank" rel="noopener" class="text-xs text-cyan-400 hover:underline">WSC History →</a>
          <a href="https://www.scrabblewordsfinder.com/blog/wespac-scrabble-championship/" target="_blank" rel="noopener" class="text-xs text-cyan-400 hover:underline">WESPAC →</a>
        </div>
      </div>

      <!-- Blog & SEO -->
      <h2 class="text-xl font-light text-amber-600 mt-14 mb-4 border-l-4 border-amber-400 pl-4">Content & SEO Strategy</h2>
      <p class="text-gray-300 leading-relaxed mb-6">Over 1,000 blog pages across 15+ categories — each with structured data (Article + FAQPage schemas), visual enhancement blocks, cross-linking, and E-E-A-T signals including author attribution and source citations.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">📚 Blog Categories</p>
          <ul class="text-xs text-gray-400 space-y-1 mt-2">
            <li>• <a href="https://www.scrabblewordsfinder.com/blog/beginner-guides/" target="_blank" rel="noopener" class="text-green-400 hover:underline">Beginner Guides</a> (10 posts)</li>
            <li>• <a href="https://www.scrabblewordsfinder.com/blog/two-letter-words/" target="_blank" rel="noopener" class="text-green-400 hover:underline">Two-Letter Words</a> (10 posts)</li>
            <li>• <a href="https://www.scrabblewordsfinder.com/blog/strategy/" target="_blank" rel="noopener" class="text-green-400 hover:underline">Strategy</a> (16 posts)</li>
            <li>• <a href="https://www.scrabblewordsfinder.com/blog/letter-guides/" target="_blank" rel="noopener" class="text-green-400 hover:underline">Letter Guides</a> (136 posts)</li>
            <li>• <a href="https://www.scrabblewordsfinder.com/blog/tournament/" target="_blank" rel="noopener" class="text-green-400 hover:underline">Tournament</a> (13 posts)</li>
            <li>• And 10+ more categories...</li>
          </ul>
        </div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">🔧 SEO Features</p>
          <ul class="text-xs text-gray-400 space-y-1 mt-2">
            <li>• JSON-LD Article + FAQPage on every post</li>
            <li>• Automated sitemap generation</li>
            <li>• Internal cross-linking engine</li>
            <li>• Category landing pages (topical clusters)</li>
            <li>• Google Search Console index tracking</li>
            <li>• AI-generated definitions & content</li>
          </ul>
        </div>
      </div>

      <!-- Daily Challenges -->
      <div class="my-8 p-5 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <p class="text-sm font-semibold text-amber-400 uppercase tracking-wider mb-2">📅 Daily Content Engine</p>
        <p class="text-sm text-gray-300 leading-relaxed">Three daily challenges seeded years in advance — <a href="https://www.scrabblewordsfinder.com/word-of-the-day/" target="_blank" rel="noopener" class="text-amber-400 hover:underline">Word of the Day</a>, <a href="https://www.scrabblewordsfinder.com/anagram/" target="_blank" rel="noopener" class="text-amber-400 hover:underline">Daily Anagram</a>, and <a href="https://www.scrabblewordsfinder.com/daily-rack/" target="_blank" rel="noopener" class="text-amber-400 hover:underline">Daily Rack Challenge</a>. Each includes definitions, fun facts, and scoring data. Gives users a reason to return every single day.</p>
      </div>

      <!-- Admin & Infrastructure -->
      <h2 class="text-xl font-light text-amber-600 mt-14 mb-4 border-l-4 border-amber-400 pl-4">Admin & Infrastructure</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">🔐 Google OAuth Admin</p>
          <p class="text-xs text-gray-400">Secure admin dashboard with role-based access, session management via KV store.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📊 Click Analytics</p>
          <p class="text-xs text-gray-400">20-field click tracking with real-time dashboard, sound alerts, and bubble chart visualization.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📡 Telemetry</p>
          <p class="text-xs text-gray-400">Endpoint health monitoring with history, auto-refresh, and response time warnings.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📧 Email System</p>
          <p class="text-xs text-gray-400">Contact/suggest forms with Cloudflare Email Routing, DB persistence, and admin CRUD.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">🖼️ Banner Rotation</p>
          <p class="text-xs text-gray-400">DB-driven banner management with toggle switches, click tracking, and SEO ad-words.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">🧪 Automated Testing</p>
          <p class="text-xs text-gray-400">Playwright test suite with sanitisation checks, email verification, and regression tests.</p>
        </div>
      </div>

      <!-- Tech Stack -->
      <h2 class="text-xl font-light text-amber-600 mt-14 mb-4 border-l-4 border-amber-400 pl-4">Technology Stack</h2>
      <div class="my-6 flex flex-wrap gap-3">
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Astro 6.x</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Cloudflare Workers</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">D1 (SQLite)</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">KV Store</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Workers AI</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Vectorize</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Tailwind CSS 4</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">TypeScript</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Playwright</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Email Routing</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Google OAuth</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Python (tooling)</span>
      </div>

      <!-- Links -->
      <h2 class="text-xl font-light text-amber-600 mt-14 mb-4 border-l-4 border-amber-400 pl-4">Explore the Platform</h2>
      <div class="my-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="https://www.scrabblewordsfinder.com/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Homepage & Word Solver</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/activities/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Games & Activities Hub</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/world-rankings/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">World Rankings</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/blog/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Blog (1000+ articles)</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/leaderboard/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Game Leaderboards</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/dictionary/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Dictionary Lookup</span>
        </a>
        <a href="https://www.scrabblewordsfinder.com/chat/" target="_blank" rel="noopener" class="flex items-center gap-2 p-3 rounded-lg border border-gray-700 hover:border-amber-500/50 hover:bg-amber-950/10 transition-all group">
          <span class="text-amber-400 group-hover:translate-x-0.5 transition-transform">→</span>
          <span class="text-sm text-gray-300 group-hover:text-amber-400">Lex AI Coach (Chat)</span>
        </a>
      </div>

      <!-- CTA -->
      <div class="mt-16 p-6 rounded-2xl bg-gradient-to-r from-indigo-950/30 to-blue-950/20 border border-indigo-500/30 text-center">
        <h3 class="text-xl font-bold text-white">Want something like this for your business?</h3>
        <p class="mt-2 text-sm text-gray-400">We can build you an AI chatbot, content platform, or full web application.</p>
        <a href="/contact/" class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">
          Get in Touch →
        </a>
      </div>

    </div>
  </section>

</Layout>
