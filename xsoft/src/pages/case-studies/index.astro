---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="Case Studies — xSoft Ltd | Real Projects, Real Results" description="See how we've built AI chatbots, 1000+ page websites, crypto platforms, and conversion tools. Live projects with measurable outcomes." keywords="case studies, portfolio, web development, AI chatbot, xSoft projects">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "xSoft Case Studies",
    "description": "Portfolio of software projects delivered by xSoft Ltd.",
    "url": "https://www.xsoftlimited.com/case-studies/",
    "publisher": { "@type": "Organization", "name": "xSoft Ltd" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What projects has xSoft delivered?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft has delivered ScrabbleWordsFinder.com (AI chatbot + 1000-page content platform), xConvert24.com (60+ utility tools with Chrome extension), and xCrypto24.com (real-time crypto tracking). Each is live and serving users daily." }},
      { "@type": "Question", "name": "Can I see xSoft's work live?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our case studies link to live, production websites. ScrabbleWordsFinder.com and xConvert24.com are fully operational — you can use them right now to see the quality of our work." }},
      { "@type": "Question", "name": "Does xSoft build projects from scratch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All projects in our portfolio were designed, built, and deployed from zero. We handle everything: architecture, development, testing, SEO, admin tools, and ongoing maintenance." }}
    ]
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Portfolio</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">Our Work</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Real products we've designed, built, and deployed. Each one is live, generating traffic, and serving real users every day.</p>
      <div class="mt-5 flex items-center justify-center gap-3">
        <a href="/tech-stack/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
          <span>⚙️</span> Tech Stack
        </a>
        <a href="/tools/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
          <span>🧰</span> Tools
        </a>
      </div>
    </div>
  </section>

  <!-- Case Studies Grid -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12">

        <!-- SWF -->
        <a href="/case-studies/scrabblewordsfinder/" class="group flex gap-6 p-8 rounded-2xl border border-gray-800 hover:border-amber-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex items-center justify-center rounded-lg w-32 h-32 overflow-hidden">
            <img src="/scrabblewordsfinder-logo.png" alt="ScrabbleWordsFinder" class="w-full h-full object-contain group-hover:scale-110 transition-transform" />
          </div>
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">AI Chatbot</span>
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">1000+ Pages</span>
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">6 Games</span>
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">World Rankings</span>
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">SEO</span>
            </div>
            <h2 class="text-2xl font-bold text-white group-hover:text-amber-400 transition-colors">ScrabbleWordsFinder.com</h2>
            <p class="mt-3 text-gray-400 leading-relaxed">A full-stack word game platform with an AI coaching chatbot, real-time word solver, 6 interactive games, world rankings database, daily challenges, and over 1,000 SEO-optimized blog pages.</p>
            <div class="mt-4 flex flex-wrap gap-4 text-sm">
              <div><span class="text-amber-400 font-bold">1,000+</span> <span class="text-gray-500">pages</span></div>
              <div><span class="text-amber-400 font-bold">6</span> <span class="text-gray-500">games</span></div>
              <div><span class="text-amber-400 font-bold">130+</span> <span class="text-gray-500">ranked players</span></div>
              <div><span class="text-amber-400 font-bold">AI</span> <span class="text-gray-500">RAG chatbot</span></div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Word Solver</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">60-Second Game</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Cows & Bulls</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Word Quiz</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Daily Rack</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Anagram</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Leaderboards</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Dictionary</span>
            </div>
            <p class="mt-4 text-sm text-indigo-400 font-medium group-hover:translate-x-1 transition-transform">Read full case study →</p>
          </div>
        </a>

        <!-- xConvert24 -->
        <a href="/case-studies/xconvert24/" class="group flex gap-6 p-8 rounded-2xl border border-gray-800 hover:border-blue-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex items-center justify-center rounded-lg w-32 h-32 overflow-hidden">
            <img src="/xconvert24-logo.svg" alt="xConvert24" class="w-full h-full object-contain group-hover:scale-110 transition-transform" />
          </div>
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">60+ Tools</span>
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">SSR</span>
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Chrome Extension</span>
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Real-time</span>
            </div>
            <h2 class="text-2xl font-bold text-white group-hover:text-blue-400 transition-colors">xConvert24.com</h2>
            <p class="mt-3 text-gray-400 leading-relaxed">A comprehensive utility platform featuring 30+ unit converters, 30+ specialized tools, real-time currency data, a published Chrome extension, and instant calculations with zero page reloads.</p>
            <div class="mt-4 flex flex-wrap gap-4 text-sm">
              <div><span class="text-blue-400 font-bold">30+</span> <span class="text-gray-500">converters</span></div>
              <div><span class="text-blue-400 font-bold">30+</span> <span class="text-gray-500">tools</span></div>
              <div><span class="text-blue-400 font-bold">&lt;100ms</span> <span class="text-gray-500">TTFB</span></div>
              <div><span class="text-blue-400 font-bold">Live</span> <span class="text-gray-500">currency rates</span></div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Currency</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Length</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Temperature</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Calculator</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Image Editor</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Color Picker</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Password Gen</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">World Clock</span>
            </div>
            <p class="mt-4 text-sm text-indigo-400 font-medium group-hover:translate-x-1 transition-transform">Read full case study →</p>
          </div>
        </a>

        <!-- xCrypto24 -->
        <a href="/case-studies/xcrypto24/" class="group flex gap-6 p-8 rounded-2xl border border-gray-800 hover:border-orange-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex items-center justify-center rounded-lg w-32 h-32 overflow-hidden">
            <img src="/xcrypto24-logo.svg" alt="xCrypto24" class="w-full h-full object-contain group-hover:scale-110 transition-transform" />
          </div>
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Real-time</span>
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Crypto</span>
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">API</span>
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Charts</span>
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Portfolio</span>
            </div>
            <h2 class="text-2xl font-bold text-white group-hover:text-orange-400 transition-colors">xCrypto24.com <span class="ml-2 px-2 py-0.5 rounded text-xs bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 align-middle">Beta</span></h2>
            <p class="mt-3 text-gray-400 leading-relaxed">A cryptocurrency tracking and analytics platform with real-time price feeds, interactive bubble charts, portfolio management tools, and market data for the top 100 coins.</p>
            <div class="mt-4 flex flex-wrap gap-4 text-sm">
              <div><span class="text-orange-400 font-bold">100+</span> <span class="text-gray-500">coins tracked</span></div>
              <div><span class="text-orange-400 font-bold">Live</span> <span class="text-gray-500">price feeds</span></div>
              <div><span class="text-orange-400 font-bold">Charts</span> <span class="text-gray-500">& bubbles</span></div>
              <div><span class="text-orange-400 font-bold">Edge</span> <span class="text-gray-500">deployed</span></div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Top 100 Coins</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Bubble Chart</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Portfolio</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Heatmap</span>
              <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">Sparklines</span>
            </div>
            <p class="mt-4 text-sm text-indigo-400 font-medium group-hover:translate-x-1 transition-transform">Read full case study →</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-gray-800/50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white">Want to be our next case study?</h2>
      <p class="mt-3 text-gray-400">We'd love to build something great for your business too.</p>
      <a href="/contact/" class="mt-6 inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all hover:shadow-xl hover:shadow-indigo-500/25">
        Start a Project →
      </a>
    </div>
  </section>

</Layout>
