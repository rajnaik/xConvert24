---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
export const prerender = true;
---

<Layout title="Case Study: xConvert24 — 60+ Tools & Converters Platform | xSoft Ltd" description="How we built a comprehensive utility platform with 30+ converters, 30+ tools, admin analytics, and Chrome extension. Astro + Cloudflare Workers." keywords="xConvert24, unit converter, web tools platform, Cloudflare Workers, case study">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Case Study: xConvert24 — Utility Tools & Converters Platform",
    "description": "How xSoft built a comprehensive platform with 60+ tools and converters on Cloudflare Workers.",
    "datePublished": "2026-07-15",
    "author": { "@type": "Organization", "name": "xSoft Ltd", "url": "https://www.xsoftlimited.com" },
    "publisher": { "@type": "Organization", "name": "xSoft Ltd", "logo": { "@type": "ImageObject", "url": "https://www.xsoftlimited.com/social-card.svg" } }
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50 bg-gradient-to-b from-blue-950/10 to-transparent">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
        <a href="/case-studies/" class="hover:text-indigo-400 transition-colors">← Case Studies</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">xConvert24</span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">60+ Tools</span>
        <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">SSR</span>
        <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Admin Dashboard</span>
        <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Chrome Extension</span>
      </div>

      <h1 class="animate-fade-in-up text-3xl sm:text-4xl lg:text-5xl font-black text-white">xConvert24.com</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl leading-relaxed">
        A comprehensive utility platform with 30+ unit converters, 30+ specialized tools, real-time currency data, admin analytics, and a companion Chrome extension — all running on Cloudflare's global edge network.
      </p>

      <div class="animate-fade-in-delay-2 mt-6">
        <a href="https://www.xconvert24.com/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold transition-all">
          Visit Live Site ↗
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-gray-800/50 bg-gray-900/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl font-black text-blue-400">30+</p>
          <p class="text-xs text-gray-400 mt-1">Converters</p>
        </div>
        <div>
          <p class="text-2xl font-black text-blue-400">30+</p>
          <p class="text-xs text-gray-400 mt-1">Tools</p>
        </div>
        <div>
          <p class="text-2xl font-black text-blue-400">&lt;80ms</p>
          <p class="text-xs text-gray-400 mt-1">TTFB</p>
        </div>
        <div>
          <p class="text-2xl font-black text-blue-400">3</p>
          <p class="text-xs text-gray-400 mt-1">Environments</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <h2 class="text-xl font-light text-blue-500 mt-10 mb-4 border-l-4 border-blue-400 pl-4">The Challenge</h2>
      <p class="text-gray-300 leading-relaxed mb-4">Create a utility website that offers genuinely useful conversion and calculation tools — fast, free, no sign-up required — while building a platform extensible enough to add new tools rapidly and generate SEO traffic from long-tail queries.</p>

      <!-- Converters -->
      <h2 class="text-xl font-light text-blue-500 mt-14 mb-4 border-l-4 border-blue-400 pl-4">Unit Converters (25+)</h2>
      <p class="text-gray-300 leading-relaxed mb-6">Every converter features real-time calculation as you type, bidirectional conversion, formula explanations, and FAQPage structured data for rich snippets.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 my-6">
        <a href="https://www.xconvert24.com/convert/length/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Length</a>
        <a href="https://www.xconvert24.com/convert/weight/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Weight</a>
        <a href="https://www.xconvert24.com/convert/temperature/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Temperature</a>
        <a href="https://www.xconvert24.com/convert/currency/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Currency</a>
        <a href="https://www.xconvert24.com/convert/area/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Area</a>
        <a href="https://www.xconvert24.com/convert/volume/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Volume</a>
        <a href="https://www.xconvert24.com/convert/speed/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Speed</a>
        <a href="https://www.xconvert24.com/convert/data/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Data Storage</a>
        <a href="https://www.xconvert24.com/convert/energy/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Energy</a>
        <a href="https://www.xconvert24.com/convert/pressure/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Pressure</a>
        <a href="https://www.xconvert24.com/convert/fuel/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Fuel Economy</a>
        <a href="https://www.xconvert24.com/convert/cooking/" target="_blank" rel="noopener" class="p-3 rounded-lg border border-gray-700 hover:border-blue-500/50 text-center text-xs text-gray-300 hover:text-blue-400 transition-all">Cooking</a>
      </div>
      <p class="text-xs text-gray-500">Plus: angle, frequency, power, time, roman numeral, base number, shoe size, clothing size, precious metals, running pace, cycling speed, oven temperature, and more.</p>

      <!-- Tools -->
      <h2 class="text-xl font-light text-blue-500 mt-14 mb-4 border-l-4 border-blue-400 pl-4">Specialized Tools (30+)</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">🧮 Calculators</p>
          <p class="text-xs text-gray-400">Scientific calculator, BMI, loan, tip, discount, age, date difference, aspect ratio</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">🎨 Media Tools</p>
          <p class="text-xs text-gray-400">Image converter, image editor, audio converter, video converter, color picker</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">⏰ Time & Productivity</p>
          <p class="text-xs text-gray-400">World clock, alarm, stopwatch, reminder, epoch converter</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/20 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">🔐 Security & Utility</p>
          <p class="text-xs text-gray-400">Password generator, Morse code, my IP, online ruler, guitar tuner</p>
        </div>
      </div>

      <!-- Chrome Extension -->
      <div class="my-8 p-6 rounded-2xl border-2 border-indigo-500/30 bg-gradient-to-r from-indigo-950/20 to-blue-950/10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">🧩</span>
          <h3 class="text-lg font-semibold text-white">Auto Button Clicker — Chrome Extension</h3>
        </div>
        <p class="text-sm text-gray-300 leading-relaxed mb-4">A companion Chrome extension that automatically clicks user-specified elements at configurable intervals. Published on the Chrome Web Store with Manifest V3, GA4 tracking, and zero data collection.</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Platform</p>
            <p class="text-sm text-indigo-400 font-semibold">Manifest V3</p>
          </div>
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Data</p>
            <p class="text-sm text-indigo-400 font-semibold">Zero collected</p>
          </div>
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Analytics</p>
            <p class="text-sm text-indigo-400 font-semibold">GA4</p>
          </div>
          <div class="p-3 rounded-lg border border-indigo-500/20 text-center">
            <p class="text-xs text-gray-400">Status</p>
            <p class="text-sm text-emerald-400 font-semibold">Published</p>
          </div>
        </div>
      </div>

      <!-- Admin -->
      <h2 class="text-xl font-light text-blue-500 mt-14 mb-4 border-l-4 border-blue-400 pl-4">Admin Infrastructure</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📊 Clicks Analysis</p>
          <p class="text-xs text-gray-400">Bubble chart visualization of user interactions by element, country, device, and browser.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📡 Telemetry</p>
          <p class="text-xs text-gray-400">Live endpoint monitoring with response time history and health status.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">📧 Email Management</p>
          <p class="text-xs text-gray-400">Contact form submissions with CRUD operations, read/actioned status tracking.</p>
        </div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/30">
          <p class="text-white font-semibold text-sm mb-1">🌐 3 Environments</p>
          <p class="text-xs text-gray-400">Dev, staging, and live — each with isolated D1 databases and KV stores.</p>
        </div>
      </div>

      <!-- Tech Stack -->
      <h2 class="text-xl font-light text-blue-500 mt-14 mb-4 border-l-4 border-blue-400 pl-4">Technology Stack</h2>
      <div class="my-6 flex flex-wrap gap-3">
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Astro 6.x</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Cloudflare Workers</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">D1 (SQLite)</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">KV Store</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Tailwind CSS 4</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">TypeScript</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Playwright</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Google OAuth</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">Chrome APIs</span>
        <span class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white">GA4</span>
      </div>

      <!-- CTA -->
      <div class="mt-16 p-6 rounded-2xl bg-gradient-to-r from-indigo-950/30 to-blue-950/20 border border-indigo-500/30 text-center">
        <h3 class="text-xl font-bold text-white">Need a tools platform or Chrome extension?</h3>
        <p class="mt-2 text-sm text-gray-400">We build utility websites and browser extensions that generate traffic and solve real problems.</p>
        <a href="/contact/" class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">
          Discuss Your Project →
        </a>
      </div>

    </div>
  </section>

</Layout>
