---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import packageJson from '../../../package.json';
export const prerender = true;

const VERSION = packageJson.version;
---

<Layout title="Release Notes — xSoft Ltd | Changelog & Updates" description="Changelog and release notes for xsoftlimited.com. Track new features, improvements, and fixes as we build." keywords="xSoft releases, changelog, updates, version history">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "xSoft Release Notes",
    "url": "https://www.xsoftlimited.com/releases/",
    "description": "Changelog and release notes for xSoft Ltd website.",
    "publisher": { "@type": "Organization", "name": "xSoft Ltd" }
  })} />

  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-black text-white">Release Notes</h1>
        <span class="px-2 py-1 rounded-lg text-xs font-mono bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">v{VERSION}</span>
      </div>
      <p class="mt-3 text-gray-400">What's new, what's improved, and what's next.</p>
      <div class="mt-4 flex items-center gap-3">
        <a href="/tech-stack/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
          <span>⚙️</span> Tech Stack
        </a>
        <a href="/tools/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
          <span>🧰</span> Tools
        </a>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- v1.3.0 -->
      <article class="relative pl-6 pb-12 border-l-2 border-indigo-500/30">
        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-indigo-500 border-2 border-gray-950"></div>
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xl font-bold text-white">v1.3.0</h2>
          <span class="text-xs text-gray-500 font-mono">19 July 2026</span>
          <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Content & UX</span>
        </div>

        <p class="text-sm text-gray-300 mb-4">10 high-value SEO blog posts, homepage hero redesign with rotating text, and campaign manager improvements.</p>

        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">New Content (10 Blog Posts)</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> How to Build an AI Chatbot for Your Business (1,135 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> How to Automate Customer Support with AI (1,003 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> How to Choose a Software Development Consultancy (1,000 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> AI Tools for Small Business — 50+ Tools Ranked (963 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> The Complete Guide to RAG for Business (901 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> SEO for Startups — 744 Pages Indexed in 8 Weeks (705 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Cloudflare Workers vs AWS Lambda vs Vercel (429 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Vector Databases Explained (532 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Chrome Extension Development Guide 2026 (628 lines)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> How Much Does a Custom Website Cost UK — enhanced with portfolio links</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Homepage Improvements</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Hero text redesigned: "We are xSoft" (orange) + rotating service keywords</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Rotating text animation: AI Automation, Chatbot Integration, Custom AI Solutions, Faster Delivery, AI Strategy</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Service keywords (AI chatbots, websites, extensions, SEO) now link to /services/ sections</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Removed "Software Consultancy" label, reduced heading sizes for cleaner look</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Admin & API</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Campaign manager: Edit button on each recipient row</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Edit modal: update email, name, company, website, and status</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Campaign API PUT endpoint extended to support all fields</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Blog Index</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Blog index updated: now shows all 14 posts in 2-column grid</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Each post has colour-coded gradient header and descriptive card</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- v1.2.0 -->
      <article class="relative pl-6 pb-12 border-l-2 border-indigo-500/30">
        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-indigo-500 border-2 border-gray-950"></div>
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xl font-bold text-white">v1.2.0</h2>
          <span class="text-xs text-gray-500 font-mono">19 July 2026</span>
          <span class="px-2 py-0.5 rounded text-xs bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Tools & Campaigns</span>
        </div>

        <p class="text-sm text-gray-300 mb-4">DB-driven tools directory, email campaign manager, pricing updates, and Versantus-inspired redesigns.</p>

        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">New Features</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Tools directory page (/tools/) — DB-driven, 25 curated tools across 7 categories</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Admin Tools CRUD (/admin/tools/) — add, edit, toggle visibility, delete</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Email Campaign Manager (/admin/campaign/) — recipients, bulk import, unsubscribe tracking</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Unsubscribe API (/api/unsubscribe/) — GDPR compliant, uses email as token</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Email template with mail merge fields for Gmail campaigns</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Lex AI Chat link added to SWF case study</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Design Updates</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> About page redesigned (Versantus-inspired: mission, values cards, numbered approach)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Blog index with card images (gradient headers + category icons)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Tools replaces Tech Stack in main nav</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Chatbot responses now render markdown, URLs, and emails as clickable links</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Policy Changes</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> All rate disclosures removed from public pages — pricing requires consultation</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Retainer shows as "Available" with book-a-call link instead of specific amount</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> llms.txt updated to reflect consultation-based pricing</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Infrastructure</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> tools table + campaign_recipients + campaign_unsubscribes tables</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Custom domain connected (xsoftlimited.com)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> CSS import moved to Layout for reliable Tailwind loading</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Fixed Astro template escaping issues on releases page</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- v1.1.0 -->
      <article class="relative pl-6 pb-12 border-l-2 border-indigo-500/30">
        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-indigo-500 border-2 border-gray-950"></div>
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xl font-bold text-white">v1.1.0</h2>
          <span class="text-xs text-gray-500 font-mono">18 July 2026</span>
          <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">AI Chatbot + SEO Admin</span>
        </div>

        <p class="text-sm text-gray-300 mb-4">Added AI chatbot, SEO admin dashboard, tech stack page, release notes, and multiple UX improvements.</p>

        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">New Features</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> AI chatbot widget (bottom-left) — knows pricing, services, case studies, encourages call booking</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> SEO Index admin page (/admin/seo/) with full CRUD, live character counts, index status tracking</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Tech Stack page with full infrastructure breakdown</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Release Notes page with timeline-style changelog</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Version stamp (fixed bottom-right corner + footer)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Voice agent widget (Cloudflare @cloudflare/voice) scaffolded</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Calendly inline booking widget on contact page</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Phone number field on contact form</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">SEO Improvements</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> FAQPage schemas added to 9 pages (Services, Homepage, About, Contact, Case Studies, 4 blogs)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Dynamic BreadcrumbList auto-generated from URL path</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Social card SVG created (1200x630)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> All titles/descriptions validated against 70/160 char limits</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> llms.txt for AI discoverability</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> WebPage schema on Privacy + Terms pages</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Sitemap lastmod dates on all URLs</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Design & UX</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> New logo: &lt;xSoft /&gt; code-brackets style + matching favicon</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Consistent SVG logos across homepage, case studies, and about page</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> xCrypto24 orange Bitcoin logo + Beta badge everywhere</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Reduced vertical spacing across all pages</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Services: inline icons with headings, delivery arrows, expanded SEO section</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Hero: "Unlock your full business potential with AI"</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Infrastructure</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> D1 staging database (xsoft-staging) created and configured</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> wrangler.staging.jsonc with DB + AI bindings</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Workers AI binding (Llama 4 Scout) for chatbot</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> All APIs updated to Astro v6 pattern (import {'{ env }'} from cloudflare:workers)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> seo_index table with 15 pages seeded</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- v1.0.0 -->
      <article class="relative pl-6 pb-12 border-l-2 border-indigo-500/30">
        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-indigo-500 border-2 border-gray-950"></div>
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xl font-bold text-white">v1.0.0</h2>
          <span class="text-xs text-gray-500 font-mono">15 July 2026</span>
          <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Initial Launch</span>
        </div>

        <p class="text-sm text-gray-300 mb-4">First release of the xSoft Ltd website — our consultancy's public presence.</p>

        <div class="space-y-6">
          <!-- Pages -->
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Pages & Content</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Homepage with animated hero, stats, services overview, case study previews</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Services page — AI Chatbots, Web Dev, Chrome Extensions, SEO with pricing</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> 3 case studies — ScrabbleWordsFinder, xConvert24, xCrypto24 (Beta)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> About page with career history, company details, and linked past employers</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Contact page with form, phone field, Calendly booking widget</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Tech Stack page with full infrastructure breakdown</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Privacy Policy (GDPR compliant) + Terms of Service</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> 4 technical blog posts (RAG chatbots, SEO at scale, Chrome extensions, D1 vs KV)</li>
            </ul>
          </div>

          <!-- Features -->
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Features</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Admin dashboard with Google OAuth (staging/live)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Contact form → saves to D1 + sends email notification</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Admin emails CRUD (view, mark read, delete enquiries)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> SEO Index admin — all pages tracked with title/desc lengths, schema types, index status</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Voice Agent widget (Cloudflare @cloudflare/voice) — AI sales assistant</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Calendly integration for booking discovery calls</li>
            </ul>
          </div>

          <!-- SEO -->
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">SEO & Technical</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> JSON-LD schemas on all pages (Organization, Article, FAQPage, BreadcrumbList, etc.)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Dynamic BreadcrumbList auto-generated from URL path</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Full OG + Twitter Card meta on every page</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> llms.txt for AI discoverability</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> XML sitemap with lastmod dates (16 URLs)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> robots.txt with /admin/ exclusion</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> SEO health check: 10/10 — all titles ≤70, descriptions ≤160</li>
            </ul>
          </div>

          <!-- Infrastructure -->
          <div>
            <h3 class="text-sm font-semibold text-indigo-400 mb-2">Infrastructure</h3>
            <ul class="space-y-1.5 text-sm text-gray-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Astro 6.4.4 + Cloudflare Workers (SSR)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> D1 database (xsoft-live + xsoft-staging)</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Tailwind CSS 4.x dark theme with custom animations</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> &lt;xSoft /&gt; code-brackets logo + matching favicon</li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">+</span> Voice agent Worker (xsoft-voice) with Durable Objects + Workers AI</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- What's Next -->
      <div class="mt-8 p-5 rounded-xl border border-gray-800 bg-gray-900/30">
        <h3 class="text-sm font-semibold text-white mb-3">Coming Next</h3>
        <ul class="space-y-1.5 text-sm text-gray-400">
          <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">✓</span> <span class="line-through text-gray-600">Deploy to live (xsoftlimited.com)</span></li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 shrink-0">✓</span> <span class="line-through text-gray-600">Google Search Console submission</span></li>
          <li class="flex items-start gap-2"><span class="text-gray-600 shrink-0">○</span> Voice agent deployment + testing with real calls</li>
          <li class="flex items-start gap-2"><span class="text-gray-600 shrink-0">○</span> More blog posts (AI agent architecture, voice agents guide)</li>
          <li class="flex items-start gap-2"><span class="text-gray-600 shrink-0">○</span> Client testimonials section</li>
          <li class="flex items-start gap-2"><span class="text-gray-600 shrink-0">○</span> Email campaign — first outreach batch (50 businesses)</li>
          <li class="flex items-start gap-2"><span class="text-gray-600 shrink-0">○</span> www.xsoftlimited.com DNS resolution (CNAME propagation)</li>
        </ul>
      </div>

      </div>

    </div>
  </section>

</Layout>
