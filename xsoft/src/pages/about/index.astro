---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="About xSoft Ltd — Software Consultancy Based in England" description="xSoft Ltd is a software consultancy founded in 2026. We build AI chatbots, web applications, Chrome extensions, and SEO strategies for businesses worldwide." keywords="about xSoft, software consultancy, Rajeev Naik, England, AI development, web development">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About xSoft Ltd",
    "url": "https://www.xsoftlimited.com/about/",
    "mainEntity": {
      "@type": "Organization",
      "name": "xSoft Ltd",
      "foundingDate": "2026-06-30",
      "founder": { "@type": "Person", "name": "Rajeev Naik", "jobTitle": "Director" },
      "address": { "@type": "PostalAddress", "addressCountry": "GB", "addressRegion": "England" },
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": "1-5" }
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Who founded xSoft Ltd?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft Ltd was founded by Raj Naik in June 2026. Raj has 27+ years of experience in the tech industry, having led engineering teams at Elsevier, Genomics England, British Heart Foundation, and FreeWheel (Comcast)." }},
      { "@type": "Question", "name": "Where is xSoft based?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft Ltd is registered in England and Wales (Company No. 17308915). We deliver projects globally — our infrastructure runs on Cloudflare's worldwide edge network." }},
      { "@type": "Question", "name": "What industries has xSoft worked in?", "acceptedAnswer": { "@type": "Answer", "text": "Our experience spans FMCG, ecommerce, publishing, AdTech, genomics, cryptocurrency, charity (BHF), social media, and SaaS platforms. We bring cross-industry perspective to every project." }}
    ]
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">About Us</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">Small team. Big output.</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">We're a lean software consultancy that punches well above its weight. Enterprise-quality work, startup speed, zero bureaucracy.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <h2 class="text-xl font-light text-indigo-400 mt-10 mb-4 border-l-4 border-indigo-400 pl-4">Our Story</h2>
      <p class="text-gray-300 leading-relaxed mb-4">xSoft Ltd was founded in June 2026 by <strong>Raj Naik</strong> — a software leader with 27+ years of experience across the tech industry. After building and scaling engineering teams at organisations like <a href="https://www.elsevier.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Elsevier</a>, <a href="https://www.genomicsengland.co.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Genomics England</a>, <a href="https://www.bhf.org.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">British Heart Foundation</a>, <a href="https://www.freewheel.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">FreeWheel (Comcast)</a>, and <a href="https://www.icis.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">ICIS (Reed Business Information)</a>, he launched xSoft to deliver enterprise-quality software without the enterprise overhead.</p>
      <p class="text-gray-300 leading-relaxed mb-4">We specialise in building software that works autonomously — AI chatbots that answer customers at 3am, websites that scale globally without DevOps teams, and tools that automate repetitive workflows so humans can focus on what matters.</p>

      <div class="my-8 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Our Approach</p>
        <p class="text-sm text-gray-300 leading-relaxed">We don't believe in building software that needs a manual. If it's not intuitive, it's not done. Every project ships with documentation, admin tools, and the ability to manage itself without calling us back every week.</p>
      </div>

      <!-- Founder -->
      <h2 class="text-xl font-light text-indigo-400 mt-14 mb-4 border-l-4 border-indigo-400 pl-4">The Team</h2>

      <div class="my-6 p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
        <div class="flex flex-col sm:flex-row gap-6">
          <div class="shrink-0 w-20 h-20 rounded-full bg-gradient-to-br from-indigo-500 to-blue-500 flex items-center justify-center">
            <span class="text-2xl font-black text-white">RN</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white">Rajeev Naik</h3>
            <p class="text-sm text-indigo-400 mb-3">Founder & Technical Director</p>
            <p class="text-sm text-gray-400 leading-relaxed">27+ years in the tech industry spanning leadership, architecture, and hands-on development. Previously directed engineering at <a href="https://www.elsevier.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Elsevier</a> (FTSE100, $8m budget, team of 45), managed genome analysis pipelines at <a href="https://www.genomicsengland.co.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Genomics England</a> (17 developers), led SiteCore platform engineering at <a href="https://www.bhf.org.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">British Heart Foundation</a>, and delivered AdTech products at <a href="https://www.freewheel.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">FreeWheel (Comcast)</a>.</p>
            <p class="text-sm text-gray-400 leading-relaxed mt-3">Served as VP of Engineering at <a href="https://www.conversocial.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Conversocial</a> (25 engineers), and spent 8 years at <a href="https://www.icis.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">ICIS/Reed Business Information</a> leading a £16m data programme with 35+ team members. Domains include FMCG, ecommerce, publishing, AdTech, genomics, crypto, and SaaS.</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Cloudflare</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">AI/ML</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Python</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">TypeScript</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Java/.Net</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">SEO</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Chrome Extensions</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">AWS</span>
            </div>
            <div class="mt-4">
              <a href="http://uk.linkedin.com/in/rajeevn" target="_blank" rel="noopener" class="text-xs text-indigo-400 hover:underline">LinkedIn →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Values -->
      <h2 class="text-xl font-light text-indigo-400 mt-14 mb-4 border-l-4 border-indigo-400 pl-4">Career Highlights</h2>
      <div class="my-6 overflow-x-auto">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left text-gray-300 font-semibold">Company</th>
              <th class="px-4 py-3 text-left text-gray-300 font-semibold">Role</th>
              <th class="px-4 py-3 text-left text-gray-300 font-semibold">Period</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3"><a href="https://www.xsoftlimited.com/" class="text-indigo-400 hover:underline">xSoft Ltd</a></td><td class="px-4 py-3 text-gray-300">Founder & Technical Director</td><td class="px-4 py-3 text-gray-400">2026 – Present</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3"><a href="https://www.bhf.org.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">British Heart Foundation</a></td><td class="px-4 py-3 text-gray-300">Software Development Manager</td><td class="px-4 py-3 text-gray-400">2022 – 2023</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3"><a href="https://www.genomicsengland.co.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Genomics England</a></td><td class="px-4 py-3 text-gray-300">Software Development Manager</td><td class="px-4 py-3 text-gray-400">2020 – 2022</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3"><a href="https://www.freewheel.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">FreeWheel (Comcast)</a></td><td class="px-4 py-3 text-gray-300">Software Development Manager</td><td class="px-4 py-3 text-gray-400">2019</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3"><a href="https://www.conversocial.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Conversocial</a></td><td class="px-4 py-3 text-gray-300">VP of Engineering</td><td class="px-4 py-3 text-gray-400">2018</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3"><a href="https://www.elsevier.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Elsevier (FTSE100)</a></td><td class="px-4 py-3 text-gray-300">Director of Software Engineering</td><td class="px-4 py-3 text-gray-400">2015 – 2018</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3"><a href="https://www.icis.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">ICIS / Reed Business Info</a></td><td class="px-4 py-3 text-gray-300">Development Manager</td><td class="px-4 py-3 text-gray-400">2007 – 2015</td></tr>
          </tbody>
        </table>
      </div>

      <!-- More + LinkedIn -->
      <div class="my-6 flex items-center gap-4">
        <p class="text-sm text-gray-400">Plus earlier roles at Splendid Unlimited, Passado, ScreePages, Paraspar, IndiaInfo.com, and more.</p>
        <a href="http://uk.linkedin.com/in/rajeevn" target="_blank" rel="noopener" class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[#0A66C2]/50 hover:border-[#0A66C2] bg-[#0A66C2]/10 hover:bg-[#0A66C2]/20 transition-all group">
          <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span class="text-sm text-[#0A66C2] font-medium group-hover:text-white transition-colors">Full Profile</span>
        </a>
      </div>

      <h2 class="text-xl font-light text-indigo-400 mt-14 mb-4 border-l-4 border-indigo-400 pl-4">What We Believe</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Speed over perfection:</span> Ship early, iterate fast. A working product today beats a perfect spec next quarter.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Transparency:</span> You see exactly what we're building, every week. No black boxes, no surprises at delivery.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Own the outcome:</span> We don't just write code — we take responsibility for whether it actually solves your problem.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">No lock-in:</span> Everything we build is yours. Open standards, documented APIs, transferable infrastructure.</p>
        </div>
      </div>

      <!-- Company Details -->
      <h2 class="text-xl font-light text-indigo-400 mt-14 mb-4 border-l-4 border-indigo-400 pl-4">Company Details</h2>

      <div class="my-6 overflow-x-auto">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden">
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">Company Name</td><td class="px-4 py-3 text-white font-semibold">xSoft Ltd</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">Company Number</td><td class="px-4 py-3 text-white">17308915</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">Type</td><td class="px-4 py-3 text-white">Private Limited Company</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">Incorporated</td><td class="px-4 py-3 text-white">30 June 2026</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">Registered</td><td class="px-4 py-3 text-white">England & Wales</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">Director</td><td class="px-4 py-3 text-white">Rajeev Naik</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">Contact</td><td class="px-4 py-3 text-white"><a href="mailto:info@xsoftlimited.com" class="text-indigo-400 hover:underline">info@xsoftlimited.com</a></td></tr>
          </tbody>
        </table>
      </div>

      <!-- Products -->
      <h2 class="text-xl font-light text-indigo-400 mt-14 mb-4 border-l-4 border-indigo-400 pl-4">Our Products</h2>
      <p class="text-gray-300 leading-relaxed mb-6">Beyond client work, we operate several of our own digital products — each serves as a live demonstration of our capabilities.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
        <a href="/case-studies/scrabblewordsfinder/" class="p-4 rounded-xl border border-gray-700 hover:border-amber-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all group">
          <p class="text-amber-400 font-semibold text-sm mb-1 group-hover:text-amber-300">🅰️ ScrabbleWordsFinder.com</p>
          <p class="text-xs text-gray-400">AI word game platform — 1000+ pages, games, rankings</p>
        </a>
        <a href="/case-studies/xconvert24/" class="p-4 rounded-xl border border-gray-700 hover:border-blue-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all group">
          <p class="text-blue-400 font-semibold text-sm mb-1 group-hover:text-blue-300">⚙️ xConvert24.com</p>
          <p class="text-xs text-gray-400">60+ utility tools and converters platform</p>
        </a>
        <a href="/case-studies/xcrypto24/" class="p-4 rounded-xl border border-gray-700 hover:border-orange-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all group">
          <p class="text-orange-400 font-semibold text-sm mb-1 group-hover:text-orange-300"><svg class="inline w-4 h-4 mr-1 -mt-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.638 14.904c-1.602 6.43-8.113 10.34-14.542 8.736C2.67 22.05-1.244 15.525.362 9.105 1.962 2.67 8.475-1.243 14.9.358c6.43 1.605 10.342 8.115 8.738 14.546zm-6.35-4.613c.24-1.59-.974-2.45-2.634-3.019l.54-2.153-1.315-.33-.525 2.107c-.345-.087-.7-.168-1.053-.252l.53-2.12-1.314-.328-.538 2.152c-.287-.065-.568-.13-.84-.2l.002-.007-1.813-.453-.35 1.407s.974.223.954.237c.535.136.63.492.614.776l-.614 2.466c.037.009.085.023.137.043l-.14-.034-.86 3.45c-.065.16-.23.4-.6.31.014.02-.954-.238-.954-.238l-.652 1.514 1.71.426c.318.08.63.164.936.242l-.543 2.18 1.314.327.54-2.17c.36.1.707.19 1.05.273l-.537 2.154 1.315.33.543-2.17c2.24.424 3.926.253 4.636-1.774.57-1.637-.03-2.58-1.217-3.196.866-.2 1.518-.77 1.69-1.95z"/></svg> xCrypto24.com <span class="ml-1 px-1.5 py-0.5 rounded text-xs bg-orange-500/20 text-orange-400 border border-orange-500/30">Beta</span></p>
          <p class="text-xs text-gray-400">Real-time cryptocurrency tracking and analytics</p>
        </a>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-900/30">
          <p class="text-cyan-400 font-semibold text-sm mb-1">🧩 Auto Button Clicker</p>
          <p class="text-xs text-gray-400">Chrome Web Store extension — DOM automation</p>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 p-6 rounded-2xl bg-gradient-to-r from-indigo-950/30 to-blue-950/20 border border-indigo-500/30 text-center">
        <h3 class="text-xl font-bold text-white">Want to work with us?</h3>
        <p class="mt-2 text-sm text-gray-400">We're always open to interesting projects. Tell us what you're building.</p>
        <a href="/contact/" class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">
          Get in Touch →
        </a>
      </div>

    </div>
  </section>

</Layout>
