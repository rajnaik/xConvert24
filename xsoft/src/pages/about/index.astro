---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="About xSoft Ltd — AI Software Consultancy, England" description="xSoft Ltd is an AI software consultancy helping businesses leverage artificial intelligence to automate, scale, and grow. Founded by Raj Naik with 27+ years of tech leadership experience." keywords="about xSoft, AI consultancy, software consultancy, Rajeev Naik, England, Cloudflare Workers">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About xSoft Ltd",
    "url": "https://www.xsoftlimited.com/about/",
    "mainEntity": {
      "@type": "Organization",
      "name": "xSoft Ltd",
      "foundingDate": "2026-06-30",
      "founder": { "@type": "Person", "name": "Rajeev Naik", "jobTitle": "Director" },
      "address": { "@type": "PostalAddress", "addressCountry": "GB", "addressRegion": "England" },
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": "1-5" }
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Who founded xSoft Ltd?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft Ltd was founded by Raj Naik in June 2026. Raj has 27+ years of experience in the tech industry, having led engineering teams at Elsevier, Genomics England, British Heart Foundation, and FreeWheel (Comcast)." }},
      { "@type": "Question", "name": "Where is xSoft based?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft Ltd is registered in England and Wales (Company No. 17308915). We deliver projects globally — our infrastructure runs on Cloudflare's worldwide edge network." }},
      { "@type": "Question", "name": "What industries has xSoft worked in?", "acceptedAnswer": { "@type": "Answer", "text": "Our experience spans FMCG, ecommerce, publishing, AdTech, genomics, cryptocurrency, charity (BHF), social media, and SaaS platforms. We bring cross-industry perspective to every project." }}
    ]
  })} />

  <!-- Hero -->
  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">About Us</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">We help businesses harness the power of AI</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">We're a team of AI strategists and technical experts helping businesses leverage artificial intelligence to automate operations, delight customers, and achieve measurable results.</p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Our Mission</p>
      <p class="text-xl sm:text-2xl text-gray-200 leading-relaxed max-w-3xl mx-auto">To make enterprise-grade AI accessible to businesses of all sizes. We believe AI should enhance human capabilities, not replace them — freeing your team to focus on what matters while intelligent systems handle the rest.</p>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">Our Values</p>
        <p class="text-gray-400">These core values guide our approach to every project and client relationship.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/30 text-center hover:border-indigo-500/30 transition-all">
          <span class="text-3xl mb-4 block">🏆</span>
          <h3 class="text-lg font-semibold text-white mb-2">Quality</h3>
          <p class="text-sm text-gray-400">We deliver excellence in every project. Enterprise-grade infrastructure, production-ready code, and solutions built to scale.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/30 text-center hover:border-indigo-500/30 transition-all">
          <span class="text-3xl mb-4 block">⚡</span>
          <h3 class="text-lg font-semibold text-white mb-2">Speed</h3>
          <p class="text-sm text-gray-400">Ship early, iterate fast. A working product today beats a perfect spec next quarter. You see progress every single week.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/30 text-center hover:border-indigo-500/30 transition-all">
          <span class="text-3xl mb-4 block">🤝</span>
          <h3 class="text-lg font-semibold text-white mb-2">Transparency</h3>
          <p class="text-sm text-gray-400">You see exactly what we're building. No black boxes, no surprises at delivery. Weekly demos, open communication, honest feedback.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/30 text-center hover:border-indigo-500/30 transition-all">
          <span class="text-3xl mb-4 block">🔓</span>
          <h3 class="text-lg font-semibold text-white mb-2">No Lock-in</h3>
          <p class="text-sm text-gray-400">Everything we build is yours. Open standards, documented APIs, transferable infrastructure. You're never dependent on us.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="py-16 border-b border-gray-800/50 bg-gray-900/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">Our Approach</p>
        <p class="text-gray-400">We combine strategic thinking with technical expertise to deliver AI solutions that drive real business value.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-3xl font-black text-indigo-400 mb-3">01</p>
          <h3 class="text-lg font-semibold text-white mb-2">Discovery & Assessment</h3>
          <p class="text-sm text-gray-400">We start by understanding your business, challenges, and objectives. A 15-minute call is all it takes to determine if we're a good fit.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-3xl font-black text-indigo-400 mb-3">02</p>
          <h3 class="text-lg font-semibold text-white mb-2">Strategy & Scoping</h3>
          <p class="text-sm text-gray-400">Based on our findings, we develop a tailored solution with clear milestones, timeline, and cost. No surprises — you approve before we start.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-3xl font-black text-indigo-400 mb-3">03</p>
          <h3 class="text-lg font-semibold text-white mb-2">Build & Deliver</h3>
          <p class="text-sm text-gray-400">We build against agreed milestones with weekly demos. You see working software every 7 days. Feedback gets incorporated immediately.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
          <p class="text-3xl font-black text-indigo-400 mb-3">04</p>
          <h3 class="text-lg font-semibold text-white mb-2">Launch & Support</h3>
          <p class="text-sm text-gray-400">We deploy globally, hand over documentation, and provide 30 days of free support. Optional retainer available for ongoing maintenance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">The Team</p>
      </div>

      <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50">
        <div class="flex flex-col sm:flex-row gap-6">
          <div class="shrink-0 w-20 h-20 rounded-full bg-gradient-to-br from-indigo-500 to-blue-500 flex items-center justify-center">
            <span class="text-2xl font-black text-white">RN</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white">Rajeev Naik</h3>
            <p class="text-sm text-indigo-400 mb-3">Founder & Technical Director</p>
            <p class="text-sm text-gray-400 leading-relaxed">27+ years in the tech industry spanning leadership, architecture, and hands-on development. Previously directed engineering at <a href="https://www.elsevier.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Elsevier</a> (FTSE100, $8m budget, team of 45), managed genome analysis pipelines at <a href="https://www.genomicsengland.co.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Genomics England</a>, led platform engineering at <a href="https://www.bhf.org.uk/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">British Heart Foundation</a>, and delivered AdTech products at <a href="https://www.freewheel.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">FreeWheel (Comcast)</a>.</p>
            <p class="text-sm text-gray-400 leading-relaxed mt-3">VP of Engineering at <a href="https://www.conversocial.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">Conversocial</a> (25 engineers), 8 years at <a href="https://www.icis.com/" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">ICIS/Reed Business Information</a> leading a £16m data programme. Domains: FMCG, ecommerce, publishing, AdTech, genomics, crypto, SaaS.</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">AI/ML</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Cloudflare</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Python</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">TypeScript</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">Java/.Net</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">SEO</span>
              <span class="px-2 py-1 rounded text-xs bg-gray-800 border border-gray-700 text-gray-300">AWS</span>
            </div>
            <div class="mt-4">
              <a href="http://uk.linkedin.com/in/rajeevn" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-[#0A66C2] hover:underline">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                View Full Profile →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Details -->
  <section class="py-16 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Company</p>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between"><span class="text-gray-400">Name</span><span class="text-white font-medium">xSoft Ltd</span></div>
            <div class="flex justify-between"><span class="text-gray-400">Number</span><span class="text-white">17308915</span></div>
            <div class="flex justify-between"><span class="text-gray-400">Type</span><span class="text-white">Private Limited</span></div>
            <div class="flex justify-between"><span class="text-gray-400">Incorporated</span><span class="text-white">30 June 2026</span></div>
            <div class="flex justify-between"><span class="text-gray-400">Registered</span><span class="text-white">England & Wales</span></div>
          </div>
        </div>
        <div class="text-right">
          <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Our Products</p>
          <div class="space-y-3">
            <a href="/case-studies/scrabblewordsfinder/" class="flex items-center justify-end gap-2 text-sm text-gray-300 hover:text-amber-400 transition-colors">
              ScrabbleWordsFinder.com <span class="text-amber-400">→</span>
            </a>
            <a href="/case-studies/xconvert24/" class="flex items-center justify-end gap-2 text-sm text-gray-300 hover:text-blue-400 transition-colors">
              xConvert24.com <span class="text-blue-400">→</span>
            </a>
            <a href="/case-studies/xcrypto24/" class="flex items-center justify-end gap-2 text-sm text-gray-300 hover:text-orange-400 transition-colors">
              xCrypto24.com <span class="px-1.5 py-0.5 rounded text-xs bg-orange-500/20 text-orange-400 border border-orange-500/30">Beta</span> <span class="text-orange-400">→</span>
            </a>
            <div class="flex items-center justify-end gap-2 text-sm text-gray-400">
              Auto Button Clicker (Chrome) <span class="text-cyan-400">→</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Ready to work with us?</h2>
      <p class="mt-4 text-gray-400">Let's discuss how we can help you leverage AI to drive innovation and achieve measurable results for your business.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact/" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all hover:shadow-xl hover:shadow-indigo-500/25">
          Get in Touch →
        </a>
        <a href="https://calendly.com/raj007/15min" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border border-gray-700 hover:border-indigo-500/50 text-gray-300 hover:text-white font-semibold transition-all">
          Book a Call
        </a>
      </div>
    </div>
  </section>

</Layout>
