---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="xSoft Ltd — AI-Powered Software Solutions for Modern Businesses" description="We build AI chatbots, high-performance websites, Chrome extensions, and SEO strategies that help businesses grow. Based in England, delivering globally." keywords="AI chatbot development, web development consultancy, Chrome extension, SEO, xSoft Ltd, Cloudflare Workers">

  <!-- JSON-LD Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "xSoft Ltd",
    "url": "https://www.xsoftlimited.com",
    "logo": "https://www.xsoftlimited.com/social-card.svg",
    "description": "AI-powered software solutions — chatbots, web development, Chrome extensions, and SEO.",
    "foundingDate": "2026-06-30",
    "founder": { "@type": "Person", "name": "Rajeev Naik" },
    "address": { "@type": "PostalAddress", "addressCountry": "GB" },
    "contactPoint": { "@type": "ContactPoint", "email": "info@xsoftlimited.com", "contactType": "sales" },
    "sameAs": []
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What does xSoft build?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft builds AI chatbots with RAG (Retrieval-Augmented Generation), high-performance websites on Cloudflare Workers, Chrome browser extensions, and SEO content strategies at scale. All deployed on enterprise-grade edge infrastructure." }},
      { "@type": "Question", "name": "Where is xSoft based?", "acceptedAnswer": { "@type": "Answer", "text": "xSoft Ltd is a private limited company registered in England and Wales (Company No. 17308915). We deliver projects globally — our infrastructure runs on Cloudflare's worldwide edge network." }},
      { "@type": "Question", "name": "How do I get started with xSoft?", "acceptedAnswer": { "@type": "Answer", "text": "Contact us at info@xsoftlimited.com or book a free 15-minute discovery call via our contact page. We'll discuss your project, provide honest feedback on feasibility, and send a written proposal within 24 hours." }}
    ]
  })} />

  <!-- Hero Section — Business Outcomes Focus -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Subtle background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-gray-950 via-indigo-950/20 to-gray-950"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Headline + Copy -->
        <div>
          <h1 class="animate-fade-in-up">
            <span class="block text-sm sm:text-base font-semibold text-indigo-400 uppercase tracking-widest mb-3">We are xSoft.</span>
            <span class="block text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-tight">Build faster.<br>Grow smarter.</span>
          </h1>
          <p class="animate-fade-in-delay-1 mt-6 text-base sm:text-lg text-gray-400 max-w-xl leading-relaxed">
            AI chatbots that handle support 24/7. Websites that convert. Chrome extensions that automate. SEO strategies that rank. Built in weeks, not months — so you can focus on what matters: growing your business.
          </p>
          <div class="animate-fade-in-delay-2 mt-8 flex flex-col sm:flex-row items-start gap-4">
            <a href="/contact/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all hover:shadow-lg hover:shadow-indigo-500/30 hover:-translate-y-0.5">
              Start a Project <span aria-hidden="true">→</span>
            </a>
            <a href="/case-studies/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-gray-700 hover:border-gray-600 text-gray-300 hover:text-white font-semibold transition-all hover:-translate-y-0.5">
              See Results
            </a>
          </div>
        </div>

        <!-- Right: Case Study Highlight -->
        <div class="animate-fade-in-delay-1 relative">
          <div class="rounded-2xl border border-gray-800 bg-gradient-to-br from-gray-900 to-gray-950 p-1">
            <div class="rounded-xl bg-gray-950 p-6 sm:p-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-lg bg-amber-500/20 border border-amber-500/30 flex items-center justify-center text-2xl">🎮</div>
                <div>
                  <p class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Recent Success</p>
                  <p class="text-sm text-gray-400">ScrabbleWordsFinder</p>
                </div>
              </div>
              <p class="text-sm text-gray-300 leading-relaxed mb-4">
                "We built a word-game platform from concept to 1000+ pages, live in 8 weeks. Real-time solver, AI chat coach, interactive games — all deployed on Cloudflare edge. Now handling 10k+ daily players with sub-200ms response times."
              </p>
              <div class="grid grid-cols-3 gap-3 pt-4 border-t border-gray-800">
                <div>
                  <p class="text-2xl font-bold text-cyan-400">1000+</p>
                  <p class="text-xs text-gray-500 mt-1">Pages</p>
                </div>
                <div>
                  <p class="text-2xl font-bold text-emerald-400">8w</p>
                  <p class="text-xs text-gray-500 mt-1">Launch</p>
                </div>
                <div>
                  <p class="text-2xl font-bold text-indigo-400">10k+</p>
                  <p class="text-xs text-gray-500 mt-1">DAU</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip — Simplified Palette -->
  <section class="border-y border-gray-800/50 bg-gray-900/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 text-center">
        <div class="animate-scale-in">
          <p class="text-3xl font-black text-indigo-400">5+</p>
          <p class="text-sm text-gray-500 mt-1">Live Products</p>
        </div>
        <div class="animate-scale-in" style="animation-delay: 0.1s;">
          <p class="text-3xl font-black text-indigo-400">1000+</p>
          <p class="text-sm text-gray-500 mt-1">Pages Deployed</p>
        </div>
        <div class="animate-scale-in" style="animation-delay: 0.2s;">
          <p class="text-3xl font-black text-emerald-400">24/7</p>
          <p class="text-sm text-gray-500 mt-1">AI Uptime</p>
        </div>
        <div class="animate-scale-in" style="animation-delay: 0.3s;">
          <p class="text-3xl font-black text-emerald-400">&lt;200ms</p>
          <p class="text-sm text-gray-500 mt-1">Response Time</p>
        </div>
        <div class="animate-scale-in" style="animation-delay: 0.4s;">
          <button onclick="document.getElementById('pagespeed-modal').classList.remove('hidden')" class="cursor-pointer hover:scale-105 transition-transform">
            <p class="text-3xl font-black text-emerald-400 underline decoration-emerald-500/40 hover:decoration-emerald-400">100/100</p>
            <p class="text-sm text-emerald-300 mt-1 underline decoration-emerald-500/30">PageSpeed Score</p>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- PageSpeed Modal -->
  <div id="pagespeed-modal" class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="relative max-w-3xl w-full max-h-[90vh] overflow-auto rounded-2xl border border-gray-700 bg-gray-900 p-4">
      <button onclick="document.getElementById('pagespeed-modal').classList.add('hidden')" class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl leading-none z-10">&times;</button>
      <p class="text-sm font-semibold text-green-400 mb-3">Google PageSpeed Insights — July 19, 2026</p>
      <img src="/pagespeed-score.png" alt="Google PageSpeed Insights — 100/100 Performance, Accessibility, Best Practices, SEO" class="w-full rounded-xl" width="1998" height="2088" />
    </div>
  </div>

  <!-- Services Overview -->
  <section class="py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">What We Do</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">End-to-end digital solutions</h2>
        <p class="mt-4 text-gray-400 max-w-xl mx-auto">From concept to deployment — we handle the entire technical stack so you can focus on growing your business.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- AI Chatbots — Indigo Primary -->
        <a href="/services/#ai-chatbots" class="group p-6 rounded-2xl border border-gray-800 hover:border-indigo-500/50 bg-gray-900/30 hover:bg-gray-900/60 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-500/5">
          <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/30 flex items-center justify-center group-hover:scale-110 transition-transform">
              <span class="text-2xl">🤖</span>
            </div>
            <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">2–4 weeks</span>
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">AI Chatbots</h3>
          <p class="mt-2 text-sm text-gray-400">Custom chatbots trained on your business data. Answer customer questions 24/7 with RAG-powered accuracy. Deployed on Cloudflare's edge for sub-200ms responses worldwide.</p>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500">Typical ROI:</p>
            <p class="text-sm font-semibold text-indigo-400">60–80% support deflection</p>
          </div>
          <p class="mt-3 text-xs text-indigo-400 font-medium group-hover:translate-x-1 transition-transform">Learn more →</p>
        </a>

        <!-- Web Development — Indigo Secondary -->
        <a href="/services/#web-development" class="group p-6 rounded-2xl border border-gray-800 hover:border-indigo-400/50 bg-gray-900/30 hover:bg-gray-900/60 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-500/5">
          <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/30 flex items-center justify-center group-hover:scale-110 transition-transform">
              <span class="text-2xl">🌐</span>
            </div>
            <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">2–4 weeks</span>
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Web Development</h3>
          <p class="mt-2 text-sm text-gray-400">High-performance websites built with Astro and deployed on Cloudflare Workers. Server-side rendered, SEO-optimized, and blazing fast on every device.</p>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500">Performance:</p>
            <p class="text-sm font-semibold text-indigo-400">100/100 PageSpeed, &lt;200ms response</p>
          </div>
          <p class="mt-3 text-xs text-indigo-400 font-medium group-hover:translate-x-1 transition-transform">Learn more →</p>
        </a>

        <!-- Chrome Extensions — Cyan Accent -->
        <a href="/services/#chrome-extensions" class="group p-6 rounded-2xl border border-gray-800 hover:border-cyan-400/50 bg-gray-900/30 hover:bg-gray-900/60 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-cyan-500/5">
          <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/30 flex items-center justify-center group-hover:scale-110 transition-transform">
              <span class="text-2xl">🧩</span>
            </div>
            <span class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">4–6 weeks</span>
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-cyan-400 transition-colors">Chrome Extensions</h3>
          <p class="mt-2 text-sm text-gray-400">Custom browser extensions that automate workflows, enhance productivity, and integrate with your existing tools. Published on the Chrome Web Store.</p>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500">Deliverables:</p>
            <p class="text-sm font-semibold text-cyan-400">Chrome Store listing + documentation</p>
          </div>
          <p class="mt-3 text-xs text-cyan-400 font-medium group-hover:translate-x-1 transition-transform">Learn more →</p>
        </a>

        <!-- SEO & Content — Emerald/Success -->
        <a href="/services/#seo" class="group p-6 rounded-2xl border border-gray-800 hover:border-emerald-400/50 bg-gray-900/30 hover:bg-gray-900/60 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-500/5">
          <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center group-hover:scale-110 transition-transform">
              <span class="text-2xl">📈</span>
            </div>
            <span class="text-xs font-semibold text-emerald-400 uppercase tracking-wider">6–12 weeks</span>
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors">SEO & Content Strategy</h3>
          <p class="mt-2 text-sm text-gray-400">Technical SEO audits, structured data implementation, content strategy, and AI-powered content generation at scale. Get indexed, get ranked, get traffic.</p>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500">Results timeline:</p>
            <p class="text-sm font-semibold text-emerald-400">Ranking improvements in 3–6 months</p>
          </div>
          <p class="mt-3 text-xs text-emerald-400 font-medium group-hover:translate-x-1 transition-transform">Learn more →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-14 border-t border-gray-800/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">Our Stack</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Built on enterprise-grade infrastructure</h2>
        <div class="mt-4 flex items-center justify-center gap-3">
          <a href="/tech-stack/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
            <span>⚙️</span> Tech Stack
          </a>
          <a href="/tools/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-700 bg-gray-900/50 hover:border-indigo-500/50 text-sm text-gray-300 hover:text-indigo-400 transition-all">
            <span>🧰</span> Tools
          </a>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Cloudflare Workers</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Workers AI</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Cloudflare D1</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Vectorize (RAG)</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Astro</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Tailwind CSS</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">TypeScript</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">KV Store</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Playwright</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Google OAuth</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Chrome APIs</span>
        <span class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-sm text-gray-300 hover:border-indigo-500/50 hover:text-white transition-all">Python</span>
      </div>
    </div>
  </section>

  <!-- Case Studies Preview -->
  <section class="py-14 border-t border-gray-800/50 bg-gray-900/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">Our Work</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Real products, real results</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- SWF -->
        <a href="/case-studies/scrabblewordsfinder/" class="group rounded-2xl border border-gray-800 hover:border-amber-500/50 overflow-hidden bg-gray-900/50 transition-all hover:-translate-y-2 hover:shadow-2xl">
          <div class="h-40 bg-gradient-to-br from-amber-500/20 to-orange-500/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-amber-400 group-hover:scale-110 transition-transform" viewBox="0 0 64 64" fill="none"><rect x="8" y="8" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.5"/><rect x="34" y="8" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.5"/><rect x="8" y="34" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.5"/><rect x="34" y="34" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.5"/><text x="14" y="25" font-size="14" font-weight="bold" fill="currentColor">S</text><text x="40" y="25" font-size="14" font-weight="bold" fill="currentColor">W</text><text x="14" y="51" font-size="14" font-weight="bold" fill="currentColor">F</text><text x="41" y="51" font-size="10" fill="currentColor">10</text></svg>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white group-hover:text-amber-400 transition-colors">ScrabbleWordsFinder</h3>
            <p class="mt-2 text-sm text-gray-400">AI-powered word game platform with 1000+ pages, real-time solver, 6 interactive games, and world rankings.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">AI Chatbot</span>
              <span class="px-2 py-0.5 rounded text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20">1000+ Pages</span>
            </div>
          </div>
        </a>

        <!-- xConvert -->
        <a href="/case-studies/xconvert24/" class="group rounded-2xl border border-gray-800 hover:border-blue-500/50 overflow-hidden bg-gray-900/50 transition-all hover:-translate-y-2 hover:shadow-2xl">
          <div class="h-40 bg-gradient-to-br from-blue-500/20 to-indigo-500/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-blue-400 group-hover:scale-110 transition-transform" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="20" stroke="currentColor" stroke-width="2.5"/><path d="M32 18v4M32 42v4M18 32h4M42 32h4M22.3 22.3l2.8 2.8M38.9 38.9l2.8 2.8M22.3 41.7l2.8-2.8M38.9 25.1l2.8-2.8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><circle cx="32" cy="32" r="6" stroke="currentColor" stroke-width="2.5"/></svg>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">xConvert24</h3>
            <p class="mt-2 text-sm text-gray-400">60+ unit converters and utility tools with real-time calculations, SEO-optimized pages, and admin analytics.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">60+ Tools</span>
              <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">SSR</span>
            </div>
          </div>
        </a>

        <!-- xCrypto -->
        <a href="/case-studies/xcrypto24/" class="group rounded-2xl border border-gray-800 hover:border-orange-500/50 overflow-hidden bg-gray-900/50 transition-all hover:-translate-y-2 hover:shadow-2xl">
          <div class="h-40 bg-gradient-to-br from-orange-500/20 to-amber-500/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-orange-400 group-hover:scale-110 transition-transform" viewBox="0 0 64 64" fill="currentColor"><path d="M32 4C16.536 4 4 16.536 4 32s12.536 28 28 28 28-12.536 28-28S47.464 4 32 4zm3.953 39.89c-.002 2.81-2.28 4.09-4.953 4.37v3.74h-2v-3.67c-.52-.01-1.053-.03-1.6-.06v3.73h-2v-3.74c-.44-.02-.87-.04-1.3-.06l-2.6-.001v-2.14s1.48.03 1.45 0c.56 0 .8-.36.86-.66V34.89c.002-.44-.22-.88-.87-.88.03-.03-1.45 0-1.45 0l-.39-2.4h2.47c.39 0 .78 0 1.16-.01v-3.71h2v3.64c.54-.01 1.08-.02 1.6-.02v-3.62h2v3.71c3.3.2 5.61 1.02 5.9 3.46.23 1.97-.74 3.11-2.19 3.63 1.93.54 3.17 1.73 2.87 4.07zm-2.07-6.86c0-1.97-2.62-2.26-4.28-2.4v4.85c1.66-.001 4.28-.42 4.28-2.45zm.68 6.7c0-2.17-3.14-2.48-5.04-2.56v5.16c1.9 0 5.04-.44 5.04-2.6z"/></svg>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white group-hover:text-orange-400 transition-colors">xCrypto24 <span class="ml-1 px-1.5 py-0.5 rounded text-xs bg-orange-500/20 text-orange-400 border border-orange-500/30">Beta</span></h3>
            <p class="mt-2 text-sm text-gray-400">Real-time cryptocurrency tracking, portfolio management, and market analytics with live price feeds.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Real-time</span>
              <span class="px-2 py-0.5 rounded text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20">Crypto</span>
            </div>
          </div>
        </a>
      </div>

      <div class="text-center mt-10">
        <a href="/case-studies/" class="text-sm text-indigo-400 hover:text-indigo-300 font-medium transition-colors">View all case studies →</a>
      </div>
