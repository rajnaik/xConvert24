  <!-- Rotating text animation -->
  <style>
    .rotating-text {
      display: inline-block;
    }
  </style>

  <script is:inline>
    (function() {
      if (window.__rotatingTextActive) return;
      window.__rotatingTextActive = true;
      const words = ['AI Automation', 'Chatbot Integration', 'Custom AI Solutions', 'Faster Delivery', 'AI Strategy'];
      let idx = 0;
      const el = document.getElementById('rotating-text');
      if (!el) return;
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      setInterval(() => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(-10px)';
        setTimeout(() => {
          idx = (idx + 1) % words.length;
          el.textContent = words[idx];
          el.style.transform = 'translateY(10px)';
          requestAnimationFrame(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });
        }, 500);
      }, 5000);
    })();
  </script>

