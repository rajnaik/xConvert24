---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="Blog — xSoft Ltd | AI, Cloudflare, SEO & Extensions" description="Technical deep-dives on building AI chatbots with RAG, scaling SEO to 1000+ pages, Cloudflare Workers architecture, and Chrome extension development." keywords="xSoft blog, AI chatbot development, Cloudflare Workers, RAG, SEO at scale, Chrome extensions, D1, KV">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "xSoft Technical Blog",
    "url": "https://www.xsoftlimited.com/blog/",
    "description": "Technical articles on AI, Cloudflare Workers, SEO, and Chrome extensions.",
    "publisher": { "@type": "Organization", "name": "xSoft Ltd", "url": "https://www.xsoftlimited.com" }
  })} />

  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="animate-fade-in text-sm font-medium text-indigo-400 uppercase tracking-widest mb-4">Blog</p>
      <h1 class="animate-fade-in-up text-4xl sm:text-5xl font-black text-white">Technical Insights</h1>
      <p class="animate-fade-in-delay-1 mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Deep-dives on AI, edge computing, SEO, and browser extensions — from our real production experience.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8">

        <!-- RAG Chatbots -->
        <a href="/blog/building-rag-chatbots-cloudflare/" class="group p-6 rounded-2xl border border-gray-800 hover:border-indigo-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-0.5 rounded text-xs bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">AI</span>
            <span class="px-2 py-0.5 rounded text-xs bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">Cloudflare</span>
            <span class="px-2 py-0.5 rounded text-xs bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">RAG</span>
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-indigo-400 transition-colors">Building RAG Chatbots on Cloudflare Workers AI + Vectorize</h2>
          <p class="mt-2 text-sm text-gray-400">How we built Lex — an AI coach that answers questions using 1,000+ blog articles as its knowledge base. Architecture, embedding pipeline, and prompt engineering.</p>
          <div class="mt-3 flex items-center gap-3 text-xs text-gray-500">
            <time datetime="2026-07-15">15 Jul 2026</time>
            <span>·</span>
            <span>8 min read</span>
          </div>
        </a>

        <!-- SEO at Scale -->
        <a href="/blog/seo-at-scale-1000-pages/" class="group p-6 rounded-2xl border border-gray-800 hover:border-emerald-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">SEO</span>
            <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Content</span>
            <span class="px-2 py-0.5 rounded text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Automation</span>
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors">SEO at Scale — 1000 Pages in 30 Days</h2>
          <p class="mt-2 text-sm text-gray-400">The content strategy, topical clusters, automation tools, and technical SEO architecture behind deploying 1,000+ indexed pages within 8 weeks of launch.</p>
          <div class="mt-3 flex items-center gap-3 text-xs text-gray-500">
            <time datetime="2026-07-15">15 Jul 2026</time>
            <span>·</span>
            <span>7 min read</span>
          </div>
        </a>

        <!-- Chrome Extensions -->
        <a href="/blog/manifest-v3-chrome-extensions/" class="group p-6 rounded-2xl border border-gray-800 hover:border-cyan-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-0.5 rounded text-xs bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Chrome</span>
            <span class="px-2 py-0.5 rounded text-xs bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Extensions</span>
            <span class="px-2 py-0.5 rounded text-xs bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Manifest V3</span>
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">Manifest V3 Chrome Extensions — Concept to Web Store</h2>
          <p class="mt-2 text-sm text-gray-400">A practical guide to building Chrome extensions with Manifest V3. Service workers, permissions, storage, submission, and analytics without violating privacy.</p>
          <div class="mt-3 flex items-center gap-3 text-xs text-gray-500">
            <time datetime="2026-07-15">15 Jul 2026</time>
            <span>·</span>
            <span>6 min read</span>
          </div>
        </a>

        <!-- D1 vs KV -->
        <a href="/blog/cloudflare-d1-vs-kv/" class="group p-6 rounded-2xl border border-gray-800 hover:border-blue-500/50 bg-gray-900/30 hover:bg-gray-900/50 transition-all hover:-translate-y-1">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Cloudflare</span>
            <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Database</span>
            <span class="px-2 py-0.5 rounded text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20">Architecture</span>
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Cloudflare D1 vs KV — When to Use What</h2>
          <p class="mt-2 text-sm text-gray-400">A practical comparison of D1 (SQLite) and KV (key-value). When to choose each, performance characteristics, and the combined pattern we use in production.</p>
          <div class="mt-3 flex items-center gap-3 text-xs text-gray-500">
            <time datetime="2026-07-15">15 Jul 2026</time>
            <span>·</span>
            <span>5 min read</span>
          </div>
        </a>

      </div>
    </div>
  </section>

</Layout>
