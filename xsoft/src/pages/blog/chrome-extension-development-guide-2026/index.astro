            <p class="text-2xl font-bold text-indigo-400">V3</p>
            <p class="text-xs text-gray-400 mt-1">Manifest version (required)</p>
          </div>
          <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/50 text-center">
            <p class="text-2xl font-bold text-indigo-400">JS only</p>
            <p class="text-xs text-gray-400 mt-1">No framework needed</p>
          </div>
