---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
export const prerender = true;
---

<Layout title="Tech Stack — xSoft Ltd | Technologies We Build With" description="The technology stack behind xSoft's projects. Cloudflare Workers, Astro, Workers AI, D1, Vectorize, Tailwind CSS, TypeScript, Playwright, and more." keywords="tech stack, Cloudflare Workers, Astro, Workers AI, Vectorize, D1, Tailwind CSS, TypeScript">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "xSoft Tech Stack",
    "url": "https://www.xsoftlimited.com/tech-stack/",
    "description": "The technology stack behind xSoft's projects.",
    "publisher": { "@type": "Organization", "name": "xSoft Ltd" }
  })} />

  <section class="pt-10 pb-8 border-b border-gray-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-medium text-indigo-400 uppercase tracking-widest mb-3">Infrastructure</p>
      <h1 class="text-3xl sm:text-4xl font-black text-white">Tech Stack</h1>
      <p class="mt-3 text-gray-400">The tools, platforms, and services we use to build and deliver software for our clients.</p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Development & AI -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>🤖</span> Development & AI</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="https://kiro.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">⚡</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Kiro</p>
              <p class="text-xs text-gray-500 mb-1">kiro.dev</p>
              <p class="text-xs text-gray-400">AI-powered development environment. Our primary coding partner for building and maintaining all platforms.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/workers-ai/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🧠</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare Workers AI</p>
              <p class="text-xs text-gray-500 mb-1">LLM inference on the edge</p>
              <p class="text-xs text-gray-400">Llama 3, Kimi K2.6 models for chatbots. Sub-200ms inference with no cold starts. Powers our RAG chatbots.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/vectorize/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🔍</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare Vectorize</p>
              <p class="text-xs text-gray-500 mb-1">Vector database for RAG</p>
              <p class="text-xs text-gray-400">Stores 768-dimension embeddings for semantic search. Enables natural-language queries across knowledge bases.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/agents/communication-channels/voice/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🎙️</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare Voice Agents</p>
              <p class="text-xs text-gray-500 mb-1">@cloudflare/voice</p>
              <p class="text-xs text-gray-400">Real-time voice AI with STT (Flux), TTS, and LLM — all over WebSocket. Powers our voice assistant.</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Hosting & Infrastructure -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>☁️</span> Hosting & Infrastructure</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="https://workers.cloudflare.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">☁️</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare Workers</p>
              <p class="text-xs text-gray-500 mb-1">Edge serverless compute</p>
              <p class="text-xs text-gray-400">All our applications deploy to Workers. Sub-100ms TTFB globally, zero cold starts, auto-scaling.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/d1/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">💾</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare D1</p>
              <p class="text-xs text-gray-500 mb-1">Serverless SQLite database</p>
              <p class="text-xs text-gray-400">Full SQL with 5ms reads. Stores user data, SEO indexes, analytics, emails, and game state.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/kv/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">⚡</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare KV</p>
              <p class="text-xs text-gray-500 mb-1">Global key-value store</p>
              <p class="text-xs text-gray-400">Sub-millisecond reads for session tokens, cached API responses, and feature flags.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/email-routing/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">📧</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Cloudflare Email</p>
              <p class="text-xs text-gray-500 mb-1">Send + Route</p>
              <p class="text-xs text-gray-400">Transactional email via Workers Email binding. Routes inbound mail to Gmail.</p>
            </div>
          </a>
          <a href="https://github.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🐙</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">GitHub</p>
              <p class="text-xs text-gray-500 mb-1">Source control</p>
              <p class="text-xs text-gray-400">Version control, code hosting, and collaboration for all projects.</p>
            </div>
          </a>
          <a href="https://developers.cloudflare.com/workers/wrangler/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🔧</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Wrangler CLI</p>
              <p class="text-xs text-gray-500 mb-1">Deploy & manage</p>
              <p class="text-xs text-gray-400">Cloudflare's CLI for deploying Workers, managing D1 databases, and running local dev environments.</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Frameworks & Languages -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>⚡</span> Frameworks & Languages</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="https://astro.build/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🚀</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Astro 6.x</p>
              <p class="text-xs text-gray-500 mb-1">astro.build</p>
              <p class="text-xs text-gray-400">Content-driven web framework. SSR on Workers for dynamic pages, pre-render for static. Islands architecture.</p>
            </div>
          </a>
          <a href="https://tailwindcss.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🎨</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Tailwind CSS 4.x</p>
              <p class="text-xs text-gray-500 mb-1">tailwindcss.com</p>
              <p class="text-xs text-gray-400">Utility-first CSS for rapid, consistent styling. Dark themes, responsive design, no custom CSS needed.</p>
            </div>
          </a>
          <a href="https://www.typescriptlang.org/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">📘</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">TypeScript</p>
              <p class="text-xs text-gray-500 mb-1">typescriptlang.org</p>
              <p class="text-xs text-gray-400">Type-safe JavaScript for all API endpoints, middleware, and server logic. Catches bugs at compile time.</p>
            </div>
          </a>
          <a href="https://www.python.org/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🐍</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Python</p>
              <p class="text-xs text-gray-500 mb-1">Scripting & automation</p>
              <p class="text-xs text-gray-400">Build tools, content pipelines, SEO scripts, data processing, and embedding generation.</p>
            </div>
          </a>
          <a href="https://nodejs.org/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🟢</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Node.js 24</p>
              <p class="text-xs text-gray-500 mb-1">nodejs.org</p>
              <p class="text-xs text-gray-400">JavaScript runtime for build tooling, local development, and CLI scripts.</p>
            </div>
          </a>
          <a href="https://developer.chrome.com/docs/extensions/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🧩</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Chrome Manifest V3</p>
              <p class="text-xs text-gray-500 mb-1">Chrome Extensions API</p>
              <p class="text-xs text-gray-400">Browser extensions with service workers, chrome.storage, and content script injection.</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Testing & Quality -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>🛡️</span> Testing & Quality</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="https://playwright.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🎭</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Playwright</p>
              <p class="text-xs text-gray-500 mb-1">playwright.dev</p>
              <p class="text-xs text-gray-400">End-to-end browser testing. Automated regression suites that run against every feature change.</p>
            </div>
          </a>
          <a href="https://www.aikido.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-indigo-500/50 transition-all">
            <span class="text-2xl shrink-0">🥋</span>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors">Aikido Security</p>
              <p class="text-xs text-gray-500 mb-1">aikido.dev</p>
              <p class="text-xs text-gray-400">SAST scanning, secrets detection, and vulnerability analysis integrated into our development workflow.</p>
            </div>
          </a>
        </div>
      </div>

      <!-- SEO & Analytics -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>📈</span> SEO & Analytics</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">📊</span>
            <div>
              <p class="text-sm font-semibold text-white">Google Search Console</p>
              <p class="text-xs text-gray-400">Index monitoring, crawl status tracking, and search performance data for all our sites.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">📋</span>
            <div>
              <p class="text-sm font-semibold text-white">JSON-LD Structured Data</p>
              <p class="text-xs text-gray-400">Article, FAQPage, Organization, BreadcrumbList, and WebPage schemas on every page.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">🤖</span>
            <div>
              <p class="text-sm font-semibold text-white">llms.txt</p>
              <p class="text-xs text-gray-400">AI discoverability file for LLMs and search crawlers to understand site structure and services.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">🗺️</span>
            <div>
              <p class="text-sm font-semibold text-white">XML Sitemaps</p>
              <p class="text-xs text-gray-400">Auto-generated sitemaps with lastmod dates, priority, and changefreq for all public pages.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Authentication & Security -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>🔐</span> Authentication & Security</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">🔑</span>
            <div>
              <p class="text-sm font-semibold text-white">Google OAuth 2.0</p>
              <p class="text-xs text-gray-400">Admin authentication via Google accounts. Session cookies, 7-day expiry, role-based access.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
            <span class="text-2xl shrink-0">🛡️</span>
            <div>
              <p class="text-sm font-semibold text-white">Cloudflare Security</p>
              <p class="text-xs text-gray-400">DDoS protection, WAF, SSL/TLS, and bot management — all automatic via Cloudflare's edge.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-12 p-6 rounded-2xl bg-gradient-to-r from-indigo-950/30 to-blue-950/20 border border-indigo-500/30 text-center">
        <h3 class="text-xl font-bold text-white">Want us to build with this stack for you?</h3>
        <p class="mt-2 text-sm text-gray-400">Enterprise-grade infrastructure, delivered in weeks not months.</p>
        <a href="/contact/" class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-all">
          Start a Project →
        </a>
      </div>

    </div>
  </section>

</Layout>
