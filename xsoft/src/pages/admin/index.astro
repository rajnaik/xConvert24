---
import '../../styles/global.css';
export const prerender = false;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — xSoft Ltd</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <!-- Admin Nav -->
  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/admin/" class="text-lg font-bold bg-gradient-to-r from-indigo-400 to-blue-400 bg-clip-text text-transparent">xSoft Admin</a>
      <a href="/admin/emails/" class="text-sm text-gray-400 hover:text-indigo-400 transition-colors">Emails</a>
    </div>
    <div class="flex items-center gap-4">
      <a href="/" class="text-sm text-gray-500 hover:text-white transition-colors">← Site</a>
      <a href="/api/auth/logout/" class="text-sm text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </nav>

  <!-- Dashboard -->
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-white mb-8">Dashboard</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Emails Tile -->
      <a href="/admin/emails/" class="group p-6 rounded-2xl border border-gray-800 hover:border-indigo-500/50 bg-gray-900/50 hover:bg-gray-900/80 transition-all hover:-translate-y-1">
        <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">📧</span>
        </div>
        <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Emails</h3>
        <p class="mt-1 text-sm text-gray-400">View and manage contact form submissions</p>
      </a>

      <!-- SEO Tile -->
      <a href="/admin/seo/" class="group p-6 rounded-2xl border border-gray-800 hover:border-emerald-500/50 bg-gray-900/50 hover:bg-gray-900/80 transition-all hover:-translate-y-1">
        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">📈</span>
        </div>
        <h3 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors">SEO Index</h3>
        <p class="mt-1 text-sm text-gray-400">View and manage page SEO tags and index status</p>
      </a>

      <!-- Site Tile (link to live site) -->
      <a href="https://www.xsoftlimited.com/" target="_blank" rel="noopener" class="group p-6 rounded-2xl border border-gray-800 hover:border-blue-500/50 bg-gray-900/50 hover:bg-gray-900/80 transition-all hover:-translate-y-1">
        <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">🌐</span>
        </div>
        <h3 class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Live Site</h3>
        <p class="mt-1 text-sm text-gray-400">Open xsoftlimited.com in a new tab</p>
      </a>

      <!-- Case Studies -->
      <a href="/case-studies/" class="group p-6 rounded-2xl border border-gray-800 hover:border-emerald-500/50 bg-gray-900/50 hover:bg-gray-900/80 transition-all hover:-translate-y-1">
        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">📂</span>
        </div>
        <h3 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors">Case Studies</h3>
        <p class="mt-1 text-sm text-gray-400">View published portfolio pages</p>
      </a>
    </div>

    <!-- Quick Stats -->
    <div class="mt-12 p-6 rounded-2xl border border-gray-800 bg-gray-900/30">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Info</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-xl font-bold text-indigo-400" id="email-count">—</p>
          <p class="text-xs text-gray-500">Enquiries</p>
        </div>
        <div>
          <p class="text-xl font-bold text-blue-400">11</p>
          <p class="text-xs text-gray-500">Pages</p>
        </div>
        <div>
          <p class="text-xl font-bold text-emerald-400">3</p>
          <p class="text-xs text-gray-500">Case Studies</p>
        </div>
        <div>
          <p class="text-xl font-bold text-amber-400">4</p>
          <p class="text-xs text-gray-500">Services</p>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (async () => {
      try {
        const res = await fetch('/api/emails/?count=true');
        if (res.ok) {
          const data = await res.json();
          document.getElementById('email-count').textContent = data.count ?? '0';
        }
      } catch {}
    })();
  </script>
</body>
</html>
