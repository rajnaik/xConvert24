{
  "name": "xconvert24-com",
  "type": "module",
  "version": "1.21.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --remote",
    "dev:local": "astro dev",
    "preview": "astro build && astro preview",
    "build": "astro build",
    "deploy": "astro build && npx wrangler deploy",
    "deploy:staging": "astro build && node scripts/deploy-to-staging.mjs",
    "deploy:pipeline": "bash scripts/deploy-staging.sh",
    "test": "npx playwright test",
    "test:deploy": "bash scripts/post-deploy-test.sh",
    "test:deploy:staging": "bash scripts/post-deploy-test.sh https://staging.xconvert24.com",
    "test:mobile": "npx playwright test tests/mobile-hamburger.spec.ts",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "astro-mcp": "^0.4.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "wrangler": "^4.97.0"
  }
}
