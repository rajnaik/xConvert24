{
  "name": "scrabblewordsfinder-com",
  "type": "module",
  "version": "1.14.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --remote",
    "dev:local": "astro dev",
    "prebuild": "node scripts/generate-pagemap.mjs",
    "build": "astro build",
    "deploy": "npm run build && npx wrangler deploy",
    "deploy:staging": "npm run build && node scripts/deploy-to-staging.mjs",
    "astro": "astro",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.6.1",
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@xyflow/react": "^12.11.1",
    "astro": "6.4.4",
    "d3-force": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/d3-force": "^3.0.10",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "vite": "7.3.5"
  }
}
