    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.6.1",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.4",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "wrangler": "4.97.0"
  },
  "overrides": {
    "vite": "7.3.5"
  }
}
