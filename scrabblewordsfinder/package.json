{
  "name": "scrabblewordsfinder-com",
  "type": "module",
  "version": "1.20.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --remote",
    "dev:local": "astro dev",
    "prebuild": "node scripts/generate-pagemap.mjs",
    "build": "astro build",
    "deploy": "npm run build && npx wrangler deploy",
    "deploy:staging": "npm run build && node scripts/deploy-to-staging.mjs",
    "seo:write": "node scripts/seo-write-to-pages.cjs",
    "seo:seed": "node scripts/seed-seo-index.cjs",
    "astro": "astro",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:smoke": "npx playwright test tests/smoke.spec.ts --reporter=list",
    "test:quick": "npx playwright test tests/quick/ --reporter=list",
    "test:ai": "npx playwright test tests/api/chat-api.spec.ts tests/api/lex-chat.spec.ts tests/api/lex-quiz-coach.spec.ts tests/api/lex-anagram-coach.spec.ts tests/api/lex-solve.spec.ts tests/api/chat-bingo-words.spec.ts --reporter=list",
    "test:diamonds": "npx playwright test tests/DiamondHunt/ --reporter=list",
    "test:live:smoke": "SWF_TEST_URL=https://www.scrabblewordsfinder.com npx playwright test tests/smoke.spec.ts --reporter=list",
    "test:live:quick": "SWF_TEST_URL=https://www.scrabblewordsfinder.com npx playwright test tests/quick/ --reporter=list",
    "test:live:ai": "SWF_TEST_URL=https://www.scrabblewordsfinder.com npx playwright test tests/api/chat-api.spec.ts tests/api/lex-chat.spec.ts tests/api/lex-quiz-coach.spec.ts tests/api/lex-anagram-coach.spec.ts tests/api/lex-solve.spec.ts tests/api/chat-bingo-words.spec.ts --reporter=list",
    "test:live:diamonds": "SWF_TEST_URL=https://www.scrabblewordsfinder.com npx playwright test tests/DiamondHunt/ --reporter=list",
    "test:live:ai-full": "SWF_TEST_URL=https://www.scrabblewordsfinder.com npx playwright test --project=live-ai --reporter=list"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.6.1",
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@xyflow/react": "^12.11.1",
    "animal-avatar-generator": "^1.2.0",
    "astro": "6.4.4",
    "d3-force": "^3.0.0",
    "jspdf": "2.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/d3-force": "^3.0.10",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "vite": "7.3.5"
  }
}
