      function initSearch(inputId, findBtnId) {
        var input = document.getElementById(inputId);
        if (!input) return;
        var resultsBox = null;

        function createResultsBox() {
          if (resultsBox) return resultsBox;
          resultsBox = document.createElement('div');
          resultsBox.className = 'absolute top-full left-0 mt-1 bg-gray-800 border border-gray-700 rounded-lg shadow-xl z-50 max-h-56 overflow-y-auto hidden';
          resultsBox.style.width = inputId === 'dict-search' ? '280px' : '100%';
          input.parentElement.appendChild(resultsBox);
          return resultsBox;
        }

        function doSearch() {
          var q = input.value.trim().toLowerCase();
          var box = createResultsBox();
          if (q.length < 2) { box.classList.add('hidden'); return; }
          var matches = PAGES.filter(function(p) {
            return p.t.toLowerCase().includes(q) || p.d.toLowerCase().includes(q) || p.u.toLowerCase().includes(q);
          }).slice(0, 12);
          if (matches.length === 0) {
            box.innerHTML = '<div class="px-3 py-2 text-xs text-gray-500">No results — press Enter to search all blog posts</div>';
          } else {
            box.innerHTML = matches.map(function(p) {
              var href = p.u.endsWith('/') ? p.u : p.u + '/';
              return '<a href="' + href + '" class="block px-3 py-2 hover:bg-blue-900/30 transition-colors border-b border-gray-700/50 last:border-0"><span class="text-xs font-medium text-gray-200 block">' + p.t + '</span><span class="text-xs text-gray-500">' + p.d + '</span></a>';
            }).join('');
          }
          box.classList.remove('hidden');
        }

        var debounce = null;
        input.addEventListener('input', function() {
          clearTimeout(debounce);
          debounce = setTimeout(doSearch, 150);
        });

        input.addEventListener('focus', function() {
          if (input.value.trim().length >= 2) doSearch();
        });

        // Find button navigates to blog with search query
        var findBtn = document.getElementById(findBtnId);
        if (findBtn) {
          findBtn.addEventListener('click', function(e) {
            var q = input.value.trim();
            if (q.length >= 2) {
              e.preventDefault();
              window.location.href = '/blog?q=' + encodeURIComponent(q);
            }
          });
        }

        // Close on click outside
        document.addEventListener('click', function(e) {
          if (resultsBox && !input.contains(e.target) && !resultsBox.contains(e.target) && (!findBtn || !findBtn.contains(e.target))) {
            resultsBox.classList.add('hidden');
          }
        });

        input.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && resultsBox) resultsBox.classList.add('hidden');
          if (e.key === 'Enter') {
            var q = input.value.trim();
            if (q.length >= 2) window.location.href = '/blog?q=' + encodeURIComponent(q);
          }
        });
      }

      // Init both desktop and mobile search inputs
      initSearch('dict-search', 'search-find-btn');
      initSearch('dict-search-mobile', 'search-find-btn-mobile');
    })();
    </script>

    <!-- Global storage helpers with TTL support (available to all inline scripts) -->
    <script is:inline>
    (function() {
      window.__swfStore = {
        setWithExpiry: function(key, value, expiresAt) {
          try { localStorage.setItem(key, JSON.stringify({ value: value, expiresAt: expiresAt })); } catch(e) {}
        },
        getIfValid: function(key) {
          try {
            var raw = localStorage.getItem(key);
            if (!raw) return null;
            var envelope = JSON.parse(raw);
            if (envelope && envelope.expiresAt && new Date(envelope.expiresAt).getTime() <= Date.now()) {
              localStorage.removeItem(key);
              return null;
            }
            return envelope && envelope.value !== undefined ? envelope.value : null;
          } catch(e) { localStorage.removeItem(key); return null; }
        },
        setItem: function(key, value) {
          try { localStorage.setItem(key, JSON.stringify({ value: value })); } catch(e) {}
        },
        getItem: function(key) { return window.__swfStore.getIfValid(key); },
        removeItem: function(key) { try { localStorage.removeItem(key); } catch(e) {} },
        setRaw: function(key, value) { try { localStorage.setItem(key, value); } catch(e) {} },
        getRaw: function(key) { try { return localStorage.getItem(key); } catch(e) { return null; } },
        purgeExpired: function() {
          var purged = 0;
          try {
            for (var i = localStorage.length - 1; i >= 0; i--) {
              var key = localStorage.key(i);
              if (!key) continue;
              var raw = localStorage.getItem(key);
              if (!raw) continue;
              try {
                var envelope = JSON.parse(raw);
                if (envelope && envelope.expiresAt && new Date(envelope.expiresAt).getTime() <= Date.now()) {
                  localStorage.removeItem(key);
                  purged++;
                }
              } catch(e) {}
            }
          } catch(e) {}
          return purged;
        },
        getNextMidnightUTC: function() {
          var t = new Date();
          t.setUTCDate(t.getUTCDate() + 1);
          t.setUTCHours(0, 0, 0, 0);
          return t.toISOString();
        },
        has: function(key) { return window.__swfStore.getIfValid(key) !== null; }
      };
      // Purge expired items on every page load
      window.__swfStore.purgeExpired();
    })();
    </script>

    <slot />

    <!-- Heartbeat — pings /api/heartbeat/ every 30s for live session tracking -->
    <script is:inline>
    (function() {
      if (window.location.pathname.startsWith('/admin')) return;

      var S = window.__swfStore;
      var UID_KEY = 'swf-uid';
      function getUid() {
        try {
          var uid = S.getRaw(UID_KEY);
          if (!uid) {
            uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
            S.setRaw(UID_KEY, uid);
          }
          return uid;
        } catch(e) {
          return 'anon_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
        }
      }

      function sendHeartbeat() {
        try {
          var payload = JSON.stringify({
            uid: getUid(),
            page: window.location.pathname
          });
          if (navigator.sendBeacon) {
            navigator.sendBeacon('/api/heartbeat/', new Blob([payload], { type: 'application/json' }));
          } else {
            fetch('/api/heartbeat/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: payload,
              keepalive: true
            }).catch(function() {});
          }
        } catch(e) {}
      }

      // Send immediately on page load, then every 30 seconds
      sendHeartbeat();
      setInterval(sendHeartbeat, 30000);

      // Also send on page visibility change (user returns to tab)
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'visible') sendHeartbeat();
      });
    })();
    </script>

