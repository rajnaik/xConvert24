    <script is:inline>
    // Admin message modal dismiss + clear
    (function() {
      var dismissBtn = document.getElementById('admin-message-dismiss');
      var modal = document.getElementById('admin-message-modal');
      if (!dismissBtn || !modal) return;

      function dismiss() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        // Clear message on the server so user doesn't see it again
        var uid = localStorage.getItem('swf-uid');
        if (uid) {
          fetch('/api/users/message-read/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: uid })
          }).catch(function() {});
        }
      }

      dismissBtn.addEventListener('click', dismiss);
      modal.addEventListener('click', function(e) {
        if (e.target === modal) dismiss();
      });
    })();
    </script>

