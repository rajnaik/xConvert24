---
import packageJson from '../../package.json';
import CookieConsent from "../components/CookieConsent.astro";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  showHeader?: boolean;
  showSectionLinks?: boolean;
}

const VERSION = packageJson.version;
const { title, description = 'Free Scrabble Word Finder — find the highest-scoring words from your tiles instantly. No sign-up needed.', keywords = 'scrabble word finder, scrabble solver, word finder, scrabble cheat, anagram solver' , showHeader = true, showSectionLinks = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://www.scrabblewordsfinder.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {Astro.url.pathname.startsWith('/admin') && <meta name="robots" content="noindex, nofollow" />}
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ScrabbleWordsFinder.com" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content="https://scrabblewordsfinder.com/social-card.svg" />
    <meta name="twitter:image" content="https://scrabblewordsfinder.com/social-card.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100 antialiased">
    {showHeader && (
    <header class="mx-auto max-w-6xl px-6 pt-3 mb-4">
      <div class="grid grid-cols-[auto_1fr] grid-rows-3 gap-x-3 gap-y-0">
        <a href="/" class="row-span-3 flex items-start">
          <img id="site-logo" src="/logo-options/option-1.svg" alt="ScrabbleWordsFinder" class="h-[268px] w-[268px] rounded-lg" />
        </a>
        <div class="flex items-center gap-3 pt-1 whitespace-nowrap overflow-x-auto text-sm justify-end">
          <span class="text-gray-400 shrink-0"><span class="text-blue-400">Free, Fast, No-Sign Up</span> — Scrabble Words Finder</span>
          <a href="/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔍 Solver</a>
          <a href="/guide" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">📘 Guide</a>
          <a href="/about" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">ℹ️ About</a>
          <a href="/privacy" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔒 Privacy</a>
          <a href="/contact" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">✉️ Contact</a>
          <a href="/suggest" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">💡 Suggest</a>
          <a href="/settings" class="text-gray-500 hover:text-purple-400 transition-colors shrink-0">⚙️</a>
        </div>
        <a id="hero-banner-link" href="/" class="block cursor-pointer self-end">
          <img id="hero-banner-img" src="/banner-options/banner-1.svg" alt="Scrabble Word Finder" class="w-full h-auto max-h-[80px] object-cover rounded-lg" />
        </a>
        <!-- Row 3, Col 2: Section quick-links (only on solver page) -->
        {showSectionLinks && <div class="flex flex-wrap items-center gap-2 pt-2 pb-1">
          <a href="#section-probability" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🎲 Probability</a>
          <a href="#section-rack-leave" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🧮 Rack Leave</a>
          <a href="#section-best-opening" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🏆 Openers</a>
          <a href="#section-two-letter" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🔤 Two-Letter Words</a>
          <a href="#section-rare-letters" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">💎 Rare Letters</a>
          <a href="#section-three-letter" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🏆 Top 3-Letter</a>
          <a href="#section-q-no-u" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-gray-800 text-xs font-medium text-gray-400 hover:bg-blue-900/30 hover:text-blue-400 transition-colors">🅀 Q Without U</a>
        </div>}
      </div>
    </header>
    )}
    <slot />

    <!-- Global click tracker — captures ALL interactive element clicks to /api/clicks -->
    <script is:inline>
    (function() {
      var UID_KEY = 'swf-uid';
      function getUid() {
        try {
          var uid = localStorage.getItem(UID_KEY);
          if (!uid) {
            uid = 'u_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
            localStorage.setItem(UID_KEY, uid);
          }
          return uid;
        } catch(e) {
          return 'anon_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
        }
      }

      function describeElement(el) {
        return el.getAttribute('aria-label')
          || el.getAttribute('data-track')
          || el.getAttribute('title')
          || (el.textContent || '').trim().slice(0, 60)
          || el.getAttribute('id')
          || el.getAttribute('name')
          || el.tagName.toLowerCase();
      }

      var INTERACTIVE = 'a, button, [role="button"], input[type="submit"], input[type="button"], [data-track], summary, [onclick]';

      document.addEventListener('click', function(e) {
        var el = e.target.closest ? e.target.closest(INTERACTIVE) : null;
        if (!el) return;

        var uid = getUid();
        var pageUrl = window.location.pathname + window.location.search;
        var element = describeElement(el);

        var payload = JSON.stringify({
          user_id: uid,
          ui_element: element,
          url: pageUrl
        });

        try {
          fetch('/api/clicks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true
          }).catch(function() {});
          return;
        } catch(e) {}

        try {
          if (navigator.sendBeacon) {
            navigator.sendBeacon('/api/clicks', new Blob([payload], { type: 'application/json' }));
            return;
          }
        } catch(e) {}

        try {
          var xhr = new XMLHttpRequest();
          xhr.open('POST', '/api/clicks', true);
          xhr.setRequestHeader('Content-Type', 'application/json');
          xhr.send(payload);
        } catch(e2) {}
      });
    })();
    </script>
    <!-- Live click counter — fetches total on load, increments optimistically -->
    <script is:inline>
    (function() {
      var counterEl = document.getElementById('total-clicks-value');
      if (!counterEl) return;
      var currentCount = 0;

      fetch('/api/clicks?count=true')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          currentCount = data.total || 0;
          counterEl.textContent = currentCount.toLocaleString();
        })
        .catch(function() { counterEl.textContent = '—'; });

      var INTERACTIVE = 'a, button, [role="button"], input[type="submit"], input[type="button"], [data-track], summary, [onclick]';
      document.addEventListener('click', function(e) {
        var el = e.target.closest(INTERACTIVE);
        if (!el) return;
        currentCount++;
        counterEl.textContent = currentCount.toLocaleString();
      });
    })();
    </script>
    <!-- Version stamp -->
    <div class="fixed bottom-2 right-2 z-40 hidden sm:block">
      <a href="/releases" class="flex flex-col items-end leading-none shrink-0 opacity-60 hover:opacity-100 transition-opacity" title={`Version ${VERSION}`} style="font-size:8px;">
        <span class="text-blue-400 font-mono">v{VERSION}</span>
        <span class="text-gray-500 font-mono mt-0.5">{new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}).replace(/ /g,'').toUpperCase()}</span>
      </a>
    </div>
    <!-- Footer -->
    <footer class="border-t border-gray-800 px-6 py-8 mt-16">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-sm text-gray-500">&copy; 2025 ScrabbleWordsFinder.com</p>
        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
          <a href="/guide" class="hover:text-blue-400 transition-colors">Guide</a>
          <a href="/about" class="hover:text-blue-400 transition-colors">About</a>
          <a href="/privacy" class="hover:text-blue-400 transition-colors">Privacy</a>
          <a href="/contact" class="hover:text-blue-400 transition-colors">Contact</a>
          <a href="/disclaimer" class="hover:text-blue-400 transition-colors">Disclaimer</a>
          <a href="/terms" class="hover:text-blue-400 transition-colors">Terms</a>
          <a href="/suggest" class="hover:text-blue-400 transition-colors">Suggest</a>
        </div>
      </div>
      <!-- Clicks stats bar -->
      <div class="mx-auto max-w-6xl mt-4 pt-4 border-t border-purple-800/50 flex items-center justify-center gap-4">
        <span id="footer-clicks" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-purple-700 bg-purple-950/30 text-xs font-mono text-purple-300">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
          <span id="footer-clicks-value">—</span> clicks
        </span>
      </div>
    </footer>
    <script is:inline>
      function updateClickCounter() {
        fetch('/api/clicks?count=true')
          .then(function(r){ return r.json(); })
          .then(function(d){
            var el = document.getElementById('footer-clicks-value');
            if (el && d.total !== undefined) el.textContent = d.total.toLocaleString();
          })
          .catch(function(){});
      }
      updateClickCounter();
      setInterval(updateClickCounter, 2000);
    </script>

    
    <script>
      (async function loadSiteAssets() {
        try {
          const res = await fetch("/api/site-status");
          if (res.ok) {
            const data = await res.json();
            const logoImg = document.getElementById("site-logo");
            if (logoImg) logoImg.setAttribute("src", "/logo-options/option-" + (data.logo_option || 1) + ".svg");
          }
        } catch {}
        try {
          const bres = await fetch("/api/banners?active=true");
          if (bres.ok) {
            const bdata = await bres.json();
            const banners = bdata.banners || [];
            if (banners.length > 0) {
              const picked = banners[Math.floor(Math.random() * banners.length)];
              const bimg = document.getElementById("hero-banner-img");
              if (bimg) bimg.setAttribute("src", "/banner-options/banner-" + picked.option_number + ".svg");
            }
          }
        } catch {}

        // Attach banner click tracker
        const bannerLink = document.getElementById('hero-banner-link');
        const bannerImg = document.getElementById('hero-banner-img');
        if (bannerLink && bannerImg) {
          bannerLink.addEventListener('click', async (e) => {
            e.preventDefault();
            const bannerId = bannerImg.getAttribute('src')?.match(/banner-(\d+)/)?.[1] || '1';
            try {
              await fetch('/api/banner-click', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ banner_id: 'banner-' + bannerId, page_url: window.location.pathname }),
              });
            } catch {}
            window.location.href = '/';
          });
        }
      })();
    </script>
    <CookieConsent />
    <script is:inline>
    (function(){
      // Don't track clicks on admin pages
      if(window.location.pathname.startsWith("/admin"))return;

      function getSessionId(){let s=sessionStorage.getItem("swf_session_id");if(!s){s=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);sessionStorage.setItem("swf_session_id",s)}return s}
      function getUserId(){let u=localStorage.getItem("swf_user_id");if(!u){u=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);localStorage.setItem("swf_user_id",u)}return u}
      function getDevice(){var a=navigator.userAgent;if(/tablet|ipad|playbook|silk/i.test(a))return"tablet";if(/mobile|iphone|ipod|android.*mobile|windows phone/i.test(a))return"mobile";return"desktop"}
      function getBrowser(){var a=navigator.userAgent;if(a.includes("Firefox/"))return"Firefox";if(a.includes("Edg/"))return"Edge";if(a.includes("Chrome/")&&!a.includes("Edg/"))return"Chrome";if(a.includes("Safari/")&&!a.includes("Chrome"))return"Safari";return"Other"}
      function getOS(){var a=navigator.userAgent;if(a.includes("Windows"))return"Windows";if(a.includes("Mac OS"))return"macOS";if(a.includes("Android"))return"Android";if(/iPhone|iPad|iPod/.test(a))return"iOS";if(a.includes("Linux"))return"Linux";return"Other"}
      document.addEventListener("click",function(e){
        var t=e.target;
        var name=t.getAttribute("data-track")||(t.closest("[data-track]")||{}).getAttribute&&t.closest("[data-track]")&&t.closest("[data-track]").getAttribute("data-track")||(t.closest("a")||{textContent:""}).textContent&&t.closest("a")&&t.closest("a").textContent.trim().slice(0,60)||(t.closest("button")||{textContent:""}).textContent&&t.closest("button")&&t.closest("button").textContent.trim().slice(0,60)||t.tagName;
        // Skip refresh/poll-related clicks
        if(name==="🔄 Refresh"||name==="refresh"||name==="Refresh")return;
        fetch("/api/clicks",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({user_id:getUserId(),ui_element:name,url:window.location.pathname,session_id:getSessionId(),screen_width:window.screen.width,screen_height:window.screen.height,viewport_width:window.innerWidth,viewport_height:window.innerHeight,click_x:e.clientX,click_y:e.clientY,page_title:document.title,device_type:getDevice(),browser:getBrowser(),os:getOS()})}).catch(function(){});
      });
    })();
    </script>
  </body>
</html>
