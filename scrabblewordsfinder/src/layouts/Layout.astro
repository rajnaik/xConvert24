    <!-- Diamond Mine — hidden collectible diamonds on pages -->
    <script is:inline>
    (function() {
      if (window.location.pathname.startsWith('/admin')) return;

      var S = window.__swfStore;
      var page = window.location.pathname;
      var uid = S ? S.getRaw('swf-uid') : localStorage.getItem('swf-uid');

      function getOrCreateUid() {
        var u = S ? S.getRaw('swf-uid') : localStorage.getItem('swf-uid');
        if (!u) {
          u = 'swf-' + Date.now() + '-' + Math.random().toString(36).slice(2, 10);
          try { localStorage.setItem('swf-uid', u); } catch(e) {}
        }
        return u;
      }

      // Check if there's an active diamond mine on this page
      var url = '/api/diamond-hunt-claim/?page=' + encodeURIComponent(page) + (uid ? '&user_id=' + encodeURIComponent(uid) : '');
      fetch(url).then(function(r) { return r.json(); }).then(function(data) {
        var diamonds = data.diamonds || [];
        if (diamonds.length === 0) return;

        // Show the first unclaimed AND non-depleted diamond
        var target = null;
        for (var i = 0; i < diamonds.length; i++) {
          if (!diamonds[i].already_claimed && !diamonds[i].depleted) { target = diamonds[i]; break; }
        }

        // If all claimed or depleted, do nothing (no badge)
        if (!target) return;

        // Render the diamond mine element — mine is active, clear any stale mined timestamp
        try { localStorage.removeItem('dm-mined-' + page); } catch(e) {}
        var el = document.createElement('div');
        el.id = 'diamond-mine-' + target.id;
        el.className = 'diamond-mine-gem';
        el.setAttribute('role', 'button');
        el.setAttribute('aria-label', 'Hidden diamond — click to claim ' + target.diamonds_per_claim + ' diamonds');
        el.setAttribute('tabindex', '0');
        el.innerHTML = '<span class="dm-icon">💎</span><span class="dm-label">Find!</span>';
        el.title = 'You found a hidden diamond! Click to claim ' + target.diamonds_per_claim + ' 💎';

        // Style it
        var style = document.createElement('style');
        style.textContent = '.diamond-mine-gem{position:fixed;bottom:24px;left:24px;z-index:9999;display:flex;align-items:center;gap:6px;padding:10px 16px;border-radius:16px;background:linear-gradient(135deg,#1a0533,#2d1b69);border:2px solid rgba(168,85,247,0.6);box-shadow:0 0 20px rgba(168,85,247,0.3),0 4px 12px rgba(0,0,0,0.5);cursor:pointer;transition:all .3s;animation:dm-pulse 2s infinite}' +
          '.diamond-mine-gem:hover{transform:scale(1.1);border-color:rgba(168,85,247,0.9);box-shadow:0 0 30px rgba(168,85,247,0.5),0 6px 16px rgba(0,0,0,0.6)}' +
          '.dm-icon{font-size:24px;animation:dm-sparkle 1.5s ease-in-out infinite}' +
          '.dm-label{color:#c4b5fd;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px}' +
          '@keyframes dm-pulse{0%,100%{box-shadow:0 0 20px rgba(168,85,247,0.3),0 4px 12px rgba(0,0,0,0.5)}50%{box-shadow:0 0 30px rgba(168,85,247,0.5),0 6px 16px rgba(0,0,0,0.6)}}' +
          '@keyframes dm-sparkle{0%,100%{transform:scale(1) rotate(0)}50%{transform:scale(1.15) rotate(5deg)}}' +
          '.dm-claimed{animation:none!important;border-color:rgba(34,197,94,0.6)!important;background:linear-gradient(135deg,#052e16,#14532d)!important;box-shadow:0 0 20px rgba(34,197,94,0.3),0 4px 12px rgba(0,0,0,0.5)!important}' +
          '.dm-claimed .dm-icon{animation:none!important}';
        document.head.appendChild(style);
        document.body.appendChild(el);

        // Claim handler
        function claimDiamond() {
          el.removeEventListener('click', claimDiamond);
          el.removeEventListener('keydown', claimKeyHandler);
          el.innerHTML = '<span class="dm-icon">⏳</span><span class="dm-label">Claiming...</span>';

          var claimUid = getOrCreateUid();
          fetch('/api/diamond-hunt-claim/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ diamond_id: target.id, user_id: claimUid })
          }).then(function(r) { return r.json(); }).then(function(result) {
            if (result.success) {
              // Record claim timestamp for 1h mined badge
              try { localStorage.setItem('dm-mined-' + page, String(Date.now())); } catch(e) {}
              el.classList.add('dm-claimed');
              el.innerHTML = '<span class="dm-icon">✅</span><span class="dm-label">+' + result.diamonds_earned + ' 💎</span>';
              // Remove after 4 seconds
              setTimeout(function() { el.remove(); }, 4000);
            } else {
              el.innerHTML = '<span class="dm-icon">❌</span><span class="dm-label">' + (result.error || 'Failed') + '</span>';
              setTimeout(function() { el.remove(); }, 3000);
            }
          }).catch(function() {
            el.innerHTML = '<span class="dm-icon">❌</span><span class="dm-label">Error</span>';
            setTimeout(function() { el.remove(); }, 3000);
          });
        }

        function claimKeyHandler(e) { if (e.key === 'Enter' || e.key === ' ') claimDiamond(); }

        el.addEventListener('click', claimDiamond);
        el.addEventListener('keydown', claimKeyHandler);
      }).catch(function() {});
    })();
    </script>

    <script is:inline>
    (function(){
      // Don't track clicks on admin pages
      if(window.location.pathname.startsWith("/admin"))return;

      function getSessionId(){let s=sessionStorage.getItem("swf_session_id");if(!s){s=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);sessionStorage.setItem("swf_session_id",s)}return s}
      function getUserId(){let u=window.__swfStore.getRaw("swf_user_id");if(!u){u=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);window.__swfStore.setRaw("swf_user_id",u)}return u}
      function getDevice(){var a=navigator.userAgent;if(/tablet|ipad|playbook|silk/i.test(a))return"tablet";if(/mobile|iphone|ipod|android.*mobile|windows phone/i.test(a))return"mobile";return"desktop"}
      function getBrowser(){var a=navigator.userAgent;if(a.includes("Firefox/"))return"Firefox";if(a.includes("Edg/"))return"Edge";if(a.includes("Chrome/")&&!a.includes("Edg/"))return"Chrome";if(a.includes("Safari/")&&!a.includes("Chrome"))return"Safari";return"Other"}
      function getOS(){var a=navigator.userAgent;if(a.includes("Windows"))return"Windows";if(a.includes("Mac OS"))return"macOS";if(a.includes("Android"))return"Android";if(/iPhone|iPad|iPod/.test(a))return"iOS";if(a.includes("Linux"))return"Linux";return"Other"}
      document.addEventListener("click",function(e){
        var t=e.target;
        var name=t.getAttribute("data-track")||(t.closest("[data-track]")||{}).getAttribute&&t.closest("[data-track]")&&t.closest("[data-track]").getAttribute("data-track")||(t.closest("a")||{textContent:""}).textContent&&t.closest("a")&&t.closest("a").textContent.trim().slice(0,60)||(t.closest("button")||{textContent:""}).textContent&&t.closest("button")&&t.closest("button").textContent.trim().slice(0,60)||t.tagName;
        // Skip refresh/poll-related clicks and noise elements
        if(name==="🔄 Refresh"||name==="refresh"||name==="Refresh"||name==="SPAN"||name==="DIV"||name==="IMG"||name==="P"||name==="INPUT"||name==="TEXTAREA"||name==="svg"||name==="path"||name==="SVG"||name==="LABEL"||name===">"||name==="✕")return;
        // Append current solver word to SolverUsed events
        if(name==="SolverUsed"){var sw=document.getElementById("text-solver");if(sw&&sw.value.trim())name="SolverUsed-"+sw.value.trim().toUpperCase();}
        fetch("/api/clicks/",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({user_id:getUserId(),ui_element:name,url:window.location.pathname,session_id:getSessionId(),screen_width:window.screen.width,screen_height:window.screen.height,viewport_width:window.innerWidth,viewport_height:window.innerHeight,click_x:e.clientX,click_y:e.clientY,page_title:document.title,device_type:getDevice(),browser:getBrowser(),os:getOS()})}).catch(function(){});
      });
    })();
    </script>
  </body>
