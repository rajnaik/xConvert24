---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = 'ScrabbleWordsFinder.com Blog — free tips, strategy, and history for Scrabble players.', keywords = 'scrabble, word finder, scrabble strategy, scrabble tips' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://www.scrabblewordsfinder.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ScrabbleWordsFinder.com" />
    <meta property="og:image" content="https://www.scrabblewordsfinder.com/social-card.svg" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.scrabblewordsfinder.com/social-card.svg" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18216393264"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18216393264');
      gtag('config', 'G-HYBGD6YJHW');
    </script>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100 antialiased">
    <!-- Shared header -->
    <header class="mx-auto max-w-6xl px-4 sm:px-6 pt-3 mb-0">
      <div class="grid grid-cols-1 sm:grid-cols-[auto_1fr] sm:grid-rows-3 gap-x-3 gap-y-0">
        <a href="/" class="sm:row-span-3 flex items-center sm:items-start justify-center sm:justify-start mb-1 sm:mb-0">
          <img id="site-logo" src="/logo-options/option-1.svg" alt="ScrabbleWordsFinder" class="h-16 w-16 sm:h-[188px] sm:w-[188px] rounded-lg" />
        </a>
        <div class="flex items-center gap-2 sm:gap-3 whitespace-nowrap overflow-x-auto text-xs sm:text-sm justify-center sm:justify-end">
          <span class="text-gray-400 shrink-0"><span class="text-blue-400">Free, Fast, No-Sign Up</span></span>
          <a href="/guide" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">📘 Guide</a>
          <a href="/about" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">ℹ️ About</a>
          <a href="/privacy" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔒 Privacy</a>
          <a href="/contact" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">✉️ Contact</a>
          <a href="/suggest" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">💡 Suggest</a>
        </div>
        <a id="blog-banner-link" href="/" class="block cursor-pointer self-start sm:-mt-[15px]">
          <img id="blog-banner-img" src="/banner-options/banner-1.svg" alt="Scrabble Word Finder" class="w-full h-auto max-h-[80px] object-cover rounded-lg" />
        </a>
        <!-- Icons + search bar -->
        <div class="flex flex-wrap items-center gap-2 sm:-mt-[30px]">
          <div class="ml-auto shrink-0 flex items-center gap-3">
            <a href="/" class="relative group flex items-center justify-center w-9 h-9 sm:w-12 sm:h-12 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors" title="Solver"><span class="text-lg sm:text-2xl">🔍</span><span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Solver</span></a>
            <a href="/contact?subject=bug" class="relative group flex items-center justify-center w-9 h-9 sm:w-12 sm:h-12 rounded-lg bg-gray-800 hover:bg-red-900/30 transition-colors" title="Bug"><span class="text-lg sm:text-2xl">🐛</span><span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Report Bug</span></a>
            <a href="/suggest" class="relative group flex items-center justify-center w-9 h-9 sm:w-12 sm:h-12 rounded-lg bg-gray-800 hover:bg-purple-900/30 transition-colors" title="Suggest"><span class="text-lg sm:text-2xl">💡</span><span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Suggest</span></a>
            <a href="/achievements" class="relative group flex items-center justify-center w-9 h-9 sm:w-12 sm:h-12 rounded-lg bg-gray-800 hover:bg-amber-900/30 transition-colors" title="Achievements"><span class="text-lg sm:text-2xl">🏅</span><span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Achievements</span></a>
            <div class="w-4"></div>
            <div class="relative">
              <input id="dict-search" type="text" value="Words starting with Q" class="h-7 w-36 sm:w-44 pl-7 pr-2 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-400 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" autocomplete="off" />
              <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <a id="search-find-btn" href="/blog" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-blue-600/20 border border-blue-500/30 text-xs font-medium text-blue-400 hover:bg-blue-600/40 hover:text-blue-300 transition-colors cursor-pointer">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <span>Find</span>
            </a>
          </div>
        </div>
        <div class="col-span-full border-t border-purple-800/50 mt-2"></div>
      </div>
    </header>

    <slot />

    <!-- Footer -->

    <script>
      (async function loadBanner() {
        try {
          // Fetch active banners for rotation
          const res = await fetch('/api/banners?active=true');
          let opt = 1;
          let bannerId = 'banner-1';

          if (res.ok) {
            const data = await res.json();
            const activeBanners = data.banners || [];
            if (activeBanners.length > 0) {
              // Pick a random banner from the active pool
              const picked = activeBanners[Math.floor(Math.random() * activeBanners.length)];
              opt = picked.option_number;
              bannerId = `banner-${opt}`;
            }
          }

          const img = document.getElementById('blog-banner-img') as HTMLImageElement;
          if (img) img.src = `/banner-options/banner-${opt}.svg`;

          // Make banner clickable — track click then navigate to solver
          const bannerLink = document.getElementById('blog-banner-link') as HTMLAnchorElement;
          if (bannerLink) {
            bannerLink.dataset.bannerId = bannerId;
            bannerLink.addEventListener('click', async (e) => {
              e.preventDefault();
              try {
                await fetch('/api/banner-click', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ banner_id: bannerId, page_url: window.location.pathname }),
                });
              } catch {}
              window.location.href = '/';
            });
          }
        } catch {}
      })();
    </script>
    <!-- Footer -->
    <footer class="border-t border-gray-800 px-6 py-8 mt-16">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-sm text-gray-500">&copy; 2025 ScrabbleWordsFinder.com</p>
        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
          <a href="/guide" class="hover:text-blue-400 transition-colors">Guide</a>
          <a href="/about" class="hover:text-blue-400 transition-colors">About</a>
          <a href="/privacy" class="hover:text-blue-400 transition-colors">Privacy</a>
          <a href="/contact" class="hover:text-blue-400 transition-colors">Contact</a>
          <a href="/disclaimer" class="hover:text-blue-400 transition-colors">Disclaimer</a>
          <a href="/terms" class="hover:text-blue-400 transition-colors">Terms</a>
          <a href="/suggest" class="hover:text-blue-400 transition-colors">Suggest</a>
        </div>
      </div>
    </footer>
  </body>
</html>
