      // Minimal swfStore for click tracker (getRaw/setRaw only)
      if(!window.__swfStore){window.__swfStore={getRaw:function(k){try{return localStorage.getItem(k)}catch(e){return null}},setRaw:function(k,v){try{localStorage.setItem(k,v)}catch(e){}}}}
      function getSessionId(){let s=sessionStorage.getItem("swf_session_id");if(!s){s=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);sessionStorage.setItem("swf_session_id",s)}return s}
      function getUserId(){let u=window.__swfStore.getRaw("swf_user_id");if(!u){u=crypto.randomUUID?crypto.randomUUID():Math.random().toString(36).slice(2)+Date.now().toString(36);window.__swfStore.setRaw("swf_user_id",u)}return u}
      function getDevice(){var a=navigator.userAgent;if(/tablet|ipad|playbook|silk/i.test(a))return"tablet";if(/mobile|iphone|ipod|android.*mobile|windows phone/i.test(a))return"mobile";return"desktop"}
      function getBrowser(){var a=navigator.userAgent;if(a.includes("Firefox/"))return"Firefox";if(a.includes("Edg/"))return"Edge";if(a.includes("Chrome/")&&!a.includes("Edg/"))return"Chrome";if(a.includes("Safari/")&&!a.includes("Chrome"))return"Safari";return"Other"}
      function getOS(){var a=navigator.userAgent;if(a.includes("Windows"))return"Windows";if(a.includes("Mac OS"))return"macOS";if(a.includes("Android"))return"Android";if(/iPhone|iPad|iPod/.test(a))return"iOS";if(a.includes("Linux"))return"Linux";return"Other"}
      document.addEventListener("click",function(e){
        var t=e.target;
        var name=t.getAttribute("data-track")||(t.closest("[data-track]")||{}).getAttribute&&t.closest("[data-track]")&&t.closest("[data-track]").getAttribute("data-track")||(t.closest("a")||{textContent:""}).textContent&&t.closest("a")&&t.closest("a").textContent.trim().slice(0,60)||(t.closest("button")||{textContent:""}).textContent&&t.closest("button")&&t.closest("button").textContent.trim().slice(0,60)||t.tagName;
        if(name==="🔄 Refresh"||name==="refresh"||name==="Refresh"||name==="SPAN"||name==="DIV"||name==="IMG"||name==="P"||name==="INPUT"||name==="TEXTAREA"||name==="svg"||name==="path"||name==="SVG"||name==="LABEL"||name===">"||name==="✕")return;
        fetch("/api/clicks/",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({user_id:getUserId(),ui_element:name,url:window.location.pathname,session_id:getSessionId(),screen_width:window.screen.width,screen_height:window.screen.height,viewport_width:window.innerWidth,viewport_height:window.innerHeight,click_x:e.clientX,click_y:e.clientY,page_title:document.title,device_type:getDevice(),browser:getBrowser(),os:getOS()})}).catch(function(){});
      });
    })();
