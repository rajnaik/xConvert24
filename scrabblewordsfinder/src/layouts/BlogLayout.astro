---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = 'ScrabbleWordsFinder.com Blog — free tips, strategy, and history for Scrabble players.', keywords = 'scrabble, word finder, scrabble strategy, scrabble tips' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://www.scrabblewordsfinder.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ScrabbleWordsFinder.com" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100 antialiased">
    <!-- Shared header -->
    <header class="mx-auto max-w-6xl px-6 pt-3 mb-4">
      <div class="grid grid-cols-[auto_1fr] grid-rows-2 gap-x-3 gap-y-0">
        <a href="/" class="row-span-2 flex items-start">
          <img id="site-logo" src="/logo-options/option-1.svg" alt="ScrabbleWordsFinder" class="h-[268px] w-[268px] rounded-lg" />
        </a>
        <div class="flex items-center gap-3 pt-1 whitespace-nowrap overflow-x-auto text-sm justify-end">
          <span class="text-gray-400 shrink-0"><span class="text-blue-400">Free, Fast, No-Sign Up</span> — Scrabble Words Finder</span>
          <a href="/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔍 Solver</a>
          <a href="/guide" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">📘 Guide</a>
          <a href="/about" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">ℹ️ About</a>
          <a href="/privacy" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔒 Privacy</a>
          <a href="/contact" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">✉️ Contact</a>
          <a href="/suggest" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">💡 Suggest</a>
          <a href="/settings" class="text-gray-500 hover:text-purple-400 transition-colors shrink-0">⚙️</a>
        </div>
        <a id="blog-banner-link" href="/" class="block cursor-pointer self-end">
          <img id="blog-banner-img" src="/banner-options/banner-1.svg" alt="Scrabble Word Finder" class="w-full h-auto max-h-[80px] object-cover rounded-lg" />
        </a>
      </div>
    </header>

    <slot />

    <!-- Footer -->

    <script>
      (async function loadBanner() {
        try {
          // Fetch active banners for rotation
          const res = await fetch('/api/banners?active=true');
          let opt = 1;
          let bannerId = 'banner-1';

          if (res.ok) {
            const data = await res.json();
            const activeBanners = data.banners || [];
            if (activeBanners.length > 0) {
              // Pick a random banner from the active pool
              const picked = activeBanners[Math.floor(Math.random() * activeBanners.length)];
              opt = picked.option_number;
              bannerId = `banner-${opt}`;
            }
          }

          const img = document.getElementById('blog-banner-img') as HTMLImageElement;
          if (img) img.src = `/banner-options/banner-${opt}.svg`;

          // Make banner clickable — track click then navigate to solver
          const bannerLink = document.getElementById('blog-banner-link') as HTMLAnchorElement;
          if (bannerLink) {
            bannerLink.dataset.bannerId = bannerId;
            bannerLink.addEventListener('click', async (e) => {
              e.preventDefault();
              try {
                await fetch('/api/banner-click', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ banner_id: bannerId, page_url: window.location.pathname }),
                });
              } catch {}
              window.location.href = '/';
            });
          }
        } catch {}
      })();
    </script>
    <!-- Footer -->
    <footer class="border-t border-gray-800 px-6 py-8 mt-16">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-sm text-gray-500">&copy; 2025 ScrabbleWordsFinder.com</p>
        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
          <a href="/guide" class="hover:text-blue-400 transition-colors">Guide</a>
          <a href="/about" class="hover:text-blue-400 transition-colors">About</a>
          <a href="/privacy" class="hover:text-blue-400 transition-colors">Privacy</a>
          <a href="/contact" class="hover:text-blue-400 transition-colors">Contact</a>
          <a href="/disclaimer" class="hover:text-blue-400 transition-colors">Disclaimer</a>
          <a href="/terms" class="hover:text-blue-400 transition-colors">Terms</a>
          <a href="/suggest" class="hover:text-blue-400 transition-colors">Suggest</a>
        </div>
      </div>
    </footer>
  </body>
</html>
