---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Avatar Collage — Pick Your Style" description="Browse avatar styles side by side to choose the best look for SWF player avatars. Free tool on ScrabbleWordsFinder.com — instant results, no sign-up. Free." keywords="scrabble avatar, player avatar, avatar picker, scrabble profile" showHeader={false}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do I change my avatar on ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "Go to Settings, then tap Change Avatar. Pick from 50 unique animal-themed styles. Your choice saves automatically in your browser." }},
      { "@type": "Question", "name": "Are avatars anonymous?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Avatars are randomly generated from seeds — no photos, no personal data. Other players see your avatar on leaderboards." }},
      { "@type": "Question", "name": "Can I preview avatars before choosing?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Avatar Collage page shows all styles side by side so you can compare before selecting one." }}
    ]
  })} />
  <div class="min-h-screen bg-gray-950 text-white p-6 max-w-7xl mx-auto">
    <a href="/settings/" class="text-sm text-teal-400 hover:underline mb-4 inline-block">← Back to Settings</a>
    <h1 class="text-3xl font-bold mb-2">🎨 Avatar Style Collage</h1>
    <p class="text-gray-400 mb-6">Browse all avatar styles with animal-themed seeds. The <span class="text-amber-400 font-semibold">★ Animal Avatars</span> section uses a dedicated animal face generator. Pick what feels right for SWF.</p>

    <!-- Style filter buttons -->
    <div class="flex flex-wrap gap-2 mb-8 sticky top-0 bg-gray-950/95 backdrop-blur py-3 z-10 border-b border-gray-800">
      <button data-filter="all" class="filter-btn active px-3 py-1.5 rounded-lg text-sm font-medium bg-teal-600 text-white">All Styles</button>
      <button data-filter="animal-avatars" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-amber-700 text-amber-100 hover:bg-amber-600">★ Animal Faces</button>
      <button data-filter="fun-emoji" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Fun Emoji</button>
      <button data-filter="thumbs" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Thumbs</button>
      <button data-filter="bottts" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Bottts</button>
      <button data-filter="adventurer" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Adventurer</button>
      <button data-filter="pixel-art" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Pixel Art</button>
      <button data-filter="big-smile" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Big Smile</button>
      <button data-filter="lorelei" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Lorelei</button>
      <button data-filter="notionists" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">Notionists</button>
    </div>

    <!-- Animal Avatars section (generated client-side) -->
    <div id="animal-section" class="mb-10">
      <h2 class="text-xl font-bold text-amber-400 mb-3 flex items-center gap-2">★ Animal Face Avatars <span class="text-xs text-gray-400 font-normal">(animal-avatar-generator — MIT license)</span></h2>
      <p class="text-sm text-gray-400 mb-4">These are actual animal faces generated from seed strings. Each seed produces a unique, cute animal.</p>
      <div id="animal-grid" class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-8 lg:grid-cols-10 gap-3">
      </div>
    </div>

    <!-- DiceBear section -->
    <div id="dicebear-section">
      <h2 class="text-xl font-bold text-teal-400 mb-3">DiceBear Styles <span class="text-xs text-gray-400 font-normal">(human/abstract faces — various licenses)</span></h2>
      <div id="avatar-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
      </div>
    </div>

    <div class="mt-12 p-4 rounded-xl bg-gray-900 border border-gray-700">
      <h2 class="text-lg font-semibold mb-2">📋 Style Summary</h2>
      <table class="w-full text-sm text-left">
        <thead class="text-gray-400 border-b border-gray-700">
          <tr><th class="py-2">Style</th><th>Vibe</th><th>License</th><th>Best For</th></tr>
        </thead>
        <tbody class="text-gray-300">
          <tr class="bg-amber-950/30"><td class="py-1.5 font-medium text-amber-400">★ animal-avatars</td><td>Cute animal faces (actual animals!)</td><td>MIT</td><td>Games with animal themes — perfect for SWF</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">fun-emoji</td><td>Colorful expressive faces</td><td>CC BY 4.0</td><td>Playful, casual games</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">thumbs</td><td>Rounded thumb shapes, bold color</td><td>CC0 1.0</td><td>Minimal, clean look</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">bottts</td><td>Robot/creature heads</td><td>Free commercial</td><td>Techy, distinctive</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">adventurer</td><td>Character faces with accessories</td><td>CC BY 4.0</td><td>RPG-ish, detailed</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">pixel-art</td><td>Retro pixel characters</td><td>Free commercial</td><td>Nostalgic gamer</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">big-smile</td><td>Happy illustrated people</td><td>CC BY 4.0</td><td>Warm, friendly</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">lorelei</td><td>Artistic line-drawn faces</td><td>CC BY 4.0</td><td>Elegant, minimalist</td></tr>
          <tr><td class="py-1.5 font-medium text-teal-300">notionists</td><td>Notion-style doodle people</td><td>CC0 1.0</td><td>Professional, clean</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    import createAvatar from 'animal-avatar-generator';

    const ANIMAL_SEEDS = [
      'BlueFox', 'RedPanda', 'SilverWolf', 'GoldenOwl', 'CrimsonBear',
      'JadeFalcon', 'ArcticHare', 'EmberLynx', 'CoralDolphin', 'MidnightRaven',
      'IvoryElephant', 'TopazTiger', 'VioletViper', 'BronzeBison', 'IndigoIguana',
      'ScarletSparrow', 'OpalOtter', 'CobaltCrane', 'AmberAntelope', 'PearlPenguin',
      'RubyRooster', 'SapphireSeal', 'OnyxOcelot', 'TurquoiseTurtle', 'GarnetGazelle',
      'EmeraldEagle', 'CitrineCheetah', 'AquaAlbatross', 'MagentaMoose', 'LavenderLion',
      'NeonNewt', 'SunflowerStork', 'ThunderThornbill', 'WhisperWhale', 'ZenZebra',
      'PrismPanther', 'DawnDeer', 'FrostFerret', 'GlowGecko', 'HazeHawk',
      'MistMarten', 'PulseParrot', 'QuartzQuail', 'RippleRaccoon', 'ShimmerShark',
      'TwilightTapir', 'VelvetVulture', 'WillowWombat', 'ZephyrZorilla', 'FlintFlamingo'
    ];

    // Generate animal avatars
    const animalGrid = document.getElementById('animal-grid');
    ANIMAL_SEEDS.forEach(seed => {
      const svg = createAvatar(seed, { size: 80, round: true });
      const card = document.createElement('div');
      card.className = 'avatar-card flex flex-col items-center gap-1 p-2 rounded-xl bg-gray-900/60 border border-amber-800/30 hover:border-amber-500/60 hover:bg-gray-800/80 transition-all cursor-pointer';
      card.dataset.style = 'animal-avatars';
      card.innerHTML = `
        <div class="w-16 h-16 rounded-full overflow-hidden bg-gray-800 flex items-center justify-center">${svg}</div>
        <span class="text-[10px] text-gray-400 truncate w-full text-center">${seed}</span>
        <span class="text-[9px] text-amber-500/80 font-mono">animal</span>
      `;
      animalGrid.appendChild(card);
    });

    // DiceBear styles
    const STYLES = ['fun-emoji', 'thumbs', 'bottts', 'adventurer', 'pixel-art', 'big-smile', 'lorelei', 'notionists'];
    const grid = document.getElementById('avatar-grid');

    const cards = [];
    STYLES.forEach(style => {
      ANIMAL_SEEDS.forEach(seed => {
        const url = `https://api.dicebear.com/10.x/${style}/svg?seed=${seed}&size=96`;
        const card = document.createElement('div');
        card.className = 'avatar-card flex flex-col items-center gap-1 p-2 rounded-xl bg-gray-900/60 border border-gray-800 hover:border-teal-500/60 hover:bg-gray-800/80 transition-all cursor-pointer';
        card.dataset.style = style;
        card.innerHTML = `
          <img src="${url}" alt="${seed} (${style})" class="w-16 h-16 rounded-full bg-gray-800" loading="lazy" />
          <span class="text-[10px] text-gray-400 truncate w-full text-center">${seed}</span>
          <span class="text-[9px] text-teal-500/80 font-mono">${style}</span>
        `;
        cards.push(card);
      });
    });

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function render(filter) {
      grid.innerHTML = '';
      const animalSection = document.getElementById('animal-section');
      const dicebearSection = document.getElementById('dicebear-section');

      if (filter === 'all') {
        animalSection.style.display = '';
        dicebearSection.style.display = '';
        shuffle([...cards]).forEach(c => grid.appendChild(c.cloneNode(true)));
      } else if (filter === 'animal-avatars') {
        animalSection.style.display = '';
        dicebearSection.style.display = 'none';
      } else {
        animalSection.style.display = 'none';
        dicebearSection.style.display = '';
        cards.filter(c => c.dataset.style === filter).forEach(c => grid.appendChild(c.cloneNode(true)));
      }
    }

    // Filter buttons
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('active', 'bg-teal-600', 'text-white', 'bg-amber-700', 'text-amber-100');
          b.classList.add('bg-gray-800', 'text-gray-300');
        });
        if (btn.dataset.filter === 'animal-avatars') {
          btn.classList.add('active', 'bg-amber-700', 'text-amber-100');
        } else {
          btn.classList.add('active', 'bg-teal-600', 'text-white');
        }
        btn.classList.remove('bg-gray-800', 'text-gray-300');
        render(btn.dataset.filter);
      });
    });
  </script>
</Layout>
