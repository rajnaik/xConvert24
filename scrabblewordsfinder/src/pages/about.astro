---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { TAGLINE } from '../lib/constants';
import '../styles/global.css';
---

<Layout title="About ScrabbleWordsFinder — Free Instant Scrabble Solver" description="ScrabbleWordsFinder.com is a free, instant Scrabble word solver. Fun, Fast, Free and No sign-up. Built for casual players and competitive enthusiasts." keywords="about scrabble word finder, free scrabble solver, instant scrabble solver, SOWPODS dictionary online, no signup word finder, scrabble helper, Scrabble Dictionary, Word Games, Word of the Day, Daily Rack, Anagram">
<div class="max-w-3xl mx-auto px-6 pt-4 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">About ScrabbleWordsFinder.com - Scrabble Word Finder, English Scrabble Sovler</h1>
    <p class="text-gray-400 mb-8">A free word solver built by word game lovers, for word game lovers. <span id="site-tagline" class="text-purple-400 font-medium">{TAGLINE}</span></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">What We Do</h2>
    <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is a free, no-sign-up Scrabble word solver. Enter your rack tiles, and we'll instantly show you every valid word you can play — sorted by points, filterable by length, pattern, or position.</p>
    <p class="text-gray-300 mb-4">Whether you're stuck with a rack full of vowels, hunting for that 7-letter bingo, or just learning new words to expand your game, we've got you covered.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Built For Everyone</h2>
    <p class="text-gray-300 mb-4">We built this tool for three audiences:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Casual players</strong> who want a quick answer when they're stuck during a friendly game at home</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Competitive enthusiasts</strong> who study word lists, analyze rack leaves, and optimize their opening moves</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Serious students of the game</strong> who want to commit words to long-term memory</span></li>
    </ul>

    <!-- Memory WordBench Feature Highlight -->
    <div class="border border-purple-600/60 rounded-xl p-6 mb-6 bg-gradient-to-br from-purple-950/40 to-gray-900/60 shadow-lg shadow-purple-900/20">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-purple-400 text-lg">⭐</span>
        <h3 class="text-lg font-semibold text-purple-200">Memory WordBench</h3>
        <span class="text-purple-400 text-lg">⭐</span>
      </div>
      <p class="text-gray-300 mb-4">Our <a href="/#wordBench" class="text-purple-300 hover:text-purple-200 underline underline-offset-2 font-medium">Memory WordBench</a> turns your saved words into a purpose-built study tool for word retention:</p>
      <ul class="space-y-2 text-gray-300 ml-1">
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Flashcards</strong> — tap-to-flip recall with meanings on the back</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Autoplay</strong> — hands-free drilling at your chosen pace</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Fullscreen mode</strong> — distraction-free immersion for deep study</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">One-click save</strong> — add words directly from solver results</span></li>
      </ul>
    </div>
    <p class="text-gray-400 text-sm mt-3">🏆 Read more: <a href="/blog/competitive-scrabble-tournament-world/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Inside Competitive Scrabble: Tournaments, Records & the Mental Game</a></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Our Promise</h2>
    <div class="border border-purple-800/50 rounded-lg p-6 mb-6 bg-gray-900/50">
      <ul class="space-y-3 text-gray-300">
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Always free.</strong> No premium tiers, no paywalls, no "5 searches per day" limits.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Clean experience.</strong> No pop-ups, no sponsored results cluttering your solver.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">No account required.</strong> Just open the page and start solving. Zero friction.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Privacy first.</strong> We don't track you, sell your data, or require personal information.</span></li>
      </ul>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Our Dictionaries</h2>
    <p class="text-gray-300 mb-4">We support two official Scrabble dictionaries:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">SOWPODS</strong> — The international word list used in most countries outside North America. Over 74,000 valid words.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">TWL (Tournament Word List)</strong> — The official list for North American Scrabble tournaments, maintained by Hasbro.</span></li>
    </ul>
    <p class="text-gray-400 text-sm mt-3">📖 Deep dive: <a href="/blog/scrabble-dictionaries-languages-weird-words/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Scrabble Dictionaries, Languages & the Strangest Legal Words</a></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Part of the xConvert24 Family</h2>
    <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is part of the <a href="https://xconvert24.com" class="inline-flex items-center gap-1.5 text-blue-400 hover:text-blue-300 underline underline-offset-2"><img src="/xconvert24-logo.svg" alt="xConvert24" class="inline h-5 w-auto" />xConvert24.com</a> family of free online tools. We build useful, fast, privacy-respecting utilities — from unit converters to calculators to word solvers.</p>
    <p class="text-gray-400 text-sm">No corporate agenda. Just useful tools, built with care.</p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder is a free online tool that helps you find valid words for Scrabble, Words With Friends, and other word games. It provides instant results with scores, definitions, and tile probability analysis." } },
    { "@type": "Question", "name": "Is ScrabbleWordsFinder free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, ScrabbleWordsFinder is completely free with no signup required. There are no premium tiers, no daily limits, and no paywalls — all features are available instantly." } },
    { "@type": "Question", "name": "What dictionaries does ScrabbleWordsFinder support?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder uses the official TWL (Tournament Word List) and SOWPODS dictionaries, covering both North American and international Scrabble tournaments." } }
  ]
}
</script>

<!-- DB-driven tagline fetch -->
<script is:inline>
  (async function() {
    try {
      const res = await fetch('/api/constants/?name=TAGLINE');
      if (res.ok) {
        const { constant } = await res.json();
        if (constant && constant.text) {
          const el = document.getElementById('site-tagline');
          if (el) el.textContent = constant.text;
        }
      }
    } catch (e) { /* fallback to static text */ }
  })();
</script>
</Layout>
