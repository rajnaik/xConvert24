---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { TAGLINE } from '../lib/constants';
import '../styles/global.css';
---

<Layout title="About ScrabbleWordsFinder — Free Instant Scrabble Solver" description="ScrabbleWordsFinder.com is a free, instant Scrabble word solver. Fun, Fast, Free and No sign-up. Built for casual players and competitive enthusiasts." keywords="about scrabble word finder, free scrabble solver, instant scrabble solver, SOWPODS dictionary online, no signup word finder, scrabble helper, Scrabble Dictionary, Word Games, Word of the Day, Daily Rack, Anagram">
<div class="max-w-3xl mx-auto px-6 pt-4 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">About ScrabbleWordsFinder.com - Scrabble Word Finder, English Scrabble Sovler</h1>
    <p class="text-gray-400 mb-8">A free word solver built by word game lovers, for word game lovers. <span id="site-tagline" class="text-purple-400 font-medium">{TAGLINE}</span></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">What We Do</h2>
    <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is a free, no-sign-up Scrabble word solver. Enter your rack tiles, and we'll instantly show you every valid word you can play — sorted by points, filterable by length, pattern, or position.</p>
    <p class="text-gray-300 mb-4">Whether you're stuck with a rack full of vowels, hunting for that 7-letter bingo, or just learning new words to expand your game, we've got you covered.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Built For Everyone</h2>
    <p class="text-gray-300 mb-4">We built this tool for three audiences:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Casual players</strong> who want a quick answer when they're stuck during a friendly game at home</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Competitive enthusiasts</strong> who study word lists, analyze rack leaves, and optimize their opening moves</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Serious students of the game</strong> who want to commit words to long-term memory</span></li>
    </ul>

    <!-- Memory WordBench Feature Highlight -->
    <div class="border border-purple-600/60 rounded-xl p-6 mb-6 bg-gradient-to-br from-purple-950/40 to-gray-900/60 shadow-lg shadow-purple-900/20">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-purple-400 text-lg">⭐</span>
        <h3 class="text-lg font-semibold text-purple-200">Memory WordBench</h3>
        <span class="text-purple-400 text-lg">⭐</span>
      </div>
      <p class="text-gray-300 mb-4">Our <a href="/#wordBench" class="text-purple-300 hover:text-purple-200 underline underline-offset-2 font-medium">Memory WordBench</a> turns your saved words into a purpose-built study tool for word retention:</p>
      <ul class="space-y-2 text-gray-300 ml-1">
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Flashcards</strong> — tap-to-flip recall with meanings on the back</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Autoplay</strong> — hands-free drilling at your chosen pace</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">Fullscreen mode</strong> — distraction-free immersion for deep study</span></li>
        <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span><span><strong class="text-white">One-click save</strong> — add words directly from solver results</span></li>
      </ul>
    </div>
    <p class="text-gray-400 text-sm mt-3">🏆 Read more: <a href="/blog/competitive-scrabble-tournament-world/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Inside Competitive Scrabble: Tournaments, Records & the Mental Game</a></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Our Promise</h2>
    <div class="border border-purple-800/50 rounded-lg p-6 mb-6 bg-gray-900/50">
      <ul class="space-y-3 text-gray-300">
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Always free.</strong> No premium tiers, no paywalls, no "5 searches per day" limits.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Clean experience.</strong> No pop-ups, no sponsored results cluttering your solver.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">No account required.</strong> Just open the page and start solving. Zero friction.</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span><strong class="text-white">Privacy first.</strong> We don't track you, sell your data, or require personal information.</span></li>
      </ul>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Our Dictionaries</h2>
    <p class="text-gray-300 mb-4">We support four official Scrabble dictionaries, containing a combined 267,751 unique valid words:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">SOWPODS</strong> — 267,751 words. The international tournament list used in 121 countries. Updated annually by Collins and Mattel.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">TWL / NASPA Word List</strong> — 187,632 words. The official list for North American Scrabble tournaments, maintained by NASPA (formerly by Hasbro).</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Collins Scrabble Words</strong> — The full Collins dictionary used in international competitive play.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Words With Friends</strong> — The dictionary used by Zynga's popular mobile word game.</span></li>
    </ul>
    <p class="text-gray-300 mb-4">Our solver processes your rack against these dictionaries in under 100 milliseconds, returning every valid word sorted by Scrabble tile score. The standard Scrabble tile set contains 100 tiles with values from 0 (blank) to 10 (Q, Z) points.</p>
    <p class="text-gray-400 text-sm mt-3">📖 Deep dive: <a href="/blog/scrabble-dictionaries-languages-weird-words/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Scrabble Dictionaries, Languages & the Strangest Legal Words</a></p>

    <!-- E-E-A-T Section: Who Built This -->
    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Who Built ScrabbleWordsFinder</h2>
    <div class="border border-teal-700/40 rounded-xl p-6 mb-6 bg-gradient-to-br from-teal-950/30 to-gray-900/60">
      <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com was created by <strong class="text-white">Rajeev Naik</strong>, a software engineer and competitive word game enthusiast based in England. With over 15 years of experience building web applications and a lifelong passion for Scrabble, Raj built this tool to be the solver he always wanted: fast, free, and genuinely useful.</p>
      <p class="text-gray-300 mb-4">The platform is operated by <strong class="text-white">xSoft Ltd</strong>, a private limited company registered in England and Wales (Company No. 17308915). We are committed to providing free, high-quality tools for the word game community.</p>
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="text-center p-3 rounded-lg bg-gray-800/50 border border-gray-700/50">
          <p class="text-lg font-bold text-blue-400">900+</p>
          <p class="text-[10px] text-gray-500">Blog Articles</p>
        </div>
        <div class="text-center p-3 rounded-lg bg-gray-800/50 border border-gray-700/50">
          <p class="text-lg font-bold text-green-400">267,751</p>
          <p class="text-[10px] text-gray-500">Dictionary Words</p>
        </div>
        <div class="text-center p-3 rounded-lg bg-gray-800/50 border border-gray-700/50">
          <p class="text-lg font-bold text-amber-400">6</p>
          <p class="text-[10px] text-gray-500">Daily Games</p>
        </div>
        <div class="text-center p-3 rounded-lg bg-gray-800/50 border border-gray-700/50">
          <p class="text-lg font-bold text-purple-400">&lt;100ms</p>
          <p class="text-[10px] text-gray-500">Solve Time</p>
        </div>
      </div>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Our Expertise</h2>
    <p class="text-gray-300 mb-4">We don't just build a solver — we actively research and write about Scrabble strategy, tournament play, and word game pedagogy. Our content covers:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-teal-400 mt-0.5">✦</span><span><strong class="text-white">Tournament-level strategy</strong> — rack management, leave analysis, endgame theory, and board control</span></li>
      <li class="flex items-start gap-2"><span class="text-teal-400 mt-0.5">✦</span><span><strong class="text-white">Vocabulary science</strong> — systematic approaches to memorizing the 267,751 valid words, hook patterns, and bingo stems</span></li>
      <li class="flex items-start gap-2"><span class="text-teal-400 mt-0.5">✦</span><span><strong class="text-white">AI-powered coaching</strong> — our Lex AI Coach analyses play patterns and generates personalised improvement plans</span></li>
      <li class="flex items-start gap-2"><span class="text-teal-400 mt-0.5">✦</span><span><strong class="text-white">Scrabble mathematics</strong> — tile probability, EV scoring, and optimal play calculations based on bag composition</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Part of the xSoft Ltd Family</h2>
    <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is operated by <strong class="text-white">xSoft Ltd</strong> (Company No. 17308915, England & Wales), the same team behind <a href="https://xconvert24.com" class="inline-flex items-center gap-1.5 text-blue-400 hover:text-blue-300 underline underline-offset-2"><img src="/xconvert24-logo.svg" alt="xConvert24" class="inline h-5 w-auto" />xConvert24.com</a> — a suite of free online conversion tools.</p>
    <p class="text-gray-400 text-sm">Registered business. Real people. Built with care.</p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder.com is a free online Scrabble word solver that searches 267,751 valid words from the SOWPODS dictionary in under 100 milliseconds. It provides instant results with Scrabble scores, definitions, rack leave analysis, and tile probability calculations. No sign-up required." } },
    { "@type": "Question", "name": "Is ScrabbleWordsFinder free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, ScrabbleWordsFinder is completely free with no signup required. There are no premium tiers, no daily limits, and no paywalls. All features including the AI coach, daily challenges, leaderboards, and 900+ blog articles are available instantly." } },
    { "@type": "Question", "name": "What dictionaries does ScrabbleWordsFinder support?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder supports four dictionaries: SOWPODS (267,751 words, international), TWL/NASPA (187,632 words, North America), Collins Scrabble Words (international competitive), and Words With Friends. The solver finds all valid words from 2 to 15 letters." } },
    { "@type": "Question", "name": "Who operates ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder.com is operated by xSoft Ltd, a private limited company registered in England and Wales (Company No. 17308915). It was built by Rajeev Naik, a software engineer and competitive word game enthusiast with over 15 years of web development experience." } }
  ]
}
</script>

<!-- DB-driven tagline fetch -->
<script is:inline>
  (async function() {
    try {
      const res = await fetch('/api/constants/?name=TAGLINE');
      if (res.ok) {
        const { constant } = await res.json();
        if (constant && constant.text) {
          const el = document.getElementById('site-tagline');
          if (el) el.textContent = constant.text;
        }
      }
    } catch (e) { /* fallback to static text */ }
  })();
</script>
</Layout>
