---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { TAGLINE } from '../lib/constants';
import '../styles/global.css';
---

<Layout title="Free Scrabble Solver Guide — Tips, Filters & Strategy" description="Learn how to use our free Scrabble word finder. Master tile entry, filters, rack leave analysis, bingo hunting, and strategy tips. No sign-up required." keywords="scrabble word finder guide, scrabble strategy tips, scrabble rack leave, scrabble opening moves, scrabble bingo words, free word finder tutorial, scrabble tile probability">

<style>
  @keyframes typeIn { from { width: 0; } to { width: 100%; } }
  @keyframes blink { 0%, 100% { border-color: transparent; } 50% { border-color: #60a5fa; } }
  @keyframes popIn { 0% { transform: scale(0); opacity: 0; } 60% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }
  @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulseGlow { 0%, 100% { box-shadow: 0 0 0 0 rgba(168,85,247,0); } 50% { box-shadow: 0 0 8px 2px rgba(168,85,247,0.3); } }
  @keyframes flipReveal { 0% { transform: rotateY(90deg); opacity: 0; } 100% { transform: rotateY(0); opacity: 1; } }
  @keyframes slideScore { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes syncType { 0%, 100% { width: 0; } 50% { width: 100%; } }
  @keyframes syncTile { 0%, 100% { opacity: 0; transform: scale(0.5); } 14%, 85% { opacity: 1; transform: scale(1); } }
  @keyframes slowReveal { 0% { opacity: 0; max-height: 0; filter: blur(4px); transform: translateY(-4px); } 100% { opacity: 1; max-height: 60px; filter: blur(0); transform: translateY(0); } }
  @keyframes cardSwap { 0% { transform: translateX(40px) scale(0.9); opacity: 0; } 100% { transform: translateX(0) scale(1); opacity: 1; } }
  @keyframes cardSwapReverse { 0% { transform: translateX(-40px) scale(0.9); opacity: 0; } 100% { transform: translateX(0) scale(1); opacity: 1; } }
  .demo-type { overflow: hidden; white-space: nowrap; border-right: 2px solid #60a5fa; animation: syncType 4s steps(7) infinite, blink 0.7s step-end infinite; }
  .demo-tile { animation: syncTile 4s ease-out infinite; }
  .demo-tile:nth-child(1) { animation-delay: 0s; }
  .demo-tile:nth-child(2) { animation-delay: 0.28s; }
  .demo-tile:nth-child(3) { animation-delay: 0.56s; }
  .demo-tile:nth-child(4) { animation-delay: 0.84s; }
  .demo-tile:nth-child(5) { animation-delay: 1.12s; }
  .demo-tile:nth-child(6) { animation-delay: 1.4s; }
  .demo-tile:nth-child(7) { animation-delay: 1.68s; }
  .demo-result { animation: fadeSlideUp 0.5s ease-out both; }
  .demo-result:nth-child(1) { animation-delay: 0.2s; }
  .demo-result:nth-child(2) { animation-delay: 0.5s; }
  .demo-result:nth-child(3) { animation-delay: 0.8s; }
  .demo-card-flip { animation: flipReveal 0.6s ease-out both; animation-delay: 0.5s; }
  .demo-score { animation: slideScore 0.4s ease-out both; animation-delay: 1.2s; }
  .demo-glow { animation: pulseGlow 2s ease-in-out infinite; }
  .fc-guide-card { transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .fc-guide-card.flip-next { animation: cardSwap 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
  .fc-guide-card.flip-prev { animation: cardSwapReverse 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
  .fc-guide-meaning { animation: slowReveal 0.8s ease-out both; }
</style>

<div class="max-w-3xl mx-auto px-6 pt-4 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">User Guide</h1>
    <p class="text-gray-400 mb-8">Everything you need to know to get the most out of ScrabbleWordsFinder.com.</p>

    <!-- Our Promise -->
    <div class="rounded-xl border border-blue-800/40 bg-blue-950/20 p-5 mb-10">
      <p class="text-blue-400 font-semibold text-lg mb-2">{TAGLINE}</p>
      <p class="text-gray-300 text-sm leading-relaxed">ScrabbleWordsFinder.com will always remain <strong class="text-white">free</strong> to use — no paywalls, no premium tiers, no hidden charges. It will always be <strong class="text-white">fun</strong> — with daily challenges, achievements, and new features landing regularly. It will always be <strong class="text-white">fast</strong> — results appear as you type, no page reloads, no waiting. And it will always require <strong class="text-white">no sign-up</strong> — jump in and start solving, no account needed, no email required. That's our promise.</p>
    </div>

    <h2 class="text-xl font-semibold text-white mt-10 mb-3 border-l-4 border-blue-500 pl-3">Entering Your Tiles</h2>
    <p class="text-gray-300 mb-4">You have two ways to input your rack tiles, and they stay perfectly in sync:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Word Solver (text box):</strong> Type up to 15 letters directly. Results appear as you type — no need to click anything. Press Enter or click <strong class="text-white">Solve</strong> as a fallback if auto-search doesn't fire.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Tile Rack (7 boxes):</strong> Click individual tile slots to enter one letter per box. The cursor moves right automatically after each letter. Press Backspace to go left. Click <strong class="text-white">Find Words</strong> to search.</span></li>
    </ul>

    <!-- Demo: Word Solver -->
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 mb-4">
      <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-3">Demo — Word Solver</p>
      <div class="flex items-center gap-2 mb-2">
        <span class="font-semibold text-white text-sm flex items-center gap-2"><span>🔍</span> Word Solver</span>
        <span class="text-gray-600 text-xs">📋 📌</span>
      </div>
      <div class="flex gap-2">
        <div class="flex-1 h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg flex items-center"><span class="demo-type text-blue-300 font-mono uppercase tracking-widest text-sm">AEINRST</span></div>
        <div class="w-7 h-7 rounded-full bg-purple-600/30 border border-purple-500/50 flex items-center justify-center self-center"><span class="text-purple-300 text-xs">✕</span></div>
        <button class="h-10 px-4 rounded-lg bg-blue-500 text-gray-950 font-semibold text-xs">Solve</button>
      </div>
      <p class="text-[10px] text-gray-500 mt-2">↑ Type tiles, click Solve or just start typing — results appear automatically</p>
    </div>

    <!-- Demo: Tile Rack -->
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 mb-6">
      <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-3">Demo — Tile Rack</p>
      <div class="flex gap-1.5 items-center">
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">A</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">E</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">I</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">N</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">R</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">S</div>
        <div class="demo-tile w-10 h-12 rounded-lg bg-gray-800 border-2 border-purple-700/50 flex items-center justify-center text-blue-300 text-xl font-mono font-bold">T</div>
        <button class="h-10 px-3 rounded-lg bg-blue-500 text-gray-950 font-semibold text-xs ml-2">Find Words</button>
      </div>
      <p class="text-[10px] text-gray-500 mt-2">↑ One letter per box. Both inputs sync — type in either one</p>
    </div>

    <h3 class="text-lg font-semibold text-purple-400 mt-6 mb-3">🔄 Bidirectional Sync</h3>
    <p class="text-gray-300 mb-4">The Word Solver and Tile Rack are linked — type in one, and the other updates instantly:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Type "SCRABBLE" in the Word Solver → the first 7 letters fill the Tile Rack boxes automatically</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Fill the Tile Rack boxes → the Word Solver text field updates to match</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>The Word Solver supports up to 15 letters (for longer searches), while the Tile Rack shows the first 7</span></li>
    </ul>

    <h3 class="text-lg font-semibold text-purple-400 mt-6 mb-3">✖️ Clear Button</h3>
    <p class="text-gray-300 mb-4">The purple ✖️ button between the Word Solver and the Solve button clears everything in one click:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Clears the Word Solver text</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Clears all 7 Tile Rack boxes</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Resets the results panel to "Enter at least 2 tiles"</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Use it to start a fresh search without refreshing the page</span></li>
    </ul>

    <h3 class="text-lg font-semibold text-purple-400 mt-6 mb-3">🔘 Solve vs Find Words</h3>
    <p class="text-gray-300 mb-4">Both buttons trigger word search, but they work slightly differently:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Solve</strong> — uses the full Word Solver text (up to 15 letters). Finds all words up to your tile count length.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Find Words</strong> — reads from the hidden tiles field. If you have more than 7 tiles (via the text solver), it searches the full set. With 7 or fewer, it caps at 7-letter words.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Both are fallbacks — the solver normally searches automatically as you type (300ms debounce). Use the buttons if results don't appear.</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-10 mb-3 border-l-4 border-blue-500 pl-3">Using Blank Tiles (?)</h2>
    <p class="text-gray-300 mb-4">Blank tiles are wildcards that can represent any letter. Enter them as a question mark (<code class="bg-gray-800 px-1.5 py-0.5 rounded text-blue-400">?</code>) in your rack.</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>You can use up to 2 blanks (matching a real Scrabble set)</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Words using blanks will show the blank letter in lowercase in results</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Blank tiles score 0 points, so the solver accounts for this in point totals</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-10 mb-3 border-l-4 border-blue-500 pl-3">Filters &amp; Options</h2>
    <p class="text-gray-300 mb-4">Narrow down results to find exactly the word you need:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Dictionary:</strong> Switch between SOWPODS (international, 74,000+ words) and TWL (North American tournament list)</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Sort by:</strong> Points (highest first), length, or alphabetical</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Minimum length:</strong> Only show words of a certain length or longer</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Contains:</strong> Only show words containing a specific letter or sequence</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Starts with:</strong> Filter words by their opening letters</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Ends with:</strong> Filter words by their ending letters</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>📖 For more on how dictionaries differ, read <a href="/blog/scrabble-dictionaries-languages-weird-words/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Scrabble Dictionaries: Languages & Weird Words</a></span></li>
    </ul>

    <!-- Demo: Filters -->
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 mb-6">
      <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-3">Demo — Filters Panel</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div>
          <label class="text-[10px] text-gray-400">Dictionary</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-gray-100 flex items-center">SOWPODS</div>
        </div>
        <div>
          <label class="text-[10px] text-gray-400">Sort by</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-gray-100 flex items-center">Highest Score</div>
        </div>
        <div>
          <label class="text-[10px] text-gray-400">Min length</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-gray-100 flex items-center">2</div>
        </div>
        <div>
          <label class="text-[10px] text-gray-400">Starts with</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-blue-300 font-mono flex items-center">TR</div>
        </div>
        <div>
          <label class="text-[10px] text-gray-400">Ends with</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-gray-500 flex items-center italic">any</div>
        </div>
        <div>
          <label class="text-[10px] text-gray-400">Contains</label>
          <div class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-gray-500 flex items-center italic">any</div>
        </div>
      </div>
      <p class="text-[10px] text-gray-500 mt-2">↑ Combine filters to narrow results — e.g. "starts with TR" + "min 5 letters"</p>
    </div>

    <h2 class="text-xl font-semibold text-white mt-10 mb-3 border-l-4 border-blue-500 pl-3">Achievements &amp; Memory WordBench</h2>
    <p class="text-gray-300 mb-4">Track your progress and build your personal word bank:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Click any word in the results to save it to your 👑 Memory WordBench collection with an auto-fetched definition</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Memory WordBench persist in your browser and can be backed up to our server via your UUID</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Review, edit, or delete Memory WordBench from the Memory WordBench panel on the solver page</span></li>
    </ul>

    <h3 class="text-lg font-semibold text-purple-400 mt-6 mb-3">🏅 Score-Based Achievements</h3>
    <p class="text-gray-300 mb-4">When you click a word in the results, the Tile Scores panel shows your score and awards you an achievement level. There are 5 levels:</p>
    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden">
        <thead class="bg-gray-800">
          <tr>
            <th class="px-4 py-2 text-left text-gray-300">Level</th>
            <th class="px-4 py-2 text-left text-gray-300">Name</th>
            <th class="px-4 py-2 text-left text-gray-300">Score</th>
            <th class="px-4 py-2 text-left text-gray-300">Icon</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <tr class="bg-gray-900"><td class="px-4 py-2 text-gray-400">1</td><td class="px-4 py-2 text-gray-200">Rising Star</td><td class="px-4 py-2 text-gray-400">1–9 pts</td><td class="px-4 py-2">⭐</td></tr>
          <tr class="bg-gray-900/50"><td class="px-4 py-2 text-gray-400">2</td><td class="px-4 py-2 text-gray-200">Word Builder</td><td class="px-4 py-2 text-gray-400">10–19 pts</td><td class="px-4 py-2">👍</td></tr>
          <tr class="bg-gray-900"><td class="px-4 py-2 text-gray-400">3</td><td class="px-4 py-2 text-gray-200">Hot Streak</td><td class="px-4 py-2 text-gray-400">20–29 pts</td><td class="px-4 py-2">🔥</td></tr>
          <tr class="bg-gray-900/50"><td class="px-4 py-2 text-gray-400">4</td><td class="px-4 py-2 text-gray-200">Triple Threat</td><td class="px-4 py-2 text-gray-400">30–49 pts</td><td class="px-4 py-2">🏆</td></tr>
          <tr class="bg-gray-900"><td class="px-4 py-2 text-gray-400">5</td><td class="px-4 py-2 text-gray-200">Scrabble Legend</td><td class="px-4 py-2 text-gray-400">50+ pts</td><td class="px-4 py-2">🌟</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-gray-300 mb-4">When you see your achievement, click <strong class="text-purple-300">Save</strong> to file it permanently. You can add an optional note before saving. All filed achievements are stored in your account and linked to your UUID.</p>

    <div class="rounded-lg border border-blue-800/40 bg-blue-900/10 p-4 mb-4">
      <p class="text-sm text-blue-300 font-medium mb-2">💡 Memory WordBench — Your Personal Word Memory Tool</p>
      <p class="text-xs text-gray-400 mb-2">The Memory WordBench works like a set of flash cards. As you solve words and save them, each entry gets a definition — creating a personal vocabulary deck you can scroll through anytime to jog your memory.</p>
      <ul class="text-xs text-gray-400 space-y-1">
        <li>→ Use the ◀ ▶ arrows to flip through your saved words like memory cards</li>
        <li>→ Each card shows the word, its score, and meaning — perfect for recall practice</li>
        <li>→ Add personal notes to words (click ✏️ Edit) to create mnemonics or context</li>
        <li>→ Over time, your workbench becomes a curated study deck of words you discovered through play</li>
        <li>→ Many players report noticeably better spelling accuracy and word recall after regular use</li>
      </ul>
    </div>

    <!-- Demo: Memory WordBench Card -->
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 mb-4">
      <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-3">Demo — Memory WordBench (Flash Card Mode) <span class="text-gray-600">— click ◀ ▶ to flip, tap card to reveal</span></p>
      <div class="text-center py-4" id="guide-fc-container">
        <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-2" id="guide-fc-counter">Flash Card 1 / 4</p>
        <div class="fc-guide-card p-5 bg-gray-800 rounded-xl border border-purple-800/50 inline-block min-w-[200px] cursor-pointer transition-shadow hover:shadow-lg hover:shadow-purple-900/20" id="guide-fc-body">
          <span class="font-mono font-extrabold text-2xl text-white uppercase tracking-widest" id="guide-fc-word">QUARTZ</span>
          <span class="block text-sm text-blue-400 mt-1" id="guide-fc-pts">24 pts</span>
          <div id="guide-fc-meaning" class="mt-3">
            <p class="text-xs text-gray-500 italic animate-pulse">Tap to reveal meaning</p>
          </div>
        </div>
        <div class="flex items-center justify-center gap-4 mt-3">
          <button id="guide-fc-prev" class="px-3 py-1 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-all">&lt;</button>
          <span class="text-xs text-gray-500" id="guide-fc-cat">manual</span>
          <button id="guide-fc-next" class="px-3 py-1 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-all">&gt;</button>
        </div>
      </div>
      <p class="text-[10px] text-gray-500 mt-2">↑ Tap card to slowly reveal meaning. Use ◀ ▶ to flip through cards with animation.</p>
    </div>

    <script>
      (function() {
        const cards = [
          { word: 'QUARTZ', pts: 24, meaning: '(noun) A hard mineral consisting of silica', cat: 'manual' },
          { word: 'ZAX', pts: 19, meaning: '(noun) A tool for cutting roofing slates', cat: 'rare-letters' },
          { word: 'QI', pts: 11, meaning: '(noun) The vital force in Chinese philosophy', cat: 'two-letter' },
          { word: 'JOKILY', pts: 20, meaning: '(adverb) In a joking or humorous manner', cat: 'high-scoring' }
        ];
        let idx = 0, revealed = false, direction = 'next';
        const wordEl = document.getElementById('guide-fc-word');
        const ptsEl = document.getElementById('guide-fc-pts');
        const meaningEl = document.getElementById('guide-fc-meaning');
        const counterEl = document.getElementById('guide-fc-counter');
        const catEl = document.getElementById('guide-fc-cat');
        const bodyEl = document.getElementById('guide-fc-body');

        function render() {
          if (!wordEl || !bodyEl) return;
          const c = cards[idx];
          wordEl.textContent = c.word;
          ptsEl.textContent = c.pts + ' pts';
          counterEl.textContent = 'Flash Card ' + (idx + 1) + ' / ' + cards.length;
          catEl.textContent = c.cat;
          if (revealed) {
            meaningEl.innerHTML = '<p class="fc-guide-meaning text-xs text-gray-400 max-w-[220px] mx-auto text-center leading-relaxed">' + c.meaning + '</p>';
          } else {
            meaningEl.innerHTML = '<p class="text-xs text-gray-500 italic animate-pulse">Tap to reveal meaning</p>';
          }
          bodyEl.classList.remove('flip-next', 'flip-prev');
          void bodyEl.offsetWidth;
          bodyEl.classList.add(direction === 'next' ? 'flip-next' : 'flip-prev');
        }

        if (bodyEl) {
          bodyEl.addEventListener('click', function() {
            if (!revealed) { revealed = true; direction = 'next'; render(); }
          });
        }
        var prevBtn = document.getElementById('guide-fc-prev');
        var nextBtn = document.getElementById('guide-fc-next');
        if (nextBtn) nextBtn.addEventListener('click', function() {
          if (idx < cards.length - 1) { idx++; revealed = false; direction = 'next'; render(); }
        });
        if (prevBtn) prevBtn.addEventListener('click', function() {
          if (idx > 0) { idx--; revealed = false; direction = 'prev'; render(); }
        });
      })();
    </script>

