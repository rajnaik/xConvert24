---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="60-Second Word Finder — Timed Scrabble Challenge" description="Find as many words as you can from 7 random tiles in 60 seconds. Free timed Scrabble word game — no signup, instant play." keywords="60 second word game, timed scrabble, word finder game, scrabble challenge, speed word game, timed word puzzle">

  <main class="mx-auto max-w-3xl px-4 sm:px-6 pb-20 pt-4">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2"><span class="text-green-400">⏱️</span> 60-Second Word Finder</h1>
    <p class="text-sm text-gray-400 mb-6">Find as many words as you can from 7 tiles in 60 seconds. Every valid word scores!</p>

    <!-- Game Setup -->
    <div id="game-setup" class="rounded-xl border border-green-800/50 bg-gray-900/50 p-6 text-center">
      <p class="text-gray-300 mb-4">You'll get 7 random Scrabble tiles. Make as many words (2-7 letters) as you can before time runs out.</p>
      <div class="flex items-center justify-center gap-4 mb-6">
        <label class="text-sm text-gray-400">Dictionary:</label>
        <select id="sixty-dict" class="h-8 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white">
          <option value="sowpods">SOWPODS (International)</option>
          <option value="twl">TWL (North America)</option>
        </select>
      </div>
      <button id="start-btn" class="px-8 py-3 rounded-xl bg-green-600 text-white font-bold text-lg hover:bg-green-500 transition-colors shadow-lg shadow-green-900/30">▶ Start Game</button>
    </div>

    <!-- Game Active -->
    <div id="game-active" class="hidden">
      <!-- Timer + Score bar -->
      <div class="flex items-center justify-between mb-4 p-3 rounded-xl border border-green-800/50 bg-gray-900/50">
        <div class="flex items-center gap-2">
          <span class="text-2xl">⏱️</span>
          <span id="timer-display" class="text-3xl font-black text-green-400 font-mono tabular-nums">60</span>
          <span class="text-sm text-gray-500">sec</span>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-500 uppercase">Score</p>
          <p id="score-display" class="text-2xl font-black text-amber-400 font-mono">0</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-500 uppercase">Words</p>
          <p id="words-count" class="text-2xl font-black text-blue-400 font-mono">0</p>
        </div>
      </div>

      <!-- Tiles -->
      <div id="sixty-tiles" class="flex gap-2 justify-center mb-6"></div>

      <!-- Input -->
      <div class="flex gap-2 mb-4">
        <input id="sixty-input" type="text" maxlength="7" placeholder="Type a word..." class="flex-1 h-12 px-4 bg-gray-800 border border-gray-700 rounded-xl text-lg text-white uppercase tracking-wider font-mono placeholder-gray-500 focus:outline-none focus:border-green-500" autocomplete="off" />
        <button id="sixty-submit" class="h-12 px-6 rounded-xl bg-green-600 text-white font-bold hover:bg-green-500 transition-colors">Go</button>
      </div>

      <!-- Feedback -->
      <div id="sixty-feedback" class="hidden mb-4 p-3 rounded-lg text-center text-sm font-medium"></div>

      <!-- Found words -->
      <div id="found-words" class="flex flex-wrap gap-2 mb-4"></div>
    </div>

    <!-- Game Over -->
    <div id="game-over" class="hidden rounded-xl border border-green-800/50 bg-gray-900/50 p-8 text-center">
      <p class="text-4xl mb-3" id="result-emoji">🎉</p>
      <p class="text-2xl font-black text-white mb-2" id="result-title">Time's Up!</p>
      <div class="flex items-center justify-center gap-8 my-6">
        <div><p id="final-score" class="text-3xl font-black text-amber-400">0</p><p class="text-xs text-gray-500">Points</p></div>
        <div><p id="final-words" class="text-3xl font-black text-blue-400">0</p><p class="text-xs text-gray-500">Words</p></div>
        <div><p id="final-best" class="text-3xl font-black text-purple-400">—</p><p class="text-xs text-gray-500">Best Word</p></div>
      </div>
      <!-- Missed words -->
      <div id="missed-section" class="hidden mt-6 pt-4 border-t border-gray-800 text-left">
        <p class="text-xs text-gray-500 uppercase mb-2">Words you missed (top 20)</p>
        <div id="missed-words" class="flex flex-wrap gap-1.5"></div>
      </div>
      <div class="flex gap-3 justify-center mt-6">
        <button id="play-again-btn" class="px-6 py-3 rounded-xl bg-green-600 text-white font-bold hover:bg-green-500 transition-colors">🔄 Play Again</button>
        <button id="share-btn" class="px-6 py-3 rounded-xl bg-purple-600/30 border border-purple-500/50 text-purple-300 font-bold hover:bg-purple-600/50 transition-colors">📋 Share</button>
      </div>
    </div>

    <!-- Personal best -->
    <div class="mt-6 p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <span class="text-sm text-gray-400">🏆 Personal Best</span>
      <span id="personal-best" class="text-lg font-bold text-amber-400 font-mono">—</span>
    </div>
  </main>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the 60-Second Word Finder?", "acceptedAnswer": { "@type": "Answer", "text": "A timed Scrabble word game where you get 7 random letter tiles and must find as many valid words as possible in 60 seconds. Words are scored using standard Scrabble tile values. The game uses the same SOWPODS and TWL dictionaries as our main word finder." } },
      { "@type": "Question", "name": "How is the 60-Second Word Finder scored?", "acceptedAnswer": { "@type": "Answer", "text": "Each valid word scores the sum of its tile values (using standard Scrabble scoring: A=1, B=3, C=3, etc.). Longer words naturally score more. Your total score is the sum of all valid words found within the 60-second time limit." } },
      { "@type": "Question", "name": "Can I use the same tile twice in one word?", "acceptedAnswer": { "@type": "Answer", "text": "No. Each tile can only be used once per word, just like in real Scrabble. However, you can reuse tiles across different words — the 7 tiles are available for every word you submit during the round." } }
    ]
  }
  </script>

  <script is:inline>
  (function() {
    var SCORES = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
    var TILE_BAG = 'AAAAAAAAABBCCDDDDEEEEEEEEEEEEFFGGGHHIIIIIIIIIJKLLLLMMNNNNNNOOOOOOOOPPQRRRRRRSSSSTTTTTTUUUUVVWWXYYZ';
    var WORDS = [];
    var dictLoaded = false;
    var gameActive = false;
    var timer = null;
    var timeLeft = 60;
    var score = 0;
    var foundWords = [];
    var currentTiles = '';
    var PB_KEY = 'swf-60s-pb';

    // Load personal best
    var pb = parseInt(localStorage.getItem(PB_KEY) || '0');
    document.getElementById('personal-best').textContent = pb > 0 ? pb + ' pts' : '—';

    // Load dictionary preference
    var dictPref = localStorage.getItem('scbDictionary') || 'sowpods';
    document.getElementById('sixty-dict').value = dictPref;

    // Load dictionary
    function loadDict(dictName) {
      var urls = dictName === 'twl'
        ? ['/data/twl06-2-7.json', '/data/sowpods-8-15.json']
        : ['/data/sowpods-2-7.json', '/data/sowpods-8-15.json'];
      Promise.all(urls.map(function(u) { return fetch(u).then(function(r) { return r.json(); }); }))
        .then(function(results) {
          WORDS = results[0].concat(results[1] || []).map(function(w) { return w.toUpperCase(); });
          dictLoaded = true;
          document.getElementById('start-btn').textContent = '\u25B6 Start Game';
        })
        .catch(function() {
          document.getElementById('start-btn').textContent = '\u274C Dict failed';
        });
    }
    document.getElementById('start-btn').textContent = '\u23F3 Loading...';
    loadDict(dictPref);

    document.getElementById('sixty-dict').addEventListener('change', function() {
      dictPref = this.value;
      localStorage.setItem('scbDictionary', dictPref);
      dictLoaded = false;
      document.getElementById('start-btn').textContent = '\u23F3 Loading...';
      loadDict(dictPref);
    });

    // Generate 7 random tiles from the Scrabble bag
    function drawTiles() {
      var bag = TILE_BAG.split('');
      var tiles = '';
      for (var i = 0; i < 7; i++) {
        var idx = Math.floor(Math.random() * bag.length);
        tiles += bag[idx];
        bag.splice(idx, 1);
      }
      return tiles;
    }

    function renderTiles(tiles) {
      var html = tiles.split('').map(function(letter) {
        var pts = SCORES[letter] || 0;
        return '<div class="w-12 h-16 rounded-lg flex flex-col items-center justify-center select-none" style="background:linear-gradient(145deg,#d4f0d4,#b8e8b8);box-shadow:inset 0 2px 0 rgba(255,255,255,0.5),inset 0 -3px 0 rgba(0,0,0,0.08),0 4px 8px rgba(0,0,0,0.3);border:2px solid #6db86d;">' +
          '<span class="text-xl font-black text-gray-800">' + letter + '</span>' +
          '<span class="text-[9px] text-gray-600 -mt-0.5">' + pts + '</span>' +
        '</div>';
      }).join('');
      document.getElementById('sixty-tiles').innerHTML = html;
    }

    function canMake(word, rack) {
      var available = rack.split('');
      for (var i = 0; i < word.length; i++) {
        var idx = available.indexOf(word[i]);
        if (idx === -1) return false;
        available.splice(idx, 1);
      }
      return true;
    }

    function wordScore(word) {
      return word.split('').reduce(function(s, c) { return s + (SCORES[c] || 0); }, 0);
    }

    function isValidWord(word) {
      return WORDS.indexOf(word) !== -1;
    }

    function startGame() {
      if (!dictLoaded) return;
      gameActive = true;
      timeLeft = 60;
      score = 0;
      foundWords = [];
      currentTiles = drawTiles();

      document.getElementById('game-setup').classList.add('hidden');
      document.getElementById('game-over').classList.add('hidden');
      document.getElementById('game-active').classList.remove('hidden');

      renderTiles(currentTiles);
      document.getElementById('timer-display').textContent = '60';
      document.getElementById('timer-display').classList.remove('text-red-400');
      document.getElementById('timer-display').classList.add('text-green-400');
      document.getElementById('score-display').textContent = '0';
      document.getElementById('words-count').textContent = '0';
      document.getElementById('found-words').innerHTML = '';
      document.getElementById('sixty-feedback').classList.add('hidden');
      document.getElementById('sixty-input').value = '';
      document.getElementById('sixty-input').focus();

      timer = setInterval(function() {
        timeLeft--;
        document.getElementById('timer-display').textContent = timeLeft;
        if (timeLeft <= 10) {
          document.getElementById('timer-display').classList.remove('text-green-400');
          document.getElementById('timer-display').classList.add('text-red-400');
        }
        if (timeLeft <= 0) endGame();
      }, 1000);
    }

    function submitWord() {
      if (!gameActive) return;
      var input = document.getElementById('sixty-input');
      var word = input.value.trim().toUpperCase();
      input.value = '';
      if (!word || word.length < 2) return;

      var fb = document.getElementById('sixty-feedback');

      if (foundWords.indexOf(word) !== -1) {
        showFeedback(fb, '\u26A0\uFE0F Already found!', 'amber');
        return;
      }

      if (!canMake(word, currentTiles)) {
        showFeedback(fb, "\u274C Can't make from tiles", 'red');
        return;
      }

      if (!isValidWord(word)) {
        showFeedback(fb, '\u274C Not in dictionary', 'red');
        return;
      }

      var pts = wordScore(word);
      score += pts;
      foundWords.push(word);
      document.getElementById('score-display').textContent = score;
      document.getElementById('words-count').textContent = foundWords.length;

      var pill = '<span class="px-2 py-1 rounded-lg bg-green-900/30 border border-green-700/50 text-xs text-green-300 font-mono uppercase">' + word + ' <span class="text-green-500 font-bold">' + pts + '</span></span>';
      document.getElementById('found-words').innerHTML += pill;

      showFeedback(fb, '\u2705 ' + word + ' = ' + pts + ' pts!', 'green');
      input.focus();
    }

    function showFeedback(el, text, color) {
      var colors = {
        green: 'bg-green-900/30 border border-green-500/50 text-green-300',
        red: 'bg-red-900/30 border border-red-500/50 text-red-300',
        amber: 'bg-amber-900/30 border border-amber-500/50 text-amber-300'
      };
      el.className = 'mb-4 p-3 rounded-lg text-center text-sm font-medium ' + (colors[color] || '');
      el.textContent = text;
      el.classList.remove('hidden');
      setTimeout(function() { el.classList.add('hidden'); }, 1500);
    }

    function endGame() {
      gameActive = false;
      clearInterval(timer);

      document.getElementById('game-active').classList.add('hidden');
      document.getElementById('game-over').classList.remove('hidden');

      document.getElementById('final-score').textContent = score;
      document.getElementById('final-words').textContent = foundWords.length;

      var best = foundWords.reduce(function(b, w) { var s = wordScore(w); return s > b.s ? {w:w,s:s} : b; }, {w:'\u2014',s:0});
      document.getElementById('final-best').textContent = best.w;

      var emoji = score >= 100 ? '\uD83C\uDFC6' : score >= 60 ? '\uD83C\uDF89' : score >= 30 ? '\uD83D\uDC4D' : '\uD83D\uDCAA';
      document.getElementById('result-emoji').textContent = emoji;
      document.getElementById('result-title').textContent = score >= 100 ? 'Amazing!' : score >= 60 ? 'Great round!' : score >= 30 ? 'Nice work!' : "Time's Up!";

      if (score > pb) {
        pb = score;
        localStorage.setItem(PB_KEY, String(pb));
        document.getElementById('personal-best').textContent = pb + ' pts \uD83C\uDD95';
        document.getElementById('result-title').textContent += ' New PB! \uD83C\uDFC6';
      } else {
        document.getElementById('personal-best').textContent = pb + ' pts';
      }

      // Find missed words
      var allPossible = WORDS.filter(function(w) { return w.length >= 2 && w.length <= 7 && canMake(w, currentTiles); });
      var missed = allPossible.filter(function(w) { return foundWords.indexOf(w) === -1; });
      missed.sort(function(a, b) { return wordScore(b) - wordScore(a); });
      var topMissed = missed.slice(0, 20);

      if (topMissed.length > 0) {
        document.getElementById('missed-section').classList.remove('hidden');
        document.getElementById('missed-words').innerHTML = topMissed.map(function(w) {
          return '<span class="px-2 py-0.5 rounded bg-gray-800 border border-gray-700 text-xs text-gray-400 font-mono uppercase">' + w + ' <span class="text-gray-500">' + wordScore(w) + '</span></span>';
        }).join('');
      } else {
        document.getElementById('missed-section').classList.add('hidden');
      }
    }

    // Event listeners
    document.getElementById('start-btn').addEventListener('click', startGame);
    document.getElementById('play-again-btn').addEventListener('click', startGame);
    document.getElementById('sixty-submit').addEventListener('click', submitWord);
    document.getElementById('sixty-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') submitWord();
    });

    // Share button
    document.getElementById('share-btn').addEventListener('click', function() {
      var bestWord = foundWords.length > 0 ? foundWords.reduce(function(b, w) { var s = wordScore(w); return s > b.s ? {w:w,s:s} : b; }, {w:'\u2014',s:0}).w : '\u2014';
      var text = '\u23F1\uFE0F 60-Second Word Finder\n' +
        '\uD83C\uDFC5 Score: ' + score + ' pts | ' + foundWords.length + ' words\n' +
        '\uD83C\uDFC6 Best: ' + bestWord + '\n\n' +
        'https://www.scrabblewordsfinder.com/sixty-seconds/';
      navigator.clipboard.writeText(text).then(function() {
        document.getElementById('share-btn').textContent = '\u2713 Copied!';
        setTimeout(function() { document.getElementById('share-btn').textContent = '\uD83D\uDCCB Share'; }, 2000);
      });
    });
  })();
  </script>
</Layout>
