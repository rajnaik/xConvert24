---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Disclaimer — Free Scrabble Solver (Not Hasbro)" description="Legal disclaimer for ScrabbleWordsFinder.com. Free instant solver, not affiliated with Hasbro or Mattel. No sign-up required. Educational use only." keywords="scrabble disclaimer, free word finder legal, hasbro, mattel, no signup scrabble tool, instant scrabble solver">


  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Disclaimer</h1>
    <p class="text-gray-400 mb-8">Important legal information about ScrabbleWordsFinder.com.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Trademark Notice</h2>
    <div class="border border-purple-800/50 rounded-lg p-6 mb-6 bg-gray-900/50">
      <p class="text-gray-300 mb-3">ScrabbleWordsFinder.com is <strong class="text-white">NOT</strong> affiliated with, endorsed by, or connected to Hasbro Inc., Mattel Inc., or any official Scrabble organization.</p>
      <p class="text-gray-300">SCRABBLE® is a registered trademark of Hasbro Inc. in the United States and Canada, and of Mattel Inc. in all other countries.</p>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Purpose of This Tool</h2>
    <p class="text-gray-300 mb-4">This tool is provided for <strong class="text-white">educational and entertainment purposes only</strong>. It is designed to:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Help players learn new words and expand their vocabulary</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Assist with practice and study for word games</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Provide a reference tool for casual play</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Settle disputes about word validity in friendly games</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Realtime, Free, Instant — No Sign-Up Required</h2>
    <div class="border border-purple-800/50 rounded-lg p-6 mb-6 bg-gray-900/50">
      <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is built on a simple promise: <strong class="text-white">everything happens in realtime, at your fingertips, for free, with no sign-up required</strong>.</p>
      <p class="text-gray-300 mb-4">When you solve a word, you don't just get results — you get <em>all the information you need in one place, instantly</em>:</p>
      <ul class="space-y-2 text-gray-300 mb-4">
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">⚡</span><span><strong class="text-white">Instant results</strong> — words appear as you type, ranked by score, no waiting</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">⚡</span><span><strong class="text-white">Realtime rack analysis</strong> — tile probability, rack leave quality, and best opening moves update automatically as you enter tiles</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">⚡</span><span><strong class="text-white">Automatic word saving</strong> — click a word and it's instantly saved with its definition, score, and meaning fetched in the background</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">⚡</span><span><strong class="text-white">Free forever</strong> — no trial periods, no premium tiers, no per-day limits</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">⚡</span><span><strong class="text-white">No sign-up</strong> — no email, no password, no account creation. Open the page and start solving immediately</span></li>
      </ul>
      <p class="text-gray-400 text-sm">This tool is provided as-is for educational and recreational use. While we strive for accuracy, we make no guarantees about tournament-level word validity. See below for full details.</p>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">ScrabbleWordsFinder as an Educational Tool</h2>
    <div class="border border-blue-800/50 rounded-lg p-6 mb-6 bg-gray-900/50">
      <p class="text-gray-300 mb-4">ScrabbleWordsFinder is more than a solver — it's a <strong class="text-white">vocabulary-building companion</strong> designed to help you learn:</p>
      <ul class="space-y-2 text-gray-300 mb-4">
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">📚</span><span><strong class="text-white">Word patterns</strong> — discover letter combinations, prefixes, and suffixes that form valid words</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">🧠</span><span><strong class="text-white">Strategic thinking</strong> — learn rack leave analysis, tile probability, and optimal opening moves</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">📖</span><span><strong class="text-white">Vocabulary expansion</strong> — every word comes with a definition, helping you remember and use new words</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">🎯</span><span><strong class="text-white">Score optimization</strong> — understand tile values and board positioning to improve your game</span></li>
      </ul>
      <p class="text-gray-300">Whether you're a student improving English vocabulary, a casual player wanting to get better, or a competitive player studying word lists — this tool helps you learn by doing.</p>
      <p class="text-gray-400 text-sm mt-4">📘 See our <a href="/guide" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">User Guide</a> for tips, tricks, and tactics to improve your Scrabble game.</p>
    </div>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Word Lists &amp; Dictionaries</h2>
    <p class="text-gray-300 mb-4">The word lists used by this tool are sourced from publicly available dictionaries:</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">SOWPODS</strong> — The combined international word list</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">TWL (Tournament Word List)</strong> — The North American tournament list</span></li>
    </ul>
    <p class="text-gray-300 mb-4">These lists are publicly documented and widely used across word game reference tools.</p>
    <p class="text-gray-400 text-sm mt-3">📖 Learn more: <a href="/blog/scrabble-dictionaries-languages-weird-words" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Scrabble Dictionaries, Languages & the Strangest Legal Words</a></p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">No Guarantee of Word Validity</h2>
    <p class="text-gray-300 mb-4">We make <strong class="text-white">no guarantee</strong> that words shown by this tool will be accepted in official tournament play. Dictionary lists are updated periodically, and tournament organizers may use different versions or supplements. Always defer to the official word list and adjudication process used in your specific tournament or event.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Use at Your Own Discretion</h2>
    <p class="text-gray-300 mb-4">This tool is a reference aid. How you use it — whether during live games, for study, or for settling debates — is entirely your choice and responsibility.</p>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>We encourage fair play and using this tool ethically</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>Many tournaments prohibit electronic aids during play — respect the rules of your event</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span>We are not responsible for any consequences of using this tool during competitive play</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Not Responsible for Game Outcomes</h2>
    <p class="text-gray-300 mb-4">ScrabbleWordsFinder.com is not liable for any game outcomes, disputed words, tournament disqualifications, or any other consequences arising from the use of this tool. Use it wisely, play fair, and have fun.</p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is ScrabbleWordsFinder affiliated with Hasbro or Mattel?", "acceptedAnswer": { "@type": "Answer", "text": "No, ScrabbleWordsFinder is an independent tool and is not affiliated with, endorsed by, or sponsored by Hasbro, Mattel, or any official Scrabble brand owner." } },
    { "@type": "Question", "name": "Can I use ScrabbleWordsFinder during tournament play?", "acceptedAnswer": { "@type": "Answer", "text": "Word-finding tools are not permitted during official tournament play. ScrabbleWordsFinder is designed for practice, study, and casual games only." } },
    { "@type": "Question", "name": "Are the word scores always accurate?", "acceptedAnswer": { "@type": "Answer", "text": "Scores are calculated based on standard tile values. Actual in-game scores may differ due to board position, premium squares, and blank tile usage." } }
  ]
}
</script>
</Layout>
