---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Diamond Badges & Achievement Tiers — 20 Levels" description="Earn diamond badges through daily activities and word score achievements. Progress from Word Maker to Grand Word Deity across 20 tiers. Free, no sign-up." keywords="scrabble badges, diamond badges, word game progression, scrabble tiers, word maker badge, lex legend badge, grand word deity, scrabble achievements, diamond rewards, rising star, hot streak, triple threat, scrabble legend, word builder">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Diamond Badges & Achievement Tiers — Progression Levels",
    "description": "Earn diamond badges through daily activities (15 tiers) and word score achievement badges (5 tiers). From Word Maker to Grand Word Deity.",
    "url": "https://www.scrabblewordsfinder.com/badges/",
    "isPartOf": { "@type": "WebSite", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I earn diamond badges on ScrabbleWordsFinder?",
        "acceptedAnswer": { "@type": "Answer", "text": "Diamond badges are earned by accumulating diamonds. You earn diamonds by completing all 7 daily activities (Word of the Day, Quiz, Memory WordBench, Daily Rack, Daily Anagram, 60-Second Challenge, and Cows & Bulls) in a single day. Each full day earns 1 diamond, and badges unlock at milestones: 25, 100, 250, 500, 1000, 2500, and 5000 diamonds." }
      },
      {
        "@type": "Question",
        "name": "What are the 7 badge tiers?",
        "acceptedAnswer": { "@type": "Answer", "text": "The 15 badge tiers range from Word Maker (25 diamonds) through Word Smith (100), Word Master (250), Word Wizard (500), Grand Lexicon (1,000), Scrabble Sage (2,500), Lex Legend (5,000), Vocabulary Virtuoso (10,000), Dictionary Guardian (20,000), Letter Lord (40,000), Tile Titan (75,000), Word Emperor (125,000), Lexicon Immortal (250,000), Alphabet Ascendant (500,000), to Grand Word Deity (1,000,000 diamonds). Each represents a milestone of daily dedication." }
      },
      {
        "@type": "Question",
        "name": "Where can I see my current badge progress?",
        "acceptedAnswer": { "@type": "Answer", "text": "Your badge progress is visible on the MyBag page. It shows your total diamonds, earned badges in full colour, and locked badges greyed out with a lock icon so you always know what you're working towards." }
      }
    ]
  })} />

  <main class="mx-auto max-w-4xl px-4 sm:px-6 pb-20 pt-4">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/" class="hover:text-amber-400 transition-colors">Home</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Badges</span>
    </nav>

    <!-- Hero -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">
        <span class="text-amber-400">💎</span> Diamond Badges
      </h1>
      <p class="text-gray-300 text-base sm:text-lg leading-relaxed max-w-2xl">
        Earn diamonds by completing all 7 daily activities each day. As your diamond collection grows, you unlock increasingly prestigious badges — visual proof of your dedication to word mastery.
      </p>
    </div>

    <!-- How it works stat strip -->
    <div class="mb-10 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
      <div class="flex flex-wrap items-center justify-center gap-6 text-center">
        <div><p class="text-xl font-bold text-amber-400">7</p><p class="text-xs text-gray-400">Daily activities</p></div>
        <div><p class="text-xl font-bold text-amber-400">7 ⭐ = 1 💎</p><p class="text-xs text-gray-400">All stars earn a diamond</p></div>
        <div><p class="text-xl font-bold text-amber-400">15</p><p class="text-xs text-gray-400">Diamond badge tiers</p></div>
        <div><p class="text-xl font-bold text-amber-400">5</p><p class="text-xs text-gray-400">Word score tiers</p></div>
        <div><p class="text-xl font-bold text-amber-400">1,000,000</p><p class="text-xs text-gray-400">Diamonds for top tier</p></div>
      </div>
    </div>

    <!-- Badge Tiers Grid -->
    <h2 class="text-xl font-semibold text-white mb-6">The 15 Badge Tiers</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      <!-- Word Maker -->
      <div class="rounded-2xl border-2 border-purple-500/40 bg-gradient-to-b from-purple-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-purple-400/70 transition-colors">
        <img src="/badges/word-maker.svg" alt="Word Maker badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-purple-300 mb-1">Word Maker</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">25 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Your first milestone. You've committed to daily word practice and earned your first badge.</p>
      </div>

      <!-- Word Smith -->
      <div class="rounded-2xl border-2 border-blue-500/40 bg-gradient-to-b from-blue-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-blue-400/70 transition-colors">
        <img src="/badges/word-smith.svg" alt="Word Smith badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-blue-300 mb-1">Word Smith</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">100 💎 Diamonds</p>
        <p class="text-xs text-gray-400">A dedicated player. Over 3 months of consistent daily play gets you here.</p>
      </div>

      <!-- Word Master -->
      <div class="rounded-2xl border-2 border-green-500/40 bg-gradient-to-b from-green-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-green-400/70 transition-colors">
        <img src="/badges/word-master.svg" alt="Word Master badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-green-300 mb-1">Word Master</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">250 💎 Diamonds</p>
        <p class="text-xs text-gray-400">True mastery through persistence. Nearly 9 months of daily diamonds.</p>
      </div>

      <!-- Word Wizard -->
      <div class="rounded-2xl border-2 border-violet-500/40 bg-gradient-to-b from-violet-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-violet-400/70 transition-colors">
        <img src="/badges/word-wizard.svg" alt="Word Wizard badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-violet-300 mb-1">Word Wizard</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">500 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Magical dedication. You've made word practice a deep part of your routine.</p>
      </div>

      <!-- Grand Lexicon -->
      <div class="rounded-2xl border-2 border-amber-500/40 bg-gradient-to-b from-amber-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-amber-400/70 transition-colors">
        <img src="/badges/grand-lexicon.svg" alt="Grand Lexicon badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-amber-300 mb-1">Grand Lexicon</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">1,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">A walking dictionary. Nearly 3 years of daily diamonds. Extraordinary commitment.</p>
      </div>

      <!-- Scrabble Sage -->
      <div class="rounded-2xl border-2 border-teal-500/40 bg-gradient-to-b from-teal-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-teal-400/70 transition-colors">
        <img src="/badges/scrabble-sage.svg" alt="Scrabble Sage badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-teal-300 mb-1">Scrabble Sage</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">2,500 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Wisdom earned through years of wordplay. Only the most devoted reach this level.</p>
      </div>

      <!-- Lex Legend -->
      <div class="rounded-2xl border-2 border-yellow-500/40 bg-gradient-to-b from-yellow-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-yellow-400/70 transition-colors">
        <img src="/badges/lex-legend.svg" alt="Lex Legend badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-yellow-300 mb-1">Lex Legend</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">5,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Legendary status. Over 13 years of daily diamonds or accelerated through Diamond Hunt mining.</p>
      </div>

      <!-- Vocabulary Virtuoso -->
      <div class="rounded-2xl border-2 border-rose-500/40 bg-gradient-to-b from-rose-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-rose-400/70 transition-colors">
        <img src="/badges/vocabulary-virtuoso.svg" alt="Vocabulary Virtuoso badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-rose-300 mb-1">Vocabulary Virtuoso</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">10,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Elite vocabulary mastery. Your word knowledge surpasses casual players by orders of magnitude.</p>
      </div>

      <!-- Dictionary Guardian -->
      <div class="rounded-2xl border-2 border-sky-500/40 bg-gradient-to-b from-sky-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-sky-400/70 transition-colors">
        <img src="/badges/dictionary-guardian.svg" alt="Dictionary Guardian badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-sky-300 mb-1">Dictionary Guardian</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">20,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Protector of words. You guard the dictionary with the dedication of a true scholar.</p>
      </div>

      <!-- Letter Lord -->
      <div class="rounded-2xl border-2 border-orange-500/40 bg-gradient-to-b from-orange-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-orange-400/70 transition-colors">
        <img src="/badges/letter-lord.svg" alt="Letter Lord badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-orange-300 mb-1">Letter Lord</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">40,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Commander of all 26 letters. Every tile bends to your will.</p>
      </div>

      <!-- Tile Titan -->
      <div class="rounded-2xl border-2 border-red-500/40 bg-gradient-to-b from-red-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-red-400/70 transition-colors">
        <img src="/badges/tile-titan.svg" alt="Tile Titan badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-red-300 mb-1">Tile Titan</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">75,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">A giant among word players. Your tile rack mastery is unmatched.</p>
      </div>

      <!-- Word Emperor -->
      <div class="rounded-2xl border-2 border-fuchsia-500/40 bg-gradient-to-b from-fuchsia-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-fuchsia-400/70 transition-colors">
        <img src="/badges/word-emperor.svg" alt="Word Emperor badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-fuchsia-300 mb-1">Word Emperor</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">125,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Royal authority over language. Your word empire spans the entire dictionary.</p>
      </div>

      <!-- Lexicon Immortal -->
      <div class="rounded-2xl border-2 border-cyan-500/40 bg-gradient-to-b from-cyan-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-cyan-400/70 transition-colors">
        <img src="/badges/lexicon-immortal.svg" alt="Lexicon Immortal badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-cyan-300 mb-1">Lexicon Immortal</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">250,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Eternal word mastery. Your dedication transcends mortal limits.</p>
      </div>

      <!-- Alphabet Ascendant -->
      <div class="rounded-2xl border-2 border-indigo-500/40 bg-gradient-to-b from-indigo-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-indigo-400/70 transition-colors">
        <img src="/badges/alphabet-ascendant.svg" alt="Alphabet Ascendant badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-indigo-300 mb-1">Alphabet Ascendant</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">500,000 💎 Diamonds</p>
        <p class="text-xs text-gray-400">Mythical status. You have risen above all but the divine tier.</p>
      </div>

      <!-- Grand Word Deity (full width, ultimate treatment) -->
      <div class="sm:col-span-2 lg:col-span-3 rounded-2xl border-2 border-yellow-500/60 bg-gradient-to-r from-amber-950/40 to-yellow-950/30 p-8 flex flex-col sm:flex-row items-center gap-6 hover:border-yellow-400/80 transition-colors relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 ULTIMATE</div>
        <img src="/badges/grand-word-deity.svg" alt="Grand Word Deity badge" class="w-36 h-36 shrink-0" loading="lazy" />
        <div class="text-center sm:text-left">
          <h3 class="text-2xl font-black text-yellow-300 mb-1">Grand Word Deity</h3>
          <p class="text-amber-400 font-semibold mb-2">1,000,000 💎 Diamonds</p>
          <p class="text-sm text-gray-300 leading-relaxed">The ultimate pinnacle of word mastery. Reaching Grand Word Deity requires extraordinary dedication — a million diamonds earned through years of daily play, Diamond Hunt mining, and special events. This badge is the rarest honour on ScrabbleWordsFinder, reserved for those who have truly ascended beyond mortal word players.</p>
        </div>
      </div>

    </div>

    <!-- Word Score Achievement Tiers -->
    <h2 class="text-xl font-semibold text-white mb-4">Word Score Achievement Tiers</h2>
    <p class="text-gray-300 text-sm mb-6">When you find a word using the solver and save it, you earn an achievement badge based on that word's Scrabble score. These 5 tiers celebrate individual word mastery — from common finds to legendary bingo-level discoveries.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      <!-- Rising Star -->
      <div class="rounded-2xl border-2 border-blue-500/40 bg-gradient-to-b from-blue-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-blue-400/70 transition-colors">
        <img src="/badges/rising-star.svg" alt="Rising Star badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-blue-300 mb-1">Rising Star</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">1–9 pts</p>
        <p class="text-xs text-gray-400">Common short words — you're building vocabulary one word at a time.</p>
      </div>

      <!-- Word Builder -->
      <div class="rounded-2xl border-2 border-green-500/40 bg-gradient-to-b from-green-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-green-400/70 transition-colors">
        <img src="/badges/word-builder.svg" alt="Word Builder badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-green-300 mb-1">Word Builder</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">10–19 pts</p>
        <p class="text-xs text-gray-400">Solid mid-range words showing consistent quality and growing tile awareness.</p>
      </div>

      <!-- Hot Streak -->
      <div class="rounded-2xl border-2 border-orange-500/40 bg-gradient-to-b from-orange-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-orange-400/70 transition-colors">
        <img src="/badges/hot-streak.svg" alt="Hot Streak badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-orange-300 mb-1">Hot Streak</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">20–29 pts</p>
        <p class="text-xs text-gray-400">High-value tiles and smart placement knowledge — you're on fire.</p>
      </div>

      <!-- Triple Threat -->
      <div class="rounded-2xl border-2 border-yellow-500/40 bg-gradient-to-b from-yellow-950/30 to-gray-900/80 p-6 flex flex-col items-center text-center hover:border-yellow-400/70 transition-colors">
        <img src="/badges/triple-threat.svg" alt="Triple Threat badge" class="w-28 h-28 mb-4" loading="lazy" />
        <h3 class="text-lg font-bold text-yellow-300 mb-1">Triple Threat</h3>
        <p class="text-amber-400 font-semibold text-sm mb-2">30–49 pts</p>
        <p class="text-xs text-gray-400">Expert-level finds using rare letters combined with length — premium-square worthy.</p>
      </div>

      <!-- Scrabble Legend (full width, ultimate) -->
      <div class="sm:col-span-2 lg:col-span-3 rounded-2xl border-2 border-purple-500/60 bg-gradient-to-r from-purple-950/40 to-violet-950/30 p-8 flex flex-col sm:flex-row items-center gap-6 hover:border-purple-400/80 transition-colors relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-purple-500/70">🌟 PINNACLE</div>
        <img src="/badges/scrabble-legend.svg" alt="Scrabble Legend badge" class="w-36 h-36 shrink-0" loading="lazy" />
        <div class="text-center sm:text-left">
          <h3 class="text-2xl font-black text-purple-300 mb-1">Scrabble Legend</h3>
          <p class="text-amber-400 font-semibold mb-2">50+ pts</p>
          <p class="text-sm text-gray-300 leading-relaxed">Bingo-level mastery — the pinnacle of word scoring. Finding words worth 50+ points requires combining rare high-value tiles (Q, Z, X, J) with length and placement skill. This badge marks you as a true word game legend.</p>
        </div>
      </div>

    </div>

    <!-- Summary table -->
    <h2 class="text-xl font-semibold text-white mb-4">Quick Reference</h2>

    <div class="overflow-x-auto mb-10 rounded-xl border border-gray-700/50">
      <table class="w-full text-sm">
        <thead class="bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Badge</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Tier</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-300">Diamonds</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Theme</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Approx. Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <tr class="bg-gray-900">
            <td class="px-4 py-3"><img src="/badges/word-maker.svg" alt="" class="w-8 h-8 inline-block mr-2" />Word Maker</td>
            <td class="px-4 py-3 text-purple-400">1</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">25</td>
            <td class="px-4 py-3 text-gray-300">Beginner</td>
            <td class="px-4 py-3 text-gray-400">~0.4 hours</td>
          </tr>
          <tr class="bg-gray-800/50">
            <td class="px-4 py-3"><img src="/badges/word-smith.svg" alt="" class="w-8 h-8 inline-block mr-2" />Word Smith</td>
            <td class="px-4 py-3 text-blue-400">2</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">100</td>
            <td class="px-4 py-3 text-gray-300">Crafter</td>
            <td class="px-4 py-3 text-gray-400">~1.7 hours</td>
          </tr>
          <tr class="bg-gray-900">
            <td class="px-4 py-3"><img src="/badges/word-master.svg" alt="" class="w-8 h-8 inline-block mr-2" />Word Master</td>
            <td class="px-4 py-3 text-green-400">3</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">250</td>
            <td class="px-4 py-3 text-gray-300">Skilled</td>
            <td class="px-4 py-3 text-gray-400">~4 hours</td>
          </tr>
          <tr class="bg-gray-800/50">
            <td class="px-4 py-3"><img src="/badges/word-wizard.svg" alt="" class="w-8 h-8 inline-block mr-2" />Word Wizard</td>
            <td class="px-4 py-3 text-violet-400">4</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">500</td>
            <td class="px-4 py-3 text-gray-300">Magical</td>
            <td class="px-4 py-3 text-gray-400">~8 hours</td>
          </tr>
          <tr class="bg-gray-900">
            <td class="px-4 py-3"><img src="/badges/grand-lexicon.svg" alt="" class="w-8 h-8 inline-block mr-2" />Grand Lexicon</td>
            <td class="px-4 py-3 text-amber-400">5</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">1,000</td>
            <td class="px-4 py-3 text-gray-300">Vocabulary</td>
            <td class="px-4 py-3 text-gray-400">~17 hours</td>
          </tr>
          <tr class="bg-gray-800/50">
            <td class="px-4 py-3"><img src="/badges/scrabble-sage.svg" alt="" class="w-8 h-8 inline-block mr-2" />Scrabble Sage</td>
            <td class="px-4 py-3 text-teal-400">6</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">2,500</td>
            <td class="px-4 py-3 text-gray-300">Wise</td>
            <td class="px-4 py-3 text-gray-400">~42 hours</td>
          </tr>
          <tr class="bg-gray-900">
            <td class="px-4 py-3"><img src="/badges/lex-legend.svg" alt="" class="w-8 h-8 inline-block mr-2" />Lex Legend</td>
            <td class="px-4 py-3 text-yellow-400">7</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">5,000</td>
            <td class="px-4 py-3 text-gray-300">Legendary</td>
            <td class="px-4 py-3 text-gray-400">~83 hours</td>
          </tr>
          <tr class="bg-gray-800/50">
            <td class="px-4 py-3"><img src="/badges/vocabulary-virtuoso.svg" alt="" class="w-8 h-8 inline-block mr-2" />Vocabulary Virtuoso</td>
            <td class="px-4 py-3 text-rose-400">8</td>
            <td class="px-4 py-3 text-center text-amber-400 font-medium">10,000</td>
            <td class="px-4 py-3 text-gray-300">Elite</td>
            <td class="px-4 py-3 text-gray-400">~167 hours</td>
          </tr>
          <tr class="bg-gray-900">
