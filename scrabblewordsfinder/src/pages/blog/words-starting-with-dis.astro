      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">DISQUALIFY</td><td class="px-4 py-3 text-amber-600 font-bold">25</td><td class="px-4 py-3">10</td><td class="px-4 py-3">Q(10)+Y(4) power</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">DISKLIKE</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">8</td><td class="px-4 py-3">K(5)+K(5) double</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">DISEMBARK</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">9</td><td class="px-4 py-3">K(5)+B(3)+M(3)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">DISJOINT</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">8</td><td class="px-4 py-3">J(8) power tile</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">DISJOINED</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">9</td><td class="px-4 py-3">J(8)+D(2) bingo</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">DISYOKED</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">8</td><td class="px-4 py-3">Y(4)+K(5)+D(2)</td></tr>
