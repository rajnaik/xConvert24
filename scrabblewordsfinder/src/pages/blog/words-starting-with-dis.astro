      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">DISPLACE</td><td class="px-4 py-3 text-amber-600 font-bold">13</td><td class="px-4 py-3">8</td><td class="px-4 py-3">P(3)+C(3) + bingo</td></tr>
    </tbody>
  </table>
</div>

