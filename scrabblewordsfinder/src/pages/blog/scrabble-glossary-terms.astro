---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Glossary — Key Terms Explained"
  description="Every Scrabble term you need to know. Bingo, hook, leave, rack, stem, and 30+ more defined."
  keywords="scrabble, scrabble, glossary, terms"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Glossary — Key Terms Explained",
    "description": "Every Scrabble term you need to know. Bingo, hook, leave, rack, stem, and 30+ more defined.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-glossary-terms" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a bingo in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "A bingo is when a player uses all 7 tiles from their rack in a single turn, earning a 50-point bonus on top of the word's score. Bingos typically score 60-100+ points and are often game-deciding plays." }
      },
      {
        "@type": "Question",
        "name": "What does hook mean in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "A hook is a single letter added to the front or back of an existing word to form a new valid word. For example, adding S to PLAY makes PLAYS, or adding C to LASH makes CLASH. Hooks let you score points from two words simultaneously." }
      },
      {
        "@type": "Question",
        "name": "What is rack leave in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Rack leave refers to the tiles remaining on your rack after making a play. Good rack leave means keeping tiles that work well together for future turns — balanced vowels/consonants, bingo-friendly combinations, or tiles that pair with common board openings." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/beginner-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Beginner Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Glossary — Key Terms Explained</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Every Scrabble term you need to know. Bingo, hook, leave, rack, stem, and 30+ more defined.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
