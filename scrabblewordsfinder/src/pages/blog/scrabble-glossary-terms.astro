    { "@type": "Question", "name": "What does 'leave' mean in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "The leave is the set of tiles remaining on your rack after you make a play. Good leave management means choosing plays that leave you with a balanced, flexible rack for future turns rather than just maximising the current turn's score." }},
    { "@type": "Question", "name": "What is a phoney in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "A phoney is a word played that is not in the official dictionary. If unchallenged, it stays on the board and scores normally. If challenged and found invalid, the player loses their turn. Playing phoneys is a legitimate strategy in competitive Scrabble." }}
  ]
