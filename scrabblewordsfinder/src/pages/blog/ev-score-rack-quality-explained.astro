      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-bold text-orange-400">20-39</td><td class="px-4 py-3">Weak</td><td class="px-4 py-3">Consider exchanging 2-4 tiles</td><td class="px-4 py-3 font-mono">UUOIIVC</td></tr>
