  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words Ending in -ITY ‚Äî QUALITY, QUANTITY, MAJORITY","description":"Master -ITY suffix bingos in Scrabble: QUALITY (19pts), QUANTITY (20pts), MAJORITY (20pts). Q-containing noun suffix bingos.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-ending-in-ity"}})} />
