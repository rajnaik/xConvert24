      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">6</p><p class="text-xs text-gray-400">Base Score</p></div>
          <div><p class="text-xl font-bold text-amber-400">9</p><p class="text-xs text-gray-400">M on DL</p></div>
          <div><p class="text-xl font-bold text-amber-400">12</p><p class="text-xs text-gray-400">M on TL</p></div>
          <div><p class="text-xl font-bold text-amber-400">12</p><p class="text-xs text-gray-400">MM on DW</p></div>
        </div>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-no-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
