            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">JACKING</td><td class="px-4 py-3 text-blue-400">25</td><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-gray-400">J(8) + K(5)</td></tr>
