        "acceptedAnswer": { "@type": "Answer", "text": "In NASPA tournaments, the penalty is 10 points deducted for each minute (or fraction thereof) over the 25-minute limit. Going 2 minutes over costs you 20 points — often the difference between winning and losing." }
      }
