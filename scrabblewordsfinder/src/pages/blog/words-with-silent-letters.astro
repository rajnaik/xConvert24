---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words With Silent Letters in Scrabble"
  description="KNIGHT, PSYCHOLOGY, RHYTHM — words with silent letters that are valid and useful in Scrabble."
  keywords="scrabble, words, with, silent, letters"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words With Silent Letters in Scrabble",
    "description": "KNIGHT, PSYCHOLOGY, RHYTHM — words with silent letters that are valid and useful in Scrabble.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-with-silent-letters" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Scrabble words have silent letters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Common silent-letter words valid in Scrabble: KNIGHT (14 pts, silent K), GNAW (8 pts, silent G), WRECK (14 pts, silent W), PSALM (9 pts, silent P), LISTEN (6 pts, silent T), HONEST (9 pts, silent H), DEBT (7 pts, silent B), ISLAND (7 pts, silent S)." }
      },
      {
        "@type": "Question",
        "name": "Are silent-letter words good for Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "They can be strategic because opponents may not expect them, and they often use consonant clusters that help clear difficult racks. Words like KNIGHT, GNASH, and PNEUMONIA use letters that might otherwise be hard to play." }
      },
      {
        "@type": "Question",
        "name": "What are the highest-scoring silent-letter words?",
        "acceptedAnswer": { "@type": "Answer", "text": "PSYCHOLOGY (20 pts, silent P), KNIGHTHOOD (19 pts, silent K), ACKNOWLEDGE (22 pts, silent K), and PNEUMONIA (13 pts, silent P) score well. On premium squares, the silent-letter tiles still count toward the word score despite not being pronounced." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words With Silent Letters in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">KNIGHT, PSYCHOLOGY, RHYTHM — words with silent letters that are valid and useful in Scrabble.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
