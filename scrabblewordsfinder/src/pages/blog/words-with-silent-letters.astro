      <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Words Containing WR — silent W patterns</span>
    </a>
  </div>
</div>

<aside class="border-t border-gray-200 dark:border-gray-800 mt-12 pt-8 not-prose">
  <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
  <div class="grid gap-3">
    <a href="/blog/words-containing-gh/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group">
      <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
