          <div><p class="text-xl font-bold text-amber-400">~90%</p><p class="text-xs text-gray-400">Overlap with Scrabble</p></div>
          <div><p class="text-xl font-bold text-amber-400">Proprietary</p><p class="text-xs text-gray-400">Not published</p></div>
          <div><p class="text-xl font-bold text-amber-400">Zynga</p><p class="text-xs text-gray-400">Sole authority</p></div>
        </div>
      </div>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
