  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words Ending in -IC — EXOTIC, TRAFFIC, SPECIFIC","description":"Master -IC suffix words: SPECIFIC (17pts), EXOTIC (15pts), TRAFFIC (15pts). Adjective patterns.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-ending-in-ic"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best -IC words for Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SPECIFIC leads at 17 points (8 letters). EXOTIC and TRAFFIC both score 15 points. The C tile (3pts) in -IC adds consistent value to every word with this ending."}},{"@type":"Question","name":"Why is -IC a strong Scrabble pattern?","acceptedAnswer":{"@type":"Answer","text":"-IC is just 2 tiles but the C is worth 3 points. It turns nouns into adjectives. Many -IC words are 6-8 letters — ideal for bingos and premium square plays."}},{"@type":"Question","name":"What -IC words are bingo candidates?","acceptedAnswer":{"@type":"Answer","text":"SPECIFIC (8 letters, 17pts), ACOUSTIC, DRAMATIC, ELECTRIC (all 8 letters). For 7-letter bingos: ORGANIC, GENERIC, PACIFIC. Look for 5-6 letter roots that take -IC."}}]})} />
