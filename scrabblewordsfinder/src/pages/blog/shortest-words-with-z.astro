---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Shortest Words With Z"
  description="Best short Z words. ZA, ZO, ZAP, ZED — score big with the 10-point Z tile."
  keywords="scrabble, shortest, words, with, z"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Shortest Words With Z",
    "description": "Best short Z words. ZA, ZO, ZAP, ZED — score big with the 10-point Z tile.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/shortest-words-with-z" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the shortest valid Scrabble words with Z?",
        "acceptedAnswer": { "@type": "Answer", "text": "Two-letter Z words: ZA (11), ZO (11 — SOWPODS only). Three-letter Z words include: ZAP (14), ZAX (19), ZED (13), ZEE (12), ZEN (12), ZEP (14), ZIG (13), ZIN (12), ZIP (14), ZIT (12), ZOA (12), ZOO (12). ZA scores highest among 2-letter Z words." }
      },
      {
        "@type": "Question",
        "name": "Is ZA a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes — ZA is valid in both TWL and SOWPODS. It is informal for pizza and scores 11 points (Z=10, A=1). It is one of the most valuable 2-letter words and essential for tight positions when Z cannot be used in longer words." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring short Z word?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZAX (19 pts) is the highest 3-letter Z word, combining Z (10) + A (1) + X (8). ZA (11 pts) is the highest 2-letter Z word. On premium squares, ZA on DLS for Z yields 21 points; on TLS it yields 31 points." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Shortest Words With Z</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Best short Z words. ZA, ZO, ZAP, ZED — score big with the 10-point Z tile.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
