        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">JAK</span><span class="text-blue-400 text-xs">14 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">JEE</span><span class="text-blue-400 text-xs">10 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">JEW</span><span class="text-blue-400 text-xs">13 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">JOE</span><span class="text-blue-400 text-xs">10 pts</span>
        </span>
