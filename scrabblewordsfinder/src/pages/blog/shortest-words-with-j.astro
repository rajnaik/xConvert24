import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Shortest Words With J — Quick J Plays for Scrabble"
  description="Master the shortest J words in Scrabble. JO, JAB, JET, JIG and more — deploy your 8-point J tile fast with these compact power plays. No sign-up needed."
  keywords="shortest words with j, short j words scrabble, 2 letter j words, 3 letter j words, jo scrabble, jab scrabble, j tile strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Shortest Words With J — Quick J Plays for Scrabble",
    "description": "Master the shortest J words in Scrabble. JO, JAB, JET, JIG and more — deploy your 8-point J tile fast.",
    "datePublished": "2026-06-15",
    "dateModified": "2026-07-02",
    "author": { "@type": "Person", "name": "Raj Naik", "url": "https://www.scrabblewordsfinder.com/about/" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
