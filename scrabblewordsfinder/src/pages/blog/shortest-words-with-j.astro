---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Shortest Words With J"
  description="Best short J words for Scrabble. JO, JAB, JET, JIG — deploy your J tile quickly and effectively."
  keywords="scrabble, shortest, words, with, j"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Shortest Words With J",
    "description": "Best short J words for Scrabble. JO, JAB, JET, JIG — deploy your J tile quickly and effectively.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/shortest-words-with-j" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the shortest valid Scrabble words with J?",
        "acceptedAnswer": { "@type": "Answer", "text": "JO (9 pts) is the only 2-letter J word. Three-letter J words include JAB (12), JAG (11), JAM (12), JAR (10), JAW (13), JAY (13), JET (10), JIG (11), JOB (12), JOG (11), JOT (10), JOW (13), JOY (13), and JUS (10)." }
      },
      {
        "@type": "Question",
        "name": "What is JO in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "JO is a Scottish/dialectal word meaning a sweetheart or darling. It scores 9 points (J=8, O=1) and is the only 2-letter word containing J in both TWL and SOWPODS. It is essential for tight board positions where longer J words cannot fit." }
      },
      {
        "@type": "Question",
        "name": "How many 3-letter words with J exist in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "There are approximately 30+ valid 3-letter words containing J in SOWPODS, and slightly fewer in TWL. Common ones include JAB, JAM, JAR, JET, JIG, JOB, JOT, JOY, and JUS. All score well because J alone is worth 8 points." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Shortest Words With J</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Best short J words for Scrabble. JO, JAB, JET, JIG — deploy your J tile quickly and effectively.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
