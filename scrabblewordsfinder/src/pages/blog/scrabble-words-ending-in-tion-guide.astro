        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ POSITION</p><p class="text-xs text-gray-400">10 points · 8 letters · P(3)+O(1)+S(1)+I(1)+TION(4) · All common tiles</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ FUNCTION</p><p class="text-xs text-gray-400">13 points · 8 letters · F(4)+U(1)+N(1)+C(3)+TION(4) · Duplicate N</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">-TION Bingo Strategy</h2>
