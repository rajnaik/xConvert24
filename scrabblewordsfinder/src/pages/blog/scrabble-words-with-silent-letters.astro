---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Silent Letters — KNIGHT, WRECK, PSALM Strategy" description="Master silent-letter words in Scrabble: KNACK (15pts), WRECK (14pts), KNIGHT (13pts), PSALM (9pts), GNAW (8pts). Turn tricky spelling into scoring opportunities." keywords="scrabble silent letter words, knight scrabble, wreck scrabble, psalm scrabble, gnaw scrabble, knack scrabble, silent letters strategy">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Silent Letters — KNIGHT, WRECK, PSALM Strategy","description":"Master silent-letter words in Scrabble with scoring breakdowns for KNIGHT, WRECK, PSALM, GNAW, and KNACK.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-silent-letters"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best silent-letter words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"KNACK (15pts), WRECK (14pts), and KNIGHT (13pts) are top silent-letter words. The silent K, W, and P add tile value without pronunciation, making these words unexpectedly high-scoring."}},{"@type":"Question","name":"Why are silent-letter words strategic in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Silent-letter words use high-value consonants (K=5, W=4, P=3) that opponents may not anticipate. Words like KNIGHT use both K and GH, scoring 13 points from tiles most players discard early."}},{"@type":"Question","name":"Are all silent-letter words valid in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Most common silent-letter words are valid in both SOWPODS and TWL: KNIGHT, WRECK, PSALM, GNAW, KNACK, WRIST, KNEEL, GNAT. Always verify unusual forms with a word checker."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Silent Letters — Hidden Scoring Power</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">Silent letters are a quirk of English spelling — but in Scrabble, they're a hidden advantage. Words like KNIGHT and WRECK pack high-value consonants (K=5, W=4) that many players rush to dump. Knowing these words lets you turn "awkward" tiles into consistent points.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">15</p><p class="text-xs text-gray-400">Top Score (KNACK)</p></div>
          <div><p class="text-xl font-bold text-amber-400">5</p><p class="text-xs text-gray-400">Words Featured</p></div>
          <div><p class="text-xl font-bold text-amber-400">K, W, P, G</p><p class="text-xs text-gray-400">Silent Consonants</p></div>
          <div><p class="text-xl font-bold text-amber-400">4-6</p><p class="text-xs text-gray-400">Letter Range</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top Silent-Letter Words by Score</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 KNACK</p><p class="text-xs text-gray-400">15 points · 5 letters · K(5)+N(1)+A(1)+C(3)+K(5)</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 WRECK</p><p class="text-xs text-gray-400">14 points · 5 letters · W(4)+R(1)+E(1)+C(3)+K(5)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ KNIGHT</p><p class="text-xs text-gray-400">13 points · 6 letters · K(5)+N(1)+I(1)+G(2)+H(4)+T(1)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ PSALM</p><p class="text-xs text-gray-400">9 points · 5 letters · P(3)+S(1)+A(1)+L(1)+M(3)</p></div>
        <div class="p-4 rounded-xl border border-gray-700 bg-gray-800/40"><p class="text-white font-semibold text-sm mb-1">✦ GNAW</p><p class="text-xs text-gray-400">8 points · 4 letters · G(2)+N(1)+A(1)+W(4)</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Silent-Letter Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">KN- words are K-dumpers:</span> KNIGHT, KNACK, KNEEL, KNIT, KNOB, KNOCK — all use K (5pts) in positions opponents forget. Keep K when you see N on your rack.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">WR- words clear W tiles:</span> WRECK, WRIST, WRONG, WRATH, WRITE — W (4pts) combined with common R, E, I creates reliable 10+ point plays without premium squares.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">PS- and GN- surprise plays:</span> PSALM, PSYCHE, GNAT, GNAW — opponents rarely block these openings. Silent P and G use tiles worth 3 and 2 points that might sit idle otherwise.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">KNACK</span><span class="text-blue-400 text-xs">15pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WRECK</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">KNIGHT</span><span class="text-blue-400 text-xs">13pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PSALM</span><span class="text-blue-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">GNAW</span><span class="text-blue-400 text-xs">8pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Silent-letter words are <span class="text-white font-medium">deceptive scorers</span>. Opponents think K, W, and G are hard to place — but KN-, WR-, GN-, and PS- openings make them reliable mid-game plays worth 8-15 points without premium squares.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-kn/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing KN</span></a>
          <a href="/blog/words-containing-wr/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing WR</span></a>
          <a href="/blog/consonant-heavy-rack-strategy/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Consonant-Heavy Rack Strategy</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all silent-letter words from your tiles — free, instant, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
