    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WHISKY</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">6</td><td class="px-4 py-3">K(5) + Y(4) bonuses</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WHACK</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">5</td><td class="px-4 py-3">K(5) + compact</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WHIMSY</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">6</td><td class="px-4 py-3">M(3) + Y(4)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WHAMMY</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Double M + Y</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WHISK</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">5</td><td class="px-4 py-3">K(5) at the end</td></tr>
