  title="Tile Tracking Guide — Count What's Left in the Bag"
  description="Learn tile tracking in Scrabble: how to count remaining tiles, predict opponent's rack, and make informed decisions using tile distribution knowledge."
  keywords="scrabble tile tracking, count tiles scrabble, tile distribution, predict opponent rack, scrabble bag count, remaining tiles strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Tile Tracking Guide — Count What's Left in the Bag",
    "description": "Learn tile tracking in Scrabble: how to count remaining tiles, predict opponent's rack, and make informed decisions.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/tile-tracking-guide" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is tile tracking in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Tile tracking means counting which letters have been played and which remain unseen (in the bag or on your opponent's rack). By crossing off played tiles against the known distribution, you can deduce what's left and make better strategic decisions." }
      },
      {
        "@type": "Question",
        "name": "How many of each letter are in a Scrabble bag?",
        "acceptedAnswer": { "@type": "Answer", "text": "A standard Scrabble bag has 100 tiles: 12 E's, 9 A's and I's, 8 O's, 6 N's/R's/T's, 4 D's/L's/S's/U's, 3 G's, 2 each of B/C/F/H/M/P/V/W/Y, 1 each of J/K/Q/X/Z, and 2 blanks." }
      },
      {
        "@type": "Question",
        "name": "When should you start tracking tiles in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Track from the start if you can, but it becomes critical when the bag has fewer than 15 tiles. At that point, you can deduce your opponent's exact rack by subtracting played tiles and your own tiles from the full distribution. This information is decisive for endgame strategy." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
