      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono">ZIPPY</td><td class="px-4 py-3">19</td><td class="px-4 py-3">Lively and energetic</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">ZIPPER</td><td class="px-4 py-3">19</td><td class="px-4 py-3">A fastening device with interlocking teeth</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono">HAPPY</td><td class="px-4 py-3">15</td><td class="px-4 py-3">Feeling pleasure or contentment</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">WRAPPER</td><td class="px-4 py-3">14</td><td class="px-4 py-3">A cover or enclosing material</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono">PEPPER</td><td class="px-4 py-3">12</td><td class="px-4 py-3">A pungent spice from dried berries</td></tr>
