        <div><p class="text-2xl font-bold text-emerald-400">61</p><p class="text-xs text-gray-400">Guides</p></div>
        <div><p class="text-2xl font-bold text-emerald-400">26</p><p class="text-xs text-gray-400">Single Letters</p></div>
