---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Ending In — Suffix Guides for Scrabble"
  description="61 guides to Scrabble words ending in specific letters and suffixes. Find words ending in Q, J, V, X, Z, -ING, -TION, -ABLE, -OUS, and more."
  keywords="words ending in, scrabble suffixes, words ending with, scrabble word endings, suffix words scrabble, words ending in q, words ending in j"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why learn words by their ending letters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Knowing word endings helps you hook onto existing tiles on the board. If a word already ends in a specific position, you can extend it by adding suffix letters. Endings like -ING, -ED, -ER are especially powerful for parallel plays." }
      },
      {
        "@type": "Question",
        "name": "What are the hardest word endings to use in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Words ending in Q (like SUQ, TRANQ), J (like HAJ, TAJ), and V (like SPIV, PERV) are rare and high-value. Memorising even a few gives you a significant edge over opponents who don't know them." }
      },
      {
        "@type": "Question",
        "name": "How do suffixes help score more points?",
        "acceptedAnswer": { "@type": "Answer", "text": "Adding -ING or -TION to existing words creates 7+ letter plays that earn the 50-point bingo bonus. Suffix knowledge turns 4-letter words into bingos by extending through tiles already on the board." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Words Ending In</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">Words Ending In — Suffix Guides</h1>
    <p class="text-lg text-gray-300 mb-6">
      61 guides covering every useful word ending in Scrabble. From rare endings (Q, J, V) to
      powerful suffixes (-ING, -TION, -ABLE) — master the endings that unlock parallel plays and bingos.
    </p>

    <!-- Stat Strip -->
    <div class="not-prose my-8 p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
