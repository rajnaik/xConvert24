---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With PH — High-Scoring Digraph Strategy" description="Master PH words in Scrabble: PHONE (10pts), GRAPH (11pts), PHOBIA (13pts), PHARMACY (18pts). Learn how to score big with the PH letter combination." keywords="scrabble words with ph, ph scrabble words, phone scrabble, graph scrabble, ph digraph strategy, high scoring ph words">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With PH — High-Scoring Digraph Strategy","description":"Master PH words in Scrabble with scoring breakdowns and strategic placement tips.","datePublished":"2026-06-29","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-ph"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best PH words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top PH words include PHARMACY (18pts), PHOBIA (13pts), GRAPH (11pts), PHONE (10pts), SPHINX (18pts), and TRIUMPH (14pts). PH words score well because P=3 and H=4, giving 7 points just from those two letters."}},{"@type":"Question","name":"How many points is the PH combination worth?","acceptedAnswer":{"@type":"Answer","text":"P (3 points) + H (4 points) = 7 points just from those two tiles. This makes any PH word automatically start with strong base scoring before counting other letters."}},{"@type":"Question","name":"Can PH land on premium squares effectively?","acceptedAnswer":{"@type":"Answer","text":"Yes — placing H on a DLS gives 8 points from H alone. If the entire PH word crosses a DWS, the 7-point PH combination doubles. Target premium squares with the H tile specifically for maximum scoring."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With PH — High-Scoring Digraph Strategy</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-29">June 29, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">The PH digraph is a Scrabble goldmine. P (3pts) and H (4pts) combine for 7 points before you even count the other letters. Words like PHARMACY, SPHINX, and GRAPH pack serious punch — and PH words are plentiful in English thanks to Greek-origin vocabulary.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">7</p><p class="text-xs text-gray-400">PH Base Points</p></div>
          <div><p class="text-xl font-bold text-amber-400">P=3</p><p class="text-xs text-gray-400">+ H=4</p></div>
          <div><p class="text-xl font-bold text-amber-400">2 P-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
          <div><p class="text-xl font-bold text-amber-400">2 H-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top PH Words by Score</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 PHARMACY</p><p class="text-xs text-gray-400">18 points · 8 letters · Bingo potential</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 SPHINX</p><p class="text-xs text-gray-400">18 points · 6 letters · X bonus</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ TRIUMPH</p><p class="text-xs text-gray-400">14 points · 7 letters · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ PHOBIA</p><p class="text-xs text-gray-400">13 points · 6 letters · Common word</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">PH Strategy Tips</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Target H on DLS:</span> H is worth 4 points — on a Double Letter Score it becomes 8. Position PH words so H lands on premium squares for maximum value.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Short PH words:</span> PHO (8pts) and PHI (8pts) are 3-letter PH words that fit anywhere. Use them when the board is crowded and longer words won't fit.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Greek origins:</span> Many PH words come from Greek — PHOTO, PHASE, PHOSPHOR. Know Greek roots and you'll spot PH opportunities others miss.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PHO</span><span class="text-blue-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PHI</span><span class="text-blue-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PHONE</span><span class="text-blue-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">GRAPH</span><span class="text-blue-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PHASE</span><span class="text-blue-400 text-xs">10pts</span></span>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-th/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With TH — Digraph Strategy</span></a>
          <a href="/blog/scrabble-words-with-ch/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With CH — Digraph Strategy</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all PH words instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
