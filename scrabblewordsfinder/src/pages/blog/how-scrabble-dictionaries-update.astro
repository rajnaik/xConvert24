  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How often is the official Scrabble dictionary updated?", "acceptedAnswer": { "@type": "Answer", "text": "The TWL (Tournament Word List) is typically updated every 4-5 years by NASPA. SOWPODS (Collins Scrabble Words) follows a similar cycle but is managed by Collins Dictionary editors. The most recent major updates were in 2014 (TWL06→OWL2014) and ongoing Collins editions." }},
    { "@type": "Question", "name": "Who decides what words get added to the Scrabble dictionary?", "acceptedAnswer": { "@type": "Answer", "text": "For TWL, the NASPA Dictionary Committee reviews submissions and evidence of word usage. For SOWPODS/Collins Scrabble Words, Collins Dictionary editors evaluate words based on their appearance in published sources, frequency of use, and established English dictionaries." }},
    { "@type": "Question", "name": "Can I suggest a word to be added to the Scrabble dictionary?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. NASPA accepts word suggestions from the public. You need to provide evidence the word appears in reputable published sources. Collins also considers submissions through their dictionary feedback channels. However, acceptance typically takes years." }}
  ]
})} />

