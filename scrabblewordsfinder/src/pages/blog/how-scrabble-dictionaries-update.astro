---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="How Scrabble Dictionaries Get Updated"
  description="The process behind adding and removing words from official Scrabble dictionaries. Who decides and how often."
  keywords="scrabble, how, scrabble, dictionaries, update"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "How Scrabble Dictionaries Get Updated",
    "description": "The process behind adding and removing words from official Scrabble dictionaries. Who decides and how often.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/how-scrabble-dictionaries-update" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How often are Scrabble dictionaries updated?",
        "acceptedAnswer": { "@type": "Answer", "text": "The TWL (North American) dictionary is updated every 4-5 years by NASPA. Collins Scrabble Words (SOWPODS) is updated every 2-3 years. The most recent TWL update was TWL06 and Collins updates incorporate new English words adopted into common usage." }
      },
      {
        "@type": "Question",
        "name": "Who decides which words go in the Scrabble dictionary?",
        "acceptedAnswer": { "@type": "Answer", "text": "For TWL, a committee at NASPA (North American Scrabble Players Association) reviews submissions. For Collins, lexicographers at HarperCollins evaluate words based on evidence of usage in published sources." }
      },
      {
        "@type": "Question",
        "name": "Can I suggest a word for the Scrabble dictionary?",
        "acceptedAnswer": { "@type": "Answer", "text": "NASPA accepts word suggestions from players for consideration during review cycles. However, a word must meet strict criteria — typically appearing in at least one standard English dictionary with evidence of sustained usage." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">How Scrabble Dictionaries Get Updated</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">The process behind adding and removing words from official Scrabble dictionaries. Who decides and how often.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
