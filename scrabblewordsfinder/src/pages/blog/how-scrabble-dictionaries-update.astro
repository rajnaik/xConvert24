      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3">Total words</td><td class="px-4 py-3">~187,000</td><td class="px-4 py-3">~279,000</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3">Governing body</td><td class="px-4 py-3">NASPA</td><td class="px-4 py-3">Collins</td></tr>
