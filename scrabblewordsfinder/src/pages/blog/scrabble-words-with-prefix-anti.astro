---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix ANTI- — ANTIQUE, ANXIETY" description="Master ANTI- prefix words: ANXIETY (17pts), ANTIQUE (16pts). Opposition prefix strategy for high-scoring Scrabble plays and bingo opportunities." keywords="scrabble anti prefix, antique scrabble, anxiety scrabble, anti words scrabble, opposition prefix, scrabble prefix strategy">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix ANTI- — ANTIQUE, ANXIETY","description":"Master ANTI- prefix words: ANXIETY (17pts), ANTIQUE (16pts). Opposition prefix strategy for Scrabble.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-anti"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What ANTI- words score highest in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"ANXIETY scores 17 points (7 letters) with X(8) as the power tile. ANTIQUE scores 16 points (7 letters) with QU(11) providing massive value. Both are bingo-length words."}},{"@type":"Question","name":"Is ANTI a valid Scrabble word on its own?","acceptedAnswer":{"@type":"Answer","text":"Yes, ANTI is valid as a standalone 4-letter word (4 points). It can also be extended: ANTIS (plural), or used as a prefix in ANTIQUE, ANXIETY, ANTIGEN, ANTIDOTE."}},{"@type":"Question","name":"How do I use the ANTI- prefix strategically?","acceptedAnswer":{"@type":"Answer","text":"ANTI- is 4 tiles using all common letters (A+N+T+I). Look for 3-4 tile extensions: QUE for ANTIQUE, XIETY for ANXIETY. You can also hook ANTI onto existing words on the board."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix ANTI- — Opposition Prefix</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>4 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">ANTI- is a 4-letter prefix using all common tiles (A, N, T, I — totalling just 4 points) that unlocks premium scoring opportunities. ANXIETY hits 17 points thanks to the X, while ANTIQUE scores 16 with the QU combo. The prefix itself costs almost nothing in tile value, so all scoring power comes from the extension tiles.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">17</p><p class="text-xs text-gray-400">Top Score (ANXIETY)</p></div>
          <div><p class="text-xl font-bold text-amber-400">4</p><p class="text-xs text-gray-400">Prefix Tiles</p></div>
          <div><p class="text-xl font-bold text-amber-400">4pts</p><p class="text-xs text-gray-400">Prefix Cost</p></div>
          <div><p class="text-xl font-bold text-amber-400">7+</p><p class="text-xs text-gray-400">Bingo Length</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top ANTI- Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 ANXIETY</p><p class="text-xs text-gray-400">17 pts · 7 letters · A(1)+N(1)+X(8)+I(1)+E(1)+T(1)+Y(4)</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 ANTIQUE</p><p class="text-xs text-gray-400">16 pts · 7 letters · A(1)+N(1)+T(1)+I(1)+Q(10)+U(1)+E(1)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ ANTIDOTE</p><p class="text-xs text-gray-400">9 pts · 8 letters · A(1)+N(1)+T(1)+I(1)+D(2)+O(1)+T(1)+E(1)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ ANTIGEN</p><p class="text-xs text-gray-400">8 pts · 7 letters · A(1)+N(1)+T(1)+I(1)+G(2)+E(1)+N(1)</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">ANTI- Prefix Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Low-cost prefix, high-value extensions:</span> ANTI costs just 4 points (all 1-point tiles). The scoring comes from what follows: X in ANXIETY (8pts), QU in ANTIQUE (11pts). The prefix is free scaffolding for premium tiles.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Hook onto existing words:</span> If a word on the board starts with a vowel, check if ANTI + that word is valid. ANTI+SOCIAL, ANTI+BODY, ANTI+THESIS — many compounds work as Scrabble plays.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">ANTIQUE uses Q with U:</span> If you draw Q, ANTIQUE should be in your top options. It uses Q naturally with U and the remaining tiles (A, N, T, I, E) are all common 1-pointers you'll likely have.</p></div>
      </div>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ANXIETY</span><span class="text-blue-400 text-xs">17pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ANTIQUE</span><span class="text-blue-400 text-xs">16pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ANTIDOTE</span><span class="text-blue-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ANTIGEN</span><span class="text-blue-400 text-xs">8pts</span></span>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">ANTI- is the <span class="text-white font-medium">cheapest prefix in Scrabble</span> (4 tiles, 4 points) but enables some of the highest-scoring bingos. When you see A+N+T+I on your rack, scan for premium extension tiles like Q, X, or high-value roots.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-prefix-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Prefix UN-</span></a>
          <a href="/blog/scrabble-words-with-prefix-re/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Prefix RE-</span></a>
          <a href="/blog/best-q-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Q Words for Scrabble</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find ANTI- words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
