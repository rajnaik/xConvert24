---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Architecture — Building Terms That Score"
  description="Architecture terms valid in Scrabble with point values. FRIEZE 18pts, VAULT 8pts, PLINTH 11pts, QUOIN 14pts. Architectural vocabulary for competitive players."
  keywords="scrabble architecture words, frieze scrabble points, vault scrabble, plinth scrabble word, quoin scrabble, architecture terms scrabble, building words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Architecture — Building Terms That Score","description":"Architecture terms valid in Scrabble with point values. FRIEZE 18pts, VAULT 8pts, PLINTH 11pts, QUOIN 14pts.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-architecture"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is FRIEZE a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! FRIEZE scores 18 points (F=4, R=1, I=1, E=1, Z=10, E=1). The Z=10 makes this one of the highest-scoring 6-letter architectural words. It means a decorative horizontal band."}},{"@type":"Question","name":"Is PLINTH valid in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes. PLINTH scores 11 points (P=3, L=1, I=1, N=1, T=1, H=4). It means the base of a column or statue. Valid in both TWL and SOWPODS."}},{"@type":"Question","name":"What architecture words score highest in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top architectural Scrabble words: FRIEZE (18pts), QUOIN (14pts), FACADE (12pts), PLINTH (11pts), CUPOLA (10pts), VAULT (8pts). These words feature Z, Q, F, and H tiles."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Architecture — Building Terms That Score</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">Architecture gives Scrabble players an arsenal of unusual, high-scoring words. Classical building terms from Greek, Latin, and French feature Z, Q, F, and H tiles — delivering 10-18 points from words your opponents won't think to challenge.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18 pts</p><p class="text-xs text-gray-400">FRIEZE (Top)</p></div>
          <div><p class="text-xl font-bold text-amber-400">14 pts</p><p class="text-xs text-gray-400">QUOIN</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">PLINTH</p></div>
          <div><p class="text-xl font-bold text-amber-400">8 pts</p><p class="text-xs text-gray-400">VAULT</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">High-Scoring Architecture Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">FRIEZE — 18 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">F=4, R=1, I=1, E=1, Z=10, E=1 · 6 letters · Uses Z tile</p>
        <p class="text-sm text-gray-300 leading-relaxed">A decorative horizontal band along a wall. FRIEZE gets its power from Z=10 plus F=4, delivering 18 base points. On a DWS this becomes 36 — exceptional for a 6-letter word.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🏛️ QUOIN</p><p class="text-xs text-gray-400">14 pts · Q=10, U=1, O=1, I=1, N=1 · Corner stone</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🏛️ FACADE</p><p class="text-xs text-gray-400">12 pts · F=4, A=1, C=3, A=1, D=2, E=1 · Front face</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🏛️ PLINTH</p><p class="text-xs text-gray-400">11 pts · P=3, L=1, I=1, N=1, T=1, H=4 · Column base</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🏛️ CUPOLA</p><p class="text-xs text-gray-400">10 pts · C=3, U=1, P=3, O=1, L=1, A=1 · Dome structure</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Architecture Words</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">VAULT</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">GABLE</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">TRUSS</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">SPIRE</span><span class="text-green-400 text-xs">7pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">ATRIUM</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">ALCOVE</span><span class="text-green-400 text-xs">11pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Architecture Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">FRIEZE for Z placement:</span> Z=10 is always hard to place efficiently. FRIEZE uses it within a 6-letter word with common tiles (R, I, E, E), making it one of the best Z words.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">QUOIN solves Q+U:</span> QUOIN (14pts) uses Q and U plus common tiles O, I, N. Less known than QUEEN or QUILT, so opponents rarely challenge it.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">VAULT hooks well:</span> VAULT (8pts) becomes VAULTS (9pts), VAULTED (11pts), or VAULTING (13pts). Strong extension potential near premium squares.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Architecture words are <span class="text-white font-medium">rarely challenged</span> because they sound legitimate. FRIEZE, QUOIN, PLINTH — these look like real English words (because they are). Your opponent will assume they're valid.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/best-z-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Z Words in Scrabble</span></a>
          <a href="/blog/best-q-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Q Words in Scrabble</span></a>
          <a href="/blog/foreign-words-valid-in-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Foreign Words Valid in Scrabble</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Check any architecture term — free Scrabble word validator, instant results</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
