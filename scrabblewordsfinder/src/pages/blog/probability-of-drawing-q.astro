            <tr class="bg-gray-900"><td class="px-4 py-3 text-white">93 (opening)</td><td class="px-4 py-3 text-gray-300">7.5%</td><td class="px-4 py-3 text-gray-300">1.1%</td><td class="px-4 py-3 text-gray-400">Turn 1</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white">70</td><td class="px-4 py-3 text-gray-300">10%</td><td class="px-4 py-3 text-gray-300">1.4%</td><td class="px-4 py-3 text-gray-400">Early game</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white">50</td><td class="px-4 py-3 text-gray-300">14%</td><td class="px-4 py-3 text-gray-300">2.0%</td><td class="px-4 py-3 text-gray-400">Mid game</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white">30</td><td class="px-4 py-3 text-gray-300">23.3%</td><td class="px-4 py-3 text-gray-300">3.3%</td><td class="px-4 py-3 text-gray-400">Late mid</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white">20</td><td class="px-4 py-3 text-gray-300">35%</td><td class="px-4 py-3 text-gray-300">5.0%</td><td class="px-4 py-3 text-gray-400">Late game</td></tr>
