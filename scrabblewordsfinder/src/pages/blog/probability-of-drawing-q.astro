      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Q Endgame Penalty</h2>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
