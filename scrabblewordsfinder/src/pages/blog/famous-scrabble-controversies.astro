---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Famous Scrabble Controversies"
  description="The biggest controversies in competitive Scrabble history. Tile manipulation, clock violations, and dictionary disputes."
  keywords="scrabble, famous, scrabble, controversies"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Famous Scrabble Controversies",
    "description": "The biggest controversies in competitive Scrabble history. Tile manipulation, clock violations, and dictionary disputes.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/famous-scrabble-controversies" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the biggest controversies in Scrabble history?",
        "acceptedAnswer": { "@type": "Answer", "text": "Major controversies include the 2005 blank tile palming incident, disputes over offensive words in dictionaries, the Collins vs TWL dictionary split, and allegations of tile manipulation at international tournaments." }
      },
      {
        "@type": "Question",
        "name": "Has anyone been caught cheating at Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, several players have been caught cheating. The most notable case was a player caught hiding blank tiles during the 2012 US National Championship. Players have also been disqualified for peeking at tiles in the bag." }
      },
      {
        "@type": "Question",
        "name": "Why did Scrabble remove offensive words?",
        "acceptedAnswer": { "@type": "Answer", "text": "In 2020, amid broader cultural reckonings, Hasbro (NA) and Mattel (international) removed slurs from official tournament lists. The decision was controversial — some argued for free play while others welcomed the change as overdue." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/tournament/" class="hover:text-blue-400 transition-colors text-gray-300">Tournament</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Famous Scrabble Controversies</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">The biggest controversies in competitive Scrabble history. Tile manipulation, clock violations, and dictionary disputes.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
