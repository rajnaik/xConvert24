  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Is PE a Scrabble Word? Yes! (Score 4 Points)","description":"PE is a valid Scrabble word worth 4 points in both TWL and SOWPODS. It's the 17th letter of the Hebrew alphabet.","datePublished":"2026-06-29","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/is-pe-a-scrabble-word"}})} />
