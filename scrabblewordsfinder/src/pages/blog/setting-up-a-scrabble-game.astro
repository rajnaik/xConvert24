    { "@type": "Question", "name": "How many tiles does each player start with in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Each player draws 7 tiles from the bag at the start of the game. After each turn, players replenish their rack back to 7 tiles until the bag is empty." }},
    { "@type": "Question", "name": "Who goes first in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Each player draws one tile from the bag — the player who draws closest to A goes first. Blanks beat all letters. If there's a tie, redraw. Return tiles to the bag after determining order." }},
    { "@type": "Question", "name": "How many tiles are in a Scrabble game?", "acceptedAnswer": { "@type": "Answer", "text": "A standard English Scrabble game contains 100 tiles: 98 letter tiles and 2 blank tiles. The distribution varies by letter — E has 12 tiles while Q, Z, X, J, and K have only 1 each." }}
