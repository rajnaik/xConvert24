---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Setting Up a Scrabble Game"
  description="Step-by-step guide to setting up a Scrabble game. Tile drawing, first player, and board orientation."
  keywords="scrabble, setting, up, a, scrabble, game"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Setting Up a Scrabble Game",
    "description": "Step-by-step guide to setting up a Scrabble game. Tile drawing, first player, and board orientation.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/setting-up-a-scrabble-game" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you set up a Scrabble game?",
        "acceptedAnswer": { "@type": "Answer", "text": "Unfold the board, place all 100 tiles face-down in the bag or pile, each player draws one tile — closest to A goes first (blanks beat A). Return drawn tiles, shuffle, then each player draws 7 tiles. The first word must cross the center star square." }
      },
      {
        "@type": "Question",
        "name": "Who goes first in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Each player draws one tile from the bag. The player whose tile is closest to A goes first (A beats B, B beats C, etc.). A blank tile beats all letters. In case of a tie, redraw. Return tiles to the bag, reshuffle, then draw starting racks of 7." }
      },
      {
        "@type": "Question",
        "name": "What do you need to play Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "You need: the game board, 100 letter tiles, tile racks (one per player), the tile bag, a score pad and pen, and 2-4 players. For tournament play, add a chess clock (25 min/player). A dictionary should be available for challenges." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/beginner-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Beginner Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Setting Up a Scrabble Game</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Step-by-step guide to setting up a Scrabble game. Tile drawing, first player, and board orientation.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
