---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing IU — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing IU with scores, definitions, and strategic tips. Master IU words for better Scrabble plays."
  keywords="scrabble words containing iu, iu words scrabble, words with iu, scrabble iu word list, iu scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing IU — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing IU with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-iu" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring IU words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Top IU words include STADIUM (10 pts), CALCIUM (11 pts), PREMIUM (11 pts), MEDIUM (12 pts), and PODIUM (11 pts). IU appears mainly in -IUM scientific endings." } },
      { "@type": "Question", "name": "How many Scrabble words contain IU?", "acceptedAnswer": { "@type": "Answer", "text": "~40 valid Scrabble words contain IU. Common examples include TITANIUM, AQUARIUM, OPIUM, RADIUM, RIUM, STADIUM, and CALCIUM." } },
      { "@type": "Question", "name": "What strategy works best with IU tiles?", "acceptedAnswer": { "@type": "Answer", "text": "IU appears mainly in -IUM endings (STADIUM, CALCIUM, PREMIUM, MEDIUM, PODIUM, HELIUM). These are scientific and Latin-derived words. AQUARIUM (19 pts) is the top scorer. IU words help dump vowels in a productive way, turning I+U combinations into solid mid-range plays." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Letter Pair Content</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing IU — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">IU is a relatively rare pair appearing in about 40 valid Scrabble words, mostly through the -IUM suffix (STADIUM, CALCIUM, PREMIUM, MEDIUM, PODIUM, HELIUM). AQUARIUM (19 pts) is the premium target. Knowing IU words helps when your rack has both I and U tiles — these plays efficiently clear two vowels while scoring respectably.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top IU Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">STADIUM</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A sports arena</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">CALCIUM</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A chemical element</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">PREMIUM</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">Of superior quality</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">MEDIUM</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A middle state</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">PODIUM</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A raised platform</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">HELIUM</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A noble gas</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">TITANIUM</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A strong metal</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">AQUARIUM</td><td class="px-4 py-3 text-blue-400">19</td><td class="px-4 py-3 text-gray-400">A fish tank</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">OPIUM</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">A narcotic substance</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">RADIUM</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">A radioactive element</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">RIUM</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">A suffix element</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">~40</p><p class="text-xs text-gray-400">Valid IU words</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Rare</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for IU Words</h2>

      <p>IU appears mainly in -IUM endings (STADIUM, CALCIUM, PREMIUM, MEDIUM, PODIUM, HELIUM). These are scientific and Latin-derived words. AQUARIUM (19 pts) is the top scorer. IU words help dump vowels in a productive way, turning I+U combinations into solid mid-range plays.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">STADIUM</span><span class="text-blue-400 text-xs">10 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CALCIUM</span><span class="text-blue-400 text-xs">11 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PREMIUM</span><span class="text-blue-400 text-xs">11 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">MEDIUM</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PODIUM</span><span class="text-blue-400 text-xs">11 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">HELIUM</span><span class="text-blue-400 text-xs">11 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">IU provides <span class="text-white font-medium">~40 words</span>. STADIUM (10 pts) and CALCIUM (11 pts) are top targets. OPIUM (9 pts) and RADIUM (9 pts) are reliable everyday plays that efficiently use the IU combination near premium squares.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every IU word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
