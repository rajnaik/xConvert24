      { "@type": "Question", "name": "Can you still play removed words in casual Scrabble games?", "acceptedAnswer": { "@type": "Answer", "text": "In casual home games, house rules apply — you can agree to allow any words. However, in sanctioned tournaments and rated club play, removed words are invalid and will lose you your turn if challenged. Online platforms like Scrabble GO also enforce the updated word lists." } },
      { "@type": "Question", "name": "How does the Scrabble dictionary committee decide which words to add or remove?", "acceptedAnswer": { "@type": "Answer", "text": "Dictionary committees (NASPA for North America, Collins for international play) review words based on evidence of usage in published sources, cultural sensitivity, and linguistic merit. New words need documented usage over several years. Removals typically follow community petitions or broader cultural shifts around offensive language." } }
    ]
  })} />

