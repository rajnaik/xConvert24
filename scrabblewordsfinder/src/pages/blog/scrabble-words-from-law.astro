---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Law — Legal Terms That Score Big"
  description="Legal terms valid in Scrabble with point values. JUDGE 14pts, PROXY 17pts, WRIT 7pts, JURY 14pts, EQUITY 18pts. Courtroom vocabulary for competitive players."
  keywords="scrabble legal words, judge scrabble points, proxy scrabble, writ scrabble word, jury scrabble, legal terms scrabble, law words scrabble valid"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Law — Legal Terms That Score Big","description":"Legal terms valid in Scrabble with point values. JUDGE 14pts, PROXY 17pts, WRIT 7pts, JURY 14pts, EQUITY 18pts.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-law"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is JUDGE a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! JUDGE scores 14 points (J=8, U=1, D=2, G=2, E=1). Valid in both TWL and SOWPODS. The J tile contributes 8 of the 14 points."}},{"@type":"Question","name":"Is PROXY valid in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes. PROXY scores 17 points (P=3, R=1, O=1, X=8, Y=4). The X=8 and Y=4 make this a powerful 5-letter word valid in competitive Scrabble."}},{"@type":"Question","name":"What legal words score highest in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top legal Scrabble words: EQUITY (18pts), PROXY (17pts), ACQUIT (17pts), JUDGE (14pts), JURY (14pts). Words with J, X, and Q dominate because legal terminology uses these rare letters frequently."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Law — Legal Terms That Score Big</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">The courtroom is surprisingly rich with Scrabble gold. Legal English draws heavily from Latin and French — languages full of J, Q, X, and high-value consonants. Words like JUDGE, PROXY, and EQUITY deliver 14-18 points without needing premium squares.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18 pts</p><p class="text-xs text-gray-400">EQUITY (Top)</p></div>
          <div><p class="text-xl font-bold text-amber-400">17 pts</p><p class="text-xs text-gray-400">PROXY</p></div>
          <div><p class="text-xl font-bold text-amber-400">14 pts</p><p class="text-xs text-gray-400">JUDGE</p></div>
          <div><p class="text-xl font-bold text-amber-400">7 pts</p><p class="text-xs text-gray-400">WRIT</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">High-Scoring Legal Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">EQUITY — 18 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">E=1, Q=10, U=1, I=1, T=1, Y=4 · 6 letters · Uses Q with U</p>
        <p class="text-sm text-gray-300 leading-relaxed">Fairness in law; ownership value in finance. EQUITY deploys Q=10 with U support and adds Y=4 for 18 base points. On a DWS, that's 36 points from a single common word.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚖️ PROXY</p><p class="text-xs text-gray-400">17 pts · P=3, R=1, O=1, X=8, Y=4 · Acting for another</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚖️ ACQUIT</p><p class="text-xs text-gray-400">17 pts · A=1, C=3, Q=10, U=1, I=1, T=1 · Found not guilty</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">⚖️ JUDGE</p><p class="text-xs text-gray-400">14 pts · J=8, U=1, D=2, G=2, E=1 · Court official</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">⚖️ JURY</p><p class="text-xs text-gray-400">14 pts · J=8, U=1, R=1, Y=4 · Panel of peers</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Mid-Range Legal Words</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">JUROR</span><span class="text-green-400 text-xs">12pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">FELONY</span><span class="text-green-400 text-xs">12pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">BRIEF</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">WRIT</span><span class="text-green-400 text-xs">7pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">LEGAL</span><span class="text-green-400 text-xs">6pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">TRIAL</span><span class="text-green-400 text-xs">5pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Legal Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">JUDGE for J dumps:</span> When you draw J early, JUDGE is reliable. J=8 does the heavy lifting, and UDGE are common tiles you'll likely hold.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">PROXY for X placement:</span> X=8 and Y=4 give PROXY 12 points from just two tiles. Look for open O positions near premium squares.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">WRIT hooks perfectly:</span> WRIT (7pts) becomes WRITS (8pts) or WRITTEN (10pts). Short legal words extend naturally for hook plays.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Legal words excel because they contain <span class="text-white font-medium">rare high-value tiles (J, Q, X) paired with common vowels</span>. JUDGE, JURY, EQUITY, and PROXY all use difficult tiles alongside letters you'll always have available.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/best-j-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best J Words in Scrabble</span></a>
          <a href="/blog/best-q-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Q Words in Scrabble</span></a>
          <a href="/blog/best-x-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best X Words in Scrabble</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Check any legal term in our free Scrabble dictionary — instant validation</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
