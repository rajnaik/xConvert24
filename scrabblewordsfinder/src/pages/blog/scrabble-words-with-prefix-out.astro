---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix OUT- — OUTFOX, OUTWORK, OUTWIT" description="Top OUT- prefix Scrabble words: OUTFOX (16pts), OUTWORK (13pts), OUTWIT (9pts). Master the competitive surpassing prefix for board dominance." keywords="scrabble out prefix words, outfox scrabble, outwork scrabble, outwit scrabble, out prefix strategy, competitive prefix scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix OUT- — OUTFOX, OUTWORK, OUTWIT","description":"Master OUT- prefix words in Scrabble: OUTFOX (16pts), OUTWORK (13pts), OUTWIT (9pts) with competitive surpassing prefix strategy.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-out"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the highest-scoring OUT- prefix words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"OUTFOX scores 16 points thanks to F(4) and X(8). OUTWORK scores 13 points with W(4) and K(5). OUTPUT scores 8 points as a reliable mid-scorer. The OUT- prefix adds only 3 points in tiles but unlocks high-value base words."}},{"@type":"Question","name":"How does the OUT- prefix work strategically in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"OUT- means surpassing or exceeding. It hooks onto existing words on the board — if FOX is played, you can front-hook OUT to create OUTFOX for the full word score. OUT- words also take back hooks: OUTWORK+S, OUTWIT+S, OUTFOX+ED."}},{"@type":"Question","name":"How many valid OUT- words exist in the Scrabble dictionary?","acceptedAnswer":{"@type":"Answer","text":"Over 200 valid OUT- words exist in SOWPODS. Common ones include OUTRUN, OUTDO, OUTBID, OUTPACE, OUTWIT, OUTFOX, and OUTWORK. Many are 6-7 letters, making them accessible without needing a full bingo rack."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix OUT- — Surpass Your Opponent</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">OUT- is the competitive prefix — it means surpassing, exceeding, or beating. OUTFOX uses the 8-point X for a massive 16-point play, OUTWORK pairs W(4) with K(5) for 13 points, and OUTWIT delivers a clean 9 from just 6 tiles. The prefix itself costs only 3 points (O+U+T) but unlocks access to high-value consonant bases.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">16</p><p class="text-xs text-gray-400">Top Score (OUTFOX)</p></div>
          <div><p class="text-xl font-bold text-amber-400">3</p><p class="text-xs text-gray-400">Prefix Tiles (OUT)</p></div>
          <div><p class="text-xl font-bold text-amber-400">200+</p><p class="text-xs text-gray-400">Valid OUT- Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">3pts</p><p class="text-xs text-gray-400">Prefix Cost (O+U+T)</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top OUT- Prefix Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 OUTFOX</p><p class="text-xs text-gray-400">16 points · 6 letters · O(1)+U(1)+T(1)+F(4)+O(1)+X(8) · X carries</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 OUTWORK</p><p class="text-xs text-gray-400">13 points · 7 letters · O(1)+U(1)+T(1)+W(4)+O(1)+R(1)+K(5) · W+K</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ OUTWIT</p><p class="text-xs text-gray-400">9 points · 6 letters · O(1)+U(1)+T(1)+W(4)+I(1)+T(1) · W adds 4</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ OUTPUT</p><p class="text-xs text-gray-400">8 points · 6 letters · O(1)+U(1)+T(1)+P(3)+U(1)+T(1) · P adds 3</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">OUT- Prefix Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Hook existing board words:</span> If FOX, WIT, or WORK sits on the board, hook OUT- in front for the full word score. You invest only 3 tiles (O+U+T) to claim the entire word.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Target high-value bases:</span> OUT- works best with F, X, K, W bases. OUTFOX (16), OUTWORK (13), OUTWIT (9). The cheap 3-point prefix amplifies expensive consonants.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Extend with back hooks:</span> OUTFOX+ED, OUTWORK+ED, OUTWIT+S. Many OUT- words accept -ED, -S, or -ING suffixes, turning 6-letter plays into 7-8 letter bingos.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OUTFOX</span><span class="text-blue-400 text-xs">16pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OUTWORK</span><span class="text-blue-400 text-xs">13pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OUTWIT</span><span class="text-blue-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OUTPUT</span><span class="text-blue-400 text-xs">8pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">OUT- is the <span class="text-white font-medium">competitive prefix</span> — it literally means to surpass. Pair it with X, K, or W bases for maximum return. The 3-point prefix investment unlocks 200+ valid words, and most accept further suffixes for bingo potential.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-starting-with-out/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Starting With OUT</span></a>
          <a href="/blog/scrabble-words-with-prefix-over/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix OVER-</span></a>
          <a href="/blog/scrabble-words-with-prefix-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix UN-</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all OUT- prefix words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
