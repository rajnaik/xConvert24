>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Top Bingo Stems — SATIRE, RETINA & The Best 6-Letter Foundations",
    "description": "The 15 most productive bingo stems in Scrabble ranked by output. Learn SATIRE, RETINA, SALINE, ORNATE and how each pairs with dozens of 7th letters for valid bingos.",
