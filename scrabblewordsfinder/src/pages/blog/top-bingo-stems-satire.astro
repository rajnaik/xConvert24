          <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3">6</td><td class="px-4 py-3">STERNA</td><td class="px-4 py-3">55</td><td class="px-4 py-3">ASTERN, ANTLERS</td></tr>
          <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3">7</td><td class="px-4 py-3">SORTIE</td><td class="px-4 py-3">54</td><td class="px-4 py-3">STORIES, ROSIEST</td></tr>
