          <a href="/blog/scrabble-parallel-play-mastery/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">ŌåÆ</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Parallel Play Mastery</span></a>
          <a href="/blog/scrabble-highest-points-per-tile/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">ŌåÆ</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Highest Points Per Tile Ranking</span></a>
