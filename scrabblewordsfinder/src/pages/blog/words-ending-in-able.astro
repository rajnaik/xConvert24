            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">WORKABLE</td><td class="px-4 py-3 text-blue-400">17</td><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-gray-400">Capable of functioning</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">REVOCABLE</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-gray-400">Can be withdrawn</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">LAUGHABLE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-gray-400">Ridiculous or funny</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">TAXABLE</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-gray-400">Subject to taxation</td></tr>
