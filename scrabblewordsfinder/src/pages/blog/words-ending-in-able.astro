      },
      {
        "@type": "Question",
        "name": "How many valid ABLE words exist in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Over 1,000 valid -ABLE words exist in the official Scrabble dictionaries (SOWPODS/TWL). This makes it one of the most productive suffixes available — nearly any transitive verb can take -ABLE to form a valid adjective (readable, washable, breakable, enjoyable)." }
      }
    ]
