            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">EQUITABLE</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-gray-400">Fair and impartial</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">EXCITABLE</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-gray-400">Easily aroused</td></tr>
