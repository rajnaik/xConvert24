---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout title="Words With No Vowels Except Y — Consonant Words for Scrabble | ScrabbleWordsFinder.com" description="Find valid Scrabble words with no traditional vowels — only Y as the vowel sound. Essential for consonant-heavy racks: GYM, HYMN, GLYPH, CRY and more." keywords="words without vowels scrabble, no vowel words, y as vowel words, consonant only words, gym scrabble, hymn scrabble word">

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Words With No Vowels Except Y — Consonant Words for Scrabble",
  "datePublished": "2026-06-15",
  "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" },
  "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What Scrabble words have no vowels except Y?", "acceptedAnswer": { "@type": "Answer", "text": "Common examples include CRY (8 pts), DRY (7 pts), FLY (9 pts), FRY (9 pts), GYM (9 pts), HYMN (12 pts), LYNX (14 pts), GLYPH (14 pts), CRYPT (12 pts), and PYGMY (15 pts). Y acts as the vowel sound in all these words." }},
    { "@type": "Question", "name": "Can you play a word with no vowels in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Technically yes — SH, HM, and a few other 2-letter words contain no vowels at all (not even Y). But most 'no vowel' words use Y as their vowel substitute. These are perfectly valid in both SOWPODS and TWL." }},
    { "@type": "Question", "name": "What is the highest-scoring word with no vowels except Y?", "acceptedAnswer": { "@type": "Answer", "text": "PYGMY scores 15 points with all consonants plus two Y tiles. GLYPH and LYNX score 14 each. For extremely high scores, RHYTHMS (16 pts) uses Y as its only vowel in a 7-letter bingo-eligible word." }}
  ]
})} />

<div class="max-w-3xl mx-auto px-4">
<article class="prose dark:prose-invert prose-gray max-w-none">

<nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
  <a href="/blog/" class="hover:text-amber-500 transition-colors">← Blog</a>
