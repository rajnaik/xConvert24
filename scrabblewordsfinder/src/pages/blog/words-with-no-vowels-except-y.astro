---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words With No Vowels Except Y"
  description="Valid Scrabble words using Y as the only vowel. CRY, DRY, FLY, GYM, HYMN and more."
  keywords="scrabble, words, with, no, vowels, except, y"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words With No Vowels Except Y",
    "description": "Valid Scrabble words using Y as the only vowel. CRY, DRY, FLY, GYM, HYMN and more.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-with-no-vowels-except-y" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Scrabble words have no vowels except Y?",
        "acceptedAnswer": { "@type": "Answer", "text": "Common examples: BY (7), CRY (8), DRY (7), FLY (9), FRY (9), GYM (9), GYP (9), HYP (8), LYN (6), MY (7), PLY (8), PRY (8), SHY (9), SKY (10), SLY (6), SPY (8), STY (6), TRY (6), WHY (12), WRY (9). All valid without A, E, I, O, or U." }
      },
      {
        "@type": "Question",
        "name": "What is the longest word with no standard vowels in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "RHYTHMS (16 pts, 7 letters) is often cited as the longest common word without A, E, I, O, or U. GLYCYLS (15 pts, 7 letters) and SYZYGYS (depending on dictionary) are other long examples. Some argue Y is functionally a vowel in these words." }
      },
      {
        "@type": "Question",
        "name": "Are vowelless words useful in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Extremely useful when your rack has no standard vowels. Rather than exchanging tiles, playing SH, HM, or words like CRYPT, LYMPH, GLYPH, and PSYCH lets you score points and redraw. These situations occur in about 5% of racks." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words With No Vowels Except Y</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Valid Scrabble words using Y as the only vowel. CRY, DRY, FLY, GYM, HYMN and more.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
