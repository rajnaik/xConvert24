---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words Ending in OE — Uncommon Vowel Endings" description="Master OE-ending words in Scrabble. From OBOE to FOE, learn the best scoring words that end in OE and how to play them strategically." keywords="words ending in OE, scrabble OE words, OE ending words, scrabble word list, oboe scrabble, canoe scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Words Ending in OE — Uncommon Vowel Endings",
    "datePublished": "2026-06-22",
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "description": "Master OE-ending words in Scrabble. From OBOE to FOE, learn the best scoring words that end in OE and how to play them strategically."
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What Scrabble words end in OE?", "acceptedAnswer": { "@type": "Answer", "text": "Common OE-ending words include OBOE, CANOE, ALOE, SHOE, FLOE, SLOE, HOE, FOE, TOE, ROE, DOE, and JOE. These range from 3 to 10 points." }},
      { "@type": "Question", "name": "Is OBOE a valid Scrabble word?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, OBOE is valid in both TWL and SOWPODS dictionaries. It scores 6 points and is a useful word for clearing double vowels from your rack." }},
      { "@type": "Question", "name": "How to use OE-ending words strategically?", "acceptedAnswer": { "@type": "Answer", "text": "OE-ending words are excellent for parallel plays alongside existing words. Short OE words like HOE, FOE, and TOE work well in tight board positions and can connect to premium squares." }}
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400">← Blog</a>
        <span>›</span>
        <span>Word Lists</span>
      </nav>

      <h1>Scrabble Words Ending in OE — Uncommon Vowel Endings</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-22">June 22, 2026</time>
        <span>·</span>
        <span>4 min read</span>
        <span>·</span>
        <a href="/" class="text-blue-400 hover:underline">Open Word Finder →</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Words ending in OE might seem uncommon, but they are surprisingly versatile in Scrabble. From the musical OBOE to the botanical ALOE, these vowel-heavy endings help you clear awkward racks and create parallel plays in tight board positions.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><span class="block text-2xl font-bold text-amber-400">13</span><span class="text-xs text-gray-400">OE Words</span></div>
          <div><span class="block text-2xl font-bold text-amber-400">10</span><span class="text-xs text-gray-400">Top Score (JOE)</span></div>
          <div><span class="block text-2xl font-bold text-amber-400">3</span><span class="text-xs text-gray-400">Min Score (TOE/ROE)</span></div>
          <div><span class="block text-2xl font-bold text-amber-400">5.8</span><span class="text-xs text-gray-400">Avg Points</span></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top OE-Ending Words by Score</h2>

      <div class="not-prose my-6 overflow-x-auto">
        <table class="w-full border border-gray-700 rounded-lg overflow-hidden shadow-sm text-sm">
          <thead class="bg-gray-800"><tr><th class="px-4 py-2 text-left text-gray-300">Word</th><th class="px-4 py-2 text-left text-gray-300">Length</th><th class="px-4 py-2 text-left text-gray-300">Points</th><th class="px-4 py-2 text-left text-gray-300">Notes</th></tr></thead>
          <tbody>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">JOE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">10</td><td class="px-4 py-2 text-gray-400">J tile worth 8 alone</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">CANOE</td><td class="px-4 py-2">5</td><td class="px-4 py-2 text-blue-400">7</td><td class="px-4 py-2 text-gray-400">Common noun, great rack clearer</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">SHOE</td><td class="px-4 py-2">4</td><td class="px-4 py-2 text-blue-400">7</td><td class="px-4 py-2 text-gray-400">SH combo scores well</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">FLOE</td><td class="px-4 py-2">4</td><td class="px-4 py-2 text-blue-400">7</td><td class="px-4 py-2 text-gray-400">A sheet of floating ice</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">OBOE</td><td class="px-4 py-2">4</td><td class="px-4 py-2 text-blue-400">6</td><td class="px-4 py-2 text-gray-400">Musical instrument, double O</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">HOE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">6</td><td class="px-4 py-2 text-gray-400">Garden tool, H worth 4</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">FOE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">6</td><td class="px-4 py-2 text-gray-400">F tile worth 4</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">SLOE</td><td class="px-4 py-2">4</td><td class="px-4 py-2 text-blue-400">4</td><td class="px-4 py-2 text-gray-400">A thorny shrub berry</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">ALOE</td><td class="px-4 py-2">4</td><td class="px-4 py-2 text-blue-400">4</td><td class="px-4 py-2 text-gray-400">Succulent plant, vowel dump</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">DOE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">4</td><td class="px-4 py-2 text-gray-400">Female deer</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono">TOE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">3</td><td class="px-4 py-2 text-gray-400">Body part, very common</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono">ROE</td><td class="px-4 py-2">3</td><td class="px-4 py-2 text-blue-400">3</td><td class="px-4 py-2 text-gray-400">Fish eggs</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-blue-400 font-medium text-sm mb-2">💡 Insight</p>
        <p class="text-gray-300 text-sm">OE-ending words are rare in English, which means opponents often overlook them. FLOE and SLOE are particularly strong surprise plays — most casual players won't challenge them, and they fit neatly into four-tile spaces on the board.</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Quick-Play OE Words</h2>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">HOE <span class="text-blue-400">6</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">FOE <span class="text-blue-400">6</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">TOE <span class="text-blue-400">3</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">ROE <span class="text-blue-400">3</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">DOE <span class="text-blue-400">4</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">JOE <span class="text-blue-400">10</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">ALOE <span class="text-blue-400">4</span></span>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for OE Endings</h2>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-purple-300 font-medium text-sm mb-1">Vowel Management</p>
          <p class="text-gray-400 text-sm">Stuck with too many vowels? ALOE, OBOE, and CANOE all dump multiple vowels in one play while still scoring respectably.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-purple-300 font-medium text-sm mb-1">Parallel Play Power</p>
          <p class="text-gray-400 text-sm">Three-letter OE words like HOE, FOE, and TOE are ideal for parallel plays. Place them beside existing words to score in both directions simultaneously.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-purple-300 font-medium text-sm mb-1">Premium Square Targeting</p>
          <p class="text-gray-400 text-sm">JOE on a double-letter square under the J scores 18 points from just three tiles. Always look for premium squares when you hold high-value consonants with OE available.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-purple-300 font-medium text-sm mb-1">Defensive Awareness</p>
          <p class="text-gray-400 text-sm">FLOE and SLOE are lesser-known words your opponent might challenge. Be confident — both are valid in TWL and SOWPODS. A failed challenge costs your opponent their turn.</p>
        </div>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-indigo-500/30 bg-indigo-950/10">
        <p class="text-indigo-400 font-medium text-sm mb-2">Related Word Lists</p>
        <ul class="space-y-1 text-sm">
          <li><a href="/blog/words-ending-in-ai" class="text-gray-300 hover:text-blue-400">Words Ending in AI →</a></li>
          <li><a href="/blog/words-containing-oe" class="text-gray-300 hover:text-blue-400">Words Containing OE →</a></li>
          <li><a href="/blog/words-ending-in-aa" class="text-gray-300 hover:text-blue-400">Words Ending in AA →</a></li>
        </ul>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-medium text-gray-400 mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-ending-in-ai" class="block p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-colors"><span class="text-sm text-gray-200">Words Ending in AI — Exotic Vowel Endings</span></a>
          <a href="/blog/words-ending-in-ew" class="block p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-colors"><span class="text-sm text-gray-200">Words Ending in EW — High-Value W Endings</span></a>
          <a href="/blog/best-two-letter-words-scrabble" class="block p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-colors"><span class="text-sm text-gray-200">Best Two-Letter Words in Scrabble</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <p class="text-gray-200 font-medium mb-2">Find More OE Words Instantly</p>
        <p class="text-gray-400 text-sm mb-3">Type your rack into our free word finder and filter by ending to discover every valid OE word available.</p>
        <a href="/" class="inline-block px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm rounded-lg transition-colors">Open Word Finder →</a>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to Blog</a>
      </div>
    </article>
  </div>
</BlogLayout>
