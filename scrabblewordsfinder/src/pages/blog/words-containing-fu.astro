            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">FUNKY</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">Unconventional or stylish</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">USEFUL</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Serving a purpose</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">FUTURE</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Time yet to come</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">REFUSE</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">To decline</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">FUNERAL</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A burial ceremony</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">CAREFUL</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">Done with attention</td></tr>
