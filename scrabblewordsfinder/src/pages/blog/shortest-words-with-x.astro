---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Shortest Words With X"
  description="Best short X words. AX, EX, OX, XI, XU — maximum points from minimum tiles."
  keywords="scrabble, shortest, words, with, x"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Shortest Words With X",
    "description": "Best short X words. AX, EX, OX, XI, XU — maximum points from minimum tiles.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/shortest-words-with-x" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the shortest valid Scrabble words with X?",
        "acceptedAnswer": { "@type": "Answer", "text": "Two-letter X words: AX (9), EX (9), OX (9), XI (9), XU (9). Three-letter X words include: BOX (12), COX (12), FAX (13), FIX (13), FOX (13), HEX (13), MIX (12), PAX (12), PIX (12), POX (12), REX (10), SAX (10), SEX (10), SIX (10), TAX (10), TUX (10), VEX (13), VOX (13), WAX (13), and ZAX (19)." }
      },
      {
        "@type": "Question",
        "name": "What is XI in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "XI is the 14th letter of the Greek alphabet. It scores 9 points (X=8, I=1) and is one of the most useful 2-letter words for parallel plays. XI is valid in both TWL and SOWPODS dictionaries." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring short X word?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZAX (19 pts) is the highest-scoring 3-letter X word, combining Z (10) + A (1) + X (8). Among 2-letter words, all X words score 9 points. On a TLS, XI or XU can score 25+ points from just two tiles." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Shortest Words With X</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Best short X words. AX, EX, OX, XI, XU — maximum points from minimum tiles.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
