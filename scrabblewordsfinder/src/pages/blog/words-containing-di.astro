---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing DI — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing DI with scores, definitions, and strategic tips. Master DI words for better Scrabble plays."
  keywords="scrabble words containing di, di words scrabble, words with di, scrabble di word list, di scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing DI — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing DI with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-di" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring DI words?", "acceptedAnswer": { "@type": "Answer", "text": "Top DI words include DISQUALIFY (26 pts), DIZZYING (20 pts), DIGITIZE (19 pts), DIFFER (13 pts), and DIPLOMA (12 pts). DI words with Z, Q, or X deliver the highest scores." } },
      { "@type": "Question", "name": "How many Scrabble words contain DI?", "acceptedAnswer": { "@type": "Answer", "text": "Over 900 valid Scrabble words contain DI. The DI- prefix starts many common words: DIG, DID, DIM, DIP, DINE, DIRT, DISH, DIRECT, DIFFER, DINNER, DIVINE, DIVIDE, DISCOVER." } },
      { "@type": "Question", "name": "What strategy works with DI tiles?", "acceptedAnswer": { "@type": "Answer", "text": "DI gives you quick 3-letter plays (DIG, DID, DIM, DIP) for 5-7 points when clearing tiles. For higher scores, DIFFER (13 pts), DIPLOMA (12 pts), and DIVERGE (12 pts) use common consonants effectively." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing DI — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">DI forms over 900 valid Scrabble words, making it one of the most versatile D-pairs. From DIG, DID, and DIM to DIRECT, DIVINE, and DIPLOMA, DI works as both a starter and mid-word combination. The DI- prefix means apart or two in many words (DIVIDE, DIFFER, DIRECT, DISCOVER), expanding your vocabulary significantly.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top DI Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">DIZZYING</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">Causing dizziness</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">DIGITIZE</td><td class="px-4 py-3 text-blue-400">19</td><td class="px-4 py-3 text-gray-400">To convert to digital</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">DISQUALIFY</td><td class="px-4 py-3 text-blue-400">26</td><td class="px-4 py-3 text-gray-400">To make ineligible</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">DIPLOMA</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A certificate</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">DIVERGE</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To go separate ways</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">DIFFER</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">To be unlike</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">DIVINE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">Of or like God</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">DIRECT</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Straight or to guide</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">DINNER</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">An evening meal</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">DIGIT</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A finger or number</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">DIG</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">To excavate</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">900+</p><p class="text-xs text-gray-400">Valid DI words</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for DI Words</h2>

      <p>DI- starts many common words: DIG, DID, DIM, DIP, DINE, DIRT, DISH, DIRECT, DIFFER, DINNER, DIVINE. The pair also appears mid-word (EDIT, RADIO, AUDIO,UNDI). DIFFER (13 pts) and DIPLOMA (12 pts) use common tiles for strong scores.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DIZZYING</span><span class="text-blue-400 text-xs">20 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DIGITIZE</span><span class="text-blue-400 text-xs">19 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DISQUALIFY</span><span class="text-blue-400 text-xs">26 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DIPLOMA</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DIVERGE</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DIFFER</span><span class="text-blue-400 text-xs">13 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">DI provides <span class="text-white font-medium">900+ words with excellent versatility</span>. Short DI plays (DIG, DID, DIM, DIP) score 5-7 points for quick tile clearing. DIFFER (13 pts), DIPLOMA (12 pts), and DIVINE (10 pts) offer premium mid-range scores from common rack combinations.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every DI word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>