            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-amber-400">900-1200</td><td class="px-4 py-3 text-white font-medium">Intermediate</td><td class="px-4 py-3 text-gray-400">Regular competitors, learning strategy</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-amber-400">Under 900</td><td class="px-4 py-3 text-white font-medium">Beginner</td><td class="px-4 py-3 text-gray-400">New to competition, building fundamentals</td></tr>
          </tbody>
        </table>
