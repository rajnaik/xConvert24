---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing DO — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing DO with scores, definitions, and strategic tips. Master DO words for better Scrabble plays."
  keywords="scrabble words containing do, do words scrabble, words with do, scrabble do word list, do scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing DO — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing DO with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-do" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring DO words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Top DO words include PARADOX (17 pts), KINGDOM (15 pts), ABDOMEN (12 pts), OUTDOOR (8 pts), and SHADOW (13 pts). DO words paired with high-value letters like X, K, and Z score best." } },
      { "@type": "Question", "name": "How many Scrabble words contain DO?", "acceptedAnswer": { "@type": "Answer", "text": "Over 700 valid Scrabble words contain DO. Common examples include DO, DOG, DOT, DONE, DOOR, UNDO, SHADOW, WINDOW, KINGDOM, FREEDOM, and WISDOM." } },
      { "@type": "Question", "name": "What strategy works best with DO tiles?", "acceptedAnswer": { "@type": "Answer", "text": "DO is excellent for suffixes (-DOM as in KINGDOM, FREEDOM, WISDOM) and for short plays (DO, DOG, DOT, DOE). Use -DONE and -DOOR patterns for parallel plays extending existing words." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing DO — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">DO is one of the most flexible two-letter combos in Scrabble, appearing in over 700 valid words. From the simplest plays like DO and DOG to powerhouse words like KINGDOM, PARADOX, and WISDOM, this pair works as a starter, mid-word connector, and suffix builder (-DOM). Learning DO words gives you reliable options in nearly every game state.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top DO Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">PARADOX</td><td class="px-4 py-3 text-blue-400">17</td><td class="px-4 py-3 text-gray-400">A contradictory statement</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">KINGDOM</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A realm ruled by a king</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">SHADOW</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">A dark area cast by light</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">FREEDOM</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">State of being free</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">WINDOW</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">An opening in a wall</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">ABDOMEN</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">The belly area</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">WISDOM</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">Knowledge and judgement</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">DONATE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">To give as a gift</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">DOLLAR</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A unit of currency</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">DONE</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Finished or completed</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">DOG</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A domesticated canine</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">700+</p><p class="text-xs text-gray-400">Valid DO words</p></div>
          <div><p class="text-xl font-bold text-amber-400">10 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for DO Words</h2>

      <p>DO works brilliantly as a suffix builder. Words ending in -DOM (KINGDOM, FREEDOM, WISDOM, BOREDOM) score well and use common tiles. The pair also starts many everyday words: DOG, DOT, DONE, DOOR, DOLLAR, DONATE. Mid-word DO appears in SHADOW, WINDOW, UNDO, and INDOOR — useful for parallel plays.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PARADOX</span><span class="text-blue-400 text-xs">17 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">KINGDOM</span><span class="text-blue-400 text-xs">15 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SHADOW</span><span class="text-blue-400 text-xs">13 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">FREEDOM</span><span class="text-blue-400 text-xs">13 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WINDOW</span><span class="text-blue-400 text-xs">13 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WISDOM</span><span class="text-blue-400 text-xs">12 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">DO provides <span class="text-white font-medium">700+ words with exceptional suffix power</span>. The -DOM ending (KINGDOM, FREEDOM, WISDOM) scores 12-15 points from common tiles. Short plays like DOG, DOT, and DONE (5 pts each) clear tiles efficiently while keeping your rack flexible.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every DO word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
