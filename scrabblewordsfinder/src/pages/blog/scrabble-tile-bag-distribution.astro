---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Tile Bag Distribution"
  description="Complete breakdown of all 100 tiles in a Scrabble set. How many of each letter, blanks, and what it means for strategy."
  keywords="scrabble, scrabble, tile, bag, distribution"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Tile Bag Distribution",
    "description": "Complete breakdown of all 100 tiles in a Scrabble set. How many of each letter, blanks, and what it means for strategy.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-tile-bag-distribution" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many tiles are in a Scrabble bag?",
        "acceptedAnswer": { "@type": "Answer", "text": "A standard English Scrabble set contains 100 tiles: 98 letter tiles and 2 blank tiles. The distribution varies by letter — E has 12 tiles, A has 9, I has 9, O has 8, while Q, Z, X, J, and K have only 1 each." }
      },
      {
        "@type": "Question",
        "name": "What is the tile distribution in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most common tiles: E(12), A(9), I(9), O(8), N(6), R(6), T(6), L(4), S(4), U(4). Least common: Q(1), Z(1), X(1), J(1), K(1). There are also 2 blank tiles worth zero points that can represent any letter." }
      },
      {
        "@type": "Question",
        "name": "How many points is each Scrabble tile worth?",
        "acceptedAnswer": { "@type": "Answer", "text": "Blank=0, A/E/I/O/U/L/N/S/T/R=1, D/G=2, B/C/M/P=3, F/H/V/W/Y=4, K=5, J/X=8, Q/Z=10. The total point value of all tiles in the bag is 187 points." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/beginner-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Beginner Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Tile Bag Distribution</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Complete breakdown of all 100 tiles in a Scrabble set. How many of each letter, blanks, and what it means for strategy.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
