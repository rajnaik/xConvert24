            <tr class="bg-gray-900"><td class="px-4 py-3 text-blue-400 font-bold text-lg">S</td><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-gray-300 font-mono">SH, SI, SO, ST*</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">T</td><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-gray-300 font-mono">TA, TE*, TI, TO</td></tr>
