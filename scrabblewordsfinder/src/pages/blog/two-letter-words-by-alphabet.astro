            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">D</td><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-gray-300 font-mono">DA, DE, DI*, DO</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-blue-400 font-bold text-lg">E</td><td class="px-4 py-3 text-gray-300">11</td><td class="px-4 py-3 text-gray-300 font-mono">EA*, ED, EE, EF, EH, EL, EM, EN, ER, ES, ET</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">F</td><td class="px-4 py-3 text-gray-300">3</td><td class="px-4 py-3 text-gray-300 font-mono">FA, FE*, FY*</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-blue-400 font-bold text-lg">G</td><td class="px-4 py-3 text-gray-300">3</td><td class="px-4 py-3 text-gray-300 font-mono">GI, GO, GU*</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">H</td><td class="px-4 py-3 text-gray-300">5</td><td class="px-4 py-3 text-gray-300 font-mono">HA, HE, HI, HM, HO</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-blue-400 font-bold text-lg">I</td><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-gray-300 font-mono">IF, IN, IO*, IS, IT</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">J</td><td class="px-4 py-3 text-gray-300">2</td><td class="px-4 py-3 text-gray-300 font-mono">JA*, JO</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-blue-400 font-bold text-lg">K</td><td class="px-4 py-3 text-gray-300">3</td><td class="px-4 py-3 text-gray-300 font-mono">KA, KI, KO*</td></tr>
