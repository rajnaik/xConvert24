    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which letter starts the most two-letter Scrabble words?",
        "acceptedAnswer": { "@type": "Answer", "text": "The letters A and O start the most two-letter words, with 16 each in the SOWPODS dictionary. This makes sense because vowels combine easily with most consonants to form valid short words." }
      },
      {
        "@type": "Question",
        "name": "Are there two-letter words starting with every letter of the alphabet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Almost. In SOWPODS, every letter except V starts at least one valid two-letter word. Letters like Q (only QI), X (XI, XU), and Z (ZA, ZO) have very few options but they exist." }
      },
      {
        "@type": "Question",
        "name": "What two-letter words start with X?",
