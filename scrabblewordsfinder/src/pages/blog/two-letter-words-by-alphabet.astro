            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-blue-400 font-bold text-lg">B</td><td class="px-4 py-3 text-gray-300">5</td><td class="px-4 py-3 text-gray-300 font-mono">BA, BE, BI, BO, BY</td></tr>
