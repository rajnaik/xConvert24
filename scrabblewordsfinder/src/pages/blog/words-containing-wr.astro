      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WRECK</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">5</td><td class="px-4 py-3">K(5) + C(3) boosts</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WRYLY</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">5</td><td class="px-4 py-3">Double Y value</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WRAITH</td><td class="px-4 py-3 text-amber-600 font-bold">12</td><td class="px-4 py-3">6</td><td class="px-4 py-3">H(4) at end</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WRATH</td><td class="px-4 py-3 text-amber-600 font-bold">11</td><td class="px-4 py-3">5</td><td class="px-4 py-3">H(4) adds punch</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WRING</td><td class="px-4 py-3 text-amber-600 font-bold">9</td><td class="px-4 py-3">5</td><td class="px-4 py-3">G(2) + common</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WRONG</td><td class="px-4 py-3 text-amber-600 font-bold">9</td><td class="px-4 py-3">5</td><td class="px-4 py-3">Very common word</td></tr>
