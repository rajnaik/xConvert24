            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">14</td><td class="px-4 py-3 text-white font-medium">DIRGE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">D2+I1+R1+G2+E1</td><td class="px-4 py-3 text-gray-400">Vocal</td></tr>
