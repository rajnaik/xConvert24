            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">12</td><td class="px-4 py-3 text-white font-medium">FORTE</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">F4+O1+R1+T1+E1</td><td class="px-4 py-3 text-gray-400">Italian</td></tr>
