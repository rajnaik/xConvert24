            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">16</td><td class="px-4 py-3 text-white font-medium">RONDO</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">R1+O1+N1+D2+O1</td><td class="px-4 py-3 text-gray-400">Form</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">17</td><td class="px-4 py-3 text-white font-medium">OBOE</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">O1+B3+O1+E1</td><td class="px-4 py-3 text-gray-400">Instrument</td></tr>
