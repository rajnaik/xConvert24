<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is Y a vowel or consonant in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "In Scrabble, Y is officially classified as a consonant tile (it's in the consonant section of the bag), but it functions as a vowel in many words like GYM, HYMN, GLYPH, and CRY. This dual nature makes Y extremely versatile." }},
    { "@type": "Question", "name": "How many points is Y worth in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Y is worth 4 points in Scrabble with 2 tiles in the bag. Its value matches H, V, and W, but Y's vowel flexibility makes it arguably the most useful of the 4-point tiles." }},
    { "@type": "Question", "name": "What words use Y as a vowel in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "GYM (9 pts), HYMN (12 pts), GLYPH (14 pts), CRYPT (12 pts), LYNCH (13 pts), and PYGMY (15 pts) all use Y as their only vowel. These are essential for vowel-starved racks." }}
  ]
})} />

