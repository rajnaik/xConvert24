    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">ANTIQUELY</td><td class="px-4 py-3 text-amber-600 font-bold">21</td><td class="px-4 py-3">9</td><td class="px-4 py-3">Q(10) power tile</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">ANTIQUES</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">8</td><td class="px-4 py-3">Q(10) + bingo length</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">ANTICKING</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">9</td><td class="px-4 py-3">K(5)+C(3) combo</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">ANTIQUE</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Q(10) bingo stem</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">ANTIJACK</td><td class="px-4 py-3 text-amber-600 font-bold">21</td><td class="px-4 py-3">8</td><td class="px-4 py-3">J(8)+K(5) pair</td></tr>
