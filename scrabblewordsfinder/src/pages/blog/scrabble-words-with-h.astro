      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WHIZ</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">4</td><td class="px-4 py-3">Z(10)+W(4)+H(4)</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">HAZY</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">4</td><td class="px-4 py-3">Z(10)+Y(4)+H(4)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">HYPER</td><td class="px-4 py-3 text-amber-600 font-bold">13</td><td class="px-4 py-3">5</td><td class="px-4 py-3">H(4)+Y(4)+P(3)</td></tr>
