---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words With All Vowels (No Consonants)"
  description="Valid Scrabble words made entirely of vowels. Emergency plays when your rack is vowel-heavy."
  keywords="scrabble, words, with, all, vowels"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words With All Vowels (No Consonants)",
    "description": "Valid Scrabble words made entirely of vowels. Emergency plays when your rack is vowel-heavy.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-with-all-vowels" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What words in Scrabble use every vowel?",
        "acceptedAnswer": { "@type": "Answer", "text": "SEQUOIA (16 pts), EQUATION (17 pts), AUTHORIZE (21 pts), EDUCATION (12 pts), AUTOMOBILE (16 pts), and COMMUNICATE (19 pts) all contain A, E, I, O, and U. Shorter options include SEQUOIA (7) and DIALOGUE (8)." }
      },
      {
        "@type": "Question",
        "name": "How do I handle a vowel-heavy rack in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Use vowel-dumping words: AUDIO (6 pts), ADIEU (6 pts), AIOLI (5 pts), OORIE (5 pts), OURIE (5 pts), and URAEI (5 pts). These use 4-5 vowels in one play, letting you draw consonants. If desperate, exchange — but try vowel dumps first." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring all-vowel-containing word?",
        "acceptedAnswer": { "@type": "Answer", "text": "AUTHORIZE scores 21 points base (plus 50-point bingo bonus = 71+). EQUATION scores 17 + 50 = 67+. SEQUOIA scores 16 + 50 = 66+. On premium squares, these can exceed 100 points in a single turn." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/high-scoring/" class="hover:text-blue-400 transition-colors text-gray-300">High Scoring</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words With All Vowels (No Consonants)</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Valid Scrabble words made entirely of vowels. Emergency plays when your rack is vowel-heavy.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
