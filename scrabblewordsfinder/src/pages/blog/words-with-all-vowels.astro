            <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">AI</td><td class="px-4 py-3 text-amber-600 font-bold">2</td><td class="px-4 py-3">Both</td><td class="px-4 py-3">A three-toed sloth</td></tr>
            <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono">OE</td><td class="px-4 py-3 text-amber-600 font-bold">2</td><td class="px-4 py-3">Both</td><td class="px-4 py-3">A whirlwind off the Faeroes</td></tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">EAU</td><td class="px-4 py-3 text-amber-600 font-bold">3</td><td class="px-4 py-3">Both</td><td class="px-4 py-3">A watery solution (perfumery)</td></tr>
            <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono">OO</td><td class="px-4 py-3 text-amber-600 font-bold">2</td><td class="px-4 py-3">SOWPODS</td><td class="px-4 py-3">Scottish word for wool</td></tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">EUOUAE</td><td class="px-4 py-3 text-amber-600 font-bold">6</td><td class="px-4 py-3">SOWPODS</td><td class="px-4 py-3">A medieval musical cadence</td></tr>
