            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">OX</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Hooks easily onto O words</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">JO</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Only 2-letter J word in TWL</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">KA</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">Plays K with common A</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">KI</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">Alternative K play</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">WO</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Plays W with common O</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">YA</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Plays Y with common A</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">FE</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Musical note, plays F easily</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">HM</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">No vowel needed</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">SH</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">No vowel needed</td></tr>
