    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/shortest-legal-words" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many valid 2-letter words are there in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "In the TWL (Tournament Word List) dictionary used in North American Scrabble, there are 107 valid two-letter words. SOWPODS (international dictionary) has even more, with 127 valid two-letter words." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring 2-letter word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI scores 11 points (Q=10, I=1) making it the highest-scoring two-letter word without premium squares. ZA scores 11 points as well (Z=10, A=1). Both are essential for tight board positions." }
      },
      {
        "@type": "Question",
        "name": "Why are 2-letter words important in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Two-letter words enable parallel plays where you place a word alongside an existing word, scoring points for every new two-letter combination formed. A single parallel play can score 30-50+ points by creating multiple words simultaneously." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
