            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">HE</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Common pronoun, parallel play</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">IF</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Common word, easy to spot</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-medium">BI</td><td class="px-4 py-3 text-blue-400">4</td><td class="px-4 py-3 text-gray-400">Plays B with common I</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-medium">DO</td><td class="px-4 py-3 text-blue-400">3</td><td class="px-4 py-3 text-gray-400">Musical note, very flexible</td></tr>
          </tbody>
        </table>
