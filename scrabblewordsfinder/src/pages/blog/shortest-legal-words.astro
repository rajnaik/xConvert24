  keywords="shortest scrabble words, 2 letter scrabble words, two letter words list, valid short words scrabble, parallel plays scrabble, qi scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Shortest Legal Scrabble Words — All Valid 2-Letter Words",
    "description": "Complete list of valid 2-letter Scrabble words with point values and parallel play strategy.",
