---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Carpentry — Woodworking Terms That Build Points"
  description="Carpentry and woodworking words valid in Scrabble with full scoring. PLYWOOD (15pts), CHISEL (11pts), DOWEL (9pts). Workshop vocabulary for competitive players."
  keywords="scrabble carpentry words, plywood scrabble points, chisel scrabble, dowel scrabble word, woodworking terms scrabble, workshop words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Carpentry — Woodworking Terms That Build Points","description":"Carpentry and woodworking words valid in Scrabble with full scoring. PLYWOOD (15pts), CHISEL (11pts), DOWEL (9pts).","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-carpentry"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many points is PLYWOOD worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"PLYWOOD scores 15 points (P=3, L=1, Y=4, W=4, O=1, O=1, D=2) as a 7-letter word. The Y=4 and W=4 tiles provide the scoring backbone."}},{"@type":"Question","name":"Is CHISEL a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! CHISEL scores 11 points (C=3, H=4, I=1, S=1, E=1, L=1). The C+H combination delivers 7 points from the first two letters alone."}},{"@type":"Question","name":"Can you play DOWEL in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes! DOWEL scores 9 points (D=2, O=1, W=4, E=1, L=1). It's a cylindrical wooden pin used in joinery, valid in both TWL and SOWPODS dictionaries."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Carpentry — Woodworking Terms That Build Points</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">The workshop is full of words that work hard on the Scrabble board. Carpentry terms feature W, Y, and CH combinations that score well above average. Whether you're planing a board or drilling a dowel hole, woodworking vocabulary gives you reliable mid-range plays.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">15 pts</p><p class="text-xs text-gray-400">PLYWOOD (Top)</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">CHISEL</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">DOWEL</p></div>
          <div><p class="text-xl font-bold text-amber-400">14 pts</p><p class="text-xs text-gray-400">JIGSAW</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top-Scoring Workshop Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">PLYWOOD — 15 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">P=3, L=1, Y=4, W=4, O=1, O=1, D=2 · 7 letters · Uses W+Y combo</p>
        <p class="text-sm text-gray-300 leading-relaxed">Layered wood sheets used in construction. PLYWOOD scores 15 points from 7 letters, and as a full-rack play qualifies for the 50-point bingo bonus — 65 total. The Y=4 and W=4 combination is the engine here.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🪚 JIGSAW</p><p class="text-xs text-gray-400">14 pts · J=8, I=1, G=2, S=1, A=1, W=4 · Cutting tool</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🔨 CHISEL</p><p class="text-xs text-gray-400">11 pts · C=3, H=4, I=1, S=1, E=1, L=1 · Carving tool</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🪵 DOWEL</p><p class="text-xs text-gray-400">9 pts · D=2, O=1, W=4, E=1, L=1 · Wooden pin</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">📐 MITRE</p><p class="text-xs text-gray-400">7 pts · M=3, I=1, T=1, R=1, E=1 · Angled joint</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Carpentry Vocabulary</h2>
      <p>The toolbox has plenty more valid Scrabble words:</p>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">LATHE</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">TENON</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">CLAMP</span><span class="text-green-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PLANE</span><span class="text-green-400 text-xs">7pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">HINGE</span><span class="text-green-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">WEDGE</span><span class="text-green-400 text-xs">10pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Carpentry Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">PLYWOOD is a bingo candidate:</span> At 7 letters with common tiles (P, L, Y, W, O, O, D), PLYWOOD can score 65 points with the bingo bonus. Watch for two O tiles on your rack as the trigger.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">CHISEL extends easily:</span> CHISEL (11pts) hooks into CHISELS (12pts) or CHISELED (14pts). The CH opening also connects well with existing board words.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">JIGSAW deploys the J tile:</span> At 14 points, JIGSAW (J=8, W=4) is one of the best ways to use a J tile. The remaining letters (I, G, S, A) are all common draws.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Carpentry words excel with <span class="text-white font-medium">W (4pts), CH (7pts combined), and J (8pts)</span>. Unlike many word lists, woodworking terms use these awkward consonants productively — PLYWOOD, CHISEL, JIGSAW, and DOWEL all turn hard-to-place tiles into solid scores.</p>
      </div>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid woodworking word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
      <!-- Related Articles -->
      <aside class="border-t border-gray-700 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-chess/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Chess</span></a>
          <a href="/blog/scrabble-words-from-sailing/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Sailing</span></a>
          <a href="/blog/scrabble-words-from-aviation/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Aviation</span></a>
          <a href="/blog/scrabble-words-from-photography/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Photography</span></a>
          <a href="/blog/scrabble-words-from-mythology-greek/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Greek Mythology</span></a>
        </div>
      </aside>

    </article>
  </div>
</BlogLayout>
