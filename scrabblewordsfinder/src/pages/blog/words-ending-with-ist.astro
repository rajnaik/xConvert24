    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">PHYSICIST</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">9</td><td class="px-4 py-3">PH(7)+Y(4)+C(3)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">EXORCIST</td><td class="px-4 py-3 text-amber-600 font-bold">17</td><td class="px-4 py-3">8</td><td class="px-4 py-3">X(8)+C(3) + bingo</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">PUBLICIST</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">9</td><td class="px-4 py-3">P(3)+B(3)+C(3)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">CYCLIST</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Y(4)+C(3)+C(3) + bingo</td></tr>
