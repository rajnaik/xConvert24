      {
        "@type": "Question",
        "name": "How do you come back from a big deficit in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Focus on bingo hunting (50-point bonus plays), open the board to create high-scoring lanes, target premium squares aggressively, and consider exchanging tiles to build a better rack. A single bingo with a TWS can swing 80+ points in one turn." }
      },
      {
        "@type": "Question",
        "name": "When should you exchange tiles instead of playing a word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Exchange when your rack has no plays scoring above 15 points AND you have a bad letter mix (too many vowels, duplicate consonants, or dead tiles like V+W+C together). If behind by 50+ points, exchanging 4-5 tiles for a fresh draw gives better comeback odds than a weak 12-point play." }
      },
