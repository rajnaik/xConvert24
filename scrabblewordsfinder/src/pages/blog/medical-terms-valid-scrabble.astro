---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Medical Terms Valid in Scrabble"
  description="Medical and scientific words legal in Scrabble. High-scoring technical vocabulary for competitive play."
  keywords="scrabble, medical, terms, valid, scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Medical Terms Valid in Scrabble",
    "description": "Medical and scientific words legal in Scrabble. High-scoring technical vocabulary for competitive play.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/medical-terms-valid-scrabble" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are medical terms valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Many medical terms are valid if they appear in the official dictionary. Words like ZYGOMA (20 pts), QUINSY (18 pts), PHLEGM (14 pts), and SCALPEL (11 pts) are all playable. However, highly technical abbreviations and proprietary drug names are not valid." }
      },
      {
        "@type": "Question",
        "name": "What high-scoring medical words work in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZYMOTIC (23 pts), PHARYNX (22 pts), OXYGEN (17 pts), QUINSY (18 pts), and SYZYGY (24 pts) are high-scoring medical/scientific terms. Many use uncommon letter combinations that reach premium squares effectively." }
      },
      {
        "@type": "Question",
        "name": "Are drug names valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Brand-name drugs (ASPIRIN was once trademarked) are generally not valid as they are proper nouns. Generic chemical names may be valid if they appear in the dictionary. Common terms like CODEINE, ASPIRIN, and IBUPROFEN have mixed validity depending on the dictionary edition." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Medical Terms Valid in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Medical and scientific words legal in Scrabble. High-scoring technical vocabulary for competitive play.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
