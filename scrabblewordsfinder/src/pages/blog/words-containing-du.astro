---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing DU — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing DU with scores, definitions, and strategic tips. Master DU words for better Scrabble plays."
  keywords="scrabble words containing du, du words scrabble, words with du, scrabble du word list, du scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing DU — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing DU with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-du" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring DU words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Top DU words include PREJUDGE (18 pts), DUSKY (13 pts), PRODUCT (12 pts), EDUCATE (10 pts), and CONDUCT (12 pts). DU combined with high-value consonants produces strong scores." } },
      { "@type": "Question", "name": "How many Scrabble words contain DU?", "acceptedAnswer": { "@type": "Answer", "text": "Over 500 valid Scrabble words contain DU. Common examples include DUE, DUG, DUB, DULL, DUSK, DUST, ADULT, EDUCATE, REDUCE, PRODUCE, and CONDUCT." } },
      { "@type": "Question", "name": "What strategy works best with DU tiles?", "acceptedAnswer": { "@type": "Answer", "text": "DU appears in many -DUCE and -DUCT words (REDUCE, PRODUCE, CONDUCT). Short plays like DUE (4 pts), DUG (5 pts), and DUB (6 pts) are useful for clearing consonants. The pair also forms ADULT, ENDURE, and INDULGE." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing DU — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">DU appears in over 500 valid Scrabble words, covering everything from short plays like DUE and DUG to powerful mid-game words like PRODUCE, EDUCATE, and CONDUCT. The DU pair often appears in Latin-rooted words with -DUCE and -DUCT patterns, giving you access to high-scoring plays using common rack tiles.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top DU Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">PREJUDGE</td><td class="px-4 py-3 text-blue-400">18</td><td class="px-4 py-3 text-gray-400">To judge beforehand</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">DUSKY</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">Somewhat dark</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">PRODUCT</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">Something produced</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">CONDUCT</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To lead or direct</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">PRODUCE</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To make or create</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">EDUCATE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">To teach or instruct</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">INDULGE</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">To gratify a desire</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">ENDURE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">To bear with patience</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">ADULT</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">A fully grown person</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">DUB</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">To name or call</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">DUST</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">Fine dry particles</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">500+</p><p class="text-xs text-gray-400">Valid DU words</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for DU Words</h2>

      <p>DU excels in Latin-rooted words. The -DUCE pattern (PRODUCE, REDUCE, INDUCE) and -DUCT pattern (CONDUCT, PRODUCT) give you reliable mid-game options. Short DU starters — DUE (4), DUG (5), DUB (6), DUSK (9) — help clear tough consonants while maintaining board presence.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PREJUDGE</span><span class="text-blue-400 text-xs">18 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DUSKY</span><span class="text-blue-400 text-xs">13 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PRODUCT</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CONDUCT</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PRODUCE</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">EDUCATE</span><span class="text-blue-400 text-xs">10 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">DU provides <span class="text-white font-medium">500+ words with strong Latin-root patterns</span>. PRODUCE, CONDUCT, and PRODUCT (12 pts each) use common tiles effectively. Short plays like DUB (6 pts) and DUST (5 pts) keep your rack balanced while maintaining scoring opportunities.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every DU word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
