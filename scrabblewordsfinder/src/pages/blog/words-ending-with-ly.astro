    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">QUICKLY</td><td class="px-4 py-3 text-amber-600 font-bold">25</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Q(10)+K(5)+Y(4)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">JOKINGLY</td><td class="px-4 py-3 text-amber-600 font-bold">23</td><td class="px-4 py-3">8</td><td class="px-4 py-3">J(8)+K(5)+Y(4)</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">QUAINTLY</td><td class="px-4 py-3 text-amber-600 font-bold">20</td><td class="px-4 py-3">8</td><td class="px-4 py-3">Q(10)+Y(4) bingo</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">FOXILY</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">6</td><td class="px-4 py-3">F(4)+X(8) combo</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WAXILY</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">6</td><td class="px-4 py-3">W(4)+X(8) combo</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">BLACKLY</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">7</td><td class="px-4 py-3">B(3)+K(5)+C(3)</td></tr>
