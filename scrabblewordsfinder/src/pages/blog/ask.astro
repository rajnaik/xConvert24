---
export const prerender = false;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Ask AI — Scrabble Expert Assistant"
  description="Ask our AI-powered Scrabble assistant any question about strategy, rules, word lists, bingos, and tips. Instant answers from our blog content."
  keywords="scrabble ai, ask scrabble question, scrabble help, scrabble strategy ai, word game assistant"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Scrabble AI Assistant",
    "description": "AI-powered Scrabble expert that answers questions about strategy, rules, and word lists.",
    "url": "https://www.scrabblewordsfinder.com/blog/ask/",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Ask AI</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Ask AI — Scrabble Expert Assistant</h1>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        Our AI assistant has read 650+ blog posts about Scrabble strategy, rules, word lists, and game tips. Ask any question and get an instant, expert answer with links to our source articles.
      </p>

      <!-- Tailwind safelist: classes used in JS-generated HTML (formatAnswer + getCategoryColor) -->
      <div class="hidden">
        <!-- Inline formatting -->
        <span class="text-white font-semibold"></span>
        <code class="px-1.5 py-0.5 rounded bg-gray-700 text-purple-300 text-xs font-mono"></code>
        <p class="text-sm text-gray-300 leading-relaxed mt-2"></p>
        <!-- FVT numbered steps block -->
        <div class="my-3 p-4 rounded-xl border border-purple-500/30 bg-purple-950/10"></div>
        <p class="text-xs font-semibold text-purple-400 uppercase tracking-wider mb-3"></p>
        <div class="space-y-2.5"></div>
        <div class="flex items-start gap-3"></div>
        <span class="shrink-0 w-5 h-5 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-[10px] text-purple-300 font-bold"></span>
        <!-- FVT bullet tiles -->
        <div class="my-3 space-y-2"></div>
        <div class="flex items-start gap-2.5 p-2.5 rounded-lg border border-purple-500/20 bg-purple-950/10"></div>
        <span class="text-purple-400 mt-0.5 shrink-0 text-xs">▶</span>
        <!-- Source card colors -->
        <span class="border-purple-500/40 bg-purple-900/20 text-purple-300 bg-purple-900/50"></span>
        <span class="border-blue-500/40 bg-blue-900/20 text-blue-300 bg-blue-900/50"></span>
        <span class="border-amber-500/40 bg-amber-900/20 text-amber-300 bg-amber-900/50"></span>
        <span class="border-cyan-500/40 bg-cyan-900/20 text-cyan-300 bg-cyan-900/50"></span>
        <span class="border-green-500/40 bg-green-900/20 text-green-300 bg-green-900/50"></span>
        <span class="border-red-500/40 bg-red-900/20 text-red-300 bg-red-900/50"></span>
        <span class="border-indigo-500/40 bg-indigo-900/20 text-indigo-300 bg-indigo-900/50"></span>
        <span class="border-gray-600 bg-gray-800/40 bg-gray-800"></span>
        <span class="text-[9px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded"></span>
        <span class="ml-auto shrink-0 text-[10px] font-mono text-gray-500 bg-gray-800 px-1.5 py-0.5 rounded"></span>
        <a class="flex items-center gap-3 p-2.5 rounded-xl border hover:scale-[1.02] transition-all duration-200 group"></a>
        <span class="group-hover:translate-x-0.5 transition-transform duration-200 shrink-0 text-sm"></span>
        <div class="min-w-0 flex-1"><p class="text-xs text-gray-200 font-medium truncate group-hover:text-white transition-colors"></p></div>
        <div class="flex items-center gap-2 mt-0.5"></div>
        <div class="space-y-2"></div>
        <p class="text-[10px] text-gray-500 mb-2.5 uppercase tracking-widest font-bold flex items-center gap-1.5"></p>
      </div>

      <!-- Full-page chat interface -->
      <div id="ask-ai-full" class="not-prose">
        <div class="rounded-2xl border border-gray-700/60 bg-gradient-to-b from-gray-900/80 to-gray-950/90 overflow-hidden shadow-xl shadow-black/30">
          <!-- Messages -->
          <div id="ask-messages" class="p-6 space-y-4 min-h-[400px] max-h-[500px] overflow-y-auto">
            <!-- Welcome -->
            <div class="flex gap-3">
              <div class="shrink-0 w-9 h-9 rounded-full bg-gradient-to-br from-purple-600 to-blue-600 border border-purple-400/50 flex items-center justify-center shadow-lg shadow-purple-900/30">
                <span class="text-base">🧠</span>
              </div>
              <div class="rounded-2xl rounded-tl-sm px-5 py-4 max-w-[85%] border border-gray-700/60 bg-gradient-to-br from-gray-800/90 to-gray-900/90 shadow-lg shadow-black/20">
                <p class="text-sm text-gray-200 font-medium mb-2">Hi! I'm your Scrabble AI expert.</p>
                <p class="text-xs text-gray-400 mb-3">I've read our entire blog library (650+ articles) — ask me anything about:</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  <div class="flex items-center gap-2 p-2 rounded-lg border border-purple-500/20 bg-purple-950/20">
                    <span class="text-purple-400 text-xs">🎯</span>
                    <span class="text-xs text-gray-300">Strategy & tactics</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg border border-blue-500/20 bg-blue-950/20">
                    <span class="text-blue-400 text-xs">📝</span>
                    <span class="text-xs text-gray-300">Word lists & bingos</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg border border-green-500/20 bg-green-950/20">
                    <span class="text-green-400 text-xs">📖</span>
                    <span class="text-xs text-gray-300">Rules & scoring</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg border border-amber-500/20 bg-amber-950/20">
                    <span class="text-amber-400 text-xs">🏆</span>
                    <span class="text-xs text-gray-300">History & tournaments</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Input -->
          <div class="px-5 py-4 border-t border-gray-800/80 bg-gray-900/95 backdrop-blur-sm">
            <form id="ask-form" class="flex gap-3">
              <input
                id="ask-input"
                type="text"
                placeholder="Ask about Scrabble strategy, rules, words..."
                maxlength="500"
                autofocus
                class="flex-1 px-4 py-3 rounded-xl bg-gray-800/80 border border-gray-700/60 text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-purple-500/60 focus:ring-2 focus:ring-purple-500/20 transition-all"
              />
              <button
                type="submit"
                id="ask-send"
                class="px-5 py-3 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white text-sm font-semibold transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2 shadow-md shadow-purple-900/30 hover:shadow-lg hover:shadow-purple-900/40"
              >
                <span>Ask</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
              </button>
            </form>
            <div class="flex items-center justify-between mt-2.5">
              <p class="text-[10px] text-gray-500 flex items-center gap-1.5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>Powered by Workers AI • 650+ blog articles indexed</p>
              <p id="ask-counter" class="text-[10px] text-gray-500 font-mono"></p>
            </div>
          </div>
        </div>

        <!-- Suggested questions -->
        <div class="mt-6">
          <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-3 flex items-center gap-2"><span class="text-purple-400">💬</span> Try asking:</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="ask-suggestions">
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">What are the best two-letter words?</button>
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">How do I manage a vowel-heavy rack?</button>
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">What is a bingo in Scrabble?</button>
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">Best opening moves?</button>
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">Q words without U?</button>
            <button class="ask-suggest px-4 py-2.5 rounded-xl bg-gray-800/60 border border-gray-700/50 text-xs text-gray-300 hover:border-purple-500/50 hover:bg-purple-950/20 hover:text-purple-300 transition-all text-left">Who invented Scrabble?</button>
          </div>
        </div>
      </div>

    </article>
  </div>
</BlogLayout>

<script is:inline>
(function() {
  const form = document.getElementById('ask-form');
  const input = document.getElementById('ask-input');
  const sendBtn = document.getElementById('ask-send');
  const messagesEl = document.getElementById('ask-messages');
  const counterEl = document.getElementById('ask-counter');
  const suggestions = document.querySelectorAll('.ask-suggest');

  let isLoading = false;
  let queryCount = 0;

  // Suggestion buttons
  suggestions.forEach(function(btn) {
    btn.addEventListener('click', function() {
      input.value = btn.textContent;
      form.dispatchEvent(new Event('submit'));
    });
  });

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    const question = input.value.trim();
    if (!question || isLoading) return;

    addMessage(question, 'user');
    input.value = '';
    isLoading = true;
    sendBtn.disabled = true;

    const typingId = addTypingIndicator();

    try {
      const res = await fetch('/api/rag-query/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: question })
      });

      removeTypingIndicator(typingId);

      if (res.ok) {
        const data = await res.json();
        addMessage(data.answer, 'ai', data.sources);
        queryCount++;
        counterEl.textContent = queryCount + '/20 questions this hour';
      } else if (res.status === 429) {
        addMessage("You've reached the question limit (20/hour). Please try again later.", 'ai');
      } else {
        addMessage("Sorry, something went wrong. Please try again.", 'ai');
      }
    } catch (err) {
      removeTypingIndicator(typingId);
      addMessage("Network error. Please check your connection.", 'ai');
    }

    isLoading = false;
    sendBtn.disabled = false;
    input.focus();
  });

  function formatAnswer(text) {
    // FVT-style rich rendering of AI responses
    var escaped = escapeHtml(text);

    // Split into paragraphs on double newlines
    var blocks = escaped.split(/\n\n+/);
    var htmlParts = [];

    blocks.forEach(function(block) {
      block = block.trim();
      if (!block) return;

      // Detect numbered list block (lines starting with 1. 2. 3. etc.)
      var numberedLines = block.split('\n').filter(function(l) { return /^\d+[\.\)]\s/.test(l.trim()); });
      if (numberedLines.length >= 2) {
        var stepsHtml = '<div class="my-3 p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">';
        stepsHtml += '<p class="text-xs font-semibold text-purple-400 uppercase tracking-wider mb-3">🧩 Steps</p>';
        stepsHtml += '<div class="space-y-2.5">';
        numberedLines.forEach(function(line, idx) {
          var content = line.replace(/^\d+[\.\)]\s*/, '');
          content = applyInlineFormatting(content);
          stepsHtml += '<div class="flex items-start gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-[10px] text-purple-300 font-bold">' + (idx + 1) + '</span><p class="text-sm text-gray-300 leading-relaxed">' + content + '</p></div>';
        });
        stepsHtml += '</div></div>';
        htmlParts.push(stepsHtml);
        return;
      }

      // Detect bullet list block (lines starting with - or •)
      var bulletLines = block.split('\n').filter(function(l) { return /^[\-•]\s/.test(l.trim()); });
      if (bulletLines.length >= 2) {
        var listHtml = '<div class="my-3 space-y-2">';
        bulletLines.forEach(function(line) {
          var content = line.replace(/^[\-•]\s*/, '');
          content = applyInlineFormatting(content);
          listHtml += '<div class="flex items-start gap-2.5 p-2.5 rounded-lg border border-purple-500/20 bg-purple-950/10"><span class="text-purple-400 mt-0.5 shrink-0 text-xs">▶</span><p class="text-sm text-gray-300 leading-relaxed">' + content + '</p></div>';
        });
        listHtml += '</div>';
        htmlParts.push(listHtml);
        return;
      }

      // Regular paragraph — apply inline formatting
      var paraHtml = applyInlineFormatting(block.replace(/\n/g, ' '));
      htmlParts.push('<p class="text-sm text-gray-300 leading-relaxed mt-2">' + paraHtml + '</p>');
    });

    return htmlParts.join('');
  }

  function applyInlineFormatting(text) {
    // Bold: **text** or __text__
    text = text.replace(/\*\*(.+?)\*\*/g, '<span class="text-white font-semibold">$1</span>');
    text = text.replace(/__(.+?)__/g, '<span class="text-white font-semibold">$1</span>');
    // Inline code: `text`
    text = text.replace(/`(.+?)`/g, '<code class="px-1.5 py-0.5 rounded bg-gray-700 text-purple-300 text-xs font-mono">$1</code>');
    return text;
  }

  function getCategoryColor(category) {
    var colors = {
      'Strategy': { border: 'border-purple-500/40', bg: 'bg-purple-900/20', text: 'text-purple-300', badge: 'bg-purple-900/50 text-purple-300' },
      'Two-Letter Words': { border: 'border-blue-500/40', bg: 'bg-blue-900/20', text: 'text-blue-300', badge: 'bg-blue-900/50 text-blue-300' },
      'Three-Letter Words': { border: 'border-blue-500/40', bg: 'bg-blue-900/20', text: 'text-blue-300', badge: 'bg-blue-900/50 text-blue-300' },
      'Bingos': { border: 'border-amber-500/40', bg: 'bg-amber-900/20', text: 'text-amber-300', badge: 'bg-amber-900/50 text-amber-300' },
      'Letter Guides': { border: 'border-cyan-500/40', bg: 'bg-cyan-900/20', text: 'text-cyan-300', badge: 'bg-cyan-900/50 text-cyan-300' },
      'Beginner Guides': { border: 'border-green-500/40', bg: 'bg-green-900/20', text: 'text-green-300', badge: 'bg-green-900/50 text-green-300' },
      'Tournament': { border: 'border-red-500/40', bg: 'bg-red-900/20', text: 'text-red-300', badge: 'bg-red-900/50 text-red-300' },
      'High-Scoring Words': { border: 'border-amber-500/40', bg: 'bg-amber-900/20', text: 'text-amber-300', badge: 'bg-amber-900/50 text-amber-300' },
      'History & Culture': { border: 'border-indigo-500/40', bg: 'bg-indigo-900/20', text: 'text-indigo-300', badge: 'bg-indigo-900/50 text-indigo-300' },
    };
    return colors[category] || { border: 'border-gray-600', bg: 'bg-gray-800/40', text: 'text-gray-300', badge: 'bg-gray-800 text-gray-300' };
  }

  function addMessage(text, role, sources) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-3' + (role === 'user' ? ' justify-end' : '');

    if (role === 'ai') {
      const avatar = document.createElement('div');
      avatar.className = 'shrink-0 w-9 h-9 rounded-full bg-gradient-to-br from-purple-600 to-blue-600 border border-purple-400/50 flex items-center justify-center shadow-lg shadow-purple-900/30';
      avatar.innerHTML = '<span class="text-base">🧠</span>';
      wrapper.appendChild(avatar);
    }

    const bubble = document.createElement('div');
    if (role === 'user') {
      bubble.className = 'bg-gradient-to-br from-blue-600 to-blue-700 rounded-2xl rounded-tr-sm px-4 py-3 max-w-[80%] shadow-md shadow-blue-900/20';
      bubble.innerHTML = '<p class="text-sm text-white leading-relaxed">' + escapeHtml(text) + '</p>';
    } else {
      bubble.className = 'rounded-2xl rounded-tl-sm px-5 py-4 max-w-[85%] border border-gray-700/60 bg-gradient-to-br from-gray-800/90 to-gray-900/90 shadow-lg shadow-black/20';
      bubble.innerHTML = '<p class="text-sm text-gray-300 leading-relaxed">' + formatAnswer(text) + '</p>';

      if (sources && sources.length > 0) {
        const srcDiv = document.createElement('div');
        srcDiv.className = 'mt-4 pt-3 border-t border-gray-700/50';
        srcDiv.innerHTML = '<p class="text-[10px] text-gray-500 mb-2.5 uppercase tracking-widest font-bold flex items-center gap-1.5"><span>📚</span> Sources</p><div class="space-y-2"></div>';
        const linksContainer = srcDiv.querySelector('div');
        sources.forEach(function(s) {
          const colors = getCategoryColor(s.category);
          const card = document.createElement('a');
          card.href = '/blog/' + s.slug + '/';
          card.className = 'flex items-center gap-3 p-2.5 rounded-xl border ' + colors.border + ' ' + colors.bg + ' hover:scale-[1.02] transition-all duration-200 group';
          
          var scoreHtml = '';
          if (s.score) {
            var pct = Math.round(s.score * 100);
            scoreHtml = '<span class="ml-auto shrink-0 text-[10px] font-mono text-gray-500 bg-gray-800 px-1.5 py-0.5 rounded">' + pct + '%</span>';
          }
          
          var categoryBadge = s.category ? '<span class="text-[9px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded ' + colors.badge + '">' + escapeHtml(s.category) + '</span>' : '';
          
          card.innerHTML = '<span class="' + colors.text + ' group-hover:translate-x-0.5 transition-transform duration-200 shrink-0 text-sm">→</span><div class="min-w-0 flex-1"><p class="text-xs text-gray-200 font-medium truncate group-hover:text-white transition-colors">' + escapeHtml(s.title || s.slug.replace(/-/g, ' ')) + '</p><div class="flex items-center gap-2 mt-0.5">' + categoryBadge + '</div></div>' + scoreHtml;
          linksContainer.appendChild(card);
        });
        bubble.appendChild(srcDiv);
      }
    }

    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addTypingIndicator() {
    const id = 'typing-' + Date.now();
    const wrapper = document.createElement('div');
    wrapper.id = id;
    wrapper.className = 'flex gap-3';
    wrapper.innerHTML = '<div class="shrink-0 w-9 h-9 rounded-full bg-gradient-to-br from-purple-600 to-blue-600 border border-purple-400/50 flex items-center justify-center shadow-lg shadow-purple-900/30"><span class="text-base">🧠</span></div><div class="rounded-2xl rounded-tl-sm px-5 py-4 border border-gray-700/60 bg-gradient-to-br from-gray-800/90 to-gray-900/90"><div class="flex gap-2 items-center h-5"><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:0ms"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:150ms"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:300ms"></span></div></div>';
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return id;
  }

  function removeTypingIndicator(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>
