          <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono">EMOJI</td><td class="px-4 py-3">14</td><td class="px-4 py-3">A digital pictogram</td><td class="px-4 py-3">Both</td></tr>
