        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">SIREN</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">CHAOS</span><span class="text-green-400 text-xs">10pts</span></span>
