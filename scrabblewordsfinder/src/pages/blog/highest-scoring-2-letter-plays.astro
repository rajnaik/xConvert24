---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Highest Scoring 2-Letter Plays"
  description="Two-letter words that score big on premium squares. QI, ZA, XI and their scoring potential."
  keywords="scrabble, highest, scoring, 2, letter, plays"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Highest Scoring 2-Letter Plays",
    "description": "Two-letter words that score big on premium squares. QI, ZA, XI and their scoring potential.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/highest-scoring-2-letter-plays" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the highest-scoring 2-letter word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI scores 11 points without any premium squares, making it the highest-scoring 2-letter word. On a Double Letter Score, QI scores 21 points. ZA (11 pts) ties with QI as the joint highest base-score 2-letter word." }
      },
      {
        "@type": "Question",
        "name": "How many 2-letter words are valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "There are 107 valid 2-letter words in SOWPODS (international) and 101 in TWL (North American). These include common words like IT and AT, plus useful oddities like QI, ZA, XI, XU, and JO." }
      },
      {
        "@type": "Question",
        "name": "What 2-letter words use high-value tiles?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI (Q=10), ZA (Z=10), XI (X=8), XU (X=8), JO (J=8), and KA (K=5) all use premium tiles. Playing these on Double/Triple Letter Scores can yield 20-30+ points from just two tiles." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/high-scoring/" class="hover:text-blue-400 transition-colors text-gray-300">High Scoring</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Highest Scoring 2-Letter Plays</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Two-letter words that score big on premium squares. QI, ZA, XI and their scoring potential.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
