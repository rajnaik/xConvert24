            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono text-blue-300">QI</td><td class="px-4 py-2">11</td><td class="px-4 py-2 text-green-400">21</td><td class="px-4 py-2 text-green-400">31</td><td class="px-4 py-2 text-green-400">22</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono text-blue-300">ZA/ZO</td><td class="px-4 py-2">11</td><td class="px-4 py-2 text-green-400">21</td><td class="px-4 py-2 text-green-400">31</td><td class="px-4 py-2 text-green-400">22</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono text-blue-300">XI/XU</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-green-400">17</td><td class="px-4 py-2 text-green-400">25</td><td class="px-4 py-2 text-green-400">18</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-mono text-blue-300">AX/EX/OX</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-green-400">17</td><td class="px-4 py-2 text-green-400">25</td><td class="px-4 py-2 text-green-400">18</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-mono text-blue-300">JA/JO</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-green-400">17</td><td class="px-4 py-2 text-green-400">25</td><td class="px-4 py-2 text-green-400">18</td></tr>
          </tbody>
        </table>
