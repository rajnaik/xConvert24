            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-bold text-blue-300">4</td><td class="px-4 py-2 font-mono text-green-400">XI</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-gray-400">Greek letter</td><td class="px-4 py-2 text-gray-400">Both</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2 font-bold text-blue-300">5</td><td class="px-4 py-2 font-mono text-green-400">XU</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-gray-400">Vietnamese currency</td><td class="px-4 py-2 text-gray-400">Both</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2 font-bold text-blue-300">6</td><td class="px-4 py-2 font-mono text-green-400">AX</td><td class="px-4 py-2">9</td><td class="px-4 py-2 text-gray-400">A chopping tool</td><td class="px-4 py-2 text-gray-400">Both</td></tr>
