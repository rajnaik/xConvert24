  title="Words With Rare Letter Combinations in Scrabble"
  description="Discover valid Scrabble words with unusual letter pairings like QX, ZX, JK, VW. Surprising combinations your opponents won't expect. No sign-up needed."
  keywords="rare letter combinations scrabble, unusual scrabble words, QI scrabble, ZAX scrabble, rare word pairs, unexpected scrabble plays, uncommon letter pairings, JK words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
