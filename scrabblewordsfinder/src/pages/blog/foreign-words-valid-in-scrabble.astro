---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Foreign Words Valid in Scrabble"
  description="Borrowed words from other languages that are legal in English Scrabble. TOFU, EMOJI, MANGA and more."
  keywords="scrabble, foreign, words, valid, in, scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Foreign Words Valid in Scrabble",
    "description": "Borrowed words from other languages that are legal in English Scrabble. TOFU, EMOJI, MANGA and more.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/foreign-words-valid-in-scrabble" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are foreign words allowed in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Words of foreign origin are valid if they appear in the official Scrabble dictionary (TWL or SOWPODS). Words like QI (Chinese), TOFU (Japanese), PIZZA (Italian), and FJORD (Norwegian) are all playable because they have been adopted into English." }
      },
      {
        "@type": "Question",
        "name": "What high-scoring foreign-origin words work in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI (11 pts), QOPH (18 pts), PIZZA (25 pts), FJORD (16 pts), KIBBUTZ (24 pts), and SCHMALTZ (24 pts) are high-scoring words borrowed from other languages that are valid in English Scrabble." }
      },
      {
        "@type": "Question",
        "name": "How do foreign words enter the Scrabble dictionary?",
        "acceptedAnswer": { "@type": "Answer", "text": "A foreign word becomes valid when major English dictionaries (Merriam-Webster, Collins) include it as an adopted English word. Dictionary committees review new additions periodically, typically every few years." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Foreign Words Valid in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Borrowed words from other languages that are legal in English Scrabble. TOFU, EMOJI, MANGA and more.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
