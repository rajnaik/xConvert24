        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Points</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Meaning</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">HAJJ</td><td class="px-4 py-3">Arabic</td><td class="px-4 py-3 text-amber-600 font-bold">21</td><td class="px-4 py-3">Islamic pilgrimage</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WAQF</td><td class="px-4 py-3">Arabic</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">Religious endowment</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">QOPH</td><td class="px-4 py-3">Hebrew</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">Hebrew letter</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">JEUX</td><td class="px-4 py-3">French</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">Games (SOWPODS)</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">KANJI</td><td class="px-4 py-3">Japanese</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">Chinese characters</td></tr>
