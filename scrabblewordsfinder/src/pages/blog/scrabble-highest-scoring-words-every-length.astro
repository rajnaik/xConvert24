<BlogLayout
  title="Highest-Scoring Valid Word at Every Length (2–15 Letters)"
  description="The single highest-scoring valid SOWPODS word for each word length from 2 to 15 letters. Letter-by-letter tile breakdowns, definitions. No sign-up needed."
  keywords="highest scoring scrabble words by length, best scrabble word every length, maximum score word 2-15 letters, highest point scrabble words, SOWPODS high scoring, scrabble tile values, best words by letter count"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
