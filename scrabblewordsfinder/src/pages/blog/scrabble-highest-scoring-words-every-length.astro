              <th class="px-4 py-3 text-left font-semibold text-gray-300">Score</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Breakdown</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">2</td><td class="px-4 py-3 text-white font-bold">QI</td><td class="px-4 py-3 text-amber-400 font-bold">11</td><td class="px-4 py-3 text-gray-400">Q(10)+I(1)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">3</td><td class="px-4 py-3 text-white font-bold">ZAX</td><td class="px-4 py-3 text-amber-400 font-bold">19</td><td class="px-4 py-3 text-gray-400">Z(10)+A(1)+X(8)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-white font-bold">JAZZ</td><td class="px-4 py-3 text-amber-400 font-bold">29</td><td class="px-4 py-3 text-gray-400">J(8)+A(1)+Z(10)+Z(10)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">5</td><td class="px-4 py-3 text-white font-bold">JAZZY</td><td class="px-4 py-3 text-amber-400 font-bold">33</td><td class="px-4 py-3 text-gray-400">J(8)+A(1)+Z(10)+Z(10)+Y(4)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">6</td><td class="px-4 py-3 text-white font-bold">JAZZED</td><td class="px-4 py-3 text-amber-400 font-bold">32</td><td class="px-4 py-3 text-gray-400">J(8)+A(1)+Z(10)+Z(10)+E(1)+D(2)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">7</td><td class="px-4 py-3 text-white font-bold">JAZZING</td><td class="px-4 py-3 text-amber-400 font-bold">33</td><td class="px-4 py-3 text-gray-400">J(8)+A(1)+Z(10)+Z(10)+I(1)+N(1)+G(2)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">8</td><td class="px-4 py-3 text-white font-bold">QUIZZIFY</td><td class="px-4 py-3 text-amber-400 font-bold">41</td><td class="px-4 py-3 text-gray-400">Q(10)+U(1)+I(1)+Z(10)+Z(10)+I(1)+F(4)+Y(4)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">9</td><td class="px-4 py-3 text-white font-bold">QUIZZICAL</td><td class="px-4 py-3 text-amber-400 font-bold">39</td><td class="px-4 py-3 text-gray-400">Q(10)+U(1)+I(1)+Z(10)+Z(10)+I(1)+C(3)+A(1)+L(1)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">10</td><td class="px-4 py-3 text-white font-bold">QUIZZIFIED</td><td class="px-4 py-3 text-amber-400 font-bold">43</td><td class="px-4 py-3 text-gray-400">Q(10)+U(1)+I(1)+Z(10)+Z(10)+I(1)+F(4)+I(1)+E(1)+D(2)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">11</td><td class="px-4 py-3 text-white font-bold">QUIZZIFYING</td><td class="px-4 py-3 text-amber-400 font-bold">46</td><td class="px-4 py-3 text-gray-400">Q(10)+U(1)+I(1)+Z(10)+Z(10)+I(1)+F(4)+Y(4)+I(1)+N(1)+G(2)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-white font-bold">BLACKJACKING</td><td class="px-4 py-3 text-amber-400 font-bold">34</td><td class="px-4 py-3 text-gray-400">B(3)+L(1)+A(1)+C(3)+K(5)+J(8)+A(1)+C(3)+K(5)+I(1)+N(1)+G(2)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">13</td><td class="px-4 py-3 text-white font-bold">OBJECTIVIZING</td><td class="px-4 py-3 text-amber-400 font-bold">37</td><td class="px-4 py-3 text-gray-400">O(1)+B(3)+J(8)+E(1)+C(3)+T(1)+I(1)+V(4)+I(1)+Z(10)+I(1)+N(1)+G(2)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">14</td><td class="px-4 py-3 text-white font-bold">PHOTOOXIDIZING</td><td class="px-4 py-3 text-amber-400 font-bold">39</td><td class="px-4 py-3 text-gray-400">P(3)+H(4)+O(1)+T(1)+O(1)+X(8)+I(1)+D(2)+I(1)+Z(10)+I(1)+N(1)+G(2)+... see analysis</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-white font-bold">OXYPHENBUTAZONE</td><td class="px-4 py-3 text-amber-400 font-bold">41</td><td class="px-4 py-3 text-gray-400">O(1)+X(8)+Y(4)+P(3)+H(4)+E(1)+N(1)+B(3)+U(1)+T(1)+A(1)+Z(10)+O(1)+N(1)+E(1)</td></tr>
