            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">15</td><td class="px-4 py-3 text-white font-medium">SQUID</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A marine cephalopod</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">16</td><td class="px-4 py-3 text-white font-medium">MONKEY</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A primate</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">17</td><td class="px-4 py-3 text-white font-medium">CHEETAH</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">The fastest land animal</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">18</td><td class="px-4 py-3 text-white font-medium">BUFFALO</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A large bovine</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">19</td><td class="px-4 py-3 text-white font-medium">RHINOCEROS</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A large horned mammal</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">20</td><td class="px-4 py-3 text-white font-medium">QUAIL</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A small ground bird</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">21</td><td class="px-4 py-3 text-white font-medium">PYTHON</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A large constricting snake</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">22</td><td class="px-4 py-3 text-white font-medium">LYNX</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A wild cat with tufted ears</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">23</td><td class="px-4 py-3 text-white font-medium">HAWK</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A bird of prey</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">24</td><td class="px-4 py-3 text-white font-medium">GIRAFFE</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">The tallest living animal</td></tr>
