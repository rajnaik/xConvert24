          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">JACKAL</td><td class="px-4 py-3 text-blue-400">19</td><td class="px-4 py-3 text-gray-400">A wild canine of Africa and Asia</td></tr>
