              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Meaning</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">27</td><td class="px-4 py-3 text-white font-medium">WOMBAT</td><td class="px-4 py-3 text-green-400">13</td><td class="px-4 py-3 text-gray-400">A burrowing marsupial</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">28</td><td class="px-4 py-3 text-white font-medium">TURKEY</td><td class="px-4 py-3 text-green-400">13</td><td class="px-4 py-3 text-gray-400">A large domesticated bird</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">29</td><td class="px-4 py-3 text-white font-medium">SHRIMP</td><td class="px-4 py-3 text-green-400">13</td><td class="px-4 py-3 text-gray-400">A small crustacean</td></tr>
