          <div><p class="text-xl font-bold text-amber-400">30</p><p class="text-xs text-gray-400">Verified Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">43 pts</p><p class="text-xs text-gray-400">Highest (ZYZZYVA)</p></div>
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">Minimum Score</p></div>
          <div><p class="text-xl font-bold text-amber-400">SOWPODS</p><p class="text-xs text-gray-400">Dictionary Verified</p></div>
        </div>
      </div>

      <!-- Hero Card: ZYZZYVA -->
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 #1 Animal Word</div>
