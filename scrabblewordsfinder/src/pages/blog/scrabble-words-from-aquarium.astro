---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from the Aquarium — Fish Terms That Score Big"
  description="Aquarium and fish words valid in Scrabble with full scoring. GUPPY (13pts), SHARK (12pts), CORAL (7pts). Aquatic vocabulary for competitive Scrabble players."
  keywords="scrabble aquarium words, guppy scrabble points, shark scrabble, coral scrabble, fish words scrabble, aquatic vocabulary scrabble, marine words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from the Aquarium — Fish Terms That Score Big","description":"Aquarium and fish words valid in Scrabble with full scoring. GUPPY (13pts), SHARK (12pts), CORAL (7pts).","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-aquarium"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is GUPPY a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! GUPPY scores 13 points (G=2, U=1, P=3, P=3, Y=4). The double P=3 tiles plus Y=4 give this small fish big Scrabble value. Valid in both TWL and SOWPODS."}},{"@type":"Question","name":"How many points is SHARK worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SHARK scores 12 points (S=1, H=4, A=1, R=1, K=5). The H=4 and K=5 combination makes this 5-letter predator a reliable mid-game scorer."}},{"@type":"Question","name":"Can you play CORAL in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes. CORAL scores 7 points (C=3, O=1, R=1, A=1, L=1). A solid 5-letter word that hooks easily with S to make CORALS (8pts) or ED to make CORALED."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from the Aquarium — Fish Terms That Score Big</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">Dive into aquarium vocabulary for your next Scrabble game. Fish names and marine terms feature double letters, K tiles, and Y tiles that translate into surprisingly high scores from familiar words.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">GUPPY</p></div>
          <div><p class="text-xl font-bold text-amber-400">12 pts</p><p class="text-xs text-gray-400">SHARK</p></div>
          <div><p class="text-xl font-bold text-amber-400">7 pts</p><p class="text-xs text-gray-400">CORAL</p></div>
          <div><p class="text-xl font-bold text-amber-400">14 pts</p><p class="text-xs text-gray-400">SHRIMP</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top-Scoring Aquarium Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">SHRIMP — 14 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">S=1, H=4, R=1, I=1, M=3, P=3 · 6 letters · H+M+P power</p>
        <p class="text-sm text-gray-300 leading-relaxed">This tiny crustacean packs a big scoring punch. SHRIMP stacks H=4, M=3, and P=3 — three premium consonants in a natural 6-letter word that flows easily onto the board.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🐟 GUPPY</p><p class="text-xs text-gray-400">13 pts · G=2, U=1, P=3, P=3, Y=4 · Double P</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🦈 SHARK</p><p class="text-xs text-gray-400">12 pts · S=1, H=4, A=1, R=1, K=5 · H+K combo</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🪸 CORAL</p><p class="text-xs text-gray-400">7 pts · C=3, O=1, R=1, A=1, L=1 · Hookable</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🐙 SQUID</p><p class="text-xs text-gray-400">15 pts · S=1, Q=10, U=1, I=1, D=2 · Q word</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Aquatic Vocabulary</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PLANKTON</span><span class="text-green-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">KELP</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">TROUT</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PRAWN</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">ALGAE</span><span class="text-green-400 text-xs">6pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">REEF</span><span class="text-green-400 text-xs">7pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Aquarium Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">SQUID is your Q-with-U play:</span> At 15 points from 5 tiles (3.0 pts/tile), SQUID uses Q naturally. One of the highest-efficiency Q words available.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">GUPPY doubles the P tile:</span> Two P=3 tiles plus Y=4 in just 5 letters. When you draw double P, think aquarium — GUPPY is the highest-scoring PP word at this length.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">SHARK combines H and K:</span> H=4 plus K=5 gives you 9 points from just two tiles. SHARK is the go-to word when both appear on your rack.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Aquarium words love <span class="text-white font-medium">doubled consonants and premium combos</span>. GUPPY (PP), SHARK (H+K), SHRIMP (H+M+P), and KELP (K) all punch above their length in points per tile.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-ocean/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from the Ocean</span></a>
          <a href="/blog/scrabble-nature-words/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Nature Words</span></a>
          <a href="/blog/scrabble-animal-words/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Animal Words</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid aquatic word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
