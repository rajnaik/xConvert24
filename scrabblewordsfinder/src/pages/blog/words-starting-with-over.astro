---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';

import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<BlogLayout title="Words Starting With OVER- — Scrabble Prefix Scoring Guide" description="Master OVER- prefix words in Scrabble. Find high-scoring overjoyed, overkill, and overwhelm plays with strategy tips for this excess prefix. Free tool." keywords="words starting with over, scrabble over words, over prefix scrabble, high scoring over words, overjoyed scrabble, over prefix strategy">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Starting With OVER- — Scrabble Prefix Scoring Guide",
    "datePublished": "2026-06-15",
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring OVER- words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "OVERJOYED scores 23 points, OVERTAXED scores 20 points, and OVERKILL scores 15 points. The OVER- prefix contributes 7 base points (O=1, V=4, E=1, R=1) before premium squares." } },
      { "@type": "Question", "name": "How many valid OVER- words exist in the Scrabble dictionary?", "acceptedAnswer": { "@type": "Answer", "text": "There are over 500 valid OVER- words in the SOWPODS Scrabble dictionary, ranging from 4-letter OVER itself to 15-letter compounds like OVERCOMPENSATED." } },
      { "@type": "Question", "name": "Is OVER a valid Scrabble word on its own?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, OVER is a valid Scrabble word scoring 7 points (O=1, V=4, E=1, R=1). It can also serve as a hook base for extensions like OVERT, OVERS, and OVERLY." } }
    ]
  })} />

  <article class="max-w-4xl mx-auto px-4 py-8">

    <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">The OVER- prefix is one of Scrabble's most versatile tools for racking up points. With over 500 valid words and power-tile magnets like OVERJOYED and OVERTAXED, this excess prefix transforms ordinary racks into bingo machines. The V alone contributes 4 points, making OVER- one of the higher-value prefixes in the game.</p>

    <!-- Stat Strip -->
    <div class="grid grid-cols-3 gap-4 mb-8 p-4 rounded-lg bg-amber-500/30 dark:bg-amber-500/10">
      <div class="text-center">
        <div class="text-2xl font-bold text-amber-700 dark:text-amber-400">7 pts</div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Base Value (O1+V4+E1+R1)</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-amber-700 dark:text-amber-400">500+</div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Valid Words</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-amber-700 dark:text-amber-400">4–15</div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Letter Range</div>
      </div>
    </div>

    <!-- Top Scoring Words -->
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-amber-500 pl-3">Top-Scoring OVER- Words</h2>
    <div class="overflow-x-auto mb-8">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-100 dark:bg-gray-800">
            <th class="p-3 font-semibold text-gray-700 dark:text-gray-300">Word</th>
            <th class="p-3 font-semibold text-gray-700 dark:text-gray-300">Points</th>
            <th class="p-3 font-semibold text-gray-700 dark:text-gray-300">Length</th>
            <th class="p-3 font-semibold text-gray-700 dark:text-gray-300">Power Tiles</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-200 dark:border-gray-700"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERJOYED</td><td class="p-3">23 pts</td><td class="p-3">9 letters</td><td class="p-3">J(8) + Y(4) power</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERTAXED</td><td class="p-3">20 pts</td><td class="p-3">9 letters</td><td class="p-3">X(8) + D(2) combo</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERWHELM</td><td class="p-3">17 pts</td><td class="p-3">9 letters</td><td class="p-3">W(4) + H(4) + M(3)</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERWATCH</td><td class="p-3">17 pts</td><td class="p-3">9 letters</td><td class="p-3">W(4) + H(4) + C(3)</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERPOWER</td><td class="p-3">16 pts</td><td class="p-3">9 letters</td><td class="p-3">P(3) + W(4) + P(3)</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERKILL</td><td class="p-3">15 pts</td><td class="p-3">8 letters</td><td class="p-3">K(5) + L(1) pair</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERCOME</td><td class="p-3">15 pts</td><td class="p-3">8 letters</td><td class="p-3">C(3) + M(3) bingo</td></tr>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-mono font-bold text-amber-700 dark:text-amber-400">OVERLOOK</td><td class="p-3">12 pts</td><td class="p-3">8 letters</td><td class="p-3">K(5) + L(1) clean</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Category Cards -->
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-amber-500 pl-3">OVER- Words by Category</h2>
    <div class="grid md:grid-cols-2 gap-4 mb-8">
      <div class="p-4 rounded-lg border border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-900/20">
