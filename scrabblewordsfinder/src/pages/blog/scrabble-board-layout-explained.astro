      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/understanding-premium-squares/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Understanding Premium Squares: DL, TL, DW, TW Strategy Guide</span>
          </a>
          <a href="/blog/scrabble-scoring-guide/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Scoring Guide: Letter Values & Premium Squares</span>
          </a>
          <a href="/blog/scrabble-rules-explained/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
