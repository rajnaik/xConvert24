    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between SOWPODS and TWL in Scrabble?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SOWPODS (now called Collins Scrabble Words or CSW) contains approximately 280,000 words and is used in international tournaments governed by WESPA. TWL (Tournament Word List) contains approximately 190,000 words and is used in North American tournaments governed by NASPA. SOWPODS includes all TWL words plus about 90,000 additional words from British, Australian, and other English-speaking regions."
        }
      },
      {
        "@type": "Question",
        "name": "Which Scrabble dictionary should I study — SOWPODS or TWL?",
