---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix SUB- — SUBJECT, SUBTEXT, SUBWAY" description="Top SUB- prefix Scrabble words: SUBJECT (18pts), SUBTEXT (16pts), SUBWAY (14pts). Master the underground prefix for high-scoring plays and bingos." keywords="scrabble sub prefix words, subject scrabble, subtext scrabble, subway scrabble, sub prefix strategy, sub prefix bingo">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix SUB- — SUBJECT, SUBTEXT, SUBWAY","description":"Master SUB- prefix words in Scrabble: SUBJECT (18pts), SUBTEXT (16pts), SUBWAY (14pts) for high-scoring plays.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-sub"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best SUB- prefix words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SUBJECT scores 18 points (J=8, B=3, C=3), SUBTEXT scores 16 points (X=8), and SUBWAY scores 14 points (W=4, Y=4). SUB- pairs exceptionally well with J, X, and W."}},{"@type":"Question","name":"How many valid SUB- words exist in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Over 150 valid SUB- words exist in SOWPODS. The prefix costs 5 points (S=1, U=1, B=3) and creates words from 5-15 letters."}},{"@type":"Question","name":"Is SUB- good for bingos?","acceptedAnswer":{"@type":"Answer","text":"SUB- uses only 3 tiles, leaving 4 for the root. SUBJECT (7 letters) is a valid bingo earning 18 + 50 = 68 points. More root flexibility means more bingo opportunities."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix SUB- — The Underground Prefix</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">SUB- is a compact 3-tile prefix costing 5 points (B=3 provides weight). With only 3 tiles consumed, you have 4 remaining for the root — making bingos easier to reach than with longer prefixes. SUBJECT pairs SUB- with J for 18 points, SUBTEXT uses X for 16, and SUBWAY leverages W+Y for 14.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18</p><p class="text-xs text-gray-400">Top Score (SUBJECT)</p></div>
          <div><p class="text-xl font-bold text-amber-400">3</p><p class="text-xs text-gray-400">Prefix Tiles (SUB)</p></div>
          <div><p class="text-xl font-bold text-amber-400">150+</p><p class="text-xs text-gray-400">Valid SUB- Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">5pts</p><p class="text-xs text-gray-400">Prefix Cost</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top SUB- Prefix Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 SUBJECT</p><p class="text-xs text-gray-400">18 points · 7 letters · S(1)+U(1)+B(3)+J(8)+E(1)+C(3)+T(1) · Bingo!</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 SUBTEXT</p><p class="text-xs text-gray-400">16 points · 7 letters · S(1)+U(1)+B(3)+T(1)+E(1)+X(8)+T(1) · Bingo!</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ SUBWAY</p><p class="text-xs text-gray-400">14 points · 6 letters · S(1)+U(1)+B(3)+W(4)+A(1)+Y(4)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ SUBMIT</p><p class="text-xs text-gray-400">10 points · 6 letters · S(1)+U(1)+B(3)+M(3)+I(1)+T(1)</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">SUB- Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">3-tile prefix advantage:</span> SUB- uses only 3 rack tiles, leaving 4 for the root. More root flexibility means more bingo opportunities than longer prefixes like INTER- or SUPER-.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Pair with J or X:</span> SUBJECT (J=8) and SUBTEXT (X=8) both score 16-18 points. When holding S+U+B alongside J or X, immediately check for valid combinations.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Front hook onto board words:</span> If JECT, TEXT, WAY, or MIT are on the board, front-hook SUB for instant scoring. SUB+JECT uses only 3 rack tiles while scoring the full 7-letter word.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUBJECT</span><span class="text-blue-400 text-xs">18pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUBTEXT</span><span class="text-blue-400 text-xs">16pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUBWAY</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUBMIT</span><span class="text-blue-400 text-xs">10pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">SUB- is the <span class="text-white font-medium">shortest high-value prefix</span> in Scrabble. At 3 tiles with B contributing 3 points, it leaves maximum room for powerful roots. SUBJECT = 18 + 50 bonus = 68 points minimum from a single play.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-starting-with-sub/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Starting With SUB-</span></a>
          <a href="/blog/scrabble-words-with-prefix-pre/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix PRE-</span></a>
          <a href="/blog/scrabble-words-with-prefix-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix UN-</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all SUB- prefix words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
