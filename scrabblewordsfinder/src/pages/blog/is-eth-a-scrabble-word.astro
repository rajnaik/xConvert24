        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">Old English Letters</p>
          <p class="text-xs text-gray-400">ETH (6pts) — ð, the voiced "th"</p>
          <p class="text-xs text-gray-400">ASH (6pts) — æ, the "a" in "cat"</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">Greek Letters</p>
          <p class="text-xs text-gray-400">PHI (8pts), CHI (8pts), PSI (5pts)</p>
          <p class="text-xs text-gray-400">ETA (3pts), RHO (6pts), NU (2pts)</p>
        </div>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">Hebrew Letters</p>
          <p class="text-xs text-gray-400">FE (5pts), PE (4pts), HE (5pts)</p>
          <p class="text-xs text-gray-400">BETH (9pts), GIMEL (8pts)</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">English Letter Names</p>
          <p class="text-xs text-gray-400">ZEE (12pts), ZED (13pts)</p>
          <p class="text-xs text-gray-400">ESS (3pts), CEE (5pts), DEE (4pts)</p>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategic Value of ETH</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
