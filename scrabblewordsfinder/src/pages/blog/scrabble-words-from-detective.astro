---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Detective Stories — Mystery Terms That Score Big"
  description="Detective and mystery words valid in Scrabble with full scoring. JURY (14pts), SLEUTH (9pts), CLUE (6pts). Crime vocabulary for competitive Scrabble players."
  keywords="scrabble detective words, sleuth scrabble points, jury scrabble, clue scrabble, mystery words scrabble, crime vocabulary scrabble, detective terms scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Detective Stories — Mystery Terms That Score Big","description":"Detective and mystery words valid in Scrabble with full scoring. JURY (14pts), SLEUTH (9pts), CLUE (6pts).","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-detective"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is SLEUTH a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! SLEUTH scores 9 points (S=1, L=1, E=1, U=1, T=1, H=4). A 6-letter detective term where the H=4 tile carries most of the value. Valid in both TWL and SOWPODS."}},{"@type":"Question","name":"How many points is JURY worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"JURY scores 14 points (J=8, U=1, R=1, Y=4). The J=8 alone provides over half the total, making this compact 4-letter word extremely efficient at 3.5 points per tile."}},{"@type":"Question","name":"Can you play CLUE in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes. CLUE scores 6 points (C=3, L=1, U=1, E=1). A handy 4-letter word that hooks easily with S to make CLUES (7pts) or D to make CLUED (8pts)."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Detective Stories — Mystery Terms That Score Big</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">Every great mystery has the right words — and so does your Scrabble rack. Detective vocabulary delivers high-value J tiles, compact scorers, and bingo-length words that will leave opponents guessing.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">14 pts</p><p class="text-xs text-gray-400">JURY</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">SLEUTH</p></div>
          <div><p class="text-xl font-bold text-amber-400">6 pts</p><p class="text-xs text-gray-400">CLUE</p></div>
          <div><p class="text-xl font-bold text-amber-400">15 pts</p><p class="text-xs text-gray-400">CONVICT</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top-Scoring Detective Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">CONVICT — 15 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">C=3, O=1, N=1, V=4, I=1, C=3, T=1 · 7 letters · Bingo candidate</p>
        <p class="text-sm text-gray-300 leading-relaxed">A courtroom staple. CONVICT at 7 letters qualifies for the 50-point bingo bonus (65 total). Two C=3 tiles plus V=4 give it strong base value from common letters.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚖️ JURY</p><p class="text-xs text-gray-400">14 pts · J=8, U=1, R=1, Y=4 · J-tile efficiency</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🔍 SLEUTH</p><p class="text-xs text-gray-400">9 pts · S=1, L=1, E=1, U=1, T=1, H=4 · 6 letters</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🔎 CLUE</p><p class="text-xs text-gray-400">6 pts · C=3, L=1, U=1, E=1 · Hookable</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🕵️ SUSPECT</p><p class="text-xs text-gray-400">11 pts · S=1, U=1, S=1, P=3, E=1, C=3, T=1 · 7 letters</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Mystery Vocabulary</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">WITNESS</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">FORGERY</span><span class="text-green-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">MOTIVE</span><span class="text-green-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">ALIBI</span><span class="text-green-400 text-xs">7pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">HEIST</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">THEFT</span><span class="text-green-400 text-xs">11pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Detective Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">JURY is the ultimate J-tile dump:</span> 14 points from just 4 tiles — that's 3.5 points per tile. J=8 and Y=4 do all the work with minimal board space.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">CONVICT is your bingo target:</span> At 7 letters with 15 base points, CONVICT + 50 bonus = 65 points. Common letters (O, N, I, T) plus V and double C make it achievable.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">CLUE hooks everything:</span> Add S for CLUES, D for CLUED, or ING for CLUEING. Low base score but maximum flexibility for parallel plays.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Detective words split into two camps: <span class="text-white font-medium">compact J-tile plays</span> (JURY, JUDGE) and <span class="text-white font-medium">bingo-length courtroom words</span> (CONVICT, SUSPECT, VERDICT). Stock your mental dictionary with both.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-law/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Law</span></a>
          <a href="/blog/obscure-legal-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Obscure Legal Words in Scrabble</span></a>
          <a href="/blog/best-j-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best J Words in Scrabble</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid mystery word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
