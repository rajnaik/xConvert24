            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300 font-bold">WIZ</td><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-gray-300">A wizard; an expert</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300 font-bold">FIZ</td><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-gray-300">To make a hissing sound</td></tr>
