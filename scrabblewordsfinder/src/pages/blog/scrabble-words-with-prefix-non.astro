---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix NON- — NONSENSE, NONPROFIT, NONFICTION" description="Master NON- prefix words: NONFICTION, NONSENSE (8pts), NONPROFIT. Negation 3-letter prefix strategy for extending words and building bingos." keywords="scrabble non prefix, nonsense scrabble, nonprofit scrabble, nonfiction scrabble, non words scrabble, negation prefix strategy">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix NON- — NONSENSE, NONPROFIT, NONFICTION","description":"Master NON- prefix words: NONFICTION, NONSENSE (8pts), NONPROFIT. Negation 3-letter prefix strategy.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-non"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What NON- words are valid in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"NONSENSE (8pts, 8 letters), NONPLUS (9pts, 7 letters), and NONSTOP (9pts, 7 letters) are all valid. Some compound NON- words are not valid — always verify with the dictionary."}},{"@type":"Question","name":"Why is NON- useful as a Scrabble prefix?","acceptedAnswer":{"@type":"Answer","text":"NON- is just 3 tiles (N+O+N, 3 points total) that negate any word. It extends existing 4-5 letter words into 7-8 letter bingos. If STOP is on the board, you can hook NON- to make NONSTOP."}},{"@type":"Question","name":"Can I extend words on the board with NON-?","acceptedAnswer":{"@type":"Answer","text":"Yes — this is NON-'s greatest strength. If SENSE is on the board, adding NON- creates NONSENSE (8 letters). If STOP is played, NON+STOP = NONSTOP. Look for 4-5 letter words that accept NON- as a front hook."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix NON- — Negation 3-Letter Prefix</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>4 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">NON- is the ultimate board-extension prefix. At just 3 tiles (N, O, N — 3 points total), it transforms any existing word into a longer play. SENSE becomes NONSENSE, STOP becomes NONSTOP, PLUS becomes NONPLUS. The double-N uses two of the most common tiles in the bag, and the prefix extends 4-5 letter words into bingo territory.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">9</p><p class="text-xs text-gray-400">Top Score (NONPLUS)</p></div>
          <div><p class="text-xl font-bold text-amber-400">3</p><p class="text-xs text-gray-400">Prefix Tiles</p></div>
          <div><p class="text-xl font-bold text-amber-400">3pts</p><p class="text-xs text-gray-400">Prefix Cost</p></div>
          <div><p class="text-xl font-bold text-amber-400">7-8</p><p class="text-xs text-gray-400">Result Length</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top NON- Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 NONPLUS</p><p class="text-xs text-gray-400">9 pts · 7 letters · N(1)+O(1)+N(1)+P(3)+L(1)+U(1)+S(1)</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 NONSTOP</p><p class="text-xs text-gray-400">9 pts · 7 letters · N(1)+O(1)+N(1)+S(1)+T(1)+O(1)+P(3)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ NONSENSE</p><p class="text-xs text-gray-400">8 pts · 8 letters · N(1)+O(1)+N(1)+S(1)+E(1)+N(1)+S(1)+E(1)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ NONSUIT</p><p class="text-xs text-gray-400">7 pts · 7 letters · N(1)+O(1)+N(1)+S(1)+U(1)+I(1)+T(1)</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">NON- Extension Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Front-hook existing words:</span> NON-'s power is extending words already on the board. If SENSE, STOP, PLUS, or SUIT is played, hook NON- in front for 7-8 letter plays — potentially earning the bingo bonus.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Cheapest negation prefix:</span> UN- costs 2 tiles but NON- creates words UN- can't — NONSENSE, NONSTOP, NONPLUS are uniquely NON-. The extra tile is worth it for exclusive bingo opportunities.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Double-N availability:</span> With 6 N tiles in the bag, drawing two is common. When you have N+N+O, scan the board for hookable 4-5 letter words. NON- turns a crowded board into an opportunity.</p></div>
      </div>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">NONPLUS</span><span class="text-blue-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">NONSTOP</span><span class="text-blue-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">NONSENSE</span><span class="text-blue-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">NONSUIT</span><span class="text-blue-400 text-xs">7pts</span></span>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">NON- is the <span class="text-white font-medium">best board-extension prefix</span> in Scrabble. While other prefixes require building from scratch, NON- leverages words your opponent already played — turning their 5-letter word into your 8-letter bingo.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-prefix-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Prefix UN-</span></a>
          <a href="/blog/scrabble-words-with-prefix-dis/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Prefix DIS-</span></a>
          <a href="/blog/common-bingo-prefixes/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Common Bingo Prefixes</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find NON- words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
