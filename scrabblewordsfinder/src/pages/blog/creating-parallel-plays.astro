  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a parallel play in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "A parallel play is when you place a word directly alongside an existing word on the board, so that every pair of adjacent letters also forms a valid two-letter word. You score points for your main word plus every cross-word formed, often doubling or tripling your total score for the turn." }
      },
      {
        "@type": "Question",
        "name": "How many points can a parallel play score?",
        "acceptedAnswer": { "@type": "Answer", "text": "A well-placed parallel play can easily score 40-60+ points because you're scoring multiple words simultaneously. A 4-letter word played parallel to an existing 4-letter word scores your main word plus up to 4 additional two-letter cross-words — all in one turn." }
      },
      {
        "@type": "Question",
        "name": "What two-letter words are most useful for parallel plays?",
