<BlogLayout
  title="Creating Parallel Plays — Score Double Every Turn"
  description="Master parallel plays in Scrabble: place words alongside existing ones to score multiple words simultaneously. Learn the 2-letter word pairs that unlock this technique."
  keywords="parallel plays scrabble, scrabble parallel words, two letter words scrabble, multi-word scoring, adjacent plays scrabble, scrabble cross words strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Creating Parallel Plays — Score Double Every Turn",
    "description": "Master parallel plays in Scrabble: place words alongside existing ones to score multiple words simultaneously.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/creating-parallel-plays" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a parallel play in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "A parallel play places a word directly alongside (above, below, or beside) an existing word on the board. Every adjacent letter pair must form a valid 2-letter word. You score your main word PLUS every 2-letter cross-word created, often doubling or tripling your expected score." }
      },
      {
        "@type": "Question",
        "name": "How many points can a parallel play score in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Parallel plays routinely score 30-50 points because you're scoring 3-6 words simultaneously. A 4-letter word played parallel to a 4-letter word scores your word (say 8 pts) plus four 2-letter cross-words (say 4-6 pts each) = 24-32 total. With premium squares, parallels can exceed 60 points." }
      },
      {
        "@type": "Question",
        "name": "What 2-letter words do you need to know for parallel plays?",
        "acceptedAnswer": { "@type": "Answer", "text": "The most useful 2-letter words for parallels include: SH, AN, IT, IS, AT, EN, ER, RE, OR, ON, IN, TO, EM, EL, AL, and all vowel combinations (AA, AI, OE, etc.). Memorizing all ~100 valid 2-letter words unlocks parallel opportunities in nearly every board position." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
