      },
      {
        "@type": "Question",
        "name": "When should I use a parallel play instead of a normal play?",
        "acceptedAnswer": { "@type": "Answer", "text": "Use parallel plays when: the board is tight with few open lanes, you have tiles that form valid two-letter combinations with existing letters, a premium square is accessible only through parallel placement, or you want to dump difficult tiles while still scoring well." }
