---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Vocabulary — Word Categories, Learning & Reference"
  description="80+ vocabulary guides: themed word lists (animals, food, science), learning techniques, dictionary comparisons, valid/invalid words, and essential Scrabble vocabulary."
  keywords="scrabble vocabulary, scrabble word lists, themed words, learning scrabble, scrabble dictionary, valid scrabble words, word categories"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How can I improve my Scrabble vocabulary?", "acceptedAnswer": { "@type": "Answer", "text": "Focus on themed word groups (animals, food, science), learn all two-letter words first, then study high-value letter words (Q, X, Z, J). Use our word finder for post-game review to discover words you missed." } },
      { "@type": "Question", "name": "What is the difference between SOWPODS and TWL?", "acceptedAnswer": { "@type": "Answer", "text": "SOWPODS (used internationally) combines British and American dictionaries with ~280,000 words. TWL (Tournament Word List, used in North America) has ~190,000 words. SOWPODS includes everything in TWL plus additional words." } },
      { "@type": "Question", "name": "Are animal names valid in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Many common animal names are valid (CAT, DOG, EMU, GNU) but proper nouns are not (no brand names or specific animal names like FIDO). Scientific genus names and common English animal words are generally valid." } }
    ]
  })} />

