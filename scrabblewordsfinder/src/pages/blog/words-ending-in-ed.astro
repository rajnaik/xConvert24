            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">WAXED</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-gray-400">Applied wax; grew</td></tr>
