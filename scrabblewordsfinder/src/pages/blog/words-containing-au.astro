---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AU — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AU with scores, definitions, and strategic tips. Master AU words for higher-scoring plays."
  keywords="scrabble words containing au, au words scrabble, words with au, scrabble au word list, au scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AU — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AU with scores, definitions, and strategic tips. Master AU words for higher-scoring plays.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-au" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the highest-scoring AU words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top AU words include GAUZE (15 pts), JAUNT (12 pts), HAIKU (12 pts), FRAUD (9 pts), and VAULT (8 pts). Words combining AU with high-value consonants like Z and J score best." }
      },
      {
        "@type": "Question",
        "name": "How many Scrabble words contain AU?",
        "acceptedAnswer": { "@type": "Answer", "text": "Over 800 valid Scrabble words contain the AU pair. Common patterns include -AULT, -AUSE, -AUNT endings, plus words starting with AUG-, AUT-, and AUD-." }
      },
      {
        "@type": "Question",
        "name": "What strategy works best with AU tiles?",
        "acceptedAnswer": { "@type": "Answer", "text": "AU words excel at managing vowel-heavy racks since they use two vowels productively. The -AULT and -AUSE endings pair with common consonants for consistent 7-8 point plays. Look for GAUZE or JAUNT when high-value tiles are available." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AU — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">AU is a versatile vowel pair that appears in over 800 valid Scrabble words. From everyday plays like CAUSE, FAULT, and HAUNT to scoring gems like GAUZE and JAUNT, mastering AU words helps you manage vowel-heavy racks while maintaining strong scores. Both A and U are common tiles (9 A's and 4 U's in the bag), so you'll encounter this pair frequently.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AU Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">GAUZE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">Thin transparent fabric</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">JAUNT</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A short trip</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">HAIKU</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">Japanese poem form</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">FRAUD</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">Deliberate deception</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">VAULT</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">A secure room</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">FAULT</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">A defect or error</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">HAUNT</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">To visit as a ghost</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">FAUNA</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">Animal life of a region</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">CAUSE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A reason or motive</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">PAUSE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A brief stop</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">SAUCE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A liquid condiment</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">800+</p><p class="text-xs text-gray-400">Valid AU words</p></div>
          <div><p class="text-xl font-bold text-amber-400">8 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for AU Words</h2>

      <p>AU excels at managing vowel-heavy racks. When you draw multiple vowels, AU words let you use two at once while still scoring well. The -AULT and -AUSE endings are especially productive.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">FAULT</span><span class="text-blue-400 text-xs">8 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">VAULT</span><span class="text-blue-400 text-xs">8 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAUSE</span><span class="text-blue-400 text-xs">7 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PAUSE</span><span class="text-blue-400 text-xs">7 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">GAUZE</span><span class="text-blue-400 text-xs">15 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">JAUNT</span><span class="text-blue-400 text-xs">12 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AU appears in <span class="text-white font-medium">800+ valid words</span> and is your best tool for vowel-heavy racks. The -AULT pattern (FAULT, VAULT) and -AUSE ending (CAUSE, PAUSE) deliver consistent 7-8 point plays. Pair AU with high-value letters like Z (GAUZE) or J (JAUNT) for premium scores.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AU word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
