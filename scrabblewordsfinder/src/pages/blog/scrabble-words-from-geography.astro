---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Geography Words Valid in Scrabble — FJORD, CANYON, STEPPE & More"
  description="Discover geography-derived words that are legal in Scrabble. From FJORD (16pts) to CANYON (11pts) to STEPPE (10pts), these landscape terms score big on the board."
  keywords="geography scrabble words, FJORD scrabble, CANYON scrabble, STEPPE scrabble, landform words scrabble, geographic terms valid scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Geography Words Valid in Scrabble — FJORD, CANYON, STEPPE & More",
    "description": "Discover geography-derived words that are legal in Scrabble. From FJORD (16pts) to CANYON (11pts) to STEPPE (10pts), these landscape terms score big on the board.",
    "datePublished": "2026-06-30",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-words-from-geography" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is FJORD a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, FJORD is valid in both SOWPODS and TWL. It scores 16 points (F=4, J=8, O=1, R=1, D=2) and refers to a long narrow sea inlet between steep cliffs. The J tile (8pts) makes it particularly valuable." }
      },
      {
        "@type": "Question",
        "name": "What geography words score highest in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top geography-origin words by score: FJORD (16pts with J=8), CANYON (11pts), STEPPE (10pts), GEYSER (10pts), GLACIER (10pts), PLATEAU (9pts), TUNDRA (7pts). Words containing J and F from geographic terms score highest." }
      },
      {
        "@type": "Question",
        "name": "Are country names valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No, proper nouns (country names, city names, specific places) are not valid. However, many geographic TERMS describing landforms are valid: fjord, canyon, mesa, butte, delta, steppe, tundra, prairie, glacier, and archipelago are all playable." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Geography Words Valid in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>6 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        Geography has gifted Scrabble players an entire vocabulary of landform words — from Norwegian FJORD (16pts) to Russian STEPPE (10pts) to Spanish CANYON (11pts). These words often come from foreign languages, giving them unusual letter combinations that score higher than typical English. Best of all, they're common nouns — perfectly legal in tournament play.
      </p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">16 pts</p><p class="text-xs text-gray-400">FJORD (highest)</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">CANYON</p></div>
          <div><p class="text-xl font-bold text-amber-400">10 pts</p><p class="text-xs text-gray-400">STEPPE / GEYSER</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">High-Scoring Landform Words</h2>

      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Highest</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">FJORD — 16 pts</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">F(4) + J(8) + O(1) + R(1) + D(2) = 16</p>
        <p class="text-sm text-gray-300 leading-relaxed">A Norwegian narrow sea inlet between steep cliffs. The J tile (8pts) makes this one of the highest-scoring 5-letter geography words. On a DWS this hits 32 points.</p>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">FJORD</span><span class="text-blue-400 text-xs">16pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">CANYON</span><span class="text-blue-400 text-xs">11pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">STEPPE</span><span class="text-blue-400 text-xs">10pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">GEYSER</span><span class="text-blue-400 text-xs">10pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">GLACIER</span><span class="text-blue-400 text-xs">10pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">PLATEAU</span><span class="text-blue-400 text-xs">9pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">TUNDRA</span><span class="text-blue-400 text-xs">7pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">MESA</span><span class="text-blue-400 text-xs">6pts</span>
        </span>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Short Geography Words (2-4 letters)</h2>
      <p>These short landform terms fit into tight board positions:</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">Water Features</p>
          <p class="text-xs text-gray-400">RIA (3pts, inlet), WADI (8pts, dry riverbed), LOCH (9pts, lake), BECK (12pts, stream), TARN (4pts, mountain lake)</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">Land Features</p>
          <p class="text-xs text-gray-400">MESA (6pts, flat hill), BUTTE (7pts, isolated hill), COL (5pts, mountain pass), CWM (10pts, valley), KNOLL (9pts, small hill)</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 CWM — The Secret Weapon</p>
        <p class="text-base text-gray-200">CWM (10pts) is a Welsh word for a mountain valley — with <span class="text-white font-medium">no vowels at all</span>. C(3)+W(4)+M(3) = 10 points for 3 consonants. Perfect when your rack is vowelless. Plural: CWMS (11pts).</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Climate & Biome Words</h2>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">TUNDRA (7pts):</span> Arctic treeless plain. Common tiles but hooks to TUNDRAS for 8pts.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">STEPPE (10pts):</span> Russian grassland. S(1)+T(1)+E(1)+P(3)+P(3)+E(1). Double P boosts this above average.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">SAVANNAH (14pts):</span> Tropical grassland. 8 letters — potential bingo with two N's and three A's.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">PRAIRIE (9pts):</span> North American grassland. 7 letters = bingo! P(3)+R(1)+A(1)+I(1)+R(1)+I(1)+E(1) + 50 bonus = 59pts.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">TAIGA (6pts):</span> Boreal forest region. Short and easy to place with common tiles.</p>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Proper Nouns vs Common Nouns</h2>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">✓ Valid (common nouns)</p>
          <p class="text-xs text-gray-400">fjord, canyon, mesa, delta, glacier, tundra, steppe, plateau, geyser, atoll, butte, prairie</p>
        </div>
        <div class="p-4 rounded-xl border border-red-500/30 bg-red-950/10">
          <p class="text-red-400 font-semibold text-sm mb-1">✗ Invalid (proper nouns)</p>
          <p class="text-xs text-gray-400">Sahara, Amazon, Everest, Thames, Alps, Nile, Atlantic, Pacific, Himalayas</p>
        </div>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-mythology/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Mythology Words Valid in Scrabble</span>
          </a>
          <a href="/blog/foreign-origin-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Foreign-Origin Words Valid in Scrabble</span>
          </a>
          <a href="/blog/scrabble-legal-words-surprises/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Surprising Words That Are Legal in Scrabble</span>
          </a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find geography words from your tiles — free, instant, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
