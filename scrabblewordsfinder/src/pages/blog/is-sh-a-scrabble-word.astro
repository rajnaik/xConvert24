        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-orange-500/40 text-sm">
          <span class="text-white font-bold">SH</span><span class="text-orange-400 text-xs">5pts · SOWPODS</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-orange-500/40 text-sm">
          <span class="text-white font-bold">HM</span><span class="text-orange-400 text-xs">7pts · SOWPODS</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-amber-500/40 text-sm">
          <span class="text-white font-bold">MM</span><span class="text-amber-400 text-xs">6pts · Both</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-amber-500/40 text-sm">
          <span class="text-white font-bold">SHH</span><span class="text-amber-400 text-xs">9pts · Both</span>
        </span>
