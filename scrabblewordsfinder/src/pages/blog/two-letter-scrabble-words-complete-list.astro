<BlogLayout
  title="Complete List of Two-Letter Scrabble Words — All Valid 2-Letter Words"
  description="Every valid two-letter word in Scrabble with point values. Complete SOWPODS list of 127 two-letter words grouped by vowel and consonant starters. Free reference."
  keywords="two letter scrabble words, 2 letter words scrabble, complete two letter word list, all 2 letter scrabble words, sowpods two letter words, valid two letter words"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Complete List of Two-Letter Scrabble Words",
    "description": "Every valid two-letter word in Scrabble with point values. Complete SOWPODS list of 127 two-letter words grouped by vowel and consonant starters.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/two-letter-scrabble-words-complete-list" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many two-letter words are valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "There are 127 valid two-letter words in SOWPODS (the international Scrabble dictionary used in most countries). The TWL (Tournament Word List used in North America) contains 107 two-letter words." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring two-letter word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI is the highest-scoring two-letter word at 11 points (Q=10, I=1). Other high scorers include ZA (11 points), XI (9 points), XU (9 points), and ZO (11 points in SOWPODS)." }
      },
      {
        "@type": "Question",
        "name": "Are all two-letter combinations valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Only 127 out of 676 possible two-letter combinations (26×26) are valid Scrabble words. Each must appear in the official dictionary to be playable." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Two-Letter Words</span>
