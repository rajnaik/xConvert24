      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">NYMPH</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">5</td><td class="px-4 py-3">Y(4) + M(3) boost</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">GLYPH</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">5</td><td class="px-4 py-3">G(2) + Y(4) + L(1)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">TROPHY</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Common rack tiles</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">PHANTOM</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Bingo candidate</td></tr>
