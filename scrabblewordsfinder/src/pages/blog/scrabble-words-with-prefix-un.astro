---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix UN- — UNJUST, UNWIND, UNKIND" description="Top UN- prefix Scrabble words: UNJUST (13pts), UNWIND (10pts), UNKIND (11pts). Master the negation prefix strategy for extending words and scoring big." keywords="scrabble un prefix words, unjust scrabble, unwind scrabble, unkind scrabble, un prefix strategy, negation words scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix UN- — UNJUST, UNWIND, UNKIND","description":"Master UN- prefix words in Scrabble: UNJUST (13pts), UNWIND (10pts), UNKIND (11pts) with negation prefix strategy.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-un"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best UN- prefix words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"UNJUST (13pts) scores high thanks to J worth 8 points. UNKIND (11pts) benefits from K worth 5 points. UNWIND (10pts) uses the W worth 4 points. All three are 6 letters, making them easy to play without needing a bingo."}},{"@type":"Question","name":"How does UN- strategy work in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"UN- is a front hook — you can add it to existing words already on the board. If JUST is played, adding UN in front creates UNJUST for the full word's score. This works with hundreds of words: KIND→UNKIND, WIND→UNWIND, FAIR→UNFAIR."}},{"@type":"Question","name":"Can you extend UN- words further?","acceptedAnswer":{"@type":"Answer","text":"Yes — many UN- words take back hooks too. UNKIND+LY, UNWIND+S, UNJUST+LY. This creates multi-layer scoring: the base word points plus crossing letter bonuses. UN- words are also great for playing through existing board letters."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix UN- — Negation Strategy</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">UN- is the ultimate front hook in Scrabble. It attaches to hundreds of base words, instantly doubling your scoring real estate. UNJUST leverages the 8-point J for 13 total, UNKIND capitalises on the 5-point K for 11, and UNWIND uses the 4-point W for 10. Better yet, if an opponent plays JUST on the board, you can simply hook UN- in front of it — scoring the entire word.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">13</p><p class="text-xs text-gray-400">Top Score (UNJUST)</p></div>
          <div><p class="text-xl font-bold text-amber-400">2</p><p class="text-xs text-gray-400">Prefix Tiles (UN)</p></div>
          <div><p class="text-xl font-bold text-amber-400">500+</p><p class="text-xs text-gray-400">Valid UN- Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">2pts</p><p class="text-xs text-gray-400">Prefix Cost (U+N)</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top UN- Prefix Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 UNJUST</p><p class="text-xs text-gray-400">13 points · 6 letters · U(1)+N(1)+J(8)+U(1)+S(1)+T(1) · J carries the score</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 UNKIND</p><p class="text-xs text-gray-400">11 points · 6 letters · U(1)+N(1)+K(5)+I(1)+N(1)+D(2) · K adds 5pts</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ UNWIND</p><p class="text-xs text-gray-400">10 points · 6 letters · U(1)+N(1)+W(4)+I(1)+N(1)+D(2) · W adds 4pts</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ UNLOCK</p><p class="text-xs text-gray-400">12 points · 6 letters · U(1)+N(1)+L(1)+O(1)+C(3)+K(5) · C+K = 8pts</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">UN- Prefix Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Front hook existing words:</span> If your opponent plays KIND, JUST, WIND, LOCK, FAIR — you can hook UN- in front for the full word score. This is one of the most efficient scoring moves because you invest only 2 tiles.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">UN- extends to bingos:</span> UNKINDLY (8 letters), UNWISELY (8 letters), UNFAIRLY (8 letters). Adding UN- to a 5-6 letter base often creates a bingo-length word. Hold U+N when you see this potential.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Pair with high-value tiles:</span> UN- works best with J, K, W, X bases. UNJUST (13), UNKIND (11), UNWIND (10). The cheap prefix (2pts) leverages expensive base letters.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">UNJUST</span><span class="text-blue-400 text-xs">13pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">UNKIND</span><span class="text-blue-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">UNWIND</span><span class="text-blue-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">UNLOCK</span><span class="text-blue-400 text-xs">12pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">UN- costs only <span class="text-white font-medium">2 points in tiles but unlocks the entire word's score</span> as a front hook. It's the cheapest prefix with the widest reach — over 500 valid UN- words exist in SOWPODS. Always scan the board for hookable words.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-starting-with-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Starting With UN-</span></a>
          <a href="/blog/scrabble-words-with-prefix-re/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix RE-</span></a>
          <a href="/blog/complete-guide-to-hooks/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Complete Guide to Hooks</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all UN- prefix words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
