---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix SUPER- — SUPERB, SUPERFOX, SUPERMAN" description="Top SUPER- prefix Scrabble words: SUPERB (10pts), SUPERFOX (18pts), SUPERMAN (12pts). Master the 5-tile prefix for high-scoring bingo plays." keywords="scrabble super prefix words, superb scrabble, superfox scrabble, superman scrabble, super prefix bingo, 5 tile prefix scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix SUPER- — SUPERB, SUPERFOX, SUPERMAN","description":"Master SUPER- prefix words in Scrabble: SUPERB (10pts), SUPERFOX (18pts), SUPERMAN (12pts) for bingo plays.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-super"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best SUPER- prefix words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SUPERFOX scores 18 points (F=4, O=1, X=8), SUPERMAN scores 12 points (M=3, A=1, N=1), and SUPERB scores 10 points as one of the shortest SUPER- words at just 6 letters."}},{"@type":"Question","name":"Is SUPERB a bingo in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SUPERB at 6 letters is NOT a bingo (you need 7+ tiles played). However, SUPERBLY (8 letters) IS a bingo scoring 15 points + 50 bonus = 65 points. Look for SUPER- words of 7+ letters."}},{"@type":"Question","name":"How many valid SUPER- words are in the Scrabble dictionary?","acceptedAnswer":{"@type":"Answer","text":"Over 100 valid SUPER- words exist in SOWPODS. The prefix costs 7 points (S=1, U=1, P=3, E=1, R=1) and creates words from 6-15 letters."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix SUPER- — Power Prefix Bingos</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">SUPER- is a 5-tile prefix costing 7 points (P=3 does the heavy lifting). Unlike INTER- which uses all 1-point tiles, SUPER- brings P into play for slightly higher raw scoring. SUPERB is the shortest at 6 letters, while SUPERFOX and SUPERMAN push into bingo territory with X and high-frequency consonants.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18</p><p class="text-xs text-gray-400">Top Score (SUPERFOX)</p></div>
          <div><p class="text-xl font-bold text-amber-400">5</p><p class="text-xs text-gray-400">Prefix Tiles (SUPER)</p></div>
          <div><p class="text-xl font-bold text-amber-400">100+</p><p class="text-xs text-gray-400">Valid SUPER- Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">7pts</p><p class="text-xs text-gray-400">Prefix Cost</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top SUPER- Prefix Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 SUPERFOX</p><p class="text-xs text-gray-400">18 points · 8 letters · SUPER(7)+F(4)+O(1)+X(8)</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 SUPERMAN</p><p class="text-xs text-gray-400">12 points · 8 letters · SUPER(7)+M(3)+A(1)+N(1)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ SUPERB</p><p class="text-xs text-gray-400">10 points · 6 letters · SUPER(7)+B(3) · Short and sweet</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ SUPERBLY</p><p class="text-xs text-gray-400">15 points · 8 letters · SUPER(7)+B(3)+L(1)+Y(4)</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">SUPER- Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">P makes the difference:</span> Unlike RE- or UN- which use only 1-point tiles, SUPER- includes P(3). This means the prefix itself contributes decent scoring. SUPERB alone scores 10 in just 6 tiles.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Pair with power tiles:</span> SUPER- shines combined with X (SUPERFOX=18), J, or K. If you draw S+U+P+E+R and have an X remaining, immediately check for valid SUPER- words — the combination is devastating.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Extend SUPERB:</span> SUPERB on the board becomes SUPERBLY (add LY). If you see SUPER already played, hook B for SUPERB, then later extend to SUPERBLY. Multi-turn strategy wins games.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUPERFOX</span><span class="text-blue-400 text-xs">18pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUPERMAN</span><span class="text-blue-400 text-xs">12pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUPERB</span><span class="text-blue-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SUPERBLY</span><span class="text-blue-400 text-xs">15pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">SUPER- is a <span class="text-white font-medium">mid-tier prefix that pairs beautifully with power tiles</span>. While INTER- and RE- are cheaper, SUPER- has P contributing 3 points to every word. Combined with X, J, or K as the root, you get 60-80 point plays including the bingo bonus.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-starting-with-super/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Starting With SUPER-</span></a>
          <a href="/blog/scrabble-words-with-prefix-inter/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix INTER-</span></a>
          <a href="/blog/scrabble-words-with-prefix-over/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix OVER-</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all SUPER- prefix words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
