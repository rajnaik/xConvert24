<BlogLayout
  title="Midgame Strategy — Controlling the Board"
  description="Master Scrabble midgame strategy: board control, balancing offense and defense, lane management, and positioning for the endgame transition."
  keywords="scrabble midgame strategy, board control scrabble, scrabble positioning, midgame tactics, scrabble lane management, transition endgame scrabble"
>
