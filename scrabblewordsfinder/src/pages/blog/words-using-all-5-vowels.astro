---
import Layout from '../../layouts/Layout.astro';
import { isBlogPublished } from '../../lib/blogGate';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<Layout title="Words Using All 5 Vowels — A, E, I, O, U Words for Scrabble | ScrabbleWordsFinder.com" description="Find valid Scrabble words containing all five vowels (A, E, I, O, U). Perfect for dumping vowel-heavy racks while scoring decent points." keywords="words with all 5 vowels, aeiou words scrabble, all vowels word, five vowel words, scrabble vowel dump, words containing aeiou">

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Words Using All 5 Vowels — A, E, I, O, U Words for Scrabble",
  "datePublished": "2026-06-15",
  "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" },
  "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the shortest word with all 5 vowels?", "acceptedAnswer": { "@type": "Answer", "text": "ADIEU (5 letters, 6 points) and AUDIO (5 letters, 6 points) are the shortest common words containing A, E, I, O, and U. OUIJA is another 5-letter option at 12 points with the J tile." }},
    { "@type": "Question", "name": "Are there Scrabble bingo words with all 5 vowels?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! SEQUOIA (7 letters, 16 pts), EULOGIA (7 letters, 8 pts), and ABOITEAU (8 letters, 10 pts) all contain A, E, I, O, U and qualify for the 50-point bingo bonus as 7+ letter words." }},
    { "@type": "Question", "name": "Why are all-vowel words useful in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Vowel-heavy racks are common (5+ vowels with 2 consonants). Knowing words that use multiple vowels lets you dump excess vowels in one play while still scoring, rather than exchanging tiles and losing a turn." }}
  ]
})} />

<div class="max-w-3xl mx-auto px-4">
<article class="prose dark:prose-invert prose-gray max-w-none">

<nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
