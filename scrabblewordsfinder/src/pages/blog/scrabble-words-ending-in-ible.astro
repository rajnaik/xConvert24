      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top -IBLE Word</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">FLEXIBLE — 20 Points</p>
