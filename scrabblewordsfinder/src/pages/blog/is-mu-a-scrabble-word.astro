      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-amber-500/40 text-sm"><span class="text-white font-bold">MUCH</span><span class="text-amber-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-amber-500/40 text-sm"><span class="text-white font-bold">MUSK</span><span class="text-amber-400 text-xs">10pts</span></span>
