            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">FACT</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">A known truth</td></tr>
