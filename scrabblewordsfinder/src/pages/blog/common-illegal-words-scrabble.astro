---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Common Illegal Words in Scrabble"
  description="Words people think are valid but aren't. Proper nouns, abbreviations, and other common mistakes."
  keywords="scrabble, common, illegal, words, scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Common Illegal Words in Scrabble",
    "description": "Words people think are valid but aren't. Proper nouns, abbreviations, and other common mistakes.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/common-illegal-words-scrabble" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What common words are illegal in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Proper nouns (LONDON, NIKE), abbreviations (TV, DNA, ASAP), hyphenated words (WELL-KNOWN), and apostrophised words (CAN'T) are all illegal. Many players also try slang like AIN'T or text speak like LOL which are invalid." }
      },
      {
        "@type": "Question",
        "name": "Why are some everyday words banned in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Scrabble only allows words found in the official dictionary (TWL or SOWPODS). Proper nouns, abbreviations, and words requiring punctuation marks are excluded by the official rules regardless of how commonly they are used." }
      },
      {
        "@type": "Question",
        "name": "Is OK a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "OK was added to the Collins Scrabble dictionary (SOWPODS) in 2014, making it valid in international play. However, it remains invalid in the North American TWL dictionary used in US and Canadian tournaments." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/beginner-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Beginner Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Common Illegal Words in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Words people think are valid but aren't. Proper nouns, abbreviations, and other common mistakes.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
