---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With TH — Common Digraph, Big Scores" description="Master TH words in Scrabble: THRUSH (12pts), THATCH (14pts), HEALTH (12pts), GROWTH (13pts). The most common English digraph and how to score with it." keywords="scrabble words with th, th scrabble words, thrush scrabble, thatch scrabble, th digraph strategy, common th words scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With TH — Common Digraph, Big Scores","description":"Master TH words in Scrabble with scoring breakdowns and strategic tips.","datePublished":"2026-06-29","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-th"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best TH words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top TH words include THATCH (14pts), GROWTH (13pts), HEALTH (12pts), THRUSH (12pts), and WARMTH (14pts). TH is versatile at the start, middle, or end of words."}},{"@type":"Question","name":"How many points is TH worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"T (1 point) + H (4 points) = 5 points from those two tiles. While T is common and low-value, H's 4 points make TH words consistently score above average."}},{"@type":"Question","name":"Is TH the most common digraph in English?","acceptedAnswer":{"@type":"Answer","text":"Yes, TH is the most frequent digraph in English text. You'll encounter T+H on your rack often — knowing TH words gives you reliable scoring options almost every game."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With TH — Common Digraph, Big Scores</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-29">June 29, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">TH is the most common digraph in English — and that frequency translates directly to Scrabble. You'll hold T and H together regularly, and knowing TH words means reliable scoring. With H worth 4 points, every TH word starts with a solid 5-point base from just those two tiles.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">5</p><p class="text-xs text-gray-400">TH Base Points</p></div>
          <div><p class="text-xl font-bold text-amber-400">T=1</p><p class="text-xs text-gray-400">+ H=4</p></div>
          <div><p class="text-xl font-bold text-amber-400">6 T-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
          <div><p class="text-xl font-bold text-amber-400">2 H-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top TH Words by Score</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 THATCH</p><p class="text-xs text-gray-400">14 points · 6 letters · Double T+H</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 GROWTH</p><p class="text-xs text-gray-400">13 points · 6 letters · -TH ending</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ HEALTH</p><p class="text-xs text-gray-400">12 points · 6 letters · Common word</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ THRUSH</p><p class="text-xs text-gray-400">12 points · 6 letters · THR- start</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">TH Strategy Tips</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Three positions:</span> TH works at the start (THE, THICK), middle (PYTHON, GOTHIC), and end (GROWTH, HEALTH). This flexibility means you can almost always find a TH word spot.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">-TH endings are hooks:</span> Many words end in -TH (GROWTH, HEALTH, WEALTH, WARMTH). Add TH to existing words on the board for bonus points.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">H on premium squares:</span> Target DLS for H. H on DLS = 8 points from one tile. Even short THE (6pts) becomes 10pts with H on DLS.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">THE</span><span class="text-blue-400 text-xs">6pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">THICK</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">PYTHON</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WARMTH</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WEALTH</span><span class="text-blue-400 text-xs">12pts</span></span>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-ph/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With PH — Digraph Strategy</span></a>
          <a href="/blog/scrabble-words-with-wh/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With WH — W+H Power</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all TH words instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
