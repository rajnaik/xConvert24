  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Famous Scrabble Matches in History","description":"Relive the most famous Scrabble matches ever played. From record-breaking games to dramatic championship finals, these legendary moments defined competitive Scrabble history.","datePublished":"2026-06-14","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/famous-scrabble-matches"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the highest-scoring Scrabble game ever recorded?","acceptedAnswer":{"@type":"Answer","text":"The highest combined score in a sanctioned tournament game is 1,320 points (830-490), achieved in a 2006 NASPA tournament. The highest single-player score in a tournament game is 830 points. These records involved multiple bingos, perfect premium square usage, and exceptional tile draws combined with elite word knowledge."}},{"@type":"Question","name":"What is the most famous Scrabble match in history?","acceptedAnswer":{"@type":"Answer","text":"Several matches stand out: the 1991 inaugural World Championship final won by Peter Morris, Nigel Richards winning the 2015 French championship without speaking French, and various dramatic come-from-behind victories in national finals. The Richards French championship win is perhaps the most discussed due to its seemingly impossible nature."}},{"@type":"Question","name":"What is the highest single word score in tournament Scrabble?","acceptedAnswer":{"@type":"Answer","text":"The highest single-word score in a sanctioned game is QUIXOTRY played across two triple-word squares for 365 points. Single-word scores exceeding 100 points occur regularly in expert play when high-value tiles hit triple-word squares or when bingos land on premium positions."}}]})} />

  <div class="max-w-3xl mx-auto px-4 py-12">
