---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AT — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AT with scores, definitions, and strategic tips. Find AT words for your next winning play."
  keywords="scrabble words containing at, at words scrabble, words with at, scrabble at word list, at scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AT — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AT with scores, definitions, and strategic tips. Find AT words for your next winning play.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-at" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the highest-scoring AT words?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top AT words include GAZETTE (17 pts), WATCH (13 pts), MATCH/BATCH/CATCH (12 pts each), and SCRATCH (12 pts). The -ATCH ending pattern is particularly productive for scoring." }
      },
      {
        "@type": "Question",
        "name": "How many Scrabble words contain AT?",
        "acceptedAnswer": { "@type": "Answer", "text": "Over 1,500 valid Scrabble words contain AT, making it the most common letter pair in the game. With 9 A tiles and 6 T tiles in the bag, you will draw this combination constantly." }
      },
      {
        "@type": "Question",
        "name": "What makes AT the best letter pair to know?",
        "acceptedAnswer": { "@type": "Answer", "text": "AT appears in more valid words than any other pair. The -AT ending accepts every consonant prefix (BAT through VAT), the -ATCH extension scores 12+ points, and AT itself is a valid 2-letter word for parallel plays." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AT — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">AT is the most common letter pair in Scrabble. With well over 1,500 valid words, you will play AT combinations more than any other pair. From the simple 2-letter word AT to everyday plays like THAT, WATER, and GREAT, this pair is the backbone of Scrabble vocabulary. The T tile appears 6 times in the bag, making AT draws extremely frequent.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AT Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">GAZETTE</td><td class="px-4 py-3 text-blue-400">17</td><td class="px-4 py-3 text-gray-400">A newspaper</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">SCRATCH</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To scrape</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">WATCH</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">A timepiece</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">MATCH</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A contest</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">BATCH</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A group quantity</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">CATCH</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To grab</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">FLAT</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">Level and smooth</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">CHAT</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">To talk casually</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">THAT</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">Referring to</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">BAT</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A flying mammal</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">CAT</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A feline</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">1,500+</p><p class="text-xs text-gray-400">Valid AT words</p></div>
          <div><p class="text-xl font-bold text-amber-400">7 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Very Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">The -AT and -ATCH Endings</h2>

      <p>The -AT ending is the most flexible in Scrabble — BAT, CAT, FAT, HAT, MAT, PAT, RAT, SAT, VAT. The -ATCH extension (BATCH, CATCH, MATCH, WATCH) adds significant scoring power.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">BAT</span><span class="text-blue-400 text-xs">5 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAT</span><span class="text-blue-400 text-xs">5 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">HAT</span><span class="text-blue-400 text-xs">6 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CHAT</span><span class="text-blue-400 text-xs">9 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">MATCH</span><span class="text-blue-400 text-xs">12 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WATCH</span><span class="text-blue-400 text-xs">13 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AT is the <span class="text-white font-medium">most played letter pair</span> in Scrabble with 1,500+ words. The -AT ending (BAT, CAT, FAT, HAT, MAT, PAT, RAT, SAT, VAT) gives you a play from almost any rack. For higher scores, the -ATCH pattern (MATCH, WATCH, CATCH, BATCH) delivers 12-13 points consistently.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AT word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>