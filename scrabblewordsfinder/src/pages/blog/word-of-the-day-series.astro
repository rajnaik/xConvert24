---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Word of the Day Series — Daily Scrabble Words"
  description="Explore our Word of the Day series: daily curated Scrabble words with definitions, scoring tips, and usage examples. Build your vocabulary one word at a time — free and automatic."
  keywords="scrabble word of the day, daily scrabble word, word of the day series, wotd scrabble, learn scrabble words daily, vocabulary builder scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Word of the Day Series — Daily Scrabble Words",
    "description": "Explore our Word of the Day series: daily curated Scrabble words with definitions, scoring tips, and usage examples.",
    "datePublished": "2026-06-18",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/word-of-the-day-series" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the Word of the Day work?",
        "acceptedAnswer": { "@type": "Answer", "text": "Every day at midnight, a new Scrabble word is revealed on the Activities page. Each word includes its definition, point value, valid dictionaries (SOWPODS/TWL), and strategic tips for using it in gameplay. Words are curated to help you learn uncommon but high-scoring options." }
      },
      {
        "@type": "Question",
        "name": "Where can I see past Words of the Day?",
        "acceptedAnswer": { "@type": "Answer", "text": "Visit the Word of the Day Archive at /blog/wotd/ to browse all past words organised by month. Each month shows every word that was revealed, along with definitions and scoring information. You can also see upcoming months (locked until their dates arrive)." }
      },
      {
        "@type": "Question",
        "name": "Are the Words of the Day valid in competitive Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes — every Word of the Day is verified against the SOWPODS dictionary (280,000+ words used in international Scrabble). Most are also valid in TWL (North American tournaments). Each word card shows which dictionaries accept it." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">&larr; Blog</a>
        <span class="mx-1">&rsaquo;</span>
        <span class="text-gray-300">Word of the Day Series</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">📅 Word of the Day Series</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-18">June 18, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>3 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/activities/" class="inline-flex items-center gap-1 text-purple-400 hover:underline"><span aria-hidden="true">🧠</span> Activities</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        Every day, we reveal a new Scrabble word designed to expand your vocabulary and sharpen your game. From obscure two-letter gems to powerful bingo-length plays, the Word of the Day series helps you learn one word at a time — with definitions, scoring breakdowns, and strategic tips delivered automatically.
      </p>

      <h2 class="text-xl font-light text-purple-400 mt-10 mb-4 border-l-4 border-purple-400 pl-4">What You Get Each Day</h2>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-purple-400 font-semibold text-sm mb-1">📖 Definition</p>
          <p class="text-xs text-gray-400">Full meaning from official dictionaries with part of speech and usage context.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-purple-400 font-semibold text-sm mb-1">🎯 Point Value</p>
          <p class="text-xs text-gray-400">Exact Scrabble score calculated using standard tile values.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-purple-400 font-semibold text-sm mb-1">✅ Dictionary Validity</p>
          <p class="text-xs text-gray-400">Shows whether the word is valid in SOWPODS, TWL, or both.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20">
          <p class="text-purple-400 font-semibold text-sm mb-1">💡 Strategy Tips</p>
          <p class="text-xs text-gray-400">When and how to play this word for maximum board impact.</p>
        </div>
      </div>

      <h2 class="text-xl font-light text-purple-400 mt-10 mb-4 border-l-4 border-purple-400 pl-4">Browse the Archive</h2>

      <p>Every word ever featured is saved in our monthly archive. Browse past months to find words you missed, or revisit favourites to reinforce your memory.</p>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">📚 Monthly Archive</p>
        <p class="text-base text-gray-200">Visit the <a href="/blog/wotd/" class="text-blue-400 hover:underline font-medium">Word of the Day Archive</a> to browse all past words organised by month. Each entry includes the word, definition, score, and which dictionaries accept it.</p>
      </div>

      <h2 class="text-xl font-light text-purple-400 mt-10 mb-4 border-l-4 border-purple-400 pl-4">How Words Are Selected</h2>

      <div class="not-prose my-6 p-5 rounded-xl border border-purple-500/30 bg-purple-950/10">
        <p class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-3">🧩 Selection Criteria</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">1</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Uncommon but valid</strong> — words most players haven't seen but are tournament-legal.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">2</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Strategically useful</strong> — words that open new plays or score well on premium squares.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">3</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Varied length</strong> — a mix of short tactical words and longer bingo candidates.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">4</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Interesting etymology</strong> — words with memorable origins that help them stick.</p>
          </div>
        </div>
      </div>

      <h2 class="text-xl font-light text-purple-400 mt-10 mb-4 border-l-4 border-purple-400 pl-4">Related Activities</h2>

      <p>The Word of the Day is part of our daily activities suite. Challenge yourself with more ways to improve:</p>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <a href="/activities/" class="p-4 rounded-xl border border-gray-700 bg-gray-900/50 hover:border-purple-500 transition-colors group">
          <p class="text-purple-400 font-semibold text-sm mb-1 group-hover:text-purple-300">🧠 Word Quiz</p>
          <p class="text-xs text-gray-400">Test your word knowledge with daily multiple-choice challenges.</p>
        </a>
        <a href="/activities/" class="p-4 rounded-xl border border-gray-700 bg-gray-900/50 hover:border-purple-500 transition-colors group">
          <p class="text-purple-400 font-semibold text-sm mb-1 group-hover:text-purple-300">🎲 Daily Rack Challenge</p>
          <p class="text-xs text-gray-400">Find the highest-scoring word from a random rack of 7 tiles.</p>
        </a>
        <a href="/activities/" class="p-4 rounded-xl border border-gray-700 bg-gray-900/50 hover:border-purple-500 transition-colors group">
          <p class="text-purple-400 font-semibold text-sm mb-1 group-hover:text-purple-300">🔤 Daily Anagram</p>
          <p class="text-xs text-gray-400">Unscramble a word each day to train pattern recognition.</p>
        </a>
        <a href="/activities/" class="p-4 rounded-xl border border-gray-700 bg-gray-900/50 hover:border-purple-500 transition-colors group">
          <p class="text-purple-400 font-semibold text-sm mb-1 group-hover:text-purple-300">⏱️ 60-Second Blitz</p>
          <p class="text-xs text-gray-400">How many words can you find in 60 seconds? Race the clock daily.</p>
        </a>
      </div>

      <!-- Related Articles -->
      <aside class="border-t border-gray-200 dark:border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">
          Related Articles
        </h3>
        <div class="grid gap-3">
          <a href="/blog/wotd/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-purple-300 dark:hover:border-purple-700 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 transition-all group">
            <span class="text-purple-500 group-hover:translate-x-0.5 transition-transform">&rarr;</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">Word of the Day Monthly Archive</span>
          </a>
          <a href="/blog/beginner-guides/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-purple-300 dark:hover:border-purple-700 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 transition-all group">
            <span class="text-purple-500 group-hover:translate-x-0.5 transition-transform">&rarr;</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">Beginner Guides — Start Learning Scrabble</span>
          </a>
          <a href="/blog/strategy/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-purple-300 dark:hover:border-purple-700 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 transition-all group">
            <span class="text-purple-500 group-hover:translate-x-0.5 transition-transform">&rarr;</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">Scrabble Strategy Guides</span>
          </a>
        </div>
      </aside>

      <!-- CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-purple-50 to-blue-50 dark:from-purple-900/20 dark:to-blue-900/20 border border-purple-200 dark:border-purple-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-purple-800 dark:text-purple-300 font-medium">
            🔤 See today's word and try all daily challenges
          </p>
          <a
            href="/activities/"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-purple-500 hover:bg-purple-600 text-white text-sm font-semibold transition-colors shadow-sm"
          >
            Open Activities &rarr;
          </a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-purple-500 transition-colors">
          &larr; Back to all articles
        </a>
      </div>
    </article>
  </div>
</BlogLayout>
