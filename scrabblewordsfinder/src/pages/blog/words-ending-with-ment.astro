      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">ENJOYMENT</td><td class="px-4 py-3 text-amber-600 font-bold">21</td><td class="px-4 py-3">9</td><td class="px-4 py-3">J(8)+Y(4) pair</td></tr>
