      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">MISQUOTE</td><td class="px-4 py-3 text-amber-600 font-bold">19</td><td class="px-4 py-3">8</td><td class="px-4 py-3">Q(10) bingo</td></tr>
