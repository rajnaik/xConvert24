---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble World Champions — Complete List"
  description="Every World Scrabble Champion from 1991 to present. Stats, playing styles, and notable achievements."
  keywords="scrabble, scrabble, world, champions"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble World Champions — Complete List",
    "description": "Every World Scrabble Champion from 1991 to present. Stats, playing styles, and notable achievements.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-world-champions" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Who are the most successful Scrabble world champions?",
        "acceptedAnswer": { "@type": "Answer", "text": "Nigel Richards (New Zealand) is the most dominant, winning the World Championship 5 times (2007, 2011, 2013, 2019, 2023) plus the French championship despite not speaking French. Other multiple winners include Mark Nyman and Joel Wapnick." }
      },
      {
        "@type": "Question",
        "name": "How do you become a Scrabble world champion?",
        "acceptedAnswer": { "@type": "Answer", "text": "Qualify through national championships or rating thresholds, then compete in the biennial World Scrabble Championship. Champions typically know 180,000+ words, play 1000+ games yearly, and spend 4-6 hours daily studying words and positions." }
      },
      {
        "@type": "Question",
        "name": "What country produces the best Scrabble players?",
        "acceptedAnswer": { "@type": "Answer", "text": "Thailand, Nigeria, and the English-speaking world dominate. Nigel Richards (NZ) is GOAT. Nigeria has produced champions like Wellington Jighere (2015). Thailand's players excel due to their memorization culture. The UK, USA, and Australia have deep competitive scenes." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/tournament/" class="hover:text-blue-400 transition-colors text-gray-300">Tournament</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Scrabble World Champions — Complete List</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Every World Scrabble Champion from 1991 to present. Stats, playing styles, and notable achievements.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
