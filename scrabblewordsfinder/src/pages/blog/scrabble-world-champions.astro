  "mainEntity": [
    { "@type": "Question", "name": "Who has won the most World Scrabble Championships?", "acceptedAnswer": { "@type": "Answer", "text": "No player has won more than one official World Scrabble Championship title. The event has produced a different champion each time since its inception in 1991, highlighting the immense difficulty of repeating." }},
