    { "@type": "Question", "name": "Which countries dominate competitive Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Thailand, Nigeria, Malaysia, and the United States have produced the most world-class players. Thailand's Panupol Sujjayakorn won in 2003, and Nigerian players have consistently reached finals since the 2000s." }}
  ]
