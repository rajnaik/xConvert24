---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Fun Facts & Statistics — Numbers, Records & Oddities"
  description="Fascinating Scrabble statistics, weird facts, probability breakdowns, tile distributions, and record-breaking numbers. The data behind the game."
  keywords="scrabble facts, scrabble statistics, tile probability, scrabble records, weird scrabble facts, scrabble numbers, tile distribution"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the maximum possible Scrabble score in one turn?", "acceptedAnswer": { "@type": "Answer", "text": "The theoretical maximum single-turn score is 1,778 points using the word OXYPHENBUTAZONE across two triple word scores with additional crossword formations. In practice, the highest single-turn score recorded is around 365 points." } },
      { "@type": "Question", "name": "What is the probability of drawing a blank tile?", "acceptedAnswer": { "@type": "Answer", "text": "With 2 blanks in 100 tiles, the probability of drawing at least one blank in your initial 7-tile rack is approximately 13.3%. Each blank is worth 0 points but can represent any letter." } },
      { "@type": "Question", "name": "What is the average winning Scrabble score?", "acceptedAnswer": { "@type": "Answer", "text": "In competitive play, average winning scores range from 350-450 points. Club-level players average 300-350, while casual players typically score 200-300 per game." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Fun Facts & Statistics</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">Fun Facts & Statistics</h1>
    <p class="text-lg text-gray-300 mb-6">
      The numbers behind Scrabble — probability breakdowns, tile distributions, scoring records,
      and fascinating oddities that every word game enthusiast should know.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose mt-8">
      <a href="/blog/weird-scrabble-facts/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Weird Scrabble facts</a>
      <a href="/blog/scrabble-by-the-numbers/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Scrabble by the numbers</a>
      <a href="/blog/maximum-possible-scrabble-score/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Maximum possible score</a>
      <a href="/blog/highest-possible-scrabble-score/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Highest possible score</a>
      <a href="/blog/average-winning-score/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Average winning score</a>
      <a href="/blog/average-game-length/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Average game length</a>
      <a href="/blog/most-valuable-tile/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Most valuable tile</a>
      <a href="/blog/least-valuable-tile/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Least valuable tile</a>
      <a href="/blog/most-surprising-valid-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Most surprising valid words</a>
      <a href="/blog/letter-frequency-in-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Letter frequency</a>
      <a href="/blog/letter-frequency-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Letter frequency (detailed)</a>
      <a href="/blog/tile-distribution-explained/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Tile distribution explained</a>
      <a href="/blog/scrabble-tile-bag-distribution/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Tile bag distribution</a>
      <a href="/blog/scrabble-tile-distribution/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Tile distribution guide</a>
      <a href="/blog/probability-of-drawing-blank/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Probability of drawing blank</a>
      <a href="/blog/probability-of-drawing-blank-tiles/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Blank tile probability</a>
      <a href="/blog/probability-of-drawing-q/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Probability of drawing Q</a>
      <a href="/blog/bingo-frequency-by-dictionary/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Bingo frequency by dictionary</a>
    </div>

    <div class="not-prose mt-12 p-5 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border border-blue-200 dark:border-blue-800 rounded-xl shadow-sm">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <p class="text-sm text-blue-800 dark:text-blue-300 font-medium">Try our free Scrabble Word Finder</p>
        <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
      </div>
    </div>
    <div class="not-prose mt-8 text-center">
      <a href="/blog/" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">← Back to all articles</a>
    </div>
  </div>
</BlogLayout>
