import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Endgame Strategy — Tile Counting & Playing Out First" description="Master Scrabble endgame: tile counting, playing out first for the bonus, strategic passing, and subtracting opponent tiles. Win close games with precision play." keywords="scrabble endgame strategy, playing out first scrabble, tile counting scrabble, endgame bonus scrabble, strategic passing, scrabble final moves">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Endgame Strategy — Tile Counting & Playing Out First","description":"Master Scrabble endgame tactics: tile counting, going-out bonus, strategic passing, and deducing opponent tiles.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-endgame-strategy"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What happens when you play out first in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"When you play your last tile, your opponent subtracts the face value of their remaining tiles from their score, and that same value is added to YOUR score. This double swing makes going out first worth roughly 2× your opponent's remaining tile value."}},{"@type":"Question","name":"When should you pass in the Scrabble endgame?","acceptedAnswer":{"@type":"Answer","text":"Pass when: you're ahead and your opponent is stuck with high-value tiles they can't play (the penalty grows), or when every available play would open a TWS for your opponent. Passing is also correct when you have no legal plays."}},{"@type":"Question","name":"How do you count tiles in the Scrabble endgame?","acceptedAnswer":{"@type":"Answer","text":"Subtract tiles on the board + tiles on your rack from 100 (total tiles). This gives your opponent's exact rack. Knowing their tiles lets you block their best plays and calculate whether going out first is worth more than a higher-scoring play."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12"><article class="prose prose-invert prose-gray max-w-none">
    <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Strategy</span></nav>
    <h1 class="text-3xl font-bold text-white mb-4">Scrabble Endgame Strategy — Tile Counting & Playing Out First</h1>
    <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>6 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
    <p class="text-lg leading-relaxed text-gray-300 mb-8">The endgame begins when the tile bag is empty. From this point, you have perfect information — you can deduce your opponent's exact tiles. Games are won and lost in these final moves, where the going-out bonus creates scoring swings of 20-40 points.</p>
    <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><div class="flex flex-wrap items-center justify-center gap-6 text-center"><div><p class="text-xl font-bold text-amber-400">2×</p><p class="text-xs text-gray-400">Going-Out Swing</p></div><div><p class="text-xl font-bold text-amber-400">100</p><p class="text-xs text-gray-400">Total Tiles</p></div><div><p class="text-xl font-bold text-amber-400">20-40</p><p class="text-xs text-gray-400">Avg Endgame Swing</p></div><div><p class="text-xl font-bold text-amber-400">0</p><p class="text-xs text-gray-400">Tiles in Bag</p></div></div></div>
    <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Playing Out First</h2>
    <div class="not-prose my-6 grid grid-cols-1 gap-4">
      <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">The double swing:</span> Going out means your opponent loses their remaining tile values AND you gain them. If they hold Q-V (14pts face value), the swing is 28 points — enough to flip most close games.</p></div>
      <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Low score ≠ bad play:</span> A 6-point word that empties your rack is often better than a 20-point word that leaves tiles. Calculate: play score + going-out bonus vs higher score without bonus.</p></div>
    </div>
    <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategic Passing</h2>
    <div class="not-prose my-6 grid grid-cols-1 gap-4">
      <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Pass when ahead:</span> If you're leading and your opponent holds Q/Z/V with no valid plays, passing forces them to pass too. After 3 consecutive passes (6 total), the game ends and they eat their tile penalties.</p></div>
      <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Don't pass when behind:</span> You need points to catch up. Even if your only play gives your opponent access to a good square, you must score or you'll lose by attrition.</p></div>
    </div>
    <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Subtracting Opponent Tiles</h2>
    <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">✓ Track high-value tiles</p><p class="text-xs text-gray-400">Know where Q, Z, X, J are — on board or opponent's rack</p></div>
      <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">✓ Count remaining tiles</p><p class="text-xs text-gray-400">100 - board tiles - your rack = opponent's rack</p></div>
      <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚡ Block their plays</p><p class="text-xs text-gray-400">If they hold V, block the only V-playable spots</p></div>
      <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚡ Force stuck tiles</p><p class="text-xs text-gray-400">Make Q/Z unplayable and they eat the penalty</p></div>
    </div>
    <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20"><p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p><p class="text-base text-gray-200">The endgame is <span class="text-white font-medium">chess, not word-finding</span>. You already know every tile in play. The winner is the player who calculates the full sequence — not just the next move, but every move until game end.</p></div>
    <aside class="border-t border-gray-800 mt-12 pt-8 not-prose"><h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3><div class="grid gap-3"><a href="/blog/how-to-count-tiles-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">How to Count Tiles in Scrabble</span></a><a href="/blog/scrabble-board-control-strategy/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Board Control Strategy</span></a></div></aside>
    <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl"><div class="flex items-center justify-between gap-4 flex-wrap"><p class="text-sm text-blue-300 font-medium">🔤 Plan endgame moves with tile tracking — free solver, no sign-up</p><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a></div></div>
    <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
  </article></div>
</BlogLayout>
