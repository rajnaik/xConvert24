          <div><p class="text-xl font-bold text-amber-400">121</p><p class="text-xs text-gray-400">Countries Played In</p></div>
          <div><p class="text-xl font-bold text-amber-400">1938</p><p class="text-xs text-gray-400">Year Invented</p></div>
        </div>
