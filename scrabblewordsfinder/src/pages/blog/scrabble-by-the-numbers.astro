          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Milestone</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Year</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Significance</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900">
              <td class="px-4 py-3 text-white font-semibold">Invented by Alfred Butts</td>
              <td class="px-4 py-3 text-amber-400 font-bold">1938</td>
              <td class="px-4 py-3 text-gray-300">Originally called "Criss-Crosswords"</td>
            </tr>
            <tr class="bg-gray-800/50">
              <td class="px-4 py-3 text-white font-semibold">Trademarked as "Scrabble"</td>
              <td class="px-4 py-3 text-amber-400 font-bold">1948</td>
