---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AZ — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AZ with scores, definitions, and strategic tips. Master AZ words for better Scrabble plays."
  keywords="scrabble words containing az, az words scrabble, words with az, scrabble az word list, az scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AZ — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AZ with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-az" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring AZ words?", "acceptedAnswer": { "@type": "Answer", "text": "Top AZ words include JAZZ (29 pts), DAZZLE (25 pts), BLAZING (19 pts), GAZETTE (17 pts), and BLAZE (16 pts). Z is worth 10 points making AZ among the highest-scoring pairs." } },
      { "@type": "Question", "name": "How many Scrabble words contain AZ?", "acceptedAnswer": { "@type": "Answer", "text": "Around 150 valid words contain AZ. Key patterns include -AZE (BLAZE, GRAZE, GLAZE), -AZZ (JAZZ, RAZZ), and -AZING (BLAZING, GRAZING)." } },
      { "@type": "Question", "name": "Why is AZ a premium combination?", "acceptedAnswer": { "@type": "Answer", "text": "Z is worth 10 points. AZ pairs this with the most common vowel for reliable plays. RAZE, BLAZE, GRAZE all use common tiles for massive scores." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AZ — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">AZ combines the most common vowel with the highest-value tile in Scrabble. Z is worth 10 points, making every AZ word a potential game-changer. With around 150 valid words from RAZE and BLAZE to DAZZLE and GAZETTE, mastering AZ patterns ensures you maximize the Z tile every time it appears on your rack.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AZ Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">JAZZ</td><td class="px-4 py-3 text-blue-400">29</td><td class="px-4 py-3 text-gray-400">A music genre</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">DAZZLE</td><td class="px-4 py-3 text-blue-400">25</td><td class="px-4 py-3 text-gray-400">To blind with light</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">BLAZING</td><td class="px-4 py-3 text-blue-400">19</td><td class="px-4 py-3 text-gray-400">Burning intensely</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">GAZETTE</td><td class="px-4 py-3 text-blue-400">17</td><td class="px-4 py-3 text-gray-400">A newspaper</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">BLAZE</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A bright flame</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">CRAZE</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A brief fashion</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">HAZE</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A thin mist</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">GRAZE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">To feed on grass</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">GLAZE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A shiny coating</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">MAZE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A complex network</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">RAZE</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">To demolish</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">150+</p><p class="text-xs text-gray-400">Valid AZ words</p></div>
          <div><p class="text-xl font-bold text-amber-400">16 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Rare</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for AZ Words</h2>

      <p>With Z worth 10 points, AZ words deliver premium scores even in short forms. The -AZE ending (BLAZE, GRAZE, GLAZE, CRAZE, RAZE, HAZE, MAZE) is the most productive pattern. Place Z on a premium square for devastating point totals.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">JAZZ</span><span class="text-blue-400 text-xs">29 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DAZZLE</span><span class="text-blue-400 text-xs">25 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">BLAZING</span><span class="text-blue-400 text-xs">19 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">GAZETTE</span><span class="text-blue-400 text-xs">17 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">BLAZE</span><span class="text-blue-400 text-xs">16 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CRAZE</span><span class="text-blue-400 text-xs">16 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AZ is a <span class="text-white font-medium">premium scoring combination</span> averaging 16 points per word. The -AZE ending (BLAZE, GRAZE, GLAZE, CRAZE) uses common tiles for 13-16 point plays. DAZZLE (25 pts) and JAZZ (29 pts) are game-winning plays on premium squares.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AZ word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>