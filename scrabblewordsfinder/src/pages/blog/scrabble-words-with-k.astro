    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">KAYAK</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">5</td><td class="px-4 py-3">Uses K twice (rare!)</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">QUIRKY</td><td class="px-4 py-3 text-amber-600 font-bold">22</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Q(10)+K(5)+Y(4)</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">KNACK</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">5</td><td class="px-4 py-3">K+CK ending</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">KAYAKS</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Plural adds 1 pt</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">KICK</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">4</td><td class="px-4 py-3">K(5)+CK(8) double K</td></tr>
