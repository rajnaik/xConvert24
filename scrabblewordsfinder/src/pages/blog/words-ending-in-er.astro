            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">WHACKER</td><td class="px-4 py-3 text-blue-400">19</td><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-gray-400">One who whacks</td></tr>
