            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">BOXER</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-gray-400">A fighter; a dog breed</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">MIXER</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-gray-400">A blending device</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">HIKER</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-gray-400">One who hikes</td></tr>
