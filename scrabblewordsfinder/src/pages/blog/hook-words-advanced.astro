import BlogCrossLinks from '../../components/BlogCrossLinks.astro';

const slug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const isPublished = await isBlogPublished(slug);
if (!isPublished) return Astro.redirect('/404');
---

<BlogLayout
  title="Advanced Hook Words — Front Hooks, Back Hooks &amp; Multi-Hook Strategy"
  description="Master advanced hook word strategy in Scrabble. Front hooks, back hooks, multi-hooking, and defensive hook blocking. Free Scrabble guide. Try it free."
  keywords="hook words scrabble advanced, front hook scrabble, back hook strategy, multi-hook plays, scrabble hook list, hook words competitive"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Advanced Hook Words — Front Hooks, Back Hooks & Multi-Hook Strategy",
    "description": "Master advanced hook word strategy in Scrabble. Front hooks, back hooks, multi-hooking, and defensive hook blocking.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "logo": { "@type": "ImageObject", "url": "https://www.scrabblewordsfinder.com/web-app-manifest-512x512.png" } },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/hook-words-advanced/" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is a hook word in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "A hook word is formed by adding a single letter to the front or back of an existing word on the board. For example, adding C to HEAT makes CHEAT (front hook), or adding S to PLANT makes PLANTS (back hook). Hooks let you score for both the new letter and the perpendicular word you play through that position." } },
      { "@type": "Question", "name": "What are the best front hooks to memorise?", "acceptedAnswer": { "@type": "Answer", "text": "The most valuable front hooks use uncommon prefixes: C+LOSE=CLOSE, S+LAUGHTER=SLAUGHTER, T+RAINING=TRAINING, B+RANCH=BRANCH, G+RAFT=GRAFT. Focus on hooks that create non-obvious words — opponents often miss defending against front hooks because they don't see the word changing." } },
      { "@type": "Question", "name": "How do I use hooks defensively in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Block hook spots by playing words that cannot be hooked. Words ending in non-hookable letters (V, Q, J) or words where no valid front-hook exists are defensive plays. Also, avoid leaving your own words in hookable positions near premium squares where an opponent could score big." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4">
    <article class="prose dark:prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-amber-500 transition-colors">← Blog</a>
