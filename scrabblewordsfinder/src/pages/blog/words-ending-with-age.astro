      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">BLOCKAGE</td><td class="px-4 py-3 text-amber-600 font-bold">20</td><td class="px-4 py-3">8</td><td class="px-4 py-3">B(3)+K(5)+C(3)</td></tr>
