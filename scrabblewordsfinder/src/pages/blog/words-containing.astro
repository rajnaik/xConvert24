---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing Letter Pairs — Scrabble Guide"
  description="Browse 127 guides to Scrabble words containing specific letter combinations. Find valid words with AA, QU, PH, double letters, and every two-letter pair."
  keywords="words containing, scrabble letter pairs, words with double letters, words containing qu, scrabble word lists, letter combinations scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why are letter-pair word lists useful for Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Knowing words containing specific letter pairs helps you play through existing tiles on the board. If the board has TH already placed, knowing words containing TH lets you build through that combination for high scores." }
      },
      {
        "@type": "Question",
        "name": "What are the hardest letter combinations to use in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Combinations like QU (without U after), II, IU, AJ, and AQ are among the hardest. These pairs appear in few valid words, making them valuable knowledge for competitive players." }
      },
      {
        "@type": "Question",
        "name": "How many two-letter combinations exist in Scrabble words?",
        "acceptedAnswer": { "@type": "Answer", "text": "There are hundreds of valid two-letter combinations (bigrams) in the SOWPODS dictionary. Our guides cover the most strategically useful pairs organized by starting letter, double letters, and common digraphs." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Words Containing</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">Words Containing Letter Pairs</h1>
    <p class="text-lg text-gray-300 mb-6">
      127 guides covering every strategically useful letter combination in Scrabble. Whether you need words with
      double letters, rare bigrams like QU or PH, or common pairs like TH and SH — find them all here.
