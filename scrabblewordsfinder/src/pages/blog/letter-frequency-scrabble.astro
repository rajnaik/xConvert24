            <tr class="bg-gray-900"><td class="px-3 py-2 text-white font-mono">G</td><td class="px-3 py-2 text-gray-300">3</td><td class="px-3 py-2 text-gray-300">2</td><td class="px-3 py-2 text-white font-mono">T</td><td class="px-3 py-2 text-gray-300">6</td><td class="px-3 py-2 text-gray-300">1</td></tr>
