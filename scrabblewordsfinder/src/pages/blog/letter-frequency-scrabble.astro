  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Letter Frequency in Scrabble — Tile Distribution Guide","description":"Complete guide to letter frequency and tile distribution in Scrabble. Learn how many of each letter exist, their point values, and how frequency affects strategy.","datePublished":"2026-06-14","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/letter-frequency-scrabble"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the most common letter in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"The letter E is the most common tile in Scrabble with 12 tiles in the standard English set. This mirrors English language frequency where E appears in roughly 13% of all words. The high count means E tiles are easy to draw but worth only 1 point each."}},{"@type":"Question","name":"How many tiles are in a standard Scrabble game?","acceptedAnswer":{"@type":"Answer","text":"A standard English Scrabble game contains exactly 100 tiles: 98 letter tiles and 2 blank tiles. The letter tiles are distributed based on how frequently each letter appears in English, with common letters like E (12 tiles) having more copies than rare letters like Z (1 tile)."}},{"@type":"Question","name":"Why does knowing tile frequency matter for Scrabble strategy?","acceptedAnswer":{"@type":"Answer","text":"Knowing tile frequency helps with tile tracking (knowing what's left in the bag), rack balancing (understanding which letters you're likely to draw), and defensive play (predicting what opponents might have). Expert players memorize the full distribution to make informed decisions throughout the game."}}]})} />
