          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-3 py-2 text-white font-mono">A</td><td class="px-3 py-2 text-gray-300">9</td><td class="px-3 py-2 text-gray-300">1</td><td class="px-3 py-2 text-white font-mono">N</td><td class="px-3 py-2 text-gray-300">6</td><td class="px-3 py-2 text-gray-300">1</td></tr>
