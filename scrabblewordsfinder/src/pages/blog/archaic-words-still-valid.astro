---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Archaic Words Still Valid in Scrabble"
  description="Old English words that remain in the Scrabble dictionary. THOU, DOTH, HATH and other useful archaisms."
  keywords="scrabble, archaic, words, still, valid"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Archaic Words Still Valid in Scrabble",
    "description": "Old English words that remain in the Scrabble dictionary. THOU, DOTH, HATH and other useful archaisms.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/archaic-words-still-valid" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What archaic words are still valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Words like THOU (7 pts), DOTH (8 pts), HATH (10 pts), YE (5 pts), THEE (7 pts), and WHENCE (14 pts) remain valid in both SOWPODS and TWL dictionaries despite being obsolete in modern English." }
      },
      {
        "@type": "Question",
        "name": "Why are archaic words allowed in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Scrabble dictionaries include all words that have appeared in standard English dictionaries, regardless of current usage. Once a word enters the official word list, it stays unless actively removed during periodic reviews." }
      },
      {
        "@type": "Question",
        "name": "What are the highest-scoring archaic words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "FORSOOTH scores 14 points, WHENCE scores 14 points, PRITHEE scores 12 points, and METHINKS scores 17 points. Many archaic words use common tiles making them reliable scoring options." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Archaic Words Still Valid in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Old English words that remain in the Scrabble dictionary. THOU, DOTH, HATH and other useful archaisms.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
