---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Only in TWL (Not SOWPODS)"
  description="Words valid in North American Scrabble but not international. TWL-exclusive entries."
  keywords="scrabble, words, only, in, twl"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Only in TWL (Not SOWPODS)",
    "description": "Words valid in North American Scrabble but not international. TWL-exclusive entries.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-only-in-twl" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are there words valid in TWL but not SOWPODS?",
        "acceptedAnswer": { "@type": "Answer", "text": "Very few. SOWPODS is a superset that includes virtually all TWL words. A small number of words removed from Collins in recent editions may still appear in TWL if NASPA has not also removed them. In practice, almost every TWL word is also in SOWPODS." }
      },
      {
        "@type": "Question",
        "name": "What is the TWL dictionary in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "TWL (Tournament Word List) is the official North American Scrabble dictionary maintained by NASPA. Currently TWL06, it contains approximately 190,000 valid words. It is used in all sanctioned North American tournaments and most online platforms for NA players." }
      },
      {
        "@type": "Question",
        "name": "How does TWL differ from SOWPODS for competitive play?",
        "acceptedAnswer": { "@type": "Answer", "text": "TWL has ~90,000 fewer words than SOWPODS, making the game slightly more restrictive in North America. Key missing words include many British spellings, obscure international English terms, and some 2-letter words (CH, ZO, GU). Strategy differs because fewer parallel play options exist." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Only in TWL (Not SOWPODS)</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Words valid in North American Scrabble but not international. TWL-exclusive entries.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
