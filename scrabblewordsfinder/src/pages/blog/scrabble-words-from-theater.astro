      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">CURTAIN</span><span class="text-green-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PROMPT</span><span class="text-green-400 text-xs">12pts</span></span>
