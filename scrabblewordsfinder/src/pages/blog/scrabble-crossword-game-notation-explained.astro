    "mainEntity": [
      { "@type": "Question", "name": "What is Crossword Game Notation?", "acceptedAnswer": { "@type": "Answer", "text": "Crossword Game Notation (CGN) is the standard format for recording Scrabble games move by move. It uses a coordinate system (columns A-O, rows 1-15) plus direction indicators to specify exactly where each word was placed on the board, along with the score for each turn." } },
      { "@type": "Question", "name": "How do you read Scrabble board coordinates?", "acceptedAnswer": { "@type": "Answer", "text": "Columns are labeled A through O (left to right) and rows are numbered 1 through 15 (top to bottom). A play written as '8G' means row 8, column G. The letter before the number indicates a vertical (down) play; the number before the letter indicates a horizontal (across) play." } },
