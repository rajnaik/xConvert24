---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AF — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AF with scores, definitions, and strategic tips. Find AF words for your next winning play."
  keywords="scrabble words containing af, af words scrabble, words with af, scrabble af word list, af scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AF — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AF with scores, definitions, and strategic tips. Find AF words for your next winning play.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-af" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the highest-scoring Scrabble words containing AF?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top AF words include SCAFFOLDING (19 pts), HALFWAY (19 pts), CHAFF (16 pts), GIRAFFE (14 pts), and CRAFT (10 pts). The F tile is worth 4 points, making AF words consistently above-average scorers." }
      },
      {
        "@type": "Question",
        "name": "How many valid Scrabble words contain AF?",
        "acceptedAnswer": { "@type": "Answer", "text": "Around 400 valid Scrabble words contain AF. The pair appears in common words like AFTER, SAFE, CRAFT, STAFF, and DRAFT. The F tile (4 pts) adds scoring weight to every AF word." }
      },
      {
        "@type": "Question",
        "name": "What short AF words work well in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Key short AF words include AFT (6 pts), OAF (6 pts), DAFT (8 pts), RAFT (7 pts), WAFT (10 pts), CAFÉ (9 pts), and SAFE (7 pts). These fit tight board positions while delivering solid scores thanks to the 4-point F." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AF — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        The AF pair benefits from the F tile being worth 4 points, giving every AF word a natural scoring boost. From short plays like AFT and OAF to longer words like CRAFT and GIRAFFE, AF is a reliable scoring combination. The pair appears in about 400 valid words and works well in both offensive and defensive positions.
      </p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AF Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">CHAFF</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">Husks of grain</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">GIRAFFE</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A tall African animal</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">SCAFFOLD</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A temporary platform</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">STAFF</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A group of workers</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">CRAFT</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A skilled activity</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">WAFT</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">To carry gently</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">DRAFT</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">A preliminary version</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">DAFT</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">Silly or foolish</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">SAFE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">Free from danger</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">RAFT</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">A flat floating platform</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">AFT</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">Toward the rear</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">~400</p><p class="text-xs text-gray-400">Valid AF words</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">The -AFT Ending Pattern</h2>

      <p>The -AFT ending creates a family of compact, high-scoring words. With F worth 4 points and T worth 1, the base -AFT scores 5 before you even add the leading consonant.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">AFT</span><span class="text-blue-400 text-xs">6 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">DAFT</span><span class="text-blue-400 text-xs">8 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">RAFT</span><span class="text-blue-400 text-xs">7 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">WAFT</span><span class="text-blue-400 text-xs">10 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">CRAFT</span><span class="text-blue-400 text-xs">10 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">DRAFT</span><span class="text-blue-400 text-xs">9 pts</span>
        </span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AF words benefit from the <span class="text-white font-medium">4-point F tile</span> making every play score above average. The -AFT ending (DAFT, RAFT, WAFT, CRAFT, DRAFT) is a reliable pattern that delivers 7-10 points in compact words. Place the F on a double-letter square for maximum impact.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span>
          </a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span>
          </a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span>
          </a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AF word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
