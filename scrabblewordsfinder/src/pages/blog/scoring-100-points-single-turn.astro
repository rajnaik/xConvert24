      { "@type": "Question", "name": "What is the highest possible single-turn score in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "The theoretical maximum is 1778 points for OXYPHENBUTAZONE across two triple word scores with optimal crosswords. In actual tournament play, the highest recorded single turn is around 365 points." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4">
