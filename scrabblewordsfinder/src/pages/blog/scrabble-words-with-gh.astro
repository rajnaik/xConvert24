  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With GH — Silent & Sounding Digraph Guide","description":"Master GH words in Scrabble with scoring breakdowns and strategic placement tips.","datePublished":"2026-06-30",
    "dateModified": "2026-06-24","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-gh"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best GH words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top GH words include KNIGHT (14pts), FREIGHT (14pts), GHASTLY (14pts), THROUGH (13pts), and GHOUL (9pts). GH words benefit from G=2 and H=4 totalling 6 points from the digraph alone."}},{"@type":"Question","name":"Is GH silent in all Scrabble words?","acceptedAnswer":{"@type":"Answer","text":"No — GH has two pronunciations in valid Scrabble words. It's silent in words like KNIGHT, THOUGHT, and FREIGHT. It sounds like a hard G in GHOST, GHEE, and GHOUL. Both types are valid and score well."}},{"@type":"Question","name":"How many GH words are in the Scrabble dictionary?","acceptedAnswer":{"@type":"Answer","text":"There are hundreds of GH words in SOWPODS. Common categories include -IGHT words (LIGHT, MIGHT, FIGHT), -OUGH words (THOUGH, DOUGH), and GH- starters (GHOST, GHEE, GHAT). Learning these patterns covers most scenarios."}}]})} />
  <div class="max-w-3xl mx-auto px-4 pt-4 pb-12">
    <article class="prose prose-invert prose-gray max-w-none">
