>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Sports Words Valid in Scrabble — Game Terminology",
    "description": "Discover 18 sports words valid in Scrabble with point values and strategic tips for playing athletic terminology.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/sports-words-scrabble" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are sports team names valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Proper nouns like team names (Lakers, Arsenal, Yankees) are never valid in Scrabble. However, generic sport terms and game terminology like BOGEY, WICKET, and SCRUM are perfectly valid because they are common English words found in the dictionary." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring sports word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "KAYAK scores 16 points (K5+A1+Y4+A1+K5) thanks to its two K tiles worth 5 points each. WICKET scores 15 points (W4+I1+C3+K5+E1+T1) as the second highest. Both use premium consonants that multiply well on bonus squares." }
      },
      {
        "@type": "Question",
        "name": "Is JOUST a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes! JOUST is valid in both TWL and SOWPODS dictionaries. It scores 12 points (J8+O1+U1+S1+T1) with the J tile contributing 8 points alone. It's one of the best J words for mid-game plays when the board is tight." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Sports</span>
