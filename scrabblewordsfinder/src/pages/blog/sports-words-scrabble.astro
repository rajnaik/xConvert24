          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">KAYAK</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">K5+A1+Y4+A1+K5</td><td class="px-4 py-3 text-gray-400">Paddling</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">WICKET</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">W4+I1+C3+K5+E1+T1</td><td class="px-4 py-3 text-gray-400">Cricket</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">VOLLEY</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">V4+O1+L1+L1+E1+Y4</td><td class="px-4 py-3 text-gray-400">Tennis</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">BUNKER</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">B3+U1+N1+K5+E1+R1</td><td class="px-4 py-3 text-gray-400">Golf</td></tr>
