            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">CRAWL</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">C3+R1+A1+W4+L1</td><td class="px-4 py-3 text-gray-400">Swimming</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">PIVOT</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">P3+I1+V4+O1+T1</td><td class="px-4 py-3 text-gray-400">Basketball</td></tr>
