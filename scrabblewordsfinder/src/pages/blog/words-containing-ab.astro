---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AB — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AB with scores, definitions, and strategic tips. Find AB words for your next winning play."
  keywords="scrabble words containing ab, ab words scrabble, words with ab, scrabble ab word list, ab scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AB — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AB with scores, definitions, and strategic tips. Find AB words for your next winning play.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-ab" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the highest-scoring Scrabble words containing AB?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top AB words include SQUAB (16 pts), CABBAGE (14 pts), TAXICAB (18 pts), KABOB (13 pts), and RABBLE (10 pts). The AB pair is extremely common and appears in hundreds of valid Scrabble words across all lengths." }
      },
      {
        "@type": "Question",
        "name": "How common is the AB letter pair in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "AB is one of the most common letter pairs in English. Over 800 valid Scrabble words contain AB, making it one of the easiest pairs to play. Words like CAB, TAB, GRAB, and CABLE appear frequently in games." }
      },
      {
        "@type": "Question",
        "name": "What short AB words are useful in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Key short AB words include CAB (7 pts), TAB (5 pts), DAB (6 pts), FAB (8 pts), GAB (6 pts), JAB (12 pts), LAB (5 pts), and NAB (5 pts). These 3-letter words fit tight board positions and set up scoring opportunities." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AB — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        The AB letter pair is one of the most versatile combinations in Scrabble. Appearing in hundreds of common English words, AB gives you enormous flexibility whether it starts a word (ABLE, ABOUT), sits in the middle (CABLE, RABBIT), or ends it (CAB, STAB). Knowing the top-scoring AB words ensures you maximize points from this frequent pairing.
      </p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AB Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">TAXICAB</td><td class="px-4 py-3 text-blue-400">18</td><td class="px-4 py-3 text-gray-400">A hired car</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">SQUAB</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A young pigeon</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">CABBAGE</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A leafy vegetable</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">FABRIC</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">Woven material</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">KABOB</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">Skewered meat</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">JAB</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A quick punch</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">ABSORB</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">To soak up</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">FABLE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A moral story</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">CABLE</td><td class="px-4 py-3 text-blue-400">9</td><td class="px-4 py-3 text-gray-400">A thick rope or wire</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">STABLE</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">A horse shelter</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">GRAB</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">To seize suddenly</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">800+</p><p class="text-xs text-gray-400">Valid AB words</p></div>
          <div><p class="text-xl font-bold text-amber-400">9 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Very Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Quick AB Words for Tight Spots</h2>

      <p>These short AB words fit almost anywhere on the board and are perfect for parallel plays or setting up your next big move.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">CAB</span><span class="text-blue-400 text-xs">7 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">JAB</span><span class="text-blue-400 text-xs">12 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">TAB</span><span class="text-blue-400 text-xs">5 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">DAB</span><span class="text-blue-400 text-xs">6 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">FAB</span><span class="text-blue-400 text-xs">8 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">GAB</span><span class="text-blue-400 text-xs">6 pts</span>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
          <span class="text-white font-bold">NAB</span><span class="text-blue-400 text-xs">5 pts</span>
        </span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AB is one of the <span class="text-white font-medium">most playable letter pairs</span> in Scrabble. With 800+ valid words, you'll almost always find a play. Focus on high-value short words like JAB (12 pts) and FAB (8 pts) for quick scores, and look for premium square placement with longer words like FABRIC and TAXICAB.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span>
          </a>
          <a href="/blog/words-with-multiple-vowels" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span>
          </a>
          <a href="/blog/four-letter-words-every-player-should-know" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span>
          </a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AB word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
