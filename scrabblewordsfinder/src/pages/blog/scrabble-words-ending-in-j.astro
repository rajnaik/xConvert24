  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words Ending in J — The Rarest Category","description":"Words ending in J are extremely rare in Scrabble. HAJ (13pts), RAJ (10pts), TAJ (10pts) are the key plays. Why J rarely ends English words.","datePublished":"2026-06-29",
    "dateModified": "2026-06-18","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-ending-in-j"}})} />
