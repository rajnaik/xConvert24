      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">THWACK</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">6</td><td class="px-4 py-3">W(4) + K(5) boost</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">PYTHON</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Y(4) + P(3) value</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">RHYTHM</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">6</td><td class="px-4 py-3">No vowels needed</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">GROWTH</td><td class="px-4 py-3 text-amber-600 font-bold">13</td><td class="px-4 py-3">6</td><td class="px-4 py-3">W(4) + common tiles</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">THRASH</td><td class="px-4 py-3 text-amber-600 font-bold">12</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Double H letter value</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WORTH</td><td class="px-4 py-3 text-amber-600 font-bold">11</td><td class="px-4 py-3">5</td><td class="px-4 py-3">W(4) makes it punch</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WARMTH</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">6</td><td class="px-4 py-3">W(4) + M(3)</td></tr>
