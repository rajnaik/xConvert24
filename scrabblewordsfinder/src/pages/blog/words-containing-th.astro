<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Words Containing TH — The Most Common English Digraph",
  "datePublished": "2026-06-15",
  "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" },
  "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com/" }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are the highest-scoring TH words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "PYTHON (14 pts), THWACK (18 pts), GROWTH (13 pts), and RHYTHM (14 pts) are top TH scorers. TH words gain value when combined with premium consonants like W, K, and Y." }},
    { "@type": "Question", "name": "Why is TH so common in English?", "acceptedAnswer": { "@type": "Answer", "text": "TH represents two of English's most frequent sounds: the voiced /ð/ (THE, THIS) and voiceless /θ/ (THINK, THROW). It appears in the 3 most common English words: THE, THAT, THIS." }},
    { "@type": "Question", "name": "What 2-3 letter TH words are valid in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "THE (6 pts) and THO (6 pts, archaic for 'though') are the shortest valid TH-start words. ETH (6 pts, Old English letter) is a handy 3-letter TH-end word." }}
  ]
})} />

