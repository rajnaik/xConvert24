    </tbody>
  </table>
</div>

<h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">TH by Position</h2>

<div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
