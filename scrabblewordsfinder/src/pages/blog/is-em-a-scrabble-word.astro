import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Is EM a Scrabble Word? Yes — Valid in TWL & SOWPODS (4 Points)"
  description="EM is a valid Scrabble word in both TWL and SOWPODS, scoring 4 points (E=1, M=3). It's a typographic unit of measurement (em-dash, em-space). Learn strategy for playing EM."
  keywords="is em a scrabble word, em scrabble, em valid scrabble, em points scrabble, em typographic unit, two letter words scrabble em, em vs en scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Article", "headline": "Is EM a Scrabble Word? Yes — Valid in TWL & SOWPODS (4 Points)", "description": "EM is a valid Scrabble word in both TWL and SOWPODS, scoring 4 points. It's a typographic unit of measurement.", "datePublished": "2026-06-23", "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" }, "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" }, "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/is-em-a-scrabble-word" } })} />
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [ { "@type": "Question", "name": "Is EM a valid Scrabble word?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — EM is valid in both TWL (Tournament Word List, North America) and SOWPODS (International/Collins). It scores 4 points (E=1, M=3) and refers to a typographic unit of measurement equal to the width of the letter M in a given typeface. It's also the basis for em-dash and em-space." } }, { "@type": "Question", "name": "How many points is EM worth in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "EM scores 4 points in Scrabble (E=1, M=3). The M tile contributes 3 of those points. On a Double Letter square for M, EM scores 7 points. On a Triple Letter for M, it scores 10 points. Compare this to EN which only scores 2 points (E=1, N=1)." } }, { "@type": "Question", "name": "What is the difference between EM and EN in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Both EM and EN are valid typographic units and Scrabble words. EM scores 4 points (E=1, M=3) while EN scores only 2 points (E=1, N=1). EM is the stronger play — it scores double what EN does. Both refer to measurement units in typography: an em is the width of M, an en is the width of N (half an em)." } } ] })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/two-letter-words/" class="hover:text-blue-400 transition-colors text-gray-300">Two-Letter Words</a>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Is EM a Scrabble Word?</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-23">June 23, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Yes — EM is a valid Scrabble word in both TWL and SOWPODS. It scores 4 points and refers to a typographic unit of measurement — the width of the capital letter M in a given font. You know it from em-dashes (—) and em-spaces. At 4 points for just 2 tiles, EM is one of the stronger two-letter words thanks to M's 3-point value.</p>

      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-green-500/50 bg-gradient-to-r from-green-950/30 to-emerald-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-green-500/70">✓ VALID</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">EM</p>
        <p class="text-sm text-green-300 font-semibold mb-3">4 points · E=1, M=3 · Noun: typographic unit</p>
        <p class="text-sm text-gray-300 leading-relaxed">Valid in both TWL (North American) and SOWPODS (International). A unit of measurement in typography equal to the width of the letter M. The basis for em-dashes and em-spaces in printed text.</p>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-green-500/30 bg-green-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-green-400">4</p><p class="text-xs text-gray-400">Points</p></div>
          <div><p class="text-xl font-bold text-green-400">TWL ✓</p><p class="text-xs text-gray-400">North America</p></div>
          <div><p class="text-xl font-bold text-green-400">SOWPODS ✓</p><p class="text-xs text-gray-400">International</p></div>
          <div><p class="text-xl font-bold text-green-400">Noun</p><p class="text-xs text-gray-400">Typography</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">EM vs EN: Typographic Siblings</h2>
      <p>Both EM and EN are valid Scrabble words from the world of typography. Here's how they compare:</p>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">EM — 4 points</p>
          <p class="text-xs text-gray-400">E=1, M=3. Width of letter M. Used in em-dash (—) and em-space. The stronger play at double EN's score.</p>
        </div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">EN — 2 points</p>
          <p class="text-xs text-gray-400">E=1, N=1. Width of letter N (half an em). Used in en-dash (–). Scores half of EM but still valid.</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">EM scores <span class="text-white font-medium">exactly double</span> what EN scores (4 vs 2). When you have both E+M and E+N available, EM is always the stronger 2-letter play. The M tile's 3-point value makes EM one of the top-scoring two-letter words in the game.</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy: When to Play EM</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Parallel plays:</span> Place EM parallel to an existing word to form crosswords. E and M both connect well — E crosses with almost everything, M forms MA, ME, MI, MO, MU, MY.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">M on premium squares:</span> M is worth 3 points — on a Double Letter that's 6 from one tile, making EM score 7 total. On Triple Letter, M gives 9, and EM scores 10 for just 2 tiles.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Preserve M for bigger plays:</span> Before playing EM, check if M could form a higher-scoring word (MATE, MAKE, MAZE). EM is a safety play when better options don't exist.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Hook potential:</span> EM can be extended to EME, EMS, or EMU. Front hooks include HEM, FEM, GEM, REM. Multiple directions for future scoring.</p>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">EM Premium Square Scoring</h2>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">4</p><p class="text-xs text-gray-400">Base Score</p></div>
          <div><p class="text-xl font-bold text-amber-400">7</p><p class="text-xs text-gray-400">M on DL</p></div>
          <div><p class="text-xl font-bold text-amber-400">10</p><p class="text-xs text-gray-400">M on TL</p></div>
          <div><p class="text-xl font-bold text-amber-400">8</p><p class="text-xs text-gray-400">EM on DW</p></div>
        </div>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/is-nu-a-scrabble-word/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Is NU a Scrabble Word? Greek Letter Validity</span></a>
          <a href="/blog/is-li-a-scrabble-word/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Is LI a Scrabble Word? Chinese Distance Unit</span></a>
          <a href="/blog/best-two-letter-words-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Two-Letter Words in Scrabble: Complete Guide</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-50 to-cyan-50 dark:from-blue-900/20 dark:to-cyan-900/20 border border-blue-200 dark:border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-800 dark:text-blue-300 font-medium">🔤 Check any word instantly — free Scrabble solver, no sign-up required</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
