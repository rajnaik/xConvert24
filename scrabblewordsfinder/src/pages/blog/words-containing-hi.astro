            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">ACHIEVE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">To accomplish</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">HIGHWAY</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">A main road</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">ARCHIVE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">A collection of records</td></tr>
