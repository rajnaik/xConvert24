            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">MACHINE</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">A mechanical device</td></tr>
