            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">HIT</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">To strike</td></tr>
