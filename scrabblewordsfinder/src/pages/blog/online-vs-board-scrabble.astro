          <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3">Word validation</td><td class="px-4 py-3">Instant — invalid plays rejected</td><td class="px-4 py-3">Challenge system — risk a turn</td></tr>
          <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3">Scoring</td><td class="px-4 py-3">Automatic</td><td class="px-4 py-3">Manual (both verify)</td></tr>
