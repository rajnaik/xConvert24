---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words Ending in -GY — Energy-Packed Suffix Plays"
  description="Scrabble words ending in -GY with point values. SYNERGY 11pts, CLERGY 12pts, ENERGY 10pts, FOGGY 13pts. Build vocabulary around the -GY suffix for competitive play."
  keywords="scrabble words ending in gy, energy scrabble points, synergy scrabble, clergy scrabble word, gy suffix words, foggy scrabble score"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words Ending in -GY — Energy-Packed Suffix Plays","description":"Scrabble words ending in -GY with point values. SYNERGY 11pts, CLERGY 12pts, ENERGY 10pts, FOGGY 13pts.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-ending-in-gy"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many points is SYNERGY in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SYNERGY scores 11 points (S=1, Y=4, N=1, E=1, R=1, G=2, Y=4). It's a 7-letter word making it a bingo candidate worth 61 points if you play all tiles from your rack."}},{"@type":"Question","name":"Is FOGGY a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! FOGGY scores 13 points (F=4, O=1, G=2, G=2, Y=4) and is valid in both TWL and SOWPODS. The double G and F tile make it a solid mid-range play at just 5 letters."}},{"@type":"Question","name":"What high-scoring words end in -GY?","acceptedAnswer":{"@type":"Answer","text":"Top -GY words include FOGGY (13pts), CLERGY (12pts), SYNERGY (11pts), ENERGY (10pts), and GROGGY (11pts). The Y tile at the end always adds 4 points, and many -GY words contain F, K, or double G for extra value."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words Ending in -GY — Energy-Packed Suffix Plays</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">The -GY ending combines two tiles worth 6 points together (G=2, Y=4). While neither is a premium tile on its own, the combination appears in dozens of common English words — many of which carry additional scoring power from double letters or consonant clusters.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">FOGGY (Top)</p></div>
          <div><p class="text-xl font-bold text-amber-400">12 pts</p><p class="text-xs text-gray-400">CLERGY</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">SYNERGY</p></div>
          <div><p class="text-xl font-bold text-amber-400">10 pts</p><p class="text-xs text-gray-400">ENERGY</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Best -GY Words by Score</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">FOGGY — 13 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">F=4, O=1, G=2, G=2, Y=4 · 5 letters · Double G + F power</p>
        <p class="text-sm text-gray-300 leading-relaxed">FOGGY packs 13 points into just 5 letters (2.6 per tile). The F tile contributes 4 points, both G tiles add 4 more, and Y finishes with another 4. Short, efficient, and uses tiles that can be hard to offload otherwise.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⛪ CLERGY</p><p class="text-xs text-gray-400">12 pts · C=3, L=1, E=1, R=1, G=2, Y=4 · 6 common letters</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🍺 GROGGY</p><p class="text-xs text-gray-400">11 pts · G=2, R=1, O=1, G=2, G=2, Y=4 · Triple G play</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">⚡ SYNERGY</p><p class="text-xs text-gray-400">11 pts · S=1, Y=4, N=1, E=1, R=1, G=2, Y=4 · Bingo word</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🔋 ENERGY</p><p class="text-xs text-gray-400">10 pts · E=1, N=1, E=1, R=1, G=2, Y=4 · All common tiles</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More -GY Words to Know</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">EDGY</span><span class="text-green-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">DINGY</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">MANGY</span><span class="text-green-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">BUGGY</span><span class="text-green-400 text-xs">12pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">TANGY</span><span class="text-green-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PUDGY</span><span class="text-green-400 text-xs">12pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">SYNERGY is your bingo play:</span> At 7 letters using all common tiles (S, Y, N, E, R, G, Y), SYNERGY gives you 61 points with the bingo bonus. The double Y is unusual but Y appears once in the tile bag — use a blank for the second.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Double-G words clear dead tiles:</span> FOGGY, GROGGY, BUGGY, and SOGGY all use multiple G tiles. G is only worth 2 points and can clog your rack — these -GY words turn that liability into 11-13 point plays.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Short -GY words for tight boards:</span> EDGY (4 letters, 9pts) and ORGY (4 letters, 8pts) fit in cramped positions. When the board is locked down, these compact plays still deliver decent scores.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">The -GY suffix is a <span class="text-white font-medium">G-tile escape valve</span>. When your rack has two or three G tiles dragging you down, scan for -GY words first — FOGGY, GROGGY, MUGGY, SOGGY all turn that dead weight into respectable scores.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-ending-in-ing/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words Ending in -ING</span></a>
          <a href="/blog/scrabble-words-ending-in-fy/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words Ending in -FY</span></a>
          <a href="/blog/scrabble-words-with-double-g/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words with Double G</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid -GY word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
