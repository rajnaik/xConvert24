            <tr class="bg-gray-900"><td class="px-4 py-3 text-amber-400 font-bold">7</td><td class="px-4 py-3 font-mono text-blue-400">STAINED</td><td class="px-4 py-3 text-gray-300">S T A I N E D</td><td class="px-4 py-3 text-gray-400">{"SATINE +D"}</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-amber-400 font-bold">8</td><td class="px-4 py-3 font-mono text-blue-400">TRAINED</td><td class="px-4 py-3 text-gray-300">T R A I N E D</td><td class="px-4 py-3 text-gray-400">{"RETINA +D"}</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-amber-400 font-bold">9</td><td class="px-4 py-3 font-mono text-blue-400">DETRAIN</td><td class="px-4 py-3 text-gray-300">D E T R A I N</td><td class="px-4 py-3 text-gray-400">{"RETINA +D"}</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-amber-400 font-bold">10</td><td class="px-4 py-3 font-mono text-blue-400">ELASTIN</td><td class="px-4 py-3 text-gray-300">E L A S T I N</td><td class="px-4 py-3 text-gray-400">{"SATINE +L"}</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-amber-400 font-bold">11</td><td class="px-4 py-3 font-mono text-blue-400">SALIENT</td><td class="px-4 py-3 text-gray-300">S A L I E N T</td><td class="px-4 py-3 text-gray-400">{"SALINE +T"}</td></tr>
