            <tr class="bg-gray-900"><td class="px-4 py-3 text-amber-400 font-bold">3</td><td class="px-4 py-3 font-mono text-blue-400">ANTSIER</td><td class="px-4 py-3 text-gray-300">A N T S I E R</td><td class="px-4 py-3 text-gray-400">{"SATINE +R"}</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-amber-400 font-bold">4</td><td class="px-4 py-3 font-mono text-blue-400">SARDINE</td><td class="px-4 py-3 text-gray-300">S A R D I N E</td><td class="px-4 py-3 text-gray-400">{"SALINE +D/R"}</td></tr>
