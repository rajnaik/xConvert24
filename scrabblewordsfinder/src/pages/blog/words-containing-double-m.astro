      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">FLAMMABLE</td><td class="px-4 py-3 text-amber-600 font-bold">18</td><td class="px-4 py-3">9</td><td class="px-4 py-3">F(4) + B(3) + bingo</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">MAMMOTH</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">7</td><td class="px-4 py-3">H(4) + double MM</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">SWIMMING</td><td class="px-4 py-3 text-amber-600 font-bold">16</td><td class="px-4 py-3">8</td><td class="px-4 py-3">W(4) + bingo territory</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">COMMAND</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">7</td><td class="px-4 py-3">C(3) + D(2) + bingo</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">SHIMMER</td><td class="px-4 py-3 text-amber-600 font-bold">14</td><td class="px-4 py-3">7</td><td class="px-4 py-3">H(4) + bingo candidate</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">STAMMER</td><td class="px-4 py-3 text-amber-600 font-bold">11</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Common tiles, bingo</td></tr>
