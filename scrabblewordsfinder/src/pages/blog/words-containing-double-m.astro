  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">COMMA</span><span class="text-blue-400 text-xs">11 pts</span></span>
