---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words With Double D — ADDED, ODDITY, WADDING & More"
  description="Best double-D words for Scrabble. ADDED (7pts), ODDITY (10pts), WADDING (13pts), SHREDDED (13pts). DD pattern strategy for rack management. Free word finder."
  keywords="scrabble double d words, added scrabble, oddity scrabble, wadding scrabble, shredded scrabble, dd words scrabble, double d strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Article",
    "headline": "Scrabble Words With Double D — ADDED, ODDITY, WADDING & More",
    "description": "Best double-D Scrabble words with scores. DD pattern strategy for efficient rack clearing.",
    "datePublished": "2026-06-30",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-words-with-double-d" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the best double-D Scrabble words?", "acceptedAnswer": { "@type": "Answer", "text": "WADDING (13pts), SHREDDED (13pts), ODDITY (10pts), and ADDLED (9pts). D=2pts each so DD pairs contribute 4 base points to any word." } },
      { "@type": "Question", "name": "How many D tiles are in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "There are 4 D tiles in a standard Scrabble set, each worth 2 points. Drawing two D tiles is fairly common, making DD word knowledge valuable." } },
      { "@type": "Question", "name": "What short DD words are valid in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "ADD (5pts), ODD (5pts), ADDS (6pts), ODDS (6pts). These are essential rack-clearing plays when you draw duplicate D tiles." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Double D — ADDED, ODDITY, WADDING & More</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>4 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">With 4 D tiles in the bag at 2 points each, drawing a pair of D's is one of the most common duplicate scenarios in Scrabble. Knowing your DD words lets you clear those tiles efficiently while scoring respectably — especially with -DDING endings that connect to bingo opportunities.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">WADDING</p></div>
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">SHREDDED</p></div>
          <div><p class="text-xl font-bold text-amber-400">10 pts</p><p class="text-xs text-gray-400">ODDITY</p></div>
          <div><p class="text-xl font-bold text-amber-400">4</p><p class="text-xs text-gray-400">D tiles in bag</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top Double-D Words</h2>

      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top DD Word</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">PADDOCK — 17 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">P=3, A=1, D=2, D=2, O=1, C=3, K=5 · 7 letters · Bingo eligible</p>
        <p class="text-sm text-gray-300 leading-relaxed">K=5 and P=3 combine with DD=4 for a powerful 17-point base. As a 7-letter word, PADDOCK qualifies for the 50-point bingo bonus — delivering 67 total.</p>
      </div>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🧶 WADDING</p><p class="text-xs text-gray-400">13 pts · 7 letters · W=4+DD · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">📄 SHREDDED</p><p class="text-xs text-gray-400">13 pts · 8 letters · S+H+R+E+DD+E+D · Bingo</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🎲 ODDITY</p><p class="text-xs text-gray-400">10 pts · 6 letters · O+DD+I+T+Y</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🧩 ADDLED</p><p class="text-xs text-gray-400">9 pts · 6 letters · A+DD+L+E+D</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">DD Pattern Strategy</h2>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">-DDING endings:</span> WADDING, PADDING, ADDING, BIDDING, WEDDING — the -ING suffix makes DD words natural bingo candidates at 7+ letters.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">ADD as a hook base:</span> ADD (5pts) extends to ADDED, ADDER, ADDING, ADDS. Plant ADD early and hook it later for additional scoring.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">ODD family plays:</span> ODD (5pts) extends to ODDS, ODDLY, ODDITY, ODDMENT. Each extension uses common tiles for easy rack clearing.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ADD</span><span class="text-blue-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">ODD</span><span class="text-blue-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">MUDDY</span><span class="text-blue-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">DADDY</span><span class="text-blue-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">BUDDY</span><span class="text-blue-400 text-xs">11pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Duplicate Tile Relief</p>
        <p class="text-base text-gray-200">With 4 D tiles in the bag, drawing two or even three is common. Knowing DD words means you <span class="text-white font-medium">never need to exchange</span> — you always have a productive play available.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-double-s/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Double S</span></a>
          <a href="/blog/scrabble-words-with-double-t/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Double T</span></a>
          <a href="/blog/best-words-with-double-letters/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Best Words With Double Letters</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find double-D words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
