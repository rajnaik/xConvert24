---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Only in SOWPODS (Not TWL)"
  description="Scrabble words valid in international play but not North American tournaments. SOWPODS-exclusive words to know."
  keywords="scrabble, words, only, in, sowpods"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Only in SOWPODS (Not TWL)",
    "description": "Scrabble words valid in international play but not North American tournaments. SOWPODS-exclusive words to know.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-only-in-sowpods" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What words are valid in SOWPODS but not TWL?",
        "acceptedAnswer": { "@type": "Answer", "text": "SOWPODS includes thousands of words not in TWL, particularly British English spellings (COLOUR, FAVOUR), Scottish/dialectal terms (BRAE, LOCH), South African English (BRAAI), and Australian slang (ARVO). Notable examples include CH, GU, ZO, and many others." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between SOWPODS and TWL?",
        "acceptedAnswer": { "@type": "Answer", "text": "SOWPODS (Collins Scrabble Words) is the international dictionary with ~280,000 words used outside North America. TWL (Tournament Word List) is the North American dictionary with ~190,000 words. SOWPODS includes all TWL words plus about 90,000 additional entries." }
      },
      {
        "@type": "Question",
        "name": "Should I learn SOWPODS-only words?",
        "acceptedAnswer": { "@type": "Answer", "text": "Only if you play in international tournaments or online against international players. In North American clubs and tournaments, only TWL words are valid. However, knowing SOWPODS words helps if you play on platforms like ISC that default to the international dictionary." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/dictionaries/" class="hover:text-blue-400 transition-colors text-gray-300">Dictionaries</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Only in SOWPODS (Not TWL)</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Scrabble words valid in international play but not North American tournaments. SOWPODS-exclusive words to know.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
