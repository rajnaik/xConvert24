    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/is-po-a-scrabble-word" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is PO a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, PO is valid in both TWL (North American) and SOWPODS (International) Scrabble dictionaries. It scores 4 points (P=3, O=1) and refers to a chamber pot — an archaic term for a portable toilet used before indoor plumbing." }
      },
      {
        "@type": "Question",
        "name": "What does PO mean in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "PO is an informal, archaic English word for a chamber pot — a bowl-shaped container used as a toilet, typically kept under the bed. The term comes from the French 'pot de chambre'. Despite its unusual meaning, PO is fully valid in competitive Scrabble and scores a respectable 4 points." }
      },
      {
        "@type": "Question",
        "name": "How many points is PO worth in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "PO scores 4 points in Scrabble (P=3, O=1). The P tile carries 3 points, making PO one of the higher-scoring 2-letter words. On a Double Letter square, P contributes 6 points alone. PO is stronger than common 2-letter words like IT (2), IS (2), or AN (2)." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/two-letter-words/" class="hover:text-blue-400 transition-colors text-gray-300">Two-Letter Words</a>
