---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Prefix Guides — Scrabble Words by Prefix"
  description="57 guides to Scrabble words organized by prefix. Learn words starting with UN-, RE-, PRE-, DIS-, OVER-, ANTI-, and more common English prefixes."
  keywords="scrabble prefixes, words starting with, prefix words scrabble, un words, re words, pre words, dis words, over words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why are prefixes important in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Prefixes let you extend existing words on the board by adding letters to the front. Playing UN- before DONE creates UNDONE, and RE- before PLAY creates REPLAY. This technique is called front-hooking and is essential for competitive play." }
      },
      {
        "@type": "Question",
        "name": "What are the most useful Scrabble prefixes to memorise?",
        "acceptedAnswer": { "@type": "Answer", "text": "The top prefixes by frequency are RE- (thousands of valid words), UN- (hundreds), PRE-, DIS-, OVER-, OUT-, MIS-, and INTER-. Learning just these eight prefixes unlocks thousands of valid plays." }
      },
      {
        "@type": "Question",
        "name": "Can you add a prefix to any word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No — the resulting word must be in the official dictionary. UNCAT and REDOG are not valid. Always verify with a word checker. Our guides list only confirmed valid prefix words from SOWPODS and TWL dictionaries." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Prefix Guides</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">Prefix Guides</h1>
    <p class="text-lg text-gray-300 mb-6">
      57 guides covering Scrabble words by their prefix or starting letters. From single-letter starts (A-Z) to
      powerful multi-letter prefixes (UN-, RE-, PRE-, DIS-) — extend existing board words for big scores.
    </p>

    <div class="not-prose my-8 p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
      <div class="flex flex-wrap items-center justify-center gap-6 text-center">
        <div><p class="text-2xl font-bold text-emerald-400">57</p><p class="text-xs text-gray-400">Guides</p></div>
        <div><p class="text-2xl font-bold text-emerald-400">26</p><p class="text-xs text-gray-400">A-Z Letters</p></div>
        <div><p class="text-2xl font-bold text-emerald-400">31</p><p class="text-xs text-gray-400">Multi-Letter Prefixes</p></div>
