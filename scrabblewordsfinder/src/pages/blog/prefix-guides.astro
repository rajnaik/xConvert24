---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Prefix Guides — Scrabble Words by Prefix"
  description="57 guides to Scrabble words organized by prefix. Learn words starting with UN-, RE-, PRE-, DIS-, OVER-, ANTI-, and more common English prefixes. Free tool."
  keywords="scrabble prefixes, words starting with, prefix words scrabble, un words, re words, pre words, dis words, over words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Prefix Guides — Scrabble Words by Prefix",
    "description": "57 guides to Scrabble words organized by prefix. Learn words starting with UN-, RE-, PRE-, DIS-, OVER-, ANTI-, and more common English prefixes.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Person", "name": "Raj Naik", "url": "https://www.scrabblewordsfinder.com/about/" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/prefix-guides/" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why are prefixes important in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Prefixes let you extend existing words on the board by adding letters to the front. Playing UN- before DONE creates UNDONE, and RE- before PLAY creates REPLAY. This technique is called front-hooking and is essential for competitive play." }
      },
      {
        "@type": "Question",
        "name": "What are the most useful Scrabble prefixes to memorise?",
        "acceptedAnswer": { "@type": "Answer", "text": "The top prefixes by frequency are RE- (thousands of valid words), UN- (hundreds), PRE-, DIS-, OVER-, OUT-, MIS-, and INTER-. Learning just these eight prefixes unlocks thousands of valid plays." }
      },
      {
        "@type": "Question",
        "name": "Can you add a prefix to any word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No — the resulting word must be in the official dictionary. UNCAT and REDOG are not valid. Always verify with a word checker. Our guides list only confirmed valid prefix words from SOWPODS and TWL dictionaries." }
      }
    ]
  })} />

