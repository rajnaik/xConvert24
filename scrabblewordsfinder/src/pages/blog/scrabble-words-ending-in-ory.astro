---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words Ending in -ORY — HISTORY, FACTORY, VICTORY" description="Master -ORY suffix words: FACTORY (15pts), VICTORY (15pts), HISTORY (13pts). Noun and adjective bingos using the -ORY pattern." keywords="scrabble words ending in ory, factory scrabble, victory scrabble, history scrabble, ory suffix bingo, scrabble noun suffix">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words Ending in -ORY — HISTORY, FACTORY, VICTORY","description":"Master -ORY suffix words: FACTORY (15pts), VICTORY (15pts), HISTORY (13pts). Noun and adjective bingos.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-ending-in-ory"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best -ORY words for Scrabble?","acceptedAnswer":{"@type":"Answer","text":"FACTORY and VICTORY both score 15 points at 7 letters — perfect bingo length. HISTORY scores 13 points. The Y tile (4pts) adds consistent value to all -ORY words."}},{"@type":"Question","name":"Is -ORY good for bingos?","acceptedAnswer":{"@type":"Answer","text":"Yes — many -ORY words are exactly 7 letters (FACTORY, VICTORY, HISTORY), using all your rack tiles for the 50-point bingo bonus. The 3-tile suffix (O+R+Y) leaves 4 tiles for the root."}},{"@type":"Question","name":"What roots combine with -ORY?","acceptedAnswer":{"@type":"Answer","text":"Common roots: FACT(ORY), VICT(ORY), HIST(ORY). Also AUDITORY, SENSORY, PRIORY. Look for roots ending in T or S that naturally extend to -ORY."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words Ending in -ORY — Noun & Adjective Suffix</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>4 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">-ORY is uniquely versatile — it creates both nouns (FACTORY, HISTORY) and adjectives (SENSORY, AUDITORY). FACTORY and VICTORY both score 15 points at exactly 7 letters, making them natural bingo plays. The Y tile contributes 4 points to every -ORY word, and the suffix uses only common tiles.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">15</p><p class="text-xs text-gray-400">Top Score (FACTORY)</p></div>
          <div><p class="text-xl font-bold text-amber-400">7</p><p class="text-xs text-gray-400">Letters (Bingo)</p></div>
          <div><p class="text-xl font-bold text-amber-400">4pts</p><p class="text-xs text-gray-400">Y Tile Value</p></div>
          <div><p class="text-xl font-bold text-amber-400">3</p><p class="text-xs text-gray-400">Suffix Tiles</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top -ORY Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 FACTORY</p><p class="text-xs text-gray-400">15 pts · 7 letters · F(4)+A(1)+C(3)+T(1)+O(1)+R(1)+Y(4)</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 VICTORY</p><p class="text-xs text-gray-400">15 pts · 7 letters · V(4)+I(1)+C(3)+T(1)+O(1)+R(1)+Y(4)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ HISTORY</p><p class="text-xs text-gray-400">13 pts · 7 letters · H(4)+I(1)+S(1)+T(1)+O(1)+R(1)+Y(4)</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ PRIORY</p><p class="text-xs text-gray-400">11 pts · 6 letters · P(3)+R(1)+I(1)+O(1)+R(1)+Y(4)</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">-ORY Strategy Tips</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Y is your scoring anchor:</span> Every -ORY word gets 4 free points from Y. Combined with F(4) in FACTORY or V(4) in VICTORY, you're getting 8+ points from just two consonants.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">7-letter bingo sweet spot:</span> FACTORY, VICTORY, and HISTORY are all exactly 7 tiles — use your entire rack for the 50-point bonus. No board letter needed, just find an open spot.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Dual function suffix:</span> -ORY creates nouns AND adjectives. SENSORY, AUDITORY work as descriptors. FACTORY, HISTORY work as nouns. This doubles your play opportunities.</p></div>
      </div>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">FACTORY</span><span class="text-blue-400 text-xs">15pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">VICTORY</span><span class="text-blue-400 text-xs">15pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">HISTORY</span><span class="text-blue-400 text-xs">13pts</span></span>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">-ORY words are <span class="text-white font-medium">among the most recognisable bingos</span> because they're everyday vocabulary. You don't need obscure roots — FACTORY, VICTORY, and HISTORY are words you already know.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-ending-in-ary/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Ending in -ARY</span></a>
          <a href="/blog/scrabble-words-ending-in-ment/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Ending in -MENT</span></a>
          <a href="/blog/common-bingo-endings/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Common Bingo Endings</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find -ORY words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
