  <script is:inline>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var q = (params.get('q') || '').trim().toLowerCase();
    if (!q) return;

    var banner = document.getElementById('search-banner');
    var display = document.getElementById('search-query-display');
    var cards = document.querySelectorAll('.blog-card');
    var noResults = document.getElementById('no-results');
    var visibleCount = 0;

    banner.classList.remove('hidden');
    display.textContent = decodeURIComponent(params.get('q'));

    cards.forEach(function(card) {
      var title = card.getAttribute('data-title') || '';
      var desc = card.getAttribute('data-desc') || '';
      var href = card.getAttribute('href') || '';
      if (title.includes(q) || desc.includes(q) || href.includes(q)) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Hide category headings with no visible cards
    document.querySelectorAll('#blog-grid h2').forEach(function(h2) {
      var grid = h2.nextElementSibling;
      if (grid) {
        var visible = grid.querySelectorAll('.blog-card:not([style*="display: none"])');
        if (visible.length === 0) {
          h2.style.display = 'none';
          grid.style.display = 'none';
        }
      }
    });

    if (visibleCount === 0) {
      noResults.classList.remove('hidden');
    }
  })();

  // Dynamic article count
  (function() {
    var count = document.querySelectorAll('.blog-card').length;
    var el = document.getElementById('article-count');
    if (el && count > 0) el.textContent = count + ' articles';
  })();
  </script>
