---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Strategy Blog — Free Tips & Word Lists" description="Scrabble strategy articles: tile values, rack management, dictionaries, and competitive play. Level up your game with our free instant word finder." keywords="scrabble blog, scrabble strategy tips, two letter scrabble words, scrabble tile values, free scrabble word finder, scrabble bingo words">

  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">
      <span class="text-blue-400">Scrabble</span> Blog
    </h1>
    <p class="text-gray-400 mb-10">Strategy, history, and tips to dominate the board.</p>

    <div class="grid gap-6 sm:grid-cols-2">
      <a href="/blog/scrabble-history-origins-great-depression" class="group rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-all">
        <div class="text-2xl mb-3">🏛️</div>
        <h2 class="text-lg font-semibold text-gray-200 group-hover:text-blue-400 transition-colors mb-2">The History of Scrabble</h2>
        <p class="text-sm text-gray-400">From the Great Depression to Global Phenomenon — how an unemployed architect created one of history's best-selling board games.</p>
        <div class="mt-4 text-xs text-gray-500">June 9, 2026 · 5 min read</div>
      </a>

      <a href="/blog/scrabble-tile-strategy-letters-scoring" class="group rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-all">
        <div class="text-2xl mb-3">🎯</div>
        <h2 class="text-lg font-semibold text-gray-200 group-hover:text-blue-400 transition-colors mb-2">Scrabble Tile Strategy</h2>
        <p class="text-sm text-gray-400">Letter values, rack management, and scoring tips to maximize every turn.</p>
        <div class="mt-4 text-xs text-gray-500">June 9, 2026 · 6 min read</div>
      </a>

      <a href="/blog/scrabble-dictionaries-languages-weird-words" class="group rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-all">
        <div class="text-2xl mb-3">📖</div>
        <h2 class="text-lg font-semibold text-gray-200 group-hover:text-blue-400 transition-colors mb-2">Scrabble Dictionaries</h2>
        <p class="text-sm text-gray-400">Languages, weird words, and what counts — everything about the word lists that power the game.</p>
        <div class="mt-4 text-xs text-gray-500">June 9, 2026 · 5 min read</div>
      </a>

      <a href="/blog/competitive-scrabble-tournament-world" class="group rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-all">
        <div class="text-2xl mb-3">🏆</div>
        <h2 class="text-lg font-semibold text-gray-200 group-hover:text-blue-400 transition-colors mb-2">Inside Competitive Scrabble</h2>
        <p class="text-sm text-gray-400">Tournaments, records, and the mental game behind the world's best Scrabble players.</p>
        <div class="mt-4 text-xs text-gray-500">June 9, 2026 · 6 min read</div>
      </a>
    </div>

    <div class="mt-12 text-center">
      <a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-blue-500 text-gray-950 font-semibold hover:bg-blue-400 transition-colors">
        🔤 Try the Word Finder →
      </a>
    </div>
  </div>
</BlogLayout>
