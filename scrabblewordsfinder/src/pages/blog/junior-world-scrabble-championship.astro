---
export const prerender = false;
import Layout from '../../layouts/BlogLayout.astro';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
import '../../styles/global.css';
import { env } from 'cloudflare:workers';

const db = (env as any).DB;
let winners: any[] = [];
try {
  const res = await db.prepare("SELECT * FROM tournament_winners WHERE tournament = 'JWSC' ORDER BY year DESC").all();
  winners = (res.results || []) as any[];
} catch (e) { console.error('JWSC winners fetch error:', e); }

function toSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
