---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing CO — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing CO with scores, definitions, and strategic tips. Master CO words for better Scrabble plays."
  keywords="scrabble words containing co, co words scrabble, words with co, scrabble co word list, co scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing CO — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing CO with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-co" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring CO words?", "acceptedAnswer": { "@type": "Answer", "text": "Top CO words include COMPLEXITY (26 pts), CONJECTURE (22 pts), CONQUER (18 pts), COWBOY (16 pts), and COPPER (12 pts). CO words with X, Q, or Y deliver the biggest scores." } },
      { "@type": "Question", "name": "How many Scrabble words contain CO?", "acceptedAnswer": { "@type": "Answer", "text": "Over 1,800 valid Scrabble words contain CO, making it one of the most common pairs in the game. CO- is one of English's most productive prefixes: COME, COLD, COOK, COPY, CORE, CORN, COST, COUNT, COVER." } },
      { "@type": "Question", "name": "Is CO good for Scrabble strategy?", "acceptedAnswer": { "@type": "Answer", "text": "CO is excellent because it nearly guarantees a play when you hold C and O. The sheer number of CO- words (1,800+) means you will always find options regardless of your remaining tiles." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing CO — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">CO is the most prolific letter pair starting with C, appearing in over 1,800 valid Scrabble words. The CO- prefix is one of English's most productive, creating words like COME, COLD, COOK, COPY, CORE, CORN, COST, COUNT, and COVER. With C worth 3 points, even simple CO words score reliably.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top CO Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">CONJECTURE</td><td class="px-4 py-3 text-blue-400">22</td><td class="px-4 py-3 text-gray-400">A guess</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">COMPLEXITY</td><td class="px-4 py-3 text-blue-400">26</td><td class="px-4 py-3 text-gray-400">State of being complex</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">CONQUER</td><td class="px-4 py-3 text-blue-400">18</td><td class="px-4 py-3 text-gray-400">To defeat</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">COWBOY</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A cattle herder</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">COLUMN</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A vertical structure</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">CORNER</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">Where edges meet</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">COPPER</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">A metal element</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">COULD</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">Past tense of can</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">COLD</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">Low temperature</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">COST</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">A price paid</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">COT</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A small bed</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">1,800+</p><p class="text-xs text-gray-400">Valid CO words</p></div>
          <div><p class="text-xl font-bold text-amber-400">8 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Very Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for CO Words</h2>

      <p>CO- starts more words than almost any other two-letter combination. COME, COLD, COOK, COPY, CORE, CORN, COST, COUNT, COVER, COULD — the list is enormous. You will nearly always find a CO play when holding C and O. COPPER (12 pts) and COLUMN (10 pts) score well with common tiles.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CONJECTURE</span><span class="text-blue-400 text-xs">22 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">COMPLEXITY</span><span class="text-blue-400 text-xs">26 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CONQUER</span><span class="text-blue-400 text-xs">18 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">COWBOY</span><span class="text-blue-400 text-xs">16 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">COLUMN</span><span class="text-blue-400 text-xs">10 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CORNER</span><span class="text-blue-400 text-xs">8 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">CO is one of Scrabble's <span class="text-white font-medium">most prolific pairs with 1,800+ words</span>. The CO- prefix gives near-guaranteed plays (COME, COLD, COOK, COST, COUNT). For higher scores, COWBOY (16 pts), CONQUER (18 pts), and COPPER (12 pts) use accessible letter combinations.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every CO word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>