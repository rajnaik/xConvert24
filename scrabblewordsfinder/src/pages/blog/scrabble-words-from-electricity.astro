      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">WATT</td><td class="px-4 py-3 text-amber-600 font-bold">7</td><td class="px-4 py-3">4</td><td class="px-4 py-3">Unit of power</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">VOLT</td><td class="px-4 py-3 text-amber-600 font-bold">7</td><td class="px-4 py-3">4</td><td class="px-4 py-3">Unit of potential</td></tr>
