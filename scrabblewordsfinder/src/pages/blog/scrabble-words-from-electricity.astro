  <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-sm">
    <thead class="bg-gray-100 dark:bg-gray-800">
      <tr>
        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Word</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Points</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Length</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Meaning</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">QUARTZ</td><td class="px-4 py-3 text-amber-600 font-bold">24</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Crystal used in oscillators</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">KILOWATT</td><td class="px-4 py-3 text-amber-600 font-bold">15</td><td class="px-4 py-3">8</td><td class="px-4 py-3">1000 watts of power</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">VOLTAGE</td><td class="px-4 py-3 text-amber-600 font-bold">11</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Electric potential difference</td></tr>
      <tr class="bg-gray-50 dark:bg-gray-800/50"><td class="px-4 py-3 font-mono font-bold">WATTAGE</td><td class="px-4 py-3 text-amber-600 font-bold">11</td><td class="px-4 py-3">7</td><td class="px-4 py-3">Amount of electrical power</td></tr>
      <tr class="bg-white dark:bg-gray-900"><td class="px-4 py-3 font-mono font-bold">AMPERE</td><td class="px-4 py-3 text-amber-600 font-bold">10</td><td class="px-4 py-3">6</td><td class="px-4 py-3">Unit of electric current</td></tr>
