            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-gray-300 font-bold">ZOO</td><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300">Z(10) + O(1) + O(1)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">16</td><td class="px-4 py-3 text-gray-300 font-bold">QUA</td><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300">Q(10) + U(1) + A(1)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">17</td><td class="px-4 py-3 text-gray-300 font-bold">QIS</td><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300">Q(10) + I(1) + S(1)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">18</td><td class="px-4 py-3 text-gray-300 font-bold">SUQ</td><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300">S(1) + U(1) + Q(10)</td></tr>
