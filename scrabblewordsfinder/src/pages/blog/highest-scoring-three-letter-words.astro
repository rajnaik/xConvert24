import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
import AuthorInfo from '../../components/AuthorInfo.astro';
---

<BlogLayout
  title="Highest Scoring Three-Letter Words in Scrabble"
  description="Complete ranking of the top 20 highest-scoring 3-letter words in Scrabble. Learn how premium squares multiply these short words into game-winning. Free."
  keywords="highest scoring 3 letter words, top scoring short words, best scrabble plays, three letter word scores, highest point 3 letter words"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Highest Scoring Three-Letter Words in Scrabble",
    "description": "Complete ranking of the top 20 highest-scoring 3-letter words in Scrabble. Learn how premium squares multiply these short words into game-winning plays.",
    "datePublished": "2026-06-14",
    "dateModified": "2026-06-09",
    "author": { "@type": "Person", "name": "Raj Naik", "url": "https://www.scrabblewordsfinder.com/about/" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/highest-scoring-three-letter-words" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What 3-letter word scores the most points in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZAX scores 19 points at base value (Z=10, A=1, X=8). On a Triple Word Score, it becomes 57 points. With the Z on a Triple Letter Score, it reaches 39 points from just three tiles." }
      },
      {
        "@type": "Question",
        "name": "How do premium squares affect 3-letter word scores?",
        "acceptedAnswer": { "@type": "Answer", "text": "Premium squares multiply individual tile values (Double/Triple Letter Score) or the entire word value (Double/Triple Word Score). A 19-point word like ZAX becomes 57 on a Triple Word Score. Placing the Z tile specifically on a Triple Letter Score gives it 30 points for that tile alone." }
      },
      {
        "@type": "Question",
        "name": "Which letters make the highest-scoring 3-letter words?",
        "acceptedAnswer": { "@type": "Answer", "text": "Z (10 points), Q (10 points), X (8 points), and J (8 points) are the key tiles. The highest-scoring 3-letter words almost always contain at least one of these letters. Words combining two high-value tiles like ZAX (Z + X) score the most." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 pt-4 pb-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Three-Letter Words</span>
      </nav>
      <BlogCrossLinks title="Highest Scoring Three Letter Words" />

      <h1 class="text-3xl font-bold text-white mb-4">Highest Scoring Three-Letter Words in Scrabble</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>6 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔍</span> Solver</a> <a href="/activities/#quiz" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🎯</span> Quiz</a> <a href="/activities/#anagram" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔀</span> Anagram</a> <a href="/activities/#rack" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🎲</span> Rack</a> <a href="/activities/#wotd" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">📖</span> WOTD</a> <a href="/sixty-seconds/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">⏱️</span> 60s</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        In competitive Scrabble, every point matters. Three-letter words with high-value tiles can outscore most longer words — especially when you place them on premium squares. This guide ranks the top 20 highest-scoring 3-letter words by base point value and shows you exactly how premium square placement turns them into devastating plays.
      </p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Complete Ranking: Top 20 by Base Score</h2>
      <p>Every word below is valid in the official TWL (Tournament Word List) and SOWPODS dictionaries. The base score assumes no premium squares — the actual in-game score will often be much higher.</p>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Rank</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Base Score</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Tile Breakdown</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">1</td><td class="px-4 py-3 text-gray-300 font-bold">ZAX</td><td class="px-4 py-3 text-gray-300">19</td><td class="px-4 py-3 text-gray-300">Z(10) + A(1) + X(8)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">2</td><td class="px-4 py-3 text-gray-300 font-bold">JAX</td><td class="px-4 py-3 text-gray-300">17</td><td class="px-4 py-3 text-gray-300">J(8) + A(1) + X(8)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">3</td><td class="px-4 py-3 text-gray-300 font-bold">ZEK</td><td class="px-4 py-3 text-gray-300">16</td><td class="px-4 py-3 text-gray-300">Z(10) + E(1) + K(5)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">4</td><td class="px-4 py-3 text-gray-300 font-bold">FEZ</td><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-gray-300">F(4) + E(1) + Z(10)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">5</td><td class="px-4 py-3 text-gray-300 font-bold">WIZ</td><td class="px-4 py-3 text-gray-300">15</td><td class="px-4 py-3 text-gray-300">W(4) + I(1) + Z(10)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">6</td><td class="px-4 py-3 text-gray-300 font-bold">ZEP</td><td class="px-4 py-3 text-gray-300">14</td><td class="px-4 py-3 text-gray-300">Z(10) + E(1) + P(3)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">7</td><td class="px-4 py-3 text-gray-300 font-bold">ZAP</td><td class="px-4 py-3 text-gray-300">14</td><td class="px-4 py-3 text-gray-300">Z(10) + A(1) + P(3)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">8</td><td class="px-4 py-3 text-gray-300 font-bold">BIZ</td><td class="px-4 py-3 text-gray-300">14</td><td class="px-4 py-3 text-gray-300">B(3) + I(1) + Z(10)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">9</td><td class="px-4 py-3 text-gray-300 font-bold">COZ</td><td class="px-4 py-3 text-gray-300">14</td><td class="px-4 py-3 text-gray-300">C(3) + O(1) + Z(10)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">10</td><td class="px-4 py-3 text-gray-300 font-bold">ZAG</td><td class="px-4 py-3 text-gray-300">13</td><td class="px-4 py-3 text-gray-300">Z(10) + A(1) + G(2)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">11</td><td class="px-4 py-3 text-gray-300 font-bold">ZIG</td><td class="px-4 py-3 text-gray-300">13</td><td class="px-4 py-3 text-gray-300">Z(10) + I(1) + G(2)</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300 font-bold">ADZ</td><td class="px-4 py-3 text-gray-300">13</td><td class="px-4 py-3 text-gray-300">A(1) + D(2) + Z(10)</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-300">13</td><td class="px-4 py-3 text-gray-300 font-bold">AZO</td><td class="px-4 py-3 text-gray-300">12</td><td class="px-4 py-3 text-gray-300">A(1) + Z(10) + O(1)</td></tr>
