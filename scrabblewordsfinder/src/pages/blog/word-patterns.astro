---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Word Patterns — Vowels, Consonants & Special Combinations"
  description="41 guides to Scrabble word patterns: vowel-heavy words, consonant-heavy words, words without vowels, double/triple letters, palindromes, and scoring thresholds."
  keywords="scrabble word patterns, vowel words, consonant words, words without vowels, double letter words, high scoring words, scrabble palindromes"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Scrabble words have no vowels?",
        "acceptedAnswer": { "@type": "Answer", "text": "Several valid Scrabble words contain no standard vowels (A, E, I, O, U). Examples include CRY, DRY, FLY, GYM, HMM, SHH, and TSK. Y acts as a vowel substitute in many of these words." }
      },
      {
        "@type": "Question",
        "name": "Are there Scrabble words with all five vowels?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Words like EDUCATION, SEQUOIA, and AUTHORIZE contain all five vowels. These are valuable to know when holding a vowel-heavy rack, as they help you use multiple vowels in a single play." }
      },
      {
        "@type": "Question",
        "name": "What are the highest-scoring short words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Short words with high-value tiles score big: QI (11), ZA (11), AX (9), EX (9), XI (9), XU (9), JO (9). These 2-3 letter words are essential for tight board positions and parallel plays." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">Word Patterns</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">Word Patterns</h1>
    <p class="text-lg text-gray-300 mb-6">
      41 guides exploring word structure patterns in Scrabble. Learn which words are vowel-heavy, consonant-heavy,
      contain unusual letter combinations, or hit specific scoring thresholds.
    </p>

    <div class="not-prose my-8 p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">
      <div class="flex flex-wrap items-center justify-center gap-6 text-center">
        <div><p class="text-2xl font-bold text-emerald-400">41</p><p class="text-xs text-gray-400">Guides</p></div>
        <div><p class="text-2xl font-bold text-emerald-400">50+</p><p class="text-xs text-gray-400">Points (Top Words)</p></div>
        <div><p class="text-2xl font-bold text-emerald-400">0</p><p class="text-xs text-gray-400">Vowels Needed</p></div>
      </div>
    </div>

    <!-- Vowel Patterns -->
    <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Vowel Patterns</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose">
      <a href="/blog/words-with-all-vowels/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with all vowels</a>
      <a href="/blog/words-using-all-5-vowels/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words using all 5 vowels</a>
      <a href="/blog/words-with-multiple-vowels/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with multiple vowels</a>
      <a href="/blog/words-with-four-vowels-in-row/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Four vowels in a row</a>
      <a href="/blog/words-with-only-vowels/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with only vowels</a>
      <a href="/blog/four-vowel-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Four-vowel words</a>
      <a href="/blog/best-vowel-heavy-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Best vowel-heavy words</a>
      <a href="/blog/vowel-heavy-rack-solutions/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Vowel-heavy rack solutions</a>
      <a href="/blog/words-alternating-vowels-consonants/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Alternating vowels/consonants</a>
    </div>

    <!-- Consonant Patterns -->
    <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Consonant Patterns</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose">
      <a href="/blog/words-without-vowels/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words without vowels</a>
      <a href="/blog/words-with-no-vowels-except-y/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">No vowels except Y</a>
      <a href="/blog/words-using-only-consonants/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Only consonants</a>
      <a href="/blog/four-consonant-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Four-consonant words</a>
      <a href="/blog/best-consonant-heavy-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Best consonant-heavy words</a>
      <a href="/blog/consonant-heavy-rack-strategy/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Consonant-heavy rack strategy</a>
    </div>

    <!-- Special Letter Patterns -->
    <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Special Letter Patterns</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose">
      <a href="/blog/words-with-double-letters/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with double letters</a>
      <a href="/blog/words-with-triple-letters/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with triple letters</a>
      <a href="/blog/words-with-silent-letters/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words with silent letters</a>
      <a href="/blog/words-with-x-in-the-middle/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">X in the middle</a>
      <a href="/blog/words-with-z-in-the-middle/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Z in the middle</a>
      <a href="/blog/words-with-w-not-followed-by-vowel/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">W not followed by vowel</a>
      <a href="/blog/words-rare-letter-combinations/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Rare letter combinations</a>
      <a href="/blog/palindrome-words-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Palindrome words</a>
    </div>

    <!-- Word Length & Scoring -->
    <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Word Length &amp; Scoring</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose">
      <a href="/blog/shortest-legal-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Shortest legal words</a>
      <a href="/blog/shortest-words-with-j/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Shortest words with J</a>
      <a href="/blog/shortest-words-with-x/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Shortest words with X</a>
      <a href="/blog/shortest-words-with-z/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Shortest words with Z</a>
      <a href="/blog/longest-scrabble-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Longest Scrabble words</a>
      <a href="/blog/longest-common-scrabble-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Longest common words</a>
      <a href="/blog/four-letter-power-words/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Four-letter power words</a>
      <a href="/blog/four-letter-words-every-player-should-know/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Must-know four-letter words</a>
      <a href="/blog/five-letter-words-that-score-high/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">High-scoring five-letter words</a>
      <a href="/blog/short-words-high-point-values/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Short words, high points</a>
      <a href="/blog/long-words-low-point-values/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Long words, low points</a>
      <a href="/blog/words-worth-over-20-points/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words worth 20+ points</a>
      <a href="/blog/words-worth-over-30-points/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words worth 30+ points</a>
      <a href="/blog/words-worth-over-40-points/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words worth 40+ points</a>
      <a href="/blog/words-worth-50-plus-points/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words worth 50+ points</a>
    </div>

    <!-- Dictionary-specific -->
    <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Dictionary-Specific</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose">
      <a href="/blog/words-only-in-sowpods/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words only in SOWPODS</a>
      <a href="/blog/words-only-in-twl/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words only in TWL</a>
      <a href="/blog/words-with-friends-vs-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Words With Friends vs Scrabble</a>
    </div>

    <!-- CTA -->
    <div class="not-prose mt-12 p-5 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border border-blue-200 dark:border-blue-800 rounded-xl shadow-sm">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <p class="text-sm text-blue-800 dark:text-blue-300 font-medium">Try our free Scrabble Word Finder — discover unusual word patterns</p>
        <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
      </div>
    </div>

    <div class="not-prose mt-8 text-center">
      <a href="/blog/" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">← Back to all articles</a>
    </div>
  </div>
</BlogLayout>
