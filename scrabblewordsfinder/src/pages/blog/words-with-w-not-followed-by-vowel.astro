---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words With W Not Followed by Vowel"
  description="Unusual W words for Scrabble. CWM, TWP and other W-consonant combinations."
  keywords="scrabble, words, with, w, not, followed, by, vowel"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words With W Not Followed by Vowel",
    "description": "Unusual W words for Scrabble. CWM, TWP and other W-consonant combinations.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-with-w-not-followed-by-vowel" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Scrabble words have W not followed by a vowel?",
        "acceptedAnswer": { "@type": "Answer", "text": "Valid examples: AWL (6 pts), AWN (6 pts), OWL (6 pts), OWN (6 pts), TWO (6 pts), BROW (9 pts), CROW (9 pts), DRAW (8 pts), BREW (9 pts), SHAWL (11 pts), GROWL (9 pts), HEWN (10 pts), TOWN (7 pts), DOWN (8 pts), and BOWL (9 pts)." }
      },
      {
        "@type": "Question",
        "name": "Are there words where W acts as a vowel in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "In some Welsh-origin words, W functions as a vowel (like CWM, 10 pts). CWM is a technical geography term for a cirque or valley and is one of the most famous vowelless words in Scrabble. It is valid in both TWL and SOWPODS." }
      },
      {
        "@type": "Question",
        "name": "What is CWM in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "CWM (10 pts) is a Welsh word for a steep-sided valley or cirque. It is notable for being a valid 3-letter word with no standard vowels (W acts as the vowel). It scores C(3)+W(4)+M(3)=10 points and is useful for consonant-heavy racks." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/letter-guides/" class="hover:text-blue-400 transition-colors text-gray-300">Letter Guides</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words With W Not Followed by Vowel</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Unusual W words for Scrabble. CWM, TWP and other W-consonant combinations.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
