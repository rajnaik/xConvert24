---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
import AuthorInfo from '../../components/AuthorInfo.astro';
---

<BlogLayout
  title="Words with X and Z: High-Scoring Scrabble Plays"
  description="Complete list of short X words and Z words for Scrabble. Top 20 highest-scoring plays, words containing both X and Z, and premium square strategy. Free."
  keywords="x and z words scrabble, words with x, words with z, high scoring scrabble words, short x words, short z words, x z scrabble strategy, words with both x and z"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words with X and Z: High-Scoring Scrabble Plays",
    "description": "Complete list of short X and Z words for Scrabble with premium square strategy.",
    "datePublished": "2026-06-20",
    "dateModified": "2026-06-26",
    "author": { "@type": "Person", "name": "Raj Naik", "url": "https://www.scrabblewordsfinder.com/about/" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-words-with-x-and-z" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the best short X words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "The best short X words are AX (9pts), EX (9pts), OX (9pts), XI (9pts), XU (9pts) for 2-letter plays. For 3-letter: ZAX (19pts), WAX (13pts), HEX (13pts), VEX (13pts), REX (10pts), and TAX (10pts)." }
      },
      {
        "@type": "Question",
        "name": "What are the best short Z words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "The best short Z words are ZA (11pts) for 2-letter. For 3-letter: ZAX (19pts), ZAP (14pts), ZIP (14pts), ZEP (14pts), ZAG (13pts), ZED (13pts), and ADZ (13pts). ZAX uses both Z and X in one word." }
      },
      {
        "@type": "Question",
        "name": "Are there Scrabble words with both X and Z?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. The most playable is ZAX (19pts, a slate-cutting tool). Others include ZAXES (21pts), OXAZINE, EXORCIZE, and OXIDIZE. ZAX is the most practical at only 3 letters using two high-value tiles at once." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 pt-4 pb-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/high-scoring/" class="hover:text-blue-400 transition-colors text-gray-300">High Scoring</a>
      </nav>
      <BlogCrossLinks title="Scrabble Words With X And Z" />

      <h1 class="text-3xl font-bold text-white mb-4">Words with X and Z: High-Scoring Scrabble Plays</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-20">June 20, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>8 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔍</span> Solver</a> <a href="/activities/#quiz" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🎯</span> Quiz</a> <a href="/activities/#anagram" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔀</span> Anagram</a> <a href="/activities/#rack" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🎲</span> Rack</a> <a href="/activities/#wotd" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">📖</span> WOTD</a> <a href="/sixty-seconds/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">⏱️</span> 60s</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">
        X and Z are the two highest-value tiles in Scrabble — both worth 10 points each. Together, they account for 20 of the 187 total points in the tile bag. Mastering short X and Z words is essential for competitive play because these tiles score massive points even in 2-3 letter words, especially when landing on premium squares. This guide covers every practical short word for both tiles, plus the rare words that contain both X and Z.
      </p>

      <!-- Hero Card for ZAX -->
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Best X+Z Word</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">ZAX</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">19 points · Contains both Z and X · Only 3 letters · Valid TWL + SOWPODS</p>
        <p class="text-sm text-gray-300 leading-relaxed">ZAX is a tool used for cutting roofing slates. It combines the two highest-value tiles (Z=10, X=8) plus a common A for 19 points in just 3 letters. On a Triple Letter square under Z, that is 39 points.</p>
      </div>

      <!-- Stat Strip -->
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">10</p><p class="text-xs text-gray-400">X Tile Value</p></div>
          <div><p class="text-xl font-bold text-amber-400">10</p><p class="text-xs text-gray-400">Z Tile Value</p></div>
          <div><p class="text-xl font-bold text-amber-400">5</p><p class="text-xs text-gray-400">2-Letter X Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">19</p><p class="text-xs text-gray-400">ZAX Base Score</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Short X Words (2-3 Letters)</h2>

      <p>X is one of the easiest high-value tiles to play because it has five 2-letter options. You can almost always find a spot for X within one turn.</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">2-Letter X Words (all 9pts)</p>
          <p class="text-xs text-gray-400">AX · EX · OX · XI · XU — five options means X is never stuck</p>
        </div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
          <p class="text-cyan-400 font-semibold text-sm mb-1">3-Letter X Words (high value)</p>
          <p class="text-xs text-gray-400">ZAX (19pts) · WAX (13pts) · HEX (13pts) · VEX (13pts) · BOX (12pts) · FOX (13pts) · TAX (10pts) · REX (10pts)</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">X has <span class="text-white font-medium">five 2-letter words</span> (AX, EX, OX, XI, XU) vs. Z which has only one (ZA). This makes X the <span class="text-white font-medium">easiest high-value tile</span> to play — you can always fit it somewhere on the board.</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Short Z Words (2-3 Letters)</h2>

      <p>Z has fewer 2-letter options than X but compensates with excellent 3-letter words. The combination of Z + common vowels creates reliable plays.</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">2-Letter Z Words</p>
          <p class="text-xs text-gray-400">ZA (11pts) — only option in TWL · ZO (11pts, SOWPODS) · ZE (11pts, SOWPODS)</p>
        </div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">3-Letter Z Words (high value)</p>
          <p class="text-xs text-gray-400">ZAX (19pts) · ZAP (14pts) · ZIP (14pts) · ZEP (14pts) · ZAG (13pts) · ZIG (13pts) · ZED (13pts) · ADZ (13pts)</p>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Words Containing Both X and Z</h2>

      <p>These rare words use both premium tiles at once. If you have X and Z on your rack together, these are your options for dumping both in a single play.</p>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">⭐ Practical (3-5 letters)</p>
          <p class="text-xs text-gray-400">ZAX (19pts) · ZAXES (21pts) — a slate tool and its plural. By far the most playable X+Z words.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">⭐ Longer (6+ letters)</p>
          <p class="text-xs text-gray-400">OXAZINE · OXIDIZE · EXORCIZE · OXAZINES · OXIDIZES — rare in practice but devastating if playable</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Strategy Note</p>
        <p class="text-base text-gray-200">If you draw both X and Z, <span class="text-white font-medium">do not try to play them together</span> unless ZAX is available. It is almost always better to play them separately on different premium squares for maximum total points.</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top 20 X Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Score</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">OXAZEPAM</td><td class="px-4 py-3 text-amber-400">28</td><td class="px-4 py-3 text-gray-400">A sedative drug</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">EXOZYMIC</td><td class="px-4 py-3 text-amber-400">31</td><td class="px-4 py-3 text-gray-400">Acting outside the cell</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">QUIXOTIC</td><td class="px-4 py-3 text-amber-400">26</td><td class="px-4 py-3 text-gray-400">Idealistic, impractical</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">JINXED</td><td class="px-4 py-3 text-amber-400">21</td><td class="px-4 py-3 text-gray-400">Cursed with bad luck</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">OXYGEN</td><td class="px-4 py-3 text-amber-400">17</td><td class="px-4 py-3 text-gray-400">Chemical element</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">BOXCAR</td><td class="px-4 py-3 text-amber-400">17</td><td class="px-4 py-3 text-gray-400">Railway freight car</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">FOXHOUND</td><td class="px-4 py-3 text-amber-400">22</td><td class="px-4 py-3 text-gray-400">Hunting dog breed</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">COMPLEX</td><td class="px-4 py-3 text-amber-400">20</td><td class="px-4 py-3 text-gray-400">Intricate, compound</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">MAXIM</td><td class="px-4 py-3 text-amber-400">16</td><td class="px-4 py-3 text-gray-400">A general truth</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">EXPIRE</td><td class="px-4 py-3 text-amber-400">15</td><td class="px-4 py-3 text-gray-400">To come to an end</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top 20 Z Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Score</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">FUZZY</td><td class="px-4 py-3 text-amber-400">29</td><td class="px-4 py-3 text-gray-400">Covered in fuzz</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">JAZZY</td><td class="px-4 py-3 text-amber-400">33</td><td class="px-4 py-3 text-gray-400">Lively, flashy</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">FIZZY</td><td class="px-4 py-3 text-amber-400">29</td><td class="px-4 py-3 text-gray-400">Carbonated, bubbly</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">PIZZA</td><td class="px-4 py-3 text-amber-400">25</td><td class="px-4 py-3 text-gray-400">Italian flatbread dish</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">ZIPPY</td><td class="px-4 py-3 text-amber-400">21</td><td class="px-4 py-3 text-gray-400">Quick, energetic</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">ZILCH</td><td class="px-4 py-3 text-amber-400">19</td><td class="px-4 py-3 text-gray-400">Nothing, zero</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">ZAX</td><td class="px-4 py-3 text-amber-400">19</td><td class="px-4 py-3 text-gray-400">Slate-cutting tool</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">ZESTY</td><td class="px-4 py-3 text-amber-400">17</td><td class="px-4 py-3 text-gray-400">Flavorful, lively</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-white font-bold">ZINCS</td><td class="px-4 py-3 text-amber-400">16</td><td class="px-4 py-3 text-gray-400">Plural of zinc</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-white font-bold">ZINC</td><td class="px-4 py-3 text-amber-400">15</td><td class="px-4 py-3 text-gray-400">Metallic element</td></tr>
          </tbody>
        </table>
