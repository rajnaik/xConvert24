            <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Scoring Guide — deep dive into letter values and premium square math</span>
          </a>
        </div>
      </div>

      <!-- Related Articles -->
      <aside class="border-t border-gray-700 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/what-is-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-400 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">What Is Scrabble? A Complete Introduction</span>
          </a>
          <a href="/blog/scrabble-rules-explained/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-400 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Rules Explained: The Complete Breakdown</span>
          </a>
          <a href="/blog/scrabble-scoring-guide/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-400 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Scoring Guide: Letter Values & Premium Squares</span>
          </a>
          <a href="/guide/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group">
            <span class="text-blue-400 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">📘 Word Finder Guide — Get the Most From Our Free Tool</span>
          </a>
        </div>
      </aside>

      <!-- CTA -->
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-indigo-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Practise finding words — free, instant, no signup required</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
