  keywords="scrabble hook chains, hook words scrabble, front hooks back hooks, scrabble setup play, multi-turn scrabble strategy, scrabble word extensions, hook chain examples, scrabble planning ahead"
>
  <script type="application/ld+json" set:html={JSON.stringify({
