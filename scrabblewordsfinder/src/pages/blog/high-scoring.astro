---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="High-Scoring Scrabble Words — Maximum Points Guide"
  description="The most valuable words in Scrabble ranked by points. Best Q, Z, X, J words, power words by length, and the legendary OXYPHENBUTAZONE. Free guides, no signup."
  keywords="high scoring scrabble words, best scrabble words, highest point words, q words scrabble, z words scrabble, x words scrabble, power words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the highest scoring word possible in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "OXYPHENBUTAZONE is theoretically the highest-scoring single word in Scrabble, worth 1,778 points when played across three triple word squares. In practice, the highest verified single-turn score is 365 points for QUIXOTRY played across two triple word squares." }
      },
      {
        "@type": "Question",
        "name": "Which letters score the most points in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Q and Z are worth 10 points each, X and J are worth 8 points each, and K is worth 5 points. Words using these tiles score significantly higher, especially when placed on premium squares that double or triple the letter value." }
      },
      {
        "@type": "Question",
        "name": "What are the best short high-scoring words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI (11 pts), ZA (11 pts), ZO (11 pts), AX (9 pts), XI (9 pts), XU (9 pts), JO (9 pts), and EX (9 pts) are the highest face-value two-letter words. For three letters, ZAX (19 pts), ZEK (16 pts), and QAT (12 pts) lead the pack." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">High-Scoring Words</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">High-Scoring Scrabble Words</h1>
    <p class="text-lg text-gray-300 mb-6">
      Points win games. These 11 guides focus on the most valuable words in Scrabble — organised by letter, 
      by word length, and by scoring potential. Learn which words to reach for when you need maximum impact, 
      and how to deploy premium tiles for devastating scores.
    </p>

    <!-- Stat Strip: Category Overview -->
    <div class="not-prose my-8 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
      <div class="flex flex-wrap items-center justify-center gap-6 text-center">
        <div><p class="text-2xl font-bold text-amber-400">11</p><p class="text-xs text-gray-400">Guides</p></div>
        <div><p class="text-2xl font-bold text-amber-400">4</p><p class="text-xs text-gray-400">Power Letters</p></div>
        <div><p class="text-2xl font-bold text-amber-400">1,778</p><p class="text-xs text-gray-400">Max Theoretical Score</p></div>
        <div><p class="text-2xl font-bold text-amber-400">36</p><p class="text-xs text-gray-400">Tile Points (Q+Z+X+J)</p></div>
      </div>
    </div>

    <!-- Insight Callout -->
    <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
      <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Why This Matters</p>
      <p class="text-base text-gray-200">The four power tiles — <span class="text-white font-medium">Q (10 pts), Z (10 pts), X (8 pts), J (8 pts)</span> — represent just 4% of tiles in the bag but can swing a game by 50+ points in a single turn. Placing a Z on a Triple Letter square scores <span class="text-white font-medium">30 points from one tile alone</span>.</p>
    </div>

    <!-- Power Tile Pill Badges -->
    <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
        <span class="text-white font-bold">Q</span><span class="text-amber-400 text-xs">10 pts</span>
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm">
        <span class="text-white font-bold">Z</span><span class="text-amber-400 text-xs">10 pts</span>
      </span>
