---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With WH — Master the W+H Power Combo" description="Dominate with WH words in Scrabble: WHISKEY (20pts), WHIPLASH (19pts), WHEREVER (17pts), WHARF (14pts). The W+H combo delivers 8 base points every time." keywords="scrabble words with wh, wh scrabble words, whiskey scrabble, whiplash scrabble, wh combination strategy, high scoring wh words">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With WH — Master the W+H Power Combo","description":"Master WH words in Scrabble with scoring breakdowns for WHISKEY, WHIPLASH, WHEREVER, and WHARF.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-wh"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many points is the WH combination worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"W (4 points) + H (4 points) = 8 points from just two tiles. This makes WH one of the most valuable two-letter combinations in Scrabble, giving any WH word an automatic high-scoring base."}},{"@type":"Question","name":"What is the highest-scoring WH word in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"WHISKEY scores 20 points without premium squares. The combination of W(4) + H(4) + I(1) + S(1) + K(5) + E(1) + Y(4) makes it one of the strongest 7-letter WH plays available."}},{"@type":"Question","name":"Is WHARF a good Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes, WHARF scores 14 points in just 5 letters — that's 2.8 points per tile, well above average. It's compact enough to fit in tight board positions and can be extended to WHARFS or WHARVES for even more points."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With WH — Master the W+H Power Combo</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">W and H are both 4-point tiles, and when they combine at the start of a word, you're already sitting on 8 points before counting anything else. English is rich with WH-words — questions, actions, places — and many of them score impressively well in Scrabble.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">8</p><p class="text-xs text-gray-400">WH Base Points</p></div>
          <div><p class="text-xl font-bold text-amber-400">W=4</p><p class="text-xs text-gray-400">+ H=4</p></div>
          <div><p class="text-xl font-bold text-amber-400">2 W-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
          <div><p class="text-xl font-bold text-amber-400">2 H-tiles</p><p class="text-xs text-gray-400">In Bag</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top WH Words by Score</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 WHISKEY</p><p class="text-xs text-gray-400">20 points · 7 letters · K bonus · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 WHIPLASH</p><p class="text-xs text-gray-400">19 points · 8 letters · Bingo bonus potential</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ WHEREVER</p><p class="text-xs text-gray-400">17 points · 8 letters · Double W+H · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ WHARF</p><p class="text-xs text-gray-400">14 points · 5 letters · Compact powerhouse</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">WH Placement Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">W on DLS = 8pts from one tile:</span> W is already worth 4 — doubling it gives you 8 points from a single letter. Position your WH words so W lands on Double Letter Score squares.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">WHARF for tight spots:</span> At 5 letters with 14 points, WHARF averages 2.8 pts/tile. It fits where longer words can't and extends to WHARFS (15pts) or WHARVES (16pts).</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">WHIPLASH bingo play:</span> As an 8-letter word, WHIPLASH earns the 50-point bingo bonus. That's 69 points from one play — before any premium square multipliers.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WHISKEY</span><span class="text-blue-400 text-xs">20pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WHIPLASH</span><span class="text-blue-400 text-xs">19pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WHEREVER</span><span class="text-blue-400 text-xs">17pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WHARF</span><span class="text-blue-400 text-xs">14pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">WHACK</span><span class="text-blue-400 text-xs">17pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">WH words are <span class="text-white font-medium">question starters</span> (WHO, WHAT, WHERE, WHY, WHEN) — but the real scoring power comes from longer forms like WHISKEY, WHIPLASH, and WHEREVER that turn those common beginnings into premium plays.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-with-ph/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With PH — High-Scoring Digraph Strategy</span></a>
          <a href="/blog/scrabble-words-with-th/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With TH — Digraph Strategy</span></a>
          <a href="/blog/words-containing-wh/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing WH — Full List</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all WH words instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
