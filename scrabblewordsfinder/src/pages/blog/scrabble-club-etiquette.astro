---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Club Etiquette — Unwritten Rules"
  description="The unwritten rules of Scrabble club play. Clock handling, challenge protocol, and social norms."
  keywords="scrabble, scrabble, club, etiquette"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Club Etiquette — Unwritten Rules",
    "description": "The unwritten rules of Scrabble club play. Clock handling, challenge protocol, and social norms.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-club-etiquette" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the rules of etiquette at a Scrabble club?",
        "acceptedAnswer": { "@type": "Answer", "text": "Key rules: announce your score clearly, keep quiet during others games, don't slam tiles, accept challenges gracefully, shake hands before and after games, don't comment on opponents' boards mid-game, and clean up your area after playing." }
      },
      {
        "@type": "Question",
        "name": "How do I find a Scrabble club near me?",
        "acceptedAnswer": { "@type": "Answer", "text": "Check NASPA's club directory (for North America) or your national Scrabble association's website. Facebook groups, Meetup.com, and local libraries also host clubs. Many cities have weekly gatherings at cafes, community centres, or game shops." }
      },
      {
        "@type": "Question",
        "name": "What skill level do I need for a Scrabble club?",
        "acceptedAnswer": { "@type": "Answer", "text": "All levels are welcome at most clubs. Many have social/casual and competitive divisions. Beginners are encouraged — club members are generally happy to mentor new players. Knowing the two-letter words and basic scoring gives you enough to participate." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/tournament/" class="hover:text-blue-400 transition-colors text-gray-300">Tournament</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Club Etiquette — Unwritten Rules</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">The unwritten rules of Scrabble club play. Clock handling, challenge protocol, and social norms.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
