---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogCrossLinks from '../../components/BlogCrossLinks.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Clock Management — Master the 25-Minute Game"
  description="How to manage your tournament clock in competitive Scrabble. Time allocation per turn, when to think long, when to play fast, and avoiding costly overtime penalties."
  keywords="scrabble clock management, tournament scrabble time, scrabble timer strategy, 25 minute scrabble, scrabble overtime penalty, competitive scrabble clock"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Clock Management — Master the 25-Minute Game",
    "description": "How to manage your tournament clock in competitive Scrabble. Time allocation, when to think long, when to play fast, and avoiding overtime penalties.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "logo": { "@type": "ImageObject", "url": "https://www.scrabblewordsfinder.com/web-app-manifest-512x512.png" } },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/scrabble-clock-management/" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the clock work in tournament Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Each player gets 25 minutes total for all their moves. After your time expires, you lose 10 points per minute or fraction of overtime. Some tournaments use 22 or 20 minutes. The clock runs only during your turn — press it after every play to start your opponent's time." }
      },
      {
        "@type": "Question",
        "name": "How much time should I spend per turn in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Average 90 seconds per turn across 12-15 turns. Spend under 30 seconds on obvious plays (exchanges, simple extensions) and save 2-3 minutes for critical moments like bingo searches, endgame calculations, and close strategic decisions." }
      },
      {
        "@type": "Question",
        "name": "What happens if you run out of time in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "You lose 10 points per minute of overtime (rounded up). In NASPA rules, the game continues until both players finish. In some formats, exceeding 10 minutes overtime means automatic forfeit. Clock management alone can swing a game by 30-50 points." }
      },
      {
        "@type": "Question",
        "name": "How do I practice clock management for Scrabble tournaments?",
        "acceptedAnswer": { "@type": "Answer", "text": "Play online with tournament clocks (25 minutes per side). Practice making your first instinct play on low-value turns. Time yourself solving anagrams — aim for under 60 seconds per 7-letter rack. Review games to identify where you spent time unproductively." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-amber-500 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-600 dark:text-gray-300">Tournament & Competitive</span>
      </nav>

      <BlogCrossLinks title="Scrabble Clock Management — Master the 25-Minute Game" />

      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Clock Management</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>9 min read</span>
      </div>

      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-300 mb-8">The clock is the most underestimated weapon in tournament Scrabble. Two players with identical vocabulary can finish 50 points apart because one managed their 25 minutes intelligently while the other burned time on low-value decisions. Here's how to make every second count.</p>

      <!-- Hero Card -->
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">⏱️ Clock Mastery</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">25 MINUTES. EVERY SECOND COUNTS.</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">12-15 turns · ~90 sec average · -10 pts/min overtime</p>
        <p class="text-sm text-gray-300 leading-relaxed">Most tournament games are decided by margins under 30 points. A single overtime minute wipes that out. The best players spend time like currency — investing heavily on high-value decisions and spending nothing on the obvious ones.</p>
      </div>

      <!-- Stat Strip -->
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">25 min</p><p class="text-xs text-gray-400">Total clock per player</p></div>
          <div><p class="text-xl font-bold text-amber-400">~90 sec</p><p class="text-xs text-gray-400">Average per turn</p></div>
          <div><p class="text-xl font-bold text-amber-400">-10 pts</p><p class="text-xs text-gray-400">Per overtime minute</p></div>
          <div><p class="text-xl font-bold text-amber-400">12-15</p><p class="text-xs text-gray-400">Turns per game</p></div>
        </div>
      </div>

      <!-- Section 1 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">How Tournament Clocks Work</h2>

      <p>Tournament Scrabble uses chess clocks — dual timers where only one side runs at a time. After you place your tiles and announce your score, you press the clock to start your opponent's time. Your 25 minutes is your entire budget for the game — typically 12-15 turns of thinking, scanning, and deciding.</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">✓ Standard Format (NASPA/WESPA)</p>
          <p class="text-xs text-gray-400">25 minutes per player. 10-point penalty per minute overtime. Game continues until both players finish. No sudden death — just escalating penalties.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">⚡ Speed Formats</p>
          <p class="text-xs text-gray-400">Some events use 15 or 20 minutes. Blitz tournaments (5-10 minutes) exist for fun. Strategy changes dramatically — instinct over calculation.</p>
        </div>
        <div class="p-4 rounded-xl border border-red-500/30 bg-red-950/10">
          <p class="text-red-400 font-semibold text-sm mb-1">✗ Common Mistake</p>
          <p class="text-xs text-gray-400">Forgetting to press the clock after playing. Your time keeps running. Make pressing the clock a physical reflex — part of the play motion itself.</p>
        </div>
        <div class="p-4 rounded-xl border border-blue-500/30 bg-blue-950/10">
          <p class="text-blue-400 font-semibold text-sm mb-1">💡 Key Insight</p>
          <p class="text-xs text-gray-400">Your clock runs during challenges too. If you challenge a word, YOUR time ticks while the adjudicator checks. Factor this into challenge decisions.</p>
        </div>
      </div>

      <!-- Section 2 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Time Allocation Strategy</h2>

      <p>Not every turn deserves equal thinking time. The key principle: spend time where the point differential is highest. A turn where you're choosing between a 45-point play and a 42-point play doesn't need 3 minutes of deliberation. A turn where you might find a bingo worth 70+ points absolutely does.</p>

      <div class="not-prose my-6 p-5 rounded-xl border border-purple-500/30 bg-purple-950/10">
        <p class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-3">🧩 Time Budget Framework</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">1</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Quick plays (under 30 sec):</strong> Obvious moves, tile exchanges, simple hooks, plays where the best option is clear immediately. Target 40% of your turns here.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">2</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Standard plays (60-90 sec):</strong> Multiple good options, need to evaluate rack leave, considering board position. Target 40% of your turns here.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">3</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Deep thinks (2-4 min):</strong> Bingo searches, critical endgame calculations, game-changing strategic decisions. Reserve for 2-3 turns per game maximum.</p>
          </div>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 The Banking Principle</p>
        <p class="text-base text-gray-200">Every second you save on obvious plays gets <span class="text-white font-medium">banked for critical moments</span>. If you spend 20 seconds on 6 easy turns, you've saved 7 minutes compared to averaging 90 seconds. That banked time is the difference between finding the bingo or missing it.</p>
      </div>

      <!-- Cross-links -->
      <div class="not-prose my-6 p-4 rounded-xl border border-indigo-500/30 bg-indigo-950/10">
        <p class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-3">📚 Dig Deeper</p>
        <div class="grid gap-2">
          <a href="/blog/preparing-for-first-tournament/" class="flex items-center gap-2 p-2 rounded-lg hover:bg-indigo-900/20 transition-all group">
            <span class="text-indigo-400 group-hover:translate-x-0.5 transition-transform shrink-0">→</span>
            <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Preparing for Your First Tournament — full pre-event preparation guide</span>
          </a>
          <a href="/blog/endgame-strategy/" class="flex items-center gap-2 p-2 rounded-lg hover:bg-indigo-900/20 transition-all group">
            <span class="text-indigo-400 group-hover:translate-x-0.5 transition-transform shrink-0">→</span>
            <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Endgame Strategy — where time investment pays the highest dividends</span>
          </a>
        </div>
      </div>

      <!-- Section 3 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">When to Think Long</h2>

      <p>Certain game situations consistently reward extra thinking time. Recognising these moments — and giving yourself permission to use 2-3 minutes — is what separates intermediate players from experts.</p>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Bingo-likely racks:</span> When your rack has 5-6 common letters (SATIRE, RETINA patterns) and the board has open lanes, spend 2-3 minutes searching. A bingo is worth 50+ bonus points — far more than you'd gain from spending that time elsewhere.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Endgame with 3-4 tiles in bag:</span> Once you can infer your opponent's rack, precise calculation becomes possible. Spending 3 minutes to map out the remaining 4-5 turns can win games you'd otherwise lose by making suboptimal guesses.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Close games in the final third:</span> When the score is within 30 points and 5+ turns remain, every move has strategic weight. Should you open that triple lane? Block the hook spot? The calculation is worth the time.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Challenge decisions on unfamiliar words:</span> If challenging costs your turn (NASPA rules), take 30-60 seconds to really assess: have you seen this word before? Does it follow English word patterns? Is the point swing worth the gamble?</p>
        </div>
      </div>

      <!-- Section 4 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">When to Play Fast</h2>

      <p>Speed isn't just about saving time — it builds psychological momentum. When you play quickly and confidently, you project strength. When you deliberate endlessly on a 25-point play, you signal uncertainty. Know which turns deserve speed.</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">✓ Play Fast When</p>
          <p class="text-xs text-gray-400">Your best play is 5+ points above alternatives. You're exchanging tiles. You're hooking an obvious word (plurals, -ED, -ING). The board position is clear and your rack leave is balanced regardless of placement.</p>
        </div>
        <div class="p-4 rounded-xl border border-red-500/30 bg-red-950/10">
          <p class="text-red-400 font-semibold text-sm mb-1">✗ Don't Rush When</p>
          <p class="text-xs text-gray-400">Multiple plays score within 5 points of each other (rack leave decides). You might have a bingo but haven't checked all arrangements. The board is about to close and this turn decides access to premium squares.</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-cyan-500/30 bg-cyan-950/10">
        <p class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-2">🔬 The 5-Point Rule</p>
        <p class="text-base text-gray-200">If your top two options differ by <span class="text-white font-medium">5 points or less</span>, the one with better rack leave wins — and that decision takes under 15 seconds once you're practiced. If they differ by <span class="text-white font-medium">more than 10 points</span>, take the higher scorer immediately. The middle zone (5-10 points) is where genuine thought adds value.</p>
      </div>

      <!-- Section 5 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Avoiding Overtime Penalties</h2>

      <p>The -10 points per minute penalty is brutal. Going 2 minutes over costs 20 points — often the margin between winning and losing. Most overtime happens not from one slow turn but from many turns that each ran 30 seconds too long. Prevention starts with awareness.</p>

      <div class="not-prose my-6 p-5 rounded-xl border border-purple-500/30 bg-purple-950/10">
        <p class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-3">🧩 Overtime Prevention Checklist</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">1</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Check your clock every 3 turns</strong> — divide remaining time by remaining turns (estimate). If you're averaging over 2 minutes and you're past turn 8, start speeding up now.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">2</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Set a mental alarm at 5 minutes remaining</strong> — at this point, every turn must be under 60 seconds unless it's literally the last play of the game.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">3</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Practice the "good enough" mindset</strong> — a 35-point play made in 20 seconds beats a 40-point play that cost you 3 minutes. The 5-point gain doesn't compensate for the time debt.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-purple-900/50 border border-purple-500/40 flex items-center justify-center text-xs text-purple-300 font-bold">4</span>
            <p class="text-sm text-gray-300"><strong class="text-white">Pre-plan during opponent's turn</strong> — scan the board while they think. Identify 2-3 potential spots for your next play. When you draw tiles, you already know where to look.</p>
          </div>
        </div>
      </div>

      <!-- Section 6 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Practice Techniques for Clock Speed</h2>

      <p>Clock management is a trainable skill. Like any muscle, your speed of pattern recognition and decision-making improves with targeted practice. These drills build the reflexes that translate to faster, more confident tournament play.</p>

      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Timed anagram drills:</span> Use a word finder to generate 7-letter racks. Set a 60-second timer and find the highest-scoring word. Track your success rate over weeks — it will improve from 30% to 70%+ with practice.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Speed games online:</span> Play 15-minute games on ISC or Woogles. The compressed format forces fast decisions and breaks the habit of over-thinking. Even losing at speed teaches you which turns genuinely need time.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Post-game time analysis:</span> After each game, estimate where you spent your time. Were any 3-minute turns actually decisive? Often you'll find that your longest thinks didn't produce better moves — they just produced the same move with more certainty.</p>
        </div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors">
          <p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Rack-spot matching:</span> Before searching for words, spend 5 seconds identifying the best 2-3 spots on the board. Then check if your tiles fit those spots. This top-down approach is faster than scanning every possible placement.</p>
        </div>
      </div>

      <!-- Cross-links -->
      <div class="not-prose my-6 p-4 rounded-xl border border-indigo-500/30 bg-indigo-950/10">
        <p class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-3">📚 Dig Deeper</p>
        <div class="grid gap-2">
          <a href="/blog/mental-stamina-tournament-scrabble/" class="flex items-center gap-2 p-2 rounded-lg hover:bg-indigo-900/20 transition-all group">
            <span class="text-indigo-400 group-hover:translate-x-0.5 transition-transform shrink-0">→</span>
            <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Mental Stamina in Tournament Scrabble — staying sharp when the clock pressure builds</span>
          </a>
          <a href="/blog/rack-management-basics/" class="flex items-center gap-2 p-2 rounded-lg hover:bg-indigo-900/20 transition-all group">
            <span class="text-indigo-400 group-hover:translate-x-0.5 transition-transform shrink-0">→</span>
            <span class="text-sm text-gray-300 group-hover:text-indigo-300 transition-colors">Rack Management Basics — faster decisions come from better rack awareness</span>
          </a>
        </div>
      </div>

      <!-- Section 7 -->
      <h2 class="text-xl font-light text-amber-600 dark:text-amber-400 mt-10 mb-4 border-l-4 border-amber-400 pl-4">Clock Psychology — Using Time Pressure as a Weapon</h2>

      <p>Advanced players use clock awareness not just defensively but offensively. When your opponent is in time trouble, you can exploit it. When you're ahead on the clock, you play with confidence knowing you have a margin for deeper thinking if needed.</p>

      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10">
          <p class="text-green-400 font-semibold text-sm mb-1">✓ When You're Ahead on Clock</p>
          <p class="text-xs text-gray-400">Take extra time on close decisions — you've earned it through earlier efficiency. Play complex setups that force your opponent into longer thinks on their already-stretched time. Consider fishing for bingos even in marginal situations.</p>
        </div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
          <p class="text-amber-400 font-semibold text-sm mb-1">⚡ When Opponent is in Time Trouble</p>
          <p class="text-xs text-gray-400">Play quickly to increase the psychological pressure. Make moves that require them to think (extensions into triple lanes, unusual hook spots). Their rushed decisions will produce suboptimal plays — your normal pace becomes an advantage.</p>
        </div>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 The Confidence Dividend</p>
        <p class="text-base text-gray-200">Players who manage their clock well <span class="text-white font-medium">play better in the last 5 turns</span> because they're relaxed and thinking clearly. Players in time trouble make panic decisions, miss scoring opportunities, and often give away 20-40 points in the final turns. Clock management is endgame preparation.</p>
      </div>

      <!-- Related Articles Aside -->
      <aside class="border-t border-gray-200 dark:border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/preparing-for-first-tournament/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group">
            <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Preparing for Your First Tournament — everything you need before game day</span>
          </a>
          <a href="/blog/mental-stamina-tournament-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group">
            <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Mental Stamina in Tournament Scrabble — staying sharp across 7 games</span>
          </a>
          <a href="/blog/endgame-strategy/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800 hover:border-amber-300 dark:hover:border-amber-700 hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-all group">
            <span class="text-amber-500 group-hover:translate-x-0.5 transition-transform">→</span>
            <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Endgame Strategy — winning the final turns with precise calculation</span>
          </a>
        </div>
