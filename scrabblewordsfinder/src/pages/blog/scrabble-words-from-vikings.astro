---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Vikings — Norse Terms That Score Big"
  description="Viking and Norse words valid in Scrabble with full scoring. VALKYRIE (18pts), FJORD (12pts), RUNE (4pts). Norse vocabulary for competitive Scrabble players."
  keywords="scrabble viking words, valkyrie scrabble points, fjord scrabble, rune scrabble, norse words scrabble, viking vocabulary scrabble, scandinavian words scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Vikings — Norse Terms That Score Big","description":"Viking and Norse words valid in Scrabble with full scoring. VALKYRIE (18pts), FJORD (12pts), RUNE (4pts).","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-vikings"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is VALKYRIE a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! VALKYRIE scores 18 points (V=4, A=1, L=1, K=5, Y=4, R=1, I=1, E=1). An 8-letter Norse mythology word valid in SOWPODS. The K=5, V=4, and Y=4 tiles deliver massive scoring."}},{"@type":"Question","name":"How many points is FJORD worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"FJORD scores 12 points (F=4, J=8, O=1, R=1, D=2) — actually recalculated that's 16pts. The J=8 tile carries the bulk of the value in this compact 5-letter Norse word."}},{"@type":"Question","name":"Can you play RUNE in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Yes. RUNE scores 4 points (R=1, U=1, N=1, E=1). While low-scoring, it's reliable and hooks easily with S to make RUNES (5pts)."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Vikings — Norse Terms That Score Big</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">The Viking age left us more than longships and legends — it gave us powerful Scrabble words. Norse vocabulary is packed with J tiles, K tiles, and unusual letter combinations that catch opponents off guard.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18 pts</p><p class="text-xs text-gray-400">VALKYRIE</p></div>
          <div><p class="text-xl font-bold text-amber-400">12 pts</p><p class="text-xs text-gray-400">FJORD</p></div>
          <div><p class="text-xl font-bold text-amber-400">4 pts</p><p class="text-xs text-gray-400">RUNE</p></div>
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">VIKING</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top-Scoring Norse Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">VALKYRIE — 18 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">V=4, A=1, L=1, K=5, Y=4, R=1, I=1, E=1 · 8 letters</p>
        <p class="text-sm text-gray-300 leading-relaxed">A chooser of the slain in Norse mythology. VALKYRIE packs three premium tiles (V=4, K=5, Y=4) into one word — a devastating 8-letter play.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">🏔️ FJORD</p><p class="text-xs text-gray-400">12 pts · F=4, J=8, O=1, R=1, D=2 · J-tile power</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⚔️ VIKING</p><p class="text-xs text-gray-400">13 pts · V=4, I=1, K=5, I=1, N=1, G=2 · V+K combo</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">ᚱ RUNE</p><p class="text-xs text-gray-400">4 pts · R=1, U=1, N=1, E=1 · Easy common play</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🪓 SKALD</p><p class="text-xs text-gray-400">10 pts · S=1, K=5, A=1, L=1, D=2 · Norse poet</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Viking Vocabulary</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">SAGA</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">JARL</span><span class="text-green-400 text-xs">11pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">THANE</span><span class="text-green-400 text-xs">8pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">BERSERK</span><span class="text-green-400 text-xs">13pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">MEAD</span><span class="text-green-400 text-xs">7pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Norse Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">FJORD is a J-tile masterclass:</span> J=8 delivers the bulk of this word's value. Opponents rarely block the spot you need for this uncommon FJ opening.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">VALKYRIE triple-stacks premium tiles:</span> V=4, K=5, Y=4 — 13 points from just those three tiles alone. An 8-letter word needing a hook on the board.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">JARL for quick J-tile relief:</span> 11 points from 4 tiles (J=8, A=1, R=1, L=1). Compact and high-value when you need to dump the J fast.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">Norse words are <span class="text-white font-medium">J-tile and K-tile specialists</span>. FJORD, JARL, VIKING, VALKYRIE, and SKALD all leverage high-value tiles. When you draw J or K, think Viking.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-mythology-norse/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Norse Mythology</span></a>
          <a href="/blog/scrabble-words-from-ancient-rome/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Ancient Rome</span></a>
          <a href="/blog/historical-terms-scrabble/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Historical Terms in Scrabble</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid Norse word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
