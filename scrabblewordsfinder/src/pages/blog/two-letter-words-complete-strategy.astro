---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Two-Letter Words — Complete Strategy Guide"
  description="How to use all 107 two-letter words strategically. Parallel plays, hooks, and board control."
  keywords="scrabble, two, letter, words, complete, strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Two-Letter Words — Complete Strategy Guide",
    "description": "How to use all 107 two-letter words strategically. Parallel plays, hooks, and board control.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/two-letter-words-complete-strategy" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why are two-letter words the most important words to learn in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Two-letter words unlock parallel plays (placing a word beside an existing one, creating multiple 2-letter combinations). A single parallel play can score 30-50+ points by forming 3-4 valid 2-letter words simultaneously. They also let you play in otherwise impossible tight board positions." }
      },
      {
        "@type": "Question",
        "name": "How many two-letter words are valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "TWL (North American) has 107 valid 2-letter words. SOWPODS (international) has 127. The difference includes words like ZO, CH, GU, and others valid only internationally. Memorizing all of them is considered the single highest-value study investment." }
      },
      {
        "@type": "Question",
        "name": "What are the highest-scoring two-letter words?",
        "acceptedAnswer": { "@type": "Answer", "text": "QI (11 pts) and ZA (11 pts) are tied as the highest-scoring 2-letter words. Next are XI, XU, AX, EX, OX (all 9 pts using X), then JO (9 pts using J). Even without premium squares, these outscore most 3-4 letter words." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/two-letter-words/" class="hover:text-blue-400 transition-colors text-gray-300">Two Letter Words</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Two-Letter Words — Complete Strategy Guide</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">How to use all 107 two-letter words strategically. Parallel plays, hooks, and board control.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
