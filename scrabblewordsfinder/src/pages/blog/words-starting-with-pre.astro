      <span class="inline-flex items-center gap-1 bg-gray-100 dark:bg-gray-800 rounded-full px-3 py-1 text-sm font-mono font-bold text-gray-900 dark:text-white">PREST <span class="text-amber-600 dark:text-amber-400 font-normal">7 pts</span></span>
    </div>

