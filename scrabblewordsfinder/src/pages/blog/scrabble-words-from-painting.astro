---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble Words from Painting — Artistic Terms That Score"
  description="Art and painting terms valid in Scrabble with full scoring. SKETCH (15pts), FRESCO (11pts), CANVAS (11pts). Brush up your Scrabble vocabulary with art words."
  keywords="scrabble painting words, sketch scrabble points, fresco scrabble, canvas scrabble, art words scrabble, painting vocabulary scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words from Painting — Artistic Terms That Score","description":"Art and painting terms valid in Scrabble with full scoring. SKETCH (15pts), FRESCO (11pts), CANVAS (11pts).","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-from-painting"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many points is SKETCH worth in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"SKETCH scores 15 points (S=1, K=5, E=1, T=1, C=3, H=4). The combination of K=5, C=3, and H=4 makes it one of the highest-scoring 6-letter art words."}},{"@type":"Question","name":"Is FRESCO a valid Scrabble word?","acceptedAnswer":{"@type":"Answer","text":"Yes! FRESCO scores 11 points (F=4, R=1, E=1, S=1, C=3, O=1). It means painting on wet plaster. Valid in both TWL and SOWPODS dictionaries."}},{"@type":"Question","name":"What art words score highest in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"Top painting/art words include SKETCH (15pts), FRESCO (11pts), CANVAS (11pts), VARNISH (13pts), and PIGMENT (12pts). SKETCH leads thanks to K=5 and H=4 tiles."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1"><a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a><span class="mx-1">›</span><span class="text-gray-300">Word Lists</span></nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words from Painting — Artistic Terms That Score</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400"><time datetime="2026-06-30">June 30, 2026</time><span class="w-1 h-1 rounded-full bg-gray-600"></span><span>5 min read</span><span class="w-1 h-1 rounded-full bg-gray-600"></span><a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a></div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">Art vocabulary paints a masterpiece on the Scrabble board. Words like SKETCH, FRESCO, and CANVAS combine high-value tiles K, H, F, and V with accessible letter patterns. Brush up on these terms and watch your scores become works of art.</p>
      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">15 pts</p><p class="text-xs text-gray-400">SKETCH</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">FRESCO</p></div>
          <div><p class="text-xl font-bold text-amber-400">11 pts</p><p class="text-xs text-gray-400">CANVAS</p></div>
          <div><p class="text-xl font-bold text-amber-400">13 pts</p><p class="text-xs text-gray-400">VARNISH</p></div>
        </div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top-Scoring Art Words</h2>
      <div class="not-prose my-8 p-6 rounded-2xl border-2 border-amber-500/50 bg-gradient-to-r from-amber-950/30 to-yellow-950/20 relative overflow-hidden">
        <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-amber-500/70">👑 Top Scorer</div>
        <p class="text-2xl font-black text-white tracking-wider mb-2">SKETCH — 15 Points</p>
        <p class="text-sm text-amber-300 font-semibold mb-3">S=1, K=5, E=1, T=1, C=3, H=4 · 6 letters</p>
        <p class="text-sm text-gray-300 leading-relaxed">A rough drawing or outline. SKETCH combines K=5, C=3, and H=4 for 12 points from just three tiles, with common letters S, E, T filling in. SKETCHY adds Y=4 for even more.</p>
      </div>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🎨 FRESCO</p><p class="text-xs text-gray-400">11 pts · F=4, R=1, E=1, S=1, C=3, O=1 · Wall painting</p></div>
        <div class="p-4 rounded-xl border border-cyan-500/30 bg-cyan-950/10"><p class="text-cyan-400 font-semibold text-sm mb-1">🖼️ CANVAS</p><p class="text-xs text-gray-400">11 pts · C=3, A=1, N=1, V=4, A=1, S=1 · Painting surface</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">✨ VARNISH</p><p class="text-xs text-gray-400">13 pts · V=4, A=1, R=1, N=1, I=1, S=1, H=4 · Glossy coat</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🖌️ PIGMENT</p><p class="text-xs text-gray-400">12 pts · P=3, I=1, G=2, M=3, E=1, N=1, T=1 · Color matter</p></div>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">More Painting Vocabulary</h2>
      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">EASEL</span><span class="text-green-400 text-xs">5pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">MURAL</span><span class="text-green-400 text-xs">7pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">PALETTE</span><span class="text-green-400 text-xs">9pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">GESSO</span><span class="text-green-400 text-xs">6pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">BRUSH</span><span class="text-green-400 text-xs">10pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-green-500/40 text-sm"><span class="text-white font-bold">OCHRE</span><span class="text-green-400 text-xs">10pts</span></span>
      </div>
      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">SKETCH extends to SKETCHY (19pts):</span> Adding Y=4 turns a 15-point word into 19 points — and SKETCHY uses 7 tiles for a bingo opportunity worth 69 total points.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">VARNISH is a 7-letter bingo:</span> At exactly 7 letters with V=4 and H=4, VARNISH scores 13 + 50 = 63 points as a bingo. Look for it when you hold V and H together.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">CANVAS uses the V effectively:</span> With V=4 embedded between common vowels, CANVAS is easy to spot and play. CANVASES extends to 8 letters for bingo potential.</p></div>
      </div>
      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">�� Key Insight</p>
        <p class="text-base text-gray-200">Art words combine <span class="text-white font-medium">K, H, F, and V tiles</span> with common letter patterns. SKETCH, VARNISH, and FRESCO all deliver 11+ points while using tiles that often sit unused on racks. Think gallery when your tiles feel artistic.</p>
      </div>
      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/scrabble-words-from-photography/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Photography</span></a>
          <a href="/blog/scrabble-words-from-ceramics/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words from Ceramics</span></a>
          <a href="/blog/scrabble-color-words/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Color Words</span></a>
        </div>
      </aside>
      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl shadow-sm">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every valid art word instantly — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center"><a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a></div>
    </article>
  </div>
</BlogLayout>
