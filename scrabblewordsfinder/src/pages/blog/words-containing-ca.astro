---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing CA — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing CA with scores, definitions, and strategic tips. Master CA words for better Scrabble plays."
  keywords="scrabble words containing ca, ca words scrabble, words with ca, scrabble ca word list, ca scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing CA — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing CA with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-ca" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring CA words?", "acceptedAnswer": { "@type": "Answer", "text": "Top CA words include CATALYZE (22 pts), CACHEXIA (22 pts), CAPSIZE (20 pts), CAVALRY (15 pts), and CATCH (12 pts). CA words with Z, X, or Y score highest." } },
      { "@type": "Question", "name": "How many Scrabble words contain CA?", "acceptedAnswer": { "@type": "Answer", "text": "Over 1,400 valid Scrabble words contain CA. The CA- prefix is one of the most productive in English: CAT, CAP, CAR, CAKE, CALL, CAME, CAMP, CARD, CARE, CASE, CASH, and hundreds more." } },
      { "@type": "Question", "name": "What strategy works with CA tiles?", "acceptedAnswer": { "@type": "Answer", "text": "CA gives you near-guaranteed plays since CA- starts so many words. Focus on CATCH (12 pts) and CAKE (10 pts) for quick scores. Hold C when you have A because CA combinations are almost always available on the board." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing CA — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">CA is one of the most productive letter pairs in English and Scrabble, appearing in over 1,400 valid words. From simple plays like CAT, CAP, and CAR to high-scorers like CAPSIZE and CATALYZE, CA provides endless options. With C worth 3 points and A being the most common vowel, this pair appears frequently and plays easily.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top CA Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">CAPSIZE</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">To overturn a boat</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">CATALYZE</td><td class="px-4 py-3 text-blue-400">22</td><td class="px-4 py-3 text-gray-400">To speed a reaction</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">CACHEXIA</td><td class="px-4 py-3 text-blue-400">22</td><td class="px-4 py-3 text-gray-400">Severe weight loss</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">CAVALRY</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">Mounted soldiers</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">CAPTURE</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">To seize</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">CANVAS</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A strong fabric</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">CASTLE</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">A fortified building</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">CATCH</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To grab</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">CALM</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">Peaceful</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">CAKE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A baked dessert</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">CAT</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A feline</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">1,400+</p><p class="text-xs text-gray-400">Valid CA words</p></div>
          <div><p class="text-xl font-bold text-amber-400">8 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Very Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy Tips for CA Words</h2>

      <p>CA starts an enormous number of words: CAT, CAP, CAR, CAKE, CALL, CAME, CAMP, CARD, CARE, CASE, CASH, CAST, CAVE. The sheer volume means you will always find a CA play. CATCH (12 pts) and CAKE (10 pts) are strong medium-length options.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAPSIZE</span><span class="text-blue-400 text-xs">20 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CATALYZE</span><span class="text-blue-400 text-xs">22 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CACHEXIA</span><span class="text-blue-400 text-xs">22 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAVALRY</span><span class="text-blue-400 text-xs">15 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAPTURE</span><span class="text-blue-400 text-xs">11 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CANVAS</span><span class="text-blue-400 text-xs">11 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">CA is one of Scrabble's <span class="text-white font-medium">most prolific pairs with 1,400+ words</span>. You will rarely be stuck with C and A since CA- starts hundreds of common words. CATCH (12 pts) and CAKE (10 pts) are reliable mid-range scorers, while CAPSIZE (20 pts) rewards longer plays.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every CA word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>