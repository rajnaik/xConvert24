            <tr class="bg-gray-900"><td class="px-4 py-2">C</td><td class="px-4 py-2">2</td><td class="px-4 py-2">3</td><td class="px-4 py-2">P</td><td class="px-4 py-2">2</td><td class="px-4 py-2">3</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2">D</td><td class="px-4 py-2">4</td><td class="px-4 py-2">2</td><td class="px-4 py-2">Q</td><td class="px-4 py-2">1</td><td class="px-4 py-2">10</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2">E</td><td class="px-4 py-2">12</td><td class="px-4 py-2">1</td><td class="px-4 py-2">R</td><td class="px-4 py-2">6</td><td class="px-4 py-2">1</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-2">F</td><td class="px-4 py-2">2</td><td class="px-4 py-2">4</td><td class="px-4 py-2">S</td><td class="px-4 py-2">4</td><td class="px-4 py-2">1</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-2">G</td><td class="px-4 py-2">3</td><td class="px-4 py-2">2</td><td class="px-4 py-2">T</td><td class="px-4 py-2">6</td><td class="px-4 py-2">1</td></tr>
