            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">16</td><td class="px-4 py-3 text-white font-medium">SUTURE</td><td class="px-4 py-3 text-blue-400">6</td><td class="px-4 py-3 text-gray-400">S1+U1+T1+U1+R1+E1</td><td class="px-4 py-3 text-gray-400">Surgery</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">17</td><td class="px-4 py-3 text-white font-medium">AORTA</td><td class="px-4 py-3 text-blue-400">5</td><td class="px-4 py-3 text-gray-400">A1+O1+R1+T1+A1</td><td class="px-4 py-3 text-gray-400">Cardio</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">18</td><td class="px-4 py-3 text-white font-medium">ULNA</td><td class="px-4 py-3 text-blue-400">4</td><td class="px-4 py-3 text-gray-400">U1+L1+N1+A1</td><td class="px-4 py-3 text-gray-400">Bone</td></tr>
