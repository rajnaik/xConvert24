            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">VERTEX</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">V4+E1+R1+T1+E1+X8</td><td class="px-4 py-3 text-gray-400">Anatomy</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">THORAX</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">T1+H4+O1+R1+A1+X8</td><td class="px-4 py-3 text-gray-400">Anatomy</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">THROMBUS</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">T1+H4+R1+O1+M3+B3+U1+S1</td><td class="px-4 py-3 text-gray-400">Cardio</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">LYMPH</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">L1+Y4+M3+P3+H4</td><td class="px-4 py-3 text-gray-400">System</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">THYMUS</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">T1+H4+Y4+M3+U1+S1</td><td class="px-4 py-3 text-gray-400">Organ</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">KIDNEY</td><td class="px-4 py-3 text-blue-400">14</td><td class="px-4 py-3 text-gray-400">K5+I1+D2+N1+E1+Y4</td><td class="px-4 py-3 text-gray-400">Organ</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">FIBULA</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">F4+I1+B3+U1+L1+A1</td><td class="px-4 py-3 text-gray-400">Bone</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">PELVIS</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">P3+E1+L1+V4+I1+S1</td><td class="px-4 py-3 text-gray-400">Bone</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">FEMUR</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">F4+E1+M3+U1+R1</td><td class="px-4 py-3 text-gray-400">Bone</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">PLASMA</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">P3+L1+A1+S1+M3+A1</td><td class="px-4 py-3 text-gray-400">Blood</td></tr>
