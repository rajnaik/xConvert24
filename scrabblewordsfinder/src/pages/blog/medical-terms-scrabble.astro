            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">12</td><td class="px-4 py-3 text-white font-medium">CORNEA</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">C3+O1+R1+N1+E1+A1</td><td class="px-4 py-3 text-gray-400">Eye</td></tr>
