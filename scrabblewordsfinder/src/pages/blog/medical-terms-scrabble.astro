  description="Discover 18 medical terms valid in Scrabble with point values. From THORAX to THROMBUS, master anatomy and health vocabulary that scores big. Free tool."
  keywords="medical terms scrabble, anatomy words scrabble, health words scrabble, valid medical vocabulary, scrabble anatomy list, body parts scrabble"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Medical Terms Valid in Scrabble — Anatomy & Health",
    "description": "Discover 18 medical terms valid in Scrabble with point values and strategy tips for playing anatomy and health vocabulary.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/medical-terms-scrabble" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are drug brand names valid in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Drug brand names like Tylenol, Advil, and Prozac are proper nouns and never valid in Scrabble. However, generic medical terms, anatomy words, and scientific descriptions of body parts and conditions are valid: FEMUR, AORTA, SPLEEN, THYMUS, LYMPH, THORAX, and many more." }
      },
      {
        "@type": "Question",
        "name": "What is the highest-scoring medical word in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "VERTEX scores 16 points (V4+E1+R1+T1+E1+X8) and THORAX scores 16 points (T1+H4+O1+R1+A1+X8) — both use the X tile (8 pts) for heavy scoring. THROMBUS scores 15 points (T1+H4+R1+O1+M3+B3+U1+S1) and LYMPH scores 15 points (L1+Y4+M3+P3+H4) without needing rare tiles." }
      },
      {
        "@type": "Question",
        "name": "Is AORTA a valid Scrabble word?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes! AORTA is valid in both TWL and SOWPODS. It scores only 5 points (A1+O1+R1+T1+A1) but is useful for dumping vowels when your rack is vowel-heavy. AORTA uses three vowels in a 5-letter word, helping balance your rack for the next draw." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
