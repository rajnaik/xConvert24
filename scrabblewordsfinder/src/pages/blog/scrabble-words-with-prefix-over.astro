---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words With Prefix OVER- — OVERWORK, OVERTAKE, OVERLAP" description="Top OVER- prefix Scrabble words: OVERWORK (18pts), OVERTAKE (15pts), OVERLAP (12pts). Master the direction and excess prefix for high-scoring plays." keywords="scrabble over prefix words, overwork scrabble, overtake scrabble, overlap scrabble, over prefix strategy, excess prefix scrabble">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Scrabble Words With Prefix OVER- — OVERWORK, OVERTAKE, OVERLAP","description":"Master OVER- prefix words in Scrabble: OVERWORK (18pts), OVERTAKE (15pts), OVERLAP (12pts) with direction and excess prefix strategy.","datePublished":"2026-06-30","author":{"@type":"Organization","name":"ScrabbleWordsFinder.com","url":"https://www.scrabblewordsfinder.com"},"publisher":{"@type":"Organization","name":"ScrabbleWordsFinder.com"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.scrabblewordsfinder.com/blog/scrabble-words-with-prefix-over"}})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are the best OVER- prefix words in Scrabble?","acceptedAnswer":{"@type":"Answer","text":"OVERWORK scores 18 points with W(4)+K(5) making up most of the value. OVERTAKE scores 15 points with K(5) as the key letter. OVERLAP scores 12 points using P(3) for reliable mid-range scoring. All are 7-8 letters — bingo territory."}},{"@type":"Question","name":"Can OVER- prefix words score bingo bonuses?","acceptedAnswer":{"@type":"Answer","text":"Yes — many OVER- words are 7-8 letters, qualifying for the 50-point bingo bonus. OVERTAKE (8 letters), OVERWORK (8 letters), and OVERCOME (8 letters) all hit bingo length. Even without the bonus, their base scores are strong."}},{"@type":"Question","name":"How many valid OVER- words exist in the Scrabble dictionary?","acceptedAnswer":{"@type":"Answer","text":"Over 300 valid OVER- words exist in SOWPODS. The prefix means excess or above. Because OVER uses 4 common tiles (O+V+E+R), it is easy to draw naturally without forcing your rack."}}]})} />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Strategy</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-4">Scrabble Words With Prefix OVER- — Direction & Excess</h1>
      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-30">June 30, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>
      <p class="text-lg leading-relaxed text-gray-300 mb-8">OVER- is the bingo-builder prefix. At 4 tiles (O+V+E+R), it creates 7-8 letter words that qualify for the 50-point bingo bonus. OVERWORK delivers 18 base points with W(4) and K(5), OVERTAKE hits 15 with that K(5), and OVERLAP provides a reliable 12. The prefix tiles cost only 5 points total but grant access to 300+ valid words — many at bingo length.</p>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">18</p><p class="text-xs text-gray-400">Top Score (OVERWORK)</p></div>
          <div><p class="text-xl font-bold text-amber-400">4</p><p class="text-xs text-gray-400">Prefix Tiles (OVER)</p></div>
          <div><p class="text-xl font-bold text-amber-400">300+</p><p class="text-xs text-gray-400">Valid OVER- Words</p></div>
          <div><p class="text-xl font-bold text-amber-400">5pts</p><p class="text-xs text-gray-400">Prefix Cost (O+V+E+R)</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top OVER- Prefix Words</h2>
      <div class="not-prose my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 OVERWORK</p><p class="text-xs text-gray-400">18 points · 8 letters · W(4)+K(5) dominate · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-green-500/30 bg-green-950/10"><p class="text-green-400 font-semibold text-sm mb-1">🏆 OVERTAKE</p><p class="text-xs text-gray-400">15 points · 8 letters · K(5)+V(4) strong pair · Bingo</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ OVERLAP</p><p class="text-xs text-gray-400">12 points · 7 letters · V(4)+P(3) combo · Bingo eligible</p></div>
        <div class="p-4 rounded-xl border border-amber-500/30 bg-amber-950/10"><p class="text-amber-400 font-semibold text-sm mb-1">⭐ OVERCOME</p><p class="text-xs text-gray-400">15 points · 8 letters · V(4)+C(3)+M(3) spread · Bingo</p></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">OVER- Prefix Strategy</h2>
      <div class="not-prose my-6 grid grid-cols-1 gap-4">
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Bingo factory:</span> OVER- + 3-4 base letters = 7-8 letter bingo. OVERTAKE, OVERWORK, OVERCOME all hit bingo length. Hold O+V+E+R when you see common base letters in your rack.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Natural draw probability:</span> O, E, R are very common tiles (O×8, E×12, R×6). V is the bottleneck at only 2 tiles — prioritise holding it when you see O, E, R nearby on your rack.</p></div>
        <div class="p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 hover:border-purple-400 transition-colors"><p class="text-sm text-gray-300"><span class="text-purple-400 font-semibold">Front hook WORK, TAKE, LAP:</span> If your opponent plays WORK, TAKE, or LAP, adding OVER in front creates the full scoring word. Four tiles placed, full 7-8 letter score claimed.</p></div>
      </div>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OVERWORK</span><span class="text-blue-400 text-xs">18pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OVERTAKE</span><span class="text-blue-400 text-xs">15pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OVERLAP</span><span class="text-blue-400 text-xs">12pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">OVERCOME</span><span class="text-blue-400 text-xs">15pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">💡 Key Insight</p>
        <p class="text-base text-gray-200">OVER- is one of the few <span class="text-white font-medium">4-letter prefixes that consistently creates bingo-length words</span>. At 8 letters, OVERWORK and OVERTAKE earn the 50-point bonus on top of strong base scores. V is your bottleneck — hold it when you see O, E, R nearby.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-starting-with-over/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Starting With OVER</span></a>
          <a href="/blog/scrabble-words-with-prefix-out/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix OUT-</span></a>
          <a href="/blog/scrabble-words-with-prefix-un/" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Scrabble Words With Prefix UN-</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-cyan-900/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find all OVER- prefix words from your tiles — free Scrabble solver, no sign-up</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
        </div>
      </div>
      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
