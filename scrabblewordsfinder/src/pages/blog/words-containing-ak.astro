---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing AK — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing AK with scores, definitions, and strategic tips. Find AK words for your next winning play."
  keywords="scrabble words containing ak, ak words scrabble, words with ak, scrabble ak word list, ak scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing AK — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing AK with scores, definitions, and strategic tips. Find AK words for your next winning play.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-ak" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the highest-scoring AK words in Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Top AK words include KAYAK (20 pts), SHAKE (12 pts), AWAKE (12 pts), FAKE (11 pts), MAKER (11 pts), and CAKE/BAKE (10 pts each). The 5-point K tile makes all AK words score above average." }
      },
      {
        "@type": "Question",
        "name": "How many valid Scrabble words contain AK?",
        "acceptedAnswer": { "@type": "Answer", "text": "Around 350 valid Scrabble words contain AK. The -AKE ending alone gives you dozens of options (BAKE, CAKE, FAKE, LAKE, MAKE, RAKE, SAKE, TAKE, WAKE)." }
      },
      {
        "@type": "Question",
        "name": "What strategy works for AK words?",
        "acceptedAnswer": { "@type": "Answer", "text": "Target premium squares with the K tile. K on a DLS scores 10 points for one letter. The -AKE pattern accepts many consonants (B, C, F, L, M, R, S, T, W) making it easy to find plays." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing AK — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">The AK pair combines the common A with the valuable K tile (5 points). This pairing creates consistently high-scoring words even at short lengths. From BAKE and CAKE to KAYAK and AWAKE, AK words deliver strong per-tile efficiency. The K tile appears only once in the bag, so making the most of it when paired with A is essential strategy.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top AK Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">KAYAK</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">A small boat</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">AWAKE</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">Not asleep</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">MAKER</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">One who makes</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">SHAKE</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To vibrate</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">CAKE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">A baked dessert</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">BAKE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">To cook in an oven</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">FAKE</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">Not genuine</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">LAKE</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">A body of water</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">MAKE</td><td class="px-4 py-3 text-blue-400">10</td><td class="px-4 py-3 text-gray-400">To create</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">10</td><td class="px-4 py-3 text-white font-medium">TAKE</td><td class="px-4 py-3 text-blue-400">8</td><td class="px-4 py-3 text-gray-400">To grab</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">11</td><td class="px-4 py-3 text-white font-medium">AKE</td><td class="px-4 py-3 text-blue-400">7</td><td class="px-4 py-3 text-gray-400">To suffer pain</td></tr>
          </tbody>
        </table>
      </div>

      <div class="not-prose my-6 p-4 rounded-xl border border-amber-500/30 bg-amber-950/10">
        <div class="flex flex-wrap items-center justify-center gap-6 text-center">
          <div><p class="text-xl font-bold text-amber-400">~350</p><p class="text-xs text-gray-400">Valid AK words</p></div>
          <div><p class="text-xl font-bold text-amber-400">10 pts</p><p class="text-xs text-gray-400">Average score</p></div>
          <div><p class="text-xl font-bold text-amber-400">Common</p><p class="text-xs text-gray-400">Pair rarity</p></div>
        </div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">The -AKE Ending Power</h2>

      <p>The -AKE ending is one of the most productive patterns in Scrabble. With K worth 5 points, every -AKE word scores at minimum 7 points before the leading consonant.</p>

      <div class="not-prose my-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">BAKE</span><span class="text-blue-400 text-xs">10 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">CAKE</span><span class="text-blue-400 text-xs">10 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">FAKE</span><span class="text-blue-400 text-xs">11 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">LAKE</span><span class="text-blue-400 text-xs">8 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">MAKE</span><span class="text-blue-400 text-xs">10 pts</span></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm"><span class="text-white font-bold">SHAKE</span><span class="text-blue-400 text-xs">12 pts</span></span>
      </div>

      <div class="not-prose my-6 p-5 rounded-xl border border-blue-500/30 bg-blue-950/20">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-wider mb-2">🎯 Key Takeaway</p>
        <p class="text-base text-gray-200">AK words benefit from the <span class="text-white font-medium">5-point K tile</span> making every play score well. The -AKE ending (BAKE, CAKE, FAKE, LAKE, MAKE, SHAKE, WAKE) is one of the most reliable scoring patterns. Place K on a double-letter square for devastating results.</p>
      </div>

      <aside class="border-t border-gray-800 mt-12 pt-8 not-prose">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h3>
        <div class="grid gap-3">
          <a href="/blog/words-containing-qu" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words Containing QU — Essential Scrabble Q Words</span></a>
          <a href="/blog/words-with-multiple-vowels" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Words With Multiple Vowels — Scrabble Vowel Dumps</span></a>
          <a href="/blog/four-letter-words-every-player-should-know" class="flex items-center gap-3 p-3 rounded-lg border border-gray-800 hover:border-blue-700 hover:bg-blue-900/10 transition-all group"><span class="text-blue-500 group-hover:translate-x-0.5 transition-transform">→</span><span class="text-sm text-gray-300 group-hover:text-blue-400 transition-colors">Four-Letter Words Every Scrabble Player Should Know</span></a>
        </div>
      </aside>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find every AK word from your tiles — instant results, no signup</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>