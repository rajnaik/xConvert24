---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Celebrity Scrabble Players"
  description="Famous people who love Scrabble. From presidents to actors, the celebrities who play competitively."
  keywords="scrabble, celebrity, scrabble, players"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Celebrity Scrabble Players",
    "description": "Famous people who love Scrabble. From presidents to actors, the celebrities who play competitively.",
    "datePublished": "2026-06-15",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/celebrity-scrabble-players" }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which celebrities are known for playing Scrabble?",
        "acceptedAnswer": { "@type": "Answer", "text": "Notable celebrity Scrabble players include Keanu Reeves, Sting, Chris Martin, Kylie Minogue, and former US President Richard Nixon. Many Hollywood actors and musicians are avid players." }
      },
      {
        "@type": "Question",
        "name": "Do celebrities compete in Scrabble tournaments?",
        "acceptedAnswer": { "@type": "Answer", "text": "Some celebrities participate in charity Scrabble events, though most play casually. The National Scrabble Championship and World Scrabble Championship are dominated by dedicated competitive players rather than celebrities." }
      },
      {
        "@type": "Question",
        "name": "What celebrity has won a Scrabble championship?",
        "acceptedAnswer": { "@type": "Answer", "text": "No mainstream celebrity has won a major Scrabble championship. Champions like Nigel Richards and David Eldar are professional word game players who dedicate full-time study to competitive play." }
      }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <a href="/blog/tournament/" class="hover:text-blue-400 transition-colors text-gray-300">Tournament</a>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Celebrity Scrabble Players</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-15">June 15, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>5 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">Famous people who love Scrabble. From presidents to actors, the celebrities who play competitively.</p>

      <div class="not-prose mt-10 p-5 bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <p class="text-sm text-blue-300 font-medium">🔤 Find your highest-scoring words — free, instant, no signup needed</p>
          <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 text-gray-950 text-sm font-semibold transition-colors">Open Word Finder →</a>
        </div>
      </div>

      <div class="not-prose mt-8 text-center">
        <a href="/blog/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">← Back to all articles</a>
      </div>
    </article>
  </div>
</BlogLayout>
