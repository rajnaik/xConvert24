---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Scrabble History & Culture — Origins, Champions & Records"
  description="Explore the history, culture, and community of Scrabble. From its 1938 invention to world championships, famous controversies, and the game's global reach."
  keywords="scrabble history, who invented scrabble, scrabble world champions, scrabble records, famous scrabble games, scrabble culture"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Who invented Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Alfred Mosher Butts, an American architect, invented the game in 1938 during the Great Depression. He originally called it 'Criss-Crosswords'. James Brunot later bought the rights and renamed it 'Scrabble' in 1948." } },
      { "@type": "Question", "name": "When was the highest Scrabble score ever recorded?", "acceptedAnswer": { "@type": "Answer", "text": "The highest confirmed competitive game score is 830 points, achieved by Michael Cresta in 2006 at a sanctioned tournament in Massachusetts, USA." } },
      { "@type": "Question", "name": "How many countries play competitive Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Competitive Scrabble is played in over 120 countries with national associations. The World Scrabble Championship draws players from 40+ nations." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/blog/" class="hover:text-blue-400 transition-colors">← Blog</a>
      <span class="mx-1">›</span>
      <span class="text-gray-300">History & Culture</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-4">History & Culture</h1>
    <p class="text-lg text-gray-300 mb-6">
      The story of Scrabble — from a Depression-era invention to a global phenomenon played in 120+ countries.
      Champions, controversies, records, and the community that keeps the game alive.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose mt-8">
      <a href="/blog/history-of-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">History of Scrabble</a>
      <a href="/blog/who-invented-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Who invented Scrabble</a>
      <a href="/blog/scrabble-around-the-world/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Scrabble around the world</a>
      <a href="/blog/scrabble-in-different-languages/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Scrabble in different languages</a>
      <a href="/blog/scrabble-world-champions/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">World champions</a>
      <a href="/blog/greatest-scrabble-players/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Greatest players</a>
      <a href="/blog/celebrity-scrabble-players/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Celebrity players</a>
      <a href="/blog/famous-scrabble-matches/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Famous matches</a>
      <a href="/blog/famous-scrabble-controversies/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Famous controversies</a>
      <a href="/blog/record-breaking-scrabble-games/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Record-breaking games</a>
      <a href="/blog/scrabble-rating-system-explained/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Rating system explained</a>
      <a href="/blog/psychology-of-scrabble/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Psychology of Scrabble</a>
      <a href="/blog/scrabble-and-mathematics/" class="px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-amber-500 text-sm text-gray-300 hover:text-amber-400 transition-colors">Scrabble & mathematics</a>
    </div>

    <div class="not-prose mt-12 p-5 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border border-blue-200 dark:border-blue-800 rounded-xl shadow-sm">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <p class="text-sm text-blue-800 dark:text-blue-300 font-medium">Try our free Scrabble Word Finder</p>
        <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors shadow-sm">Open Word Finder →</a>
      </div>
    </div>
    <div class="not-prose mt-8 text-center">
      <a href="/blog/" class="text-sm text-gray-400 hover:text-amber-500 transition-colors">← Back to all articles</a>
    </div>
  </div>
</BlogLayout>
