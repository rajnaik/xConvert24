---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout title="Scrabble Words Ending in AA — Double-A Endings" description="Discover valid Scrabble words ending in AA like KRAAL, SALAAM, and BAAL. These borrowed words from Afrikaans and Arabic are legitimate plays in SOWPODS." keywords="words ending in aa, scrabble aa words, double a words, kraal scrabble, salaam scrabble, baal scrabble, aa ending words">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scrabble Words Ending in AA — Double-A Endings",
    "description": "Discover valid Scrabble words ending in AA — borrowed words that clear vowel-heavy racks.",
    "datePublished": "2026-06-22",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" }
  })}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What Scrabble words end in AA?", "acceptedAnswer": { "@type": "Answer", "text": "Valid Scrabble words ending in AA include KRAAL (9pts), SALAAM (8pts), BAAL (6pts), and in SOWPODS: NAAM (6pts), TAAL (4pts), and NAAN (4pts). Most are borrowed from Afrikaans or Arabic." }},
      { "@type": "Question", "name": "Is AA itself a valid Scrabble word?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. AA is a valid 2-letter word in both TWL and SOWPODS, meaning a type of rough volcanic lava. It scores just 2 points but is useful for parallel plays and vowel dumping." }},
      { "@type": "Question", "name": "Are double-A words common in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "No — words ending in AA are rare in English. Most come from loanwords (Afrikaans, Arabic, Hindi). However, knowing them gives you an edge when stuck with multiple A tiles." }}
    ]
  })}></script>

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6">
        <a href="/blog" class="hover:text-white">← Blog</a> <span class="mx-2">›</span> <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Scrabble Words Ending in AA</h1>
      <p class="text-gray-400 text-sm mb-8">Updated June 22, 2026 · 3 min read</p>

      <p class="text-lg text-gray-300 leading-relaxed mb-8">Double-A endings are exotic in English — nearly all come from loanwords. In Scrabble, these AA-enders help you clear duplicate A tiles while scoring respectable points. Here's the complete list.</p>

      <div class="border border-amber-500/30 bg-amber-950/10 rounded-xl p-6 mb-10 grid grid-cols-3 gap-4 text-center">
        <div><span class="text-amber-400 text-2xl font-bold">8+</span><br><span class="text-gray-400 text-sm">Valid AA words</span></div>
        <div><span class="text-amber-400 text-2xl font-bold">9pts</span><br><span class="text-gray-400 text-sm">Top scorer (KRAAL)</span></div>
        <div><span class="text-amber-400 text-2xl font-bold">2</span><br><span class="text-gray-400 text-sm">A tiles cleared per word</span></div>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Complete AA-Ending Word List</h2>

      <div class="overflow-x-auto mb-8">
        <table class="w-full border border-gray-700 rounded-lg text-sm">
          <thead class="bg-gray-800"><tr><th class="p-3 text-left text-gray-300">Word</th><th class="p-3 text-left text-gray-300">Points</th><th class="p-3 text-left text-gray-300">Dictionary</th><th class="p-3 text-left text-gray-300">Origin & Meaning</th></tr></thead>
          <tbody>
            <tr class="bg-gray-900"><td class="p-3 text-white font-bold">KRAAL</td><td class="p-3 text-blue-400">9</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Afrikaans — a livestock enclosure</td></tr>
            <tr class="bg-gray-800/50"><td class="p-3 text-white font-bold">SALAAM</td><td class="p-3 text-blue-400">8</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Arabic — a greeting of peace</td></tr>
            <tr class="bg-gray-900"><td class="p-3 text-white font-bold">BAAL</td><td class="p-3 text-blue-400">6</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Semitic — a false god or idol</td></tr>
            <tr class="bg-gray-800/50"><td class="p-3 text-white font-bold">NAAN</td><td class="p-3 text-blue-400">4</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Hindi — a type of flatbread</td></tr>
            <tr class="bg-gray-900"><td class="p-3 text-white font-bold">NAAM</td><td class="p-3 text-blue-400">6</td><td class="p-3 text-gray-300">SOWPODS</td><td class="p-3 text-gray-400">Afrikaans — seizure of property</td></tr>
            <tr class="bg-gray-800/50"><td class="p-3 text-white font-bold">TAAL</td><td class="p-3 text-blue-400">4</td><td class="p-3 text-gray-300">SOWPODS</td><td class="p-3 text-gray-400">Afrikaans — the Afrikaans language</td></tr>
            <tr class="bg-gray-900"><td class="p-3 text-white font-bold">KRAAL</td><td class="p-3 text-blue-400">9</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Can also be used as a verb (to pen)</td></tr>
            <tr class="bg-gray-800/50"><td class="p-3 text-white font-bold">AA</td><td class="p-3 text-blue-400">2</td><td class="p-3 text-gray-300">TWL + SOWPODS</td><td class="p-3 text-gray-400">Volcanic lava with a rough surface</td></tr>
          </tbody>
        </table>
      </div>

      <div class="border border-blue-500/30 bg-blue-950/20 rounded-xl p-6 mb-8">
        <p class="text-blue-400 font-semibold mb-2">Quick Insight</p>
        <p class="text-gray-300">AA (rough lava) is one of the shortest valid English words and appears in both major Scrabble dictionaries. It comes from Hawaiian and is pronounced "ah-ah." Geologists use it to describe a specific type of basaltic lava flow.</p>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Strategy for Double-A Racks</h2>

      <div class="border border-purple-500/30 bg-purple-950/20 rounded-xl p-6 mb-8">
        <p class="text-purple-400 font-semibold mb-2">Strategy Tips</p>
        <ul class="text-gray-300 space-y-2 list-disc pl-5">
          <li><span class="text-purple-400 font-bold">Dump duplicate A's:</span> With 9 A tiles in the bag, drawing 2-3 A's is common. KRAAL, BAAL, and SALAAM clear them efficiently.</li>
          <li><span class="text-purple-400 font-bold">KRAAL is your best bet:</span> At 9 points with common tiles (K, R, A, A, L), it's the highest-scoring AA-ender you'll realistically play.</li>
          <li><span class="text-purple-400 font-bold">Hook onto existing A:</span> If the board has a word ending in A, add another A to form AA, then extend to BAAL or KRAAL.</li>
          <li><span class="text-purple-400 font-bold">SOWPODS advantage:</span> International players get NAAM and TAAL as extra options — memorize these for tournament play.</li>
        </ul>
      </div>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Words With Double Letters (Comparison)</h2>

      <div class="flex flex-wrap gap-3 mb-10">
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">AA</span> <span class="text-blue-400 text-xs">2pts</span></span>
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">AARDVARK</span> <span class="text-blue-400 text-xs">16pts</span></span>
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">BAAL</span> <span class="text-blue-400 text-xs">6pts</span></span>
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">KRAAL</span> <span class="text-blue-400 text-xs">9pts</span></span>
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">SALAAM</span> <span class="text-blue-400 text-xs">8pts</span></span>
        <span class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2"><span class="text-white font-bold">NAAN</span> <span class="text-blue-400 text-xs">4pts</span></span>
      </div>

      <div class="border border-indigo-500/30 bg-indigo-950/10 rounded-xl p-6 mb-8">
        <p class="text-indigo-400 font-semibold mb-2">Related Reads</p>
        <ul class="text-gray-300 space-y-1">
          <li><a href="/blog/common-foreign-origin-scrabble-words" class="text-indigo-400 hover:underline">Common Foreign-Origin Scrabble Words</a></li>
          <li><a href="/blog/words-ending-in-ai" class="text-indigo-400 hover:underline">Words Ending in AI</a></li>
        </ul>
      </div>

      <div class="bg-gradient-to-r from-blue-900/20 to-blue-800/20 border border-blue-800 rounded-xl p-6 text-center mb-10">
        <p class="text-white font-semibold mb-2">Too Many A Tiles?</p>
        <p class="text-gray-300 mb-4">Enter your rack and our solver finds every AA-word and vowel-dump play available.</p>
        <a href="/" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-lg transition">Try the Word Finder →</a>
      </div>

      <aside class="border-t border-gray-800 pt-8 mt-12">
        <p class="text-gray-400 text-sm mb-4">Related Articles</p>
        <div class="grid gap-3">
          <a href="/blog/common-foreign-origin-scrabble-words" class="block border border-gray-800 hover:border-blue-700 rounded-lg p-4 transition"><span class="text-white">Foreign-Origin Scrabble Words</span><br><span class="text-gray-400 text-sm">Borrowed words that are valid plays</span></a>
          <a href="/blog/four-vowel-words" class="block border border-gray-800 hover:border-blue-700 rounded-lg p-4 transition"><span class="text-white">Words With Four Vowels</span><br><span class="text-gray-400 text-sm">More options for vowel-heavy racks</span></a>
        </div>
      </aside>

      <div class="mt-8"><a href="/blog" class="text-gray-400 hover:text-white text-sm">← Back to Blog</a></div>
    </article>
  </div>
</BlogLayout>
