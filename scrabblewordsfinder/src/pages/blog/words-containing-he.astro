---
export const prerender = true;
import BlogLayout from '../../layouts/BlogLayout.astro';
import '../../styles/global.css';
---

<BlogLayout
  title="Words Containing HE — Scrabble Word List & Strategy"
  description="Complete list of Scrabble words containing HE with scores, definitions, and strategic tips. Master HE words for better Scrabble plays."
  keywords="scrabble words containing he, he words scrabble, words with he, scrabble he word list, he scrabble strategy"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Words Containing HE — Scrabble Word List & Strategy",
    "description": "Complete list of Scrabble words containing HE with scores, definitions, and strategic tips.",
    "datePublished": "2026-06-14",
    "author": { "@type": "Organization", "name": "ScrabbleWordsFinder.com", "url": "https://www.scrabblewordsfinder.com" },
    "publisher": { "@type": "Organization", "name": "ScrabbleWordsFinder.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.scrabblewordsfinder.com/blog/words-containing-he" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the highest-scoring HE words in Scrabble?", "acceptedAnswer": { "@type": "Answer", "text": "Top HE words include BEWITCHED (20 pts), ALCHEMY (17 pts), KITCHEN (16 pts), WHETHER (16 pts), and ACHIEVE (15 pts). HE is the most common H-pair in Scrabble." } },
      { "@type": "Question", "name": "How many Scrabble words contain HE?", "acceptedAnswer": { "@type": "Answer", "text": "Over 1,500 valid Scrabble words contain HE. Common examples include HE, HER, HEW, HELP, HERE, HEAT, THEM, THEN, THEIR, THEME, SCHEME, SPHERE, WEATHER, and KITCHEN." } },
      { "@type": "Question", "name": "What strategy works best with HE tiles?", "acceptedAnswer": { "@type": "Answer", "text": "HE starts many words (HE, HER, HELP, HERE, HEAT, HEAVY) and appears mid-word in THEM, THEN, THEIR, SCHEME, SPHERE, WEATHER, KITCHEN, WHETHER. The -THE pattern (BREATHE, SOOTHE) and -CHE pattern (SCHEME, KITCHEN) score strongly." } }
    ]
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-gray max-w-none">
      <nav class="text-sm text-gray-400 mb-6 not-prose flex items-center gap-1">
        <a href="/blog" class="hover:text-blue-400 transition-colors">← Blog</a>
        <span class="mx-1">›</span>
        <span class="text-gray-300">Word Lists</span>
      </nav>

      <h1 class="text-3xl font-bold text-white mb-4">Words Containing HE — Scrabble Word List & Strategy</h1>

      <div class="not-prose mb-8 flex items-center gap-3 text-sm text-gray-400">
        <time datetime="2026-06-14">June 14, 2026</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>4 min read</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <a href="/" class="inline-flex items-center gap-1 text-blue-400 hover:underline"><span aria-hidden="true">🔤</span> Word Finder</a>
      </div>

      <p class="text-lg leading-relaxed text-gray-300 mb-8">HE is the most common H-pair, appearing in over 1,500 words. It starts HE, HER, HELP, HERE, HEAT, HEAVY and appears mid-word in THEM, THEN, THEIR, SCHEME, SPHERE, WEATHER, KITCHEN, and WHETHER. The -THER pattern (WEATHER, WHETHER, FEATHER) gives reliable 13-16 point plays. KITCHEN (16 pts) and ACHIEVE (15 pts) are premium targets.</p>

      <h2 class="text-xl font-light text-blue-400 mt-10 mb-4 border-l-4 border-blue-400 pl-4">Top HE Words by Score</h2>

      <div class="overflow-x-auto not-prose my-6">
        <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden shadow-sm">
          <thead class="bg-gray-800">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">#</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Word</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Points</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Definition</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">1</td><td class="px-4 py-3 text-white font-medium">BEWITCHED</td><td class="px-4 py-3 text-blue-400">20</td><td class="px-4 py-3 text-gray-400">Under a spell</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">2</td><td class="px-4 py-3 text-white font-medium">ALCHEMY</td><td class="px-4 py-3 text-blue-400">17</td><td class="px-4 py-3 text-gray-400">Medieval chemistry</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">3</td><td class="px-4 py-3 text-white font-medium">ACHIEVE</td><td class="px-4 py-3 text-blue-400">15</td><td class="px-4 py-3 text-gray-400">To accomplish</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">4</td><td class="px-4 py-3 text-white font-medium">KITCHEN</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">A cooking room</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">5</td><td class="px-4 py-3 text-white font-medium">WHETHER</td><td class="px-4 py-3 text-blue-400">16</td><td class="px-4 py-3 text-gray-400">Indicating a choice</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">6</td><td class="px-4 py-3 text-white font-medium">WEATHER</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">Atmospheric conditions</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">7</td><td class="px-4 py-3 text-white font-medium">BREATHE</td><td class="px-4 py-3 text-blue-400">12</td><td class="px-4 py-3 text-gray-400">To inhale and exhale</td></tr>
            <tr class="bg-gray-800/50"><td class="px-4 py-3 text-gray-400">8</td><td class="px-4 py-3 text-white font-medium">SCHEME</td><td class="px-4 py-3 text-blue-400">13</td><td class="px-4 py-3 text-gray-400">A plan or plot</td></tr>
            <tr class="bg-gray-900"><td class="px-4 py-3 text-gray-400">9</td><td class="px-4 py-3 text-white font-medium">SPHERE</td><td class="px-4 py-3 text-blue-400">11</td><td class="px-4 py-3 text-gray-400">A round shape</td></tr>
