---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Developers & Platform — APIs, Data, Feeds & Documentation"
  description="ScrabbleWordsFinder platform for developers: 8 public APIs, RSS feeds, downloadable datasets, AI discoverability files, and methodology documentation. All free, no auth required."
  keywords="scrabble api, scrabble data api, scrabble developer, scrabble rss feed, scrabble json data, scrabble platform, word of the day api, scrabble rankings api"
>

<div class="max-w-4xl mx-auto px-4 py-8">

  <div class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-light text-white mb-3">Platform & Developers</h1>
    <p class="text-gray-400 text-sm max-w-xl mx-auto">Free APIs, data feeds, and downloadable datasets for developers, researchers, and AI systems. No API key required. CORS enabled.</p>
  </div>

  <!-- Public APIs -->
  <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">🔌 Public APIs</h2>
  <p class="text-xs text-gray-500 mb-4">All endpoints return JSON. CORS enabled. No authentication required. Rate limits: reasonable use.</p>

  <div class="overflow-x-auto rounded-xl border border-gray-800 mb-10">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-900/80 text-gray-400 text-xs uppercase tracking-wider">
          <th class="px-4 py-3 text-left">Endpoint</th>
          <th class="px-4 py-3 text-left">Description</th>
          <th class="px-4 py-3 text-left">Cache</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/wotd/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/wotd/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Today's Word of the Day (word, meaning, origin, fun fact)</td><td class="px-4 py-2.5 text-gray-500 text-xs">1h</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/rankings/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/rankings/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">World Rankings (?type=wespa|ytd|online, ?limit=50)</td><td class="px-4 py-2.5 text-gray-500 text-xs">30m</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/tournaments/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/tournaments/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Tournament calendar (?status=upcoming|completed|all)</td><td class="px-4 py-2.5 text-gray-500 text-xs">30m</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/news/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/news/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Latest Scrabble news (?category=tournament|player|community)</td><td class="px-4 py-2.5 text-gray-500 text-xs">15m</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/challenge/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/challenge/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Today's daily rack + anagram with answers</td><td class="px-4 py-2.5 text-gray-500 text-xs">1h</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/search/?q=bingo" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/search/?q=</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Semantic search across 1,000+ blog articles (RAG)</td><td class="px-4 py-2.5 text-gray-500 text-xs">5m</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/player/?name=Nigel" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/player/?name=</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Player profile with rankings across all types</td><td class="px-4 py-2.5 text-gray-500 text-xs">30m</td></tr>
        <tr class="hover:bg-gray-800/30"><td class="px-4 py-2.5"><a href="/api/public/statistics/" target="_blank" class="text-blue-400 hover:underline font-mono text-xs">/api/public/statistics/</a></td><td class="px-4 py-2.5 text-gray-300 text-xs">Scrabble reference data (dictionary counts, tile bag, scoring, probability)</td><td class="px-4 py-2.5 text-gray-500 text-xs">24h</td></tr>
      </tbody>
    </table>
  </div>

  <!-- RSS Feeds -->
  <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">📡 RSS Feeds</h2>
  <div class="grid gap-2 mb-10">
    <a href="/rss/news.xml" class="p-3 rounded-lg border border-gray-800 hover:border-orange-700 transition-all flex items-center gap-3">
      <span class="text-orange-400 text-lg">📰</span>
      <div><p class="text-sm text-gray-300 font-mono">/rss/news.xml</p><p class="text-xs text-gray-500">Latest Scrabble news</p></div>
    </a>
    <a href="/rss/rankings.xml" class="p-3 rounded-lg border border-gray-800 hover:border-orange-700 transition-all flex items-center gap-3">
      <span class="text-orange-400 text-lg">🏆</span>
      <div><p class="text-sm text-gray-300 font-mono">/rss/rankings.xml</p><p class="text-xs text-gray-500">World Rankings (top 25)</p></div>
    </a>
    <a href="/rss/tournaments.xml" class="p-3 rounded-lg border border-gray-800 hover:border-orange-700 transition-all flex items-center gap-3">
      <span class="text-orange-400 text-lg">📅</span>
      <div><p class="text-sm text-gray-300 font-mono">/rss/tournaments.xml</p><p class="text-xs text-gray-500">Tournament calendar</p></div>
    </a>
    <a href="/rss/wotd.xml" class="p-3 rounded-lg border border-gray-800 hover:border-orange-700 transition-all flex items-center gap-3">
      <span class="text-orange-400 text-lg">📖</span>
      <div><p class="text-sm text-gray-300 font-mono">/rss/wotd.xml</p><p class="text-xs text-gray-500">Word of the Day (last 14 days)</p></div>
    </a>
    <a href="/rss/challenge.xml" class="p-3 rounded-lg border border-gray-800 hover:border-orange-700 transition-all flex items-center gap-3">
      <span class="text-orange-400 text-lg">🎯</span>
      <div><p class="text-sm text-gray-300 font-mono">/rss/challenge.xml</p><p class="text-xs text-gray-500">Daily rack + anagram challenges</p></div>
    </a>
  </div>

  <!-- Datasets -->
  <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">💾 Downloadable Datasets</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
    <a href="/data/tile-values.json" download class="p-3 rounded-lg border border-gray-800 hover:border-green-700 transition-all">
      <p class="text-sm text-gray-300">Tile Values & Distribution</p>
      <p class="text-xs text-gray-500">JSON + CSV</p>
    </a>
    <a href="/data/letter-frequencies.json" download class="p-3 rounded-lg border border-gray-800 hover:border-green-700 transition-all">
      <p class="text-sm text-gray-300">Letter Frequencies</p>
      <p class="text-xs text-gray-500">JSON</p>
    </a>
    <a href="/data/two-letter-words.json" download class="p-3 rounded-lg border border-gray-800 hover:border-green-700 transition-all">
      <p class="text-sm text-gray-300">Two-Letter Words (127)</p>
      <p class="text-xs text-gray-500">JSON — with scores + definitions</p>
    </a>
    <a href="/data/q-without-u-words.json" download class="p-3 rounded-lg border border-gray-800 hover:border-green-700 transition-all">
      <p class="text-sm text-gray-300">Q Without U Words (33)</p>
      <p class="text-xs text-gray-500">JSON</p>
    </a>
    <a href="/data/board-layout.json" download class="p-3 rounded-lg border border-gray-800 hover:border-green-700 transition-all">
      <p class="text-sm text-gray-300">Board Layout (15×15)</p>
      <p class="text-xs text-gray-500">JSON — premium square positions</p>
    </a>
    <a href="/data/" class="p-3 rounded-lg border border-blue-800/50 hover:border-blue-600 transition-all">
      <p class="text-sm text-blue-400">All Downloads →</p>
      <p class="text-xs text-gray-500">Full data page</p>
    </a>
  </div>

  <!-- AI & Documentation -->
  <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">🤖 AI & Documentation</h2>
  <div class="grid gap-3 mb-10">
    <a href="/llms.txt" class="p-4 rounded-xl border border-gray-800 hover:border-purple-700 transition-all flex items-start gap-3">
      <span class="text-purple-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">/llms.txt</p>
        <p class="text-xs text-gray-500">Concise site overview for AI systems (~80 lines)</p>
      </div>
    </a>
    <a href="/llms-full.txt" class="p-4 rounded-xl border border-gray-800 hover:border-purple-700 transition-all flex items-start gap-3">
      <span class="text-purple-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">/llms-full.txt</p>
        <p class="text-xs text-gray-500">Comprehensive documentation for deep indexing (~220 lines)</p>
      </div>
    </a>
    <a href="/methodology/" class="p-4 rounded-xl border border-gray-800 hover:border-purple-700 transition-all flex items-start gap-3">
      <span class="text-purple-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">/methodology/</p>
        <p class="text-xs text-gray-500">How rankings, news, and statistics are produced</p>
      </div>
    </a>
    <a href="/reference/" class="p-4 rounded-xl border border-gray-800 hover:border-purple-700 transition-all flex items-start gap-3">
      <span class="text-purple-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">/reference/</p>
        <p class="text-xs text-gray-500">Research Hub — all original research articles & datasets</p>
      </div>
    </a>
    <a href="/releases/" class="p-4 rounded-xl border border-gray-800 hover:border-purple-700 transition-all flex items-start gap-3">
      <span class="text-purple-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">/releases/</p>
        <p class="text-xs text-gray-500">Changelog — all version updates</p>
      </div>
    </a>
  </div>

  <!-- Attribution -->
  <div class="p-5 rounded-xl border border-gray-700 bg-gray-900/50">
    <h3 class="text-sm font-semibold text-gray-300 mb-2">Attribution</h3>
    <p class="text-xs text-gray-400 mb-3">All data and APIs are free to use. When citing, please attribute:</p>
    <p class="text-xs text-gray-300 font-mono bg-gray-800/50 p-2 rounded-lg">Source: ScrabbleWordsFinder.com — https://www.scrabblewordsfinder.com</p>
    <p class="text-xs text-gray-500 mt-3">Questions? <a href="/contact/" class="text-blue-400 hover:underline">Contact us</a></p>
  </div>

</div>

</Layout>
