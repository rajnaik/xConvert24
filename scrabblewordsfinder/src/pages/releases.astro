---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import packageJson from '../../package.json';

const VERSION = packageJson.version;
---

<Layout title="Release Notes — ScrabbleWordsFinder" description="Complete version changelog for ScrabbleWordsFinder.com. Track new features, bug fixes, and improvements to our free instant Scrabble word solver." keywords="scrabble word finder changelog, release notes, version history, scrabble solver updates, new features">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <a href="/" class="text-sm text-blue-400 hover:underline mb-6 inline-block">← Back to Solver</a>

    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-2xl font-bold text-white">Release Notes</h1>
      <a href="/tech-stack/" class="inline-flex items-center gap-1.5 px-2 py-1 rounded-lg text-gray-400 hover:text-purple-400 hover:bg-purple-900/20 transition-colors text-sm" title="Tech Stack"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span>Tech Stack</span></a>
    </div>
    <p class="text-sm text-gray-400 mb-8">Feature updates and improvements. Current version: <span class="font-mono text-blue-400">v{VERSION}</span></p>

    <div class="space-y-8">

      <!-- v1.8.0 -->
      <article class="border-l-2 border-purple-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.8.0 <span class="text-xs text-gray-500 font-normal ml-2">June 16, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> 60-Second Word Finder — timed game, 7 random tiles, find words in 60s, personal best tracking</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Personal Stats Dashboard — aggregated view of quiz scores, practice, streaks, games</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> WOTD Monthly Blog — dynamic /blog/wotd/[month]/ pages, words reveal daily, admin sees all</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> WOTD Monthly API — /api/wotd-monthly for blog generation (JSON + Astro format)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Roadmap page — DB-driven feature roadmap with progress tracking</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Daily Anagram — Wordle-style 6-letter puzzle with colour feedback, streak tracking, share</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Activities refactor — split into 5 components, fixed WOTD/Anagram/Rack panel bugs</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Header component extracted — reusable across Layout + BlogLayout (tech debt reduction)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Playwright upgraded 1.52 → 1.60, test runner fixed (25/25 static page tests passing)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Deploy gate hook — prevents accidental live deploys (regex-based, not all-shell)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> LIMIT added to all unbounded SELECT queries (seo-index, saved-words)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Activities links — 60-Second + Stats pills in header, improved navigation</li>
        </ul>
      </article>

      <!-- v1.7.0 -->
      <article class="border-l-2 border-purple-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.7.0 <span class="text-xs text-gray-500 font-normal ml-2">June 16, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Activities page — Word of the Day, Word Quiz, Memory WordBench (flash cards)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Word Quiz — word count picker (3-10), modal encouragement, green/red feedback, quiz history page</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Memory WordBench — auto-play with timer, speed slider (1-30s), category filters, copy/edit/delete/practice buttons</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> WordBench Practice — tracks every word reviewed with meaning, calendar view when 3+ days</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Quiz scores saved to DB with user ID — quiz history page with 8 stats</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> WOTD countdown timer — shows time until next word in purple</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> WOTD dates pre-assigned for 27 years (9,993 words through Oct 2053)</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> 10,000 words seeded in WOTD + quiz tables</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Solver — WOTD bubble with + button, quick links, + to solver button in MWB header</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Profile Data page — view all localStorage items with expand modal</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Admin — Activities section with WOTD + Quiz/Practice tiles, fixed duplicate SEO tile</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> User Guide — Activities section with tile links, educational emphasis on memory/recall</li>
          <li class="flex items-start gap-2"><span class="text-purple-400 mt-0.5">✦</span> Renamed Flash Cards to Memory WordBench sitewide</li>
        </ul>
      </article>

      <!-- v1.6.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.6.0 <span class="text-xs text-gray-500 font-normal ml-2">June 14, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Tile Rack redesign — read-only scrabble tiles with cream gradient texture (matches Tile Scores)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Drop animation — tiles flip in with bounce as you type in Word Solver</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> One-way sync — Word Solver is now sole input, eliminates bidirectional race conditions</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Unified "Find Words" button — removed duplicate button from tile rack section</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Mobile solver input — tighter tracking, smaller font, shorter placeholder for small screens</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Bigger tile letters (text-3xl/4xl) with blue score values for better readability</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Blue ? indicator in solver hint text</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Premium Squares blog — full visual treatment (stat strips, hero card, strategy tiles)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Security: removed exposed analytics ID from public release notes</li>
        </ul>
      </article>

      <!-- v1.5.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.5.0 <span class="text-xs text-gray-500 font-normal ml-2">June 14, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> BreadcrumbList JSON-LD schema on all blog pages (Home > Blog > Category > Post)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Article schema fallback in BlogLayout — all pages now have datePublished + publisher</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Blog category map (337 posts → 9 categories) for automatic category hub linking</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Non-www canonical consistency — all internal links use www.scrabblewordsfinder.com</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> GA4 analytics tag integrated as primary script ID — Google detection verified</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 4 new Strategy posts: Hooks guide, Front vs Back hooks, Triple Word strategy, Rack Balance</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> ToolSet admin (CRUD, filters, DB-backed tech stack tracking)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Environments page: traffic lights, table layout, V&P flat table, copy buttons</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Memory Workbench admin: grouped by user, color-coded categories, search</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Review Tech Stack steering file (biweekly dependency review process)</li>
        </ul>
      </article>

      <!-- v1.4.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.4.0 <span class="text-xs text-gray-500 font-normal ml-2">June 14, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 5 new category landing pages: Strategy (16), Tournament (13), Bingos (15), High-Scoring (11), Letter Guides (136)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Category cross-links on all landing pages — SEO topical cluster network</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Blog index: category pill navigation + dynamic article counter</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Purple underline hyperlink styling — all links visually obvious as clickable</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Dictionary popup: ✓/✗ active indicators + full-line clickable descriptions</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> TWL vs SOWPODS: downstream links to all sub-dictionary blog posts</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Blog intro links now point to solver sections (two-letter, three-letter, Q-without-U)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Guide link added to blog intro paragraph</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 🔍 Solver icon in BlogLayout header (all blog pages)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 🔒 Logo management: re-authentication required (server-side session check)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Non-active logos archived to /logo-options/archive/</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Sitemap: 6 new landing page URLs added (priority 0.7)</li>
        </ul>
      </article>

      <!-- v1.3.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.3.0 <span class="text-xs text-gray-500 font-normal ml-2">June 14, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> SWF Dictionary (swfdict) — pre-scraped definitions for 348 reference words, instant lookup</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Import now auto-fetches meanings from swfdict + dictionary API fallback</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Re-importing fills in missing meanings for previously imported words</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 📖 Fetch All Meanings button — one-click bulk definition fetch for all words</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Category delete (✕) — bulk-remove all words in a category with confirmation</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Workbench Data edit now uses multi-line textarea (5 rows)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Date Added field — tracks when each word was saved</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Words with no API definition get "Scrabble-legal word" label</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> User Guide updated — Rack Leave &amp; Best Opening demo mockups</li>
        </ul>
      </article>

      <!-- v1.2.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.2.0 <span class="text-xs text-gray-500 font-normal ml-2">June 14, 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Score-based Achievements system (5 levels: Rising Star → Scrabble Legend)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Achievements page — view, edit notes, track your word milestones</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 💎 Diamond icon on high-scoring words (20+ pts)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Search bar with 63-blog typeahead — find any post as you type</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Blog index expanded — all 63 posts organized by category</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> FAQ page with 11 collapsible Q&amp;A items + rich schema</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Tech Stack page — all tools and services documented</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Icon toolbar (🎲🧮🏆💎🅀🔢🐛💡🏅📝🔍) with hover tooltips</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> X clear button — clears solver + tile rack in one click</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Tile Bag reset button — restore to starting values</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Bidirectional blank sync — empty tile boxes show as ? in Word Solver</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Version stamp in footer (v1.2.0)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Consistent header across all pages (icons, search, purple line)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Mobile-responsive icon sizes and negative margins</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> 40+ new Playwright UI tests</li>
        </ul>
      </article>

      <!-- v1.1.0 -->
      <article class="border-l-2 border-emerald-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.1.0 <span class="text-xs text-gray-500 font-normal ml-2">June 2026</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Fixed dictionary loading — 8-15 letter words now load reliably (261,000+ long words)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Word Solver now finds words up to 15 letters from your tiles</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Added 21 new letter-specific blog guides (Words Starting With F through Z)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Improved dictionary load diagnostics for faster troubleshooting</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> New Playwright test coverage for solver, wildcards, and bidirectional sync</li>
        </ul>
      </article>

      <!-- v1.0.0 -->
      <article class="border-l-2 border-blue-500 pl-4">
        <h2 class="text-lg font-semibold text-white">v1.0.0 <span class="text-xs text-gray-500 font-normal ml-2">Launch</span></h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Realtime Scrabble word solver with 74,000+ SOWPODS words</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Tile rack and text input modes with wildcard support</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Live tile probability calculator</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Automatic rack leave analysis</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Best opening moves with double-word scoring</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Save words with one-click dictionary definitions</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Multi-dictionary support (SOWPODS, TWL, WWF, Collins)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Advanced filters: starts with, ends with, contains, min length</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Reference panels: 2-letter words, top 3-letter words, Q without U, rare letters</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✦</span> Achievements and word collection system</li>
        </ul>
      </article>

    </div>

    <div class="mt-12 text-center">
      <a href="/" class="text-sm text-blue-400 hover:underline">← Back to Solver</a>
    </div>
  </main>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How often is ScrabbleWordsFinder updated?", "acceptedAnswer": { "@type": "Answer", "text": "We release updates regularly, typically multiple times per week. Updates include new features, bug fixes, performance improvements, and dictionary updates." } },
    { "@type": "Question", "name": "Where can I see what changed in each release?", "acceptedAnswer": { "@type": "Answer", "text": "This releases page lists all version changes in chronological order, including the date, version number, and description of what was added, changed, or fixed." } },
    { "@type": "Question", "name": "Will updates affect my saved words or settings?", "acceptedAnswer": { "@type": "Answer", "text": "No, updates never delete your saved words or preferences. All user data is stored locally in your browser and persists across updates." } }
  ]
}
</script>
</Layout>
