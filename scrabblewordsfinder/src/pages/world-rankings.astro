<script is:inline>
(function() {
  // Tab switching with localStorage persistence
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');
  const STORAGE_KEY = 'swf-rankings-tab';

  function activateTab(target) {
    tabs.forEach(t => {
      t.classList.remove('active', 'bg-blue-600/20', 'text-blue-400', 'border-blue-500/40');
      t.classList.add('bg-gray-800/50', 'text-gray-400', 'border-gray-700');
    });
    const btn = document.querySelector(`[data-tab="${target}"]`);
    if (btn) {
      btn.classList.add('active', 'bg-blue-600/20', 'text-blue-400', 'border-blue-500/40');
      btn.classList.remove('bg-gray-800/50', 'text-gray-400', 'border-gray-700');
    }
    panels.forEach(p => p.classList.add('hidden'));
    const panel = document.getElementById('panel-' + target);
    if (panel) panel.classList.remove('hidden');
  }

  // Restore last selected tab
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved && document.getElementById('panel-' + saved)) {
    activateTab(saved);
  }

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-tab');
      activateTab(target);
      localStorage.setItem(STORAGE_KEY, target);
    });
  });

  // Search + country filter for WESPA table
  const searchInput = document.getElementById('search-wespa');
  const filterCountry = document.getElementById('filter-country');
  const wespaRows = document.querySelectorAll('#wespa-table tbody tr');

  // Populate country filter
  const countries = new Set();
  wespaRows.forEach(row => {
    const code = row.getAttribute('data-country');
    if (code) countries.add(code);
  });
  [...countries].sort().forEach(c => {
    const opt = document.createElement('option');
    opt.value = c;
    opt.textContent = c;
    filterCountry?.appendChild(opt);
  });

  function filterTable() {
    const search = (searchInput?.value || '').toLowerCase();
    const country = filterCountry?.value || '';
    wespaRows.forEach(row => {
      const name = row.getAttribute('data-name') || '';
      const cc = row.getAttribute('data-country') || '';
      const matchSearch = !search || name.includes(search);
      const matchCountry = !country || cc === country;
      row.style.display = (matchSearch && matchCountry) ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterTable);
  filterCountry?.addEventListener('change', filterTable);

})();
</script>

<script is:inline>
// Insights filtering — isolated script so earlier errors don't kill it
(function() {
  var STORAGE_KEY = 'swf-rankings-tab';
  var tabMap = { wespa: 'wespa', ytd: 'ytd', online: 'online', calendar: 'calendar', players: 'players', countries: 'wespa', movers: 'wespa', records: 'wespa' };

  function filterInsights() {
    var saved = localStorage.getItem(STORAGE_KEY) || 'wespa';
    var category = tabMap[saved] || 'wespa';
    var cards = document.querySelectorAll('[data-insight-cat]');
    for (var i = 0; i < cards.length; i++) {
      cards[i].style.display = (cards[i].getAttribute('data-insight-cat') === category) ? '' : 'none';
    }
  }

  // Run on load
  filterInsights();

  // Re-run when tabs are clicked
  var tabs = document.querySelectorAll('.tab-btn');
  for (var i = 0; i < tabs.length; i++) {
    tabs[i].addEventListener('click', function() {
      setTimeout(filterInsights, 150);
    });
  }
})();
</script>

