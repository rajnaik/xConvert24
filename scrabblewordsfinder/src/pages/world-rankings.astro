---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import '../styles/global.css';

const db = (env as any).DB;

let wespaRankings: any[] = [];
let ytdRankings: any[] = [];
let onlineRankings: any[] = [];
let upcomingTournaments: any[] = [];
let recentResults: any[] = [];

try {
  const wespaRes = await db.prepare("SELECT * FROM player_rankings WHERE ranking_type = 'wespa' AND active = 1 ORDER BY rank ASC LIMIT 50").all();
  wespaRankings = wespaRes.results || [];

  const ytdRes = await db.prepare("SELECT * FROM player_rankings WHERE ranking_type = 'ytd' AND active = 1 ORDER BY rank ASC LIMIT 50").all();
  ytdRankings = ytdRes.results || [];

  const onlineRes = await db.prepare("SELECT * FROM player_rankings WHERE ranking_type = 'online' AND active = 1 ORDER BY rank ASC LIMIT 50").all();
  onlineRankings = onlineRes.results || [];

  const upcomingRes = await db.prepare("SELECT * FROM tournaments WHERE status IN ('upcoming', 'active') ORDER BY start_date ASC").all();
  upcomingTournaments = upcomingRes.results || [];

  const recentRes = await db.prepare("SELECT * FROM tournaments WHERE status = 'completed' ORDER BY end_date DESC LIMIT 5").all();
  recentResults = recentRes.results || [];
} catch (e) {
  console.error('Failed to fetch competitive data:', e);
}

// Fetch rating changes (movers) from snapshots
let moversData: { risers: any[]; fallers: any[] } = { risers: [], fallers: [] };
try {
  // Check if ranking_snapshots table exists before querying
  const tableCheck = await db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='ranking_snapshots'").first();
  if (!tableCheck) throw new Error('ranking_snapshots table not found');

  // Get latest two snapshot dates for WESPA
  const snapDates = await db.prepare(
    "SELECT DISTINCT snapshot_date FROM ranking_snapshots WHERE ranking_type = 'wespa' ORDER BY snapshot_date DESC LIMIT 2"
  ).all();
  const dates = (snapDates.results || []).map((r: any) => r.snapshot_date);

  if (dates.length >= 2) {
    const currentDate = dates[0];
    const previousDate = dates[1];

    const currentSnap = await db.prepare(
      'SELECT player_name, rank, rating FROM ranking_snapshots WHERE snapshot_date = ? AND ranking_type = ?'
    ).bind(currentDate, 'wespa').all();
    const previousSnap = await db.prepare(
      'SELECT player_name, rank, rating FROM ranking_snapshots WHERE snapshot_date = ? AND ranking_type = ?'
    ).bind(previousDate, 'wespa').all();

    const prevMap: Record<string, { rank: number; rating: number }> = {};
    for (const p of (previousSnap.results || []) as any[]) {
      prevMap[p.player_name] = { rank: p.rank, rating: p.rating };
    }

    const changes: any[] = [];
    for (const p of (currentSnap.results || []) as any[]) {
      const prev = prevMap[p.player_name];
      if (prev) {
        changes.push({
          name: p.player_name,
          rating_change: p.rating - prev.rating,
          rank_change: prev.rank - p.rank,
          current_rating: p.rating,
          current_rank: p.rank,
        });
      }
    }

    moversData.risers = changes.filter(c => c.rating_change > 0).sort((a, b) => b.rating_change - a.rating_change).slice(0, 5);
    moversData.fallers = changes.filter(c => c.rating_change < 0).sort((a, b) => a.rating_change - b.rating_change).slice(0, 5);
  }
} catch (e) {
  console.error('Failed to fetch movers:', e);
}

// Build rating change lookup for the WESPA table (player name → delta)
const ratingChangeMap: Record<string, number> = {};
try {
  const snapDates2 = await db.prepare(
    "SELECT DISTINCT snapshot_date FROM ranking_snapshots WHERE ranking_type = 'wespa' ORDER BY snapshot_date DESC LIMIT 2"
  ).all();
  const dates2 = (snapDates2.results || []).map((r: any) => r.snapshot_date);
  if (dates2.length >= 2) {
    const curr = await db.prepare('SELECT player_name, rating FROM ranking_snapshots WHERE snapshot_date = ? AND ranking_type = ?').bind(dates2[0], 'wespa').all();
    const prev = await db.prepare('SELECT player_name, rating FROM ranking_snapshots WHERE snapshot_date = ? AND ranking_type = ?').bind(dates2[1], 'wespa').all();
    const prevLookup: Record<string, number> = {};
    for (const p of (prev.results || []) as any[]) prevLookup[p.player_name] = p.rating;
    for (const p of (curr.results || []) as any[]) {
      if (prevLookup[p.player_name] !== undefined) {
        const delta = p.rating - prevLookup[p.player_name];
        if (delta !== 0) ratingChangeMap[p.player_name] = delta;
      }
    }
  }
} catch { /* snapshots may not exist */ }

// Compute country statistics for WESPA rankings
let countryStats: any[] = [];
try {
  const countryAgg: Record<string, { code: string; name: string; players: number; totalRating: number; topPlayer: string; topRating: number; titled: number }> = {};
  for (const p of wespaRankings as any[]) {
    const code = p.country_code || 'XX';
    if (!countryAgg[code]) {
      countryAgg[code] = { code, name: p.country || code, players: 0, totalRating: 0, topPlayer: p.name, topRating: p.rating, titled: 0 };
    }
    countryAgg[code].players++;
    countryAgg[code].totalRating += p.rating;
    if (p.titles && p.titles.length > 3) countryAgg[code].titled++;
  }
  countryStats = Object.values(countryAgg)
    .map(c => ({ ...c, avgRating: Math.round(c.totalRating / c.players) }))
    .sort((a, b) => b.players - a.players);
} catch (e) {
  console.error('Failed to compute country stats:', e);
}

// Fetch records
let records: any[] = [];
try {
  const tableCheck = await db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='scrabble_records'").first();
  if (tableCheck) {
    const recordsRes = await db.prepare('SELECT * FROM scrabble_records WHERE active = 1 ORDER BY category ASC, id ASC').all();
    records = recordsRes.results || [];
  }
} catch (e) {
  console.error('Failed to fetch records:', e);
}

// Fetch tournament results for completed tournaments
let tournamentResults: Record<number, any[]> = {};
try {
  const tableCheck = await db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='tournament_results'").first();
  if (tableCheck) {
    for (const t of recentResults as any[]) {
      const res = await db.prepare('SELECT * FROM tournament_results WHERE tournament_id = ? ORDER BY position ASC').bind(t.id).all();
      if (res.results && res.results.length > 0) {
        tournamentResults[t.id] = res.results;
      }
    }
  }
} catch (e) {
  console.error('Failed to fetch tournament results:', e);
}

// Generate insights server-side
const allInsights: {text: string, category: string}[] = [];

// WESPA insights
if (wespaRankings.length > 0) {
  const top = wespaRankings[0] as any;
  allInsights.push({text: `${top.name} (${top.country}) holds the #1 WESPA rating at ${top.rating} points.`, category: 'wespa'});
  if (wespaRankings.length > 1) {
    const second = wespaRankings[1] as any;
    allInsights.push({text: `The gap between #1 and #2 is ${top.rating - second.rating} rating points.`, category: 'wespa'});
  }
  const countryCounts: Record<string, number> = {};
  for (const p of wespaRankings as any[]) countryCounts[p.country] = (countryCounts[p.country] || 0) + 1;
  const topCountry = Object.entries(countryCounts).sort((a, b) => b[1] - a[1])[0];
  if (topCountry) allInsights.push({text: `${topCountry[0]} leads with ${topCountry[1]} players in the top ${wespaRankings.length}.`, category: 'wespa'});
  const avgRating = Math.round((wespaRankings as any[]).reduce((s, p) => s + p.rating, 0) / wespaRankings.length);
  allInsights.push({text: `Average WESPA rating in the top ${wespaRankings.length}: ${avgRating}.`, category: 'wespa'});
  const uniqueCountries = Object.keys(countryCounts).length;
  allInsights.push({text: `${uniqueCountries} countries represented in the WESPA top ${wespaRankings.length}.`, category: 'wespa'});
}

// YTD insights
if (ytdRankings.length > 0) {
  const ytdTop = ytdRankings[0] as any;
  allInsights.push({text: `${ytdTop.name} leads YTD with ${ytdTop.rating.toLocaleString()} points from ${ytdTop.games_played} events.`, category: 'ytd'});
  const ytdCountries: Record<string, number> = {};
  for (const p of ytdRankings as any[]) ytdCountries[p.country] = (ytdCountries[p.country] || 0) + 1;
  const ytdTopCountry = Object.entries(ytdCountries).sort((a, b) => b[1] - a[1])[0];
  if (ytdTopCountry) allInsights.push({text: `${ytdTopCountry[0]} dominates YTD with ${ytdTopCountry[1]} players.`, category: 'ytd'});
  if (ytdRankings.length >= 24) {
    const cutoff = ytdRankings[23] as any;
    allInsights.push({text: `Summit Cup cutoff (#24): ${cutoff.name} with ${cutoff.rating.toLocaleString()} pts.`, category: 'ytd'});
  }
}

// Online insights
if (onlineRankings.length > 0) {
  const onTop = onlineRankings[0] as any;
  allInsights.push({text: `${onTop.name} (${onTop.country}) leads online ratings at ${onTop.rating}.`, category: 'online'});
  const onlineCountries = new Set((onlineRankings as any[]).map(p => p.country));
  allInsights.push({text: `${onlineCountries.size} countries in the online top ${onlineRankings.length}.`, category: 'online'});
}

// Tournament insights
if (upcomingTournaments.length > 0 || recentResults.length > 0) {
  allInsights.push({text: `${upcomingTournaments.length} tournaments upcoming, ${recentResults.length} recently completed.`, category: 'calendar'});
}

// Player profile insights
if (wespaRankings.length > 0) {
  const titledPlayers = (wespaRankings as any[]).filter(p => p.titles && p.titles.length > 5);
  if (titledPlayers.length > 0) {
    allInsights.push({text: `${titledPlayers.length} players in the top 50 hold major titles.`, category: 'players'});
  }
  const peakPlayer = (wespaRankings as any[]).reduce((max, p) => p.peak_rating > max.peak_rating ? p : max);
  allInsights.push({text: `Highest peak ever: ${peakPlayer.name} at ${peakPlayer.peak_rating}.`, category: 'players'});
}

const tierColors: Record<string, string> = {
  platinum: 'text-purple-400 bg-purple-900/30 border-purple-500/40',
  gold: 'text-amber-400 bg-amber-900/30 border-amber-500/40',
  silver: 'text-zinc-200 bg-zinc-700/30 border-zinc-400/50',
  bronze: 'text-orange-400 bg-orange-900/30 border-orange-500/40',
  others: 'text-gray-400 bg-gray-900/30 border-gray-600/40',
};

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00Z');
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC' });
}

function daysUntil(dateStr: string) {
  const now = new Date();
  const target = new Date(dateStr + 'T00:00:00Z');
  return Math.ceil((target.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
}

function toSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<Layout
  title="World Scrabble Rankings — WESPA Ratings, Tournaments & Player Profiles"
  description="Live WESPA world rankings, YTD standings, player profiles, upcoming tournaments, and recent results. Track the top competitive Scrabble players globally. Free."
  keywords="WESPA rankings, world scrabble rankings, scrabble tournament calendar, competitive scrabble, top scrabble players, WESPAC, scrabble ratings, player profiles, tournament results, scrabble world champion"
>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "World Scrabble Rankings — WESPA Ratings, Tournaments & Player Profiles",
  "description": "Live WESPA world rankings, YTD standings, player profiles, and tournament calendar for competitive Scrabble.",
  "url": "https://www.scrabblewordsfinder.com/world-rankings/",
  "mainEntity": {
    "@type": "ItemList",
    "name": "WESPA World Scrabble Rankings",
    "numberOfItems": wespaRankings.length,
    "itemListElement": wespaRankings.slice(0, 10).map((p: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "description": `Rank #${p.rank} — ${p.country} — Rating: ${p.rating}`
    }))
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is the highest-rated Scrabble player in the world?",
      "acceptedAnswer": { "@type": "Answer", "text": `As of July 2026, ${wespaRankings[0]?.name || 'David Eldar'} from ${wespaRankings[0]?.country || 'Australia'} holds the #1 WESPA rating with ${wespaRankings[0]?.rating || 2145} points. WESPA ratings are based on performance in internationally-sanctioned over-the-board tournaments.` }
    },
    {
      "@type": "Question",
      "name": "What is the WESPA rating system?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WESPA (World English-Language Scrabble Players Association) rating system ranks competitive Scrabble players globally based on their performance in sanctioned over-the-board tournaments. Ratings are calculated using an Elo-style formula that accounts for opponent strength and game results." }
    },
    {
      "@type": "Question",
      "name": "How do players qualify for the World Scrabble Championship?",
      "acceptedAnswer": { "@type": "Answer", "text": "Players qualify for the WESPA Championship (WESPAC) through a combination of their WESPA rating and Year-to-Date (YTD) performance points. The top 24 players on the YTD rankings qualify for the Summit Cup, while WESPAC uses a broader qualification based on national championships and rating thresholds." }
    }
  ]
})} />

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Hero -->
  <div class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-light text-white mb-3">World Scrabble Rankings</h1>
    <p class="text-gray-400 text-sm max-w-2xl mx-auto">WESPA ratings, Year-to-Date standings, player profiles, and the global tournament calendar — all in one place.</p>
    <p class="text-xs text-gray-500 mt-2">Last updated: July 2026 • Source: <a href="https://wespa.org/" target="_blank" rel="noopener" class="text-blue-400 hover:underline">wespa.org</a></p>
  </div>

  <!-- Tab Navigation -->
  <div class="flex flex-wrap justify-center gap-2 mb-8" id="tab-nav">
    <button data-tab="wespa" class="tab-btn active px-4 py-2 rounded-lg text-sm font-medium transition-all bg-blue-600/20 text-blue-400 border border-blue-500/40">🏆 WESPA Ratings</button>
    <button data-tab="ytd" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">📊 YTD Rankings</button>
    <button data-tab="online" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">🌐 Online Ratings</button>
    <button data-tab="players" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">👤 Player Profiles</button>
    <button data-tab="calendar" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">📅 Tournaments</button>
    <button data-tab="countries" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">🌍 Countries</button>
    <button data-tab="movers" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">🔥 Movers</button>
    <button data-tab="records" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500">🏅 Records</button>
    <a href="#insights-section" class="px-4 py-2 rounded-lg text-sm font-medium bg-purple-600/20 text-purple-400 border border-purple-500/40 hover:bg-purple-600/30 transition-all">💡 Insights</a>
  </div>

  <!-- WESPA Ratings Tab -->
  <div id="panel-wespa" class="tab-panel">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-xl font-light text-white">WESPA World Ratings — Top 50</h2>
      <div class="flex gap-2">
        <input type="text" id="search-wespa" placeholder="Search player..." class="px-3 py-1.5 text-xs rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none w-40" />
        <select id="filter-country" class="px-3 py-1.5 text-xs rounded-lg bg-gray-800 border border-gray-700 text-gray-300 focus:border-blue-500 focus:outline-none">
          <option value="">All Countries</option>
        </select>
      </div>
    </div>
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm" id="wespa-table">
        <thead>
          <tr class="bg-gray-900/80 text-gray-400 text-xs uppercase tracking-wider">
            <th class="px-3 py-3 text-left w-12">#</th>
            <th class="px-3 py-3 text-left">Player</th>
            <th class="px-3 py-3 text-left hidden sm:table-cell">Country</th>
            <th class="px-3 py-3 text-right">Rating</th>
            <th class="px-3 py-3 text-right hidden md:table-cell">Games</th>
            <th class="px-3 py-3 text-right hidden lg:table-cell">Peak</th>
            <th class="px-3 py-3 text-left hidden xl:table-cell">Titles</th>
          </tr>
        </thead>
        <tbody>
          {wespaRankings.map((player: any, i: number) => (
            <tr class={`border-t border-gray-800/50 hover:bg-gray-800/30 transition-colors ${i < 3 ? 'bg-gradient-to-r from-amber-900/5 to-transparent' : ''}`} data-name={player.name.toLowerCase()} data-country={player.country_code}>
              <td class="px-3 py-2.5">
                <span class={`text-xs font-bold ${i === 0 ? 'text-amber-400' : i === 1 ? 'text-gray-300' : i === 2 ? 'text-orange-400' : 'text-gray-500'}`}>
                  {i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : player.rank}
                </span>
              </td>
              <td class="px-3 py-2.5">
                <a href={`/players/${toSlug(player.name)}/`} class="text-white font-medium hover:text-blue-400 transition-colors">{player.name}</a>
                <span class="sm:hidden text-xs text-gray-500 ml-1">{player.country_code}</span>
              </td>
              <td class="px-3 py-2.5 hidden sm:table-cell">
                <span class="text-gray-400 text-xs">{player.country_code}</span>
                <span class="text-gray-500 text-xs ml-1">{player.country}</span>
              </td>
              <td class="px-3 py-2.5 text-right">
                <span class="text-blue-400 font-mono font-semibold">{player.rating}</span>
                {ratingChangeMap[player.name] && ratingChangeMap[player.name] > 0 && (
                  <span class="text-green-400 text-[10px] ml-1">▲{ratingChangeMap[player.name]}</span>
                )}
                {ratingChangeMap[player.name] && ratingChangeMap[player.name] < 0 && (
                  <span class="text-red-400 text-[10px] ml-1">▼{Math.abs(ratingChangeMap[player.name])}</span>
                )}
              </td>
              <td class="px-3 py-2.5 text-right hidden md:table-cell text-gray-400">{player.games_played}</td>
              <td class="px-3 py-2.5 text-right hidden lg:table-cell text-gray-500">{player.peak_rating}</td>
              <td class="px-3 py-2.5 hidden xl:table-cell">
                {player.titles ? (
                  <span class="text-xs text-amber-400/80 flex flex-wrap gap-1">{player.titles.split(', ').map((title: string) => {
                    const tl = title.toLowerCase();
                    let href = '';
                    if (tl.includes('wsc') || tl.includes('world champion')) href = '/blog/world-scrabble-championship/';
                    else if (tl.includes('wespac')) href = '/blog/wespac-scrabble-championship/';
                    else if (tl.includes('nsc') || tl.includes('nasc') || tl.includes('spc') || tl.includes('national')) href = '/blog/national-scrabble-championship/';
                    else if (tl.includes('causeway')) href = '/blog/causeway-challenge-scrabble/';
                    else if (tl.includes('wysc') || tl.includes('youth')) href = '/blog/world-youth-scrabble-championship/';
                    else if (tl.includes('world cup')) href = '/blog/scrabble-world-cup/';
                    else if (tl.includes('jwsc') || tl.includes('junior')) href = '/blog/junior-world-scrabble-championship/';
                    return href ? (
                      <a href={href} class="hover:text-amber-300 hover:underline transition-colors">{title}</a>
                    ) : (
                      <span>{title}</span>
                    );
                  })}</span>
                ) : (
                  <span class="text-xs text-gray-600">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500 mt-3 text-center">Ratings are approximate, based on publicly available WESPA tournament results. Official ratings at <a href="https://wespa.org/ratings/online-ratings" target="_blank" rel="noopener" class="text-blue-400 hover:underline">wespa.org</a>.</p>
  </div>

  <!-- YTD Rankings Tab -->
  <div id="panel-ytd" class="tab-panel hidden">
    <div class="mb-4">
      <h2 class="text-xl font-light text-white">Year-to-Date Rankings 2026</h2>
      <p class="text-xs text-gray-500 mt-1">Cumulative points from WESPA-rated OTB tournaments in 2026. Top 24 qualify for the <a href="https://wespa.org/tournaments/summit-cup" target="_blank" rel="noopener" class="text-blue-400 hover:underline">WESPA Summit Cup</a>.</p>
    </div>
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-900/80 text-gray-400 text-xs uppercase tracking-wider">
            <th class="px-3 py-3 text-left w-12">#</th>
            <th class="px-3 py-3 text-left">Player</th>
            <th class="px-3 py-3 text-left hidden sm:table-cell">Country</th>
            <th class="px-3 py-3 text-right">Events</th>
            <th class="px-3 py-3 text-right">Points</th>
          </tr>
        </thead>
        <tbody>
          {ytdRankings.map((player: any, i: number) => (
            <tr class={`border-t border-gray-800/50 hover:bg-gray-800/30 transition-colors ${i < 3 ? 'bg-gradient-to-r from-green-900/5 to-transparent' : ''} ${i === 23 ? 'border-b-2 border-dashed border-amber-500/30' : ''}`}>
              <td class="px-3 py-2.5">
                <span class={`text-xs font-bold ${i === 0 ? 'text-green-400' : i === 1 ? 'text-green-300' : i === 2 ? 'text-green-200' : 'text-gray-500'}`}>{player.rank}</span>
              </td>
              <td class="px-3 py-2.5 text-white font-medium">{player.name}</td>
              <td class="px-3 py-2.5 hidden sm:table-cell text-gray-400 text-xs">{player.country}</td>
              <td class="px-3 py-2.5 text-right text-gray-400">{player.games_played}</td>
              <td class="px-3 py-2.5 text-right">
                <span class="text-green-400 font-mono font-semibold">{player.rating.toLocaleString()}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="mt-3 flex items-center justify-center gap-2 text-xs text-gray-500">
      <span class="inline-block w-4 border-t-2 border-dashed border-amber-500/50"></span>
      <span>Summit Cup qualification line (top 24)</span>
    </div>
  </div>

  <!-- Online Ratings Tab -->
  <div id="panel-online" class="tab-panel hidden">
    <div class="mb-4">
      <h2 class="text-xl font-light text-white">WESPA Online Ratings</h2>
