---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import packageJson from '../../package.json';
const VERSION = packageJson.version;
---

<Layout title="Tech Stack — ScrabbleWordsFinder.com" description="The technology behind ScrabbleWordsFinder.com. Built with Astro, Cloudflare Workers, Tailwind CSS, and AI-powered development with Kiro." keywords="scrabble word finder tech stack, technology, cloudflare workers, astro, kiro">

  <div class="max-w-4xl mx-auto px-6 pt-4 pb-6">
    <a href="/" class="text-sm text-blue-400 hover:underline mb-6 inline-block">← Back to Solver</a>

    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">🧱</span>
      <h1 class="text-2xl font-bold text-white">Tech Stack</h1>
      <span class="ml-auto text-xs font-mono text-purple-400">v{VERSION}</span>
    </div>
    <p class="text-gray-400 mb-8">The tools, platforms, and services that power ScrabbleWordsFinder.com.</p>

    <!-- Development & AI -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>🤖</span> Development & AI</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://kiro.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://kiro.dev/favicon.ico" alt="Kiro" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Kiro</p>
            <p class="text-xs text-gray-500 mb-1">kiro.dev</p>
            <p class="text-xs text-gray-400">AI-powered development environment. Our primary coding partner for building and maintaining the entire platform.</p>
          </div>
        </a>
        <a href="https://skills.sh/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://skills.sh/favicon.ico" alt="Skills.sh" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Skills.sh</p>
            <p class="text-xs text-gray-500 mb-1">skills.sh</p>
            <p class="text-xs text-gray-400">Teaching AI agents coding skills. Enhances our development agent's capabilities.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Hosting & Infrastructure -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>☁️</span> Hosting & Infrastructure</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://cloudflare.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://www.cloudflare.com/favicon.ico" alt="Cloudflare" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Cloudflare</p>
            <p class="text-xs text-gray-500 mb-1">cloudflare.com</p>
            <p class="text-xs text-gray-400">Edge hosting via Workers, D1 database, Email Routing, and CDN. Our entire backend runs on Cloudflare's global network.</p>
          </div>
        </a>
        <a href="https://github.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://github.com/favicon.ico" alt="GitHub" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">GitHub</p>
            <p class="text-xs text-gray-500 mb-1">github.com</p>
            <p class="text-xs text-gray-400">Source code hosting, version control, and collaboration.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Frameworks & Runtime -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>⚡</span> Frameworks & Runtime</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://astro.build/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://astro.build/favicon.svg" alt="Astro" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Astro 6</p>
            <p class="text-xs text-gray-500 mb-1">astro.build</p>
            <p class="text-xs text-gray-400">Content-driven web framework. Pre-renders pages for speed, with SSR for dynamic API endpoints.</p>
          </div>
        </a>
        <a href="https://tailwindcss.com/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://tailwindcss.com/favicons/favicon.ico" alt="Tailwind CSS" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Tailwind CSS 4</p>
            <p class="text-xs text-gray-500 mb-1">tailwindcss.com</p>
            <p class="text-xs text-gray-400">Utility-first CSS for rapid, consistent dark-theme styling across the entire site.</p>
          </div>
        </a>
        <a href="https://www.typescriptlang.org/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://www.typescriptlang.org/favicon-32x32.png" alt="TypeScript" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">TypeScript</p>
            <p class="text-xs text-gray-500 mb-1">typescriptlang.org</p>
            <p class="text-xs text-gray-400">Type-safe JavaScript for reliable API endpoints and solver logic.</p>
          </div>
        </a>
        <a href="https://nodejs.org/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://nodejs.org/static/images/favicons/favicon.png" alt="Node.js" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Node.js 24</p>
            <p class="text-xs text-gray-500 mb-1">nodejs.org</p>
            <p class="text-xs text-gray-400">JavaScript runtime for build tooling, local dev, and Wrangler CLI.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Testing & Quality -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>🛡️</span> Testing & Quality</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://playwright.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://playwright.dev/img/playwright-logo.svg" alt="Playwright" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Playwright</p>
            <p class="text-xs text-gray-500 mb-1">playwright.dev</p>
            <p class="text-xs text-gray-400">End-to-end browser testing. 40+ automated tests covering solver, UI, and page structure.</p>
          </div>
        </a>
        <a href="https://www.aikido.dev/" target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50 hover:border-purple-700 transition-all">
          <img src="https://www.aikido.dev/favicon.ico" alt="Aikido Security" class="w-10 h-10 rounded-lg shrink-0" loading="lazy" />
          <div>
            <p class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors">Aikido Security</p>
            <p class="text-xs text-gray-500 mb-1">aikido.dev</p>
            <p class="text-xs text-gray-400">SAST scanning, secrets detection, and security analysis in our CI pipeline.</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Data & Dictionaries -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4 flex items-center gap-2"><span>📚</span> Data & Dictionaries</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
          <span class="text-2xl shrink-0">🔤</span>
          <div>
            <p class="text-sm font-semibold text-white">SOWPODS</p>
            <p class="text-xs text-gray-400">335,000+ words (international Scrabble dictionary). 2-15 letter words loaded client-side.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
          <span class="text-2xl shrink-0">🇺🇸</span>
          <div>
            <p class="text-sm font-semibold text-white">TWL (Tournament Word List)</p>
            <p class="text-xs text-gray-400">315,000+ words used in North American Scrabble tournaments.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
          <span class="text-2xl shrink-0">💾</span>
          <div>
            <p class="text-sm font-semibold text-white">Cloudflare D1</p>
            <p class="text-xs text-gray-400">SQLite-based serverless database for achievements, clicks, emails, and telemetry.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
          <span class="text-2xl shrink-0">🌐</span>
          <div>
            <p class="text-sm font-semibold text-white">Free Dictionary API</p>
            <p class="text-xs text-gray-400">Word definitions auto-fetched when saving words to your collection.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-blue-500 text-gray-950 font-semibold hover:bg-blue-400 transition-colors">
        🔤 Try the Word Finder →
      </a>
    </div>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What technology does ScrabbleWordsFinder use?", "acceptedAnswer": { "@type": "Answer", "text": "ScrabbleWordsFinder is built with Astro 6, Tailwind CSS 4, TypeScript, and deployed on Cloudflare Workers with D1 database. The AI development is powered by Kiro." } },
    { "@type": "Question", "name": "How fast is ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "The solver runs entirely client-side with the dictionary loaded in the browser. Results appear in under 300ms as you type. The site is hosted on Cloudflare's global edge network for sub-50ms page loads." } },
    { "@type": "Question", "name": "Is the dictionary loaded locally or from a server?", "acceptedAnswer": { "@type": "Answer", "text": "The dictionary (335,000+ words) is loaded into the browser on first visit and cached. All word solving happens client-side — no server calls needed for results." } }
  ]
}
</script>
</Layout>
