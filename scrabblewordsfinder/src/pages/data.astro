---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Scrabble Data Downloads — CSV, JSON & APIs"
  description="Free downloadable Scrabble data: tile values, letter frequencies, world rankings, tournaments. JSON and CSV formats for developers and researchers."
  keywords="scrabble data download, scrabble tile values csv, scrabble letter frequency json, scrabble api, scrabble statistics data, machine readable scrabble data"
>

<div class="max-w-4xl mx-auto px-4 py-8">

  <div class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-light text-white mb-3">Scrabble Data Downloads</h1>
    <p class="text-gray-400 text-sm max-w-xl mx-auto">Free, machine-readable Scrabble data for developers, researchers, and AI systems. All data includes source attribution.</p>
  </div>

  <!-- Static Downloads -->
  <h2 class="text-lg font-semibold text-white mb-4">Static Data Files</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/30">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">🎲</span>
        <div>
          <p class="text-white font-medium text-sm">Tile Values & Distribution</p>
          <p class="text-xs text-gray-500">Point values and bag count for all 27 tiles</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/data/tile-values.json" download class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON</a>
        <a href="/data/tile-values.csv" download class="px-3 py-1.5 rounded-lg bg-green-600/20 border border-green-500/40 text-green-400 text-xs font-medium hover:bg-green-600/30 transition-colors">CSV</a>
      </div>
    </div>

    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/30">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">📊</span>
        <div>
          <p class="text-white font-medium text-sm">Letter Frequencies</p>
          <p class="text-xs text-gray-500">Distribution, percentages, vowel/consonant split</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/data/letter-frequencies.json" download class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON</a>
      </div>
    </div>

    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/30">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">🔤</span>
        <div>
          <p class="text-white font-medium text-sm">Two-Letter Words (127)</p>
          <p class="text-xs text-gray-500">All valid 2-letter words with scores and definitions</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/data/two-letter-words.json" download class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON</a>
      </div>
    </div>

    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/30">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">🅀</span>
        <div>
          <p class="text-white font-medium text-sm">Q Without U Words (33)</p>
          <p class="text-xs text-gray-500">All valid Q-no-U words with scores and definitions</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/data/q-without-u-words.json" download class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON</a>
      </div>
    </div>

    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/30">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">🎯</span>
        <div>
          <p class="text-white font-medium text-sm">Board Layout</p>
          <p class="text-xs text-gray-500">15×15 grid with all premium square positions</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/data/board-layout.json" download class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON</a>
      </div>
    </div>
  </div>

  <!-- Live API Downloads -->
  <h2 class="text-lg font-semibold text-white mb-4">Live Data via API</h2>
  <p class="text-xs text-gray-500 mb-4">These endpoints return live data from our database. CORS enabled, no auth required.</p>
  <div class="grid grid-cols-1 gap-3 mb-10">
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">🏆 World Rankings</p>
        <p class="text-xs text-gray-500">Top 50 WESPA-rated players with country, rating, games, titles</p>
      </div>
      <a href="/api/public/rankings/" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">📊 YTD Rankings</p>
        <p class="text-xs text-gray-500">Year-to-date tournament points (top 50)</p>
      </div>
      <a href="/api/public/rankings/?type=ytd" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">📅 Tournaments</p>
        <p class="text-xs text-gray-500">Upcoming WESPA-rated events with dates, tier, location</p>
      </div>
      <a href="/api/public/tournaments/" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">📖 Word of the Day</p>
        <p class="text-xs text-gray-500">Today's word with meaning, origin, example, fun fact</p>
      </div>
      <a href="/api/public/wotd/" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">📰 Latest News</p>
        <p class="text-xs text-gray-500">Recent Scrabble news with sources and categories</p>
      </div>
      <a href="/api/public/news/" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
    <div class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <div>
        <p class="text-white font-medium text-sm">🎯 Daily Challenge</p>
        <p class="text-xs text-gray-500">Today's rack + anagram challenge with answers</p>
      </div>
      <a href="/api/public/challenge/" target="_blank" class="px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/40 text-blue-400 text-xs font-medium hover:bg-blue-600/30 transition-colors">JSON →</a>
    </div>
  </div>

  <!-- Attribution -->
  <div class="p-5 rounded-xl border border-gray-700 bg-gray-900/50 text-center">
    <p class="text-gray-300 text-sm mb-2">All data is free to use. If you cite this data, please attribute:</p>
    <p class="text-xs text-gray-400 font-mono bg-gray-800/50 p-2 rounded-lg inline-block">Source: ScrabbleWordsFinder.com</p>
  </div>

</div>

</Layout>
