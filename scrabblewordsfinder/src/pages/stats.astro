---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Your Stats — ScrabbleWordsFinder" description="View your personal Scrabble statistics: quiz scores, practice history, streaks, saved words, and game performance. Free Scrabble guide. No sign-up needed." keywords="scrabble stats, word finder stats, quiz history, practice tracking, scrabble progress" noindex={true}>

<main class="mx-auto max-w-4xl px-4 sm:px-6 py-8 pb-20">
  <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2"><span class="text-purple-400">📊</span> Your Stats</h1>
  <p class="text-sm text-gray-400 mb-6">Your personal performance across all ScrabbleWordsFinder activities.</p>

  <!-- Top-level summary cards -->
  <div id="summary-cards" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-words-saved" class="text-2xl font-black text-purple-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Words Saved</p>
    </div>
    <div class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-quizzes" class="text-2xl font-black text-blue-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Quizzes Played</p>
    </div>
    <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-practice" class="text-2xl font-black text-green-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Practice Sessions</p>
    </div>
    <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-streak" class="text-2xl font-black text-amber-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Best Streak</p>
    </div>
  </div>

  <!-- Quiz + WordBench (2-col condensed) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <!-- Quiz Performance -->
    <section>
      <h2 class="text-sm font-semibold text-white mb-2 flex items-center gap-2"><span>🧠</span> Quiz Performance</h2>
      <div id="quiz-stats" class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-4">
        <div id="quiz-loading" class="text-center text-sm text-gray-500 py-2">Loading...</div>
        <div id="quiz-content" class="hidden">
          <div class="grid grid-cols-2 gap-3 mb-3">
            <div class="text-center"><p id="quiz-total" class="text-lg font-bold text-blue-400">0</p><p class="text-[10px] text-gray-500">Quizzes</p></div>
            <div class="text-center"><p id="quiz-avg" class="text-lg font-bold text-blue-400">0%</p><p class="text-[10px] text-gray-500">Avg Score</p></div>
            <div class="text-center"><p id="quiz-perfect" class="text-lg font-bold text-blue-400">0</p><p class="text-[10px] text-gray-500">Perfect</p></div>
            <div class="text-center"><p id="quiz-best" class="text-lg font-bold text-blue-400">0%</p><p class="text-[10px] text-gray-500">Best</p></div>
          </div>
          <div id="quiz-recent" class="border-t border-gray-800 pt-2">
            <p class="text-[10px] text-gray-500 uppercase mb-1.5">Recent</p>
            <div id="quiz-recent-list" class="space-y-1"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- WordBench / Practice -->
    <section>
      <h2 class="text-sm font-semibold text-white mb-2 flex items-center gap-2"><span>📚</span> Memory WordBench</h2>
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-4">
        <div id="wb-loading" class="text-center text-sm text-gray-500 py-2">Loading...</div>
        <div id="wb-content" class="hidden">
          <div class="grid grid-cols-2 gap-3 mb-3">
            <div class="text-center"><p id="wb-total" class="text-lg font-bold text-green-400">0</p><p class="text-[10px] text-gray-500">Practised</p></div>
            <div class="text-center"><p id="wb-sessions" class="text-lg font-bold text-green-400">0</p><p class="text-[10px] text-gray-500">Sessions</p></div>
            <div class="text-center"><p id="wb-categories" class="text-lg font-bold text-green-400">0</p><p class="text-[10px] text-gray-500">Categories</p></div>
            <div class="text-center"><p id="wb-today" class="text-lg font-bold text-green-400">0</p><p class="text-[10px] text-gray-500">Today</p></div>
          </div>
          <div id="wb-by-category" class="border-t border-gray-800 pt-2">
            <p class="text-[10px] text-gray-500 uppercase mb-1.5">By Category</p>
            <div id="wb-category-pills" class="flex flex-wrap gap-1.5"></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Games (Daily Rack + Anagram + 60s) — 3-col condensed with expandable history -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>🎮</span> Games</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <!-- Daily Rack tile -->
      <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-4 text-center">
        <p class="text-xl mb-1">🎲</p>
        <p class="text-xs font-semibold text-white mb-1">Daily Rack</p>
        <p id="drc-stat-best" class="text-lg font-bold text-amber-400">—</p>
        <p class="text-[10px] text-gray-500">Best Score</p>
        <p id="drc-stat-played" class="text-[10px] text-gray-400 mt-1">— days</p>
        <button id="drc-expand-btn" class="mt-2 text-[10px] text-amber-400 hover:text-amber-300 transition-colors">▶ History</button>
      </div>
      <!-- Daily Anagram tile -->
      <div class="rounded-xl border border-rose-800/50 bg-gray-900/50 p-4 text-center">
        <p class="text-xl mb-1">🔤</p>
        <p class="text-xs font-semibold text-white mb-1">Daily Anagram</p>
        <p id="anagram-stat-streak" class="text-lg font-bold text-rose-400">—</p>
        <p class="text-[10px] text-gray-500">Streak</p>
        <p id="anagram-stat-solved" class="text-[10px] text-gray-400 mt-1">— solved</p>
        <button id="anagram-expand-btn" class="mt-2 text-[10px] text-rose-400 hover:text-rose-300 transition-colors">▶ History</button>
      </div>
      <!-- 60-Second tile -->
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-4 text-center col-span-2 sm:col-span-1">
        <p class="text-xl mb-1">⏱️</p>
        <p class="text-xs font-semibold text-white mb-1">60-Second</p>
        <p id="sixty-stat-pb" class="text-lg font-bold text-green-400">—</p>
        <p class="text-[10px] text-gray-500">Personal Best</p>
        <button id="sixty-expand-btn" class="mt-2 text-[10px] text-green-400 hover:text-green-300 transition-colors">▶ History</button>
      </div>
    </div>

    <!-- Expandable: Daily Rack History -->
    <div id="drc-history-section" class="hidden mt-4 rounded-xl border border-amber-800/50 bg-gray-900/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-amber-300 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Daily Rack History
        </h3>
        <button id="drc-history-section-close" class="text-gray-500 hover:text-white text-lg leading-none">&times;</button>
      </div>
      <div id="drc-history-section-loading" class="text-center py-3"><p class="text-xs text-gray-500">Loading...</p></div>
      <div id="drc-history-section-empty" class="hidden text-center py-3"><p class="text-xs text-gray-500">No rack history yet.</p></div>
      <div id="drc-history-section-content" class="hidden">
        <div id="drc-history-section-stats" class="grid grid-cols-3 gap-2 mb-3"></div>
        <div id="drc-history-section-groups" class="max-h-72 overflow-y-auto"></div>
      </div>
    </div>

    <!-- Expandable: Daily Anagram History -->
    <div id="anagram-history-section" class="hidden mt-4 rounded-xl border border-rose-800/50 bg-gray-900/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-rose-300 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Daily Anagram History
        </h3>
        <button id="anagram-history-section-close" class="text-gray-500 hover:text-white text-lg leading-none">&times;</button>
      </div>
      <div id="anagram-history-section-loading" class="text-center py-3"><p class="text-xs text-gray-500">Loading...</p></div>
      <div id="anagram-history-section-empty" class="hidden text-center py-3"><p class="text-xs text-gray-500">No anagram history yet.</p></div>
      <div id="anagram-history-section-content" class="hidden">
        <div id="anagram-history-section-stats" class="grid grid-cols-3 gap-2 mb-3"></div>
        <div id="anagram-history-section-list" class="max-h-72 overflow-y-auto space-y-2"></div>
      </div>
    </div>

    <!-- Expandable: 60-Second History -->
    <div id="sixty-history-section" class="hidden mt-4 rounded-xl border border-green-800/50 bg-gray-900/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-green-300 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          60-Second Round History
        </h3>
        <button id="sixty-history-section-close" class="text-gray-500 hover:text-white text-lg leading-none">&times;</button>
      </div>
      <div id="sixty-history-section-loading" class="text-center py-3"><p class="text-xs text-gray-500">Loading...</p></div>
      <div id="sixty-history-section-empty" class="hidden text-center py-3"><p class="text-xs text-gray-500">No rounds played yet.</p></div>
      <div id="sixty-history-section-content" class="hidden">
        <div id="sixty-history-section-stats" class="grid grid-cols-3 gap-2 mb-3"></div>
        <div id="sixty-history-section-list" class="max-h-72 overflow-y-auto space-y-2"></div>
      </div>
    </div>
  </section>

  <!-- WOTD + Summary row (condensed 2-col) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <!-- WOTD -->
    <section>
      <h2 class="text-sm font-semibold text-white mb-2 flex items-center gap-2"><span>📖</span> Word of the Day</h2>
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4">
        <div class="grid grid-cols-3 gap-3">
          <div class="text-center"><p id="wotd-saved" class="text-lg font-bold text-purple-400">—</p><p class="text-[10px] text-gray-500">Saved</p></div>
          <div class="text-center"><p id="wotd-looked-up" class="text-lg font-bold text-purple-400">—</p><p class="text-[10px] text-gray-500">Looked Up</p></div>
          <div class="text-center"><p id="wotd-streak" class="text-lg font-bold text-purple-400">—</p><p class="text-[10px] text-gray-500">Days Active</p></div>
        </div>
      </div>
    </section>

    <!-- Stars & Diamonds (condensed) -->
    <section>
      <h2 class="text-sm font-semibold text-white mb-2 flex items-center gap-2"><span>💎</span> Stars & Diamonds</h2>
      <div class="rounded-xl border border-purple-800/50 bg-gradient-to-r from-amber-950/10 to-purple-950/10 p-4">
        <div id="sd-loading" class="text-center text-sm text-gray-500 py-2">Loading...</div>
        <div id="sd-content" class="hidden">
          <div class="grid grid-cols-2 gap-2 mb-2">
            <div class="text-center"><p id="sd-total-stars" class="text-lg font-bold text-amber-400">0</p><p class="text-[9px] text-gray-500">⭐ Stars</p></div>
            <div class="text-center"><p id="sd-diamonds-redeemed" class="text-lg font-bold text-purple-400">0</p><p class="text-[9px] text-gray-500">💎 Redeemed</p></div>
          </div>
          <div class="grid grid-cols-3 gap-2">
            <div class="text-center"><p id="sd-best-streak" class="text-sm font-bold text-amber-400">0</p><p class="text-[9px] text-gray-500">Best Streak</p></div>
            <div class="text-center"><p id="sd-current-streak" class="text-sm font-bold text-green-400">0</p><p class="text-[9px] text-gray-500">Current</p></div>
            <div class="text-center"><p id="sd-diamonds-lost" class="text-sm font-bold text-red-400">0</p><p class="text-[9px] text-gray-500">💔 Lost</p></div>
          </div>
          <div class="hidden">
            <span id="sd-diamond-streak">0</span>
            <span id="sd-near-misses">0</span>
            <span id="sd-avg-week">—</span>
            <span id="sd-avg-month">—</span>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Links -->
  <div class="flex flex-wrap gap-3 text-sm">
    <a href="/profile-data/" class="text-gray-400 hover:text-blue-400 transition-colors">👁️ View raw data</a>
    <a href="/settings/" class="text-gray-400 hover:text-purple-400 transition-colors">⚙️ Settings</a>
    <a href="/quiz-history/" class="text-gray-400 hover:text-blue-400 transition-colors">📋 Full quiz history</a>
    <a href="/wordbench-practice/" class="text-gray-400 hover:text-green-400 transition-colors">📅 Practice calendar</a>
    <a href="/activities/" class="text-gray-400 hover:text-amber-400 transition-colors">🎯 Activities</a>
  </div>
</main>

<script is:inline>
(function() {
  var uid = localStorage.getItem('swf-uid') || '';

  // ─── Helpers ───
  function formatStatsDate(dateStr) {
    if (!dateStr || dateStr === 'Unknown') return '—';
    var today = new Date().toISOString().split('T')[0];
    var yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
    if (dateStr === today) return 'Today';
    if (dateStr === yesterday) return 'Yesterday';
    var parts = dateStr.split('-');
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return parseInt(parts[2]) + ' ' + months[parseInt(parts[1]) - 1];
  }

  // ─── Saved Words ───
  var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
  document.getElementById('stat-words-saved').textContent = saved.length;

  var categories = {};
  saved.forEach(function(w) { var cat = w.category || 'manual'; categories[cat] = (categories[cat] || 0) + 1; });
  document.getElementById('wotd-saved').textContent = categories['wotd'] || 0;

  var lookedUp = saved.filter(function(w) { return w.meaning && w.meaning.trim() && w.meaning.indexOf('Scrabble-legal') === -1 && w.meaning.indexOf('no standard') === -1; }).length;
  document.getElementById('wotd-looked-up').textContent = lookedUp;

  // WOTD activity days
  var wotdKeys = Object.keys(localStorage).filter(function(k) { return k === 'swf-wotd-cache'; });
  document.getElementById('wotd-streak').textContent = wotdKeys.length > 0 ? '1+' : '0';

  // ─── Streaks ───
  var anagramStreak = JSON.parse(localStorage.getItem('swf-anagram-streak') || '{"count":0}');
  document.getElementById('anagram-stat-streak').textContent = anagramStreak.count > 0 ? anagramStreak.count : '0';
  document.getElementById('stat-streak').textContent = anagramStreak.count || '0';

  // ─── 60-Second ───
  var sixtyRaw = localStorage.getItem('swf-60s-pb');
  var sixtyPBObj = null;
  if (sixtyRaw) {
    try { sixtyPBObj = JSON.parse(sixtyRaw); } catch(e) {}
    if (!sixtyPBObj || typeof sixtyPBObj.score !== 'number') {
      // Legacy plain number
      var num = parseInt(sixtyRaw);
      sixtyPBObj = isNaN(num) ? null : { score: num, achievedAt: null };
    }
  }
  if (sixtyPBObj && sixtyPBObj.score > 0) {
    var pbText = sixtyPBObj.score + ' pts';
    if (sixtyPBObj.achievedAt) {
      var d = new Date(sixtyPBObj.achievedAt);
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      pbText += ' (' + d.getDate() + ' ' + months[d.getMonth()] + ')';
    }
    document.getElementById('sixty-stat-pb').textContent = pbText;
  } else {
    document.getElementById('sixty-stat-pb').textContent = '—';
  }

  // ─── Anagram solved ───
  var anagramKeys = Object.keys(localStorage).filter(function(k) { return k.startsWith('swf-anagram-2'); });
  var solvedCount = 0;
  anagramKeys.forEach(function(k) { try { var s = JSON.parse(localStorage.getItem(k)); if (s && s.solved) solvedCount++; } catch(e) {} });
  document.getElementById('anagram-stat-solved').textContent = solvedCount + ' solved';

  // ─── Quiz (from API) ───
  if (uid) {
    fetch('/api/quiz-scores/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var scores = data.scores || [];
        document.getElementById('quiz-loading').classList.add('hidden');
        document.getElementById('quiz-content').classList.remove('hidden');
        document.getElementById('stat-quizzes').textContent = scores.length;
        document.getElementById('quiz-total').textContent = scores.length;
        if (scores.length > 0) {
          var totalPct = scores.reduce(function(sum, s) { return sum + (s.total > 0 ? (s.score / s.total) * 100 : 0); }, 0);
          document.getElementById('quiz-avg').textContent = Math.round(totalPct / scores.length) + '%';
          document.getElementById('quiz-perfect').textContent = scores.filter(function(s) { return s.score === s.total; }).length;
          document.getElementById('quiz-best').textContent = Math.round(Math.max.apply(null, scores.map(function(s) { return s.total > 0 ? (s.score / s.total) * 100 : 0; }))) + '%';
          var recent = scores.slice(0, 5);
          document.getElementById('quiz-recent-list').innerHTML = recent.map(function(s) {
            var pct = s.total > 0 ? Math.round((s.score / s.total) * 100) : 0;
            var color = pct === 100 ? 'text-green-400' : pct >= 70 ? 'text-blue-400' : 'text-amber-400';
            var date = new Date(s.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
            return '<div class="flex items-center justify-between text-sm"><span class="text-gray-400">' + date + ' — ' + s.score + '/' + s.total + '</span><span class="font-bold ' + color + '">' + pct + '%</span></div>';
          }).join('');
        }
      }).catch(function() { document.getElementById('quiz-loading').textContent = 'Could not load'; });

    // ─── Practice ───
    fetch('/api/wordbench-practice/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var entries = data.entries || [];
        document.getElementById('wb-loading').classList.add('hidden');
        document.getElementById('wb-content').classList.remove('hidden');
        document.getElementById('stat-practice').textContent = entries.length;
        document.getElementById('wb-total').textContent = entries.length;
        var dates = {}; var cats = {}; var today = new Date().toISOString().split('T')[0]; var todayCount = 0;
        entries.forEach(function(e) {
          var d = (e.created_at || '').split(' ')[0] || (e.created_at || '').split('T')[0];
          dates[d] = true; cats[e.category || 'general'] = (cats[e.category || 'general'] || 0) + 1;
          if (d === today) todayCount++;
        });
        document.getElementById('wb-sessions').textContent = Object.keys(dates).length;
        document.getElementById('wb-categories').textContent = Object.keys(cats).length;
        document.getElementById('wb-today').textContent = todayCount;
        document.getElementById('wb-category-pills').innerHTML = Object.keys(cats).map(function(cat) {
          return '<span class="px-2 py-1 rounded-lg bg-green-900/30 border border-green-700/50 text-xs text-green-300">' + cat + ' <span class="text-green-500 font-bold">' + cats[cat] + '</span></span>';
        }).join('');
      }).catch(function() { document.getElementById('wb-loading').textContent = 'Could not load'; });

    // ─── Daily Rack history ───
    fetch('/api/daily-rack/?user_id=' + encodeURIComponent(uid) + '&history=true')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.history && data.history.length > 0) {
          var best = data.history.reduce(function(max, h) { return h.score > max ? h.score : max; }, 0);
          document.getElementById('drc-stat-best').textContent = best + ' pts';
          document.getElementById('drc-stat-played').textContent = data.history.length + ' days';
        }
      }).catch(function() {});

    // ─── Stars & Diamonds ───
    fetch('/api/daily-progress?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        document.getElementById('sd-loading').classList.add('hidden');
        document.getElementById('sd-content').classList.remove('hidden');
        var lt = data.lifetime || {};
        document.getElementById('sd-total-stars').textContent = lt.total_stars || 0;
        document.getElementById('sd-diamonds-redeemed').textContent = lt.total_diamonds || 0;
        document.getElementById('sd-best-streak').textContent = lt.best_streak || 0;
        document.getElementById('sd-current-streak').textContent = lt.current_streak || 0;
        document.getElementById('sd-diamond-streak').textContent = lt.best_diamond_streak || 0;
        document.getElementById('sd-diamonds-lost').textContent = lt.diamonds_lost || 0;
        // Near misses + averages
        if (lt.near_misses !== undefined) document.getElementById('sd-near-misses').textContent = lt.near_misses;
        if (lt.avg_stars_week !== undefined) document.getElementById('sd-avg-week').textContent = lt.avg_stars_week;
        if (lt.avg_stars_month !== undefined) document.getElementById('sd-avg-month').textContent = lt.avg_stars_month;
      }).catch(function() { document.getElementById('sd-loading').textContent = 'Could not load'; });
  } else {
    document.getElementById('quiz-loading').textContent = 'Play a quiz to see stats';
    document.getElementById('wb-loading').textContent = 'Practice words to see stats';
    document.getElementById('stat-quizzes').textContent = '0';
    document.getElementById('stat-practice').textContent = '0';
  }

  // ─── Game History Expand/Collapse (works without uid) ───
  // Daily Rack expand
  document.getElementById('drc-expand-btn').addEventListener('click', function() {
    var section = document.getElementById('drc-history-section');
    if (!section.classList.contains('hidden')) { section.classList.add('hidden'); this.textContent = '▶ History'; return; }
    section.classList.remove('hidden');
    this.textContent = '▼ History';
    if (!uid) { document.getElementById('drc-history-section-loading').classList.add('hidden'); document.getElementById('drc-history-section-empty').classList.remove('hidden'); return; }
    loadDrcHistoryPanel();
  });
  document.getElementById('drc-history-section-close').addEventListener('click', function() {
    document.getElementById('drc-history-section').classList.add('hidden');
    document.getElementById('drc-expand-btn').textContent = '▶ History';
  });

  function loadDrcHistoryPanel() {
    var loadEl = document.getElementById('drc-history-section-loading');
    var emptyEl = document.getElementById('drc-history-section-empty');
    var contentEl = document.getElementById('drc-history-section-content');
    loadEl.classList.remove('hidden'); emptyEl.classList.add('hidden'); contentEl.classList.add('hidden');
    fetch('/api/rack-history/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loadEl.classList.add('hidden');
        var history = data.history || [];
        if (history.length === 0) { emptyEl.classList.remove('hidden'); return; }
        contentEl.classList.remove('hidden');
        var totalWords = history.length;
        var totalScore = history.reduce(function(s, h) { return s + (h.score || 0); }, 0);
        var avgScore = totalWords > 0 ? Math.round(totalScore / totalWords) : 0;
        document.getElementById('drc-history-section-stats').innerHTML =
          '<div class="rounded-lg bg-amber-900/20 border border-amber-700/30 p-2 text-center"><p class="text-lg font-bold text-amber-400">' + totalWords + '</p><p class="text-[9px] text-gray-500">Words</p></div>' +
          '<div class="rounded-lg bg-green-900/20 border border-green-700/30 p-2 text-center"><p class="text-lg font-bold text-green-400">' + avgScore + '</p><p class="text-[9px] text-gray-500">Avg Pts</p></div>' +
          '<div class="rounded-lg bg-purple-900/20 border border-purple-700/30 p-2 text-center"><p class="text-lg font-bold text-purple-400">' + history.filter(function(h) { return h.word && h.word.length === 7; }).length + '</p><p class="text-[9px] text-gray-500">Bingos</p></div>';
        var groups = {};
        history.forEach(function(h) { var d = h.submitted_at ? h.submitted_at.split(/[T ]/)[0] : 'Unknown'; if (!groups[d]) groups[d] = []; groups[d].push(h); });
        var dateKeys = Object.keys(groups).sort(function(a, b) { return b.localeCompare(a); });
        var html = '';
        dateKeys.slice(0, 15).forEach(function(date, idx) {
          var words = groups[date]; var rack = (data.racks || {})[date] || ''; var gid = 'stats-rack-g-' + idx;
          html += '<div class="mb-2 rounded-lg border border-gray-700/50 overflow-hidden">';
          html += '<div class="flex items-center justify-between gap-2 px-3 py-1.5 bg-gray-800/60 cursor-pointer" onclick="(function(){var el=document.getElementById(\'' + gid + '\');el.classList.toggle(\'hidden\');})();">';
          html += '<span class="text-[10px] text-gray-400 font-semibold">' + formatStatsDate(date) + '</span>';
          if (rack) { html += '<span class="text-[9px] text-gray-500 font-mono">' + rack + '</span>'; }
          html += '<span class="text-[10px] text-gray-500">' + words.length + ' word' + (words.length > 1 ? 's' : '') + '</span>';
          html += '</div>';
          html += '<div id="' + gid + '" class="hidden px-3 py-2 space-y-1">';
          words.forEach(function(w) { html += '<div class="flex items-center justify-between text-xs"><span class="font-mono uppercase text-amber-300">' + w.word + '</span><span class="text-green-400 font-bold">' + w.score + ' pts</span></div>'; });
          html += '</div></div>';
        });
        document.getElementById('drc-history-section-groups').innerHTML = html;
      }).catch(function() { loadEl.innerHTML = '<p class="text-xs text-red-400">Failed to load</p>'; });
  }

  // Daily Anagram expand
  document.getElementById('anagram-expand-btn').addEventListener('click', function() {
    var section = document.getElementById('anagram-history-section');
    if (!section.classList.contains('hidden')) { section.classList.add('hidden'); this.textContent = '▶ History'; return; }
    section.classList.remove('hidden');
    this.textContent = '▼ History';
    if (!uid) { document.getElementById('anagram-history-section-loading').classList.add('hidden'); document.getElementById('anagram-history-section-empty').classList.remove('hidden'); return; }
    loadAnagramHistoryPanel();
  });
  document.getElementById('anagram-history-section-close').addEventListener('click', function() {
    document.getElementById('anagram-history-section').classList.add('hidden');
    document.getElementById('anagram-expand-btn').textContent = '▶ History';
  });

  function loadAnagramHistoryPanel() {
    var loadEl = document.getElementById('anagram-history-section-loading');
    var emptyEl = document.getElementById('anagram-history-section-empty');
    var contentEl = document.getElementById('anagram-history-section-content');
    loadEl.classList.remove('hidden'); emptyEl.classList.add('hidden'); contentEl.classList.add('hidden');
    fetch('/api/anagram-history/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loadEl.classList.add('hidden');
        var history = data.history || [];
        if (history.length === 0) { emptyEl.classList.remove('hidden'); return; }
        contentEl.classList.remove('hidden');
        var solved = history.filter(function(h) { return h.solved; }).length;
        var avgGuesses = history.length > 0 ? (history.reduce(function(s, h) { return s + (h.attempts || 0); }, 0) / history.length).toFixed(1) : '—';
        document.getElementById('anagram-history-section-stats').innerHTML =
          '<div class="rounded-lg bg-rose-900/20 border border-rose-700/30 p-2 text-center"><p class="text-lg font-bold text-rose-400">' + history.length + '</p><p class="text-[9px] text-gray-500">Played</p></div>' +
          '<div class="rounded-lg bg-green-900/20 border border-green-700/30 p-2 text-center"><p class="text-lg font-bold text-green-400">' + solved + '</p><p class="text-[9px] text-gray-500">Solved</p></div>' +
          '<div class="rounded-lg bg-amber-900/20 border border-amber-700/30 p-2 text-center"><p class="text-lg font-bold text-amber-400">' + avgGuesses + '</p><p class="text-[9px] text-gray-500">Avg Guesses</p></div>';
        var listHtml = '';
        history.slice(0, 20).forEach(function(h) {
          var date = h.played_date || h.created_at || ''; if (date.indexOf('T') > -1) date = date.split('T')[0];
          var icon = h.solved ? '🟩' : '🟥'; var guessesText = h.attempts ? h.attempts + '/5' : '—';
          listHtml += '<div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-gray-800/40 border border-gray-700/30">';
          listHtml += '<span class="text-[10px] text-gray-400">' + formatStatsDate(date) + '</span>';
          listHtml += '<span class="text-xs font-mono uppercase text-rose-300">' + (h.word || '???') + '</span>';
          listHtml += '<span class="text-[10px]">' + icon + ' ' + guessesText + '</span></div>';
        });
        document.getElementById('anagram-history-section-list').innerHTML = listHtml;
      }).catch(function() { loadEl.innerHTML = '<p class="text-xs text-red-400">Failed to load</p>'; });
  }

  // 60-Second expand
  document.getElementById('sixty-expand-btn').addEventListener('click', function() {
    var section = document.getElementById('sixty-history-section');
    if (!section.classList.contains('hidden')) { section.classList.add('hidden'); this.textContent = '▶ History'; return; }
    section.classList.remove('hidden');
    this.textContent = '▼ History';
    loadSixtyHistoryPanel();
  });
  document.getElementById('sixty-history-section-close').addEventListener('click', function() {
    document.getElementById('sixty-history-section').classList.add('hidden');
    document.getElementById('sixty-expand-btn').textContent = '▶ History';
  });

  function loadSixtyHistoryPanel() {
    var loadEl = document.getElementById('sixty-history-section-loading');
    var emptyEl = document.getElementById('sixty-history-section-empty');
    var contentEl = document.getElementById('sixty-history-section-content');
    loadEl.classList.remove('hidden'); emptyEl.classList.add('hidden'); contentEl.classList.add('hidden');
    var history = [];
    try { history = JSON.parse(localStorage.getItem('swf-60s-history') || '[]'); } catch(e) {}
    loadEl.classList.add('hidden');
    if (history.length === 0) { emptyEl.classList.remove('hidden'); return; }
    contentEl.classList.remove('hidden');
    var best = history.reduce(function(m, h) { return h.total > m ? h.total : m; }, 0);
    var avg = Math.round(history.reduce(function(s, h) { return s + h.total; }, 0) / history.length);
    document.getElementById('sixty-history-section-stats').innerHTML =
      '<div class="rounded-lg bg-green-900/20 border border-green-700/30 p-2 text-center"><p class="text-lg font-bold text-green-400">' + history.length + '</p><p class="text-[9px] text-gray-500">Rounds</p></div>' +
      '<div class="rounded-lg bg-amber-900/20 border border-amber-700/30 p-2 text-center"><p class="text-lg font-bold text-amber-400">' + best + '</p><p class="text-[9px] text-gray-500">Best</p></div>' +
      '<div class="rounded-lg bg-blue-900/20 border border-blue-700/30 p-2 text-center"><p class="text-lg font-bold text-blue-400">' + avg + '</p><p class="text-[9px] text-gray-500">Avg Pts</p></div>';
    var listHtml = '';
    history.slice(0, 20).forEach(function(round, idx) {
      var date = round.created_at ? round.created_at.split('T')[0] : '';
      var wordCount = round.words ? round.words.length : 0;
      var wordPills = (round.words || []).slice(0, 5).map(function(w) {
        return '<span class="px-1 py-0.5 rounded bg-gray-800 border border-gray-700 text-[9px] text-gray-300 font-mono uppercase">' + w.word + ' <span class="text-amber-400">' + w.points + '</span></span>';
      }).join(' ');
      var moreText = wordCount > 5 ? ' <span class="text-[9px] text-gray-500">+' + (wordCount - 5) + ' more</span>' : '';
      listHtml += '<div class="p-2.5 rounded-lg border border-gray-800 bg-gray-900/30">';
      listHtml += '<div class="flex items-center justify-between mb-1.5">';
      listHtml += '<span class="text-[10px] text-gray-500">#' + (idx + 1) + ' — ' + formatStatsDate(date) + '</span>';
      listHtml += '<span class="text-xs font-bold text-amber-400">' + round.total + ' pts</span></div>';
      listHtml += '<div class="flex flex-wrap gap-1">' + wordPills + moreText + '</div></div>';
    });
    document.getElementById('sixty-history-section-list').innerHTML = listHtml;
  }
})();
</script>
