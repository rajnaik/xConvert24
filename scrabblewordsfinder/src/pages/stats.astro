---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Your Stats — ScrabbleWordsFinder" description="View your personal Scrabble statistics: quiz scores, practice history, streaks, saved words, and game performance." keywords="scrabble stats, word finder stats, quiz history, practice tracking, scrabble progress">

<main class="mx-auto max-w-4xl px-4 sm:px-6 py-8 pb-20">
  <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2"><span class="text-purple-400">📊</span> Your Stats</h1>
  <p class="text-sm text-gray-400 mb-6">Your personal performance across all ScrabbleWordsFinder activities.</p>

  <!-- Top-level summary cards -->
  <div id="summary-cards" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-words-saved" class="text-2xl font-black text-purple-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Words Saved</p>
    </div>
    <div class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-quizzes" class="text-2xl font-black text-blue-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Quizzes Played</p>
    </div>
    <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-practice" class="text-2xl font-black text-green-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Practice Sessions</p>
    </div>
    <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-4 text-center">
      <p id="stat-streak" class="text-2xl font-black text-amber-400">—</p>
      <p class="text-xs text-gray-500 mt-1">Best Streak</p>
    </div>
  </div>

  <!-- Quiz Performance -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>🧠</span> Quiz Performance</h2>
    <div id="quiz-stats" class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-5">
      <div id="quiz-loading" class="text-center text-sm text-gray-500 py-4">Loading quiz data...</div>
      <div id="quiz-content" class="hidden">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
          <div class="text-center"><p id="quiz-total" class="text-xl font-bold text-blue-400">0</p><p class="text-xs text-gray-500">Total Quizzes</p></div>
          <div class="text-center"><p id="quiz-avg" class="text-xl font-bold text-blue-400">0%</p><p class="text-xs text-gray-500">Avg Score</p></div>
          <div class="text-center"><p id="quiz-perfect" class="text-xl font-bold text-blue-400">0</p><p class="text-xs text-gray-500">Perfect Scores</p></div>
          <div class="text-center"><p id="quiz-best" class="text-xl font-bold text-blue-400">0%</p><p class="text-xs text-gray-500">Best Score</p></div>
        </div>
        <div id="quiz-recent" class="border-t border-gray-800 pt-3">
          <p class="text-xs text-gray-500 uppercase mb-2">Recent Quizzes</p>
          <div id="quiz-recent-list" class="space-y-1.5"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- WordBench / Practice -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📚</span> Memory WordBench</h2>
    <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-5">
      <div id="wb-loading" class="text-center text-sm text-gray-500 py-4">Loading practice data...</div>
      <div id="wb-content" class="hidden">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
          <div class="text-center"><p id="wb-total" class="text-xl font-bold text-green-400">0</p><p class="text-xs text-gray-500">Words Practised</p></div>
          <div class="text-center"><p id="wb-sessions" class="text-xl font-bold text-green-400">0</p><p class="text-xs text-gray-500">Sessions</p></div>
          <div class="text-center"><p id="wb-categories" class="text-xl font-bold text-green-400">0</p><p class="text-xs text-gray-500">Categories</p></div>
          <div class="text-center"><p id="wb-today" class="text-xl font-bold text-green-400">0</p><p class="text-xs text-gray-500">Today</p></div>
        </div>
        <div id="wb-by-category" class="border-t border-gray-800 pt-3">
          <p class="text-xs text-gray-500 uppercase mb-2">Words by Category</p>
          <div id="wb-category-pills" class="flex flex-wrap gap-2"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Games (Daily Rack + Anagram + 60s) -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>🎮</span> Games</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-5 text-center">
        <p class="text-2xl mb-1">🎲</p>
        <p class="text-sm font-semibold text-white mb-2">Daily Rack</p>
        <p id="drc-stat-best" class="text-lg font-bold text-amber-400">—</p>
        <p class="text-xs text-gray-500">All-Time Best</p>
        <p id="drc-stat-played" class="text-sm text-gray-400 mt-2">— days played</p>
      </div>
      <div class="rounded-xl border border-rose-800/50 bg-gray-900/50 p-5 text-center">
        <p class="text-2xl mb-1">🔤</p>
        <p class="text-sm font-semibold text-white mb-2">Daily Anagram</p>
        <p id="anagram-stat-streak" class="text-lg font-bold text-rose-400">—</p>
        <p class="text-xs text-gray-500">Current Streak</p>
        <p id="anagram-stat-solved" class="text-sm text-gray-400 mt-2">— solved</p>
      </div>
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-5 text-center">
        <p class="text-2xl mb-1">⏱️</p>
        <p class="text-sm font-semibold text-white mb-2">60-Second</p>
        <p id="sixty-stat-pb" class="text-lg font-bold text-green-400">—</p>
        <p class="text-xs text-gray-500">Personal Best</p>
      </div>
    </div>
  </section>

  <!-- WOTD -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📖</span> Word of the Day</h2>
    <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-5">
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center"><p id="wotd-saved" class="text-xl font-bold text-purple-400">—</p><p class="text-xs text-gray-500">Saved</p></div>
        <div class="text-center"><p id="wotd-looked-up" class="text-xl font-bold text-purple-400">—</p><p class="text-xs text-gray-500">Looked Up</p></div>
        <div class="text-center"><p id="wotd-streak" class="text-xl font-bold text-purple-400">—</p><p class="text-xs text-gray-500">Days Active</p></div>
      </div>
    </div>
  </section>

  <!-- Links -->
  <div class="flex flex-wrap gap-3 text-sm">
    <a href="/profile-data/" class="text-gray-400 hover:text-blue-400 transition-colors">👁️ View raw data</a>
    <a href="/settings/" class="text-gray-400 hover:text-purple-400 transition-colors">⚙️ Settings</a>
    <a href="/quiz-history/" class="text-gray-400 hover:text-blue-400 transition-colors">📋 Full quiz history</a>
    <a href="/wordbench-practice/" class="text-gray-400 hover:text-green-400 transition-colors">📅 Practice calendar</a>
    <a href="/activities/" class="text-gray-400 hover:text-amber-400 transition-colors">🎯 Activities</a>
  </div>
</main>

<script is:inline>
(function() {
  var uid = localStorage.getItem('swf-uid') || '';

  // ─── Saved Words ───
  var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
  document.getElementById('stat-words-saved').textContent = saved.length;

  var categories = {};
  saved.forEach(function(w) { var cat = w.category || 'manual'; categories[cat] = (categories[cat] || 0) + 1; });
  document.getElementById('wotd-saved').textContent = categories['wotd'] || 0;

  var lookedUp = saved.filter(function(w) { return w.meaning && w.meaning.trim() && w.meaning.indexOf('Scrabble-legal') === -1 && w.meaning.indexOf('no standard') === -1; }).length;
  document.getElementById('wotd-looked-up').textContent = lookedUp;

  // WOTD activity days
  var wotdKeys = Object.keys(localStorage).filter(function(k) { return k === 'swf-wotd-cache'; });
  document.getElementById('wotd-streak').textContent = wotdKeys.length > 0 ? '1+' : '0';

  // ─── Streaks ───
  var anagramStreak = JSON.parse(localStorage.getItem('swf-anagram-streak') || '{"count":0}');
  document.getElementById('anagram-stat-streak').textContent = anagramStreak.count > 0 ? anagramStreak.count : '0';
  document.getElementById('stat-streak').textContent = anagramStreak.count || '0';

  // ─── 60-Second ───
  var sixtyPB = localStorage.getItem('swf-60s-pb');
  document.getElementById('sixty-stat-pb').textContent = sixtyPB ? sixtyPB + ' pts' : '—';

  // ─── Anagram solved ───
  var anagramKeys = Object.keys(localStorage).filter(function(k) { return k.startsWith('swf-anagram-2'); });
  var solvedCount = 0;
  anagramKeys.forEach(function(k) { try { var s = JSON.parse(localStorage.getItem(k)); if (s && s.solved) solvedCount++; } catch(e) {} });
  document.getElementById('anagram-stat-solved').textContent = solvedCount + ' solved';

  // ─── Quiz (from API) ───
  if (uid) {
    fetch('/api/quiz-scores/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var scores = data.scores || [];
        document.getElementById('quiz-loading').classList.add('hidden');
        document.getElementById('quiz-content').classList.remove('hidden');
        document.getElementById('stat-quizzes').textContent = scores.length;
        document.getElementById('quiz-total').textContent = scores.length;
        if (scores.length > 0) {
          var totalPct = scores.reduce(function(sum, s) { return sum + (s.total > 0 ? (s.score / s.total) * 100 : 0); }, 0);
          document.getElementById('quiz-avg').textContent = Math.round(totalPct / scores.length) + '%';
          document.getElementById('quiz-perfect').textContent = scores.filter(function(s) { return s.score === s.total; }).length;
          document.getElementById('quiz-best').textContent = Math.round(Math.max.apply(null, scores.map(function(s) { return s.total > 0 ? (s.score / s.total) * 100 : 0; }))) + '%';
          var recent = scores.slice(0, 5);
          document.getElementById('quiz-recent-list').innerHTML = recent.map(function(s) {
            var pct = s.total > 0 ? Math.round((s.score / s.total) * 100) : 0;
            var color = pct === 100 ? 'text-green-400' : pct >= 70 ? 'text-blue-400' : 'text-amber-400';
            var date = new Date(s.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
            return '<div class="flex items-center justify-between text-sm"><span class="text-gray-400">' + date + ' — ' + s.score + '/' + s.total + '</span><span class="font-bold ' + color + '">' + pct + '%</span></div>';
          }).join('');
        }
      }).catch(function() { document.getElementById('quiz-loading').textContent = 'Could not load'; });

    // ─── Practice ───
    fetch('/api/wordbench-practice/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var entries = data.entries || [];
        document.getElementById('wb-loading').classList.add('hidden');
        document.getElementById('wb-content').classList.remove('hidden');
        document.getElementById('stat-practice').textContent = entries.length;
        document.getElementById('wb-total').textContent = entries.length;
        var dates = {}; var cats = {}; var today = new Date().toISOString().split('T')[0]; var todayCount = 0;
        entries.forEach(function(e) {
          var d = (e.created_at || '').split(' ')[0] || (e.created_at || '').split('T')[0];
          dates[d] = true; cats[e.category || 'general'] = (cats[e.category || 'general'] || 0) + 1;
          if (d === today) todayCount++;
        });
        document.getElementById('wb-sessions').textContent = Object.keys(dates).length;
        document.getElementById('wb-categories').textContent = Object.keys(cats).length;
        document.getElementById('wb-today').textContent = todayCount;
        document.getElementById('wb-category-pills').innerHTML = Object.keys(cats).map(function(cat) {
          return '<span class="px-2 py-1 rounded-lg bg-green-900/30 border border-green-700/50 text-xs text-green-300">' + cat + ' <span class="text-green-500 font-bold">' + cats[cat] + '</span></span>';
        }).join('');
      }).catch(function() { document.getElementById('wb-loading').textContent = 'Could not load'; });

    // ─── Daily Rack history ───
    fetch('/api/daily-rack/?user_id=' + encodeURIComponent(uid) + '&history=true')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.history && data.history.length > 0) {
          var best = data.history.reduce(function(max, h) { return h.score > max ? h.score : max; }, 0);
          document.getElementById('drc-stat-best').textContent = best + ' pts';
          document.getElementById('drc-stat-played').textContent = data.history.length + ' days';
        }
      }).catch(function() {});
  } else {
    document.getElementById('quiz-loading').textContent = 'Play a quiz to see stats';
    document.getElementById('wb-loading').textContent = 'Practice words to see stats';
    document.getElementById('stat-quizzes').textContent = '0';
    document.getElementById('stat-practice').textContent = '0';
  }
})();
</script>
</Layout>
