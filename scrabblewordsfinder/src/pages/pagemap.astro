---
import Layout from '../layouts/Layout.astro';
import PageMapGraph from '../components/PageMapGraph.tsx';
import '../styles/global.css';
---

<Layout title="Page Map — ScrabbleWordsFinder Site Structure" description="Interactive visual map of all 680+ pages on ScrabbleWordsFinder.com showing internal links and site structure. Explore the full sitemap as a node graph." keywords="site map, page map, internal links, scrabble words finder pages, site structure, node graph">

<div class="max-w-7xl mx-auto px-4 pt-4 pb-6">
  <h1 class="text-2xl font-bold text-white mb-2">Page Map</h1>
  <p class="text-gray-400 mb-4 text-sm">Interactive graph of all public pages and their internal links. Scroll to zoom, drag to pan, click a node to inspect connections.</p>

  <!-- Graph container with fixed height -->
  <div class="graph-area w-full rounded-lg border border-gray-700 overflow-hidden" style="height: 70vh; min-height: 500px;">
    <PageMapGraph client:only="react" />
  </div>

  <div class="mt-6 text-sm text-gray-400">
    <p>This graph shows <strong class="text-white">682 pages</strong> and <strong class="text-white">4,876 internal links</strong> across ScrabbleWordsFinder.com. Pages are colour-coded by type: gold for the homepage, purple for root-level pages, green for blog posts, and cyan for cheat sheets.</p>
  </div>

  <!-- About this page -->
  <section class="mt-8 prose prose-sm prose-invert max-w-none text-gray-300 leading-relaxed">
    <h2 class="text-lg font-bold text-white mb-3">About the Page Map</h2>
    <p>
      The Page Map is an interactive visual representation of the entire ScrabbleWordsFinder website structure. It renders every public page as a node and every internal link as an edge, creating a force-directed graph that reveals how content connects across the site. You can scroll to zoom in and out, drag to pan across the graph, and click any node to highlight its direct connections.
    </p>
    <p>
      Understanding site structure matters for both users and search engines. A well-connected site ensures visitors can discover related content quickly — from strategy guides to word lists, from daily challenges to cheat sheets. Search engine crawlers also benefit from clear internal linking, as it helps them understand content relationships and distribute page authority effectively.
    </p>
    <p>
      The colour coding provides instant visual orientation. Gold represents the homepage (the central hub), purple marks root-level utility pages like the solver, activities, and settings. Green nodes are blog articles — the largest cluster, covering strategy, word lists, history, and tips. Cyan nodes represent cheat sheets and quick-reference printable guides. This visual map helps identify orphan pages, thin clusters, and opportunities to strengthen internal linking.
    </p>
    <p>
      With over 680 pages and nearly 5,000 internal links, ScrabbleWordsFinder has grown into a comprehensive resource for Scrabble players at every level. The Page Map updates automatically as new content is published, giving you a live snapshot of the site's topology. Whether you are looking for a specific guide or simply exploring what is available, this graph makes the entire site navigable at a glance — free and instantly accessible.
    </p>
  </section>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the ScrabbleWordsFinder Page Map?", "acceptedAnswer": { "@type": "Answer", "text": "An interactive visual map showing all 680+ pages on the site as a node graph, revealing internal links and site structure at a glance." } },
    { "@type": "Question", "name": "How many pages does ScrabbleWordsFinder have?", "acceptedAnswer": { "@type": "Answer", "text": "Over 680 public pages including the word solver, 300+ blog articles, game features, cheat sheets, and informational pages." } },
    { "@type": "Question", "name": "Can I navigate the site from the page map?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, click any node in the graph to visit that page directly. The map shows how pages connect through internal links." } }
  ]
})}></script>
</Layout>

<style is:global>
  .graph-area astro-island,
  .graph-area astro-island > div {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
  }
</style>
