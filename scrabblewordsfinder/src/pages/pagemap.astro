---
import Layout from '../layouts/Layout.astro';
import PageMapGraph from '../components/PageMapGraph.tsx';
import '../styles/global.css';
---

<Layout title="Page Map — ScrabbleWordsFinder Site Structure" description="Interactive visual map of all 680+ pages on ScrabbleWordsFinder.com showing internal links and site structure. Explore the full sitemap as a node graph." keywords="site map, page map, internal links, scrabble words finder pages, site structure, node graph">

<div class="max-w-7xl mx-auto px-4 pt-4 pb-6">
  <h1 class="text-2xl font-bold text-white mb-2">Page Map</h1>
  <p class="text-gray-400 mb-4 text-sm">Interactive graph of all public pages and their internal links. Scroll to zoom, drag to pan, click a node to inspect connections.</p>

  <!-- Graph container with fixed height -->
  <div class="graph-area w-full rounded-lg border border-gray-700 overflow-hidden" style="height: 70vh; min-height: 500px;">
    <PageMapGraph client:only="react" />
  </div>

  <div class="mt-6 text-sm text-gray-400">
    <p>This graph shows <strong class="text-white">682 pages</strong> and <strong class="text-white">4,876 internal links</strong> across ScrabbleWordsFinder.com. Pages are colour-coded by type: gold for the homepage, purple for root-level pages, green for blog posts, and cyan for cheat sheets.</p>
  </div>
</div>

</Layout>

<style is:global>
  .graph-area astro-island,
  .graph-area astro-island > div {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
  }
</style>
