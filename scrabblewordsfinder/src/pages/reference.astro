---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Scrabble Reference Hub — Original Statistics, Analysis & Datasets"
  description="Original Scrabble research: scoring statistics, bingo probability, tile analysis, game data, and downloadable datasets. Free to cite with attribution."
  keywords="scrabble reference, scrabble statistics, scrabble data, scrabble analysis, bingo probability, tile distribution data, scrabble scoring research, original scrabble data"
>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Scrabble Reference Hub",
  "description": "Original Scrabble research articles, statistics, and downloadable datasets.",
  "url": "https://www.scrabblewordsfinder.com/reference/",
})} />

<div class="max-w-4xl mx-auto px-4 py-8">

  <div class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-light text-white mb-3">Scrabble Reference Hub</h1>
    <p class="text-gray-400 text-sm max-w-xl mx-auto">Original research, statistics, and datasets about competitive Scrabble. Free to use with attribution to ScrabbleWordsFinder.com.</p>
  </div>

  <!-- Research Articles -->
  <h2 class="text-lg font-semibold text-white mb-4">📊 Research Articles</h2>
  <div class="grid gap-3 mb-10">
    <a href="/blog/highest-scoring-scrabble-words/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Highest Scoring Scrabble Words Ever</p>
        <p class="text-xs text-gray-500">Complete analysis of maximum-scoring words by length, including theoretical and tournament records.</p>
      </div>
    </a>
    <a href="/blog/bingo-probability/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Bingo Probability — Odds of Playing All 7 Tiles</p>
        <p class="text-xs text-gray-500">Statistical analysis of bingo rates by rack composition, stem frequency, and dictionary size.</p>
      </div>
    </a>
    <a href="/blog/average-winning-score/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Average Winning Score — By Skill Level & Format</p>
        <p class="text-xs text-gray-500">Score distributions across casual, club, and tournament play. What you need to win.</p>
      </div>
    </a>
    <a href="/blog/average-game-length/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Average Game Length — Time, Turns & Tile Statistics</p>
        <p class="text-xs text-gray-500">How long Scrabble games last by format, turn counts, and tile usage patterns.</p>
      </div>
    </a>
    <a href="/blog/highest-possible-scrabble-score/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Highest Possible Scrabble Score — Theoretical Maximum</p>
        <p class="text-xs text-gray-500">Mathematical analysis of the maximum achievable score in a single game.</p>
      </div>
    </a>
    <a href="/blog/scrabble-science-probability-statistics-strategy/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">The Science of Scrabble — Probability, Statistics & Strategy</p>
        <p class="text-xs text-gray-500">Mathematical framework for optimal play: probability calculations, expected value, and decision theory.</p>
      </div>
    </a>
    <a href="/blog/record-breaking-scrabble-games/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Record-Breaking Scrabble Games</p>
        <p class="text-xs text-gray-500">Documented records: highest game scores, single-turn records, and tournament milestones.</p>
      </div>
    </a>
    <a href="/blog/scrabble-tile-counting-endgame-deduction/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Tile Counting & Endgame Deduction</p>
        <p class="text-xs text-gray-500">Techniques for tracking played tiles and deducing opponent's rack in the endgame.</p>
      </div>
    </a>
    <a href="/blog/scrabble-complete-history-from-depression-to-championships/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">Complete History of Scrabble — Great Depression to World Championships</p>
        <p class="text-xs text-gray-500">Original research into Scrabble's origins, commercial history, and competitive evolution.</p>
      </div>
    </a>
    <a href="/blog/all-2-letter-scrabble-words/" class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-blue-700 transition-all flex items-start gap-3">
      <span class="text-blue-400 mt-0.5 shrink-0">→</span>
      <div>
        <p class="text-white font-medium text-sm">All 2-Letter Words — Complete Reference (127 words)</p>
        <p class="text-xs text-gray-500">Every valid two-letter word with score, definition, and usage frequency data.</p>
      </div>
    </a>
  </div>

  <!-- Datasets -->
  <h2 class="text-lg font-semibold text-white mb-4">💾 Downloadable Datasets</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
    <a href="/data/tile-values.json" download class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-emerald-700 transition-all">
      <p class="text-white font-medium text-sm">Tile Values & Distribution</p>
      <p class="text-xs text-gray-500">JSON — all 27 tiles with points and bag counts</p>
    </a>
    <a href="/data/letter-frequencies.json" download class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-emerald-700 transition-all">
      <p class="text-white font-medium text-sm">Letter Frequencies</p>
      <p class="text-xs text-gray-500">JSON — percentages, vowel/consonant split</p>
    </a>
    <a href="/data/two-letter-words.json" download class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-emerald-700 transition-all">
      <p class="text-white font-medium text-sm">Two-Letter Words (127)</p>
      <p class="text-xs text-gray-500">JSON — all valid words with scores + definitions</p>
    </a>
    <a href="/data/q-without-u-words.json" download class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-emerald-700 transition-all">
      <p class="text-white font-medium text-sm">Q Without U Words (33)</p>
      <p class="text-xs text-gray-500">JSON — all valid Q-no-U words</p>
    </a>
    <a href="/data/board-layout.json" download class="p-4 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-emerald-700 transition-all">
      <p class="text-white font-medium text-sm">Board Layout</p>
      <p class="text-xs text-gray-500">JSON — 15×15 grid with premium squares</p>
    </a>
    <a href="/data/" class="p-4 rounded-xl border border-blue-800/50 bg-blue-950/10 hover:border-blue-600 transition-all">
      <p class="text-blue-400 font-medium text-sm">View All Downloads & APIs →</p>
      <p class="text-xs text-gray-500">Full data page with live API links</p>
    </a>
  </div>

  <!-- APIs -->
  <h2 class="text-lg font-semibold text-white mb-4">🔌 Public APIs</h2>
  <div class="grid gap-2 mb-10">
    <div class="p-3 rounded-lg border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <span class="text-sm text-gray-300">GET /api/public/statistics/</span>
      <span class="text-xs text-gray-500">Dictionary counts, tile bag, scoring records, probabilities</span>
    </div>
    <div class="p-3 rounded-lg border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <span class="text-sm text-gray-300">GET /api/public/search/?q=</span>
      <span class="text-xs text-gray-500">Semantic search across 1,000+ articles</span>
    </div>
    <div class="p-3 rounded-lg border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <span class="text-sm text-gray-300">GET /api/public/rankings/</span>
      <span class="text-xs text-gray-500">World rankings (WESPA, YTD, Online)</span>
    </div>
    <div class="p-3 rounded-lg border border-gray-800 bg-gray-900/30 flex items-center justify-between">
      <span class="text-sm text-gray-300">GET /api/public/player/?name=</span>
      <span class="text-xs text-gray-500">Player profiles with cross-type rankings</span>
    </div>
  </div>

  <!-- Citation -->
  <div class="p-5 rounded-xl border border-gray-700 bg-gray-900/50 text-center">
    <p class="text-gray-300 text-sm mb-2">All research and data is free to use with attribution.</p>
    <p class="text-xs text-gray-400 font-mono bg-gray-800/50 p-2 rounded-lg inline-block">Source: ScrabbleWordsFinder.com</p>
    <p class="text-[10px] text-gray-500 mt-2">See our <a href="/methodology/" class="text-blue-400 hover:underline">methodology</a> for how data is produced.</p>
  </div>

</div>

</Layout>
