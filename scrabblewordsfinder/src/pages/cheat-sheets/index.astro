---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Printable Scrabble Cheat Sheets — Free Word Reference Cards" description="Free printable Scrabble cheat sheets for SOWPODS and TWL. All 2-letter words, 3-letter words, high-value words, Q without U, and vowel dumps. Free tool." keywords="scrabble cheat sheet, printable scrabble words, scrabble reference card, 2 letter words printable, scrabble word list pdf, free scrabble cheat sheet">

  <style>
    .sheets-hub { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
    .sheets-hub h1 { font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; }
    .sheets-hub .subtitle { text-align: center; color: #6b7280; margin-bottom: 2.5rem; font-size: 1rem; }
    
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
    .card { border: 2px solid #e5e7eb; border-radius: 1rem; padding: 2rem; transition: border-color 0.2s, box-shadow 0.2s; }
    .card:hover { border-color: #059669; box-shadow: 0 4px 12px rgba(5, 150, 105, 0.1); }
    .card.twl:hover { border-color: #2563eb; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1); }
    
    .card h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.5rem; }
    .card .dict-label { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; margin-bottom: 0.75rem; }
    .card .dict-label.sowpods { background: #d1fae5; color: #065f46; }
    .card .dict-label.twl { background: #dbeafe; color: #1e40af; }
    
    .card p { color: #6b7280; font-size: 0.9rem; line-height: 1.5; margin-bottom: 1rem; }
    .card ul { list-style: none; padding: 0; margin: 0 0 1.5rem; }
    .card ul li { padding: 0.3rem 0; font-size: 0.85rem; color: #374151; }
    .card ul li::before { content: "✓ "; color: #059669; font-weight: 700; }
    .card.twl ul li::before { color: #2563eb; }
    
    .card .actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .card .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.2rem; border-radius: 0.5rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: background 0.2s; }
    .card .btn-primary { background: #059669; color: white; }
    .card .btn-primary:hover { background: #047857; }
    .card.twl .btn-primary { background: #2563eb; }
    .card.twl .btn-primary:hover { background: #1d4ed8; }
    .card .btn-secondary { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
    .card .btn-secondary:hover { background: #e5e7eb; }
    
    .info-section { margin-bottom: 2rem; }
    .info-section h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.75rem; }
    .info-section p { color: #4b5563; line-height: 1.7; margin-bottom: 0.75rem; }
    .info-section ul { padding-left: 1.5rem; margin-bottom: 1rem; }
    .info-section ul li { color: #4b5563; line-height: 1.7; margin-bottom: 0.25rem; }
    
    .comparison { border: 1px solid #e5e7eb; border-radius: 0.75rem; overflow: hidden; margin-bottom: 2rem; }
    .comparison table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .comparison th { background: #f9fafb; padding: 0.75rem 1rem; text-align: left; font-weight: 600; border-bottom: 1px solid #e5e7eb; }
    .comparison td { padding: 0.6rem 1rem; border-bottom: 1px solid #f3f4f6; }
    .comparison tr:last-child td { border-bottom: none; }

    :global(.dark) .card { border-color: #374151; }
    :global(.dark) .card:hover { border-color: #10b981; }
    :global(.dark) .card.twl:hover { border-color: #60a5fa; }
    :global(.dark) .card p { color: #9ca3af; }
    :global(.dark) .card ul li { color: #d1d5db; }
    :global(.dark) .card .btn-secondary { background: #374151; color: #d1d5db; border-color: #4b5563; }
    :global(.dark) .card .dict-label.sowpods { background: #064e3b; color: #a7f3d0; }
    :global(.dark) .card .dict-label.twl { background: #1e3a5f; color: #bfdbfe; }
    :global(.dark) .info-section p, :global(.dark) .info-section ul li { color: #9ca3af; }
    :global(.dark) .comparison { border-color: #374151; }
    :global(.dark) .comparison th { background: #1f2937; border-color: #374151; }
    :global(.dark) .comparison td { border-color: #1f2937; color: #d1d5db; }
  </style>

  <div class="sheets-hub">
    <h1>Printable Scrabble Cheat Sheets</h1>
    <p class="subtitle">Free, print-friendly word reference cards for competitive Scrabble players</p>

    <div class="cards">
      <!-- SOWPODS Card -->
      <div class="card">
        <span class="dict-label sowpods">International</span>
        <h2>SOWPODS Cheat Sheet</h2>
        <p>Collins Scrabble Words &mdash; the complete international dictionary used in tournaments worldwide (except North America).</p>
        <ul>
          <li>124 two-letter words</li>
          <li>1,292 three-letter words</li>
          <li>Short J, Q, X, Z words</li>
          <li>Q without U words</li>
          <li>Vowel dump words</li>
          <li>Tile point values</li>
        </ul>
        <div class="actions">
          <a href="/cheat-sheets/sowpods/" class="btn btn-primary">View &amp; Print</a>
        </div>
      </div>

      <!-- TWL Card -->
      <div class="card twl">
        <span class="dict-label twl">North America</span>
        <h2>TWL Cheat Sheet</h2>
        <p>Tournament Word List (NWL/NASPA) &mdash; the official dictionary for North American Scrabble tournaments.</p>
        <ul>
          <li>101 two-letter words</li>
          <li>1,015 three-letter words</li>
          <li>Short J, Q, X, Z words</li>
          <li>Q without U words</li>
          <li>Vowel dump words</li>
          <li>Tile point values</li>
        </ul>
        <div class="actions">
          <a href="/cheat-sheets/twl/" class="btn btn-primary">View &amp; Print</a>
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="info-section">
      <h2>SOWPODS vs TWL &mdash; Which One Should I Use?</h2>
      <div class="comparison">
        <table>
          <thead>
            <tr><th>Feature</th><th>SOWPODS (Collins)</th><th>TWL (NWL)</th></tr>
          </thead>
          <tbody>
            <tr><td>Region</td><td>International (UK, Australia, etc.)</td><td>North America (US, Canada)</td></tr>
            <tr><td>Total words</td><td>279,000+</td><td>187,000+</td></tr>
            <tr><td>2-letter words</td><td>124</td><td>101</td></tr>
            <tr><td>3-letter words</td><td>1,292</td><td>1,015</td></tr>
            <tr><td>Use if...</td><td>Playing internationally or casually</td><td>Playing in US/Canadian tournaments</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- How to Use -->
    <div class="info-section">
      <h2>How to Use These Cheat Sheets</h2>
      <p>Each cheat sheet is designed to be printed on 2-3 pages with a compact, multi-column layout. Here's how to get the most from them:</p>
      <ul>
        <li><strong>Print:</strong> Click "Print / Save as PDF" on any sheet. The page is optimized for printing &mdash; headers, navigation, and ads are hidden automatically.</li>
        <li><strong>Save as PDF:</strong> Use your browser's "Save as PDF" option in the print dialog for a digital copy on your phone or tablet.</li>
        <li><strong>Laminate:</strong> For tournament use, print and laminate for durability.</li>
        <li><strong>Study:</strong> Focus on the 2-letter words first (they're the foundation of competitive play), then move to short high-value letter words.</li>
      </ul>
    </div>

    <!-- What's Included -->
    <div class="info-section">
      <h2>What's Included</h2>
      <ul>
        <li><strong>All 2-letter words</strong> &mdash; the most important words in Scrabble, enabling parallel plays and tight board positions</li>
        <li><strong>All 3-letter words</strong> &mdash; essential for hooks and short plays</li>
        <li><strong>Short J, Q, X, Z words</strong> &mdash; high-scoring letters that are hardest to play; knowing short words with these tiles is critical</li>
        <li><strong>Q without U words</strong> &mdash; lifesavers when you draw Q but no U</li>
        <li><strong>Vowel dump words</strong> &mdash; words with 66%+ vowels for clearing a vowel-heavy rack</li>
        <li><strong>Tile point values</strong> &mdash; quick reference for scoring</li>
      </ul>
    </div>
  </div>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are these cheat sheets free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! All cheat sheets on ScrabbleWordsFinder.com are completely free to view, print, and download as PDF. No sign-up required."
        }
      },
      {
        "@type": "Question",
        "name": "Which cheat sheet should I use for Scrabble tournaments?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you play in North American tournaments (US or Canada), use the TWL cheat sheet. For international tournaments (UK, Australia, and most other countries), use the SOWPODS cheat sheet."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use these cheat sheets during a game?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In official tournament play, you cannot reference word lists during the game. These sheets are for study and practice between games. For casual home games, house rules apply — many players allow reference materials."
        }
      }
    ]
  })} />
</Layout>
