---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import wordsRaw from '../../../public/data/twl06-2-7.json';

// TWL dictionary loaded via Vite JSON import
const words: string[] = wordsRaw;

// Extract word categories
const twoLetter = words.filter(w => w.length === 2).map(w => w.toUpperCase()).sort();
const threeLetter = words.filter(w => w.length === 3).map(w => w.toUpperCase()).sort();

// Short high-value letter words (2-4 letters containing the letter)
const shortJ = words.filter(w => w.length <= 4 && w.includes('j')).map(w => w.toUpperCase()).sort();
const shortQ = words.filter(w => w.length <= 4 && w.includes('q')).map(w => w.toUpperCase()).sort();
const shortX = words.filter(w => w.length <= 4 && w.includes('x')).map(w => w.toUpperCase()).sort();
const shortZ = words.filter(w => w.length <= 4 && w.includes('z')).map(w => w.toUpperCase()).sort();

// Vowel dumps: words with 3+ letters where vowels make up >65% of letters
const vowels = new Set(['a','e','i','o','u']);
const vowelDumps = words
  .filter(w => {
    if (w.length < 3) return false;
    const vc = [...w].filter(c => vowels.has(c)).length;
    return vc / w.length >= 0.66;
  })
  .filter(w => w.length <= 6)
  .map(w => w.toUpperCase())
  .sort((a, b) => a.length - b.length || a.localeCompare(b));

// Q without U words
const qNoU = words
  .filter(w => w.includes('q') && !w.includes('qu'))
  .map(w => w.toUpperCase())
  .sort((a, b) => a.length - b.length || a.localeCompare(b));

// Scrabble letter values
const letterValues: Record<string, number> = {
  A:1, B:3, C:3, D:2, E:1, F:4, G:2, H:4, I:1, J:8, K:5, L:1, M:3,
  N:1, O:1, P:3, Q:10, R:1, S:1, T:1, U:1, V:4, W:4, X:8, Y:4, Z:10
};
---

<Layout title="TWL Scrabble Cheat Sheet — Printable Reference" description="Free printable TWL/NWL cheat sheet for North American players. All 2-letter words, 3-letter words, J/Q/X/Z words, Q without U, and vowel dumps. Free tool." keywords="twl cheat sheet, scrabble cheat sheet printable, naspa word list, north american scrabble, 2 letter words twl, scrabble reference card" noindex={false}>

  <style>
    .cheat-sheet { max-width: 1200px; margin: 0 auto; padding: 1rem; }
    .cheat-header { text-align: center; margin-bottom: 2rem; }
    .cheat-header h1 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
    .cheat-header p { color: #6b7280; font-size: 0.9rem; }
    .print-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: #2563eb; color: white; border: none; border-radius: 0.5rem; font-size: 0.95rem; font-weight: 600; cursor: pointer; margin-bottom: 1.5rem; }
    .print-btn:hover { background: #1d4ed8; }
    
    .section { margin-bottom: 2rem; break-inside: avoid; }
    .section h2 { font-size: 1.25rem; font-weight: 700; border-bottom: 2px solid #2563eb; padding-bottom: 0.25rem; margin-bottom: 0.75rem; color: #1f2937; }
    .section h3 { font-size: 1rem; font-weight: 600; margin: 0.75rem 0 0.5rem; color: #374151; }
    
    .word-grid { display: flex; flex-wrap: wrap; gap: 0.25rem 0.5rem; font-family: 'Courier New', monospace; font-size: 0.8rem; line-height: 1.4; color: #1f2937; }
    .word-grid span { display: inline-block; min-width: 2.5rem; }
    
    .word-columns { column-count: 6; column-gap: 1rem; font-family: 'Courier New', monospace; font-size: 0.75rem; line-height: 1.5; color: #1f2937; }
    .word-columns.cols-4 { column-count: 4; }
    .word-columns.cols-8 { column-count: 8; }
    .word-columns.cols-10 { column-count: 10; }
    
    .tile-values { display: grid; grid-template-columns: repeat(auto-fill, minmax(60px, 1fr)); gap: 0.25rem; font-size: 0.75rem; }
    .tile-values .tile { display: flex; justify-content: space-between; padding: 0.15rem 0.4rem; background: #dbeafe; border: 1px solid #2563eb; border-radius: 0.2rem; font-weight: 600; }
    
    .watermark { text-align: center; color: #9ca3af; font-size: 0.75rem; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e7eb; }
    
    .stats { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .stat { background: #f3f4f6; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.85rem; text-decoration: none; color: inherit; transition: background 0.15s; }
    .stat:hover { background: #e5e7eb; }
    .stat strong { color: #2563eb; }

    .sheet-nav { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .sheet-nav a { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #e5e7eb; color: #374151; transition: all 0.2s; }
    .sheet-nav a:hover { border-color: #2563eb; color: #2563eb; background: #eff6ff; }
    .sheet-nav a.active { background: #2563eb; color: white; border-color: #2563eb; pointer-events: none; }
    .sheet-nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

    @media print {
      .print-btn, nav, header, footer, .cookie-consent, .sheet-nav { display: none !important; }
      .cheat-sheet { max-width: 100%; padding: 0; margin: 0; }
      .cheat-header h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
      .section { break-inside: avoid; margin-bottom: 1rem; }
      .section h2 { font-size: 1rem; border-bottom-width: 1px; color: #000 !important; }
      .section h3 { color: #000 !important; }
      .word-columns { column-count: 8; font-size: 0.6rem; line-height: 1.3; color: #000 !important; }
      .word-columns.cols-4 { column-count: 6; }
      .word-columns.cols-10 { column-count: 12; }
      .word-grid { font-size: 0.65rem; color: #000 !important; }
      .watermark { display: block !important; font-size: 0.7rem; color: #6b7280; }
      .stats { display: none; }
      @page { margin: 1cm; }
    }

    :global(.dark) .section h2 { color: #f3f4f6; border-color: #60a5fa; }
    :global(.dark) .section h3 { color: #d1d5db; }
    :global(.dark) .word-columns { color: #f3f4f6; }
    :global(.dark) .word-grid { color: #f3f4f6; }
    :global(.dark) .stat { background: #374151; }
    :global(.dark) .sheet-nav a { border-color: #4b5563; color: #d1d5db; }
    :global(.dark) .sheet-nav a:hover { border-color: #60a5fa; color: #60a5fa; background: #1e3a5f; }
    :global(.dark) .sheet-nav a.active { background: #2563eb; color: white; border-color: #2563eb; }
    :global(.dark) .tile-values .tile { background: #1e3a5f; border-color: #60a5fa; color: #dbeafe; }
    :global(.dark) .watermark { color: #6b7280; border-color: #374151; }
  </style>

  <div class="cheat-sheet">
    <div class="cheat-header">
      <h1>TWL Scrabble Cheat Sheet</h1>
      <p>Tournament Word List / NWL (North America) &mdash; {twoLetter.length} two-letter words, {threeLetter.length} three-letter words</p>
      <button class="print-btn" onclick="window.print()">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z"/></svg>
        Print / Save as PDF
      </button>
    </div>

    <!-- Cross-links to other cheat sheets -->
    <nav class="sheet-nav" aria-label="Cheat sheet navigation">
      <a href="/cheat-sheets/" title="All Cheat Sheets">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
        All Sheets
      </a>
      <a href="/cheat-sheets/sowpods/" title="SOWPODS Cheat Sheet">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        SOWPODS
      </a>
      <a href="/cheat-sheets/twl/" class="active" title="TWL Cheat Sheet">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        TWL
      </a>
    </nav>

    <div class="stats">
      <a href="#two-letter" class="stat"><strong>{twoLetter.length}</strong> two-letter words</a>
      <a href="#three-letter" class="stat"><strong>{threeLetter.length}</strong> three-letter words</a>
      <a href="#short-j" class="stat"><strong>{shortJ.length}</strong> short J words</a>
      <a href="#short-q" class="stat"><strong>{shortQ.length}</strong> short Q words</a>
      <a href="#short-x" class="stat"><strong>{shortX.length}</strong> short X words</a>
      <a href="#short-z" class="stat"><strong>{shortZ.length}</strong> short Z words</a>
      <a href="#q-no-u" class="stat"><strong>{qNoU.length}</strong> Q without U</a>
    </div>

    <!-- Two-Letter Words -->
    <div class="section" id="two-letter">
      <h2>2-Letter Words ({twoLetter.length})</h2>
      <div class="word-columns cols-10">
        {twoLetter.map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Short J Words -->
    <div class="section" id="short-j">
      <h2>Short J Words ({shortJ.length})</h2>
      <h3>2-letter</h3>
      <div class="word-grid">
        {shortJ.filter(w => w.length === 2).map(w => <span>{w}</span>)}
      </div>
      <h3>3-letter</h3>
      <div class="word-grid">
        {shortJ.filter(w => w.length === 3).map(w => <span>{w}</span>)}
      </div>
      <h3>4-letter</h3>
      <div class="word-columns cols-8">
        {shortJ.filter(w => w.length === 4).map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Short Q Words -->
    <div class="section" id="short-q">
      <h2>Short Q Words ({shortQ.length})</h2>
      <h3>2-letter</h3>
      <div class="word-grid">
        {shortQ.filter(w => w.length === 2).map(w => <span>{w}</span>)}
      </div>
      <h3>3-letter</h3>
      <div class="word-grid">
        {shortQ.filter(w => w.length === 3).map(w => <span>{w}</span>)}
      </div>
      <h3>4-letter</h3>
      <div class="word-columns cols-8">
        {shortQ.filter(w => w.length === 4).map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Q without U -->
    <div class="section" id="q-no-u">
      <h2>Q Without U Words ({qNoU.length})</h2>
      <div class="word-columns cols-4">
        {qNoU.map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Short X Words -->
    <div class="section" id="short-x">
      <h2>Short X Words ({shortX.length})</h2>
      <h3>2-letter</h3>
      <div class="word-grid">
        {shortX.filter(w => w.length === 2).map(w => <span>{w}</span>)}
      </div>
      <h3>3-letter</h3>
      <div class="word-grid">
        {shortX.filter(w => w.length === 3).map(w => <span>{w}</span>)}
      </div>
      <h3>4-letter</h3>
      <div class="word-columns cols-8">
        {shortX.filter(w => w.length === 4).map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Short Z Words -->
    <div class="section" id="short-z">
      <h2>Short Z Words ({shortZ.length})</h2>
      <h3>2-letter</h3>
      <div class="word-grid">
        {shortZ.filter(w => w.length === 2).map(w => <span>{w}</span>)}
      </div>
      <h3>3-letter</h3>
      <div class="word-grid">
        {shortZ.filter(w => w.length === 3).map(w => <span>{w}</span>)}
      </div>
      <h3>4-letter</h3>
      <div class="word-columns cols-8">
        {shortZ.filter(w => w.length === 4).map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Vowel Dumps -->
    <div class="section">
      <h2>Vowel Dump Words ({vowelDumps.length})</h2>
      <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 0.5rem;">Words where 66%+ of letters are vowels (useful for clearing excess vowels from your rack)</p>
      <div class="word-columns cols-4">
        {vowelDumps.map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- 3-Letter Words -->
    <div class="section" id="three-letter">
      <h2>3-Letter Words ({threeLetter.length})</h2>
      <div class="word-columns cols-10">
        {threeLetter.map(w => <div>{w}</div>)}
      </div>
    </div>

    <!-- Tile Values Reference -->
    <div class="section">
      <h2>Tile Point Values</h2>
      <div class="tile-values">
        {Object.entries(letterValues).sort(([,a],[,b]) => b - a || 0).map(([letter, value]) => (
          <div class="tile"><span>{letter}</span><span>{value}</span></div>
        ))}
      </div>
    </div>

    <!-- Watermark -->
    <div class="watermark">
      <p>www.scrabblewordsfinder.com &mdash; Free Scrabble Word Finder & Solver</p>
      <p>Based on Tournament Word List (TWL/NWL) dictionary. For personal use.</p>
    </div>
  </div>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the TWL dictionary?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TWL (Tournament Word List), also known as NWL (NASPA Word List), is the official Scrabble dictionary used in North American tournaments. It contains fewer words than SOWPODS/Collins but is the standard for competitive play in the US and Canada."
        }
      },
      {
        "@type": "Question",
        "name": "How many 2-letter words are in TWL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `There are ${twoLetter.length} valid 2-letter words in the TWL dictionary. Key words include QI (the only 2-letter Q word) and ZA (a valid 2-letter Z word).`
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between TWL and SOWPODS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TWL is used in North American Scrabble tournaments and contains about 187,000 words. SOWPODS (Collins) is the international dictionary with over 279,000 words. SOWPODS includes all TWL words plus additional words accepted in international play."
        }
      }
    ]
  })} />
</Layout>
