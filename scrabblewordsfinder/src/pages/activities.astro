  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is Word of the Day on ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "Word of the Day features a new Scrabble-worthy word every day with its meaning. You can save it to your Memory WordBench for later review and practice. Words are pre-assigned for 27 years of daily coverage." } },
      { "@type": "Question", "name": "How does the Word Quiz work?", "acceptedAnswer": { "@type": "Answer", "text": "The Word Quiz tests your vocabulary under time pressure. Choose 3-10 words per round, pick a timer (30-120 seconds), and match words to their correct meanings from 4 options. Scores are tracked in your Quiz History." } },
      { "@type": "Question", "name": "What is the Daily Rack Challenge?", "acceptedAnswer": { "@type": "Answer", "text": "Every day, all players get the same 7 Scrabble tiles. Your goal is to find the highest-scoring word you can make from those tiles. Submit as many words as you like — your best score for the day is tracked." } },
      { "@type": "Question", "name": "How does the Daily Anagram work?", "acceptedAnswer": { "@type": "Answer", "text": "The Daily Anagram gives you a scrambled 6-letter word to unscramble. You have 5 guesses with Wordle-style colour feedback: green means correct letter in correct position, yellow means correct letter in wrong position, and gray means the letter is not in the word. A hint is available if you get stuck. Same puzzle for everyone each day — share your result with friends!" } }
    ]
  }
  </script>

  <script is:inline>
  (function() {
    var S = window.__swfStore;
    var uid = S.getRaw('swf-uid') || '';
    var btn = document.getElementById('backup-data-btn');
    if (!btn || !uid) return;

    // Check if user already earned the backup diamond
    var BACKUP_LS_KEY = 'swf-backup-diamond-earned';
    if (S.getRaw(BACKUP_LS_KEY) === '1') return; // Already earned, keep hidden

    // Check server-side too (in case LS was cleared)
    fetch('/api/bonus-diamond/?user_id=' + encodeURIComponent(uid) + '&bonus_type=backup')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.earned) {
          S.setRaw(BACKUP_LS_KEY, '1');
          return; // Keep hidden
        }
        // Not yet earned — show the button
        btn.classList.remove('hidden');
      })
      .catch(function() {
        // On error, show button anyway (optimistic)
        btn.classList.remove('hidden');
      });

    btn.addEventListener('click', function() {
      // Build full backup JSON from localStorage
      var backup = { version: 1, exportedAt: new Date().toISOString(), uid: uid, data: {} };
      var keysToBackup = ['scbAchievements', 'scbDictionary', 'swf-uid', 'swf-60s-pb', 'swf-stars-earned-' + new Date().toISOString().split('T')[0]];
      // Also grab any swf-* keys dynamically
      for (var i = 0; i < localStorage.length; i++) {
        var key = localStorage.key(i);
        if (key && (key.startsWith('swf-') || key.startsWith('scb') || keysToBackup.indexOf(key) !== -1)) {
          backup.data[key] = localStorage.getItem(key);
        }
      }

      var json = JSON.stringify(backup, null, 2);
      var blob = new Blob([json], { type: 'application/json' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'swf-backup-' + new Date().toISOString().split('T')[0] + '.json';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

      // Award the bonus diamond
      btn.textContent = '💎 Earning diamond...';
      btn.disabled = true;
      fetch('/api/bonus-diamond/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, bonus_type: 'backup' })
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          S.setRaw(BACKUP_LS_KEY, '1');
          btn.textContent = '💎 Diamond earned!';
          btn.classList.remove('bg-amber-600/20', 'border-amber-500/30', 'text-amber-400');
          btn.classList.add('bg-green-600/20', 'border-green-500/30', 'text-green-400');
          // Hide after a brief celebration
          setTimeout(function() { btn.style.display = 'none'; }, 2500);
          // Refresh the star bar diamond count
          window.dispatchEvent(new CustomEvent('swf-star-earned', { detail: { game: '_bonus' } }));
        })
        .catch(function() {
          btn.textContent = '💾 Backup Data 💎';
          btn.disabled = false;
        });
    });
  })();
  </script>

  <!-- Mobile Focus/Fit: anchor icon script + styles -->
  <style is:global>
    /* When a panel is in "focused" mode on mobile, constrain it to viewport */
    @media (max-width: 480px) {
      .panel-focused {
        max-height: calc(100dvh - 2rem);
        overflow-y: auto;
        scroll-behavior: smooth;
        padding: 0.75rem !important;
        transition: max-height 0.3s ease, padding 0.3s ease;
      }
      .panel-focused .panel-focus-btn {
        background: rgba(59, 130, 246, 0.3);
        border-color: rgba(96, 165, 250, 0.6);
      }
      .panel-focused .panel-focus-btn .focus-icon {
        transform: rotate(45deg);
      }
    }
    .panel-focus-btn {
      display: none;
    }
    @media (max-width: 480px) {
      .panel-focus-btn {
        display: flex;
      }
    }
  </style>
  <script is:inline>
  (function() {
    // Find all game panels (rounded-xl border containers inside the grid)
    var panels = document.querySelectorAll('.grid.grid-cols-1 > div[class*="rounded-xl"][class*="border"]');
    panels.forEach(function(panel) {
      // Skip StarBar (col-span-2)
      if (panel.classList.contains('lg:col-span-2')) return;

      // Create anchor/fit button
      var btn = document.createElement('button');
      btn.className = 'panel-focus-btn absolute top-2 left-2 w-7 h-7 items-center justify-center rounded-full border border-gray-600/50 bg-gray-800/70 hover:bg-blue-600/30 hover:border-blue-400/60 text-gray-400 hover:text-blue-300 transition-all z-10 backdrop-blur-sm';
      btn.title = 'Fit to screen';
      btn.setAttribute('aria-label', 'Fit this game to screen');
      btn.innerHTML = '<span class="focus-icon inline-block transition-transform text-sm">📌</span>';

      // Make the panel relative for absolute positioning
      panel.style.position = 'relative';
      panel.insertBefore(btn, panel.firstChild);

      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isFocused = panel.classList.contains('panel-focused');

        // Remove focused from all panels first
        panels.forEach(function(p) { p.classList.remove('panel-focused'); });

        if (!isFocused) {
          panel.classList.add('panel-focused');
          // Scroll panel into view with a small offset from top
          panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Adjust scroll position to leave a small gap
          setTimeout(function() {
            window.scrollBy({ top: -16, behavior: 'smooth' });
          }, 300);
        }
      });
    });

    // Clicking outside unfocuses
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.panel-focused') && !e.target.closest('.panel-focus-btn')) {
        panels.forEach(function(p) { p.classList.remove('panel-focused'); });
      }
    });
  })();
  </script>

  <!-- Leaderboard rank badges on each game panel -->
  <script is:inline>
  (function() {
    var S = window.__swfStore;
    var uid = S ? S.getRaw('swf-uid') : '';
    if (!uid) return;

    // Map data-game attribute to leaderboard game name
    var gameMap = {
      'sixty': 'sixty-second',
      'rack': 'daily-rack',
      'anagram': 'daily-anagram',
      'cab': 'cab'
    };

    Object.keys(gameMap).forEach(function(dataGame) {
      var leaderboardGame = gameMap[dataGame];
      fetch('/api/leaderboard/?game=' + encodeURIComponent(leaderboardGame) + '&period=today&limit=100')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.entries || data.entries.length === 0) return;
          var userEntry = null;
          for (var i = 0; i < data.entries.length; i++) {
            if (data.entries[i].user_id === uid) {
              userEntry = data.entries[i];
              break;
            }
          }
          if (!userEntry) return;

          // Find the panel via the star indicator data-game attribute
          var starEl = document.querySelector('.star-indicator[data-game="' + dataGame + '"]');
          if (!starEl) return;
          var headerRow = starEl.closest('.flex.items-center.justify-between');
          if (!headerRow) return;

          // Create rank badge
          var badge = document.createElement('a');
          badge.href = '/leaderboard/?game=' + encodeURIComponent(leaderboardGame);
          badge.className = 'inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-purple-900/30 border border-purple-500/30 text-[10px] text-purple-300 font-medium hover:bg-purple-600/30 hover:border-purple-400 transition-colors no-underline';
          badge.title = 'Your leaderboard rank today';
          badge.innerHTML = '🏆 #' + userEntry.rank;

          // Insert after the h2 heading, before the buttons area
          var h2 = headerRow.querySelector('h2');
          if (h2) {
            h2.insertAdjacentElement('afterend', badge);
            // Wrap h2 + badge if needed (use flex gap)
            h2.parentNode.style.display = 'flex';
            h2.parentNode.style.alignItems = 'center';
            h2.parentNode.style.gap = '8px';
            h2.parentNode.style.flexWrap = 'wrap';
          }
        })
        .catch(function() {});
    });
  })();
  </script>

  <!-- Coaching PDF support for Lex Quiz Coach -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script is:inline src="/js/coaching-pdf.js?v=2"></script>
</Layout>
