---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Activities — Word of the Day & Word Quiz" description="Daily word challenges and timed vocabulary quizzes. Learn new Scrabble words every day and test your knowledge." keywords="word of the day, scrabble quiz, vocabulary quiz, word game, daily word challenge">

  <main class="mx-auto max-w-5xl px-4 sm:px-6 pb-20 pt-4">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2"><span class="text-blue-400">🎯</span> Activities</h1>
    <p class="text-sm text-gray-400 mb-8">Daily word challenges and vocabulary quizzes to sharpen your Scrabble skills.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Panel 1: Word of the Day -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📖</span> Word of the Day</h2>
        <div id="wotd-panel">
          <div class="text-center py-8">
            <p id="wotd-word" class="text-4xl font-black text-purple-400 tracking-wider mb-3">—</p>
            <p id="wotd-meaning" class="text-sm text-gray-300 italic mb-4">Loading today's word...</p>
            <p id="wotd-fact" class="text-xs text-gray-500 mb-4"></p>
            <div class="flex items-center justify-center gap-3">
              <button id="wotd-add-workbench" class="px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 transition-colors">
                + Add to Memory Workbench
              </button>
              <button id="wotd-fetch-meaning" class="px-3 py-2 rounded-lg bg-blue-600/30 border border-blue-500/50 text-sm text-blue-300 hover:bg-blue-600/50 transition-colors">
                📖 Lookup
              </button>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-gray-500 text-center"><span id="wotd-date"></span> · <span id="wotd-cache-status" class="text-gray-600">checking...</span></p>
          </div>
        </div>
      </div>

      <!-- Panel 2: Word Quiz -->
      <div class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>🧠</span> Word Quiz</h2>

        <!-- Quiz Setup -->
        <div id="quiz-setup">
          <p class="text-sm text-gray-300 mb-4">Test your vocabulary! Match 10 words to their correct meanings before the timer runs out.</p>
          <div class="mb-4">
            <label class="block text-xs text-gray-400 mb-1">Timer Duration</label>
            <select id="quiz-timer-select" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 w-full">
              <option value="30">30 seconds (Expert)</option>
              <option value="45">45 seconds (Hard)</option>
              <option value="60">60 seconds (Medium)</option>
              <option value="75">75 seconds (Easy)</option>
              <option value="90" selected>90 seconds (Relaxed)</option>
              <option value="105">105 seconds (Casual)</option>
              <option value="120">120 seconds (Beginner)</option>
            </select>
          </div>
          <button id="quiz-start-btn" class="w-full h-12 rounded-lg bg-blue-600 text-white font-semibold text-sm hover:bg-blue-500 transition-colors">▶ Start Quiz</button>
        </div>

        <!-- Quiz In Progress -->
        <div id="quiz-active" class="hidden">
          <div class="flex items-center justify-between mb-4">
            <span id="quiz-progress" class="text-xs text-gray-400">Question 1/10</span>
            <span id="quiz-timer" class="text-lg font-mono font-bold text-amber-400">90s</span>
          </div>
          <div class="mb-4">
            <p id="quiz-current-word" class="text-2xl font-black text-white text-center tracking-wider mb-4">—</p>
            <div id="quiz-options" class="grid grid-cols-1 gap-2"></div>
          </div>
          <button id="quiz-next-btn" class="w-full h-10 rounded-lg bg-gray-700 text-gray-300 font-medium text-sm hover:bg-gray-600 transition-colors hidden">Next →</button>
        </div>

        <!-- Quiz Complete -->
        <div id="quiz-complete" class="hidden text-center py-4">
          <p id="quiz-result-emoji" class="text-4xl mb-2">🏆</p>
          <p id="quiz-result-text" class="text-lg font-bold text-white mb-2"></p>
          <p id="quiz-result-details" class="text-sm text-gray-400 mb-4"></p>
          <div id="quiz-splits" class="text-xs text-gray-500 mb-4"></div>
          <div class="flex gap-3 justify-center">
            <button id="quiz-retry-btn" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors">Play Again</button>
            <a href="/achievements/" class="px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 transition-colors">🏅 Achievements</a>
          </div>
        </div>
      </div>

      <!-- Panel 3: Memory Workbench -->
      <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-6 lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2"><span>👑</span> Memory Workbench</h2>
          <div class="flex items-center gap-2">
            <span id="mw-count" class="text-xs text-gray-400">0 words</span>
            <a href="/" class="text-xs text-blue-400 hover:underline">← Solver</a>
          </div>
        </div>
        <p class="text-xs text-gray-500 mb-3">Words you've collected from the solver, Word of the Day, and quizzes.</p>
        <div id="mw-list" class="max-h-[300px] overflow-y-auto">
          <p id="mw-empty" class="text-sm text-gray-500 text-center py-4 italic">No saved words yet. Use the solver or Word of the Day to collect words.</p>
        </div>
      </div>

    </div>
  </main>

  <script is:inline>
  (function() {
    // ── Word of the Day (with 24h localStorage cache) ──
    var WOTD_CACHE_KEY = 'swf-wotd-cache';
    var WOTD_CACHE_TTL = 24 * 60 * 60 * 1000;

    function getWotdCache() {
      try {
        var cached = JSON.parse(localStorage.getItem(WOTD_CACHE_KEY));
        if (cached && Date.now() - cached.ts < WOTD_CACHE_TTL) return cached.data;
      } catch(e) {}
      return null;
    }

    function setWotdCache(data) {
      localStorage.setItem(WOTD_CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data }));
    }

    function renderWotd(word) {
      document.getElementById('wotd-word').textContent = word.word || '—';
      document.getElementById('wotd-meaning').textContent = word.meaning || 'Tap "Lookup" to fetch the meaning';
      document.getElementById('wotd-fact').textContent = word.fun_fact || '';
      document.getElementById('wotd-date').textContent = word.date || new Date().toISOString().split('T')[0];
    }

    var cached = getWotdCache();
    if (cached) { renderWotd(cached); document.getElementById('wotd-cache-status').textContent = 'from cache'; }

    fetch('/api/wotd/').then(function(r) { return r.json(); }).then(function(d) {
      if (d.word) { renderWotd(d.word); setWotdCache(d.word); document.getElementById('wotd-cache-status').textContent = 'live'; }
    }).catch(function() {
      if (!cached) document.getElementById('wotd-meaning').textContent = 'Could not load — try refreshing';
      document.getElementById('wotd-cache-status').textContent = 'offline (cached)';
    });

    document.getElementById('wotd-fetch-meaning').addEventListener('click', async function() {
      var word = document.getElementById('wotd-word').textContent.toLowerCase();
      if (!word || word === '—') return;
      this.textContent = '...';
      try {
        var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word);
        if (res.ok) {
          var data = await res.json();
          var meaning = data[0]?.meanings?.[0]?.definitions?.[0]?.definition || 'No definition found';
          document.getElementById('wotd-meaning').textContent = meaning;
          var c = getWotdCache(); if (c) { c.meaning = meaning; setWotdCache(c); }
          fetch('/api/wotd/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ word: word.toUpperCase(), meaning: meaning }) });
        }
      } catch(e) {}
      this.textContent = '📖 Lookup';
    });

    document.getElementById('wotd-add-workbench').addEventListener('click', function() {
      var word = document.getElementById('wotd-word').textContent;
      if (!word || word === '—') return;
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      if (saved.find(function(s) { return s.word === word; })) { this.textContent = 'Already saved ✓'; return; }
      saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent, dateAdded: new Date().toISOString() });
      localStorage.setItem('scbAchievements', JSON.stringify(saved));
      this.textContent = 'Added ✓';
      setTimeout(function() { document.getElementById('wotd-add-workbench').textContent = '+ Add to Memory Workbench'; }, 2000);
    });

    // ── Word Quiz ──
    var quizState = { questions: [], fakes: [], current: 0, splits: [], startTime: 0, timerDuration: 90, timerId: null, correct: 0 };

    document.getElementById('quiz-start-btn').addEventListener('click', startQuiz);
    document.getElementById('quiz-next-btn').addEventListener('click', nextQuestion);
    document.getElementById('quiz-retry-btn').addEventListener('click', function() {
      document.getElementById('quiz-setup').classList.remove('hidden');
      document.getElementById('quiz-complete').classList.add('hidden');
    });

    async function startQuiz() {
      document.getElementById('quiz-setup').classList.add('hidden');
      document.getElementById('quiz-active').classList.remove('hidden');
      document.getElementById('quiz-complete').classList.add('hidden');
      quizState.timerDuration = parseInt(document.getElementById('quiz-timer-select').value);
      quizState.current = 0; quizState.splits = []; quizState.correct = 0;
      try {
        var res = await fetch('/api/word-quiz/');
        var data = await res.json();
        quizState.questions = data.questions;
        quizState.fakes = data.fakeMeanings;
      } catch(e) { alert('Failed to load quiz.'); return; }
      quizState.startTime = Date.now();
      localStorage.setItem('swf-quiz-start', String(quizState.startTime));
      startTimer(); showQuestion();
    }

    function startTimer() {
      var remaining = quizState.timerDuration;
      var timerEl = document.getElementById('quiz-timer');
      timerEl.textContent = remaining + 's';
      timerEl.classList.remove('text-red-400');
      quizState.timerId = setInterval(function() {
        remaining--;
        timerEl.textContent = remaining + 's';
        if (remaining <= 10) timerEl.classList.add('text-red-400');
        if (remaining <= 0) { clearInterval(quizState.timerId); endQuiz(true); }
      }, 1000);
    }

    function showQuestion() {
      var q = quizState.questions[quizState.current];
      document.getElementById('quiz-progress').textContent = 'Question ' + (quizState.current + 1) + '/10';
      document.getElementById('quiz-current-word').textContent = q.word;
      var options = [{ text: q.meaning, correct: true }];
      var usedFakes = new Set();
      while (options.length < 4) {
        var idx = Math.floor(Math.random() * quizState.fakes.length);
        if (!usedFakes.has(idx) && quizState.fakes[idx] !== q.meaning) { options.push({ text: quizState.fakes[idx], correct: false }); usedFakes.add(idx); }
      }
      options.sort(function() { return Math.random() - 0.5; });
      var container = document.getElementById('quiz-options');
      container.innerHTML = options.map(function(opt) {
        return '<button class="quiz-opt p-3 text-left rounded-lg border border-gray-700 bg-gray-800 text-sm text-gray-300 hover:border-blue-500 hover:bg-blue-900/20 transition-colors" data-correct="' + opt.correct + '">' + opt.text + '</button>';
      }).join('');
      container.querySelectorAll('.quiz-opt').forEach(function(btn) {
        btn.addEventListener('click', function() {
          container.querySelectorAll('.quiz-opt').forEach(function(b) { b.disabled = true; b.style.pointerEvents = 'none'; });
          if (btn.dataset.correct === 'true') { btn.classList.add('border-green-500', 'bg-green-900/30'); quizState.correct++; }
          else { btn.classList.add('border-red-500', 'bg-red-900/30'); container.querySelectorAll('.quiz-opt').forEach(function(b) { if (b.dataset.correct === 'true') b.classList.add('border-green-500', 'bg-green-900/30'); }); }
          document.getElementById('quiz-next-btn').classList.remove('hidden');
          if (quizState.current === 9) document.getElementById('quiz-next-btn').textContent = '🏁 Finish';
        });
      });
      document.getElementById('quiz-next-btn').classList.add('hidden');
      document.getElementById('quiz-next-btn').textContent = 'Next →';
    }

    function nextQuestion() {
      var split = ((Date.now() - quizState.startTime) / 1000).toFixed(1);
      quizState.splits.push(split);
      localStorage.setItem('swf-quiz-splits', JSON.stringify(quizState.splits));
      quizState.current++;
      if (quizState.current >= 10) endQuiz(false); else showQuestion();
    }

    function endQuiz(timedOut) {
      clearInterval(quizState.timerId);
      document.getElementById('quiz-active').classList.add('hidden');
      document.getElementById('quiz-complete').classList.remove('hidden');
      var totalTime = ((Date.now() - quizState.startTime) / 1000).toFixed(1);
      var score = quizState.correct, limit = quizState.timerDuration;
      var emoji = '🏆', text = '';
      if (timedOut) { emoji = '⏰'; text = "Time's Up! " + score + '/10'; }
      else if (totalTime < limit * 0.5) { emoji = '🔥'; text = 'Blazing Fast! ' + score + '/10 in ' + totalTime + 's'; }
      else if (totalTime < limit * 0.75) { emoji = '⚡'; text = 'Quick Thinker! ' + score + '/10 in ' + totalTime + 's'; }
      else { emoji = '✅'; text = 'Completed! ' + score + '/10 in ' + totalTime + 's'; }
      document.getElementById('quiz-result-emoji').textContent = emoji;
      document.getElementById('quiz-result-text').textContent = text;
      var details = 'Timer: ' + limit + 's · Correct: ' + score + '/10 · Time: ' + totalTime + 's';
      if (!timedOut && parseFloat(totalTime) < limit) {
        var margin = limit - parseFloat(totalTime);
        if (margin > 60) details += ' 🔥 Destroyed by ' + margin.toFixed(0) + 's!';
        else if (margin > 30) details += ' ⚡ Beat by ' + margin.toFixed(0) + 's!';
        else if (margin > 10) details += ' ✨ ' + margin.toFixed(0) + 's spare';
      }
      document.getElementById('quiz-result-details').textContent = details;
      document.getElementById('quiz-splits').textContent = 'Splits: ' + quizState.splits.join(', ') + 's';
      fetch('/api/achievements/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ achievement_text: 'Word Quiz', a_data: JSON.stringify({ score: score, total: 10, timeUsed: totalTime, timerLimit: limit, splits: quizState.splits, timedOut: timedOut, date: new Date().toISOString() }) }) }).catch(function(){});
      document.getElementById('quiz-timer').classList.remove('text-red-400');
    }

    // ── Memory Workbench Panel ──
    function renderWorkbench() {
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      var container = document.getElementById('mw-list');
      var countEl = document.getElementById('mw-count');
      countEl.textContent = saved.length + ' words';
      if (saved.length === 0) {
        container.innerHTML = '<p class="text-sm text-gray-500 text-center py-4 italic">No saved words yet. Use the solver or Word of the Day to collect words.</p>';
        return;
      }

      // Group by category
      var cats = {};
      saved.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = []; cats[c].push(w); });
      var catNames = Object.keys(cats).sort();

      var html = '<div class="flex flex-wrap gap-2 mb-3">';
      html += '<button class="mw-cat-btn px-2 py-1 rounded text-xs font-medium border border-purple-500/50 bg-purple-900/30 text-purple-300" data-cat="all">All (' + saved.length + ')</button>';
      catNames.forEach(function(c) {
        html += '<button class="mw-cat-btn px-2 py-1 rounded text-xs font-medium border border-gray-700 bg-gray-800 text-gray-400 hover:border-purple-500/50 hover:text-purple-300 transition-colors" data-cat="' + c + '">' + c + ' (' + cats[c].length + ')</button>';
      });
      html += '</div>';

      html += '<div id="mw-words-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">';
      saved.forEach(function(w) {
        html += '<div class="mw-word-card p-2 rounded-lg bg-gray-800 border border-gray-700" data-cat="' + (w.category || 'manual') + '">' +
          '<p class="text-sm font-bold text-white uppercase">' + (w.word || '') + '</p>' +
          '<p class="text-[10px] text-gray-500 truncate">' + (w.meaning || '') + '</p>' +
          '<p class="text-[9px] text-purple-400/60">' + (w.category || 'manual') + '</p>' +
        '</div>';
      });
      html += '</div>';

      container.innerHTML = html;

      // Category filter buttons
      container.querySelectorAll('.mw-cat-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var cat = btn.dataset.cat;
          container.querySelectorAll('.mw-cat-btn').forEach(function(b) {
            b.classList.remove('border-purple-500/50', 'bg-purple-900/30', 'text-purple-300');
            b.classList.add('border-gray-700', 'bg-gray-800', 'text-gray-400');
          });
          btn.classList.add('border-purple-500/50', 'bg-purple-900/30', 'text-purple-300');
          btn.classList.remove('border-gray-700', 'bg-gray-800', 'text-gray-400');
          container.querySelectorAll('.mw-word-card').forEach(function(card) {
            if (cat === 'all' || card.dataset.cat === cat) card.style.display = '';
            else card.style.display = 'none';
          });
        });
      });
    }
    renderWorkbench();
  })();
  </script>
</Layout>
