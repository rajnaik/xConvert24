---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Activities — Word of the Day & Word Quiz" description="Daily word challenges and timed vocabulary quizzes. Learn new Scrabble words every day and test your knowledge." keywords="word of the day, scrabble quiz, vocabulary quiz, word game, daily word challenge">

  <main class="mx-auto max-w-5xl px-4 sm:px-6 pb-20 pt-4">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2"><span class="text-blue-400">🎯</span> Activities</h1>
    <p class="text-sm text-gray-400 mb-8">Daily word challenges and vocabulary quizzes to sharpen your Scrabble skills.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Panel 1: Word of the Day -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📖</span> Word of the Day</h2>
        <div id="wotd-panel">
          <div class="text-center py-8">
            <p id="wotd-word" class="text-4xl font-black text-purple-400 tracking-wider mb-3">—</p>
            <p id="wotd-meaning" class="text-sm text-gray-300 italic mb-4">Loading today's word...</p>
            <p id="wotd-fact" class="text-xs text-gray-500 mb-4"></p>
            <div class="flex items-center justify-center gap-3">
              <button id="wotd-add-workbench" class="px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 transition-colors">
                + Add to Memory WordBench
              </button>
              <button id="wotd-fetch-meaning" class="px-3 py-2 rounded-lg bg-blue-600/30 border border-blue-500/50 text-sm text-blue-300 hover:bg-blue-600/50 transition-colors">
                📖 Lookup
              </button>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-center"><span id="wotd-date" class="hidden"></span><span id="wotd-cache-status" class="hidden"></span><span id="wotd-countdown" class="text-purple-400 font-mono"></span></p>
          </div>
        </div>
      </div>

      <!-- Panel 2: Word Quiz -->
      <div class="rounded-xl border border-blue-800/50 bg-gray-900/50 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2"><span>🧠</span> Word Quiz</h2>
          <a id="quiz-history-btn" href="/wordbench-practice/" class="hidden px-2 py-1 rounded-lg bg-purple-600/20 border border-purple-500/30 text-xs text-purple-300 hover:bg-purple-600/40 transition-colors flex items-center gap-1">
            <span>🏅</span><span id="quiz-history-count">0</span>
          </a>
        </div>

        <!-- Quiz Setup -->
        <div id="quiz-setup">
          <p class="text-sm text-gray-300 mb-4">Test your vocabulary! Match words to their correct meanings before the timer runs out.</p>
          <div class="mb-4">
            <label class="block text-xs text-gray-400 mb-1">How many words?</label>
            <div id="quiz-count-picker" class="grid grid-cols-4 gap-2">
              <button class="quiz-count-btn px-3 py-2 rounded-lg border border-gray-700 bg-gray-800 text-sm text-gray-300 hover:border-blue-500 hover:bg-blue-900/20 transition-colors" data-count="3">3</button>
              <button class="quiz-count-btn px-3 py-2 rounded-lg border border-gray-700 bg-gray-800 text-sm text-gray-300 hover:border-blue-500 hover:bg-blue-900/20 transition-colors" data-count="5">5</button>
              <button class="quiz-count-btn px-3 py-2 rounded-lg border border-blue-500 bg-blue-900/30 text-sm text-blue-300 font-semibold" data-count="7">7</button>
              <button class="quiz-count-btn px-3 py-2 rounded-lg border border-gray-700 bg-gray-800 text-sm text-gray-300 hover:border-blue-500 hover:bg-blue-900/20 transition-colors" data-count="10">10</button>
            </div>
          </div>
          <div class="mb-4">
            <label class="block text-xs text-gray-400 mb-1">Timer Duration</label>
            <select id="quiz-timer-select" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 w-full">
              <option value="30">30 seconds (Expert)</option>
              <option value="45">45 seconds (Hard)</option>
              <option value="60">60 seconds (Medium)</option>
              <option value="75">75 seconds (Easy)</option>
              <option value="90" selected>90 seconds (Relaxed)</option>
              <option value="105">105 seconds (Casual)</option>
              <option value="120">120 seconds (Beginner)</option>
            </select>
          </div>
          <button id="quiz-start-btn" class="w-full h-12 rounded-lg bg-blue-600 text-white font-semibold text-sm hover:bg-blue-500 transition-colors">▶ Start Quiz</button>
          <label id="quiz-from-workbench-label" class="hidden flex items-center gap-2 mt-3 cursor-pointer select-none">
            <input type="checkbox" id="quiz-from-workbench" class="w-4 h-4 rounded border-gray-600 bg-gray-800 text-blue-500 focus:ring-blue-500/30 focus:ring-offset-0" />
            <span class="text-xs text-gray-400">Use words from my Memory WordBench</span>
          </label>
        </div>

        <!-- Quiz In Progress -->
        <div id="quiz-active" class="hidden relative">
          <div class="flex items-center justify-between mb-4">
            <span id="quiz-progress" class="text-xs text-gray-400">Question 1/10</span>
            <span id="quiz-timer" class="text-lg font-mono font-bold text-amber-400">90s</span>
          </div>
          <div class="mb-4">
            <p id="quiz-current-word" class="text-2xl font-black text-white text-center tracking-wider mb-4">—</p>
            <div id="quiz-options" class="grid grid-cols-1 gap-2"></div>
          </div>
          <!-- Encouragement Modal Overlay -->
          <div id="quiz-modal" class="hidden absolute inset-0 z-10 flex items-center justify-center bg-gray-950/80 backdrop-blur-sm rounded-xl">
            <div id="quiz-modal-box" class="w-[90%] max-w-xs rounded-2xl border-2 p-6 text-center shadow-2xl transform transition-all scale-95 opacity-0">
              <p id="quiz-modal-emoji" class="text-4xl mb-2">🎯</p>
              <p id="quiz-modal-text" class="text-sm font-medium mb-4">Nice work!</p>
              <button id="quiz-modal-ok" class="w-full h-10 rounded-lg bg-blue-600 text-white font-semibold text-sm hover:bg-blue-500 transition-colors">OK →</button>
            </div>
          </div>
        </div>

        <!-- Quiz Complete -->
        <div id="quiz-complete" class="hidden text-center py-4">
          <p id="quiz-result-emoji" class="text-4xl mb-2">🏆</p>
          <p id="quiz-result-text" class="text-lg font-bold text-white mb-2"></p>
          <p id="quiz-result-details" class="text-sm text-gray-400 mb-4"></p>
          <div id="quiz-splits" class="text-xs text-gray-500 mb-4"></div>
          <div class="flex gap-3 justify-center">
            <button id="quiz-retry-btn" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors">Play Again</button>
            <a href="/quiz-history/" class="px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 transition-colors">📊 Quiz History</a>
          </div>
        </div>
      </div>

      <!-- Panel 3: Memory WordBench (Flash Cards) -->
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-6 lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2"><span>🃏</span> Memory WordBench</h2>
          <div class="flex items-center gap-2">
            <button id="fc-start-btn" class="px-3 py-1.5 rounded-lg bg-green-600/30 border border-green-500/50 text-sm text-green-300 hover:bg-green-600/50 transition-colors">▶ Start</button>
            <span id="fc-word-count" class="text-xs text-gray-400">0 words</span>
          </div>
        </div>
        <!-- Category tabs -->
        <div id="fc-cat-filters" class="flex flex-wrap gap-1.5 mb-3"></div>
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input type="checkbox" id="fc-real-meanings" class="w-3.5 h-3.5 rounded border-gray-600 bg-gray-800 text-purple-500 focus:ring-purple-500/30 focus:ring-offset-0" checked />
            <span class="text-xs text-gray-400">Meaningful only</span>
          </label>
          <div id="fc-speed-wrap" class="hidden flex items-center gap-3">
            <input type="range" id="fc-speed" min="1" max="30" value="5" class="w-24 h-1 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500" />
            <span id="fc-speed-label" class="text-[10px] text-gray-400 font-mono w-6">5s</span>
            <button id="fc-autoplay-btn" class="w-7 h-7 flex items-center justify-center rounded-full border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all" title="Auto-play">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <span id="fc-timer" class="hidden text-[10px] font-mono text-amber-400">0:00</span>
          </div>
        </div>
        <input type="checkbox" id="fc-autoplay" class="hidden" />
        <div id="fc-panel" class="relative text-center py-6">
          <div id="fc-card" class="hidden mx-auto w-full max-w-sm h-48 rounded-2xl border-2 border-green-500/30 bg-gradient-to-br from-gray-800 to-gray-900 flex flex-col items-center justify-center cursor-pointer transition-all hover:border-green-400 select-none">
            <p id="fc-word" class="text-3xl font-black text-green-400 tracking-wider mb-2">WORD</p>
            <p id="fc-score" class="text-sm text-blue-400 hidden"></p>
            <p id="fc-meaning" class="text-sm text-gray-400 italic px-4 hidden">Click to reveal meaning</p>
            <p id="fc-hint" class="text-xs text-gray-600 mt-2">tap to flip</p>
          </div>
          <div id="fc-empty" class="text-sm text-gray-500 italic">Add words to your Memory WordBench first, then practice here.</div>
          <div id="fc-controls" class="hidden flex items-center justify-center gap-4 mt-4">
            <button id="fc-prev" class="px-3 py-1.5 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">← Prev</button>
            <span id="fc-counter" class="text-xs text-gray-500">1 / 10</span>
            <button id="fc-next" class="px-3 py-1.5 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">Next →</button>
          </div>
          <!-- Word action buttons -->
          <div id="fc-actions" class="hidden flex items-center justify-center gap-2 mt-3">
            <button id="fc-copy-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-green-400 hover:bg-green-900/20 rounded transition-colors">📋 Copy</button>
            <button id="fc-edit-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-blue-400 hover:bg-blue-900/20 rounded transition-colors">✏️ Edit</button>
            <button id="fc-delete-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-red-400 hover:bg-red-900/20 rounded transition-colors">🗑️ Delete</button>
            <a href="/wordbench-practice/" class="px-2.5 py-1 text-xs text-gray-400 hover:text-purple-400 hover:bg-purple-900/20 rounded transition-colors">📚 Practice</a>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script is:inline>
  (function() {
    // ── Quiz History Badge ──
    (function loadQuizBadge() {
      var uid = localStorage.getItem('swf-uid') || '';

      // Show "use workbench words" option if user has saved words with meanings
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      var wordsWithMeaning = saved.filter(function(w) {
        if (!w.meaning || !w.meaning.trim()) return false;
        var m = w.meaning.toLowerCase();
        if (m.indexOf('scrabble-legal word') !== -1) return false;
        if (m.indexOf('no standard definition') !== -1) return false;
        return true;
      });
      if (wordsWithMeaning.length >= 3) {
        document.getElementById('quiz-from-workbench-label').classList.remove('hidden');
      }

      if (!uid) return;
      fetch('/api/quiz-scores/?user_id=' + encodeURIComponent(uid))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var scores = data.scores || [];
          if (scores.length === 0) return;
          var btn = document.getElementById('quiz-history-btn');
          btn.classList.remove('hidden');
          btn.style.display = 'flex';
          document.getElementById('quiz-history-count').textContent = scores.length;

        }).catch(function() {});
    })();

    // ── Word of the Day (with 24h localStorage cache) ──
    var WOTD_CACHE_KEY = 'swf-wotd-cache';
    var WOTD_CACHE_TTL = 24 * 60 * 60 * 1000;

    function getWotdCache() {
      try {
        var cached = JSON.parse(localStorage.getItem(WOTD_CACHE_KEY));
        if (cached && Date.now() - cached.ts < WOTD_CACHE_TTL) return cached.data;
      } catch(e) {}
      return null;
    }

    function setWotdCache(data) {
      localStorage.setItem(WOTD_CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data }));
    }

    function renderWotd(word) {
      document.getElementById('wotd-word').textContent = word.word || '—';
      document.getElementById('wotd-meaning').textContent = word.meaning || 'Tap "Lookup" to fetch the meaning';
      document.getElementById('wotd-fact').textContent = word.fun_fact || '';
      document.getElementById('wotd-date').textContent = word.date || new Date().toISOString().split('T')[0];
    }

    var cached = getWotdCache();
    if (cached) { renderWotd(cached); document.getElementById('wotd-cache-status').textContent = 'from cache'; }

    fetch('/api/wotd/').then(function(r) { return r.json(); }).then(function(d) {
      if (d.word) { renderWotd(d.word); setWotdCache(d.word); document.getElementById('wotd-cache-status').textContent = 'live'; }
    }).catch(function() {
      if (!cached) document.getElementById('wotd-meaning').textContent = 'Could not load — try refreshing';
      document.getElementById('wotd-cache-status').textContent = 'offline (cached)';
    });

    document.getElementById('wotd-fetch-meaning').addEventListener('click', async function() {
      var word = document.getElementById('wotd-word').textContent.toLowerCase();
      if (!word || word === '—') return;
      this.textContent = '...';
      try {
        var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word);
        if (res.ok) {
          var data = await res.json();
          var meaning = data[0]?.meanings?.[0]?.definitions?.[0]?.definition || 'No definition found';
          document.getElementById('wotd-meaning').textContent = meaning;
          var c = getWotdCache(); if (c) { c.meaning = meaning; setWotdCache(c); }
          fetch('/api/wotd/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ word: word.toUpperCase(), meaning: meaning }) });
        }
      } catch(e) {}
      this.textContent = '📖 Lookup';
    });

    document.getElementById('wotd-add-workbench').addEventListener('click', function() {
      var word = document.getElementById('wotd-word').textContent;
      if (!word || word === '—') return;
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      if (saved.find(function(s) { return s.word === word; })) { this.textContent = 'Already saved ✓'; return; }
      saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent, dateAdded: new Date().toISOString() });
      localStorage.setItem('scbAchievements', JSON.stringify(saved));
      this.textContent = 'Added ✓';
      setTimeout(function() { document.getElementById('wotd-add-workbench').textContent = '+ Add to Memory WordBench'; }, 2000);
    });

    // ── WOTD Countdown Timer ──
    (function startCountdown() {
      var el = document.getElementById('wotd-countdown');
      function update() {
        var now = new Date();
        var tomorrow = new Date(now);
        tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
        tomorrow.setUTCHours(0, 0, 0, 0);
        var diff = tomorrow - now;
        if (diff <= 0) { el.textContent = 'New word!'; return; }
        var h = Math.floor(diff / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.textContent = 'Next WOTD in ' + h + 'h ' + (m < 10 ? '0' : '') + m + 'm ' + (s < 10 ? '0' : '') + s + 's';
      }
      update();
      setInterval(update, 1000);
    })();

    // ── Word Quiz ──
    var quizState = { questions: [], fakes: [], current: 0, total: 7, splits: [], startTime: 0, timerDuration: 90, timerId: null, correct: 0 };

    // Word count picker
    document.querySelectorAll('.quiz-count-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.quiz-count-btn').forEach(function(b) {
          b.classList.remove('border-blue-500', 'bg-blue-900/30', 'text-blue-300', 'font-semibold');
          b.classList.add('border-gray-700', 'bg-gray-800', 'text-gray-300');
        });
        btn.classList.add('border-blue-500', 'bg-blue-900/30', 'text-blue-300', 'font-semibold');
        btn.classList.remove('border-gray-700', 'bg-gray-800', 'text-gray-300');
        quizState.total = parseInt(btn.dataset.count);
      });
    });

    document.getElementById('quiz-start-btn').addEventListener('click', startQuiz);
    document.getElementById('quiz-modal-ok').addEventListener('click', advanceQuiz);
    document.getElementById('quiz-retry-btn').addEventListener('click', function() {
      document.getElementById('quiz-setup').classList.remove('hidden');
      document.getElementById('quiz-complete').classList.add('hidden');
    });

    var encourageCorrect = [
      "🔥 On fire! {score}/{total} correct in {time}s",
      "💪 Nailed it! {score}/{total} — keep going!",
      "⚡ Sharp mind! {score} right so far in {time}s",
      "🎯 Bullseye! {score}/{total} correct!",
      "✨ Brilliant! {score} down, {remaining} to go",
      "🧠 Big brain move! {score}/{total} in {time}s",
      "👏 Crushed it! {score} correct so far"
    ];

    var encourageWrong = [
      "💪 Still in it! {score}/{total} correct — plenty of time to score high!",
      "🎯 Keep pushing! {score}/{total} right, {remaining} left to go",
      "⏱️ No worries — {remaining} questions left, you've got this!",
      "📚 Learning moment! {score}/{total} so far — finish strong!",
      "🚀 Don't stop now! {remaining} more chances to shine",
      "🔁 Shake it off! {score} correct, still time to recover"
    ];

    function pickRandom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    function formatMsg(template, data) {
      return template.replace(/\{(\w+)\}/g, function(_, key) { return data[key] !== undefined ? data[key] : ''; });
    }

    async function startQuiz() {
      document.getElementById('quiz-setup').classList.add('hidden');
      document.getElementById('quiz-active').classList.remove('hidden');
      document.getElementById('quiz-complete').classList.add('hidden');
      quizState.timerDuration = parseInt(document.getElementById('quiz-timer-select').value);
      quizState.current = 0; quizState.splits = []; quizState.correct = 0;

      var useWorkbench = document.getElementById('quiz-from-workbench') && document.getElementById('quiz-from-workbench').checked;

      if (useWorkbench) {
        // Use words from Memory WordBench
        var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
        var meaningful = saved.filter(function(w) {
          if (!w.meaning || !w.meaning.trim()) return false;
          var m = w.meaning.toLowerCase();
          if (m.indexOf('scrabble-legal word') !== -1) return false;
          if (m.indexOf('no standard definition') !== -1) return false;
          return true;
        });
        // Shuffle and pick N
        for (var i = meaningful.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          var tmp = meaningful[i]; meaningful[i] = meaningful[j]; meaningful[j] = tmp;
        }
        var picked = meaningful.slice(0, quizState.total);
        if (picked.length < quizState.total) picked = meaningful.slice(0, meaningful.length);
        quizState.questions = picked.map(function(w) { return { word: w.word, meaning: w.meaning }; });
        // Generate fake meanings from the rest of the saved words
        var allMeanings = meaningful.map(function(w) { return w.meaning; });
        quizState.fakes = allMeanings.sort(function() { return Math.random() - 0.5; });
      } else {
        // Fetch from API
        try {
          var res = await fetch('/api/word-quiz/?count=' + quizState.total);
          var data = await res.json();
          quizState.questions = data.questions;
          quizState.fakes = data.fakeMeanings;
        } catch(e) { alert('Failed to load quiz.'); return; }
      }

      quizState.startTime = Date.now();
      localStorage.setItem('swf-quiz-start', String(quizState.startTime));
      startTimer(); showQuestion();
    }

    function startTimer() {
      var remaining = quizState.timerDuration;
      var timerEl = document.getElementById('quiz-timer');
      timerEl.textContent = remaining + 's';
      timerEl.classList.remove('text-red-400');
      quizState.timerId = setInterval(function() {
        remaining--;
        timerEl.textContent = remaining + 's';
        if (remaining <= 10) timerEl.classList.add('text-red-400');
        if (remaining <= 0) { clearInterval(quizState.timerId); endQuiz(true); }
      }, 1000);
    }

    function showQuestion() {
      var q = quizState.questions[quizState.current];
      document.getElementById('quiz-progress').textContent = 'Question ' + (quizState.current + 1) + '/' + quizState.total;
      document.getElementById('quiz-current-word').textContent = q.word;
      document.getElementById('quiz-modal').classList.add('hidden');

      var options = [{ text: q.meaning, correct: true }];
      var usedFakes = new Set();
      while (options.length < 4) {
        var idx = Math.floor(Math.random() * quizState.fakes.length);
        if (!usedFakes.has(idx) && quizState.fakes[idx] !== q.meaning) { options.push({ text: quizState.fakes[idx], correct: false }); usedFakes.add(idx); }
      }
      options.sort(function() { return Math.random() - 0.5; });

      var container = document.getElementById('quiz-options');
      container.innerHTML = options.map(function(opt) {
        return '<button class="quiz-opt p-3 text-left rounded-lg border border-gray-700 bg-gray-800 text-sm text-gray-300 hover:border-blue-500 hover:bg-blue-900/20 transition-colors" data-correct="' + opt.correct + '">' + opt.text + '</button>';
      }).join('');

      container.querySelectorAll('.quiz-opt').forEach(function(btn) {
        btn.addEventListener('click', function() {
          // Disable all options
          container.querySelectorAll('.quiz-opt').forEach(function(b) { b.disabled = true; b.style.pointerEvents = 'none'; });

          var isCorrect = btn.dataset.correct === 'true';
          var elapsed = ((Date.now() - quizState.startTime) / 1000).toFixed(1);
          var remaining = quizState.total - quizState.current - 1;
          var correctAnswer = quizState.questions[quizState.current].meaning;
          var questionWord = quizState.questions[quizState.current].word;

          if (isCorrect) {
            quizState.correct++;
            btn.classList.add('border-green-500', 'bg-green-900/30', 'text-green-200');
            var msg = formatMsg(pickRandom(encourageCorrect), { score: quizState.correct, total: quizState.total, time: elapsed, remaining: remaining });
            showModal(msg, 'green', correctAnswer, questionWord);
          } else {
            btn.classList.add('border-red-500', 'bg-red-900/30', 'text-red-200');
            // Show correct answer
            container.querySelectorAll('.quiz-opt').forEach(function(b) { if (b.dataset.correct === 'true') b.classList.add('border-green-500', 'bg-green-900/30'); });
            var msg = formatMsg(pickRandom(encourageWrong), { score: quizState.correct, total: quizState.total, time: elapsed, remaining: remaining });
            showModal(msg, 'amber', correctAnswer, questionWord);
          }
        });
      });
    }

    function showModal(msg, color, correctAnswer, questionWord) {
      var modal = document.getElementById('quiz-modal');
      var box = document.getElementById('quiz-modal-box');
      var emoji = document.getElementById('quiz-modal-emoji');
      var text = document.getElementById('quiz-modal-text');
      var okBtn = document.getElementById('quiz-modal-ok');

      // Set content — green for correct, red for wrong
      if (color === 'green') {
        emoji.textContent = '✅';
        box.className = 'w-[90%] max-w-xs rounded-2xl border-2 border-green-500 bg-green-950/80 p-6 text-center shadow-2xl shadow-green-900/30 transform transition-all';
        text.className = 'text-sm font-medium mb-2 text-green-200';
        okBtn.className = 'w-full h-10 rounded-lg bg-green-600 text-white font-semibold text-sm hover:bg-green-500 transition-colors';
      } else {
        emoji.textContent = '❌';
        box.className = 'w-[90%] max-w-xs rounded-2xl border-2 border-red-500 bg-red-950/80 p-6 text-center shadow-2xl shadow-red-900/30 transform transition-all';
        text.className = 'text-sm font-medium mb-2 text-red-200';
        okBtn.className = 'w-full h-10 rounded-lg bg-red-600 text-white font-semibold text-sm hover:bg-red-500 transition-colors';
      }
      text.textContent = msg;

      // Show the word + correct answer
      var answerEl = document.getElementById('quiz-modal-answer');
      if (!answerEl) {
        answerEl = document.createElement('div');
        answerEl.id = 'quiz-modal-answer';
        text.parentNode.insertBefore(answerEl, okBtn);
      }
      answerEl.className = 'mb-4 px-2';
      answerEl.innerHTML = '<p class="text-sm font-mono font-bold text-white tracking-wider mb-1">' + (questionWord || '') + '</p><p class="text-xs text-green-400 italic leading-relaxed">✓ ' + (correctAnswer || '') + '</p>';

      okBtn.textContent = quizState.current === quizState.total - 1 ? '🏁 See Results' : 'OK →';

      // Show modal with animation
      modal.classList.remove('hidden');
      box.style.transform = 'scale(0.95)';
      box.style.opacity = '0';
      requestAnimationFrame(function() {
        box.style.transition = 'transform 0.2s ease-out, opacity 0.2s ease-out';
        box.style.transform = 'scale(1)';
        box.style.opacity = '1';
      });
    }

    function hideModal() {
      var modal = document.getElementById('quiz-modal');
      var box = document.getElementById('quiz-modal-box');
      box.style.transform = 'scale(0.95)';
      box.style.opacity = '0';
      setTimeout(function() { modal.classList.add('hidden'); }, 150);
    }

    function advanceQuiz() {
      hideModal();
      var split = ((Date.now() - quizState.startTime) / 1000).toFixed(1);
      quizState.splits.push(split);
      localStorage.setItem('swf-quiz-splits', JSON.stringify(quizState.splits));
      quizState.current++;
      if (quizState.current >= quizState.total) endQuiz(false); else showQuestion();
    }

    function endQuiz(timedOut) {
      clearInterval(quizState.timerId);
      document.getElementById('quiz-active').classList.add('hidden');
      document.getElementById('quiz-complete').classList.remove('hidden');
      var totalTime = ((Date.now() - quizState.startTime) / 1000).toFixed(1);
      var score = quizState.correct, total = quizState.total, limit = quizState.timerDuration;
      var emoji = '🏆', text = '';
      if (timedOut) { emoji = '⏰'; text = "Time's Up! " + score + '/' + total; }
      else if (score === total) { emoji = '🏆'; text = 'Perfect Score! ' + score + '/' + total + ' in ' + totalTime + 's'; }
      else if (totalTime < limit * 0.5) { emoji = '🔥'; text = 'Blazing Fast! ' + score + '/' + total + ' in ' + totalTime + 's'; }
      else if (totalTime < limit * 0.75) { emoji = '⚡'; text = 'Quick Thinker! ' + score + '/' + total + ' in ' + totalTime + 's'; }
      else { emoji = '✅'; text = 'Completed! ' + score + '/' + total + ' in ' + totalTime + 's'; }
      document.getElementById('quiz-result-emoji').textContent = emoji;
      document.getElementById('quiz-result-text').textContent = text;
      var details = 'Timer: ' + limit + 's · Correct: ' + score + '/' + total + ' · Time: ' + totalTime + 's';
      if (!timedOut && parseFloat(totalTime) < limit) {
        var margin = limit - parseFloat(totalTime);
        if (margin > 60) details += ' 🔥 Destroyed by ' + margin.toFixed(0) + 's!';
        else if (margin > 30) details += ' ⚡ Beat by ' + margin.toFixed(0) + 's!';
        else if (margin > 10) details += ' ✨ ' + margin.toFixed(0) + 's spare';
      }
      document.getElementById('quiz-result-details').textContent = details;
      document.getElementById('quiz-splits').textContent = 'Splits: ' + quizState.splits.join(', ') + 's';
      // Save to achievements
      fetch('/api/achievements/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ achievement_text: 'Word Quiz', a_data: JSON.stringify({ score: score, total: total, timeUsed: totalTime, timerLimit: limit, splits: quizState.splits, timedOut: timedOut, date: new Date().toISOString() }) }) }).catch(function(){});
      // Save quiz score to DB with user ID
      var uid = localStorage.getItem('swf-uid') || '';
      fetch('/api/quiz-scores/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ user_id: uid, score: score, total: total, time_used: parseFloat(totalTime), timer_limit: limit, timed_out: timedOut ? 1 : 0 }) }).catch(function(){});
      document.getElementById('quiz-timer').classList.remove('text-red-400');
    }

    // ── Memory WordBench ──
    var fcState = { words: [], current: 0, flipped: false, active: false };

    var catColors = {
      'wotd': { border: 'border-purple-500/50', bg: 'bg-purple-900/20', text: 'text-purple-300', label: '📖 Word of the Day' },
      'quiz': { border: 'border-blue-500/50', bg: 'bg-blue-900/20', text: 'text-blue-300', label: '🧠 Quiz' },
      'manual': { border: 'border-amber-500/50', bg: 'bg-amber-900/20', text: 'text-amber-300', label: '⭐ Saved' },
      'solver': { border: 'border-green-500/50', bg: 'bg-green-900/20', text: 'text-green-300', label: '🔍 Solver' },
      'default': { border: 'border-gray-500/50', bg: 'bg-gray-900/20', text: 'text-gray-300', label: '📝 Other' }
    };

    function getCatStyle(cat) { return catColors[cat] || catColors['default']; }

    function shuffleArray(arr) {
      var copy = arr.slice();
      for (var i = copy.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = copy[i]; copy[i] = copy[j]; copy[j] = tmp;
      }
      return copy;
    }

    function renderFlashCard() {
      var card = document.getElementById('fc-card');
      var wordEl = document.getElementById('fc-word');
      var meaningEl = document.getElementById('fc-meaning');
      var hintEl = document.getElementById('fc-hint');
      var counterEl = document.getElementById('fc-counter');
      var scoreEl = document.getElementById('fc-score');
      var actionsEl = document.getElementById('fc-actions');

      if (fcState.words.length === 0) return;

      var w = fcState.words[fcState.current];
      var style = getCatStyle(w.category || 'manual');

      // Calculate score
      var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
      var pts = (w.word || '').split('').reduce(function(s, c) { return s + (scores[c.toUpperCase()] || 0); }, 0);

      // Reset flip state
      fcState.flipped = false;
      wordEl.textContent = w.word || '?';
      wordEl.style.fontSize = '';
      wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
      scoreEl.textContent = pts + ' pts';
      scoreEl.classList.remove('hidden');
      meaningEl.textContent = w.meaning || 'No meaning saved';
      meaningEl.classList.add('hidden');
      hintEl.textContent = 'tap to flip';
      hintEl.classList.remove('hidden');
      counterEl.textContent = (fcState.current + 1) + ' / ' + fcState.words.length;

      // Show actions + controls
      actionsEl.classList.remove('hidden');
      document.getElementById('fc-speed-wrap').classList.remove('hidden');

      // Apply category colour to card border
      card.className = 'mx-auto w-full max-w-sm h-48 rounded-2xl border-2 flex flex-col items-center justify-center cursor-pointer transition-all select-none ' + style.border + ' ' + style.bg + ' hover:scale-[1.02]';

      // Animate card entry
      card.style.opacity = '0';
      card.style.transform = 'rotateY(90deg)';
      requestAnimationFrame(function() {
        card.style.transition = 'opacity 0.3s, transform 0.3s';
        card.style.opacity = '1';
        card.style.transform = 'rotateY(0deg)';
      });
    }

    function flipCard() {
      var wordEl = document.getElementById('fc-word');
      var meaningEl = document.getElementById('fc-meaning');
      var hintEl = document.getElementById('fc-hint');
      var card = document.getElementById('fc-card');

      fcState.flipped = !fcState.flipped;

      if (fcState.flipped) {
        card.style.transition = 'transform 0.2s';
        card.style.transform = 'rotateY(90deg)';
        setTimeout(function() {
          meaningEl.classList.remove('hidden');
          hintEl.textContent = 'tap to see word';
          wordEl.style.fontSize = '1.2rem';
          wordEl.className = 'font-black tracking-wider mb-2 text-gray-500';
          card.style.transform = 'rotateY(0deg)';
        }, 200);
      } else {
        card.style.transition = 'transform 0.2s';
        card.style.transform = 'rotateY(90deg)';
        setTimeout(function() {
          meaningEl.classList.add('hidden');
          hintEl.textContent = 'tap to flip';
          wordEl.style.fontSize = '';
          var style = getCatStyle((fcState.words[fcState.current] || {}).category || 'manual');
          wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
          card.style.transform = 'rotateY(0deg)';
        }, 200);
      }
    }

    function startFlashCards(filterCategory) {
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      if (saved.length === 0) return;

      // Build category filters
      var cats = {};
      saved.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
      var filtersEl = document.getElementById('fc-cat-filters');
      if (Object.keys(cats).length > 1) {
        filtersEl.classList.remove('hidden');
        var activeCat = filterCategory || 'all';
        var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
          (activeCat === 'all' ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
          '" data-cat="all">All (' + saved.length + ')</button>';
        Object.keys(cats).sort().forEach(function(c) {
          html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
            (activeCat === c ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
            '" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
        });
        filtersEl.innerHTML = html;
        filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
          btn.addEventListener('click', function() {
            startFlashCards(btn.dataset.cat);
          });
        });
      }

      // Apply category filter
      var words = saved;
      if (filterCategory && filterCategory !== 'all') {
        words = saved.filter(function(w) { return (w.category || 'manual') === filterCategory; });
      }

      // Filter to words with real meanings if checkbox is checked
      var filterReal = document.getElementById('fc-real-meanings').checked;
      if (filterReal) {
        words = words.filter(function(w) {
          if (!w.meaning || w.meaning.trim() === '') return false;
          var m = w.meaning.toLowerCase();
          if (m === 'no meaning saved') return false;
          if (m.indexOf('scrabble-legal word') !== -1) return false;
          if (m.indexOf('no standard definition') !== -1) return false;
          if (m === 'a type of plant found in tropical regions') return false;
          if (m === 'to move swiftly in a specified direction') return false;
          if (m === 'a container used for storage') return false;
          if (m === 'relating to the process of growth') return false;
          if (m === 'a sound made by striking two objects') return false;
          if (m === 'to arrange in a particular order') return false;
          if (m === 'a feeling of deep satisfaction') return false;
          if (m === 'the outer covering of a seed') return false;
          if (m === 'to reduce in size or quantity') return false;
          if (m === 'a tool used for cutting') return false;
          if (m === 'relating to water or moisture') return false;
          if (m === 'a method of preparation') return false;
          if (m === 'to express disapproval strongly') return false;
          if (m === 'the quality of being bright') return false;
          if (m === 'a passage between rooms or buildings') return false;
          if (m === 'to combine separate elements') return false;
          if (m === 'relating to the earth or soil') return false;
          if (m === 'a measurement of distance') return false;
          if (m === 'to make a continuous low sound') return false;
          if (m === 'a type of fabric or textile') return false;
          return true;
        });
      }

      if (words.length === 0) {
        document.getElementById('fc-empty').textContent = 'No words with real meanings in this category. Use "📖 Lookup" on Word of the Day or click words in the solver to fetch definitions.';
        document.getElementById('fc-empty').classList.remove('hidden');
        document.getElementById('fc-card').classList.add('hidden');
        document.getElementById('fc-controls').classList.add('hidden');
        return;
      }

      fcState.words = shuffleArray(words);
      fcState.current = 0;
      fcState.active = true;

      document.getElementById('fc-empty').classList.add('hidden');
      document.getElementById('fc-card').classList.remove('hidden');
      document.getElementById('fc-controls').classList.remove('hidden');
      document.getElementById('fc-controls').style.display = 'flex';
      document.getElementById('fc-start-btn').textContent = '🔀 Shuffle';

      renderFlashCard();
    }

    document.getElementById('fc-start-btn').addEventListener('click', startFlashCards);

    // Initialize word count and category tabs on load
    (function initWordBench() {
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      document.getElementById('fc-word-count').textContent = saved.length + ' words';
      // Show category tabs immediately
      if (saved.length > 0) {
        var cats = {};
        saved.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
        if (Object.keys(cats).length > 1) {
          var filtersEl = document.getElementById('fc-cat-filters');
          var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-green-500/50 bg-green-900/30 text-green-300" data-cat="all">All (' + saved.length + ')</button>';
          Object.keys(cats).sort().forEach(function(c) {
            html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
          });
          filtersEl.innerHTML = html;
          filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
            btn.addEventListener('click', function() { startFlashCards(btn.dataset.cat); });
          });
        }
      }
    })();

    // Copy button
    document.getElementById('fc-copy-btn').addEventListener('click', function() {
      if (!fcState.active || !fcState.words[fcState.current]) return;
      navigator.clipboard.writeText(fcState.words[fcState.current].word).catch(function(){});
      this.textContent = '✓ Copied';
      var self = this;
      setTimeout(function() { self.textContent = '📋 Copy'; }, 1500);
    });

    // Delete button
    document.getElementById('fc-delete-btn').addEventListener('click', function() {
      if (!fcState.active || !fcState.words[fcState.current]) return;
      var wordToDelete = fcState.words[fcState.current].word;
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      saved = saved.filter(function(a) { return a.word !== wordToDelete; });
      localStorage.setItem('scbAchievements', JSON.stringify(saved));
      // Remove from current deck
      fcState.words.splice(fcState.current, 1);
      document.getElementById('fc-word-count').textContent = saved.length + ' words';
      if (fcState.words.length === 0) {
        document.getElementById('fc-card').classList.add('hidden');
        document.getElementById('fc-controls').classList.add('hidden');
        document.getElementById('fc-actions').classList.add('hidden');
        document.getElementById('fc-empty').classList.remove('hidden');
        fcState.active = false;
      } else {
        if (fcState.current >= fcState.words.length) fcState.current = 0;
        renderFlashCard();
      }
    });

    // Edit button — prompt to edit meaning
    document.getElementById('fc-edit-btn').addEventListener('click', function() {
      if (!fcState.active || !fcState.words[fcState.current]) return;
      var w = fcState.words[fcState.current];
      var newMeaning = prompt('Edit meaning for ' + w.word + ':', w.meaning || '');
      if (newMeaning === null) return; // cancelled
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      var match = saved.find(function(a) { return a.word === w.word; });
      if (match) { match.meaning = newMeaning; localStorage.setItem('scbAchievements', JSON.stringify(saved)); }
      w.meaning = newMeaning;
      if (fcState.flipped) {
        document.getElementById('fc-meaning').textContent = newMeaning || 'No meaning saved';
      }
    });

    // + to Solver button — navigate to solver with the word
    document.getElementById('fc-card').addEventListener('click', function() {
      if (fcState.active) flipCard();
    });

    document.getElementById('fc-prev').addEventListener('click', function() {
      if (!fcState.active || fcState.words.length === 0) return;
      fcState.current = (fcState.current - 1 + fcState.words.length) % fcState.words.length;
      renderFlashCard();
    });

    document.getElementById('fc-next').addEventListener('click', function() {
      if (!fcState.active || fcState.words.length === 0) return;
      fcState.current = (fcState.current + 1) % fcState.words.length;
      renderFlashCard();
    });

    // Keyboard navigation for flash cards
    document.addEventListener('keydown', function(e) {
      if (!fcState.active) return;
      if (e.key === 'ArrowLeft') { stopAutoPlay(); document.getElementById('fc-prev').click(); }
      else if (e.key === 'ArrowRight') { stopAutoPlay(); document.getElementById('fc-next').click(); }
      else if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipCard(); }
    });

    // ── Auto-play ──
    var autoPlayTimer = null;
    var autoPlayPhase = 'word'; // 'word' → show word, 'meaning' → show meaning, then advance

    function getAutoPlaySpeed() {
      return parseInt(document.getElementById('fc-speed').value) * 1000 || 5000;
    }

    // Load saved speed from localStorage
    (function initSpeed() {
      var saved = localStorage.getItem('swf-fc-speed');
      if (saved) {
        document.getElementById('fc-speed').value = saved;
        document.getElementById('fc-speed-label').textContent = saved + 's';
      }
    })();

    function startAutoPlay() {
      if (!fcState.active) { startFlashCards(); }
      if (!fcState.active) return; // still no words
      autoPlayPhase = 'word';
      scheduleNext();
    }

    function scheduleNext() {
      clearTimeout(autoPlayTimer);
      var speed = getAutoPlaySpeed();
      autoPlayTimer = setTimeout(function() {
        if (!document.getElementById('fc-autoplay').checked) return;

        if (autoPlayPhase === 'word') {
          // Flip to show meaning
          if (!fcState.flipped) flipCard();
          autoPlayPhase = 'meaning';
          scheduleNext();
        } else {
          // Advance to next card
          fcState.current = (fcState.current + 1) % fcState.words.length;
          renderFlashCard();
          autoPlayPhase = 'word';
          scheduleNext();
        }
      }, speed);
    }

    var fcTimerInterval = null;
    var fcTimerStart = 0;

    function stopAutoPlay() {
      clearTimeout(autoPlayTimer);
      clearInterval(fcTimerInterval);
      autoPlayTimer = null;
      fcTimerInterval = null;
      document.getElementById('fc-autoplay').checked = false;
      document.getElementById('fc-speed-wrap').classList.add('hidden');
      document.getElementById('fc-timer').classList.add('hidden');
      var btn = document.getElementById('fc-autoplay-btn');
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
    }

    document.getElementById('fc-autoplay-btn').addEventListener('click', function() {
      var checkbox = document.getElementById('fc-autoplay');
      var btn = document.getElementById('fc-autoplay-btn');
      if (!checkbox.checked) {
        checkbox.checked = true;
        document.getElementById('fc-speed-wrap').classList.remove('hidden');
        btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
        // Start timer
        fcTimerStart = Date.now();
        document.getElementById('fc-timer').classList.remove('hidden');
        fcTimerInterval = setInterval(function() {
          var elapsed = Math.floor((Date.now() - fcTimerStart) / 1000);
          var mins = Math.floor(elapsed / 60);
          var secs = elapsed % 60;
          document.getElementById('fc-timer').textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
        }, 1000);
        startAutoPlay();
      } else {
        checkbox.checked = false;
        document.getElementById('fc-speed-wrap').classList.add('hidden');
        document.getElementById('fc-timer').classList.add('hidden');
        clearTimeout(autoPlayTimer);
        clearInterval(fcTimerInterval);
        btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
      }
    });

    document.getElementById('fc-speed').addEventListener('input', function() {
      var val = this.value;
      document.getElementById('fc-speed-label').textContent = val + 's';
      localStorage.setItem('swf-fc-speed', val);
      if (document.getElementById('fc-autoplay').checked) {
        clearTimeout(autoPlayTimer);
        scheduleNext();
      }
    });

  })();
  </script>
</Layout>
