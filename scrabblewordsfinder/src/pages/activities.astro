---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import WotdPanel from '../components/activities/WotdPanel.astro';
import QuizPanel from '../components/activities/QuizPanel.astro';
import WordBenchPanel from '../components/activities/WordBenchPanel.astro';
import DailyRackPanel from '../components/activities/DailyRackPanel.astro';
import DailyAnagramPanel from '../components/activities/DailyAnagramPanel.astro';
---

<Layout title="Activities — Word of the Day, Word Quiz & Daily Anagram" description="Daily word challenges, timed vocabulary quizzes, and anagram puzzles. Learn new Scrabble words every day, test your knowledge, and unscramble daily puzzles." keywords="word of the day, scrabble quiz, vocabulary quiz, word game, daily word challenge, daily anagram, word puzzle, wordle scrabble">

  <main class="mx-auto max-w-5xl px-4 sm:px-6 pb-20 pt-4">
    <div class="flex items-center justify-between mb-2">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white"><span class="text-blue-400">🎯</span> Activities</h1>
      <div class="flex items-center gap-3">
        <a href="/sixty-seconds/" class="px-3 py-1.5 rounded-lg bg-green-600/20 border border-green-500/30 text-xs font-medium text-green-400 hover:bg-green-600/40 transition-colors">⏱️ 60-Second</a>
        <a href="/stats/" class="px-3 py-1.5 rounded-lg bg-purple-600/20 border border-purple-500/30 text-xs font-medium text-purple-400 hover:bg-purple-600/40 transition-colors">📊 Your Stats</a>
      </div>
    </div>
    <p class="text-sm text-gray-400 mb-8">Daily word challenges and vocabulary quizzes to sharpen your Scrabble skills.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <WotdPanel />
      <QuizPanel />
      <WordBenchPanel />
      <DailyRackPanel />
      <DailyAnagramPanel />
    </div>
  </main>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is Word of the Day on ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "Word of the Day features a new Scrabble-worthy word every day with its meaning. You can save it to your Memory WordBench for later review and practice. Words are pre-assigned for 27 years of daily coverage." } },
      { "@type": "Question", "name": "How does the Word Quiz work?", "acceptedAnswer": { "@type": "Answer", "text": "The Word Quiz tests your vocabulary under time pressure. Choose 3-10 words per round, pick a timer (30-120 seconds), and match words to their correct meanings from 4 options. Scores are tracked in your Quiz History." } },
      { "@type": "Question", "name": "What is the Daily Rack Challenge?", "acceptedAnswer": { "@type": "Answer", "text": "Every day, all players get the same 7 Scrabble tiles. Your goal is to find the highest-scoring word you can make from those tiles. Submit as many words as you like — your best score for the day is tracked." } },
      { "@type": "Question", "name": "How does the Daily Anagram work?", "acceptedAnswer": { "@type": "Answer", "text": "The Daily Anagram gives you a scrambled 6-letter word to unscramble. You have 5 guesses with Wordle-style colour feedback: green means correct letter in correct position, yellow means correct letter in wrong position, and gray means the letter is not in the word. A hint is available if you get stuck. Same puzzle for everyone each day — share your result with friends!" } }
    ]
  }
  </script>
</Layout>
