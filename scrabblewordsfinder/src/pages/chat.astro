---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Lex — AI Scrabble Assistant | ScrabbleWordsFinder" description="Chat with Lex, your AI-powered Scrabble strategy assistant. Get instant word tips, best rack plays, strategy advice, and rules clarification for free." keywords="scrabble chat, ai scrabble helper, scrabble strategy assistant, word game ai, scrabble tips bot, lex scrabble">
  <main class="mx-auto max-w-6xl px-4 sm:px-6 py-6">
    <div class="flex flex-col lg:flex-row gap-6">
    <!-- Left column: Chat panel -->
    <div class="flex-1 min-w-0">
    <div class="flex items-center gap-3 mb-4">
      <a href="/" class="text-sm text-blue-400 hover:underline">← Solver</a>
      <h1 class="text-xl font-bold text-white flex items-center gap-2">
        <span class="relative group shrink-0">
          <img src="/lex-avatar.webp" alt="Lex" width="32" height="32" class="rounded-full cursor-pointer transition-transform duration-200 group-hover:scale-[3] group-hover:z-50 group-hover:relative group-hover:ring-2 group-hover:ring-cyan-400/60" />
          <span class="absolute top-full left-1/2 -translate-x-1/2 mt-1 px-2 py-0.5 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Lex AI</span>
        </span>
        Lex
      </h1>
      <span class="text-xs text-black font-semibold bg-orange-400 px-2 py-0.5 rounded-full">Your Scrabble AI Coach</span>
      <!-- AI Binding Status Bot — Animated Cogs -->
      <span id="ai-status-bot" class="inline-flex items-center gap-1 ml-1" title="Checking AI status...">
        <svg id="ai-cogs-icon" width="28" height="28" viewBox="0 0 80 80" class="opacity-50" aria-hidden="true">
          <!-- Large center cog (green when healthy, red when broken) -->
          <g id="cog-center" style="transform-origin: 38px 42px;">
            <path d="M38 42m-14 0a14 14 0 1 0 28 0 14 14 0 1 0-28 0" fill="none" stroke="#22c55e" stroke-width="5"/>
            <circle cx="38" cy="42" r="5" fill="#22c55e"/>
            <!-- Teeth -->
            <rect x="35" y="22" width="6" height="8" rx="1" fill="#22c55e"/>
            <rect x="35" y="54" width="6" height="8" rx="1" fill="#22c55e"/>
            <rect x="18" y="39" width="8" height="6" rx="1" fill="#22c55e"/>
            <rect x="50" y="39" width="8" height="6" rx="1" fill="#22c55e"/>
            <rect x="22.5" y="27" width="6" height="7" rx="1" fill="#22c55e" transform="rotate(-45 25.5 30.5)"/>
            <rect x="47.5" y="51" width="6" height="7" rx="1" fill="#22c55e" transform="rotate(-45 50.5 54.5)"/>
            <rect x="47.5" y="27" width="6" height="7" rx="1" fill="#22c55e" transform="rotate(45 50.5 30.5)"/>
            <rect x="22.5" y="51" width="6" height="7" rx="1" fill="#22c55e" transform="rotate(45 25.5 54.5)"/>
          </g>
          <!-- Top-right small cog (blue) -->
          <g id="cog-top" style="transform-origin: 60px 20px;">
            <path d="M60 20m-8 0a8 8 0 1 0 16 0 8 8 0 1 0-16 0" fill="none" stroke="#3b82f6" stroke-width="4"/>
            <circle cx="60" cy="20" r="3" fill="#3b82f6"/>
            <rect x="58" y="8" width="4" height="5" rx="1" fill="#3b82f6"/>
            <rect x="58" y="27" width="4" height="5" rx="1" fill="#3b82f6"/>
            <rect x="48" y="18" width="5" height="4" rx="1" fill="#3b82f6"/>
            <rect x="67" y="18" width="5" height="4" rx="1" fill="#3b82f6"/>
            <rect x="50" y="11" width="4" height="5" rx="1" fill="#3b82f6" transform="rotate(-45 52 13.5)"/>
            <rect x="66" y="23" width="4" height="5" rx="1" fill="#3b82f6" transform="rotate(-45 68 25.5)"/>
          </g>
          <!-- Bottom-left small cog (amber/orange) -->
          <g id="cog-bottom" style="transform-origin: 18px 64px;">
            <path d="M18 64m-8 0a8 8 0 1 0 16 0 8 8 0 1 0-16 0" fill="none" stroke="#f59e0b" stroke-width="4"/>
            <circle cx="18" cy="64" r="3" fill="#f59e0b"/>
            <rect x="16" y="52" width="4" height="5" rx="1" fill="#f59e0b"/>
            <rect x="16" y="71" width="4" height="5" rx="1" fill="#f59e0b"/>
            <rect x="6" y="62" width="5" height="4" rx="1" fill="#f59e0b"/>
            <rect x="25" y="62" width="5" height="4" rx="1" fill="#f59e0b"/>
            <rect x="8" y="55" width="4" height="5" rx="1" fill="#f59e0b" transform="rotate(-45 10 57.5)"/>
            <rect x="24" y="67" width="4" height="5" rx="1" fill="#f59e0b" transform="rotate(-45 26 69.5)"/>
          </g>
        </svg>
        <span id="ai-status-text" class="text-[10px] font-bold uppercase tracking-wide text-gray-500">...</span>
      </span>
    </div>

    <p class="text-sm text-gray-400 mb-4">Ask me about Scrabble strategy, word suggestions, rules, or enter your rack below for the best play.</p>

    <!-- Ask Lex — Rack Input + Dojo Mode -->
    <div id="ask-lex-panel" class="mb-4 p-3 bg-gray-800/60 border border-gray-700 rounded-xl">
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-0">
        <!-- Left: Rack Input -->
        <div class="flex-1">
          <label for="rack-input" class="text-xs font-semibold text-gray-300 uppercase tracking-wide mb-2 block">Your Rack (up to 7 tiles)</label>
          <div class="flex items-center gap-2">
            <input
              id="rack-input"
              type="text"
              maxlength="7"
              placeholder="e.g. AEILNRT"
              class="w-32 px-3 py-2 text-sm font-mono uppercase tracking-widest bg-gray-900 border border-gray-600 rounded-lg text-green-400 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
              autocomplete="off"
              spellcheck="false"
            />
            <button
              id="ask-lex-btn"
              type="button"
              class="px-4 py-2 text-sm font-semibold rounded-lg bg-emerald-600 hover:bg-emerald-500 disabled:bg-gray-700 disabled:cursor-not-allowed text-white transition-colors"
            >Ask Lex</button>
          </div>
          <p id="rack-hint" class="text-xs text-gray-500 mt-1.5">Enter your tiles and I'll find the best word</p>
          <!-- EV Score Badge — shows rack quality when tiles entered -->
          <div id="ev-score-badge" class="hidden mt-2 flex items-center gap-2">
            <span id="ev-score-bar" class="h-2 rounded-full bg-gray-700 w-24 overflow-hidden">
              <span id="ev-score-fill" class="block h-full rounded-full transition-all duration-300" style="width:0%"></span>
            </span>
            <span id="ev-score-value" class="text-xs font-bold font-mono"></span>
            <span id="ev-score-label" class="text-[10px] uppercase tracking-wider font-semibold"></span>
          </div>
          <!-- Memorise with Memory WordBench -->
          <button id="mwb-modal-open" type="button" class="inline-flex items-center gap-1.5 mt-[11px] px-3 py-1.5 text-xs font-medium rounded-lg border border-purple-500/40 bg-purple-900/20 text-purple-300 hover:bg-purple-800/40 hover:border-purple-400 transition-colors">
            <span aria-hidden="true">🧠</span> Memorise with Memory WordBench
          </button>
        </div>

        <!-- Vertical Separator -->
        <div class="hidden sm:block w-px bg-gray-600/60 mx-4 self-stretch"></div>
        <div class="sm:hidden h-px bg-gray-600/60 my-2"></div>

        <!-- Right: Dojo Mode -->
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-2">
            <label for="dojo-toggle" class="text-xs font-semibold text-gray-300 uppercase tracking-wide">Dojo Mode</label>
            <label class="relative inline-flex items-center cursor-pointer">
              <input id="dojo-toggle" type="checkbox" class="sr-only peer" checked />
              <div class="w-9 h-5 bg-gray-700 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-orange-500/50 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-gray-400 after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-orange-500 peer-checked:after:bg-white"></div>
            </label>
            <span id="dojo-status" class="text-[10px] uppercase tracking-wide font-bold text-orange-400">On</span>
          </div>
          <p class="text-xs text-gray-500 mb-2">Train your skills with AI-powered drills</p>
          <!-- Dojo training mode buttons (hidden until toggle is on) -->
          <div id="dojo-buttons" class="grid grid-cols-2 gap-2">
            <button data-dojo="bingo" class="dojo-btn px-2 py-2 text-xs font-semibold rounded-lg border border-purple-500/50 bg-purple-900/30 text-purple-300 hover:bg-purple-800/50 hover:border-purple-400 transition-colors text-left">
              <span class="block text-[11px] font-bold">🎯 Bingo Trainer</span>
              <span class="block text-[10px] text-gray-400 mt-0.5">Find all 7-letter words</span>
            </button>
            <button data-dojo="hook" class="dojo-btn px-2 py-2 text-xs font-semibold rounded-lg border border-cyan-500/50 bg-cyan-900/30 text-cyan-300 hover:bg-cyan-800/50 hover:border-cyan-400 transition-colors text-left">
              <span class="block text-[11px] font-bold">🪝 Hook Quiz</span>
              <span class="block text-[10px] text-gray-400 mt-0.5">Guess valid hooks</span>
            </button>
            <button data-dojo="countdown" class="dojo-btn px-2 py-2 text-xs font-semibold rounded-lg border border-amber-500/50 bg-amber-900/30 text-amber-300 hover:bg-amber-800/50 hover:border-amber-400 transition-colors text-left">
              <span class="block text-[11px] font-bold">🔢 Tile Countdown</span>
              <span class="block text-[10px] text-gray-400 mt-0.5">Track remaining tiles</span>
            </button>
            <button data-dojo="leave" class="dojo-btn px-2 py-2 text-xs font-semibold rounded-lg border border-emerald-500/50 bg-emerald-900/30 text-emerald-300 hover:bg-emerald-800/50 hover:border-emerald-400 transition-colors text-left">
              <span class="block text-[11px] font-bold">♻️ Rack Leave Drill</span>
              <span class="block text-[10px] text-gray-400 mt-0.5">Pick the best play</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Chat usage counter -->
    <p id="chat-usage" class="text-xs text-green-400 font-medium mb-3">Questions asked: <span id="chat-usage-count">—</span></p>

    <!-- Tailwind safelist: classes used in JS-generated FVT HTML (formatAnswer + applyInlineFormatting) -->
    <div class="hidden">
      <!-- Inline formatting -->
      <span class="text-white font-semibold"></span>
      <code class="px-1.5 py-0.5 rounded bg-gray-700 text-emerald-300 text-xs font-mono"></code>
      <p class="text-sm text-gray-200 leading-relaxed mt-2"></p>
      <!-- FVT numbered steps block (emerald theme) -->
      <div class="my-3 p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10"></div>
      <p class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-3"></p>
      <div class="space-y-2.5"></div>
      <div class="flex items-start gap-3"></div>
      <span class="shrink-0 w-5 h-5 rounded-full bg-emerald-900/50 border border-emerald-500/40 flex items-center justify-center text-[10px] text-emerald-300 font-bold"></span>
      <p class="text-sm text-gray-300 leading-relaxed"></p>
      <!-- FVT bullet tiles (emerald theme) -->
      <div class="my-3 space-y-2"></div>
      <div class="flex items-start gap-2.5 p-2.5 rounded-lg border border-emerald-500/20 bg-emerald-950/10"></div>
      <span class="text-emerald-400 mt-0.5 shrink-0 text-xs"></span>
    </div>

    <!-- Chat container -->
    <div id="chat-container" class="flex flex-col h-[60vh] min-h-[400px] bg-gray-900/50 border border-gray-700 rounded-xl overflow-hidden">
      <!-- Messages area -->
      <div id="messages" class="flex-1 overflow-y-auto p-4 space-y-4">
        <!-- Welcome message -->
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-full bg-emerald-900/50 flex items-center justify-center shrink-0">
            <img src="/lex-avatar-32.png" alt="Lex" width="20" height="20" class="rounded-full" />
          </div>
          <div class="bg-gray-800 rounded-lg rounded-tl-none px-4 py-2.5 max-w-[85%]">
            <p class="text-sm text-gray-200">I'm <strong>Lex</strong>, your Scrabble AI Coach. Ask me anything about Scrabble — strategy tips, word suggestions, rules questions, or enter your rack above and hit <strong>Ask Lex</strong> for the best word to play!</p>
          </div>
        </div>
      </div>

      <!-- Input area -->
      <div class="border-t border-gray-700 p-3 bg-gray-900/80">
        <form id="chat-form" class="flex items-end gap-2">
          <textarea
            id="chat-input"
            rows="1"
            placeholder="Ask about Scrabble strategy, words, rules..."
            class="flex-1 resize-none rounded-lg bg-gray-800 border border-gray-600 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent max-h-32"
            autocomplete="off"
          ></textarea>
          <button
            id="mic-btn"
            type="button"
            class="shrink-0 w-11 h-11 rounded-lg bg-gray-700 hover:bg-gray-600 flex items-center justify-center transition-colors"
            title="Voice input"
          >
            <svg id="mic-icon" class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-14 0m7 7v4m-4 0h8m-4-12a3 3 0 00-3 3v4a3 3 0 006 0V8a3 3 0 00-3-3z" />
            </svg>
            <svg id="mic-icon-active" class="w-5 h-5 text-red-400 hidden animate-pulse" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zM19 10v1a7 7 0 01-14 0v-1H3v1a9 9 0 004 7.46V21H9v2h6v-2h2v-2.54A9 9 0 0021 11v-1h-2z"/>
            </svg>
          </button>
          <button
            id="send-btn"
            type="submit"
            class="shrink-0 h-11 px-4 rounded-lg bg-blue-600 hover:bg-blue-500 disabled:bg-gray-700 disabled:cursor-not-allowed flex items-center justify-center gap-1.5 transition-colors"
            title="Send message"
          >
            <span class="text-sm font-semibold text-white whitespace-nowrap">Ask Lex</span>
          </button>
        </form>
        <p class="text-[10px] text-gray-600 mt-1.5 text-center">Powered by Lex AI · Responses may not always be accurate · <a href="/privacy/" class="hover:text-gray-400 underline">Privacy</a></p>
      </div>
    </div>

    <!-- Skill Level Starters -->
    <div id="skill-level-starters" class="mt-4 flex flex-col gap-2">
      <button class="static-kw flex items-center gap-3 px-4 py-3 text-left rounded-xl bg-green-900/20 border border-green-700/40 hover:border-green-500/60 hover:bg-green-900/30 transition-colors group" data-prompt="I am a beginner at Scrabble and want to get better. Teach me the fundamentals — what should I learn first? Cover basic strategy, the most important words to memorise, and common mistakes beginners make.">
        <span class="text-2xl shrink-0">🌱</span>
        <span class="text-sm text-green-300 group-hover:text-green-200">I am a beginner, and I want to get better at Scrabble.</span>
      </button>
      <button class="static-kw flex items-center gap-3 px-4 py-3 text-left rounded-xl bg-amber-900/20 border border-amber-700/40 hover:border-amber-500/60 hover:bg-amber-900/30 transition-colors group" data-prompt="Tell me about bingo words and strategies in Scrabble. What is a bingo, how do I spot bingo opportunities on my rack, what are the best bingo stems to memorise, and what strategies can I use to play more 7-letter words?">
        <span class="text-2xl shrink-0">🎯</span>
        <span class="text-sm text-amber-300 group-hover:text-amber-200">Tell me about Bingo words and strategies</span>
        <a href="/blog/bingo-stem-strategy/" class="ml-auto shrink-0 text-amber-400 hover:text-amber-300 transition-colors" title="Read Bingo Strategy Guide" onclick="event.stopPropagation()">🔗</a>
      </button>
      <button class="static-kw flex items-center gap-3 px-4 py-3 text-left rounded-xl bg-blue-900/20 border border-blue-700/40 hover:border-blue-500/60 hover:bg-blue-900/30 transition-colors group" data-prompt="I am an intermediate Scrabble player looking to improve. I know basic words and strategy but want to level up. Teach me about rack management, hook words, parallel plays, and how to score consistently higher.">
        <span class="text-2xl shrink-0">⚡</span>
        <span class="text-sm text-blue-300 group-hover:text-blue-200">I am an intermediate player, and I want to improve.</span>
      </button>
      <button class="static-kw flex items-center gap-3 px-4 py-3 text-left rounded-xl bg-purple-900/20 border border-purple-700/40 hover:border-purple-500/60 hover:bg-purple-900/30 transition-colors group" data-prompt="I am an advanced Scrabble player aiming to master the game at tournament level. Teach me advanced concepts — endgame strategy, tile tracking, leave evaluation, positional play, and how top players think differently.">
        <span class="text-2xl shrink-0">🏆</span>
        <span class="text-sm text-purple-300 group-hover:text-purple-200">I am an advanced player, and want to master Scrabble.</span>
      </button>
    </div>

    <!-- Static keyword shortcuts -->
    <div id="static-keywords" class="mt-4 flex flex-wrap gap-2">
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="What are the best opening moves in Scrabble and why? Include word suggestions with point values.">🎯 Best opening moves</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="Teach me the most useful Scrabble words that use the letter Q, including Q-without-U words with their point values.">🅀 Teach me Q words</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="Quiz me on Scrabble vocabulary! Give me a Scrabble trivia question about valid words, strategy, or scoring rules.">📚 Can you Quiz me?</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="I'd like you to analyse a Scrabble rack for me. What should I look for when evaluating my tiles and deciding what to play or exchange?">🎒 Analyse my rack</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="Pick an interesting Scrabble word and explain its meaning, point value, and when it's strategically useful to play.">📖 Explain this word</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="What are the top tips for preparing for a competitive Scrabble tournament? Cover time management, word study, and mental preparation.">🏆 Tournament tips</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="Help me with today's Scrabble daily challenge. What strategy tips do you have for solving anagrams and finding the best word from a random rack?">🎲 Daily challenge help</button>
      <button class="static-kw px-3 py-1.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-300 hover:text-emerald-200 hover:border-emerald-400 transition-colors" data-prompt="What are the most impactful ways to improve my Scrabble strategy? Give me actionable tips for scoring higher and winning more games.">📈 Improve my strategy</button>
    </div>

    <!-- Quick prompts (dynamically populated from top chat keywords) -->
    <div id="quick-prompts" class="mt-4 flex flex-wrap gap-2">
      <button class="quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors">Best 2-letter words?</button>
      <button class="quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors">Q without U words</button>
      <button class="quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors">How to manage my rack?</button>
      <button class="quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors">Triple word strategy</button>
      <button class="quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors">What is a bingo?</button>
    </div>
    </div><!-- end left column -->

    <!-- Right column: Identified Words + Keyword History -->
    <div class="lg:w-64 xl:w-72 shrink-0 flex flex-col gap-4">

    <!-- Identified Words panel -->
    <div id="identified-words-panel" class="hidden">
      <div class="sticky top-6 p-4 bg-gray-900/50 border border-emerald-700/50 rounded-xl">
        <h2 class="text-sm font-semibold text-emerald-300 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Identified Words
          <button id="add-identified-to-mwb" class="ml-auto w-6 h-6 flex items-center justify-center rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 hover:border-purple-400 text-purple-300 transition-colors" title="Add all to Memory WordBench">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"/></svg>
          </button>
        </h2>
        <p class="text-[10px] text-gray-500 mb-2">Words (6+ letters) found in Lex's responses</p>
        <div id="identified-words-list" class="flex flex-wrap gap-1.5"></div>
        <button id="clear-identified-words" class="mt-3 text-[10px] text-gray-500 hover:text-red-400 transition-colors">Clear all</button>
      </div>
    </div>

    <!-- Your Keyword History (user's own past questions) -->
    <div id="keyword-history" class="hidden">
      <div class="p-4 bg-gray-900/50 border border-gray-700 rounded-xl">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-300">Your Recent Questions</h2>
          <div class="flex items-center gap-2">
