      return Promise.all([
        fetch('/data/sowpods-2-7.json').then(function(r) { return r.json(); }),
        fetch('/data/sowpods-8-15.json').then(function(r) { return r.json(); }),
      ]).then(function(results) {
        var all = results[0].concat(results[1]).map(function(w) { return w.toUpperCase(); });
        _validWordCache = {};
        for (var i = 0; i < all.length; i++) _validWordCache[all[i]] = true;
        return _validWordCache;
      }).catch(function() { return null; });
    }

