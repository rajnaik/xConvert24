        try {
          const res = await fetch('/api/cab/?user_id=' + encodeURIComponent(uid));
          if (!res.ok) throw new Error('Failed to fetch CaB history');
          const data = await res.json();
          input.value = buildCabPrompt(data.rounds || []);
          pendingCabCoach = true;
          setTimeout(() => { form.dispatchEvent(new Event('submit', { cancelable: true })); }, 500);
        } catch {
          input.value = 'I\'ve been playing Cows and Bulls. Can you analyse my history and give me tips to improve my deduction skills?';
          pendingCabCoach = true;
          setTimeout(() => { form.dispatchEvent(new Event('submit', { cancelable: true })); }, 500);
        }
      })();
    })();

    // Voice input (Web Speech API)
    // Analyse Score tile — show game-specific coaching links if user has history
    (function initAnalyseScore() {
      const uid = localStorage.getItem('swf-uid') || '';
      if (!uid) return; // No user = no history

      const tile = document.getElementById('analyse-score-tile');
      const linksContainer = document.getElementById('analyse-score-links');
      if (!tile || !linksContainer) return;

      (async function() {
        try {
          const res = await fetch(`/api/users/${encodeURIComponent(uid)}/`);
          if (!res.ok) return;
          const data = await res.json();

          const games = [
            { key: 'quizzes', label: 'Word Quiz', icon: '📝', context: 'quiz', count: data.quizzes?.length || 0 },
            { key: 'racks', label: 'Daily Rack', icon: '🎲', context: 'rack', count: data.racks?.length || 0 },
            { key: 'anagrams', label: 'Anagram', icon: '🔤', context: 'anagram', count: data.anagrams?.length || 0 },
            { key: 'cab_games', label: 'Cows & Bulls', icon: '🐂', context: 'cab', count: data.cab_games?.length || 0 },
          ];

          const withHistory = games.filter(g => g.count > 0);
          if (withHistory.length === 0) return;

          tile.classList.remove('hidden');
          linksContainer.innerHTML = withHistory.map(g =>
            `<a href="/chat/?context=${g.context}" class="flex items-center gap-2.5 px-3 py-2 rounded-lg bg-amber-900/20 border border-amber-700/40 hover:border-amber-500/60 hover:bg-amber-800/30 transition-colors group">
              <span class="text-base" aria-hidden="true">${g.icon}</span>
              <span class="text-xs text-gray-300 group-hover:text-amber-200 transition-colors">${g.label}</span>
              <span class="ml-auto text-[10px] text-gray-500 group-hover:text-amber-400">${g.count} game${g.count === 1 ? '' : 's'}</span>
            </a>`
          ).join('');
        } catch { /* non-critical */ }
      })();
    })();

    // Saved Reports panel — shows stored coaching PDFs from localStorage
    (function initSavedReports() {
      var panel = document.getElementById('saved-reports-panel');
      var listEl = document.getElementById('saved-reports-list');
      var emptyEl = document.getElementById('saved-reports-empty');
      var countEl = document.getElementById('saved-reports-count');
      if (!panel || !listEl) return;

      function renderReports() {
        if (typeof getStoredReports !== 'function') return;
        var reports = getStoredReports();

        if (reports.length === 0) {
          panel.classList.add('hidden');
          return;
        }

        panel.classList.remove('hidden');
        countEl.textContent = reports.length + ' / 5';
        emptyEl.classList.toggle('hidden', reports.length > 0);

        var typeIcons = { quiz: '\uD83D\uDCDD', rack: '\uD83C\uDFB2', anagram: '\uD83D\uDD24', cab: '\uD83D\uDC02' };
        var typeColors = { quiz: 'emerald', rack: 'purple', anagram: 'orange', cab: 'amber' };

        listEl.innerHTML = reports.map(function(r) {
          var icon = typeIcons[r.type] || '\uD83D\uDCC4';
          var color = typeColors[r.type] || 'gray';
          var date = r.date ? new Date(r.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : 'Unknown';
          return '<div class="flex items-center gap-2 p-2 rounded-lg bg-gray-800/50 border border-gray-700/50 group">' +
            '<span class="text-sm" aria-hidden="true">' + icon + '</span>' +
            '<div class="flex-1 min-w-0">' +
              '<p class="text-xs text-gray-200 font-medium truncate">' + (r.title || 'Report') + '</p>' +
              '<p class="text-[10px] text-gray-500">' + date + '</p>' +
            '</div>' +
            '<button data-report-view="' + r.id + '" class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-cyan-900/30 border border-cyan-600/40 text-cyan-300 hover:bg-cyan-800/50 hover:border-cyan-400 transition-colors opacity-0 group-hover:opacity-100" title="View PDF">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>' +
            '</button>' +
            '<button data-report-delete="' + r.id + '" class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-red-900/20 border border-red-600/30 text-red-400 hover:bg-red-800/40 hover:border-red-400 transition-colors opacity-0 group-hover:opacity-100" title="Delete">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
            '</button>' +
          '</div>';
        }).join('');

        // Bind view buttons
        listEl.querySelectorAll('[data-report-view]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var id = btn.getAttribute('data-report-view');
            var reports = getStoredReports();
            var report = reports.find(function(r) { return r.id === id; });
            if (report && report.base64) {
              // Open in new tab
              var win = window.open('', '_blank');
              if (win) {
                win.document.write('<iframe src="' + report.base64 + '" style="width:100%;height:100%;border:none;position:fixed;top:0;left:0;" frameborder="0"></iframe>');
                win.document.title = report.title || 'Coaching Report';
              }
            }
          });
        });

        // Bind delete buttons
        listEl.querySelectorAll('[data-report-delete]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var id = btn.getAttribute('data-report-delete');
            if (typeof deleteStoredReport === 'function') {
              deleteStoredReport(id);
            }
          });
        });
      }

      // Initial render
      renderReports();

      // Listen for updates (from save button or delete)
      window.addEventListener('coaching-reports-updated', renderReports);
    })();

    (function initVoiceInput() {
      const micBtn = document.getElementById('mic-btn');
      const micIcon = document.getElementById('mic-icon');
      const micIconActive = document.getElementById('mic-icon-active');

      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) {
        // Browser doesn't support speech recognition — hide the button
        micBtn.style.display = 'none';
        return;
      }

      const recognition = new SpeechRecognition();
      recognition.continuous = false;
      recognition.interimResults = true;
      recognition.lang = 'en-US';
      let isListening = false;

      micBtn.addEventListener('click', () => {
        if (isStreaming) return;
        if (isListening) {
          recognition.stop();
          return;
        }
        recognition.start();
      });

      recognition.addEventListener('start', () => {
        isListening = true;
        micBtn.classList.remove('bg-gray-700', 'hover:bg-gray-600');
        micBtn.classList.add('bg-red-600/80', 'hover:bg-red-500');
        micIcon.classList.add('hidden');
        micIconActive.classList.remove('hidden');
        micBtn.title = 'Stop listening';
      });

      recognition.addEventListener('end', () => {
        isListening = false;
        micBtn.classList.remove('bg-red-600/80', 'hover:bg-red-500');
        micBtn.classList.add('bg-gray-700', 'hover:bg-gray-600');
        micIcon.classList.remove('hidden');
        micIconActive.classList.add('hidden');
        micBtn.title = 'Voice input';
      });

      recognition.addEventListener('result', (event) => {
        let transcript = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
          transcript += event.results[i][0].transcript;
        }
        input.value = transcript;
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 128) + 'px';

        // Auto-submit on final result
        if (event.results[event.results.length - 1].isFinal) {
          if (input.value.trim()) {
            setTimeout(() => { form.dispatchEvent(new Event('submit')); }, 200);
          }
        }
      });

      recognition.addEventListener('error', (event) => {
        isListening = false;
        micBtn.classList.remove('bg-red-600/80', 'hover:bg-red-500');
        micBtn.classList.add('bg-gray-700', 'hover:bg-gray-600');
        micIcon.classList.remove('hidden');
        micIconActive.classList.add('hidden');
        micBtn.title = 'Voice input';
        if (event.error !== 'aborted' && event.error !== 'no-speech') {
          console.warn('Speech recognition error:', event.error);
        }
      });
    })();
  })();
  </script>

  <!-- AI Binding Status Check -->
  <script is:inline>
  (function() {
    const cogsIcon = document.getElementById('ai-cogs-icon');
    const cogCenter = document.getElementById('cog-center');
    const cogTop = document.getElementById('cog-top');
    const cogBottom = document.getElementById('cog-bottom');
    const statusBot = document.getElementById('ai-status-bot');
    const statusText = document.getElementById('ai-status-text');

    async function checkAIHealth() {
      try {
        const res = await fetch('/api/chat-heartbeat/');
        if (res.ok) {
          const data = await res.json();
          if (data.healthy) {
            setHealthy();
          } else {
            setUnhealthy(data.reason || 'AI unavailable');
          }
        } else {
          setUnhealthy('Health check failed');
        }
      } catch {
        setUnhealthy('Cannot reach server');
      }
    }

    function setHealthy() {
      cogsIcon.classList.remove('opacity-50');
      cogsIcon.classList.add('ai-cogs-active');
      // Green center cog spins
      cogCenter.querySelectorAll('path, circle, rect').forEach(el => {
        const tag = el.tagName;
        if (tag === 'path') el.setAttribute('stroke', '#22c55e');
        el.setAttribute('fill', el.getAttribute('fill') === 'none' ? 'none' : '#22c55e');
      });
      cogCenter.classList.add('ai-cog-spin-cw');
      cogCenter.classList.remove('ai-cog-broken');
      // Blue top cog spins counter-clockwise
      cogTop.classList.add('ai-cog-spin-ccw');
      cogTop.classList.remove('ai-cog-stopped');
      // Amber bottom cog spins clockwise slower
      cogBottom.classList.add('ai-cog-spin-cw-slow');
      cogBottom.classList.remove('ai-cog-stopped');
      // Online text
      statusText.textContent = 'online';
      statusText.className = 'text-[10px] font-bold uppercase tracking-wide text-green-400';
      statusBot.title = 'AI is online and ready';
    }

    function setUnhealthy(reason) {
      cogsIcon.classList.remove('opacity-50');
      cogsIcon.classList.add('ai-cogs-active');
      // Center cog turns red and stutters
      cogCenter.querySelectorAll('path, circle, rect').forEach(el => {
        const tag = el.tagName;
        if (tag === 'path') el.setAttribute('stroke', '#ef4444');
        el.setAttribute('fill', el.getAttribute('fill') === 'none' ? 'none' : '#ef4444');
      });
      cogCenter.classList.remove('ai-cog-spin-cw');
      cogCenter.classList.add('ai-cog-broken');
      // Stop other cogs
      cogTop.classList.remove('ai-cog-spin-ccw');
      cogTop.classList.add('ai-cog-stopped');
      cogBottom.classList.remove('ai-cog-spin-cw-slow');
      cogBottom.classList.add('ai-cog-stopped');
      // Offline text
      statusText.textContent = 'offline';
      statusText.className = 'text-[10px] font-bold uppercase tracking-wide text-red-400';
      statusBot.title = 'AI offline: ' + reason;
    }

    checkAIHealth();
    // Re-check every 30 seconds
    setInterval(checkAIHealth, 30000);
  })();
  </script>

  <!-- MWB Modal Logic -->
  <script is:inline>
  (function() {
    var modal = document.getElementById('mwb-modal');
    var openBtn = document.getElementById('mwb-modal-open');
    var closeBtn = document.getElementById('mwb-modal-close');
    var backdrop = document.getElementById('mwb-modal-backdrop');

    // State
    var mwbState = { words: [], current: 0, flipped: false, active: false, activeCategory: 'all' };
    var mwbAutoTimer = null;
    var mwbAutoPhase = 'word';

    var catColors = {
      'wotd': { border: 'border-purple-500/50', bg: 'bg-purple-900/20', text: 'text-purple-300' },
      'quiz': { border: 'border-blue-500/50', bg: 'bg-blue-900/20', text: 'text-blue-300' },
      'manual': { border: 'border-amber-500/50', bg: 'bg-amber-900/20', text: 'text-amber-300' },
      'solver': { border: 'border-green-500/50', bg: 'bg-green-900/20', text: 'text-green-300' },
      'default': { border: 'border-gray-500/50', bg: 'bg-gray-900/20', text: 'text-gray-300' }
    };
    function getCatStyle(cat) { return catColors[cat] || catColors['default']; }

    var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
    function wordScore(w) { return (w||'').split('').reduce(function(s,c){return s+(scores[c.toUpperCase()]||0);},0); }

    function shuffleArray(arr) {
      var c = arr.slice();
      for (var i = c.length-1; i>0; i--) { var j = Math.floor(Math.random()*(i+1)); var t=c[i]; c[i]=c[j]; c[j]=t; }
      return c;
    }

    function hasMeaningfulDef(w) {
      if (!w.meaning || !w.meaning.trim()) return false;
      var m = w.meaning.toLowerCase();
      if (m === 'no meaning saved') return false;
      if (m.indexOf('scrabble-legal word') !== -1) return false;
      if (m.indexOf('no standard definition') !== -1) return false;
      return true;
    }

    // Open modal
    openBtn.addEventListener('click', function() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      refreshModalCats();
    });

    // Close modal
    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      stopMwbAuto();
    }
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    // Category filters
    function refreshModalCats() {
      var saved = JSON.parse((window.__swfStore && window.__swfStore.getRaw('scbAchievements')) || localStorage.getItem('scbAchievements') || '[]');
      var filterReal = document.getElementById('mwb-m-meaningful').checked;
      var pool = filterReal ? saved.filter(hasMeaningfulDef) : saved;
      var cats = {};
      pool.forEach(function(w) { var c = w.category || 'manual'; if(!cats[c]) cats[c]=0; cats[c]++; });

      var filtersEl = document.getElementById('mwb-m-cats');
      if (pool.length === 0) { filtersEl.innerHTML = ''; return; }

      var activeCat = mwbState.activeCategory || 'all';
      var html = '<button class="mwb-m-cat px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
        (activeCat==='all' ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
        '" data-cat="all">All ('+pool.length+')</button>';
      Object.keys(cats).sort().forEach(function(c) {
        html += '<button class="mwb-m-cat px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
          (activeCat===c ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
          '" data-cat="'+c+'">'+c+' ('+cats[c]+')</button>';
      });
      filtersEl.innerHTML = html;
      filtersEl.querySelectorAll('.mwb-m-cat').forEach(function(btn) {
        btn.addEventListener('click', function() {
          mwbState.activeCategory = btn.dataset.cat;
          startMwbCards();
        });
      });
    }

    // Start flash cards
    function startMwbCards() {
      var saved = JSON.parse((window.__swfStore && window.__swfStore.getRaw('scbAchievements')) || localStorage.getItem('scbAchievements') || '[]');
      var filterReal = document.getElementById('mwb-m-meaningful').checked;
      var pool = filterReal ? saved.filter(hasMeaningfulDef) : saved;

      // Apply category filter
      var cat = mwbState.activeCategory || 'all';
      if (cat !== 'all') pool = pool.filter(function(w) { return (w.category||'manual') === cat; });

      if (pool.length === 0) {
        document.getElementById('mwb-m-empty').textContent = 'No words saved yet. Use the solver or Word of the Day to build your collection!';
        document.getElementById('mwb-m-empty').classList.remove('hidden');
        document.getElementById('mwb-m-card').classList.add('hidden');
        document.getElementById('mwb-m-controls').classList.add('hidden');
        document.getElementById('mwb-m-actions').classList.add('hidden');
        return;
      }

      mwbState.words = shuffleArray(pool);
      mwbState.current = 0;
      mwbState.active = true;
      mwbState.flipped = false;

      document.getElementById('mwb-m-empty').classList.add('hidden');
      document.getElementById('mwb-m-card').classList.remove('hidden');
      document.getElementById('mwb-m-controls').classList.remove('hidden');
      document.getElementById('mwb-m-actions').classList.remove('hidden');
      document.getElementById('mwb-m-start').textContent = '🔀 Shuffle';
      document.getElementById('mwb-m-speed-wrap').classList.remove('hidden');

      refreshModalCats();
      renderMwbCard();
    }

    // Render current card
    function renderMwbCard() {
      if (!mwbState.words.length) return;
      var w = mwbState.words[mwbState.current];
      var style = getCatStyle(w.category || 'manual');
      var pts = wordScore(w.word);

      mwbState.flipped = false;
      document.getElementById('mwb-m-word').textContent = w.word || '?';
      document.getElementById('mwb-m-word').className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
      document.getElementById('mwb-m-score').textContent = pts + ' pts';
      document.getElementById('mwb-m-score').classList.remove('hidden');
      document.getElementById('mwb-m-meaning').textContent = w.meaning || 'No meaning saved';
      document.getElementById('mwb-m-meaning').classList.add('hidden');
      document.getElementById('mwb-m-hint').textContent = 'tap to flip';
      document.getElementById('mwb-m-hint').classList.remove('hidden');
      document.getElementById('mwb-m-counter').textContent = (mwbState.current+1) + ' / ' + mwbState.words.length;

      var card = document.getElementById('mwb-m-card');
      card.className = 'mx-auto w-full max-w-sm h-44 rounded-2xl border-2 flex flex-col items-center justify-center cursor-pointer transition-all select-none ' + style.border + ' ' + style.bg + ' hover:scale-[1.02]';

      // Animate entry
      card.style.opacity = '0';
      card.style.transform = 'rotateY(90deg)';
      requestAnimationFrame(function() {
        card.style.transition = 'opacity 0.3s, transform 0.3s';
        card.style.opacity = '1';
        card.style.transform = 'rotateY(0deg)';
      });
    }

    // Flip card
    function flipMwbCard() {
      if (!mwbState.active) return;
      mwbState.flipped = !mwbState.flipped;
      var card = document.getElementById('mwb-m-card');
      var wordEl = document.getElementById('mwb-m-word');
      var meaningEl = document.getElementById('mwb-m-meaning');
      var hintEl = document.getElementById('mwb-m-hint');

      card.style.transition = 'transform 0.2s';
      card.style.transform = 'rotateY(90deg)';
      setTimeout(function() {
        if (mwbState.flipped) {
          meaningEl.classList.remove('hidden');
          hintEl.textContent = 'tap to see word';
          wordEl.style.fontSize = '1.2rem';
          wordEl.className = 'font-black tracking-wider mb-2 text-gray-500';
        } else {
          meaningEl.classList.add('hidden');
          hintEl.textContent = 'tap to flip';
          wordEl.style.fontSize = '';
          var style = getCatStyle((mwbState.words[mwbState.current]||{}).category||'manual');
          wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
        }
        card.style.transform = 'rotateY(0deg)';
      }, 200);
    }

    // Event listeners
    document.getElementById('mwb-m-card').addEventListener('click', flipMwbCard);

    document.getElementById('mwb-m-start').addEventListener('click', startMwbCards);

    document.getElementById('mwb-m-meaningful').addEventListener('change', function() {
      refreshModalCats();
      if (mwbState.active) startMwbCards();
    });

    document.getElementById('mwb-m-prev').addEventListener('click', function() {
      if (!mwbState.active || !mwbState.words.length) return;
      stopMwbAuto();
      mwbState.current = (mwbState.current - 1 + mwbState.words.length) % mwbState.words.length;
      renderMwbCard();
    });

    document.getElementById('mwb-m-next').addEventListener('click', function() {
      if (!mwbState.active || !mwbState.words.length) return;
      stopMwbAuto();
      mwbState.current = (mwbState.current + 1) % mwbState.words.length;
      renderMwbCard();
    });

    // Copy
    document.getElementById('mwb-m-copy').addEventListener('click', function() {
      if (!mwbState.active || !mwbState.words[mwbState.current]) return;
      var self = this;
      navigator.clipboard.writeText(mwbState.words[mwbState.current].word).catch(function(){});
      self.textContent = '✓ Copied';
      setTimeout(function() { self.textContent = '📋 Copy'; }, 1500);
    });

    // Delete
    document.getElementById('mwb-m-delete').addEventListener('click', function() {
      if (!mwbState.active || !mwbState.words[mwbState.current]) return;
      var wordToDelete = mwbState.words[mwbState.current].word;
      var store = window.__swfStore ? window.__swfStore : null;
      var saved = JSON.parse((store && store.getRaw('scbAchievements')) || localStorage.getItem('scbAchievements') || '[]');
      saved = saved.filter(function(a) { return a.word !== wordToDelete; });
      if (store) store.setRaw('scbAchievements', JSON.stringify(saved));
      else localStorage.setItem('scbAchievements', JSON.stringify(saved));

      mwbState.words.splice(mwbState.current, 1);
      if (mwbState.words.length === 0) {
        document.getElementById('mwb-m-card').classList.add('hidden');
        document.getElementById('mwb-m-controls').classList.add('hidden');
        document.getElementById('mwb-m-actions').classList.add('hidden');
        document.getElementById('mwb-m-empty').textContent = 'All words deleted from this set.';
        document.getElementById('mwb-m-empty').classList.remove('hidden');
        mwbState.active = false;
      } else {
        if (mwbState.current >= mwbState.words.length) mwbState.current = 0;
        renderMwbCard();
      }
      refreshModalCats();
    });

    // Auto-play
    function getMwbSpeed() { return parseInt(document.getElementById('mwb-m-speed').value)*1000 || 5000; }

    function startMwbAuto() {
      if (!mwbState.active) startMwbCards();
      if (!mwbState.active) return;
      mwbAutoPhase = 'word';
      scheduleMwbNext();
    }

    function scheduleMwbNext() {
      clearTimeout(mwbAutoTimer);
      mwbAutoTimer = setTimeout(function() {
        if (modal.classList.contains('hidden')) return;
        if (mwbAutoPhase === 'word') {
          if (!mwbState.flipped) flipMwbCard();
          mwbAutoPhase = 'meaning';
          scheduleMwbNext();
        } else {
          mwbState.current = (mwbState.current + 1) % mwbState.words.length;
          renderMwbCard();
          mwbAutoPhase = 'word';
          scheduleMwbNext();
        }
      }, getMwbSpeed());
    }

    function stopMwbAuto() {
      clearTimeout(mwbAutoTimer);
      mwbAutoTimer = null;
      var btn = document.getElementById('mwb-m-autoplay');
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
      btn.dataset.playing = '';
    }

    document.getElementById('mwb-m-autoplay').addEventListener('click', function() {
      var btn = this;
      if (btn.dataset.playing === '1') {
        stopMwbAuto();
      } else {
        btn.dataset.playing = '1';
        btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
        startMwbAuto();
      }
    });

    document.getElementById('mwb-m-speed').addEventListener('input', function() {
      document.getElementById('mwb-m-speed-label').textContent = this.value + 's';
      if (mwbAutoTimer) { clearTimeout(mwbAutoTimer); scheduleMwbNext(); }
    });

    // Keyboard nav within modal
    document.addEventListener('keydown', function(e) {
      if (modal.classList.contains('hidden') || !mwbState.active) return;
      if (e.key === 'ArrowLeft') { stopMwbAuto(); document.getElementById('mwb-m-prev').click(); }
      else if (e.key === 'ArrowRight') { stopMwbAuto(); document.getElementById('mwb-m-next').click(); }
      else if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipMwbCard(); }
    });
  })();
  </script>

  <style is:inline>
    /* Cog spinning animations */
    .ai-cog-spin-cw {
      animation: cogSpinCW 4s linear infinite;
    }
    .ai-cog-spin-ccw {
      animation: cogSpinCCW 3s linear infinite;
    }
    .ai-cog-spin-cw-slow {
      animation: cogSpinCWSlow 5s linear infinite;
    }
    /* Broken cog — stuttering shake */
    .ai-cog-broken {
      animation: cogBroken 1s ease-in-out infinite;
    }
    /* Stopped cog — no animation, slight opacity */
    .ai-cog-stopped {
      opacity: 0.5;
    }

    @keyframes cogSpinCW {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes cogSpinCCW {
      from { transform: rotate(0deg); }
      to { transform: rotate(-360deg); }
    }
    @keyframes cogSpinCWSlow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes cogBroken {
      0%, 100% { transform: rotate(0deg); }
      20% { transform: rotate(8deg); }
      40% { transform: rotate(-5deg); }
      60% { transform: rotate(3deg); }
      80% { transform: rotate(-2deg); }
    }

    /* SVG cog groups need transform-origin set for rotation */
    #cog-center { transform-origin: 38px 42px; }
    #cog-top { transform-origin: 60px 20px; }
    #cog-bottom { transform-origin: 18px 64px; }
  </style>
</Layout>
