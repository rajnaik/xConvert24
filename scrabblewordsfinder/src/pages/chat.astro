  <script is:inline src="/js/coaching-renderers.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script is:inline src="/js/coaching-pdf.js?v=2"></script>
  <script is:inline>
  (function() {
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('send-btn');
    const messagesEl = document.getElementById('messages');
    const chatUsageCount = document.getElementById('chat-usage-count');
    const rackInput = document.getElementById('rack-input');
    const askLexBtn = document.getElementById('ask-lex-btn');

    // --- Dojo Mode Toggle & Training Buttons ---
    const dojoToggle = document.getElementById('dojo-toggle');
    const dojoButtons = document.getElementById('dojo-buttons');
    const dojoStatus = document.getElementById('dojo-status');

    if (dojoToggle) {
      dojoToggle.addEventListener('change', function() {
        const isOn = this.checked;
        dojoButtons.classList.toggle('hidden', !isOn);
        dojoStatus.textContent = isOn ? 'On' : 'Off';
        dojoStatus.classList.toggle('text-orange-400', isOn);
        dojoStatus.classList.toggle('text-gray-500', !isOn);
      });
    }

    // Dojo button click → send training prompt to Lex
    document.querySelectorAll('.dojo-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const mode = this.getAttribute('data-dojo');
        const dojoNextInstruction = ' After I complete this exercise, randomly pick a different drill type for the next round (choose from: Bingo Trainer, Hook Quiz, Tile Countdown, Rack Leave Drill). Do NOT follow a preset order — always pick the next exercise at random.';
        const prompts = {
          bingo: 'Start a Bingo Trainer drill. Generate a random 7-tile rack from a bingo-friendly stem (like SATIRE, RETINA, LADIES, ALERTS). Show me the rack and I will try to guess all valid 7-letter bingos. Confirm each guess against SOWPODS, then reveal all bingos I missed and explain the stem.' + dojoNextInstruction,
          hook: 'Start a Hook Quiz. Pick a random 3-5 letter word from the SOWPODS dictionary and tell me the word. I will guess all valid front hooks and back hooks (single-letter additions that form new valid words). Score my attempt and show any hooks I missed.' + dojoNextInstruction,
          countdown: 'Start a Tile Countdown drill. Present a sequence of 5-8 words that have been "played" in a game. Then ask me how many of a specific tile (like E, S, or blanks) remain in the bag. I will answer, then you reveal the actual count based on the standard Scrabble tile distribution minus the played tiles.' + dojoNextInstruction,
          leave: 'Start a Rack Leave Drill. Generate a 7-tile rack and present 3 possible plays (word + score). Ask me which play I would choose and why. Then evaluate each resulting rack leave for vowel/consonant balance, bingo potential, power tiles kept, and synergy. Explain which is the best play and why.' + dojoNextInstruction
        };
        const prompt = prompts[mode];
        if (prompt && input) {
          input.value = prompt;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          form.dispatchEvent(new Event('submit', { bubbles: true }));
        }
      });
    });

    // Fetch and display chat usage counter
    async function refreshChatUsage() {
      try {
        const res = await fetch('/api/site-status/');
        if (res.ok) {
          const data = await res.json();
          if (data.chatusage !== undefined) {
            chatUsageCount.textContent = Number(data.chatusage).toLocaleString();
          }
        }
      } catch {}
    }
    refreshChatUsage();

    // Log chat interaction to DB (fire-and-forget)
    function logChatUsage(userMsg, botResp, responseMs, success, errorMsg, keyword) {
      const uid = localStorage.getItem('swf-uid') || '';
      const sid = sessionStorage.getItem('swf-session') || '';
      fetch('/api/chatusage/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          user_id: uid,
          user_message: userMsg,
          bot_response: botResp,
          response_ms: responseMs,
          session_id: sid,
          success: success ? 1 : 0,
          error_message: errorMsg,
          keyword: keyword || '',
        }),
      }).catch(() => {});
    }

    // Conversation history (kept in memory for session)
    let conversationHistory = [];
    let isStreaming = false;

    // Auto-resize textarea
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 128) + 'px';
    });

    // Rack input — force uppercase, letters only + persist to localStorage
    const RACK_KEY = 'swf-chat-rack';
    const savedRack = localStorage.getItem(RACK_KEY) || '';
    if (savedRack) rackInput.value = savedRack;

    // --- EV Scoring Engine (inline) ---
    const EV_BINGO_STEMS = ['SATIRE','RETINA','NASTIER','TISANE','ARSINE','SENIOR','LINERS','SALINE','TENORS','STONER','ORNATE','ATONES','SERIAL','RAILES','SALTIE','STERNA','ANTRES','ESTRIN','INSERT','INERTS','LEARNT','RENTAL','LASTER','ALERTS','ALTERS','STEARIN','ANESTRI','RATINES','RETINAS','ANTSIER','STAINER','RETSINA'];
    const EV_SYNERGY = [{l:'ING',b:8},{l:'TION',b:7},{l:'ED',b:4},{l:'ER',b:4},{l:'EST',b:5},{l:'RE',b:3},{l:'UN',b:3},{l:'LY',b:3},{l:'NESS',b:5},{l:'ABLE',b:6},{l:'MENT',b:5},{l:'ATE',b:4},{l:'STER',b:5},{l:'IEST',b:5}];
    const EV_VOWELS = new Set(['A','E','I','O','U']);
    const EV_HIGH = new Set(['J','Q','X','Z']);

    function evCountLetters(r) { const m = new Map(); for (const c of r) m.set(c, (m.get(c)||0)+1); return m; }
    function evContains(counts, pat) { const n = new Map(); for (const c of pat) n.set(c,(n.get(c)||0)+1); for (const [c,q] of n) if ((counts.get(c)||0)<q) return false; return true; }
    function evStemOverlap(counts, stem) { const u = new Map(); let o=0; for (const c of stem) { const uc=u.get(c)||0; if (uc<(counts.get(c)||0)){o++;u.set(c,uc+1);}} return o; }

    function computeEVScore(rack) {
      const cleaned = rack.toUpperCase().replace(/[^A-Z?]/g,'');
      if (!cleaned.length) return null;
      const counts = evCountLetters(cleaned);
      // Vowel balance (0-25)
      let vc=0; for (const c of cleaned) { if (c!=='?' && EV_VOWELS.has(c)) vc++; }
      let vBal = vc>=2&&vc<=3?25:vc===4?18:vc===1?14:vc===5?8:2;
      // Power tiles (0-20)
      let pwr=0; pwr+=Math.min(counts.get('S')||0,2)*8; pwr+=Math.min(counts.get('?')||0,2)*10;
      for (const t of EV_HIGH) if (counts.has(t)) pwr+=4;
      pwr=Math.min(pwr,20);
      // Bingo stems (0-25)
      let best=0; for (const s of EV_BINGO_STEMS) { const r=evStemOverlap(counts,s)/Math.min(s.length,cleaned.length); if (r>best) best=r; }
      const bingo=Math.round(best*25);
      // Duplicate penalty (0-15)
      let dup=0; for (const [,q] of counts) { if(q===2)dup+=3;else if(q===3)dup+=7;else if(q>=4)dup+=12; }
      dup=Math.min(dup,15);
      // Synergy (0-15)
      let syn=0; for (const {l,b} of EV_SYNERGY) if (evContains(counts,l)) syn+=b;
      syn=Math.min(syn,15);
      const raw=vBal+pwr+bingo+syn-dup;
      const score=Math.max(0,Math.min(100,raw));
      let label; if(score>=80)label='Excellent';else if(score>=65)label='Strong';else if(score>=45)label='Decent';else if(score>=25)label='Weak';else label='Poor';
      return {score,label};
    }

    // EV Score UI elements
    const evBadge = document.getElementById('ev-score-badge');
    const evFill = document.getElementById('ev-score-fill');
    const evValue = document.getElementById('ev-score-value');
    const evLabel = document.getElementById('ev-score-label');

    function updateEVDisplay(rack) {
      const result = computeEVScore(rack);
      if (!result || rack.replace(/[^A-Za-z?]/g,'').length === 0) {
        evBadge.classList.add('hidden');
        return;
      }
      evBadge.classList.remove('hidden');
      evFill.style.width = result.score + '%';
      // Color based on label
      const colors = {Excellent:'bg-emerald-400',Strong:'bg-green-400',Decent:'bg-amber-400',Weak:'bg-orange-400',Poor:'bg-red-400'};
      const textColors = {Excellent:'text-emerald-400',Strong:'text-green-400',Decent:'text-amber-400',Weak:'text-orange-400',Poor:'text-red-400'};
      evFill.className = 'block h-full rounded-full transition-all duration-300 ' + (colors[result.label]||'bg-gray-400');
      evValue.textContent = result.score + '/100';
      evValue.className = 'text-xs font-bold font-mono ' + (textColors[result.label]||'text-gray-400');
      evLabel.textContent = result.label;
      evLabel.className = 'text-[10px] uppercase tracking-wider font-semibold ' + (textColors[result.label]||'text-gray-400');
    }

    rackInput.addEventListener('input', () => {
      rackInput.value = rackInput.value.replace(/[^A-Za-z]/g, '').toUpperCase().slice(0, 7);
      localStorage.setItem(RACK_KEY, rackInput.value);
      updateEVDisplay(rackInput.value);
    });

    // Show EV score on page load if rack was persisted
    if (savedRack) updateEVDisplay(savedRack);

    // Ask Lex button handler
    let pendingKeyword = ''; // Track the rack letters for chatusage keyword logging
    let pendingCabCoach = false; // Flag: append structured CaB graph/timing after AI response
    let pendingQuizCoach = false; // Flag: append structured Quiz graph/timing after AI response
    let pendingRackCoach = false; // Flag: append structured Rack graph/timing after AI response
    let pendingAnagramCoach = false; // Flag: append structured Anagram graph/timing after AI response
    askLexBtn.addEventListener('click', () => {
      const rack = rackInput.value.trim().toUpperCase();
      if (!rack || rack.length === 0 || isStreaming) return;
      pendingKeyword = rack; // Store for logging
      const askMsg = `I have these tiles on my rack: ${rack}. What is the best word I can play and why? Include the Scrabble score.`;
      input.value = askMsg;
      form.dispatchEvent(new Event('submit'));
    });

    // Enter to send (Shift+Enter for newline)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (!isStreaming && input.value.trim()) {
          form.dispatchEvent(new Event('submit'));
        }
      }
    });

    // Quick prompts — dynamically populated from top chat keywords
    const quickPromptsContainer = document.getElementById('quick-prompts');

    function bindQuickPrompts() {
      quickPromptsContainer.querySelectorAll('.quick-prompt').forEach(btn => {
        btn.addEventListener('click', () => {
          if (isStreaming) return;
          input.value = btn.textContent;
          form.dispatchEvent(new Event('submit'));
        });
      });
    }

    // Initial bind for SSR defaults
    bindQuickPrompts();

    // Static keyword shortcuts — submit text to chat on click
    // Uses data-prompt for explicit Scrabble context (avoids AI misinterpreting short labels as off-topic)
    // Stores the display label so the chat bubble shows the short text while the AI gets the full prompt
    let pendingDisplayLabel = '';
    document.querySelectorAll('.static-kw').forEach(btn => {
      btn.addEventListener('click', () => {
        if (isStreaming) return;
        pendingDisplayLabel = btn.textContent.trim();
        input.value = btn.getAttribute('data-prompt') || btn.textContent.trim();
        form.dispatchEvent(new Event('submit'));
      });
    });

    // Fetch top suggestions from chatusage and replace defaults
    (async function loadSuggestions() {
      try {
        const res = await fetch('/api/chatusage/?suggestions=true');
        if (!res.ok) return;
        const data = await res.json();
        if (data.suggestions && data.suggestions.length >= 5) {
          const btnClass = 'quick-prompt px-3 py-1.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-500/50 transition-colors';
          quickPromptsContainer.innerHTML = data.suggestions
            .slice(0, 10)
            .map(s => `<button class="${btnClass}">${s.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</button>`)
            .join('');
          bindQuickPrompts();
        }
      } catch {}
    })();

    // Keyword History — shows the user's own past questions (per-user)
    let refreshKeywordHistory = () => {}; // Exposed for instant refresh after submit
    (function initKeywordHistory() {
      const uid = localStorage.getItem('swf-uid') || '';
      if (!uid) return; // No user ID — nothing to show

      const container = document.getElementById('keyword-history');
      const listEl = document.getElementById('kh-list');
      const prevBtn = document.getElementById('kh-prev');
      const nextBtn = document.getElementById('kh-next');
      const pageInfo = document.getElementById('kh-page-info');

      let currentPage = 0;
      let totalPages = 0;

      // Expose refresh so it can be called after a new message is sent
      refreshKeywordHistory = () => loadHistory(currentPage);

      async function loadHistory(page) {
        try {
          const res = await fetch(`/api/chatusage/?suggestions=true&user_id=${encodeURIComponent(uid)}&page=${page}`);
          if (!res.ok) return;
          const data = await res.json();

          if (data.total === 0) {
            container.classList.add('hidden');
            return;
          }

          container.classList.remove('hidden');
          currentPage = data.page;
          totalPages = data.totalPages;

          // Use items (with dates) if available, fallback to suggestions
          const items = data.items || data.suggestions.map(s => ({ message: s, last_asked: '' }));
          listEl.innerHTML = items
            .map(item => {
              const dateStr = item.last_asked ? formatDate(item.last_asked) : '';
              const escaped = item.message.replace(/</g,'&lt;').replace(/>/g,'&gt;');
              return `<button class="kh-item flex items-center justify-between gap-2 w-full px-2.5 py-1.5 text-xs rounded-lg bg-indigo-900/30 border border-indigo-700/50 text-indigo-300 hover:text-indigo-200 hover:border-indigo-500/60 hover:bg-indigo-800/40 cursor-pointer transition-colors text-left">
                <span class="truncate">${escaped}</span>
                ${dateStr ? `<span class="shrink-0 text-[10px] text-gray-500">${dateStr}</span>` : ''}
              </button>`;
            })
            .join('');

          // Bind click-to-ask on history items
          listEl.querySelectorAll('.kh-item').forEach(btn => {
            btn.addEventListener('click', () => {
              if (isStreaming) return;
              input.value = btn.querySelector('span').textContent;
              form.dispatchEvent(new Event('submit'));
            });
          });

          // Update pagination
          pageInfo.textContent = `${currentPage + 1} / ${totalPages}`;
          prevBtn.disabled = currentPage === 0;
          nextBtn.disabled = currentPage >= totalPages - 1;
        } catch {
          container.classList.add('hidden');
        }
      }

      function formatDate(isoStr) {
        try {
          const d = new Date(isoStr);
          const day = d.getDate();
          const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
          return `${day} ${months[d.getMonth()]}`;
        } catch { return ''; }
      }

      prevBtn.addEventListener('click', () => {
        if (currentPage > 0) loadHistory(currentPage - 1);
      });
      nextBtn.addEventListener('click', () => {
        if (currentPage < totalPages - 1) loadHistory(currentPage + 1);
      });

      loadHistory(0);
    })();

    // Identified Words panel — extract 6+ letter ALL-CAPS words from AI responses
    // Only adds words that are valid in the SOWPODS Scrabble dictionary
    // Persisted in localStorage so they appear instantly on page load
    const identifiedWordsPanel = document.getElementById('identified-words-panel');
    const identifiedWordsList = document.getElementById('identified-words-list');
    const clearIdentifiedBtn = document.getElementById('clear-identified-words');
    const IDENTIFIED_WORDS_KEY = 'swf-chat-identified-words';
    const identifiedWords = new Set(JSON.parse(localStorage.getItem(IDENTIFIED_WORDS_KEY) || '[]'));

    // Track which words have been imported to MWB (persisted until new words arrive)
    var importedToMwb = new Set();

    // Lazy-loaded dictionary for word validation (only 6+ letter words kept)
    var validWordsDict = null;
    var dictLoadingPromise = null;
    // Expose for testing
    window.validWordsDict = null;

    function loadValidWordsDict() {
      if (validWordsDict) return Promise.resolve(validWordsDict);
      if (dictLoadingPromise) return dictLoadingPromise;
      dictLoadingPromise = Promise.all([
        fetch('/data/sowpods-2-7.json').then(r => r.json()),
        fetch('/data/sowpods-8-15.json').then(r => r.json())
      ]).then(function(results) {
        validWordsDict = new Set();
        // From 2-7 file, keep only 6+ letter words
        results[0].forEach(function(w) { if (w.length >= 6) validWordsDict.add(w.toUpperCase()); });
        // All words from 8-15 file are 8+ letters (all valid)
        results[1].forEach(function(w) { validWordsDict.add(w.toUpperCase()); });
        window.validWordsDict = validWordsDict;
        return validWordsDict;
      }).catch(function() {
        // If dictionary load fails, allow all words (graceful degradation)
        validWordsDict = null;
        dictLoadingPromise = null;
        return null;
      });
      return dictLoadingPromise;
    }

    // Show instantly on load if words exist from previous session
    renderIdentifiedWords();

    // Preload dictionary so it's ready before first AI response
    loadValidWordsDict();

    async function extractIdentifiedWords(text) {
      // Ensure dictionary is loaded before validating
      var dict = await loadValidWordsDict();

      let added = false;
      var candidates = [];

      // 1. Match standalone ALL-CAPS words that are 6+ letters long
      const capsMatches = text.match(/\b[A-Z]{6,}\b/g);
      if (capsMatches) {
        capsMatches.forEach(function(word) { candidates.push(word); });
      }

      // 2. Match words in numbered list patterns with point values
      //    e.g. "1. Laughed (17 points)" or "2) STAMPED (14 points)"
      const pointsPattern = /^\d+[\.\)]\s*\**([A-Za-z]{6,})\**\s*\(\d+\s*points?\)/gm;
      let m;
      while ((m = pointsPattern.exec(text)) !== null) {
        candidates.push(m[1].toUpperCase());
      }

      // 3. Match bold words with points: "**LAUGHED** (17 points)" or "**Laughed** (17 points)"
      const boldPointsPattern = /\*\*([A-Za-z]{6,})\*\*\s*\(\d+\s*points?\)/g;
      while ((m = boldPointsPattern.exec(text)) !== null) {
        candidates.push(m[1].toUpperCase());
      }

      // Filter: only add words that are valid in the Scrabble dictionary
      candidates.forEach(function(word) {
        if (identifiedWords.has(word)) return;
        // If dictionary loaded, validate; if load failed, allow all (graceful degradation)
        if (dict && !dict.has(word)) return;
        identifiedWords.add(word);
        added = true;
      });

      if (added) {
        // Reset imported state — new words arrived, show + icons for all
        importedToMwb.clear();
        renderIdentifiedWords();
      }
    }

    function renderIdentifiedWords() {
      if (identifiedWords.size === 0) {
        identifiedWordsPanel.classList.add('hidden');
        localStorage.removeItem(IDENTIFIED_WORDS_KEY);
        importedToMwb.clear();
        return;
      }
      identifiedWordsPanel.classList.remove('hidden');
      const wordsArr = Array.from(identifiedWords);
      identifiedWordsList.innerHTML = wordsArr
        .map(w => {
          var isImported = importedToMwb.has(w);
          var iconSvg = isImported
            ? '<svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
            : '<svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"/></svg>';
          var iconClass = isImported
            ? 'bg-green-900/40 border-green-500/50'
            : 'bg-emerald-900/60 border-emerald-600/50 hover:bg-emerald-800/60 hover:border-emerald-400 cursor-pointer';
          return `<span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono font-semibold rounded bg-emerald-900/40 border border-emerald-700/50 text-emerald-300">
            ${w}
            <span class="word-mwb-icon inline-flex items-center justify-center w-4 h-4 rounded-full ${iconClass} transition-colors" data-word="${w}" ${isImported ? 'title="Added to WordBench"' : 'title="Add to Memory WordBench"'}>${iconSvg}</span>
          </span>`;
        })
        .join('');
      localStorage.setItem(IDENTIFIED_WORDS_KEY, JSON.stringify(wordsArr));
    }

    clearIdentifiedBtn.addEventListener('click', () => {
      identifiedWords.clear();
      importedToMwb.clear();
      renderIdentifiedWords();
    });

    // Individual word + icon click — import single word to MWB
    identifiedWordsList.addEventListener('click', async function(e) {
      var icon = e.target.closest('.word-mwb-icon');
      if (!icon) return;
      var word = icon.getAttribute('data-word');
      if (!word || importedToMwb.has(word)) return;

      // Spin while importing
      icon.innerHTML = '<svg class="w-3 h-3 animate-spin" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="8"/></svg>';

      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      var alreadyExists = saved.some(function(a) { return a.word === word; });

      if (!alreadyExists) {
        var meaning = '';
        try {
          var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word.toLowerCase());
          if (res.ok) {
            var data = await res.json();
            var m = data[0]?.meanings?.[0];
            var def = m?.definitions?.[0]?.definition || '';
            var pos = m?.partOfSpeech || '';
            meaning = pos ? '(' + pos + ') ' + def : def;
          }
        } catch(e) {}
        if (!meaning) meaning = 'Scrabble-legal word (no standard definition available)';
        saved.push({ word: word, meaning: meaning, category: 'Lex AI', dateAdded: new Date().toISOString() });
        localStorage.setItem('scbAchievements', JSON.stringify(saved));

        // Sync to server
        var uid = localStorage.getItem('swf-uid') || '';
        if (uid) {
          fetch('/api/scrabble-sync/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ uid: uid, achievements: saved, dictionary: 'sowpods' }) }).catch(function(){});
