    function validateWordClaims(textEl, response) {
      var invalidPatterns = [
        /["']?([A-Z]{2,15})["']?\s+is\s+not\s+(a\s+)?valid/gi,
        /["']?([A-Z]{2,15})["']?\s+is\s+not\s+(recognized|recognised|accepted|found|in the)/gi,
        /["']?([A-Z]{2,15})["']?\s+is\s+not\s+in\s+(the\s+)?(SOWPODS|TWL|dictionary|scrabble)/gi,
        /["']?([A-Z]{2,15})["']?\s+isn't\s+(a\s+)?valid/gi,
      ];

      var claimedInvalid = [];
      for (var p = 0; p < invalidPatterns.length; p++) {
        var pat = invalidPatterns[p];
        var match;
        while ((match = pat.exec(response)) !== null) {
          var word = match[1].toUpperCase();
          if (claimedInvalid.indexOf(word) === -1) claimedInvalid.push(word);
        }
      }

      if (claimedInvalid.length === 0) return;

      loadValidWords().then(function(dict) {
        if (!dict) return;
        var falselyInvalid = [];
        for (var i = 0; i < claimedInvalid.length; i++) {
          if (dict[claimedInvalid[i]]) falselyInvalid.push(claimedInvalid[i]);
        }
        if (falselyInvalid.length > 0) {
          var correction = document.createElement('div');
          correction.className = 'mt-2 px-3 py-2 rounded-lg bg-amber-900/30 border border-amber-600/40 text-xs text-amber-300';
          correction.innerHTML = '⚠️ <strong>Correction:</strong> ' + falselyInvalid.join(', ') + ' ' + (falselyInvalid.length === 1 ? 'IS' : 'ARE') + ' valid in SOWPODS. Lex made an error — use the solver above to verify any word.';
          textEl.appendChild(correction);
        }
      });
    }

    // FVT-style rich rendering of AI responses
    function formatAnswer(text) {
      var escaped = escapeHtml(text);

      // Split into paragraphs on double newlines
      var blocks = escaped.split(/\n\n+/);
      var htmlParts = [];

      blocks.forEach(function(block) {
        block = block.trim();
        if (!block) return;

        // Detect numbered list block (lines starting with 1. 2. 3. etc.)
        var allLines = block.split('\n');
        var numberedLines = allLines.filter(function(l) { return /^\d+[\.\)]\s/.test(l.trim()); });
        if (numberedLines.length >= 2) {
          // Extract dynamic category from non-numbered intro lines in this block
          var introLines = allLines.filter(function(l) { return l.trim() && !/^\d+[\.\)]\s/.test(l.trim()); });
          var categoryLabel = introLines.length > 0 ? introLines[0].replace(/[:：]+$/, '').trim() : '';
          // If no intro line in this block, use previous paragraph block as category
          if (!categoryLabel && htmlParts.length > 0) {
            var prevHtml = htmlParts[htmlParts.length - 1];
            var prevMatch = prevHtml.match(/>([^<]+)<\/p>$/);
            if (prevMatch) categoryLabel = prevMatch[1].replace(/[:：]+$/, '').trim();
          }
          if (!categoryLabel) categoryLabel = 'Steps';
          // Truncate long labels
          if (categoryLabel.length > 50) categoryLabel = categoryLabel.substring(0, 47) + '...';
          var stepsHtml = '<div class="my-3 p-4 rounded-xl border border-emerald-500/30 bg-emerald-950/10">';
          stepsHtml += '<p class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-3">' + categoryLabel + '</p>';
          stepsHtml += '<div class="space-y-2.5">';
          numberedLines.forEach(function(line, idx) {
            var content = line.replace(/^\d+[\.\)]\s*/, '');
            content = applyInlineFormatting(content);
            stepsHtml += '<div class="flex items-start gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-emerald-900/50 border border-emerald-500/40 flex items-center justify-center text-[10px] text-emerald-300 font-bold">' + (idx + 1) + '</span><p class="text-sm text-gray-300 leading-relaxed">' + content + '</p></div>';
          });
          stepsHtml += '</div></div>';
          htmlParts.push(stepsHtml);
          return;
        }

        // Detect bullet list block (lines starting with - or •)
        var bulletLines = block.split('\n').filter(function(l) { return /^[\-•]\s/.test(l.trim()); });
        if (bulletLines.length >= 2) {
          var listHtml = '<div class="my-3 space-y-2">';
          bulletLines.forEach(function(line) {
            var content = line.replace(/^[\-•]\s*/, '');
            content = applyInlineFormatting(content);
            listHtml += '<div class="flex items-start gap-2.5 p-2.5 rounded-lg border border-emerald-500/20 bg-emerald-950/10"><span class="text-emerald-400 mt-0.5 shrink-0 text-xs">▶</span><p class="text-sm text-gray-300 leading-relaxed">' + content + '</p></div>';
          });
          listHtml += '</div>';
          htmlParts.push(listHtml);
          return;
        }

        // Detect affirmation/correct-answer lines → render in green
        var affirmationPattern = /^(✅|✓|Correct!|That's right|Well done|Excellent|You got it|Great job|Nice one|Perfect|Spot on|Right!|Bravo|Nailed it|Good job|Great work)/i;
        var plainBlock = block.replace(/\n/g, ' ');
        if (affirmationPattern.test(plainBlock)) {
          var affHtml = applyInlineFormatting(plainBlock);
          htmlParts.push('<p class="text-sm text-green-400 font-semibold leading-relaxed mt-2">' + affHtml + '</p>');
          return;
        }

        // Regular paragraph — apply inline formatting
        var paraHtml = applyInlineFormatting(plainBlock);
        htmlParts.push('<p class="text-sm text-gray-200 leading-relaxed mt-2">' + paraHtml + '</p>');
      });

      return htmlParts.join('');
    }

    function applyInlineFormatting(text) {
      // Hyphenated letter words (A-D-D-S, S-A-D style): purple font + border
      text = text.replace(/\b([A-Z](?:-[A-Z]){1,})\b/g, '<span class="inline-block px-1.5 py-0.5 rounded border border-purple-500/50 text-purple-400 font-semibold text-xs tracking-wider">$1</span>');
      // Bold: **text** or __text__
      text = text.replace(/\*\*(.+?)\*\*/g, '<span class="text-white font-semibold">$1</span>');
      text = text.replace(/__(.+?)__/g, '<span class="text-white font-semibold">$1</span>');
      // Inline code: `text`
      text = text.replace(/`(.+?)`/g, '<code class="px-1.5 py-0.5 rounded bg-gray-700 text-emerald-300 text-xs font-mono">$1</code>');
      // Linkify markdown links [text](url) — MUST run before bare URL regex
      text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, function(_, linkText, url) {
        if (url.startsWith('/') && !url.endsWith('/') && !url.includes('.')) url += '/';
        return '<a href="' + url + '" class="text-blue-400 hover:text-blue-300 underline">' + linkText + '</a>';
      });
      // Linkify bare blog paths (only if not already inside an href attribute)
      text = text.replace(/(^|[\s(])(\/(blog|chat)\/[a-z0-9-]+\/?)(?=[\s),.]|$)/gi, function(match, prefix, url) {
        // Skip if this URL is already part of an <a> tag (inside href="...")
        var before = text.substring(0, text.indexOf(match));
        if (before.match(/href="[^"]*$/)) return match;
        if (!url.endsWith('/')) url += '/';
        return prefix + '<a href="' + url + '" class="text-blue-400 hover:text-blue-300 underline">' + url + '</a>';
      });
      return text;
    }

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const userMessage = input.value.trim();
      if (!userMessage || isStreaming) return;

      // Show the friendly label in chat bubble if available, otherwise show full message
      const displayMessage = pendingDisplayLabel || userMessage;
      pendingDisplayLabel = '';

      // Add user message to UI
      appendMessage('user', displayMessage);
      conversationHistory.push({ role: 'user', content: userMessage });

      // Clear input
      input.value = '';
      input.style.height = 'auto';

      // Disable input while streaming
      setStreaming(true);

      // Create bot message placeholder
      const botBubble = appendMessage('assistant', '');
      const textEl = botBubble.querySelector('.msg-text');
      const chatStartTime = Date.now();

      try {
        const res = await fetch('/api/chat/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: conversationHistory }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Request failed' }));
          textEl.textContent = `⚠️ ${err.error || 'Something went wrong. Please try again.'}`;
          setStreaming(false);
          return;
        }

        // Read SSE stream
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let fullResponse = '';
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const data = line.slice(6);
              if (data === '[DONE]') continue;
              try {
                const parsed = JSON.parse(data);
                const token = parsed.response || (parsed.choices && parsed.choices[0] && parsed.choices[0].delta && parsed.choices[0].delta.content) || '';
                fullResponse += token;
                // During streaming, show plain text (linkify at end)
                textEl.textContent = fullResponse;
                scrollToBottom();
              } catch {
                // Non-JSON line, skip
              }
            }
          }
        }

        // Process any remaining buffer
        if (buffer.startsWith('data: ') && buffer.slice(6) !== '[DONE]') {
          try {
            const parsed = JSON.parse(buffer.slice(6));
            fullResponse += parsed.response || (parsed.choices && parsed.choices[0] && parsed.choices[0].delta && parsed.choices[0].delta.content) || '';
          } catch {}
        }

        // Save to history and linkify the final response
        if (fullResponse) {
          conversationHistory.push({ role: 'assistant', content: fullResponse });
          // Render with FVT-style rich formatting (bold, steps, bullets, links)
          textEl.innerHTML = formatAnswer(fullResponse);
          // Client-side dictionary validation: catch false "not valid" claims
          validateWordClaims(textEl, fullResponse);
          // Append relevant blog links based on the conversation topic
          appendBlogLinks(textEl, userMessage, fullResponse);
          // Extract identified words (6+ letter words: ALL-CAPS, or in numbered list with points)
          extractIdentifiedWords(fullResponse);
          // Log chat usage (fire-and-forget)
          logChatUsage(userMessage, fullResponse, Date.now() - chatStartTime, true, '', pendingKeyword);

          // If this was a CaB coaching request, append structured graph + timing data
          if (pendingCabCoach) {
            pendingCabCoach = false;
            appendCabCoachData(textEl, fullResponse);
          }
          // If this was a Quiz coaching request, append structured graph + timing data
          if (pendingQuizCoach) {
            pendingQuizCoach = false;
            appendQuizCoachData(textEl, fullResponse);
          }
          // If this was a Rack coaching request, append structured graph + timing data
          if (pendingRackCoach) {
            pendingRackCoach = false;
            appendRackCoachData(textEl, fullResponse);
          }
          // If this was an Anagram coaching request, append structured graph + timing data
          if (pendingAnagramCoach) {
            pendingAnagramCoach = false;
            appendAnagramCoachData(textEl, fullResponse);
          }
        } else {
          textEl.textContent = '⚠️ No response received. Please try again.';
          logChatUsage(userMessage, '', Date.now() - chatStartTime, false, 'No response received', pendingKeyword);
        }
      } catch (err) {
        textEl.textContent = '⚠️ Network error. Please check your connection and try again.';
        logChatUsage(userMessage, '', Date.now() - chatStartTime, false, err.message || 'Network error', pendingKeyword);
      }

      pendingKeyword = ''; // Reset after logging
      setStreaming(false);
      scrollToBottom();
      refreshChatUsage();
      refreshKeywordHistory(); // Instant update of "Your Recent Questions"
    });

    // --- CaB Coach Structured Data (graph + timing + per-game cards) ---
    function appendCabCoachData(containerEl, analysisText) {
      var uid = localStorage.getItem('swf-uid') || '';
      if (!uid) return;

      fetch('/api/lex-cab-coach/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error || !data.hasHistory) return;

        var wrapper = document.createElement('div');
        wrapper.className = 'mt-4 space-y-4';

        // Stats bar
        if (data.stats) {
          var statsHtml = '<div class="grid grid-cols-4 gap-2">';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-white">' + data.stats.totalGames + '</p><p class="text-[10px] text-gray-500">Games</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-green-400">' + data.stats.solveRate + '%</p><p class="text-[10px] text-gray-500">Solve Rate</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-orange-400">' + data.stats.avgAttempts + '</p><p class="text-[10px] text-gray-500">Avg Guesses</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-purple-400">' + data.stats.quickSolves + '</p><p class="text-[10px] text-gray-500">Quick (\u22643)</p></div>';
          statsHtml += '</div>';
          wrapper.insertAdjacentHTML('beforeend', statsHtml);
        }

        // Graph (attempts per game)
        var games = data.gameAnalysis || [];
        if (games.length >= 2) {
          var graphSection = document.createElement('div');
          graphSection.className = 'mt-3';
          graphSection.innerHTML = '<p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold mb-2">Guesses per Game (lower = better)</p><canvas id="chat-cab-graph" class="w-full h-36 rounded-lg bg-gray-800/30 border border-gray-700/30"></canvas><div class="flex justify-between mt-1 text-[9px] text-gray-600"><span>\ud83d\udfe2 Solved</span><span>\ud83d\udd34 Failed</span><span>\u2b1c Average line</span></div>';
          wrapper.appendChild(graphSection);

          // Render graph after DOM insertion
          setTimeout(function() {
            renderCabChatGraph(games);
          }, 50);
        }

        // Time commentary
        var timed = games.filter(function(g) { return g.splitTime > 0; });
        if (timed.length >= 2) {
          var sorted = timed.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
          var times = sorted.map(function(g) { return g.splitTime; });
          var fastest = Math.min.apply(null, times);
          var slowest = Math.max.apply(null, times);
          var avg = Math.round(times.reduce(function(a, b) { return a + b; }, 0) / times.length);
          var fastestGame = sorted.find(function(g) { return g.splitTime === fastest; });
          var slowestGame = sorted.find(function(g) { return g.splitTime === slowest; });
          var recent = sorted[sorted.length - 1];
          var prev = sorted[sorted.length - 2];
          var diff = recent.splitTime - prev.splitTime;
          var trend = diff < -20 ? 'Getting faster \u2014 ' + Math.abs(diff) + 's quicker than previous.' :
                     diff > 20 ? 'Took ' + diff + 's longer \u2014 possibly a tougher word.' :
                     'Consistent pace between recent games.';

          var timeHtml = '<div class="px-3 py-2 rounded-lg bg-cyan-900/20 border border-cyan-700/30">';
          timeHtml += '<p class="text-[10px] text-cyan-400 font-semibold uppercase mb-1">\u23f1 Time Insight</p>';
          timeHtml += '<p class="text-[11px] text-gray-300 leading-relaxed">Fastest: ' + fastest + 's (Game #' + fastestGame.gameNumber + ') \u00b7 Slowest: ' + slowest + 's (Game #' + slowestGame.gameNumber + ') \u00b7 Avg: ' + avg + 's. ' + trend + '</p>';
          timeHtml += '</div>';
          wrapper.insertAdjacentHTML('beforeend', timeHtml);
        }

        // Per-game cards (top 10)
        if (games.length > 0) {
          var display = games.slice(0, 10);
          var ratingColors = {
            ace: { border: 'border-purple-500/40', bg: 'bg-purple-900/10', badge: 'bg-purple-600/30 text-purple-300', icon: '\ud83c\udfc6' },
            brilliant: { border: 'border-green-500/40', bg: 'bg-green-900/10', badge: 'bg-green-600/30 text-green-300', icon: '\u26a1' },
            great: { border: 'border-blue-500/40', bg: 'bg-blue-900/10', badge: 'bg-blue-600/30 text-blue-300', icon: '\u2705' },
            good: { border: 'border-amber-500/40', bg: 'bg-amber-900/10', badge: 'bg-amber-600/30 text-amber-300', icon: '\ud83d\udc4d' },
            tough: { border: 'border-orange-500/40', bg: 'bg-orange-900/10', badge: 'bg-orange-600/30 text-orange-300', icon: '\ud83d\ude24' },
            failed: { border: 'border-red-500/40', bg: 'bg-red-900/10', badge: 'bg-red-600/30 text-red-300', icon: '\u274c' }
          };

          var cardsHtml = '<div class="mt-2"><div class="flex items-center justify-between mb-2"><p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold">Per-Game Analysis</p><span class="text-[10px] text-gray-600">' + display.length + ' of ' + games.length + ' games</span></div><div class="flex flex-col gap-2 max-h-64 overflow-y-auto">';

          for (var i = 0; i < display.length; i++) {
            var g = display[i];
            var colors = ratingColors[g.rating] || ratingColors.good;
            var dateStr = g.date && g.date !== '?' ? new Date(g.date + 'T00:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '\u2014';
            var resultText = g.solved ? 'Solved in ' + g.attempts + ' guesses' : 'Not solved';
            var timeText = g.splitTime > 0 ? ' \u00b7 ' + g.splitTime + 's' : '';

            cardsHtml += '<div class="rounded-xl ' + colors.border + ' ' + colors.bg + ' border p-3">';
            cardsHtml += '<div class="flex items-center justify-between mb-1"><div class="flex items-center gap-2"><span class="text-base">' + colors.icon + '</span><span class="text-xs font-bold text-white">Game #' + g.gameNumber + '</span><span class="px-1.5 py-0.5 rounded text-[10px] font-semibold ' + colors.badge + '">' + g.rating.toUpperCase() + '</span></div><span class="text-[10px] text-gray-500">' + dateStr + '</span></div>';
            cardsHtml += '<div class="flex items-center gap-3 text-[11px] text-gray-400"><span>' + resultText + '</span>' + (timeText ? '<span>Time: <b class="text-white">' + g.splitTime + 's</b></span>' : '') + '<span class="text-gray-600">' + g.wordLength + '-letter word</span>' + (g.word ? '<span class="font-mono uppercase text-orange-300">' + g.word + '</span>' : '') + '</div>';

            if (g.improvements && g.improvements.length > 0) {
              cardsHtml += '<div class="mt-1.5">';
              for (var s = 0; s < g.improvements.length; s++) {
                cardsHtml += '<p class="text-[11px] text-green-300/80 pl-2 border-l-2 border-green-500/30 mb-0.5">' + g.improvements[s] + '</p>';
              }
              cardsHtml += '</div>';
            }
            if (g.weaknesses && g.weaknesses.length > 0) {
              cardsHtml += '<div class="mt-1.5">';
              for (var w = 0; w < g.weaknesses.length; w++) {
                cardsHtml += '<p class="text-[11px] text-red-300/80 pl-2 border-l-2 border-red-500/30 mb-0.5">' + g.weaknesses[w] + '</p>';
              }
              cardsHtml += '</div>';
            }
            cardsHtml += '</div>';
          }
          cardsHtml += '</div></div>';
          wrapper.insertAdjacentHTML('beforeend', cardsHtml);
        }

        // PDF Download + Save buttons
        if (typeof appendCoachingPDFButtons === 'function') {
          appendCoachingPDFButtons(wrapper, 'cab', analysisText, data.stats || {}, data.phases || null);
        }

        containerEl.appendChild(wrapper);
        scrollToBottom();
      })
      .catch(function() { /* Non-critical — AI text response is still shown */ });
    }

    // Render CaB graph on canvas (chat page version)
    function renderCabChatGraph(games) {
      var canvas = document.getElementById('chat-cab-graph');
      if (!canvas) return;

      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);

      var pad = { top: 16, right: 12, bottom: 28, left: 30 };
      var plotW = w - pad.left - pad.right;
      var plotH = h - pad.top - pad.bottom;
      var n = sorted.length;

      var attempts = sorted.map(function(g) { return g.solved ? g.attempts : 10; });
      var maxAtt = Math.min(Math.max.apply(null, attempts) + 1, 12);
      var solvedAtts = attempts.filter(function(a) { return a < 10; });
      var avgAtt = solvedAtts.length > 0 ? Math.round(solvedAtts.reduce(function(a, b) { return a + b; }, 0) / solvedAtts.length * 10) / 10 : 0;

      ctx.clearRect(0, 0, w, h);

      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.06)';
      ctx.lineWidth = 1;
      for (var i = 0; i <= 5; i++) {
        var y = pad.top + (plotH / 5) * i;
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
      }

      // Y-axis labels
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillStyle = 'rgba(74,222,128,0.7)';
      for (var i = 0; i <= 5; i++) {
        var val = Math.round((maxAtt / 5) * i);
        var y = pad.top + (plotH / 5) * i;
        ctx.fillText(val === 0 ? '' : String(val), pad.left - 6, y + 3);
      }

      // X-axis labels
      ctx.textAlign = 'center';
      ctx.fillStyle = 'rgba(255,255,255,0.4)';
      var labelStep = Math.max(1, Math.floor(n / 8));
      for (var i = 0; i < n; i += labelStep) {
        var x = pad.left + (plotW / Math.max(n - 1, 1)) * i;
        ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14);
      }
      if ((n - 1) % labelStep !== 0 && n > 1) {
        ctx.fillText('#' + sorted[n - 1].gameNumber, pad.left + plotW, h - pad.bottom + 14);
      }

      function getXY(index, value) {
        var x = pad.left + (plotW / Math.max(n - 1, 1)) * index;
        var y = pad.top + (value / maxAtt) * plotH;
        return { x: x, y: y };
      }

      // Average line (dashed)
      if (avgAtt > 0) {
        var avgY = pad.top + (avgAtt / maxAtt) * plotH;
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(pad.left, avgY); ctx.lineTo(w - pad.right, avgY); ctx.stroke();
        ctx.setLineDash([]);
      }

      // Line connecting dots
      ctx.strokeStyle = 'rgba(251,146,60,0.6)';
      ctx.lineWidth = 1.5;
      ctx.lineJoin = 'round';
      ctx.beginPath();
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, attempts[i]);
        if (i === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y);
      }
      ctx.stroke();

      // Dots
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, attempts[i]);
        ctx.fillStyle = sorted[i].solved ? 'rgba(74,222,128,1)' : 'rgba(248,113,113,1)';
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, sorted[i].attempts <= 2 && sorted[i].solved ? 5 : 3.5, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Render Quiz accuracy graph on canvas
    function renderQuizChatGraph(games) {
      var canvas = document.getElementById('chat-quiz-graph');
      if (!canvas) return;
      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth; var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr; ctx.scale(dpr, dpr);
      var pad = { top: 16, right: 12, bottom: 28, left: 30 };
      var plotW = w - pad.left - pad.right; var plotH = h - pad.top - pad.bottom;
      var n = sorted.length;
      var accs = sorted.map(function(g) { return g.accuracy; });
      var avgAcc = Math.round(accs.reduce(function(a, b) { return a + b; }, 0) / accs.length);
      ctx.clearRect(0, 0, w, h);
      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 1;
      for (var i = 0; i <= 5; i++) { var y = pad.top + (plotH / 5) * i; ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke(); }
      // Y-axis labels (0-100%)
      ctx.font = '10px system-ui, sans-serif'; ctx.textAlign = 'right'; ctx.fillStyle = 'rgba(74,222,128,0.7)';
      for (var i = 0; i <= 5; i++) { var val = 100 - (i * 20); var y = pad.top + (plotH / 5) * i; ctx.fillText(val + '%', pad.left - 4, y + 3); }
      // X-axis labels
      ctx.textAlign = 'center'; ctx.fillStyle = 'rgba(255,255,255,0.4)';
      var labelStep = Math.max(1, Math.floor(n / 8));
      for (var i = 0; i < n; i += labelStep) { var x = pad.left + (plotW / Math.max(n - 1, 1)) * i; ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14); }
      function getXY(index, pct) { return { x: pad.left + (plotW / Math.max(n - 1, 1)) * index, y: pad.top + ((100 - pct) / 100) * plotH }; }
      // Average line
      if (avgAcc > 0) { var avgY = pad.top + ((100 - avgAcc) / 100) * plotH; ctx.setLineDash([4, 4]); ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(pad.left, avgY); ctx.lineTo(w - pad.right, avgY); ctx.stroke(); ctx.setLineDash([]); }
      // Line
      ctx.strokeStyle = 'rgba(96,165,250,0.6)'; ctx.lineWidth = 1.5; ctx.lineJoin = 'round'; ctx.beginPath();
      for (var i = 0; i < n; i++) { var pt = getXY(i, accs[i]); if (i === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y); } ctx.stroke();
      // Dots
      for (var i = 0; i < n; i++) { var pt = getXY(i, accs[i]); ctx.fillStyle = accs[i] === 100 ? 'rgba(74,222,128,1)' : accs[i] >= 60 ? 'rgba(251,146,60,1)' : 'rgba(248,113,113,1)'; ctx.beginPath(); ctx.arc(pt.x, pt.y, accs[i] === 100 ? 5 : 3.5, 0, Math.PI * 2); ctx.fill(); }
    }

    // Render Rack score graph on canvas
    function renderRackChatGraph(games) {
      var canvas = document.getElementById('chat-rack-graph');
      if (!canvas) return;
      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth; var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr; ctx.scale(dpr, dpr);
      var pad = { top: 16, right: 12, bottom: 28, left: 30 };
      var plotW = w - pad.left - pad.right; var plotH = h - pad.top - pad.bottom;
      var n = sorted.length;
      var scores = sorted.map(function(g) { return g.score || 0; });
      var maxScore = Math.max(Math.max.apply(null, scores) + 5, 30);
      var avgScore = Math.round(scores.reduce(function(a, b) { return a + b; }, 0) / scores.length);
      ctx.clearRect(0, 0, w, h);
      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 1;
      for (var i = 0; i <= 5; i++) { var y = pad.top + (plotH / 5) * i; ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke(); }
      // Y-axis labels
      ctx.font = '10px system-ui, sans-serif'; ctx.textAlign = 'right'; ctx.fillStyle = 'rgba(74,222,128,0.7)';
      for (var i = 0; i <= 5; i++) { var val = Math.round(maxScore - (maxScore / 5) * i); var y = pad.top + (plotH / 5) * i; ctx.fillText(String(val), pad.left - 4, y + 3); }
      // X-axis labels
      ctx.textAlign = 'center'; ctx.fillStyle = 'rgba(255,255,255,0.4)';
      var labelStep = Math.max(1, Math.floor(n / 8));
      for (var i = 0; i < n; i += labelStep) { var x = pad.left + (plotW / Math.max(n - 1, 1)) * i; ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14); }
      function getXY(index, score) { return { x: pad.left + (plotW / Math.max(n - 1, 1)) * index, y: pad.top + ((maxScore - score) / maxScore) * plotH }; }
      // Average line
      if (avgScore > 0) { var avgY = pad.top + ((maxScore - avgScore) / maxScore) * plotH; ctx.setLineDash([4, 4]); ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(pad.left, avgY); ctx.lineTo(w - pad.right, avgY); ctx.stroke(); ctx.setLineDash([]); }
      // Line
      ctx.strokeStyle = 'rgba(168,85,247,0.6)'; ctx.lineWidth = 1.5; ctx.lineJoin = 'round'; ctx.beginPath();
      for (var i = 0; i < n; i++) { var pt = getXY(i, scores[i]); if (i === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y); } ctx.stroke();
      // Dots
      for (var i = 0; i < n; i++) { var pt = getXY(i, scores[i]); ctx.fillStyle = scores[i] >= 20 ? 'rgba(74,222,128,1)' : scores[i] >= 10 ? 'rgba(251,146,60,1)' : 'rgba(248,113,113,1)'; ctx.beginPath(); ctx.arc(pt.x, pt.y, sorted[i].isBingo ? 5 : 3.5, 0, Math.PI * 2); ctx.fill(); }
    }

    // Render Anagram attempts graph on canvas
    function renderAnagramChatGraph(games) {
      var canvas = document.getElementById('chat-anagram-graph');
      if (!canvas) return;
      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth; var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr; ctx.scale(dpr, dpr);
      var pad = { top: 16, right: 12, bottom: 28, left: 30 };
      var plotW = w - pad.left - pad.right; var plotH = h - pad.top - pad.bottom;
      var n = sorted.length;
      var attempts = sorted.map(function(g) { return g.solved ? g.attempts : 6; });
      var maxAtt = 7;
      var solvedAtts = attempts.filter(function(a) { return a < 6; });
      var avgAtt = solvedAtts.length > 0 ? Math.round(solvedAtts.reduce(function(a, b) { return a + b; }, 0) / solvedAtts.length * 10) / 10 : 0;
      ctx.clearRect(0, 0, w, h);
      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 1;
      for (var i = 0; i <= 5; i++) { var y = pad.top + (plotH / 5) * i; ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke(); }
      // Y-axis labels
      ctx.font = '10px system-ui, sans-serif'; ctx.textAlign = 'right'; ctx.fillStyle = 'rgba(74,222,128,0.7)';
      for (var i = 0; i <= 5; i++) { var val = Math.round((maxAtt / 5) * i); var y = pad.top + (plotH / 5) * i; ctx.fillText(val === 0 ? '' : String(val), pad.left - 6, y + 3); }
      // X-axis labels
      ctx.textAlign = 'center'; ctx.fillStyle = 'rgba(255,255,255,0.4)';
      var labelStep = Math.max(1, Math.floor(n / 8));
      for (var i = 0; i < n; i += labelStep) { var x = pad.left + (plotW / Math.max(n - 1, 1)) * i; ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14); }
      function getXY(index, value) { return { x: pad.left + (plotW / Math.max(n - 1, 1)) * index, y: pad.top + (value / maxAtt) * plotH }; }
      // Average line
      if (avgAtt > 0) { var avgY = pad.top + (avgAtt / maxAtt) * plotH; ctx.setLineDash([4, 4]); ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(pad.left, avgY); ctx.lineTo(w - pad.right, avgY); ctx.stroke(); ctx.setLineDash([]); }
      // Line
      ctx.strokeStyle = 'rgba(251,146,60,0.6)'; ctx.lineWidth = 1.5; ctx.lineJoin = 'round'; ctx.beginPath();
      for (var i = 0; i < n; i++) { var pt = getXY(i, attempts[i]); if (i === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y); } ctx.stroke();
      // Dots
      for (var i = 0; i < n; i++) { var pt = getXY(i, attempts[i]); ctx.fillStyle = sorted[i].solved ? 'rgba(74,222,128,1)' : 'rgba(248,113,113,1)'; ctx.beginPath(); ctx.arc(pt.x, pt.y, sorted[i].attempts <= 2 && sorted[i].solved ? 5 : 3.5, 0, Math.PI * 2); ctx.fill(); }
    }

    // Shared per-game cards renderer for all coach types
    function appendCoachGameCards(wrapper, games, type) {
      if (games.length === 0) return;
      var display = games.slice(0, 10);
      var ratingColors = {
        perfect: { border: 'border-purple-500/40', bg: 'bg-purple-900/10', badge: 'bg-purple-600/30 text-purple-300', icon: '\ud83c\udfc6' },
        ace: { border: 'border-purple-500/40', bg: 'bg-purple-900/10', badge: 'bg-purple-600/30 text-purple-300', icon: '\ud83c\udfc6' },
        brilliant: { border: 'border-green-500/40', bg: 'bg-green-900/10', badge: 'bg-green-600/30 text-green-300', icon: '\u26a1' },
        great: { border: 'border-blue-500/40', bg: 'bg-blue-900/10', badge: 'bg-blue-600/30 text-blue-300', icon: '\u2705' },
        good: { border: 'border-amber-500/40', bg: 'bg-amber-900/10', badge: 'bg-amber-600/30 text-amber-300', icon: '\ud83d\udc4d' },
        fair: { border: 'border-orange-500/40', bg: 'bg-orange-900/10', badge: 'bg-orange-600/30 text-orange-300', icon: '\ud83d\ude10' },
        tough: { border: 'border-orange-500/40', bg: 'bg-orange-900/10', badge: 'bg-orange-600/30 text-orange-300', icon: '\ud83d\ude24' },
        weak: { border: 'border-red-500/40', bg: 'bg-red-900/10', badge: 'bg-red-600/30 text-red-300', icon: '\ud83d\udca2' },
        failed: { border: 'border-red-500/40', bg: 'bg-red-900/10', badge: 'bg-red-600/30 text-red-300', icon: '\u274c' }
      };

      var typeLabel = type === 'quiz' ? 'Per-Round Analysis' : type === 'rack' ? 'Per-Play Analysis' : 'Per-Puzzle Analysis';
      var cardsHtml = '<div class="mt-2"><div class="flex items-center justify-between mb-2"><p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold">' + typeLabel + '</p><span class="text-[10px] text-gray-600">' + display.length + ' of ' + games.length + '</span></div><div class="flex flex-col gap-2 max-h-64 overflow-y-auto">';

      for (var i = 0; i < display.length; i++) {
        var g = display[i];
        var colors = ratingColors[g.rating] || ratingColors.good;
        var dateStr = g.date && g.date !== '?' ? new Date(g.date.split('T')[0] + 'T00:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '\u2014';

        var resultText = '';
        if (type === 'quiz') resultText = g.accuracy + '% (' + g.score + '/' + g.total + ')' + (g.timedOut ? ' \u23f0 timed out' : '');
        else if (type === 'rack') resultText = g.word + ' = ' + g.score + ' pts' + (g.isBingo ? ' \ud83c\udf1f BINGO' : '');
        else resultText = g.solved ? 'Solved in ' + g.attempts + ' attempt' + (g.attempts === 1 ? '' : 's') : 'Not solved';

        var timeText = '';
        if (type === 'quiz' && g.timeUsed > 0) timeText = ' \u00b7 ' + g.timeUsed + 's';
        else if (type === 'anagram' && g.timeTaken > 0) timeText = ' \u00b7 ' + g.timeTaken + 's';

        var extraInfo = '';
        if (type === 'rack' && g.rack) extraInfo = '<span class="font-mono text-gray-500 text-[10px]">[' + g.rack + ']</span>';
        if (type === 'anagram' && g.scrambled) extraInfo = '<span class="font-mono text-gray-500 text-[10px]">' + g.scrambled + ' \u2192 ' + (g.word || '?') + '</span>';

        cardsHtml += '<div class="rounded-xl ' + colors.border + ' ' + colors.bg + ' border p-3">';
        cardsHtml += '<div class="flex items-center justify-between mb-1"><div class="flex items-center gap-2"><span class="text-base">' + colors.icon + '</span><span class="text-xs font-bold text-white">Game #' + g.gameNumber + '</span><span class="px-1.5 py-0.5 rounded text-[10px] font-semibold ' + colors.badge + '">' + (g.rating || 'good').toUpperCase() + '</span></div><span class="text-[10px] text-gray-500">' + dateStr + '</span></div>';
        cardsHtml += '<div class="flex items-center gap-3 text-[11px] text-gray-400 flex-wrap"><span>' + resultText + '</span>' + (timeText ? '<span>' + timeText + '</span>' : '') + (extraInfo ? extraInfo : '') + '</div>';

        if (g.improvements && g.improvements.length > 0) {
          cardsHtml += '<div class="mt-1.5">';
          for (var s = 0; s < g.improvements.length; s++) { cardsHtml += '<p class="text-[11px] text-green-300/80 pl-2 border-l-2 border-green-500/30 mb-0.5">' + g.improvements[s] + '</p>'; }
          cardsHtml += '</div>';
        }
        if (g.weaknesses && g.weaknesses.length > 0) {
          cardsHtml += '<div class="mt-1.5">';
          for (var w = 0; w < g.weaknesses.length; w++) { cardsHtml += '<p class="text-[11px] text-red-300/80 pl-2 border-l-2 border-red-500/30 mb-0.5">' + g.weaknesses[w] + '</p>'; }
          cardsHtml += '</div>';
        }
        cardsHtml += '</div>';
      }
      cardsHtml += '</div></div>';
      wrapper.insertAdjacentHTML('beforeend', cardsHtml);
    }

    // --- Quiz Coach Structured Data (graph + timing + per-game cards) ---
    function appendQuizCoachData(containerEl, analysisText) {
      var uid = localStorage.getItem('swf-uid') || '';
      if (!uid) return;

      fetch('/api/lex-quiz-coach/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
