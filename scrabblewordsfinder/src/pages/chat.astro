      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error || !data.hasHistory) return;

        var wrapper = document.createElement('div');
        wrapper.className = 'mt-4 space-y-4';

        // Stats bar
        if (data.stats) {
          var s = data.stats;
          var statsHtml = '<div class="grid grid-cols-4 gap-2">';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-white">' + s.totalGames + '</p><p class="text-[10px] text-gray-500">Games</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-green-400">' + s.accuracy + '%</p><p class="text-[10px] text-gray-500">Accuracy</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-orange-400">' + s.totalPerfect + '</p><p class="text-[10px] text-gray-500">Perfect</p></div>';
          statsHtml += '<div class="text-center p-2 rounded-lg bg-gray-700/50 border border-gray-600/50"><p class="text-lg font-bold text-purple-400">' + s.timeUsagePct + '%</p><p class="text-[10px] text-gray-500">Timer Used</p></div>';
          statsHtml += '</div>';
          wrapper.insertAdjacentHTML('beforeend', statsHtml);
        }

        // Graph (accuracy per game)
        var games = data.gameAnalysis || [];
        if (games.length >= 2) {
          var graphSection = document.createElement('div');
          graphSection.className = 'mt-3';
          graphSection.innerHTML = '<p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold mb-2">Accuracy per Game (higher = better)</p><canvas id="chat-quiz-graph" class="w-full h-36 rounded-lg bg-gray-800/30 border border-gray-700/30"></canvas><div class="flex justify-between mt-1 text-[9px] text-gray-600"><span>\ud83d\udfe2 Perfect</span><span>\ud83d\udfe0 Good (\u226560%)</span><span>\ud83d\udd34 Weak (<60%)</span><span>\u2b1c Average line</span></div>';
          wrapper.appendChild(graphSection);
          setTimeout(function() { renderQuizChatGraph(games); }, 50);
        }

        // Time insight
        var timed = games.filter(function(g) { return g.timeUsed > 0; });
        if (timed.length >= 2) {
          var sorted = timed.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
          var times = sorted.map(function(g) { return g.timeUsed; });
          var fastest = Math.min.apply(null, times);
          var slowest = Math.max.apply(null, times);
          var avg = Math.round(times.reduce(function(a, b) { return a + b; }, 0) / times.length);
          var fastestGame = sorted.find(function(g) { return g.timeUsed === fastest; });
          var slowestGame = sorted.find(function(g) { return g.timeUsed === slowest; });
          var recent = sorted[sorted.length - 1];
          var prev = sorted[sorted.length - 2];
          var diff = recent.timeUsed - prev.timeUsed;
          var trend = diff < -10 ? 'Getting faster \u2014 ' + Math.abs(diff) + 's quicker than previous.' :
                     diff > 10 ? 'Took ' + diff + 's longer \u2014 possibly harder words.' :
                     'Consistent pace between recent games.';

          var timeHtml = '<div class="px-3 py-2 rounded-lg bg-cyan-900/20 border border-cyan-700/30">';
          timeHtml += '<p class="text-[10px] text-cyan-400 font-semibold uppercase mb-1">\u23f1 Time Insight</p>';
          timeHtml += '<p class="text-[11px] text-gray-300 leading-relaxed">Fastest: ' + fastest + 's (Game #' + fastestGame.gameNumber + ') \u00b7 Slowest: ' + slowest + 's (Game #' + slowestGame.gameNumber + ') \u00b7 Avg: ' + avg + 's. ' + trend + '</p>';
          timeHtml += '</div>';
          wrapper.insertAdjacentHTML('beforeend', timeHtml);
        }

        // Per-game cards
        appendCoachGameCards(wrapper, games, 'quiz');

        // PDF Download + Save buttons
        if (typeof appendCoachingPDFButtons === 'function') {
          appendCoachingPDFButtons(wrapper, 'quiz', analysisText, data.stats || {}, data.phases || null);
        }

        containerEl.appendChild(wrapper);
        scrollToBottom();
      })
      .catch(function() { /* Non-critical */ });
    }

