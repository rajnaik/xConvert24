    // Convert markdown-style links and bare /blog/ paths to clickable HTML links
    function linkifyResponse(text) {
      // First, convert markdown links: [text](url) → <a> tags
      let html = escapeHtml(text);
      // Match escaped markdown links: [text](url)
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, function(_, linkText, url) {
        // Ensure internal links have trailing slash
        if (url.startsWith('/') && !url.endsWith('/') && !url.includes('.')) {
          url += '/';
        }
        return '<a href="' + url + '" class="text-blue-400 hover:text-blue-300 underline" target="_blank" rel="noopener">' + linkText + '</a>';
      });
      // Also linkify bare blog paths like /blog/some-slug/ that weren't in markdown format
      html = html.replace(/(^|[\s(])(\/(blog|chat)\/[a-z0-9-]+\/?)(?=[\s),.]|$)/gi, function(_, prefix, url) {
        if (!url.endsWith('/')) url += '/';
        return prefix + '<a href="' + url + '" class="text-blue-400 hover:text-blue-300 underline" target="_blank" rel="noopener">' + url + '</a>';
      });
      return html;
    }

