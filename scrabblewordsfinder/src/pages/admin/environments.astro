            </tr>
            <tr class="hover:bg-gray-900/50">
              <td class="px-4 py-3 text-sm text-gray-300"><span class="inline-block w-5 h-5 mr-2 align-middle"><svg viewBox="0 0 24 24"><path fill="#F6821F" d="M16.5 12.5l1.3-4.5c.1-.4-.2-.8-.6-.8H6.8l-.3 1h9.1c.3 0 .5.3.4.6l-1 3.4h1.5z"/><path fill="#FAAD3F" d="M19.7 11.2l.8-2.7c.2-.6-.3-1.2-.9-1.2h-1.3l-.3 1h1c.2 0 .3.2.3.4l-.5 1.8c-.1.2.1.4.3.4h.6z"/><path fill="#F6821F" d="M5.5 15.8c.1.4.5.7.9.7h11.2c.4 0 .7-.3.8-.6l.8-2.9H7.1l-1.6 2.8z"/></svg></span>Cloudflare</td>
              <td class="px-4 py-3 text-center"><a href="https://dash.cloudflare.com" target="_blank" class="text-purple-400 hover:text-purple-300"><svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a></td>
              <td class="px-4 py-3 text-center"><button class="copy-url-btn text-gray-500 hover:text-purple-400 transition-colors" data-url="https://dash.cloudflare.com" title="Copy"><svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ToolSet Summary Panel -->
    <div class="mt-6">
      <a href="/admin/toolset" class="block rounded-xl border-2 border-cyan-700 bg-gray-900/50 p-6 hover:border-cyan-500 transition-colors group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-full bg-cyan-600 flex items-center justify-center">
            <span class="text-white text-lg">🧰</span>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-cyan-400 transition-colors">ToolSet</h2>
            <p class="text-xs text-gray-400">Libraries, APIs, services & versions</p>
          </div>
          <div class="ml-auto text-gray-500 group-hover:text-cyan-400 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
        <div id="toolset-summary" class="text-xs text-gray-400">Loading...</div>
      </a>
    </div>
  </div>

  <script>
    // Load toolset summary
    fetch('/api/toolset')
      .then(r => r.json())
      .then(data => {
        const tools = data.tools || [];
        const el = document.getElementById('toolset-summary');
        if (!el || !tools.length) return;
        const outdated = tools.filter((t: any) => t.latest_version && t.installed_version && t.latest_version !== t.installed_version && t.installed_version !== '-');
        const total = tools.length;
        el.innerHTML = `<div class="grid grid-cols-3 gap-6 text-center"><div><span class="text-cyan-400 font-bold text-2xl block">${total}</span><p class="text-xs text-gray-500 mt-1">Total tools</p></div><div><span class="text-green-400 font-bold text-2xl block">${total - outdated.length}</span><p class="text-xs text-gray-500 mt-1">Up to date</p></div><div><span class="${outdated.length ? 'text-amber-400' : 'text-green-400'} font-bold text-2xl block">${outdated.length}</span><p class="text-xs text-gray-500 mt-1">Updates available</p></div></div>`;
      })
      .catch(() => {});

    // Copy URL buttons
    document.querySelectorAll('.copy-url-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url || '';
        navigator.clipboard.writeText(url).then(() => {
          const svg = btn.querySelector('svg')!;
          svg.style.color = '#4ade80';
          setTimeout(() => { svg.style.color = ''; }, 1000);
        });
      });
    });

    // Check live status
    fetch('https://www.scrabblewordsfinder.com/api/site-status')
      .then(r => { 
        document.getElementById('live-status')!.textContent = r.ok ? 'Online' : 'Issues';
        document.getElementById('live-light')!.className = r.ok ? 'traffic-light state-green' : 'traffic-light state-red';
      })
      .catch(() => {
        document.getElementById('live-status')!.textContent = 'Offline';
        document.getElementById('live-light')!.className = 'traffic-light state-red';
      });

    // Check dev (will fail if not running — that's fine)
    fetch('http://localhost:4323/api/site-status')
      .then(r => {
        document.getElementById('dev-status')!.textContent = r.ok ? 'Running' : 'Error';
        document.getElementById('dev-light')!.className = r.ok ? 'traffic-light state-green' : 'traffic-light state-red';
      })
      .catch(() => {
        document.getElementById('dev-status')!.textContent = 'Not running';
        document.getElementById('dev-light')!.className = 'traffic-light state-red';
      });

    // Staging — assume amber (checking) until we can verify
    document.getElementById('stg-light')!.className = 'traffic-light state-amber';
    document.getElementById('stg-status')!.textContent = 'Deployed';
  </script>
</Layout>
