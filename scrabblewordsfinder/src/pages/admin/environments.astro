              <td class="px-4 py-3 text-center"><button class="copy-url-btn text-gray-500 hover:text-purple-400 transition-colors" data-url="https://ads.google.com" title="Copy"><svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr class="hover:bg-gray-900/50">
              <td class="px-4 py-3 text-sm text-gray-300"><span class="inline-block w-5 h-5 mr-2 align-middle"><svg viewBox="0 0 24 24"><path fill="#4285F4" d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg></span>Google Search Console</td>
              <td class="px-4 py-3 text-center"><a href="https://search.google.com/search-console" target="_blank" class="text-purple-400 hover:text-purple-300"><svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a></td>
              <td class="px-4 py-3 text-center"><button class="copy-url-btn text-gray-500 hover:text-purple-400 transition-colors" data-url="https://search.google.com/search-console" title="Copy"><svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr class="hover:bg-gray-900/50">
              <td class="px-4 py-3 text-sm text-gray-300"><span class="inline-block w-5 h-5 mr-2 align-middle"><svg viewBox="0 0 24 24"><path fill="#F9AB00" d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path fill="#E37400" d="M9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg></span>Google Analytics</td>
