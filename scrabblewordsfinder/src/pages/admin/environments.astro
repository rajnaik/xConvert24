        </div>
        <table class="w-full text-sm">
          <tbody>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs w-14">Site</td>
              <td class="py-1.5 text-center w-8 env-icon-cell"><a href="https://scrabblewordsfinder-staging.xconvert.workers.dev" target="_blank" class="env-link text-amber-400 hover:text-amber-300 transition-colors relative group"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg><span class="env-tooltip">https://scrabblewordsfinder-staging.xconvert.workers.dev</span></a></td>
              <td class="py-1.5 text-center w-8"><button class="copy-url-btn text-gray-500 hover:text-amber-400 transition-colors" data-url="https://scrabblewordsfinder-staging.xconvert.workers.dev" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">Admin</td>
              <td class="py-1.5 text-center env-icon-cell"><a href="https://scrabblewordsfinder-staging.xconvert.workers.dev/admin" target="_blank" class="env-link text-amber-400 hover:text-amber-300 transition-colors relative group"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg><span class="env-tooltip">https://scrabblewordsfinder-staging.xconvert.workers.dev/admin</span></a></td>
              <td class="py-1.5 text-center"><button class="copy-url-btn text-gray-500 hover:text-amber-400 transition-colors" data-url="https://scrabblewordsfinder-staging.xconvert.workers.dev/admin" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">DB</td>
              <td class="py-1.5 text-gray-300 font-mono text-xs" colspan="2">scrabble-staging (be0fad12)</td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">Cmd</td>
              <td class="py-1.5 text-center"><code class="text-amber-400 text-xs">npm run deploy:staging</code></td>
              <td class="py-1.5 text-center"><button class="copy-url-btn text-gray-500 hover:text-amber-400 transition-colors" data-url="npm run deploy:staging" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
          </tbody>
        </table>
        <div class="mt-auto pt-3 border-t border-gray-800 flex items-center gap-2">
          <div id="stg-light" class="traffic-light"><span class="light light-red"></span><span class="light light-amber"></span><span class="light light-green"></span></div>
          <span id="stg-status" class="text-xs text-gray-400">Checking...</span>
        </div>
      </div>

      <!-- Live -->
      <div class="rounded-xl border-2 border-green-700 bg-gray-900/50 p-6 flex flex-col">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-full bg-green-600 flex items-center justify-center">
            <span class="text-white font-bold text-sm">LIVE</span>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white">Production</h2>
            <p class="text-xs text-gray-400">Custom domain</p>
          </div>
        </div>
        <table class="w-full text-sm">
          <tbody>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs w-14">Site</td>
              <td class="py-1.5 text-center w-8 env-icon-cell"><a href="https://www.scrabblewordsfinder.com" target="_blank" class="env-link text-green-400 hover:text-green-300 transition-colors relative group"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg><span class="env-tooltip">https://www.scrabblewordsfinder.com</span></a></td>
              <td class="py-1.5 text-center w-8"><button class="copy-url-btn text-gray-500 hover:text-green-400 transition-colors" data-url="https://www.scrabblewordsfinder.com" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">Admin</td>
              <td class="py-1.5 text-center env-icon-cell"><a href="https://www.scrabblewordsfinder.com/admin" target="_blank" class="env-link text-green-400 hover:text-green-300 transition-colors relative group"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg><span class="env-tooltip">https://www.scrabblewordsfinder.com/admin</span></a></td>
              <td class="py-1.5 text-center"><button class="copy-url-btn text-gray-500 hover:text-green-400 transition-colors" data-url="https://www.scrabblewordsfinder.com/admin" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">DB</td>
              <td class="py-1.5 text-gray-300 font-mono text-xs" colspan="2">scrabble-live (e9af2a48)</td>
            </tr>
            <tr>
              <td class="py-1.5 text-gray-400 text-xs">Cmd</td>
              <td class="py-1.5 text-center"><code class="text-green-400 text-xs">npm run deploy</code></td>
              <td class="py-1.5 text-center"><button class="copy-url-btn text-gray-500 hover:text-green-400 transition-colors" data-url="npm run deploy" title="Copy"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button></td>
            </tr>
          </tbody>
        </table>
        <div class="mt-auto pt-3 border-t border-gray-800 flex items-center gap-2">
          <div id="live-light" class="traffic-light"><span class="light light-red"></span><span class="light light-amber"></span><span class="light light-green"></span></div>
          <span id="live-status" class="text-xs text-gray-400">Checking...</span>
        </div>
      </div>

    </div>

    <!-- Vendors & Partners — flat table -->
    <div class="mt-6">
      <h2 class="text-lg font-semibold text-white mb-3 flex items-center gap-2">
        <span class="h-8 w-8 rounded-full bg-purple-600 flex items-center justify-center text-white text-xs font-bold">V&P</span>
        Vendors & Partners
      </h2>
      <div class="overflow-x-auto rounded-xl border border-gray-800">
        <table class="w-full text-sm">
          <thead class="bg-gray-900 border-b border-gray-800">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">Vendor</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-400 uppercase">Link</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-400 uppercase">Copy</th>
