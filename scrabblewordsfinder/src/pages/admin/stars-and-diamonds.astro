---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Stars & Diamonds — Admin" description="View all earned stars and diamonds grouped by user" keywords="admin, stars, diamonds, rewards">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/stars-and-diamonds/" class="text-amber-400 font-medium">Stars & Diamonds</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-white mb-2">⭐ Stars & Diamonds</h1>
    <p class="text-gray-400 mb-8">All earned stars and diamonds grouped by user.</p>

    <!-- Summary Stats -->
    <div id="summary-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-amber-400" id="stat-users">—</p>
        <p class="text-xs text-gray-400">Total Users</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-yellow-400" id="stat-stars">—</p>
        <p class="text-xs text-gray-400">Total Stars</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-blue-400" id="stat-diamonds">—</p>
        <p class="text-xs text-gray-400">Total Diamonds</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-purple-400" id="stat-bonus">—</p>
        <p class="text-xs text-gray-400">Bonus Diamonds</p>
      </div>
    </div>

    <!-- Table -->
    <div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-800 text-gray-300">
            <tr>
              <th class="px-4 py-3 text-left font-semibold">#</th>
              <th class="px-4 py-3 text-left font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="user_id" data-align="left">User ID <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="total_stars" data-align="center">⭐ Stars <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="total_diamonds" data-align="center">💎 Diamonds <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="bonus_diamonds" data-align="center">🎁 Bonus <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="current_streak" data-align="center">🔥 Streak <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="best_streak" data-align="center">🏆 Best <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-center font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="diamond_streak" data-align="center">💎 D-Streak <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-left font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="last_active_date" data-align="left">Last Active <span class="sort-arrow text-xs opacity-50"></span></th>
              <th class="px-4 py-3 text-left font-semibold cursor-pointer hover:text-amber-400 transition-colors select-none" data-sort="created_at" data-align="left">Joined <span class="sort-arrow text-xs opacity-50"></span></th>
            </tr>
          </thead>
          <tbody id="rewards-tbody" class="divide-y divide-gray-800">
            <tr><td colspan="10" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-xs text-gray-500 mt-4" id="load-time"></p>
  </div>

  <script is:inline>
    (async function loadData() {
      let rewards = [];
      let sortCol = null;
      let sortDir = 'asc'; // 'asc' or 'desc'

      const start = performance.now();
      try {
        const res = await fetch('/api/stars-and-diamonds/');
        if (!res.ok) throw new Error('API error: ' + res.status);
        const data = await res.json();

        // Summary
        document.getElementById('stat-users').textContent = data.summary.totalUsers;
        document.getElementById('stat-stars').textContent = data.summary.totalStars;
        document.getElementById('stat-diamonds').textContent = data.summary.totalDiamonds;
        document.getElementById('stat-bonus').textContent = data.summary.totalBonusDiamonds;

        rewards = data.rewards || [];
        renderTable(rewards);

        const elapsed = Math.round(performance.now() - start);
        document.getElementById('load-time').textContent = 'Loaded ' + rewards.length + ' users in ' + elapsed + 'ms';
      } catch (err) {
        document.getElementById('rewards-tbody').innerHTML = '<tr><td colspan="10" class="px-4 py-8 text-center text-red-400">Failed to load: ' + err.message + '</td></tr>';
        return;
      }

      // Sortable headers
      document.querySelectorAll('th[data-sort]').forEach(function(th) {
        th.addEventListener('click', function() {
          const col = th.getAttribute('data-sort');
          if (sortCol === col) {
            sortDir = sortDir === 'asc' ? 'desc' : 'asc';
          } else {
            sortCol = col;
            sortDir = 'desc'; // default to descending for numbers (highest first)
            if (col === 'user_id' || col === 'created_at' || col === 'last_active_date') sortDir = 'asc';
          }
          updateArrows();
          const sorted = sortRewards(rewards, sortCol, sortDir);
          renderTable(sorted);
        });
      });

      function updateArrows() {
        document.querySelectorAll('th[data-sort] .sort-arrow').forEach(function(span) {
          span.textContent = '';
          span.parentElement.classList.remove('text-amber-400');
        });
        if (sortCol) {
          const activeTh = document.querySelector('th[data-sort="' + sortCol + '"]');
          if (activeTh) {
            activeTh.querySelector('.sort-arrow').textContent = sortDir === 'asc' ? ' ▲' : ' ▼';
            activeTh.classList.add('text-amber-400');
          }
        }
      }

      function sortRewards(arr, col, dir) {
        return arr.slice().sort(function(a, b) {
          let aVal = a[col];
          let bVal = b[col];

          // Handle nulls
          if (aVal == null) aVal = '';
          if (bVal == null) bVal = '';

          // Numeric columns
          if (typeof aVal === 'number' || (col !== 'user_id' && col !== 'last_active_date' && col !== 'created_at')) {
            aVal = Number(aVal) || 0;
            bVal = Number(bVal) || 0;
          } else {
            aVal = String(aVal).toLowerCase();
            bVal = String(bVal).toLowerCase();
          }

          if (aVal < bVal) return dir === 'asc' ? -1 : 1;
          if (aVal > bVal) return dir === 'asc' ? 1 : -1;
          return 0;
        });
      }

      function renderTable(data) {
        const tbody = document.getElementById('rewards-tbody');
        if (!data.length) {
          tbody.innerHTML = '<tr><td colspan="10" class="px-4 py-8 text-center text-gray-500">No data yet.</td></tr>';
          return;
        }

        tbody.innerHTML = data.map(function(r, i) {
          const shortId = r.user_id.length > 16 ? r.user_id.slice(0, 14) + '…' : r.user_id;
          const rowBg = i % 2 === 0 ? 'bg-gray-900' : 'bg-gray-800/50';
          const lastActive = r.last_active_date || '—';
          const joined = r.created_at ? r.created_at.split('T')[0].split(' ')[0] : '—';
          return '<tr class="' + rowBg + '">' +
            '<td class="px-4 py-3 text-gray-500">' + (i + 1) + '</td>' +
            '<td class="px-4 py-3 font-mono text-xs text-gray-300" title="' + r.user_id + '">' + shortId + '</td>' +
            '<td class="px-4 py-3 text-center font-bold text-yellow-400">' + r.total_stars + '</td>' +
            '<td class="px-4 py-3 text-center font-bold text-blue-400">' + r.total_diamonds + '</td>' +
            '<td class="px-4 py-3 text-center text-purple-400">' + (r.bonus_diamonds || 0) + '</td>' +
            '<td class="px-4 py-3 text-center text-orange-400">' + r.current_streak + '</td>' +
            '<td class="px-4 py-3 text-center text-amber-300">' + r.best_streak + '</td>' +
            '<td class="px-4 py-3 text-center text-cyan-400">' + r.diamond_streak + '</td>' +
            '<td class="px-4 py-3 text-gray-400 text-xs">' + lastActive + '</td>' +
            '<td class="px-4 py-3 text-gray-500 text-xs">' + joined + '</td>' +
            '</tr>';
        }).join('');
      }
    })();
  </script>
</Layout>
