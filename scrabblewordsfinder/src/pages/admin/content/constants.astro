---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
---

<Layout title="Constants — Admin — ScrabbleWordsFinder" description="Manage site-wide constants" keywords="admin, constants, key-value, configuration">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/content/" class="hover:text-teal-400 transition-colors">Content</a>
      <a href="/admin/content/constants/" class="text-teal-400 font-medium">Constants</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-center gap-3 mb-2">
      <a href="/admin/content/" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">← Content</a>
    </div>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-white mb-1">🔑 Constants</h1>
        <p class="text-gray-400 text-sm">Site-wide key-value pairs with categories and status. Changes apply immediately.</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="cache-btn" class="px-4 py-2 rounded-lg bg-amber-600 hover:bg-amber-500 text-white text-sm font-medium transition-colors flex items-center gap-2">
          <span id="cache-icon">🔄</span> Update Cache
        </button>
        <button id="add-btn" class="px-4 py-2 rounded-lg bg-teal-600 hover:bg-teal-500 text-white text-sm font-medium transition-colors">
          + Add Constant
        </button>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="flex items-center gap-4 mb-4">
      <select id="filter-category" class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm focus:border-teal-500 focus:outline-none">
        <option value="">All Categories</option>
      </select>
      <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
        <input type="checkbox" id="filter-active" class="rounded border-gray-600 bg-gray-800 text-teal-500 focus:ring-teal-500" />
        Active only
      </label>
      <span id="stats-line" class="ml-auto text-xs text-gray-500"></span>
    </div>

    <!-- Toast notification -->
    <div id="toast" class="fixed top-6 right-6 z-50 hidden px-4 py-3 rounded-lg text-sm font-medium shadow-lg transition-all"></div>

    <!-- Table -->
    <div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800 text-gray-400 text-xs uppercase tracking-wide">
            <th class="px-4 py-3 text-left">Name</th>
            <th class="px-4 py-3 text-left">Value</th>
            <th class="px-4 py-3 text-left">Category</th>
            <th class="px-4 py-3 text-center">Status</th>
            <th class="px-4 py-3 text-left">Updated</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="constants-tbody" class="text-gray-300">
          <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="modal-overlay" class="fixed inset-0 z-40 bg-black/60 hidden flex items-center justify-center">
    <div class="bg-gray-900 border border-gray-700 rounded-xl w-full max-w-lg p-6 shadow-2xl" id="modal-box">
      <h2 id="modal-title" class="text-xl font-bold text-white mb-4">Add Constant</h2>
      <form id="modal-form" class="space-y-4">
        <input type="hidden" id="form-id" value="" />
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="form-name" class="block text-xs text-gray-400 uppercase tracking-wide mb-1">Name</label>
            <input id="form-name" type="text" required
              class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white text-sm focus:border-teal-500 focus:outline-none"
              placeholder="e.g. TAGLINE" />
          </div>
          <div>
            <label for="form-category" class="block text-xs text-gray-400 uppercase tracking-wide mb-1">Category</label>
            <input id="form-category" type="text"
              class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white text-sm focus:border-teal-500 focus:outline-none"
              placeholder="e.g. branding" />
          </div>
        </div>
        <div>
          <label for="form-text" class="block text-xs text-gray-400 uppercase tracking-wide mb-1">Value</label>
          <textarea id="form-text" rows="2" required
            class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white text-sm focus:border-teal-500 focus:outline-none resize-y"
            placeholder="The constant value..."></textarea>
        </div>
        <div>
          <label for="form-description" class="block text-xs text-gray-400 uppercase tracking-wide mb-1">Description</label>
          <input id="form-description" type="text"
            class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white text-sm focus:border-teal-500 focus:outline-none"
            placeholder="What is this constant used for?" />
        </div>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
            <input type="checkbox" id="form-status" checked
              class="rounded border-gray-600 bg-gray-800 text-teal-500 focus:ring-teal-500" />
            Active
          </label>
        </div>
        <div class="flex items-center justify-end gap-3 pt-2">
          <button type="button" id="modal-cancel" class="px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm transition-colors">Cancel</button>
          <button type="submit" id="modal-submit" class="px-4 py-2 rounded-lg bg-teal-600 hover:bg-teal-500 text-white text-sm font-medium transition-colors">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-overlay" class="fixed inset-0 z-40 bg-black/60 hidden flex items-center justify-center">
    <div class="bg-gray-900 border border-gray-700 rounded-xl w-full max-w-sm p-6 shadow-2xl">
      <h2 class="text-xl font-bold text-white mb-2">Delete Constant</h2>
      <p class="text-gray-400 text-sm mb-4">Are you sure you want to delete <strong id="delete-name" class="text-white"></strong>? This cannot be undone.</p>
      <div class="flex items-center justify-end gap-3">
        <button id="delete-cancel" class="px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm transition-colors">Cancel</button>
        <button id="delete-confirm" class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500 text-white text-sm font-medium transition-colors">Delete</button>
      </div>
    </div>
  </div>

  <script>
    interface Constant {
      id: number;
      name: string;
      text: string;
      description: string;
      category: string;
      status: number;
      updated_at: string;
      updated_by: string;
      created_at: string;
    }

    let constants: Constant[] = [];
    let filteredConstants: Constant[] = [];
    let deleteTarget: Constant | null = null;

    const tbody = document.getElementById('constants-tbody')!;
    const statsLine = document.getElementById('stats-line')!;
    const toast = document.getElementById('toast')!;
    const filterCategory = document.getElementById('filter-category') as HTMLSelectElement;
    const filterActive = document.getElementById('filter-active') as HTMLInputElement;

    // Modal elements
    const overlay = document.getElementById('modal-overlay')!;
    const modalTitle = document.getElementById('modal-title')!;
    const formId = document.getElementById('form-id') as HTMLInputElement;
    const formName = document.getElementById('form-name') as HTMLInputElement;
    const formCategory = document.getElementById('form-category') as HTMLInputElement;
    const formText = document.getElementById('form-text') as HTMLTextAreaElement;
    const formDescription = document.getElementById('form-description') as HTMLInputElement;
    const formStatus = document.getElementById('form-status') as HTMLInputElement;
    const modalForm = document.getElementById('modal-form') as HTMLFormElement;

    // Delete modal
    const deleteOverlay = document.getElementById('delete-overlay')!;
    const deleteName = document.getElementById('delete-name')!;

    function showToast(message: string, type: 'success' | 'error') {
      toast.textContent = message;
      toast.className = `fixed top-6 right-6 z-50 px-4 py-3 rounded-lg text-sm font-medium shadow-lg transition-all ${type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'}`;
      setTimeout(() => { toast.classList.add('hidden'); }, 3000);
    }

    function formatDate(iso: string): string {
      if (!iso) return '—';
      const d = new Date(iso + (iso.includes('Z') ? '' : 'Z'));
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) + ' ' +
        d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function escapeHtml(str: string): string {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function applyFilters() {
      const cat = filterCategory.value;
      const activeOnly = filterActive.checked;
      filteredConstants = constants.filter(c => {
        if (cat && c.category !== cat) return false;
        if (activeOnly && c.status !== 1) return false;
        return true;
      });
      render();
    }

    function populateCategoryFilter() {
      const cats = [...new Set(constants.map(c => c.category).filter(Boolean))].sort();
      const current = filterCategory.value;
      filterCategory.innerHTML = '<option value="">All Categories</option>' +
        cats.map(c => `<option value="${escapeHtml(c)}" ${c === current ? 'selected' : ''}>${escapeHtml(c)}</option>`).join('');
    }

    function render() {
      if (filteredConstants.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No constants found. Click "+ Add Constant" to create one.</td></tr>';
        statsLine.textContent = `${constants.length} total, 0 shown`;
        return;
      }

      tbody.innerHTML = filteredConstants.map(c => `
        <tr class="border-b border-gray-800/50 hover:bg-gray-800/30 transition-colors">
          <td class="px-4 py-3">
            <span class="font-medium text-teal-400 font-mono text-xs">${escapeHtml(c.name)}</span>
            ${c.description ? `<p class="text-gray-500 text-xs mt-0.5 truncate max-w-[200px]" title="${escapeHtml(c.description)}">${escapeHtml(c.description)}</p>` : ''}
          </td>
          <td class="px-4 py-3 text-gray-300 max-w-[250px] truncate" title="${escapeHtml(c.text)}">${escapeHtml(c.text)}</td>
          <td class="px-4 py-3">
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium ${
              c.category === 'branding' ? 'bg-purple-900/50 text-purple-300' :
              c.category === 'config' ? 'bg-blue-900/50 text-blue-300' :
              'bg-gray-800 text-gray-400'
            }">${escapeHtml(c.category)}</span>
          </td>
          <td class="px-4 py-3 text-center">
            <button data-toggle="${c.id}" class="inline-flex items-center gap-1 text-xs font-medium ${c.status === 1 ? 'text-green-400' : 'text-gray-500'} hover:opacity-80 transition-opacity" title="Click to toggle">
              <span class="w-2 h-2 rounded-full ${c.status === 1 ? 'bg-green-400' : 'bg-gray-600'}"></span>
              ${c.status === 1 ? 'Active' : 'Inactive'}
            </button>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs">
            ${formatDate(c.updated_at)}
            <span class="block text-gray-600">by ${escapeHtml(c.updated_by)}</span>
          </td>
          <td class="px-4 py-3 text-right">
            <button data-edit="${c.id}" class="text-blue-400 hover:text-blue-300 text-xs mr-3 transition-colors">Edit</button>
            <button data-delete="${c.id}" class="text-red-400 hover:text-red-300 text-xs transition-colors">Delete</button>
          </td>
        </tr>
      `).join('');

      statsLine.textContent = `${filteredConstants.length} of ${constants.length} constant${constants.length === 1 ? '' : 's'}`;

      // Attach handlers
      tbody.querySelectorAll('[data-edit]').forEach(btn => {
        btn.addEventListener('click', () => openEditModal(Number((btn as HTMLElement).dataset.edit)));
      });
      tbody.querySelectorAll('[data-delete]').forEach(btn => {
        btn.addEventListener('click', () => openDeleteModal(Number((btn as HTMLElement).dataset.delete)));
      });
      tbody.querySelectorAll('[data-toggle]').forEach(btn => {
        btn.addEventListener('click', () => toggleStatus(Number((btn as HTMLElement).dataset.toggle)));
      });
    }

    async function toggleStatus(id: number) {
      const c = constants.find(x => x.id === id);
      if (!c) return;
      const newStatus = c.status === 1 ? 0 : 1;
      try {
        const res = await fetch('/api/constants/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: c.name, status: newStatus }),
        });
        if (!res.ok) throw new Error('Toggle failed');
        showToast(`${c.name} is now ${newStatus === 1 ? 'active' : 'inactive'}`, 'success');
        await loadConstants();
      } catch (err: any) {
        showToast(err.message, 'error');
      }
    }

    async function loadConstants() {
      try {
        const res = await fetch('/api/constants/');
        if (!res.ok) throw new Error('Failed to load');
        const data = await res.json();
        constants = data.constants || [];
        populateCategoryFilter();
        applyFilters();
      } catch (err: any) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-red-400">Error loading constants: ${err.message}</td></tr>`;
      }
    }

    // Add modal
    function openAddModal() {
      modalTitle.textContent = 'Add Constant';
      formId.value = '';
      formName.value = '';
      formName.disabled = false;
      formCategory.value = 'general';
      formText.value = '';
      formDescription.value = '';
      formStatus.checked = true;
      overlay.classList.remove('hidden');
      formName.focus();
    }

    function openEditModal(id: number) {
      const c = constants.find(x => x.id === id);
      if (!c) return;
      modalTitle.textContent = 'Edit Constant';
      formId.value = String(c.id);
      formName.value = c.name;
      formName.disabled = true;
      formCategory.value = c.category;
      formText.value = c.text;
      formDescription.value = c.description;
      formStatus.checked = c.status === 1;
      overlay.classList.remove('hidden');
      formText.focus();
    }

    function closeModal() { overlay.classList.add('hidden'); }

    // Delete modal
    function openDeleteModal(id: number) {
      const c = constants.find(x => x.id === id);
      if (!c) return;
      deleteTarget = c;
      deleteName.textContent = c.name;
      deleteOverlay.classList.remove('hidden');
    }
    function closeDeleteModal() { deleteOverlay.classList.add('hidden'); deleteTarget = null; }

    // Form submit
    modalForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = formId.value;
      const name = formName.value.trim();
      const text = formText.value.trim();
      const description = formDescription.value.trim();
      const category = formCategory.value.trim() || 'general';
      const status = formStatus.checked ? 1 : 0;

      if (!name || !text) {
        showToast('Name and value are required', 'error');
        return;
      }

      try {
        if (id) {
          // Update
          const res = await fetch('/api/constants/', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, text, description, category, status }),
          });
          if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Update failed'); }
          showToast(`Updated "${name}" successfully`, 'success');
        } else {
          // Create
          const res = await fetch('/api/constants/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, text, description, category, status }),
          });
          if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Create failed'); }
          showToast(`Created "${name}" successfully`, 'success');
        }
        closeModal();
        await loadConstants();
      } catch (err: any) {
        showToast(err.message, 'error');
      }
    });

    // Delete confirm
    document.getElementById('delete-confirm')!.addEventListener('click', async () => {
      if (!deleteTarget) return;
      try {
        const res = await fetch('/api/constants/', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: deleteTarget.id }),
        });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Delete failed'); }
        showToast(`Deleted "${deleteTarget.name}" successfully`, 'success');
        closeDeleteModal();
        await loadConstants();
      } catch (err: any) {
        showToast(err.message, 'error');
        closeDeleteModal();
      }
    });

    // Event listeners
    document.getElementById('add-btn')!.addEventListener('click', openAddModal);
    document.getElementById('modal-cancel')!.addEventListener('click', closeModal);
    document.getElementById('delete-cancel')!.addEventListener('click', closeDeleteModal);
    filterCategory.addEventListener('change', applyFilters);
    filterActive.addEventListener('change', applyFilters);

    // Close modals on overlay/escape
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
    deleteOverlay.addEventListener('click', (e) => { if (e.target === deleteOverlay) closeDeleteModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeModal(); closeDeleteModal(); } });

    // Update Cache button
    document.getElementById('cache-btn')!.addEventListener('click', async () => {
      const btn = document.getElementById('cache-btn')!;
      const icon = document.getElementById('cache-icon')!;
      btn.classList.add('opacity-50', 'pointer-events-none');
      icon.textContent = '⏳';
      try {
        const res = await fetch('/api/constants/cache', { method: 'POST' });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Cache update failed'); }
        const data = await res.json();
        showToast(`Cache refreshed: ${data.cached} active constants synced to KV`, 'success');
      } catch (err: any) {
        showToast(err.message, 'error');
      } finally {
        btn.classList.remove('opacity-50', 'pointer-events-none');
        icon.textContent = '🔄';
      }
    });

    // Initial load
    loadConstants();
  </script>
</Layout>
