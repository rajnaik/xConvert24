---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
---

<Layout title="Blog Comments — Admin — ScrabbleWordsFinder" description="Manage blog comments — approve, reject, and moderate discussions." keywords="admin, blog, comments, moderation">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/content/" class="hover:text-blue-400 transition-colors">Content</a>
      <a href="/admin/content/blog-comments/" class="text-blue-400 font-medium">Comments</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-center gap-3 mb-2">
      <a href="/admin/content/" class="text-gray-400 hover:text-blue-400 text-sm transition-colors">← Content</a>
    </div>
    <h1 class="text-3xl font-bold text-white mb-2">💬 Blog Comments</h1>
    <p class="text-gray-400 mb-8">Moderate reader comments. Approve comments to make them visible on blog posts.</p>

    <!-- Stats Row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-5 text-center">
        <p class="text-3xl font-bold text-white" id="stat-total">—</p>
        <p class="text-xs text-gray-400 mt-1">Total Comments</p>
      </div>
      <div class="rounded-xl border border-green-900/50 bg-green-950/20 p-5 text-center">
        <p class="text-3xl font-bold text-green-400" id="stat-approved">—</p>
        <p class="text-xs text-gray-400 mt-1">Approved</p>
      </div>
      <div class="rounded-xl border border-amber-900/50 bg-amber-950/20 p-5 text-center">
        <p class="text-3xl font-bold text-amber-400" id="stat-pending">—</p>
        <p class="text-xs text-gray-400 mt-1">Pending Review</p>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="flex items-center gap-3 mb-4">
      <label class="text-sm text-gray-400">Filter:</label>
      <button id="filter-all" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-blue-600 text-white transition-colors">All</button>
      <button id="filter-pending" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 transition-colors">Pending</button>
      <button id="filter-approved" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 transition-colors">Approved</button>
    </div>

    <!-- Comments Table -->
    <div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 text-left text-xs text-gray-400 uppercase tracking-wider">
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">Comment</th>
              <th class="px-4 py-3">Blog Post</th>
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Action</th>
            </tr>
          </thead>
          <tbody id="comments-tbody">
            <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">Loading comments...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Toast notification -->
    <div id="toast" class="fixed bottom-6 right-6 z-50 hidden px-4 py-3 rounded-lg text-sm font-medium shadow-lg transition-all"></div>
  </div>

  <script is:inline>
  (function() {
    var tbody = document.getElementById('comments-tbody');
    var statTotal = document.getElementById('stat-total');
    var statApproved = document.getElementById('stat-approved');
    var statPending = document.getElementById('stat-pending');
    var toast = document.getElementById('toast');
    var allComments = [];
    var currentFilter = 'all';

    // Filter buttons
    var filterAll = document.getElementById('filter-all');
    var filterPending = document.getElementById('filter-pending');
    var filterApproved = document.getElementById('filter-approved');

    function setActiveFilter(btn) {
      [filterAll, filterPending, filterApproved].forEach(function(b) {
        b.className = 'px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 transition-colors';
      });
      btn.className = 'px-3 py-1.5 text-xs font-medium rounded-lg bg-blue-600 text-white transition-colors';
    }

    filterAll.addEventListener('click', function() { currentFilter = 'all'; setActiveFilter(filterAll); renderTable(); });
    filterPending.addEventListener('click', function() { currentFilter = 'pending'; setActiveFilter(filterPending); renderTable(); });
    filterApproved.addEventListener('click', function() { currentFilter = 'approved'; setActiveFilter(filterApproved); renderTable(); });

    function showToast(msg, type) {
      toast.textContent = msg;
      toast.className = 'fixed bottom-6 right-6 z-50 px-4 py-3 rounded-lg text-sm font-medium shadow-lg transition-all ' +
        (type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white');
      toast.classList.remove('hidden');
      setTimeout(function() { toast.classList.add('hidden'); }, 3000);
    }

    function escHtml(s) {
      var d = document.createElement('div');
      d.textContent = s || '';
      return d.innerHTML;
    }

    function formatDate(dt) {
      if (!dt) return '—';
      var d = new Date(dt + (dt.includes('Z') ? '' : 'Z'));
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function truncate(s, max) {
      if (!s) return '';
      return s.length > max ? s.slice(0, max) + '…' : s;
    }

    function renderTable() {
      var filtered = currentFilter === 'all' ? allComments : allComments.filter(function(c) { return c.status === currentFilter; });

      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No comments found.</td></tr>';
        return;
      }

      tbody.innerHTML = filtered.map(function(c) {
        var statusBadge = c.status === 'approved'
          ? '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-900/30 text-green-400 border border-green-800/50">✓ Approved</span>'
          : '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-900/30 text-amber-400 border border-amber-800/50">⏳ Pending</span>';

        var actionBtn = c.status === 'approved'
          ? '<button class="action-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-amber-700 hover:bg-amber-600 text-white transition-colors" data-id="' + c.id + '" data-action="pending">Unapprove</button>'
          : '<button class="action-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-green-700 hover:bg-green-600 text-white transition-colors" data-id="' + c.id + '" data-action="approved">Approve</button>';

        var blogLink = '<a href="/blog/' + escHtml(c.blogid) + '/" class="text-blue-400 hover:underline" target="_blank">' + escHtml(truncate(c.blogname || c.blogid, 30)) + '</a>';

        return '<tr class="border-b border-gray-800/50 hover:bg-gray-800/30 transition-colors">' +
          '<td class="px-4 py-3">' + statusBadge + '</td>' +
          '<td class="px-4 py-3 text-gray-200 font-medium whitespace-nowrap">' + escHtml(c.commenterName) + '</td>' +
          '<td class="px-4 py-3 text-gray-300 max-w-xs">' +
            (c.subject ? '<span class="block text-xs text-gray-500 mb-0.5">' + escHtml(c.subject) + '</span>' : '') +
            '<span class="block text-sm">' + escHtml(truncate(c.comment, 120)) + '</span>' +
          '</td>' +
          '<td class="px-4 py-3 text-sm">' + blogLink + '</td>' +
          '<td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">' + formatDate(c.datetime) + '</td>' +
          '<td class="px-4 py-3">' + actionBtn + '</td>' +
        '</tr>';
      }).join('');
    }

    function updateStats(stats) {
      statTotal.textContent = stats.total || 0;
      statApproved.textContent = stats.approved || 0;
      statPending.textContent = stats.pending || 0;
    }

    function loadComments() {
      fetch('/api/blog-comments/?admin=true')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          allComments = data.comments || [];
          if (data.stats) updateStats(data.stats);
          renderTable();
        })
        .catch(function() {
          tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-red-400">Failed to load comments.</td></tr>';
        });
    }

    // Delegate click on action buttons
    tbody.addEventListener('click', function(e) {
      var btn = e.target.closest('.action-btn');
      if (!btn) return;
      var id = Number(btn.dataset.id);
      var action = btn.dataset.action; // 'approved' or 'pending'

      btn.disabled = true;
      btn.textContent = '...';

      fetch('/api/blog-comments/', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, status: action })
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            showToast(action === 'approved' ? '✅ Comment approved' : '⏳ Comment unapproved', 'success');
            // Update local state
            var comment = allComments.find(function(c) { return c.id === id; });
            if (comment) comment.status = action;
            // Recalc stats
            var approved = allComments.filter(function(c) { return c.status === 'approved'; }).length;
            var pending = allComments.filter(function(c) { return c.status === 'pending'; }).length;
            updateStats({ total: allComments.length, approved: approved, pending: pending });
            renderTable();
          } else {
            showToast('❌ ' + (data.error || 'Failed'), 'error');
            btn.disabled = false;
            btn.textContent = action === 'approved' ? 'Approve' : 'Unapprove';
          }
        })
        .catch(function() {
          showToast('❌ Network error', 'error');
          btn.disabled = false;
          btn.textContent = action === 'approved' ? 'Approve' : 'Unapprove';
        });
    });

    // Initial load
    loadComments();
  })();
  </script>
</Layout>
