---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
---

<Layout title="Content — Admin — ScrabbleWordsFinder" description="Content management for ScrabbleWordsFinder.com" keywords="admin, content, constants, management">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/content/" class="text-teal-400 font-medium">Content</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex items-center gap-3 mb-2">
      <a href="/admin/" class="text-gray-400 hover:text-blue-400 text-sm transition-colors">← Admin</a>
    </div>
    <h1 class="text-3xl font-bold text-white mb-2">📄 Content Management</h1>
    <p class="text-gray-400 mb-8">Manage site content, constants, and configuration values.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Constants Card -->
      <a href="/admin/content/constants/" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-teal-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-teal-400 transition-colors">🔑 Constants</h2>
        <p class="text-gray-400 text-sm">Key-value pairs used across the site — taglines, labels, config.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Create, read, update, delete</li>
          <li>• Unique name per constant</li>
          <li>• Used in templates & scripts</li>
        </ul>
        <p class="mt-3 text-teal-400 font-medium text-sm" id="constants-count"></p>
      </a>

      <!-- Blog Comments Card -->
      <a href="/admin/content/blog-comments/" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">💬 Blog Comments</h2>
        <p class="text-gray-400 text-sm">Moderate reader comments — approve, reject, and manage discussions.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• <span id="comments-approved" class="text-green-400 font-medium">—</span> approved</li>
          <li>• <span id="comments-pending" class="text-amber-400 font-medium">—</span> pending</li>
          <li>• Approve / unapprove toggle</li>
        </ul>
        <p class="mt-3 text-blue-400 font-medium text-sm" id="comments-total"></p>
      </a>

      <!-- Chat Usage Card -->
      <a href="/admin/content/chatusage/" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-emerald-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">🤖 Chat Usage</h2>
        <p class="text-gray-400 text-sm">View ScrabbleBot AI chat interactions — messages, response times, errors.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• <span id="chatusage-total" class="text-emerald-400 font-medium">—</span> total chats</li>
          <li>• <span id="chatusage-failed" class="text-red-400 font-medium">—</span> failed</li>
          <li>• Avg response: <span id="chatusage-avg-ms" class="text-cyan-400 font-medium">—</span>ms</li>
        </ul>
        <p class="mt-3 text-emerald-400 font-medium text-sm" id="chatusage-last"></p>
      </a>
    </div>
  </div>

  <script>
    fetch('/api/constants/').then(r => r.json()).then(d => {
      const el = document.getElementById('constants-count');
      if (el && d.constants) el.textContent = d.constants.length + ' constants defined';
    }).catch(() => {});

    fetch('/api/blog-comments/?admin=true&stats=true').then(r => r.json()).then(d => {
      if (d.stats) {
        const approvedEl = document.getElementById('comments-approved');
        const pendingEl = document.getElementById('comments-pending');
        const totalEl = document.getElementById('comments-total');
        if (approvedEl) approvedEl.textContent = String(d.stats.approved || 0);
        if (pendingEl) pendingEl.textContent = String(d.stats.pending || 0);
        if (totalEl) totalEl.textContent = (d.stats.total || 0) + ' comments total';
      }
    }).catch(() => {});

    fetch('/api/chatusage/?stats=true').then(r => r.json()).then(d => {
      if (d.stats) {
        const totalEl = document.getElementById('chatusage-total');
        const failedEl = document.getElementById('chatusage-failed');
        const avgEl = document.getElementById('chatusage-avg-ms');
        const lastEl = document.getElementById('chatusage-last');
        if (totalEl) totalEl.textContent = String(d.stats.total || 0);
        if (failedEl) failedEl.textContent = String(d.stats.failed || 0);
        if (avgEl) avgEl.textContent = String(d.stats.avg_response_ms || 0);
        if (lastEl && d.stats.last_chat) lastEl.textContent = 'Last: ' + new Date(d.stats.last_chat + 'Z').toLocaleDateString();
      }
    }).catch(() => {});
  </script>
</Layout>
