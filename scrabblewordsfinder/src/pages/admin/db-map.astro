---
import '../../styles/global.css';
---
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>DB Map — Admin</title>
  <style>
    .db-node { transition: all 0.2s; }
    .db-node:hover { transform: scale(1.05); }
    .arrow-line { stroke-dasharray: 6 3; animation: dash 1s linear infinite; }
    @keyframes dash { to { stroke-dashoffset: -9; } }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <nav class="border-b border-gray-800 px-4 py-3 flex items-center gap-4 text-sm">
    <a href="/admin/" class="text-gray-400 hover:text-white transition-colors">← Admin</a>
    <span class="text-amber-400 font-medium">🗄️ DB Map</span>
  </nav>

  <main class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-white mb-2">Database Architecture</h1>
    <p class="text-sm text-gray-400 mb-8">10/10 D1 databases · 3 environments per workspace · All connections verified</p>

    <!-- SVG Diagram -->
    <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-6 overflow-x-auto">
      <svg viewBox="0 0 900 520" class="w-full min-w-[700px]" xmlns="http://www.w3.org/2000/svg">
        <text x="450" y="30" text-anchor="middle" fill="#9ca3af" font-size="14" font-weight="600">xSoft Infrastructure — D1 Database Map</text>

        <!-- WEBSITES (Left) -->
        <text x="80" y="65" text-anchor="middle" fill="#6b7280" font-size="11" font-weight="500">WEBSITES</text>

        <rect x="20" y="80" width="120" height="50" rx="10" fill="#1e293b" stroke="#f59e0b" stroke-width="2"/>
        <text x="80" y="100" text-anchor="middle" fill="#fbbf24" font-size="11" font-weight="700">xConvert24</text>
        <text x="80" y="118" text-anchor="middle" fill="#9ca3af" font-size="9">.com</text>

        <rect x="20" y="180" width="120" height="50" rx="10" fill="#1e293b" stroke="#a855f7" stroke-width="2"/>
        <text x="80" y="200" text-anchor="middle" fill="#c084fc" font-size="11" font-weight="700">SWF</text>
        <text x="80" y="218" text-anchor="middle" fill="#9ca3af" font-size="9">scrabblewordsfinder</text>

        <rect x="20" y="280" width="120" height="50" rx="10" fill="#1e293b" stroke="#22c55e" stroke-width="2"/>
        <text x="80" y="300" text-anchor="middle" fill="#4ade80" font-size="11" font-weight="700">xcrypto24</text>
        <text x="80" y="318" text-anchor="middle" fill="#9ca3af" font-size="9">coins</text>

        <rect x="20" y="380" width="120" height="50" rx="10" fill="#1e293b" stroke="#3b82f6" stroke-width="2"/>
        <text x="80" y="400" text-anchor="middle" fill="#60a5fa" font-size="11" font-weight="700">Playground</text>
        <text x="80" y="418" text-anchor="middle" fill="#9ca3af" font-size="9">xsoft-playground</text>

        <!-- ENV HEADERS -->
        <text x="350" y="65" text-anchor="middle" fill="#4ade80" font-size="11" font-weight="500">LIVE</text>
        <text x="550" y="65" text-anchor="middle" fill="#fbbf24" font-size="11" font-weight="500">STAGING</text>
        <text x="750" y="65" text-anchor="middle" fill="#60a5fa" font-size="11" font-weight="500">DEV</text>

        <!-- xConvert DBs -->
        <rect x="290" y="82" width="120" height="46" rx="8" fill="#1e293b" stroke="#22c55e" stroke-width="1.5" class="db-node"/>
        <text x="350" y="102" text-anchor="middle" fill="#4ade80" font-size="9" font-weight="600">xconvert24-live</text>
        <text x="350" y="118" text-anchor="middle" fill="#6b7280" font-size="8">5192e41c · 11MB</text>

        <rect x="490" y="82" width="120" height="46" rx="8" fill="#1e293b" stroke="#f59e0b" stroke-width="1.5" class="db-node"/>
        <text x="550" y="102" text-anchor="middle" fill="#fbbf24" font-size="9" font-weight="600">xconvert24-staging</text>
        <text x="550" y="118" text-anchor="middle" fill="#6b7280" font-size="8">4a6fa78e · 4.5MB</text>

        <rect x="690" y="82" width="120" height="46" rx="8" fill="#1e293b" stroke="#3b82f6" stroke-width="1.5" class="db-node"/>
        <text x="750" y="102" text-anchor="middle" fill="#60a5fa" font-size="9" font-weight="600">xconvert24-dev</text>
        <text x="750" y="118" text-anchor="middle" fill="#6b7280" font-size="8">13d84b09 · 594KB</text>

        <!-- SWF DBs -->
        <rect x="290" y="182" width="120" height="46" rx="8" fill="#1e293b" stroke="#22c55e" stroke-width="1.5" class="db-node"/>
        <text x="350" y="202" text-anchor="middle" fill="#4ade80" font-size="9" font-weight="600">scrabble-live</text>
        <text x="350" y="218" text-anchor="middle" fill="#6b7280" font-size="8">e9af2a48 · 3.3MB</text>

        <rect x="490" y="182" width="120" height="46" rx="8" fill="#1e293b" stroke="#f59e0b" stroke-width="1.5" class="db-node"/>
        <text x="550" y="202" text-anchor="middle" fill="#fbbf24" font-size="9" font-weight="600">scrabble-staging</text>
        <text x="550" y="218" text-anchor="middle" fill="#6b7280" font-size="8">be0fad12 · 201KB</text>

        <rect x="690" y="182" width="120" height="46" rx="8" fill="#1e293b" stroke="#3b82f6" stroke-width="1.5" class="db-node"/>
        <text x="750" y="202" text-anchor="middle" fill="#60a5fa" font-size="9" font-weight="600">scrabble-dev</text>
        <text x="750" y="218" text-anchor="middle" fill="#6b7280" font-size="8">3084af39 · 3.2MB</text>

        <!-- Coins DBs -->
        <rect x="290" y="282" width="120" height="46" rx="8" fill="#1e293b" stroke="#22c55e" stroke-width="1.5" class="db-node"/>
        <text x="350" y="302" text-anchor="middle" fill="#4ade80" font-size="9" font-weight="600">crypto-live</text>
        <text x="350" y="318" text-anchor="middle" fill="#6b7280" font-size="8">69fd1763 · 70KB</text>

        <rect x="490" y="282" width="120" height="46" rx="8" fill="#1e293b" stroke="#f59e0b" stroke-width="1.5" class="db-node"/>
        <text x="550" y="302" text-anchor="middle" fill="#fbbf24" font-size="9" font-weight="600">crypto-staging</text>
        <text x="550" y="318" text-anchor="middle" fill="#6b7280" font-size="8">11c6243f · 12KB</text>

        <rect x="690" y="282" width="120" height="46" rx="8" fill="#1e293b" stroke="#3b82f6" stroke-width="1.5" class="db-node"/>
        <text x="750" y="302" text-anchor="middle" fill="#60a5fa" font-size="9" font-weight="600">crypto-dev</text>
        <text x="750" y="318" text-anchor="middle" fill="#6b7280" font-size="8">eb93c76d · 12KB</text>

        <!-- Playground DB -->
        <rect x="290" y="382" width="120" height="46" rx="8" fill="#1e293b" stroke="#22c55e" stroke-width="1.5" class="db-node"/>
        <text x="350" y="402" text-anchor="middle" fill="#4ade80" font-size="9" font-weight="600">xpg</text>
        <text x="350" y="418" text-anchor="middle" fill="#6b7280" font-size="8">2f1b3fb7 · 25KB</text>

        <!-- ARROWS -->
        <line x1="140" y1="105" x2="288" y2="105" stroke="#22c55e" stroke-width="1.5" class="arrow-line"/>
        <line x1="140" y1="105" x2="488" y2="105" stroke="#f59e0b" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>
        <line x1="140" y1="105" x2="688" y2="105" stroke="#3b82f6" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>

        <line x1="140" y1="205" x2="288" y2="205" stroke="#22c55e" stroke-width="1.5" class="arrow-line"/>
        <line x1="140" y1="205" x2="488" y2="205" stroke="#f59e0b" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>
        <line x1="140" y1="205" x2="688" y2="205" stroke="#3b82f6" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>

        <line x1="140" y1="305" x2="288" y2="305" stroke="#22c55e" stroke-width="1.5" class="arrow-line"/>
        <line x1="140" y1="305" x2="488" y2="305" stroke="#f59e0b" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>
        <line x1="140" y1="305" x2="688" y2="305" stroke="#3b82f6" stroke-width="1" stroke-opacity="0.4" class="arrow-line"/>

        <line x1="140" y1="405" x2="288" y2="405" stroke="#22c55e" stroke-width="1.5" class="arrow-line"/>

        <!-- Arrowheads -->
        <polygon points="286,101 278,105 286,109" fill="#22c55e"/>
        <polygon points="286,201 278,205 286,209" fill="#22c55e"/>
        <polygon points="286,301 278,305 286,309" fill="#22c55e"/>
        <polygon points="286,401 278,405 286,409" fill="#22c55e"/>

        <!-- Legend -->
        <rect x="20" y="460" width="860" height="45" rx="8" fill="#111827" stroke="#374151" stroke-width="1"/>
        <circle cx="50" cy="482" r="5" fill="#22c55e"/><text x="62" y="486" fill="#9ca3af" font-size="10">Live</text>
        <circle cx="130" cy="482" r="5" fill="#f59e0b"/><text x="142" y="486" fill="#9ca3af" font-size="10">Staging</text>
        <circle cx="220" cy="482" r="5" fill="#3b82f6"/><text x="232" y="486" fill="#9ca3af" font-size="10">Dev</text>
        <text x="350" y="486" fill="#6b7280" font-size="10">10/10 D1 databases · Cloudflare Free Tier · June 2026</text>
      </svg>
    </div>

    <!-- Summary table -->
    <div class="mt-8 overflow-x-auto">
      <table class="w-full text-sm border border-gray-800 rounded-lg overflow-hidden">
        <thead class="bg-gray-900">
          <tr>
            <th class="px-4 py-3 text-left text-gray-400 font-medium">Workspace</th>
            <th class="px-4 py-3 text-left text-green-400 font-medium">Live DB</th>
            <th class="px-4 py-3 text-left text-amber-400 font-medium">Staging DB</th>
            <th class="px-4 py-3 text-left text-blue-400 font-medium">Dev DB</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <tr><td class="px-4 py-3 text-white font-medium">xConvert24</td><td class="px-4 py-3 font-mono text-xs text-green-300">xconvert24-live</td><td class="px-4 py-3 font-mono text-xs text-amber-300">xconvert24-staging</td><td class="px-4 py-3 font-mono text-xs text-blue-300">xconvert24-dev</td></tr>
          <tr><td class="px-4 py-3 text-white font-medium">SWF</td><td class="px-4 py-3 font-mono text-xs text-green-300">scrabble-live</td><td class="px-4 py-3 font-mono text-xs text-amber-300">scrabble-staging</td><td class="px-4 py-3 font-mono text-xs text-blue-300">scrabble-dev</td></tr>
          <tr><td class="px-4 py-3 text-white font-medium">Coins</td><td class="px-4 py-3 font-mono text-xs text-green-300">crypto-live</td><td class="px-4 py-3 font-mono text-xs text-amber-300">crypto-staging</td><td class="px-4 py-3 font-mono text-xs text-blue-300">crypto-dev</td></tr>
          <tr><td class="px-4 py-3 text-white font-medium">Playground</td><td class="px-4 py-3 font-mono text-xs text-green-300">xpg</td><td class="px-4 py-3 text-gray-600">—</td><td class="px-4 py-3 text-gray-600">—</td></tr>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
