---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Documentation — Admin" description="System documentation, architecture diagrams, and codebase resources" keywords="documentation, architecture, code diagram">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/documentation/" class="text-blue-400 font-medium">Documentation</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">📚 Documentation</h1>
    <p class="text-gray-400 mb-8">Architecture diagrams, system resources, and codebase visual maps.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Code Diagram Card -->
      <a href="/admin/resources/code-diagram/" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-sky-700 transition-colors group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sky-900/50 border border-sky-500/30 flex items-center justify-center text-lg">
            🏗️
          </div>
          <h2 class="text-lg font-semibold text-white group-hover:text-sky-400 transition-colors">Code Diagram</h2>
        </div>
        <p class="text-gray-400 text-sm">Interactive architecture diagram of the entire SWF codebase.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• System overview — all components</li>
          <li>• API endpoint map</li>
          <li>• Database ER diagram</li>
          <li>• Deployment pipeline flow</li>
          <li>• Frontend architecture</li>
          <li>• Workers & bindings</li>
        </ul>
        <div class="mt-4 flex items-center gap-2 text-xs text-sky-400 font-medium">
          <span>View diagram</span>
          <span>→</span>
        </div>
      </a>

      <!-- Future: more documentation tiles can go here -->
      <div class="block rounded-xl border border-dashed border-gray-700 bg-gray-900/20 p-6 flex flex-col items-center justify-center text-center">
        <p class="text-gray-600 text-sm">More documentation resources coming soon</p>
        <p class="text-gray-700 text-xs mt-2">API docs, data flow diagrams, onboarding guides</p>
      </div>
    </div>
  </div>
</Layout>
