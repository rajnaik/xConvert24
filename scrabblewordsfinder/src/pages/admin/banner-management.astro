    </div>

    <!-- Toast notification -->
    <div id="toast" class="hidden fixed bottom-6 right-6 rounded-xl border border-green-800 bg-green-950/90 p-4 text-center shadow-lg z-50">
      <p class="text-green-300 text-sm font-medium" id="toast-text">✅ Updated!</p>
    </div>

    <!-- Error -->
    <div id="error-banner" class="hidden mt-6 rounded-xl border border-red-800 bg-red-950/30 p-4 text-center">
      <p class="text-red-300 text-sm font-medium" id="error-text">❌ Something went wrong.</p>
    </div>
  </div>

  <script>
    interface BannerData {
      option_number: number;
      name: string;
      description: string;
      status: 'active' | 'inactive';
    }

    function updateCardStyle(option: string, isActive: boolean) {
      const card = document.querySelector(`.banner-option[data-option="${option}"]`);
      if (!card) return;

      if (isActive) {
        card.classList.remove('border-gray-700', 'opacity-60');
        card.classList.add('border-green-600', 'ring-1', 'ring-green-500/20');
      } else {
        card.classList.remove('border-green-600', 'ring-1', 'ring-green-500/20');
        card.classList.add('border-gray-700');
      }

      const label = card.querySelector('.toggle-label');
      if (label) {
        label.textContent = isActive ? 'Active' : 'Inactive';
        label.classList.toggle('text-green-400', isActive);
        label.classList.toggle('text-gray-400', !isActive);
      }
    }

    function updateSummary(activeCount: number) {
      document.getElementById('active-count')!.textContent = String(activeCount);
      const info = document.getElementById('rotation-info')!;
      if (activeCount === 0) {
        info.textContent = '⚠️ No banners active — homepage will show banner 1 as fallback';
        info.classList.add('text-amber-400');
        info.classList.remove('text-gray-400');
      } else {
        info.textContent = `${activeCount} of 10 banners will randomly appear on each page load`;
        info.classList.remove('text-amber-400');
        info.classList.add('text-gray-400');
      }
    }

    function showToast(message: string) {
      const toast = document.getElementById('toast')!;
      const text = document.getElementById('toast-text')!;
      text.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2500);
    }

    async function loadBanners() {
      try {
        const res = await fetch('/api/banners');
        if (!res.ok) throw new Error('Failed to load banners');
        const data = await res.json();
        const banners: BannerData[] = data.banners || [];

        let activeCount = 0;
        banners.forEach(b => {
          const isActive = b.status === 'active';
          if (isActive) activeCount++;

          const toggle = document.querySelector(`.banner-toggle[data-option="${b.option_number}"] input`) as HTMLInputElement;
          if (toggle) toggle.checked = isActive;

          updateCardStyle(String(b.option_number), isActive);
        });

        updateSummary(activeCount);
      } catch {
        document.getElementById('rotation-info')!.textContent = '⚠️ Failed to load banner statuses';
      }
    }

    async function toggleBanner(option: string, newStatus: 'active' | 'inactive') {
      try {
        const res = await fetch('/api/banners', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ option_number: Number(option), status: newStatus }),
        });

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || 'Update failed');
        }

        const data = await res.json();
        updateCardStyle(option, newStatus === 'active');
        updateSummary(data.active_count);
        showToast(`Banner ${option} → ${newStatus}`);
      } catch (e: any) {
        // Revert the toggle
        const toggle = document.querySelector(`.banner-toggle[data-option="${option}"] input`) as HTMLInputElement;
        if (toggle) toggle.checked = newStatus !== 'active';
        updateCardStyle(option, newStatus !== 'active');

        const errorBanner = document.getElementById('error-banner')!;
        const errorText = document.getElementById('error-text')!;
        errorBanner.classList.remove('hidden');
        errorText.textContent = `❌ ${e.message}`;
        setTimeout(() => errorBanner.classList.add('hidden'), 4000);
      }
    }

    // Attach toggle listeners
    document.querySelectorAll('.banner-toggle input').forEach(input => {
      input.addEventListener('change', (e) => {
        const checkbox = e.target as HTMLInputElement;
        const option = checkbox.closest('.banner-toggle')!.getAttribute('data-option')!;
        const newStatus = checkbox.checked ? 'active' : 'inactive';
        toggleBanner(option, newStatus);
      });
    });

    // Init
    loadBanners();
  </script>
</Layout>
