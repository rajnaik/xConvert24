---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Banner Management — Admin — ScrabbleWordsFinder" description="Manage banner rotation pool for ScrabbleWordsFinder.com" keywords="admin, banner, branding, rotation">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/report/" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/ops/" class="hover:text-blue-400 transition-colors">Ops</a>
      <a href="/admin/banner-management/" class="text-blue-400 font-medium">Banner</a>
      <a href="/admin/banner-clicks/" class="hover:text-blue-400 transition-colors">Clicks</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">🖼️ Banner Management</h1>
    <p class="text-gray-400 mb-8">Toggle banners active or inactive. All active banners participate in rotation — one is randomly selected on each page load.</p>

    <!-- Rotation pool summary -->
    <div id="rotation-summary" class="mb-6 rounded-xl border border-purple-800 bg-purple-950/30 p-4 flex items-center gap-4">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-purple-600 flex items-center justify-center">
          <span class="text-white font-bold text-lg" id="active-count">—</span>
        </div>
        <div>
          <p class="text-purple-300 text-sm font-medium">Banners in rotation</p>
          <p class="text-gray-400 text-xs" id="rotation-info">Loading...</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" id="banner-grid">

      <!-- Banner 1 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="1">
        <img src="/banner-options/banner-1.svg" alt="Banner option 1" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 1</h3>
            <p class="text-xs text-gray-400">Classic — board left, title center, scattered tiles right</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="1">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 2 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="2">
        <img src="/banner-options/banner-2.svg" alt="Banner option 2" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
