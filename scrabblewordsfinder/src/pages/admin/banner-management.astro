      <!-- Banner 5 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="5">
        <img src="/banner-options/banner-5.svg" alt="Banner option 5" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 5</h3>
            <p class="text-xs text-gray-400">Rack focus — tiles inside glass, rack at bottom with holder</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="5">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 6 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="6">
        <img src="/banner-options/banner-6.svg" alt="Banner option 6" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 6</h3>
            <p class="text-xs text-gray-400">Crossword — PLAY/WORDS intersection, spotlight glow, badge</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="6">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 7 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="7">
        <img src="/banner-options/banner-7.svg" alt="Banner option 7" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 7</h3>
            <p class="text-xs text-gray-400">Dual glass — overlapping magnifiers, score display, gold tiles</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="7">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 8 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="8">
        <img src="/banner-options/banner-8.svg" alt="Banner option 8" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 8</h3>
            <p class="text-xs text-gray-400">Symmetric — centered glass top, flanking tiles, wave bottom</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="8">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 9 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="9">
        <img src="/banner-options/banner-9.svg" alt="Banner option 9" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 9</h3>
            <p class="text-xs text-gray-400">Isometric — skewed board, "SCRABBLE" header, pill badges</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="9">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
            <span class="ml-2 text-xs font-medium text-gray-400 toggle-label">Inactive</span>
          </label>
        </div>
      </div>

      <!-- Banner 10 -->
      <div class="banner-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-4 transition-all" data-option="10">
        <img src="/banner-options/banner-10.svg" alt="Banner option 10" class="w-full h-auto rounded-lg mb-3" />
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-white">Banner 10</h3>
            <p class="text-xs text-gray-400">Grand — tiles arc, large central glass with board inside, orbs</p>
          </div>
          <label class="banner-toggle relative inline-flex items-center cursor-pointer" data-option="10">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
