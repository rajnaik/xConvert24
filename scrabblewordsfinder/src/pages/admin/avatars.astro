---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Avatars — Admin" description="Manage user avatars, display names, and profiles" keywords="admin, avatars, users, profiles">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/users/" class="hover:text-blue-400 transition-colors">Users</a>
      <a href="/admin/avatars/" class="text-teal-400 font-medium">Avatars</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-white mb-2">🎭 Avatar Management</h1>
    <p class="text-gray-400 mb-6">View and manage user avatars, display names, and profile data. Full CRUD on the <code class="text-teal-400">users</code> table.</p>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-teal-400" id="stat-total">—</p>
        <p class="text-xs text-gray-400">Total Users</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-blue-400" id="stat-avatars">50</p>
        <p class="text-xs text-gray-400">Available Avatars</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-purple-400" id="stat-returning">—</p>
        <p class="text-xs text-gray-400">Multi-Visit Users</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 text-center">
        <p class="text-2xl font-bold text-amber-400" id="stat-today">—</p>
        <p class="text-xs text-gray-400">Registered Today</p>
      </div>
    </div>

    <!-- Search + Controls -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-6">
      <div class="relative flex-1 w-full">
        <input id="search-input" type="text" placeholder="Search by name, city, country, or user ID..." class="h-10 w-full pl-10 pr-4 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-teal-500" />
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      <button id="refresh-btn" class="px-4 py-2 rounded-lg bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium transition-colors">Refresh</button>
    </div>

    <!-- Users Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-800 bg-gray-900/50">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800 text-left">
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Avatar</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Display Name</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">User ID</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Location</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Device</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Visits</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Last Seen</th>
            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase">Actions</th>
          </tr>
        </thead>

        <tbody id="users-tbody">
          <tr><td colspan="8" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4">
      <p class="text-xs text-gray-500" id="pagination-info">—</p>
      <div class="flex gap-2">
        <button id="prev-btn" class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-400 hover:border-teal-600 disabled:opacity-40 disabled:cursor-not-allowed" disabled>← Prev</button>
        <button id="next-btn" class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-400 hover:border-teal-600 disabled:opacity-40 disabled:cursor-not-allowed" disabled>Next →</button>
      </div>
    </div>

    <!-- Avatar Usage Count Panel -->
    <div class="mt-8">
      <button id="avatar-usage-toggle" class="w-full flex items-center justify-between px-5 py-3 rounded-xl border border-purple-500/30 bg-purple-950/10 hover:bg-purple-950/20 transition-colors group">
        <div class="flex items-center gap-2">
          <span class="text-purple-400 text-base">📊</span>
          <span class="text-sm font-semibold text-purple-400 group-hover:text-purple-300 transition-colors">Avatar Usage Count</span>
          <span class="text-xs text-gray-500">— Click an avatar to see user IDs</span>
        </div>
        <svg id="avatar-usage-chevron" class="w-4 h-4 text-purple-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="avatar-usage-content" class="hidden mt-3 p-4 rounded-xl border border-gray-800 bg-gray-900/50">
        <div id="avatar-usage-grid" class="grid grid-cols-5 sm:grid-cols-10 gap-3">
          <p class="col-span-full text-xs text-gray-500">Loading...</p>
        </div>
        <!-- User IDs drill-down panel -->
        <div id="avatar-users-panel" class="hidden mt-4 p-4 rounded-xl border border-purple-500/30 bg-purple-950/10">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <img id="avatar-users-img" src="/avatars/avatar-1.svg" class="w-8 h-8 rounded-full border border-purple-500" alt="" />
              <span id="avatar-users-title" class="text-sm font-semibold text-purple-300">Avatar 1 — 0 users</span>
            </div>
            <button id="avatar-users-close" class="text-gray-400 hover:text-white text-lg leading-none">&times;</button>
          </div>
          <div id="avatar-users-list" class="max-h-48 overflow-y-auto space-y-1">
            <p class="text-xs text-gray-500">Loading...</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="w-full max-w-lg mx-4 rounded-2xl border border-gray-700 bg-gray-900 p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-white">Edit User</h2>
        <button id="modal-close" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
      </div>

      <!-- Avatar Preview -->
      <div class="flex items-center gap-4 mb-6 p-4 rounded-xl bg-gray-800/60 border border-gray-700">
        <img id="modal-avatar-img" src="/avatars/avatar-1.svg" alt="Avatar" class="h-16 w-16 rounded-full border-2 border-teal-500" />
        <div>
          <p class="text-white font-medium" id="modal-display-name">—</p>
          <p class="text-xs text-gray-400" id="modal-user-id-display">—</p>
        </div>
      </div>

      <input type="hidden" id="modal-user-id" />

      <div class="space-y-4">
        <!-- Display Name -->
        <div>
          <label class="block text-xs text-gray-400 mb-1">Display Name</label>
          <div class="flex gap-2">
            <input id="modal-name-input" type="text" class="flex-1 h-9 px-3 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-teal-500" />
            <button id="modal-regen-name" class="px-3 py-1 rounded-lg bg-purple-600/30 border border-purple-600/50 text-xs text-purple-300 hover:bg-purple-600/50 transition-colors" title="Generate new random name">🎲</button>
          </div>
        </div>

        <!-- Avatar ID -->
        <div>
          <label class="block text-xs text-gray-400 mb-1">Avatar ID (1-50)</label>
          <div class="flex gap-2">
            <input id="modal-avatar-input" type="number" min="1" max="50" class="w-24 h-9 px-3 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-teal-500" />
            <button id="modal-regen-avatar" class="px-3 py-1 rounded-lg bg-amber-600/30 border border-amber-600/50 text-xs text-amber-300 hover:bg-amber-600/50 transition-colors" title="Randomize avatar + name">🔀 Random</button>
          </div>
          <!-- Avatar Grid Preview -->
          <div id="avatar-grid" class="mt-3 grid grid-cols-10 gap-1.5 max-h-32 overflow-y-auto p-2 rounded-lg bg-gray-800/40 border border-gray-700/50">
          </div>
        </div>

        <!-- Message -->
        <div>
          <label class="block text-xs text-gray-400 mb-1">Message (optional)</label>
          <textarea id="modal-message" rows="2" maxlength="1000" class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-teal-500 resize-none"></textarea>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-700">
        <button id="modal-delete" class="px-4 py-2 rounded-lg bg-red-600/20 border border-red-600/50 text-sm text-red-400 hover:bg-red-600/40 transition-colors">Delete User</button>
        <div class="flex gap-2">
          <button id="modal-cancel" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-white transition-colors">Cancel</button>
          <button id="modal-save" class="px-4 py-2 rounded-lg bg-teal-600 hover:bg-teal-700 text-sm text-white font-medium transition-colors">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 z-50 hidden rounded-xl border border-gray-700 bg-gray-900 px-5 py-3 shadow-2xl">
    <p id="toast-msg" class="text-sm text-white"></p>
  </div>

  <!-- View Modal (read-only, all fields) -->
  <div id="view-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="w-full max-w-2xl mx-4 rounded-2xl border border-gray-700 bg-gray-900 p-6 shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-white">👁️ User Details</h2>
        <button id="view-modal-close" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
      </div>

      <!-- Avatar + Name Header -->
      <div class="flex items-center gap-4 mb-6 p-4 rounded-xl bg-gray-800/60 border border-gray-700">
        <img id="view-avatar-img" src="/avatars/avatar-1.svg" alt="Avatar" class="h-16 w-16 rounded-full border-2 border-blue-500" />
        <div>
          <p class="text-white font-medium text-lg" id="view-display-name">—</p>
          <p class="text-xs text-gray-400 font-mono" id="view-user-id">—</p>
        </div>
      </div>

      <!-- All Fields Grid -->
      <div id="view-fields-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <!-- Dynamically populated -->
      </div>

      <!-- Close button -->
      <div class="mt-6 pt-4 border-t border-gray-700 text-right">
        <button id="view-modal-done" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-white transition-colors">Close</button>
      </div>
    </div>
  </div>

  <script is:inline>
    var PAGE_SIZE = 20;
    var currentOffset = 0;
    var totalUsers = 0;
    var searchQuery = '';
    var debounceTimer = null;

    function showToast(msg, type) {
      var toast = document.getElementById('toast');
      var toastMsg = document.getElementById('toast-msg');
      toastMsg.textContent = msg;
      toast.className = 'fixed bottom-6 right-6 z-50 rounded-xl border px-5 py-3 shadow-2xl ' +
        (type === 'error' ? 'border-red-700 bg-red-900/80' : 'border-teal-700 bg-teal-900/80');
      toast.classList.remove('hidden');
      setTimeout(function() { toast.classList.add('hidden'); }, 3000);
    }

    function formatDate(dateStr) {
      if (!dateStr) return '—';
      var d = new Date(dateStr.includes('Z') ? dateStr : dateStr + 'Z');
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: '2-digit' }) + ' ' +
             d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function renderAvatarGrid(selectedId) {
      var grid = document.getElementById('avatar-grid');
      var html = '';
      for (var i = 1; i <= 50; i++) {
        var selected = i === selectedId ? 'ring-2 ring-teal-400 scale-110' : 'opacity-60 hover:opacity-100';
        html += '<img src="/avatars/avatar-' + i + '.svg" data-avatar-id="' + i + '" class="w-7 h-7 rounded-full cursor-pointer transition-all ' + selected + '" title="Avatar ' + i + '" />';
      }
      grid.innerHTML = html;

      // Click handler for avatar selection
      grid.querySelectorAll('img').forEach(function(img) {
        img.addEventListener('click', function() {
          var id = parseInt(this.dataset.avatarId);
          document.getElementById('modal-avatar-input').value = id;
          document.getElementById('modal-avatar-img').src = '/avatars/avatar-' + id + '.svg';
          renderAvatarGrid(id);
        });
      });
    }

    async function loadUsers() {
      try {
        var url = '/api/users/admin/?limit=' + PAGE_SIZE + '&offset=' + currentOffset;
        if (searchQuery) url += '&search=' + encodeURIComponent(searchQuery);

        var res = await fetch(url);
        if (!res.ok) throw new Error('Failed to load');
        var data = await res.json();

        totalUsers = data.total;
        var users = data.users || [];

        // Stats
        document.getElementById('stat-total').textContent = totalUsers;
        var returning = users.filter(function(u) { return u.visit_count > 1; }).length;
        document.getElementById('stat-returning').textContent = returning;
        var today = new Date().toISOString().slice(0, 10);
        var todayCount = users.filter(function(u) { return u.created_at && u.created_at.startsWith(today); }).length;
        document.getElementById('stat-today').textContent = todayCount;

        // Avatar Usage Count
        var avatarUsage = data.avatar_usage || [];
        var usageGrid = document.getElementById('avatar-usage-grid');
        if (avatarUsage.length > 0) {
          usageGrid.innerHTML = avatarUsage.map(function(a) {
            var count = a.count || 0;
            var intensity = count === 0 ? 'opacity-40' : count >= 5 ? 'ring-2 ring-purple-400' : '';
            return '<div class="flex flex-col items-center gap-1 p-2 rounded-lg bg-gray-800/40 border border-gray-700/50 cursor-pointer hover:border-purple-400 hover:bg-purple-950/20 transition-all ' + intensity + '" data-avatar-usage-id="' + a.avatar_id + '" data-avatar-count="' + count + '">' +
              '<img src="/avatars/avatar-' + a.avatar_id + '.svg" class="w-8 h-8 rounded-full pointer-events-none" alt="Avatar ' + a.avatar_id + '" />' +
              '<span class="text-xs font-bold pointer-events-none ' + (count >= 5 ? 'text-purple-400' : count > 0 ? 'text-gray-300' : 'text-gray-600') + '">' + count + '</span>' +
            '</div>';
          }).join('');
          // Fill in missing avatars (those with 0 users won't appear in GROUP BY)
          var usedIds = avatarUsage.map(function(a) { return a.avatar_id; });
          var missingHtml = '';
          for (var i = 1; i <= 50; i++) {
            if (usedIds.indexOf(i) === -1) {
              missingHtml += '<div class="flex flex-col items-center gap-1 p-2 rounded-lg bg-gray-800/40 border border-gray-700/50 cursor-pointer hover:border-purple-400 hover:bg-purple-950/20 transition-all opacity-40" data-avatar-usage-id="' + i + '" data-avatar-count="0">' +
                '<img src="/avatars/avatar-' + i + '.svg" class="w-8 h-8 rounded-full pointer-events-none" alt="Avatar ' + i + '" />' +
                '<span class="text-xs font-bold text-gray-600 pointer-events-none">0</span>' +
              '</div>';
            }
          }
          usageGrid.innerHTML += missingHtml;

          // Attach click handlers to avatar usage tiles
          usageGrid.querySelectorAll('[data-avatar-usage-id]').forEach(function(tile) {
            tile.addEventListener('click', function() {
              var avatarId = parseInt(this.dataset.avatarUsageId);
              var count = parseInt(this.dataset.avatarCount);
              showAvatarUsers(avatarId, count);
            });
          });
        }

        // Table
        var tbody = document.getElementById('users-tbody');
        if (users.length === 0) {
          tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-gray-500">No users found.</td></tr>';
        } else {
          tbody.innerHTML = users.map(function(u) {
            var loc = [u.city, u.country].filter(Boolean).join(', ') || '—';
            var device = [u.browser, u.os, u.device_type].filter(Boolean).join(' / ') || '—';
            return '<tr class="border-b border-gray-800/50 hover:bg-gray-800/30 cursor-pointer transition-colors" data-user=\'' + JSON.stringify(u).replace(/'/g, '&#39;') + '\'>' +
              '<td class="px-4 py-3"><img src="/avatars/avatar-' + (u.avatar_id || 1) + '.svg" class="h-9 w-9 rounded-full border border-gray-700" alt="Avatar ' + u.avatar_id + '" /></td>' +
              '<td class="px-4 py-3 font-medium text-white">' + (u.display_name || '—') + '</td>' +
              '<td class="px-4 py-3 font-mono text-xs text-gray-500">' + (u.user_id || '').slice(0, 12) + '...</td>' +
              '<td class="px-4 py-3 text-gray-400 text-xs">' + loc + '</td>' +
              '<td class="px-4 py-3 text-gray-400 text-xs">' + device + '</td>' +
              '<td class="px-4 py-3 text-gray-300">' + (u.visit_count || 1) + '</td>' +
              '<td class="px-4 py-3 text-gray-400 text-xs">' + formatDate(u.last_seen) + '</td>' +
              '<td class="px-4 py-3"><button class="edit-btn px-2 py-1 rounded bg-teal-600/20 border border-teal-600/40 text-xs text-teal-300 hover:bg-teal-600/40">Edit</button> <button class="view-btn px-2 py-1 rounded bg-blue-600/20 border border-blue-600/40 text-xs text-blue-300 hover:bg-blue-600/40">View</button></td>' +
            '</tr>';
          }).join('');
        }

        // Pagination
        document.getElementById('pagination-info').textContent = 'Showing ' + (currentOffset + 1) + '-' + Math.min(currentOffset + PAGE_SIZE, totalUsers) + ' of ' + totalUsers;
        document.getElementById('prev-btn').disabled = currentOffset === 0;
        document.getElementById('next-btn').disabled = currentOffset + PAGE_SIZE >= totalUsers;

        // Row click handlers
        tbody.querySelectorAll('tr[data-user]').forEach(function(row) {
          row.addEventListener('click', function(e) {
            if (e.target.closest('.edit-btn')) {
              openEditModal(JSON.parse(this.dataset.user));
            } else if (e.target.closest('.view-btn')) {
              openViewModal(JSON.parse(this.dataset.user));
            }
          });
        });
      } catch (err) {
        document.getElementById('users-tbody').innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-red-400">Error loading users: ' + err.message + '</td></tr>';
      }
    }

    function openEditModal(user) {
      document.getElementById('edit-modal').classList.remove('hidden');
      document.getElementById('edit-modal').classList.add('flex');
      document.getElementById('modal-user-id').value = user.user_id;
      document.getElementById('modal-user-id-display').textContent = user.user_id;
      document.getElementById('modal-display-name').textContent = user.display_name;
      document.getElementById('modal-name-input').value = user.display_name || '';
      document.getElementById('modal-avatar-input').value = user.avatar_id || 1;
      document.getElementById('modal-avatar-img').src = '/avatars/avatar-' + (user.avatar_id || 1) + '.svg';
      document.getElementById('modal-message').value = user.message || '';
      renderAvatarGrid(user.avatar_id || 1);
    }

    function openViewModal(user) {
      document.getElementById('view-modal').classList.remove('hidden');
      document.getElementById('view-modal').classList.add('flex');
      document.getElementById('view-avatar-img').src = '/avatars/avatar-' + (user.avatar_id || 1) + '.svg';
      document.getElementById('view-display-name').textContent = user.display_name || '—';
      document.getElementById('view-user-id').textContent = user.user_id || '—';

      var fields = [
        { label: 'Avatar ID', value: user.avatar_id || '—' },
        { label: 'Message', value: user.message || '—' },
        { label: 'IP Address', value: user.ip_address || '—' },
        { label: 'Country', value: user.country || '—' },
        { label: 'City', value: user.city || '—' },
        { label: 'Region', value: user.region || '—' },
        { label: 'Latitude', value: user.latitude != null ? user.latitude : '—' },
        { label: 'Longitude', value: user.longitude != null ? user.longitude : '—' },
        { label: 'Timezone', value: user.timezone || '—' },
        { label: 'User Agent', value: user.user_agent || '—' },
        { label: 'Browser', value: user.browser || '—' },
        { label: 'OS', value: user.os || '—' },
        { label: 'Device Type', value: user.device_type || '—' },
        { label: 'Language', value: user.language || '—' },
        { label: 'Referrer', value: user.referrer || '—' },
        { label: 'Screen', value: (user.screen_width && user.screen_height) ? user.screen_width + ' × ' + user.screen_height : '—' },
        { label: 'Viewport', value: (user.viewport_width && user.viewport_height) ? user.viewport_width + ' × ' + user.viewport_height : '—' },
        { label: 'Visit Count', value: user.visit_count || 1 },
        { label: 'Last Seen', value: formatDate(user.last_seen) },
        { label: 'Created At', value: formatDate(user.created_at) },
      ];

      var grid = document.getElementById('view-fields-grid');
      grid.innerHTML = fields.map(function(f) {
        var val = String(f.value);
        var isLong = val.length > 40;
        return '<div class="p-3 rounded-lg bg-gray-800/60 border border-gray-700/50' + (isLong ? ' sm:col-span-2' : '') + '">' +
          '<p class="text-[10px] uppercase tracking-wider text-gray-500 mb-1">' + f.label + '</p>' +
          '<p class="text-sm text-gray-200 break-all">' + (val || '—') + '</p>' +
        '</div>';
      }).join('');
    }

    function closeViewModal() {
      document.getElementById('view-modal').classList.add('hidden');
      document.getElementById('view-modal').classList.remove('flex');
    }

    function closeModal() {
      document.getElementById('edit-modal').classList.add('hidden');
      document.getElementById('edit-modal').classList.remove('flex');
    }

    async function showAvatarUsers(avatarId, count) {
      var panel = document.getElementById('avatar-users-panel');
      var title = document.getElementById('avatar-users-title');
      var img = document.getElementById('avatar-users-img');
      var list = document.getElementById('avatar-users-list');

      img.src = '/avatars/avatar-' + avatarId + '.svg';
      title.textContent = 'Avatar ' + avatarId + ' — ' + count + ' user' + (count !== 1 ? 's' : '');
      panel.classList.remove('hidden');

      if (count === 0) {
        list.innerHTML = '<p class="text-xs text-gray-500 italic">No users have this avatar.</p>';
        return;
      }

      list.innerHTML = '<p class="text-xs text-gray-500">Loading...</p>';

      try {
        var res = await fetch('/api/users/admin/?avatar_id=' + avatarId + '&limit=100&offset=0');
        if (!res.ok) throw new Error('Failed to load');
        var data = await res.json();
        var users = data.users || [];

        if (users.length === 0) {
          list.innerHTML = '<p class="text-xs text-gray-500 italic">No users found.</p>';
          return;
        }

        list.innerHTML = users.map(function(u) {
          var loc = [u.city, u.country].filter(Boolean).join(', ');
          return '<div class="flex items-center justify-between px-3 py-2 rounded-lg bg-gray-800/40 border border-gray-700/50 hover:border-gray-600 transition-colors">' +
            '<div class="flex items-center gap-2 min-w-0">' +
              '<span class="text-xs font-medium text-white truncate">' + (u.display_name || '—') + '</span>' +
              '<span class="text-[10px] font-mono text-gray-500 break-all select-all">' + (u.user_id || '') + '</span>' +
            '</div>' +
            '<div class="flex items-center gap-3 text-[10px] text-gray-500 shrink-0 ml-2">' +
              (loc ? '<span>' + loc + '</span>' : '') +
              '<span>' + (u.visit_count || 1) + ' visits</span>' +
            '</div>' +
          '</div>';
        }).join('');
      } catch (err) {
        list.innerHTML = '<p class="text-xs text-red-400">Error: ' + err.message + '</p>';
      }
    }

    // Event Listeners
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-cancel').addEventListener('click', closeModal);
    document.getElementById('edit-modal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    // View Modal listeners
    document.getElementById('view-modal-close').addEventListener('click', closeViewModal);
    document.getElementById('view-modal-done').addEventListener('click', closeViewModal);
    document.getElementById('view-modal').addEventListener('click', function(e) {
      if (e.target === this) closeViewModal();
    });

    // Avatar Usage toggle
    document.getElementById('avatar-usage-toggle').addEventListener('click', function() {
      var content = document.getElementById('avatar-usage-content');
      var chevron = document.getElementById('avatar-usage-chevron');
      content.classList.toggle('hidden');
      chevron.style.transform = content.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });

    // Avatar Users panel close
    document.getElementById('avatar-users-close').addEventListener('click', function() {
      document.getElementById('avatar-users-panel').classList.add('hidden');
    });

    document.getElementById('refresh-btn').addEventListener('click', function() { loadUsers(); });
    document.getElementById('prev-btn').addEventListener('click', function() {
      currentOffset = Math.max(0, currentOffset - PAGE_SIZE);
      loadUsers();
    });
    document.getElementById('next-btn').addEventListener('click', function() {
      currentOffset += PAGE_SIZE;
      loadUsers();
    });

    document.getElementById('search-input').addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var val = this.value.trim();
      debounceTimer = setTimeout(function() {
        searchQuery = val;
        currentOffset = 0;
        loadUsers();
      }, 300);
    });

    // Save changes
    document.getElementById('modal-save').addEventListener('click', async function() {
      var userId = document.getElementById('modal-user-id').value;
      var displayName = document.getElementById('modal-name-input').value.trim();
      var avatarId = parseInt(document.getElementById('modal-avatar-input').value);
      var message = document.getElementById('modal-message').value.trim();

      if (!displayName) { showToast('Display name cannot be empty', 'error'); return; }
      if (avatarId < 1 || avatarId > 50) { showToast('Avatar ID must be 1-50', 'error'); return; }

      try {
        var res = await fetch('/api/users/admin/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, display_name: displayName, avatar_id: avatarId, message: message })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Update failed');
        showToast('User updated: ' + displayName, 'success');
        closeModal();
        loadUsers();
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    // Regenerate name
    document.getElementById('modal-regen-name').addEventListener('click', async function() {
      var userId = document.getElementById('modal-user-id').value;
      try {
        var res = await fetch('/api/users/admin/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, action: 'regenerate_name' })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        document.getElementById('modal-name-input').value = data.display_name;
        document.getElementById('modal-display-name').textContent = data.display_name;
        showToast('Name regenerated: ' + data.display_name, 'success');
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    // Randomize avatar
    document.getElementById('modal-regen-avatar').addEventListener('click', async function() {
      var userId = document.getElementById('modal-user-id').value;
      try {
        var res = await fetch('/api/users/admin/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, action: 'randomize_avatar' })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        document.getElementById('modal-avatar-input').value = data.avatar_id;
        document.getElementById('modal-avatar-img').src = '/avatars/avatar-' + data.avatar_id + '.svg';
        document.getElementById('modal-name-input').value = data.display_name;
        document.getElementById('modal-display-name').textContent = data.display_name;
        renderAvatarGrid(data.avatar_id);
        showToast('Avatar randomized: ' + data.display_name, 'success');
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    // Delete user
    document.getElementById('modal-delete').addEventListener('click', async function() {
      var userId = document.getElementById('modal-user-id').value;
      if (!confirm('Delete this user permanently? This cannot be undone.')) return;
      try {
        var res = await fetch('/api/users/admin/', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Delete failed');
        showToast('User deleted', 'success');
        closeModal();
        loadUsers();
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    // Avatar input change — live preview
    document.getElementById('modal-avatar-input').addEventListener('input', function() {
      var id = parseInt(this.value);
      if (id >= 1 && id <= 50) {
        document.getElementById('modal-avatar-img').src = '/avatars/avatar-' + id + '.svg';
        renderAvatarGrid(id);
      }
    });

    // Initial load
    loadUsers();
  </script>
</Layout>
