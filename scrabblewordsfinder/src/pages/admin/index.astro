---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Admin — ScrabbleWordsFinder" description="Admin dashboard for ScrabbleWordsFinder.com" keywords="admin, dashboard, scrabble word finder">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="text-blue-400 font-medium">Admin</a>
      <a href="/admin/report" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/ops" class="hover:text-blue-400 transition-colors">Ops</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">🛠️ Admin Dashboard</h1>
    <p class="text-gray-400 mb-8">Manage tasks, view reports, and run operations.</p>

    <!-- Site Status Widget -->
    <div id="site-status-widget" class="mb-8 rounded-xl border border-gray-800 bg-gray-900/50 p-6">
      <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
        <span id="status-indicator" class="inline-block w-3 h-3 rounded-full bg-gray-600 animate-pulse"></span>
        Site Status
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <!-- Status -->
        <div class="rounded-lg bg-gray-800/60 p-4">
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Status</p>
          <p class="text-lg font-bold" id="widget-status">—</p>
        </div>
        <!-- Active Logo -->
        <div class="rounded-lg bg-gray-800/60 p-4 flex items-center gap-3">
          <img id="widget-logo-img" src="/logo-options/option-1.svg" alt="Active logo" class="h-10 w-10 rounded bg-gray-700 p-0.5" />
          <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Active Logo</p>
            <p class="text-sm font-medium text-white" id="widget-logo-label">—</p>
          </div>
        </div>
        <!-- Last Updated -->
        <div class="rounded-lg bg-gray-800/60 p-4">
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Last Updated</p>
          <p class="text-sm text-gray-300" id="widget-updated">—</p>
          <p class="text-xs text-gray-500 mt-0.5" id="widget-updated-by"></p>
        </div>
      </div>
    </div>

    <!-- TODO: Add Google Authentication to this admin section -->

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Reports Card -->
      <a href="/admin/report" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">📊 Reports</h2>
        <p class="text-gray-400 text-sm">Task management, CRUD operations, and data views.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Tasks — create, edit, delete, view</li>
          <li>• Status tracking</li>
          <li>• Category filtering</li>
        </ul>
      </a>

      <!-- Ops Card -->
      <a href="/admin/ops" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-purple-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-purple-400 transition-colors">⚙️ Ops</h2>
        <p class="text-gray-400 text-sm">Operational tools, monitoring, and system commands.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• System health</li>
          <li>• Database stats</li>
          <li>• Deployment actions</li>
        </ul>
      </a>

      <!-- Logo Management Card -->
      <a href="/admin/logo-management" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-amber-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-amber-400 transition-colors">🎨 Logo Management</h2>
        <p class="text-gray-400 text-sm">Select and manage the active website logo.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• 5 logo options to choose from</li>
          <li>• Database-backed selection</li>
          <li>• Instant site-wide update</li>
        </ul>
      </a>

      <!-- Banner Management Card -->
      <a href="/admin/banner-management" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-purple-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-purple-400 transition-colors">🖼️ Banner Management</h2>
        <p class="text-gray-400 text-sm">Select the active hero banner for the site.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• 10 artistic banner options</li>
          <li>• Database-backed selection</li>
          <li>• Homepage + blog headers</li>
        </ul>
      </a>

      <!-- Environments Card -->
      <a href="/admin/environments" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-indigo-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-indigo-400 transition-colors">🌐 Environments</h2>
        <p class="text-gray-400 text-sm">Dev, Staging and Live environment URLs and status.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Dev / Staging / Live URLs</li>
          <li>• Live status check</li>
          <li>• DB identifiers</li>
        </ul>
      </a>
      <!-- Click Analysis Card -->
      <a href="/admin/clicks-analysis" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-violet-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-violet-400 transition-colors">🫧 Click Analysis</h2>
        <p class="text-gray-400 text-sm">Visual bubble chart of all clicks — by element, page, country, device.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Bubble size = click count</li>
          <li>• 5 view modes (element, page, country, device, browser)</li>
          <li>• Rich tooltip on hover</li>
        </ul>
      </a>
      <!-- Telemetry Card -->
      <a href="/admin/telemetry" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-cyan-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-cyan-400 transition-colors">📡 Telemetry</h2>
        <p class="text-gray-400 text-sm">Live site health — endpoint response times and status checks.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• All endpoints monitored</li>
          <li>• Response time tracking</li>
          <li>• Auto-refresh every 5s</li>
        </ul>
      </a>
      <!-- SEO Index Card -->
      <a href="/admin/seo" class="block rounded-xl border border-emerald-800/50 bg-gray-900/50 p-6 hover:border-emerald-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">📈 SEO Index</h2>
        <p class="text-gray-400 text-sm">Track Google indexing status — which pages are indexed, discovered, or excluded.</p>
        <div id="seo-stats" class="mt-3 grid grid-cols-5 gap-2 text-center">
          <div><p class="text-sm font-bold text-green-400" id="seo-s-indexed">-</p><p class="text-[10px] text-gray-500">Indexed</p></div>
          <div><p class="text-sm font-bold text-amber-400" id="seo-s-discovered">-</p><p class="text-[10px] text-gray-500">Discovered</p></div>
          <div><p class="text-sm font-bold text-red-400" id="seo-s-not_indexed">-</p><p class="text-[10px] text-gray-500">Not Indexed</p></div>
          <div><p class="text-sm font-bold text-gray-400" id="seo-s-excluded">-</p><p class="text-[10px] text-gray-500">Excluded</p></div>
          <div><p class="text-sm font-bold text-purple-400" id="seo-s-total">-</p><p class="text-[10px] text-gray-500">Total</p></div>
        </div>
      </a>
      <!-- Emails Card -->
      <a href="/admin/emails" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">�� Emails</h2>
        <p class="text-gray-400 text-sm">View and manage contact form and suggestion submissions.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Contact + suggestion emails in one place</li>
          <li>• Mark read, add comments, action items</li>
          <li>• Filter by category and status</li>
        </ul>
      </a>
      <!-- Release Train Card -->
      <a href="/admin/release-train" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-blue-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">🚂 Release Train</h2>
        <p class="text-gray-400 text-sm">Build and order your release pipeline from steering commands.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Select from available commands</li>
          <li>• Reorder the pipeline</li>
          <li>• Copy to clipboard for execution</li>
        </ul>
      </a>
      <!-- Memory Workbench Card -->
      <a href="/admin/saved-words" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-green-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-green-400 transition-colors">📝 Memory Workbench</h2>
        <p class="text-gray-400 text-sm">View all memory workbench grouped by user.</p>
        <p class="mt-2 text-green-400 font-medium text-sm" id="saved-words-stats"></p>
      </a>
      <!-- Clicks Card -->
      <a href="/admin/clicks" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-emerald-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">📊 Clicks</h2>
        <p class="text-gray-400 text-sm">View all UI click events across the site.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Full click event log (read-only)</li>
          <li>• Filter by user, element, URL</li>
          <li>• IP + timestamp tracking</li>
        </ul>
      </a>
      <!-- Banner Clicks Card -->
      <a href="/admin/banner-clicks" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-pink-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-pink-400 transition-colors">🖱️ Banner Clicks</h2>
        <p class="text-gray-400 text-sm">View banner click analytics and randomize the active banner.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Click event table (view mode)</li>
          <li>• Randomize banner_id on click</li>
          <li>• IP, referrer, page tracking</li>
        </ul>
      </a>
      <!-- Blog Tasks Card -->
      <a href="/admin/blog-tasks" class="block rounded-xl border border-gray-800 bg-gray-900/50 p-6 hover:border-orange-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-orange-400 transition-colors">📝 Blog Tasks</h2>
        <p class="text-gray-400 text-sm">Manage the blog content pipeline — 200 blog ideas tracked.</p>
        <ul class="mt-3 space-y-1 text-xs text-gray-500">
          <li>• Full CRUD on blog_ideas table</li>
          <li>• Filter by category, status, ready_status</li>
          <li>• Assign agents, track progress</li>
        </ul>
      </a>
    </div>

    <!-- Activities Section -->
    <h2 class="text-xl font-semibold text-white mt-10 mb-4 flex items-center gap-2">🎯 Activities</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/admin/wotd" class="block rounded-xl border border-purple-800/50 bg-gray-900/50 p-6 hover:border-purple-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-purple-400 transition-colors">📖 Word of the Day</h2>
        <p class="text-gray-400 text-sm">View all WOTD words, assignments, and rotation queue.</p>
        <div id="wotd-admin-stats" class="mt-3 grid grid-cols-3 gap-2 text-center">
          <div><p class="text-sm font-bold text-purple-400" id="wotd-a-total">-</p><p class="text-[10px] text-gray-500">Total Words</p></div>
          <div><p class="text-sm font-bold text-green-400" id="wotd-a-assigned">-</p><p class="text-[10px] text-gray-500">Assigned</p></div>
          <div><p class="text-sm font-bold text-gray-400" id="wotd-a-queued">-</p><p class="text-[10px] text-gray-500">Queued</p></div>
        </div>
      </a>
      <a href="/admin/quiz-practice" class="block rounded-xl border border-blue-800/50 bg-gray-900/50 p-6 hover:border-blue-700 transition-colors group">
        <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">🧠 Word Quiz & Practice</h2>
        <p class="text-gray-400 text-sm">Quiz scores, practice sessions, and user engagement stats.</p>
        <div id="quiz-admin-stats" class="mt-3 grid grid-cols-3 gap-2 text-center">
          <div><p class="text-sm font-bold text-blue-400" id="quiz-a-total">-</p><p class="text-[10px] text-gray-500">Quizzes</p></div>
          <div><p class="text-sm font-bold text-green-400" id="quiz-a-practice">-</p><p class="text-[10px] text-gray-500">Practice</p></div>
          <div><p class="text-sm font-bold text-amber-400" id="quiz-a-users">-</p><p class="text-[10px] text-gray-500">Users</p></div>
        </div>
      </a>
    </div>

  </div>

  <script>
    const statusColors: Record<string, string> = {
      golden: 'bg-yellow-400',
      green: 'bg-green-400',
      red: 'bg-red-500',
    };

    const statusLabels: Record<string, string> = {
      golden: '🏆 Golden',
      green: '✅ Green',
      red: '🔴 Red',
    };

    async function loadSiteStatus() {
      try {
        const res = await fetch('/api/site-status');
        if (!res.ok) throw new Error('Failed');
        const data = await res.json();

        // Status indicator
        const indicator = document.getElementById('status-indicator')!;
        indicator.classList.remove('bg-gray-600', 'animate-pulse');
        indicator.classList.add(statusColors[data.status] || 'bg-gray-600');

        // Status text
        const statusEl = document.getElementById('widget-status')!;
        statusEl.textContent = statusLabels[data.status] || data.status;
        statusEl.className = 'text-lg font-bold ' + (data.status === 'golden' ? 'text-yellow-400' : data.status === 'green' ? 'text-green-400' : 'text-red-400');

        // Logo
        const logoImg = document.getElementById('widget-logo-img') as HTMLImageElement;
        const logoLabel = document.getElementById('widget-logo-label')!;
        logoImg.src = `/logo-options/option-${data.logo_option || 1}.svg`;
        logoLabel.textContent = `Option ${data.logo_option || 1}`;

        // Updated
        const updatedEl = document.getElementById('widget-updated')!;
        const updatedByEl = document.getElementById('widget-updated-by')!;
        if (data.updated_at) {
          const d = new Date(data.updated_at + 'Z');
          updatedEl.textContent = d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        }
        if (data.updated_by) {
          updatedByEl.textContent = `by ${data.updated_by}`;
        }
      } catch {
        const statusEl = document.getElementById('widget-status')!;
        statusEl.textContent = '⚠️ Could not load';
        statusEl.className = 'text-lg font-bold text-gray-500';
      }
    }

    loadSiteStatus();
    // Load memory workbench stats for tile
    fetch("/api/saved-words").then(r => r.json()).then(d => {
      const el = document.getElementById("saved-words-stats");
      if (el) el.textContent = d.totalUsers + " users (" + d.totalWords + " words)";
    }).catch(() => {});

    // SEO Index stats
    fetch('/api/seo-index/').then(r => r.json()).then(d => {
      var counts = { indexed: 0, discovered: 0, not_indexed: 0, excluded: 0, error: 0 };
      (d.summary || []).forEach(function(s) { counts[s.status] = s.count; });
      document.getElementById('seo-s-indexed').textContent = counts.indexed;
      document.getElementById('seo-s-discovered').textContent = counts.discovered;
      document.getElementById('seo-s-not_indexed').textContent = counts.not_indexed;
      document.getElementById('seo-s-excluded').textContent = counts.excluded;
      document.getElementById('seo-s-total').textContent = d.total;
    }).catch(() => {});

    // Activities: WOTD stats
    fetch('/api/wotd/?all=true').then(r => r.json()).then(d => {
      const words = d.words || [];
      const assigned = words.filter((w: any) => w.date).length;
      document.getElementById('wotd-a-total')!.textContent = String(words.length);
      document.getElementById('wotd-a-assigned')!.textContent = String(assigned);
      document.getElementById('wotd-a-queued')!.textContent = String(words.length - assigned);
    }).catch(() => {});

    // Activities: Quiz & Practice stats
    fetch('/api/quiz-scores/').then(r => r.json()).then(d => {
      const scores = d.scores || [];
      const users = new Set(scores.map((s: any) => s.user_id)).size;
      document.getElementById('quiz-a-total')!.textContent = String(scores.length);
      document.getElementById('quiz-a-users')!.textContent = String(users);
    }).catch(() => {});
    fetch('/api/wordbench-practice/?user_id=__all__').then(r => r.json()).then(d => {
      const count = (d.records || []).length;
      document.getElementById('quiz-a-practice')!.textContent = String(count);
    }).catch(() => { document.getElementById('quiz-a-practice')!.textContent = '0'; });
  </script>
</Layout>
