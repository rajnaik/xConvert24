---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Clicks — Admin — ScrabbleWordsFinder" description="View all UI click events" keywords="admin, clicks, analytics">
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/report/" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/ops/" class="hover:text-blue-400 transition-colors">Ops</a>
      <a href="/admin/banner-management/" class="hover:text-blue-400 transition-colors">Banner</a>
      <a href="/admin/clicks/" class="text-blue-400 font-medium">Clicks</a>
      <a href="/admin/banner-clicks/" class="hover:text-blue-400 transition-colors">Banner Clicks</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">📊 Clicks</h1>
    <p class="text-gray-400 mb-6">All UI click events across the site (read-only view).</p>

    <!-- Live Sessions Panel -->
    <div class="rounded-xl border border-green-800/50 bg-green-950/20 p-4 mb-6">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
          </span>
          <h2 class="text-sm font-semibold text-green-300 uppercase tracking-wide">Live Sessions</h2>
        </div>
        <div class="flex items-center gap-2">
          <button id="heartbeat-refresh-btn" class="h-6 px-2 rounded bg-green-700 hover:bg-green-600 text-white text-xs font-medium transition-colors" title="Force refresh sessions">↻ Refresh</button>
          <span class="text-xs text-gray-500" id="heartbeat-updated">—</span>
        </div>
      </div>
      <div class="flex items-center gap-4 mb-3">
        <div class="rounded-lg bg-gray-800/60 px-4 py-2">
          <p class="text-xs text-gray-400 mb-0.5">Active Now</p>
          <p class="text-xl font-bold text-green-400" id="live-count">—</p>
        </div>
        <div class="rounded-lg bg-gray-800/60 px-4 py-2">
          <p class="text-xs text-gray-400 mb-0.5">Unique Pages</p>
          <p class="text-xl font-bold text-blue-400" id="live-pages">—</p>
        </div>
      </div>
      <div class="overflow-x-auto max-h-64 overflow-y-auto rounded-lg border border-gray-800">
        <table class="w-full text-left text-xs">
          <thead class="bg-gray-800/60 text-gray-500 uppercase sticky top-0">
            <tr>
              <th class="px-3 py-2">UID</th>
              <th class="px-3 py-2">Page</th>
              <th class="px-3 py-2">Trail</th>
              <th class="px-3 py-2">IP</th>
              <th class="px-3 py-2">Location</th>
              <th class="px-3 py-2">Last Seen</th>
            </tr>
          </thead>
          <tbody id="live-sessions-tbody" class="divide-y divide-gray-800/50 text-gray-300">
            <tr><td colspan="6" class="px-3 py-4 text-center text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Total Clicks</p>
        <p class="text-2xl font-bold text-white" id="stat-total">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Unique Elements</p>
        <p class="text-2xl font-bold text-white" id="stat-elements">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Latest Click</p>
        <p class="text-2xl font-bold text-white" id="stat-latest">—</p>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-4">
      <input id="filter-element" type="text" placeholder="Filter by UI element..." class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-48" />
      <select id="filter-limit" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="50">Last 50</option>
        <option value="100">Last 100</option>
        <option value="200">Last 200</option>
      </select>
      <button id="refresh-btn" class="h-9 px-4 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors">🔄 Refresh</button>
      <button id="sound-toggle" class="h-9 px-4 rounded-lg border border-gray-600 text-sm font-medium text-gray-300 hover:bg-gray-800 transition-colors">🔇 Sound Off</button>
      <input type="text" id="search-input" placeholder="Search all fields..." class="h-9 px-3 rounded-lg border border-gray-600 bg-gray-900 text-sm text-gray-200 w-44" />
      <button id="search-btn" class="h-9 px-4 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors">🔍</button>    </div>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-800/80 text-gray-400 text-xs uppercase">
          <tr>
            <th class="px-4 py-3">ID</th>
            <th class="px-4 py-3">User ID</th>
            <th class="px-4 py-3">UI Element</th>
            <th class="px-4 py-3">URL</th>
            <th class="px-4 py-3">IP Address</th>
            <th class="px-4 py-3">Location</th>
            <th class="px-4 py-3">Time</th>
          </tr>
        </thead>
        <tbody id="clicks-tbody" class="divide-y divide-gray-800 text-gray-300">
          <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function showToast(msg: string) {
      const existing = document.getElementById('clicks-toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.id = 'clicks-toast';
      toast.textContent = msg;
      toast.className = 'fixed bottom-6 right-6 px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium shadow-lg z-50 transition-opacity duration-300';
      document.body.appendChild(toast);
      setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
    }

    function escapeHtml(str: string): string {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function formatDate(iso: string): string {
      const d = new Date(iso + (iso.includes('Z') ? '' : 'Z'));
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) + ' ' +
             d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    async function loadClicks() {
      const limit = (document.getElementById('filter-limit') as HTMLSelectElement).value;
      const element = (document.getElementById('filter-element') as HTMLInputElement).value.trim();
      let url = `/api/clicks/?limit=${limit}`;
      if (element) url += `&ui_element=${encodeURIComponent(element)}`;

      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error('Failed to fetch');
        const data = await res.json();
        const clicks = data.clicks || [];
        const total = data.total || 0;

        // Stats
        document.getElementById('stat-total')!.textContent = String(total);
        const uniqueElements = new Set(clicks.map((c: any) => c.ui_element));
        document.getElementById('stat-elements')!.textContent = String(uniqueElements.size);
        document.getElementById('stat-latest')!.textContent = clicks.length ? formatDate(clicks[0].created_at) : '—';

        // Table
        const tbody = document.getElementById('clicks-tbody')!;
        if (!clicks.length) {
          tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">No clicks recorded yet.</td></tr>';
          return;
        }

        tbody.innerHTML = clicks.map((c: any) => {
          const loc = [c.city, c.country].filter(Boolean).join(', ') || '—';
          return `
          <tr class="hover:bg-gray-800/40 transition-colors">
            <td class="px-4 py-3 text-gray-400 font-mono text-xs">${c.id}</td>
            <td class="px-4 py-3 text-gray-300 font-mono text-xs">${escapeHtml(c.user_id || '—')}<span class="copy-uid cursor-pointer text-gray-500 hover:text-blue-400 ml-1" data-uid="${c.user_id || ''}" title="Copy">📋</span></td>
            <td class="px-4 py-3"><code class="text-emerald-300 bg-gray-800 px-1.5 py-0.5 rounded text-xs">${escapeHtml(c.ui_element)}</code></td>
            <td class="px-4 py-3 text-gray-300 text-xs max-w-[200px] truncate">${escapeHtml(c.url || '—')}</td>
            <td class="px-4 py-3 text-gray-400 font-mono text-xs">${escapeHtml(c.ip_address || '—')}</td>
            <td class="px-4 py-3 text-gray-300 text-xs">${escapeHtml(loc)}</td>
            <td class="px-4 py-3 text-gray-400 text-xs">${formatDate(c.created_at)}</td>
          </tr>
        `}).join('');
      } catch {
        document.getElementById('clicks-tbody')!.innerHTML =
          '<tr><td colspan="7" class="px-4 py-8 text-center text-red-400">⚠️ Failed to load clicks.</td></tr>';
      }
    }

    // Refresh button with visual feedback + toast
    const refreshBtn = document.getElementById('refresh-btn')!;
    refreshBtn.addEventListener('click', async () => {
      const originalText = refreshBtn.textContent;
      refreshBtn.textContent = '⏳ Refreshing...';
      refreshBtn.classList.add('opacity-60', 'pointer-events-none');
      await loadClicks();
      refreshBtn.textContent = '✅ Done';
      refreshBtn.classList.remove('opacity-60', 'pointer-events-none');
      showToast('Clicks refreshed');
      setTimeout(() => { refreshBtn.textContent = originalText; }, 1200);
    });

    document.getElementById('filter-limit')!.addEventListener('change', loadClicks);
    document.getElementById('filter-element')!.addEventListener('keyup', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') loadClicks();
    });

    // Sound toggle
    const soundBtn = document.getElementById('sound-toggle')!;
    let soundEnabled = localStorage.getItem('swf_clicks_sound') === 'on';
    let lastClickCount = 0;

    function updateSoundBtn() {
      soundBtn.textContent = soundEnabled ? '🔊 Sound On' : '🔇 Sound Off';
      soundBtn.classList.toggle('border-green-600', soundEnabled);
      soundBtn.classList.toggle('text-green-400', soundEnabled);
      soundBtn.classList.toggle('border-gray-600', !soundEnabled);
      soundBtn.classList.toggle('text-gray-300', !soundEnabled);
    }
    updateSoundBtn();

    soundBtn.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      localStorage.setItem('swf_clicks_sound', soundEnabled ? 'on' : 'off');
      updateSoundBtn();
      // Play test gong when enabling sound
      if (soundEnabled) {
        gongAudio.currentTime = 0;
        gongAudio.play().catch(() => { console.log('Audio blocked — click page first'); });
      }
    });

    // Pre-load audio element
    const gongAudio = new Audio('/media/bell-gong.wav');
    gongAudio.volume = 0.4;
    gongAudio.load();

    // Unlock audio on first user interaction with the page
    let audioUnlocked = false;
    document.addEventListener('click', () => {
      if (!audioUnlocked) {
        gongAudio.play().then(() => { gongAudio.pause(); gongAudio.currentTime = 0; }).catch(() => {});
        audioUnlocked = true;
      }
    }, { once: true });

    function playClickSound() {
      if (!soundEnabled) return;
      gongAudio.currentTime = 0;
      gongAudio.play().catch(() => {});
    }

    // Auto-poll every 2 seconds — always refresh, play sound on new clicks
    async function pollClicks() {
      try {
        const res = await fetch('/api/clicks/?count=true');
        const data = await res.json();
        const newCount = data.total || 0;
        if (lastClickCount > 0 && newCount > lastClickCount) {
          playClickSound();
        }
        if (newCount !== lastClickCount) {
          lastClickCount = newCount;
          loadClicks();
        }
      } catch {}
    }

    // Initial load + set baseline count
    (async function init() {
      try {
        await loadClicks();
      } catch (e) {
        console.error('Initial loadClicks failed:', e);
      }
      try {
        const r = await fetch('/api/clicks/?count=true');
        const d = await r.json();
        lastClickCount = d.total || 0;
      } catch {}
      // Start polling regardless of initial load success
      setInterval(pollClicks, 3000);
    })();
    // Search functionality
    document.getElementById("search-btn")!.addEventListener("click", async () => {
      const q = (document.getElementById("search-input") as HTMLInputElement).value.trim();
      if (!q) { loadClicks(); return; }
      try {
        const res = await fetch("/api/clicks/?search=" + encodeURIComponent(q));
        const data = await res.json();
        const clicks = data.clicks || [];
        const tbody = document.getElementById("clicks-tbody")!;
        if (!clicks.length) { tbody.innerHTML = "<tr><td colspan=\"6\" class=\"px-4 py-8 text-center text-gray-500\">No matches for \"" + escapeHtml(q) + "\"</td></tr>"; return; }
        document.getElementById("stat-total")!.textContent = String(clicks.length) + " results";
        // Re-render the same way as loadClicks
        tbody.innerHTML = clicks.map((c: any) => `<tr class="hover:bg-gray-800/40"><td class="px-4 py-3 text-gray-400 font-mono text-xs">${c.id}</td><td class="px-4 py-3 text-gray-300 font-mono text-xs">${escapeHtml(c.user_id || "\u2014")} <span class="copy-uid cursor-pointer text-gray-500 hover:text-blue-400 ml-1" data-uid="${c.user_id || ""}" title="Copy">\uD83D\uDCCB</span></td><td class="px-4 py-3"><code class="text-emerald-300 bg-gray-800 px-1.5 py-0.5 rounded text-xs">${escapeHtml(c.ui_element)}</code></td><td class="px-4 py-3 text-gray-300 text-xs max-w-[200px] truncate">${escapeHtml(c.url || "\u2014")}</td><td class="px-4 py-3 text-gray-400 font-mono text-xs">${escapeHtml(c.ip_address || "\u2014")}</td><td class="px-4 py-3 text-gray-400 text-xs">${formatDate(c.created_at)}</td></tr>`).join("");
      } catch(e) {}
    });
    document.getElementById("search-input")!.addEventListener("keydown", (e: any) => { if (e.key === "Enter") document.getElementById("search-btn")!.click(); });

    // Copy to clipboard on click
    document.addEventListener("click", (e: any) => {
      if (e.target.classList?.contains("copy-uid")) {
        const uid = e.target.getAttribute("data-uid");
        if (uid) { navigator.clipboard.writeText(uid); e.target.textContent = "\u2705"; setTimeout(() => e.target.textContent = "\uD83D\uDCCB", 1000); }
      }
    });

    // --- Live Sessions (Heartbeat) ---
    function formatHeartbeatTime(iso: string): string {
      const d = new Date(iso + (iso.includes('Z') ? '' : 'Z'));
      const now = new Date();
      const diffSec = Math.round((now.getTime() - d.getTime()) / 1000);
      if (diffSec < 10) return 'just now';
      if (diffSec < 60) return `${diffSec}s ago`;
      if (diffSec < 3600) return `${Math.floor(diffSec / 60)}m ago`;
      return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    async function loadHeartbeat() {
      try {
        const res = await fetch('/api/heartbeat/?minutes=2');
        if (!res.ok) throw new Error('Failed');
        const data = await res.json();
        const sessions = data.sessions || [];
        const count = data.count || 0;

        document.getElementById('live-count')!.textContent = String(count);
        const uniquePages = new Set(sessions.map((s: any) => s.page));
        document.getElementById('live-pages')!.textContent = String(uniquePages.size);
        document.getElementById('heartbeat-updated')!.textContent = 'Updated ' + new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });

        const tbody = document.getElementById('live-sessions-tbody')!;
        if (!sessions.length) {
          tbody.innerHTML = '<tr><td colspan="6" class="px-3 py-4 text-center text-gray-500">No active sessions</td></tr>';
          return;
        }

        tbody.innerHTML = sessions.map((s: any) => {
          const history: { page: string; ts: string }[] = Array.isArray(s.page_history) ? s.page_history : [];
          const trailHtml = history.length > 0
            ? history.map((h, i) => {
                const isLast = i === history.length - 1;
                return `<span class="${isLast ? 'text-green-400 font-medium' : 'text-gray-500'}">${escapeHtml(h.page)}</span>`;
              }).join('<span class="text-gray-600 mx-0.5">→</span>')
            : '<span class="text-gray-600">—</span>';

          return `
          <tr class="hover:bg-gray-800/30">
            <td class="px-3 py-1.5 font-mono text-gray-400">${escapeHtml(s.uid || '—')}</td>
            <td class="px-3 py-1.5 text-blue-300">${escapeHtml(s.page || '/')}</td>
            <td class="px-3 py-1.5 max-w-xs overflow-x-auto whitespace-nowrap"><div class="flex items-center gap-0 text-xs">${trailHtml}</div></td>
            <td class="px-3 py-1.5 font-mono text-gray-500">${escapeHtml(s.ip_address || '—')}</td>
            <td class="px-3 py-1.5 text-gray-400">${escapeHtml([s.city, s.country].filter(Boolean).join(', ') || '—')}</td>
            <td class="px-3 py-1.5 text-green-400">${formatHeartbeatTime(s.last_seen)}</td>
          </tr>`;
        }).join('');
      } catch {
        document.getElementById('live-sessions-tbody')!.innerHTML =
          '<tr><td colspan="6" class="px-3 py-4 text-center text-red-400">⚠️ Failed to load sessions</td></tr>';
      }
    }

    // Force refresh button
    const hbRefreshBtn = document.getElementById('heartbeat-refresh-btn')!;
    hbRefreshBtn.addEventListener('click', async () => {
      hbRefreshBtn.textContent = '⏳';
      hbRefreshBtn.classList.add('opacity-60', 'pointer-events-none');
      await loadHeartbeat();
      hbRefreshBtn.textContent = '✅';
      hbRefreshBtn.classList.remove('opacity-60', 'pointer-events-none');
      setTimeout(() => { hbRefreshBtn.textContent = '↻ Refresh'; }, 800);
    });

    // Initial load + poll every 10 seconds
    loadHeartbeat();
    setInterval(loadHeartbeat, 10000);
  </script>
</Layout>
