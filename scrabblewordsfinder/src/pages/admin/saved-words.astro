---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Memory Workbench | Admin" showHeader={true}>

  <div class="max-w-6xl mx-auto px-6 py-4 border-b border-gray-800">
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">← Admin</a>
      <a href="/admin/environments/" class="hover:text-blue-400 transition-colors">Environments</a>
      <a href="/admin/toolset/" class="hover:text-blue-400 transition-colors">ToolSet</a>
      <a href="/admin/saved-words/" class="text-purple-400 font-medium">Workbench</a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto p-6">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-2xl font-bold text-white flex items-center gap-2">👑 Memory Workbench</h1>
      <div id="stats" class="text-sm text-gray-400"></div>
    </div>

    <!-- Search bar -->
    <div class="mb-4">
      <input id="uid-search" type="text" placeholder="Search by User ID..." class="w-full sm:w-80 px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
    </div>

    <!-- Category filter pills -->
    <div id="cat-filters" class="flex flex-wrap gap-2 mb-6"></div>

    <!-- Filter indicator -->
    <div id="filter-indicator" class="mb-2 text-xs text-gray-500"></div>

    <!-- Users accordion -->
    <div id="users-list" class="space-y-4"></div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-12">
      <p class="text-gray-500">No words saved yet. Use the solver to collect words into the Memory Workbench.</p>
    </div>
  </div>

  <script is:inline>
    var categoryColors = {
      'manual': { bg: 'bg-purple-900/30', border: 'border-purple-700', text: 'text-purple-300', pill: 'bg-purple-900/30 border-purple-500 text-purple-400', label: '✋ Manual' },
      'two-letter': { bg: 'bg-amber-900/20', border: 'border-amber-700', text: 'text-amber-300', pill: 'bg-amber-900/30 border-amber-500 text-amber-400', label: '🔤 Two-Letter' },
      'three-letter': { bg: 'bg-blue-900/20', border: 'border-blue-700', text: 'text-blue-300', pill: 'bg-blue-900/30 border-blue-500 text-blue-400', label: '🏆 Three-Letter' },
      'q-no-u': { bg: 'bg-fuchsia-900/20', border: 'border-fuchsia-700', text: 'text-fuchsia-300', pill: 'bg-fuchsia-900/30 border-fuchsia-500 text-fuchsia-400', label: '🚫U Q Words' },
      'q-without-u': { bg: 'bg-fuchsia-900/20', border: 'border-fuchsia-700', text: 'text-fuchsia-300', pill: 'bg-fuchsia-900/30 border-fuchsia-500 text-fuchsia-400', label: '🚫U Q Words' },
      'rare-letters': { bg: 'bg-orange-900/20', border: 'border-orange-700', text: 'text-orange-300', pill: 'bg-orange-900/30 border-orange-500 text-orange-400', label: '💎 Rare Letters' },
      'high-scoring': { bg: 'bg-emerald-900/20', border: 'border-emerald-700', text: 'text-emerald-300', pill: 'bg-emerald-900/30 border-emerald-500 text-emerald-400', label: '🏅 High-Scoring' }
    };

    var users = [];
    var categories = {};
    var activeFilter = 'all';
    var searchQuery = '';

    function getColor(cat) {
      return categoryColors[cat] || categoryColors['manual'];
    }

    function getFilteredUsers() {
      var filtered = users;
      if (searchQuery) {
        filtered = filtered.filter(function(u) { return u.uid.toLowerCase().includes(searchQuery.toLowerCase()); });
      }
      return filtered;
    }

    function renderWordCard(w) {
      var c = getColor(w.category);
      var tooltip = w.meaning ? ' title="' + w.meaning.replace(/"/g, '&quot;') + '"' : '';
      var dot = w.meaning ? '<span class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-blue-400"></span>' : '';
      return '<div class="rounded-lg border ' + c.border + ' ' + c.bg + ' px-2 py-1.5 inline-block relative cursor-default"' + tooltip + '>' +
        dot +
        '<span class="font-mono font-bold text-xs ' + c.text + ' uppercase">' + w.word + '</span>' +
      '</div>';
    }

    function render() {
      var filtered = getFilteredUsers();
      var container = document.getElementById('users-list');
      var empty = document.getElementById('empty-state');
      var indicator = document.getElementById('filter-indicator');

      // Show active filter debug info
      var totalFiltered = 0;
      filtered.forEach(function(u) {
        var w = u.words.slice();
        if (activeFilter !== 'all') {
          w = w.filter(function(x) { var c = x.category || 'manual'; return c === activeFilter || ((activeFilter === 'q-without-u' || activeFilter === 'q-no-u') && (c === 'q-without-u' || c === 'q-no-u')); });
        }
        totalFiltered += w.length;
      });
      if (indicator) indicator.textContent = 'Filter: "' + activeFilter + '" → ' + totalFiltered + ' words from ' + filtered.length + ' users';

      if (!filtered.length) {
        container.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      var html = filtered.map(function(u) {
        var words = u.words.slice();
        if (activeFilter !== 'all') {
          words = words.filter(function(w) {
            var wCat = w.category || 'manual';
            if (activeFilter === 'q-without-u' || activeFilter === 'q-no-u') {
              return wCat === 'q-without-u' || wCat === 'q-no-u';
            }
            return wCat === activeFilter;
          });
        }
        if (!words.length) return '';

        var wordCount = words.length;
        var catCounts = {};
        words.forEach(function(w) { var c = w.category || 'manual'; catCounts[c] = (catCounts[c] || 0) + 1; });
        var catBadges = Object.keys(catCounts).map(function(cat) {
          var c = getColor(cat);
          return '<span class="text-[10px] px-1.5 py-0.5 rounded border ' + c.border + ' ' + c.text + '">' + c.label + ' ' + catCounts[cat] + '</span>';
        }).join(' ');

        var autoExpand = activeFilter !== 'all' ? '' : 'hidden';
        var wordCards = words.map(renderWordCard).join(' ');

        return '<div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden">' +
          '<div class="px-4 py-3 border-b border-gray-800 flex flex-wrap justify-between items-center gap-2 cursor-pointer hover:bg-gray-800/50 transition-colors" onclick="this.nextElementSibling.classList.toggle(\'hidden\')">' +
            '<div class="flex items-center gap-2">' +
              '<span class="text-purple-400 font-mono text-xs">' + u.uid.slice(0, 12) + '...</span>' +
              '<span class="text-gray-600 text-xs">' + (u.updatedAt || '') + '</span>' +
            '</div>' +
            '<div class="flex items-center gap-2">' +
              catBadges +
              '<span class="text-green-400 font-bold text-sm">' + wordCount + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="' + autoExpand + ' p-4">' +
            '<div class="flex flex-wrap gap-2">' + wordCards + '</div>' +
            '<p class="text-[10px] text-gray-600 mt-3">Full UID: ' + u.uid + '</p>' +
          '</div>' +
        '</div>';
      }).filter(Boolean).join('');

      container.innerHTML = html || '<p class="text-gray-500 text-center py-8">No words match this filter.</p>';
    }

    function renderFilters() {
      var container = document.getElementById('cat-filters');
      var total = 0;
      users.forEach(function(u) { total += u.words.length; });

      var pills = '<button class="cat-pill px-3 py-1.5 rounded-full text-xs font-medium border transition-colors ' +
        (activeFilter === 'all' ? 'bg-gray-700 border-gray-500 text-white' : 'bg-gray-800 border-gray-700 text-gray-400 hover:border-gray-500') +
        '" data-cat="all">All (' + total + ')</button>';

      Object.keys(categories).forEach(function(cat) {
        var c = getColor(cat);
        var isActive = activeFilter === cat;
        pills += '<button class="cat-pill px-3 py-1.5 rounded-full text-xs font-medium border transition-colors ' +
          (isActive ? c.pill : 'bg-gray-800 border-gray-700 text-gray-400 hover:border-gray-500') +
          '" data-cat="' + cat + '">' + c.label + ' (' + categories[cat] + ')</button>';
      });

      container.innerHTML = pills;
      container.querySelectorAll('.cat-pill').forEach(function(btn) {
        btn.addEventListener('click', function() {
          activeFilter = btn.dataset.cat;
          render();
          renderFilters();
        });
      });
    }

    // Search handler
    document.getElementById('uid-search').addEventListener('input', function(e) {
      searchQuery = e.target.value;
      render();
    });

    fetch('/api/saved-words')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        users = data.users || [];
        categories = data.categories || {};
        var stats = document.getElementById('stats');
        stats.textContent = data.totalUsers + ' users • ' + data.totalWords + ' words';
        renderFilters();
        render();
      })
      .catch(function() {
        document.getElementById('empty-state').classList.remove('hidden');
      });
  </script>
</Layout>
