---
const user = (Astro.locals as any).user || { email: '', name: '', picture: '' };
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Saved Words | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-gray-200 min-h-screen">
  <nav class="bg-gray-900 px-6 py-3 border-b border-gray-800 flex gap-6 items-center text-sm">
    <a href="/admin" class="text-gray-400 hover:text-amber-400">← Admin</a>
    <a href="/admin/saved-words" class="text-amber-400 font-medium">📝 Saved Words</a>
  </nav>

  <div class="max-w-6xl mx-auto p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-white">📝 Saved Words</h1>
      <div id="stats" class="text-green-400 font-medium"></div>
    </div>

    <div id="content"></div>
  </div>

  <script is:inline>
    async function loadWords() {
      var res = await fetch('/api/saved-words');
      var data = await res.json();

      document.getElementById('stats').textContent = data.totalUsers + ' users (' + data.totalWords + ' words)';

      var html = '';
      data.users.forEach(function(u) {
        html += '<div class="mb-4 bg-gray-900 rounded-lg border border-gray-800 overflow-hidden">' +
          '<div class="px-4 py-3 border-b border-gray-800 flex justify-between items-center cursor-pointer" onclick="this.nextElementSibling.classList.toggle(\'hidden\')">' +
            '<div><span class="text-amber-400 font-mono text-sm">' + u.uid.slice(0, 20) + '...</span> <span class="text-gray-500 text-xs ml-2">Last: ' + (u.updatedAt || '—') + '</span></div>' +
            '<span class="text-green-400 font-medium text-sm">' + u.wordCount + ' words</span>' +
          '</div>' +
          '<div class="hidden p-4">' +
            '<div class="flex flex-wrap gap-2">' +
            u.words.map(function(w) {
              return '<span class="px-2 py-1 bg-gray-800 rounded text-xs text-gray-300 border border-gray-700">' + w.word + (w.score ? ' <span class="text-amber-400">(' + w.score + ')</span>' : '') + '</span>';
            }).join('') +
            '</div>' +
          '</div>' +
        '</div>';
      });

      document.getElementById('content').innerHTML = html || '<p class="text-gray-500">No saved words yet.</p>';
    }

    loadWords();
  </script>
</body>
</html>
