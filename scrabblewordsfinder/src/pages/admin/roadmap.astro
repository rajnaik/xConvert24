---
import '../../styles/global.css';
---
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Roadmap Admin — SWF</title>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <nav class="border-b border-gray-800 px-4 py-3 flex items-center gap-4 text-sm">
    <a href="/admin/" class="text-gray-400 hover:text-white transition-colors">← Admin</a>
    <span class="text-amber-400 font-medium">🗺️ Roadmap</span>
    <a href="/roadmap/" class="ml-auto text-xs text-blue-400 hover:underline">View public page ↗</a>
  </nav>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-white">Roadmap Features</h1>
      <button id="add-btn" class="px-4 py-2 rounded-lg bg-amber-600 text-white text-sm font-semibold hover:bg-amber-500 transition-colors">+ Add Feature</button>
    </div>

    <!-- Add/Edit form -->
    <div id="form-panel" class="hidden mb-6 rounded-xl border border-gray-800 bg-gray-900/50 p-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
        <input id="f-name" type="text" placeholder="Feature name *" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-500" />
        <input id="f-icon" type="text" placeholder="Icon emoji (🚀)" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-500" />
        <select id="f-category" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
          <option value="activities">activities</option>
          <option value="tools">tools</option>
          <option value="core">core</option>
          <option value="content">content</option>
          <option value="platform">platform</option>
          <option value="admin">admin</option>
        </select>
        <select id="f-progress" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
          <option value="planned">Planned</option>
          <option value="in-progress">In Progress</option>
          <option value="live">Live</option>
        </select>
        <input id="f-sort" type="number" placeholder="Sort order (0)" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-500" />
        <select id="f-status" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
          <option value="1">Visible (status=1)</option>
          <option value="0">Hidden (status=0)</option>
        </select>
      </div>
      <textarea id="f-desc" rows="2" placeholder="Description" class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-500 mb-3"></textarea>
      <div class="flex gap-2">
        <button id="save-btn" class="px-4 py-2 rounded-lg bg-green-600 text-white text-sm font-semibold hover:bg-green-500 transition-colors">Save</button>
        <button id="cancel-btn" class="px-3 py-2 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">Cancel</button>
      </div>
      <input type="hidden" id="f-id" value="" />
    </div>

    <!-- Features list -->
    <div id="features-list" class="space-y-2"></div>
  </main>

  <script is:inline>
  (function() {
    function loadFeatures() {
      fetch('/api/roadmap-features/?all=true').then(function(r) { return r.json(); }).then(function(data) {
        var features = data.features || [];
        var html = features.map(function(f) {
          var statusBadge = f.status === 1 ? '<span class="px-1.5 py-0.5 rounded text-[9px] bg-green-900/50 text-green-400 border border-green-800">visible</span>' : '<span class="px-1.5 py-0.5 rounded text-[9px] bg-red-900/50 text-red-400 border border-red-800">hidden</span>';
          var progressColor = f.progress === 'live' ? 'text-green-400' : f.progress === 'in-progress' ? 'text-blue-400' : 'text-amber-400';
          return '<div class="rounded-lg border border-gray-800 bg-gray-900/50 p-3 flex items-center gap-3 group hover:border-gray-700">' +
            '<span class="text-lg shrink-0">' + f.icon + '</span>' +
            '<div class="flex-1 min-w-0">' +
              '<div class="flex items-center gap-2 flex-wrap">' +
                '<span class="text-sm font-medium text-white">' + f.name + '</span>' +
                statusBadge +
                '<span class="text-[10px] ' + progressColor + ' font-medium">' + f.progress + '</span>' +
                '<span class="text-[10px] text-gray-600">#' + f.sort_order + ' · ' + f.category + '</span>' +
              '</div>' +
              '<p class="text-xs text-gray-500 truncate">' + f.description + '</p>' +
            '</div>' +
            '<div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">' +
              '<button class="toggle-btn px-2 py-1 text-xs rounded ' + (f.status === 1 ? 'text-red-400 hover:bg-red-900/20' : 'text-green-400 hover:bg-green-900/20') + '" data-id="' + f.id + '" data-status="' + f.status + '">' + (f.status === 1 ? '👁 Hide' : '👁 Show') + '</button>' +
              '<button class="edit-feature-btn px-2 py-1 text-xs text-blue-400 hover:bg-blue-900/20 rounded" data-id="' + f.id + '">✏️</button>' +
              '<button class="del-feature-btn px-2 py-1 text-xs text-red-400 hover:bg-red-900/20 rounded" data-id="' + f.id + '">🗑️</button>' +
            '</div>' +
          '</div>';
        }).join('');
        document.getElementById('features-list').innerHTML = html || '<p class="text-sm text-gray-500 text-center py-8">No features.</p>';

        document.querySelectorAll('.toggle-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var newStatus = parseInt(this.dataset.status) === 1 ? 0 : 1;
            fetch('/api/roadmap-features/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: parseInt(this.dataset.id), status: newStatus }) }).then(loadFeatures);
          });
        });
        document.querySelectorAll('.edit-feature-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { editFeature(parseInt(this.dataset.id), features); });
        });
        document.querySelectorAll('.del-feature-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            if (!confirm('Delete?')) return;
            fetch('/api/roadmap-features/?id=' + this.dataset.id, { method: 'DELETE' }).then(loadFeatures);
          });
        });
      });
    }

    function editFeature(id, features) {
      var f = features.find(function(x) { return x.id === id; });
      if (!f) return;
      document.getElementById('f-id').value = id;
      document.getElementById('f-name').value = f.name;
      document.getElementById('f-icon').value = f.icon;
      document.getElementById('f-desc').value = f.description;
      document.getElementById('f-category').value = f.category;
      document.getElementById('f-progress').value = f.progress;
      document.getElementById('f-sort').value = f.sort_order;
      document.getElementById('f-status').value = f.status;
      document.getElementById('form-panel').classList.remove('hidden');
    }

    function saveFeature() {
      var id = document.getElementById('f-id').value;
      var body = {
        name: document.getElementById('f-name').value.trim(),
        icon: document.getElementById('f-icon').value.trim() || '🚀',
        description: document.getElementById('f-desc').value.trim(),
        category: document.getElementById('f-category').value,
        progress: document.getElementById('f-progress').value,
        sort_order: parseInt(document.getElementById('f-sort').value) || 0,
        status: parseInt(document.getElementById('f-status').value),
      };
      if (!body.name) return;
      if (id) body.id = parseInt(id);
      fetch('/api/roadmap-features/', { method: id ? 'PUT' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function() { hideForm(); loadFeatures(); });
    }

    function hideForm() {
      document.getElementById('form-panel').classList.add('hidden');
      document.getElementById('f-id').value = '';
      document.getElementById('f-name').value = '';
      document.getElementById('f-icon').value = '';
      document.getElementById('f-desc').value = '';
      document.getElementById('f-sort').value = '';
    }

    document.getElementById('add-btn').addEventListener('click', function() { hideForm(); document.getElementById('form-panel').classList.remove('hidden'); document.getElementById('f-name').focus(); });
    document.getElementById('save-btn').addEventListener('click', saveFeature);
    document.getElementById('cancel-btn').addEventListener('click', hideForm);
    loadFeatures();
  })();
  </script>
</body>
</html>
