    }

    // Sync SEO to Pages — compares DB with live pages and logs differences (incremental)
    document.getElementById('sync-seo-pages-btn').addEventListener('click', async function() {
      var btn = this;
      btn.textContent = '🔄 Checking...';
      btn.disabled = true;
      try {
        // Get last sync time to only process recently updated entries
        var syncInfoRes = await fetch('/api/seo-index/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ _get_sync_info: true }) });
        var syncInfo = await syncInfoRes.json();
        var lastSync = syncInfo.last_sync || '';

        // Get only entries updated since last sync
        var allEntries = [];
        var offset = 0;
        var batchSize = 200;
        var urlSuffix = lastSync ? '&updated_after=' + encodeURIComponent(lastSync) : '';
        while (true) {
          var res = await fetch('/api/seo-index/?limit=' + batchSize + '&offset=' + offset + urlSuffix);
          var data = await res.json();
          if (!data.entries || data.entries.length === 0) break;
          allEntries = allEntries.concat(data.entries);
          if (data.entries.length < batchSize) break;
          offset += batchSize;
        }

        if (allEntries.length === 0) {
          btn.textContent = '✓ No changes since last sync';
          setTimeout(function() { btn.textContent = '🔄 Sync SEO to Pages'; btn.disabled = false; }, 3000);
          return;
        }

        btn.textContent = '🔄 Scanning 0/' + allEntries.length;
        var changesLogged = 0;
        var fileUpdates = [];

        for (var i = 0; i < allEntries.length; i++) {
          var entry = allEntries[i];
          if (i % 5 === 0) btn.textContent = '🔄 Scanning ' + i + '/' + allEntries.length;

          try {
            var pageRes = await fetch(entry.url, { redirect: 'follow' });
            if (!pageRes.ok) continue;
            var html = await pageRes.text();

            var titleMatch = html.match(/<title>([^<]*)<\/title>/);
            var pageTitle = titleMatch ? titleMatch[1].trim() : '';
            var descMatch = html.match(/<meta\s+name="description"\s+content="([^"]*)"/i) || html.match(/<meta\s+content="([^"]*)"\s+name="description"/i);
            var pageDesc = descMatch ? descMatch[1] : '';
            var kwMatch = html.match(/<meta\s+name="keywords"\s+content="([^"]*)"/i) || html.match(/<meta\s+content="([^"]*)"\s+name="keywords"/i);
            var pageKeywords = kwMatch ? kwMatch[1] : '';
            var h1Match = html.match(/<h1[^>]*>([^<]+)<\/h1>/);
            var pageH1 = h1Match ? h1Match[1].trim() : '';
            var linkMatches = html.match(/href="\/[^"]*"/g);
            var linkCount = linkMatches ? linkMatches.length : 0;
            var h2Matches = html.match(/<h2[\s>]/g);
            var h2Count = h2Matches ? h2Matches.length : 0;
            var hasFaq = (html.includes('"@type":"FAQPage"') || html.includes('"@type": "FAQPage"')) ? 1 : 0;
            var hasArticle = (html.includes('"@type":"Article"') || html.includes('"@type": "Article"')) ? 1 : 0;

            var diffs = [];
            if (pageTitle.length > 0 && (entry.seo_title || '') !== '' && (entry.seo_title || '').trim().substring(0,30) !== pageTitle.trim().substring(0,30)) {
              diffs.push({ field: 'seo_title', oldVal: pageTitle.trim(), newVal: (entry.seo_title || '').trim() });
            }
            if (pageDesc.length > 0 && (entry.seo_meta_description || '') !== '' && (entry.seo_meta_description || '').trim() !== pageDesc.trim()) {
              diffs.push({ field: 'seo_meta_description', oldVal: pageDesc.trim(), newVal: (entry.seo_meta_description || '').trim() });
            }
            if (pageKeywords.length > 0 && (entry.seo_meta_keywords || '') !== '' && (entry.seo_meta_keywords || '').trim() !== pageKeywords.trim()) {
              diffs.push({ field: 'seo_meta_keywords', oldVal: pageKeywords.trim(), newVal: (entry.seo_meta_keywords || '').trim() });
            }
            if (pageH1.length > 0 && (entry.seo_h1 || '') !== '' && (entry.seo_h1 || '').trim() !== pageH1.trim()) {
              diffs.push({ field: 'seo_h1', oldVal: pageH1.trim(), newVal: (entry.seo_h1 || '').trim() });
            }
            if ((entry.seo_internal_links || 0) !== linkCount) {
              diffs.push({ field: 'seo_internal_links', oldVal: String(entry.seo_internal_links || 0), newVal: String(linkCount) });
            }
            if ((entry.seo_h2_count || 0) !== h2Count) {
              diffs.push({ field: 'seo_h2_count', oldVal: String(entry.seo_h2_count || 0), newVal: String(h2Count) });
            }
            if ((entry.seo_json_ld_faq || 0) !== hasFaq) {
              diffs.push({ field: 'seo_json_ld_faq', oldVal: String(entry.seo_json_ld_faq || 0), newVal: String(hasFaq) });
            }
            if ((entry.seo_json_ld_article || 0) !== hasArticle) {
              diffs.push({ field: 'seo_json_ld_article', oldVal: String(entry.seo_json_ld_article || 0), newVal: String(hasArticle) });
            }

            for (var d = 0; d < diffs.length; d++) {
              await fetch('/api/seo-index/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ _sync_log: true, url: entry.url, field_changed: diffs[d].field, old_value: diffs[d].oldVal, new_value: diffs[d].newVal }) });
              changesLogged++;
              // Collect text field updates for file writing
              if (['seo_title', 'seo_meta_description', 'seo_meta_keywords', 'seo_h1'].indexOf(diffs[d].field) !== -1) {
                fileUpdates.push({ url: entry.url, field: diffs[d].field, value: diffs[d].newVal });
              }
            }

            if (diffs.some(function(dd) { return dd.field === 'seo_internal_links' || dd.field === 'seo_h2_count' || dd.field === 'seo_json_ld_faq' || dd.field === 'seo_json_ld_article'; })) {
              await fetch('/api/seo-index/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: entry.id, seo_internal_links: linkCount, seo_h2_count: h2Count, seo_json_ld_article: hasArticle, seo_json_ld_faq: hasFaq }) });
            }
          } catch (fetchErr) { /* skip */ }
        }

        // Update sync timestamp — file writes happen via prebuild or "sync seo" command in Kiro
        await fetch('/api/seo-index/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ _sync_pages: true }) });
        btn.textContent = '✓ ' + changesLogged + ' changes logged (' + allEntries.length + ' pages)';
        setTimeout(function() { btn.textContent = '🔄 Sync SEO to Pages'; btn.disabled = false; }, 3000);
        loadData();

        // Show reminder popup if there were text field changes
        if (fileUpdates.length > 0) {
          setTimeout(function() {
            var popup = document.createElement('div');
            popup.className = 'fixed bottom-6 right-6 z-50 p-4 rounded-xl border border-amber-500/50 bg-gray-900/95 shadow-2xl max-w-sm';
            popup.innerHTML = '<div class="flex items-start gap-3"><span class="text-2xl">📝</span><div><p class="text-sm font-semibold text-amber-400 mb-1">SEO changes logged</p><p class="text-xs text-gray-300 leading-relaxed">Ask Kiro: <span class="font-mono text-amber-300">"sync seo"</span> to write ' + fileUpdates.length + ' field changes to your .astro files so you can test locally.</p><button class="mt-2 text-xs text-gray-500 hover:text-gray-300" onclick="this.parentElement.parentElement.parentElement.remove()">Dismiss</button></div></div>';
            document.body.appendChild(popup);
            setTimeout(function() { if (popup.parentElement) popup.remove(); }, 15000);
          }, 500);
        }
      } catch (err) {
        btn.textContent = '✕ ' + (err.message || 'Failed');
        setTimeout(function() { btn.textContent = '🔄 Sync SEO to Pages'; btn.disabled = false; }, 3000);
      }
    });

    // Read URL params for pre-filtering
    var urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('status')) {
      filterStatus.value = urlParams.get('status');
    }

    // Sync Links — fetch all pages and count internal links
    document.getElementById('sync-links-btn').addEventListener('click', async function() {
      var btn = this;
      if (!confirm('This will fetch all pages and re-count internal links. It may take a minute for large sites. Continue?')) return;
      btn.textContent = '🔗 Loading pages...';
      btn.disabled = true;

      try {
        // Get all entries from seo_index
        var allEntries = [];
        var offset = 0;
        var batchSize = 200;
        while (true) {
          var res = await fetch('/api/seo-index/?limit=' + batchSize + '&offset=' + offset);
          var data = await res.json();
          if (!data.entries || data.entries.length === 0) break;
          allEntries = allEntries.concat(data.entries);
          if (data.entries.length < batchSize) break;
          offset += batchSize;
        }

        btn.textContent = '🔗 Scanning 0/' + allEntries.length;
        var updated = 0;

        for (var i = 0; i < allEntries.length; i++) {
          var entry = allEntries[i];
          if (i % 10 === 0) btn.textContent = '🔗 Scanning ' + i + '/' + allEntries.length;

          try {
            var pageRes = await fetch(entry.url, { redirect: 'follow' });
            if (!pageRes.ok) continue;
            var html = await pageRes.text();

            // Count internal links (href="/...")
            var linkMatches = html.match(/href="\/[^"]*"/g);
            var linkCount = linkMatches ? linkMatches.length : 0;

            // Count H2s
            var h2Matches = html.match(/<h2[\s>]/g);
            var h2Count = h2Matches ? h2Matches.length : 0;

            // Count word count (strip HTML, count words)
            var textContent = html.replace(/<script[\s\S]*?<\/script>/gi, '').replace(/<style[\s\S]*?<\/style>/gi, '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ');
            var wordCount = textContent.split(' ').filter(function(w) { return w.length > 2; }).length;

            // Check for JSON-LD schemas
            var hasArticle = html.includes('"@type":"Article"') || html.includes('"@type": "Article"') ? 1 : 0;
            var hasFaq = html.includes('"@type":"FAQPage"') || html.includes('"@type": "FAQPage"') ? 1 : 0;

            // Only update if something changed
            if (linkCount !== (entry.seo_internal_links || 0) || h2Count !== (entry.seo_h2_count || 0) || wordCount !== (entry.seo_word_count || 0) || hasArticle !== (entry.seo_json_ld_article || 0) || hasFaq !== (entry.seo_json_ld_faq || 0)) {
              await fetch('/api/seo-index/', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: entry.id, seo_internal_links: linkCount, seo_h2_count: h2Count, seo_word_count: wordCount, seo_json_ld_article: hasArticle, seo_json_ld_faq: hasFaq })
              });
              updated++;
            }
          } catch (fetchErr) {
            // Skip pages that fail to fetch (404, timeout, etc.)
          }
        }

        btn.textContent = '✓ Updated ' + updated + '/' + allEntries.length;
        setTimeout(function() { btn.textContent = '🔗 Sync Links'; btn.disabled = false; }, 3000);
        loadData();
      } catch (err) {
        btn.textContent = '✕ Failed: ' + err.message;
        setTimeout(function() { btn.textContent = '🔗 Sync Links'; btn.disabled = false; }, 3000);
      }
    });

    // Read URL params for pre-filtering
    var urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('status')) {
      filterStatus.value = urlParams.get('status');
    }

    // Initial load
    // --- SEO Tag Audit ---
    async function loadAudit() {
      var body = document.getElementById('tag-audit-body');
      body.innerHTML = '<tr><td colspan="8" class="px-4 py-3 text-center text-gray-500 italic">Loading...</td></tr>';
      try {
        var res = await fetch('/api/seo-tag-audit/');
        var data = await res.json();
        if (!data.audit) { body.innerHTML = '<tr><td colspan="8" class="px-4 py-3 text-center text-red-400">Error loading audit</td></tr>'; return; }
        var a = data.audit;
        var l = data.lengths || {};
        var total = a.total || 1;

        // Tags with length data: [name, icon, present, stipulated, avgLen, minLen, maxLen]
        var tags = [
          { name: 'Title', icon: '📝', present: a.has_title, stipulated: '50-60', avg: l.avg_title_len, min: l.min_title_len, max: l.max_title_len },
          { name: 'Meta Description', icon: '📋', present: a.has_description, stipulated: '120-155', avg: l.avg_desc_len, min: l.min_desc_len, max: l.max_desc_len },
          { name: 'Keywords', icon: '🔑', present: a.has_keywords, stipulated: '50-200', avg: l.avg_keywords_len, min: l.min_keywords_len, max: l.max_keywords_len },
          { name: 'H1 Heading', icon: '🏷️', present: a.has_h1, stipulated: '20-70', avg: l.avg_h1_len, min: l.min_h1_len, max: l.max_h1_len },
          { name: 'H2 Count', icon: '📌', present: a.has_h2, stipulated: '3-10', avg: l.avg_h2_count_val, min: l.min_h2_count, max: l.max_h2_count },
          { name: 'Article Schema', icon: '📰', present: a.has_article_schema, stipulated: '—', avg: null, min: null, max: null },
          { name: 'FAQPage Schema', icon: '❓', present: a.has_faq_schema, stipulated: '—', avg: null, min: null, max: null },
          { name: 'OG Title', icon: '🌐', present: a.has_og_title, stipulated: '40-60', avg: l.avg_og_title_len, min: l.min_og_title_len, max: l.max_og_title_len },
          { name: 'OG Description', icon: '🌐', present: a.has_og_desc, stipulated: '80-155', avg: l.avg_og_desc_len, min: l.min_og_desc_len, max: l.max_og_desc_len },
          { name: 'OG Image', icon: '🖼️', present: a.has_og_image, stipulated: '—', avg: null, min: null, max: null },
          { name: 'Canonical URL', icon: '🔗', present: a.has_canonical, stipulated: '—', avg: null, min: null, max: null },
          { name: 'Internal Links', icon: '🔀', present: a.has_internal_links, stipulated: '2-20', avg: l.avg_links, min: l.min_links, max: l.max_links },
          { name: 'Word Count (≥150)', icon: '📄', present: a.has_sufficient_content, stipulated: '300-2000', avg: l.avg_words, min: l.min_words, max: l.max_words },
        ];

        body.innerHTML = tags.map(function(t) {
          var present = t.present || 0;
          var missing = total - present;
          var pct = Math.round((present / total) * 100);
          var color = pct === 100 ? 'text-green-400' : pct >= 95 ? 'text-amber-400' : 'text-red-400';
          var bar = pct === 100 ? '✅' : pct >= 95 ? '⚠️' : '❌';
          var avgStr = t.avg != null ? t.avg : '—';
          var minStr = t.min != null ? t.min : '—';
          var maxStr = t.max != null ? t.max : '—';
          return '<tr class="hover:bg-gray-800/50">' +
            '<td class="px-3 py-2 text-gray-200">' + t.icon + ' ' + t.name + '</td>' +
            '<td class="px-3 py-2 text-right text-green-400 font-mono">' + present + '</td>' +
            '<td class="px-3 py-2 text-right ' + (missing > 0 ? 'text-red-400' : 'text-gray-600') + ' font-mono">' + missing + '</td>' +
            '<td class="px-3 py-2 text-right ' + color + ' font-mono font-semibold">' + pct + '%</td>' +
            '<td class="px-3 py-2 text-center text-cyan-400 text-xs font-mono">' + t.stipulated + '</td>' +
            '<td class="px-3 py-2 text-right text-blue-400 font-mono text-xs">' + avgStr + '</td>' +
            '<td class="px-3 py-2 text-right text-gray-500 font-mono text-xs">' + minStr + '</td>' +
            '<td class="px-3 py-2 text-right text-gray-500 font-mono text-xs">' + maxStr + '</td>' +
            '<td class="px-3 py-2 text-center">' + bar + '</td></tr>';
        }).join('');

        document.getElementById('audit-timestamp').textContent = 'Last checked: ' + new Date(data.timestamp).toLocaleString();
      } catch(e) {
        body.innerHTML = '<tr><td colspan="8" class="px-4 py-3 text-center text-red-400">Failed to load: ' + e.message + '</td></tr>';
      }
    }
    document.getElementById('refresh-audit-btn').addEventListener('click', loadAudit);
    loadAudit();

    loadData();
  })();
  </script>
</Layout>
