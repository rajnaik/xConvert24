      updatesModal.classList.remove('flex');
    });
    document.getElementById('updates-text').addEventListener('input', function() {
      var chunks = this.value.split(/(?=https?:\/\/www\.scrabblewordsfinder\.com)/).filter(function(c) { return c.includes('scrabblewordsfinder.com'); });
      document.getElementById('updates-preview').textContent = chunks.length + ' URLs detected';
    });
    document.getElementById('updates-submit').addEventListener('click', async function() {
      var btn = this;
      var text = document.getElementById('updates-text').value;
      var selectedStatus = document.getElementById('updates-status').value;
      var updates = [];

      // Split by URL pattern — handles both newline-separated and concatenated text
      var chunks = text.split(/(?=https?:\/\/www\.scrabblewordsfinder\.com)/);

      for (var i = 0; i < chunks.length; i++) {
        var chunk = chunks[i].trim();
        var urlMatch = chunk.match(/https?:\/\/www\.scrabblewordsfinder\.com([^\s]*?)(?=(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec|N\/A|$))/i) || chunk.match(/https?:\/\/www\.scrabblewordsfinder\.com([^\s]*)/);
        if (!urlMatch) continue;
        var path = urlMatch[1] || '/';

        var dateMatch = chunk.match(/(\d{1,2}\s+(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+\d{4})/i) || chunk.match(/((?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+\d{1,2},?\s+\d{4})/i);
        var crawlDate = null;
        if (dateMatch) {
          var d = new Date(dateMatch[1].replace(',', '') + ' 12:00:00');
          if (!isNaN(d.getTime())) crawlDate = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
        }

        updates.push({ url: path, status: selectedStatus, last_crawled: crawlDate, notes: 'Updated from Search Console ' + new Date().toISOString().slice(0,16).replace('T',' '), force_status: true });
      }

      if (updates.length === 0) {
        document.getElementById('updates-preview').textContent = 'No valid URLs found!';
        return;
      }

      btn.textContent = 'Updating ' + updates.length + '...';
      btn.disabled = true;

      for (var j = 0; j < updates.length; j++) {
        await fetch('/api/seo-index/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updates[j])
        });
      }

      btn.textContent = 'Updated ' + updates.length + ' ✓';

      // Log the raw input to DB for potential re-run later
      await fetch('/api/seo-index/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _log: true, status: selectedStatus, url_count: updates.length, raw_text: text })
      });

      setTimeout(function() {
        btn.textContent = 'Update';
        btn.disabled = false;
        updatesModal.classList.add('hidden');
        updatesModal.classList.remove('flex');
        loadData();
      }, 1500);
    });

    // Analyse Sitemap button
    document.getElementById('analyse-sitemap-btn').addEventListener('click', async function() {
      var btn = this;
      btn.textContent = 'Analysing...';
      btn.disabled = true;
      try {
        var res = await fetch('/sitemap.xml');
        var text = await res.text();
        var parser = new DOMParser();
        var xml = parser.parseFromString(text, 'text/xml');
        var urls = xml.querySelectorAll('url');
        var total = urls.length;
        var freqs = {};
        var freqUrls = {};
        var priorities = {};
        var priUrls = {};
        var lastmods = [];
        var baseUrl = 'https://www.scrabblewordsfinder.com';

        for (var i = 0; i < urls.length; i++) {
          var loc = urls[i].querySelector('loc');
          var freq = urls[i].querySelector('changefreq');
          var pri = urls[i].querySelector('priority');
          var lm = urls[i].querySelector('lastmod');
          var path = loc ? loc.textContent.replace(baseUrl, '') : '';
          var f = freq ? freq.textContent : 'unset';
          var p = pri ? pri.textContent : 'unset';
          freqs[f] = (freqs[f] || 0) + 1;
          if (!freqUrls[f]) freqUrls[f] = [];
          freqUrls[f].push(path);
          priorities[p] = (priorities[p] || 0) + 1;
          if (!priUrls[p]) priUrls[p] = [];
          priUrls[p].push(path);
          if (lm && lm.textContent) lastmods.push(lm.textContent);
        }

        lastmods.sort();
        var oldest = lastmods[0] || 'N/A';
        var newest = lastmods[lastmods.length - 1] || 'N/A';
        var idCounter = 0;

        var html = '<div class="space-y-4 max-h-[70vh] overflow-y-auto">';
        html += '<div class="text-center"><p class="text-3xl font-bold text-cyan-400">' + total + '</p><p class="text-xs text-gray-400">Total URLs in Sitemap</p></div>';
        html += '<div class="grid grid-cols-2 gap-3 text-center"><div class="p-2 rounded-lg bg-gray-800"><p class="text-sm font-bold text-green-400">' + oldest + '</p><p class="text-[10px] text-gray-500">Oldest lastmod</p></div><div class="p-2 rounded-lg bg-gray-800"><p class="text-sm font-bold text-blue-400">' + newest + '</p><p class="text-[10px] text-gray-500">Newest lastmod</p></div></div>';

        // By Change Frequency with expandable URL lists
        html += '<div><p class="text-xs font-semibold text-gray-300 mb-2">By Change Frequency</p>';
        Object.keys(freqs).sort().forEach(function(k) {
          var id = 'freq-' + (idCounter++);
          html += '<div class="mb-2"><button onclick="document.getElementById(\'' + id + '\').classList.toggle(\'hidden\')" class="w-full p-2 rounded-lg bg-gray-800 text-left flex items-center justify-between hover:bg-gray-700 transition-colors"><span class="text-xs text-gray-300"><span class="text-amber-400 font-bold">' + freqs[k] + '</span> — ' + k + '</span><span class="text-gray-500 text-xs">▼</span></button>';
          html += '<div id="' + id + '" class="hidden mt-1 ml-2 max-h-40 overflow-y-auto border-l-2 border-amber-500/30 pl-2">';
          freqUrls[k].forEach(function(u) { html += '<p class="text-[11px] text-gray-400 py-0.5 font-mono">' + u + '</p>'; });
          html += '</div></div>';
        });
        html += '</div>';

        // By Priority with expandable URL lists
        var priLabels = {'1.0':'Homepage','0.8':'Blog Index','0.7':'Category Hubs','0.6':'Blog Posts','0.5':'Secondary Pages','0.4':'Utility Pages','0.3':'Legal Pages'};
        html += '<div><p class="text-xs font-semibold text-gray-300 mb-2">By Priority</p>';
        Object.keys(priorities).sort().reverse().forEach(function(k) {
          var id = 'pri-' + (idCounter++);
          var label = priLabels[k] || '';
          html += '<div class="mb-2"><button onclick="document.getElementById(\'' + id + '\').classList.toggle(\'hidden\')" class="w-full p-2 rounded-lg bg-gray-800 text-left flex items-center justify-between hover:bg-gray-700 transition-colors"><span class="text-xs text-gray-300"><span class="text-purple-400 font-bold">' + priorities[k] + '</span> — priority ' + k + (label ? ' <span class="text-gray-500">(' + label + ')</span>' : '') + '</span><span class="text-gray-500 text-xs">▼</span></button>';
          html += '<div id="' + id + '" class="hidden mt-1 ml-2 max-h-40 overflow-y-auto border-l-2 border-purple-500/30 pl-2">';
          priUrls[k].forEach(function(u) { html += '<p class="text-[11px] text-gray-400 py-0.5 font-mono">' + u + '</p>'; });
          html += '</div></div>';
        });
        html += '</div>';
        html += '</div>';

        var modal = document.getElementById('analyse-modal');
        document.getElementById('analyse-content').innerHTML = html;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      } catch (err) {
        alert('Failed to fetch sitemap: ' + err.message);
      }
      btn.textContent = '🔍 Analyse Sitemap';
      btn.disabled = false;
    });

