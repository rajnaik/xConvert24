---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="SEO Index — Admin" description="Track Google indexing status for all pages" showHeader={false}>
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/seo/" class="text-blue-400 font-medium">SEO</a>
      <a href="/admin/telemetry/" class="hover:text-blue-400 transition-colors">Telemetry</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-2">📈 SEO Index Tracker</h1>
        <p class="text-sm text-gray-400 mt-1">Track which pages Google has indexed from Search Console</p>
      </div>
      <div class="flex gap-2">
        <button id="add-btn" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors">+ Add Page</button>
        <button id="new-updates-btn" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-500 transition-colors">New Updates</button>
        <button id="sync-sitemap-btn" class="px-4 py-2 rounded-lg bg-purple-600 text-white text-sm font-medium hover:bg-purple-500 transition-colors" title="Last sitemap sync: never">Sync Sitemap.xml</button>
        <button id="sync-links-btn" class="px-4 py-2 rounded-lg bg-teal-600 text-white text-sm font-medium hover:bg-teal-500 transition-colors" title="Re-scan all pages for internal link counts">🔗 Sync Links</button>
        <button id="sync-seo-pages-btn" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-500 transition-colors" title="Sync SEO data from seo_index back to page files">🔄 Sync SEO to Pages</button>
        <button id="view-sync-log-btn" class="px-4 py-2 rounded-lg bg-gray-700 text-white text-sm font-medium hover:bg-gray-600 transition-colors" title="View sync change history">📋 Sync Log</button>
        <button id="nuke-btn" class="px-4 py-2 rounded-lg bg-red-700 text-white text-sm font-medium hover:bg-red-600 transition-colors opacity-30 cursor-not-allowed" disabled>☢️ Nuke</button>
        <button id="analyse-sitemap-btn" class="px-4 py-2 rounded-lg bg-cyan-700 text-white text-sm font-medium hover:bg-cyan-600 transition-colors">🔍 Analyse Sitemap</button>
      </div>
      <p id="last-sync-text" class="text-[10px] text-gray-500 mt-1 text-right"></p>
    </div>

    <!-- Sync Log Panel (collapsible) -->
    <div id="sync-log-panel" class="hidden mt-4 rounded-xl border border-gray-700 bg-gray-900/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-300">📋 SEO Sync Log — Recent Changes</h3>
        <button id="close-sync-log" class="text-gray-500 hover:text-white text-lg">&times;</button>
      </div>
      <div id="sync-log-table" class="overflow-x-auto max-h-64 overflow-y-auto">
        <table class="w-full text-xs">
          <thead class="bg-gray-800/60 sticky top-0">
            <tr>
              <th class="px-3 py-2 text-left text-gray-400">URL</th>
              <th class="px-3 py-2 text-left text-gray-400">Field</th>
              <th class="px-3 py-2 text-left text-gray-400">Old Value</th>
              <th class="px-3 py-2 text-left text-gray-400">New Value</th>
              <th class="px-3 py-2 text-left text-gray-400">When</th>
            </tr>
          </thead>
          <tbody id="sync-log-body" class="divide-y divide-gray-800"></tbody>
        </table>
      </div>
      <p id="sync-log-empty" class="text-xs text-gray-500 italic hidden">No sync log entries yet. Run: node scripts/sync-seo-to-pages.cjs</p>
    </div>

    <!-- Summary cards -->
    <div id="summary-cards" class="grid grid-cols-2 sm:grid-cols-7 gap-3 mb-6">
      <button data-filter="indexed" class="filter-card p-3 rounded-xl border border-green-500/30 bg-green-950/10 text-center cursor-pointer hover:border-green-400 transition-colors">
        <p id="count-indexed" class="text-xl font-bold text-green-400">-</p>
        <p class="text-xs text-gray-400">Indexed</p>
      </button>
      <button data-filter="discovered" class="filter-card p-3 rounded-xl border border-amber-500/30 bg-amber-950/10 text-center cursor-pointer hover:border-amber-400 transition-colors">
        <p id="count-discovered" class="text-xl font-bold text-amber-400">-</p>
        <p class="text-xs text-gray-400">Discovered</p>
      </button>
      <button data-filter="not_indexed" class="filter-card p-3 rounded-xl border border-red-500/30 bg-red-950/10 text-center cursor-pointer hover:border-red-400 transition-colors">
        <p id="count-not_indexed" class="text-xl font-bold text-red-400">-</p>
        <p class="text-xs text-gray-400">Not Indexed</p>
      </button>
      <button data-filter="excluded" class="filter-card p-3 rounded-xl border border-gray-500/30 bg-gray-800/40 text-center cursor-pointer hover:border-gray-400 transition-colors">
        <p id="count-excluded" class="text-xl font-bold text-gray-400">-</p>
        <p class="text-xs text-gray-400">Excluded</p>
      </button>
      <div class="p-3 rounded-xl border border-blue-500/30 bg-blue-950/10 text-center">
        <p id="count-avg-h2" class="text-xl font-bold text-blue-400">-</p>
        <p class="text-xs text-gray-400">Avg H2s</p>
      </div>
      <div class="p-3 rounded-xl border border-cyan-500/30 bg-cyan-950/10 text-center">
        <p id="count-avg-kw" class="text-xl font-bold text-cyan-400">-</p>
        <p class="text-xs text-gray-400">Has Keywords</p>
      </div>
      <button data-filter="" class="filter-card p-3 rounded-xl border border-purple-500/30 bg-purple-950/10 text-center cursor-pointer hover:border-purple-400 transition-colors">
        <p id="count-total" class="text-xl font-bold text-purple-400">-</p>
        <p class="text-xs text-gray-400">Total</p>
      </button>
    </div>

    <!-- SEO Tag Presence Audit -->
    <div id="tag-audit-panel" class="mb-6 rounded-xl border border-gray-700 bg-gray-900/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-300">🏷️ SEO Tag Presence Audit</h3>
        <button id="refresh-audit-btn" class="px-3 py-1.5 rounded-lg bg-gray-700 text-gray-300 text-xs font-medium hover:bg-gray-600 hover:text-white transition-colors">↻ Refresh</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead class="bg-gray-800/60">
            <tr>
              <th class="px-3 py-2 text-left text-gray-400 font-medium">SEO Element</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Present</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Missing</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Coverage</th>
              <th class="px-3 py-2 text-center text-gray-400 font-medium">Stipulated</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Avg Len</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Min</th>
              <th class="px-3 py-2 text-right text-gray-400 font-medium">Max</th>
              <th class="px-3 py-2 text-left text-gray-400 font-medium">Status</th>
            </tr>
          </thead>
          <tbody id="tag-audit-body" class="divide-y divide-gray-800">
            <tr><td colspan="5" class="px-4 py-4 text-center text-gray-500 italic">Click Refresh to load...</td></tr>
          </tbody>
        </table>
      </div>
      <p id="audit-timestamp" class="text-[10px] text-gray-600 mt-2 text-right"></p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="filter-status" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
        <option value="">All statuses</option>
        <option value="indexed">Indexed</option>
        <option value="discovered">Discovered</option>
        <option value="not_indexed">Not Indexed</option>
        <option value="excluded">Excluded</option>
        <option value="error">Error</option>
      </select>
      <input id="filter-search" type="text" placeholder="Search URL..." class="h-9 px-3 w-64 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
      <button id="refresh-btn" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-300 hover:text-blue-400 transition-colors">↻ Refresh</button>
      <button id="pinned-filter" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-300 hover:text-amber-400 transition-colors">📌 Pinned</button>
      <select id="page-size" class="h-9 px-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-300">
        <option value="10">10</option>
        <option value="25" selected>25</option>
        <option value="50">50</option>
      </select>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/60">
          <tr class="text-xs">
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white" data-sort="url">URL ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white" data-sort="status">Status ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-14" data-sort="seo_title_length">Title ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-14" data-sort="seo_desc_length">Desc ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-10" data-sort="seo_h2_count">H2s ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium w-16">Schema</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-14" data-sort="seo_word_count">Words ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-14" data-sort="seo_internal_links">Links ↕</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium cursor-pointer hover:text-white w-24" data-sort="last_crawled">Crawled ↕</th>
            <th class="px-3 py-2 text-center text-gray-400 font-medium w-16">Act</th>
          </tr>
        </thead>
        <tbody id="seo-table-body" class="divide-y divide-gray-800">
          <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500 italic">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4">
      <button id="prev-page" class="h-8 px-4 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm hover:bg-gray-700 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">&lt; Prev</button>
      <span id="page-info" class="text-sm text-gray-400"></span>
      <button id="next-page" class="h-8 px-4 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm hover:bg-gray-700 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">Next &gt;</button>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="seo-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
    <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 shadow-2xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
      <h3 id="modal-title" class="text-lg font-semibold text-white mb-4">Add Page</h3>
      <form id="seo-form" class="space-y-3">
        <input type="hidden" id="form-id" />
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">URL Path</label>
          <input id="form-url" type="text" required class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" placeholder="/blog/my-post/" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">Status</label>
            <select id="form-status" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
              <option value="indexed">Indexed</option>
              <option value="discovered">Discovered</option>
              <option value="not_indexed">Not Indexed</option>
              <option value="excluded">Excluded</option>
              <option value="error">Error</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">📌 Pinned</label>
            <select id="form-pinned" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">Last Crawled</label>
            <input id="form-crawled" type="date" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">First Indexed</label>
            <input id="form-indexed" type="date" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">SEO Title <span id="count-title" class="text-gray-500">0/60</span></label>
          <input id="form-seo-title" type="text" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Meta Description <span id="count-desc" class="text-gray-500">0/155</span></label>
          <textarea id="form-seo-desc" rows="3" class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">H1 <span id="count-h1" class="text-gray-500">0/70</span></label>
          <input id="form-seo-h1" type="text" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Keywords <span id="count-kw" class="text-gray-500">0/200</span></label>
          <textarea id="form-seo-keywords" rows="2" class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100"></textarea>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">H2 Count</label>
            <input id="form-seo-h2" type="number" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">Article LD</label>
            <select id="form-seo-article" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1">FAQ LD</label>
            <select id="form-seo-faq" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Notes</label>
          <input id="form-notes" type="text" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100" placeholder="Optional notes..." />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 h-10 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-500 transition-colors text-sm">Save</button>
          <button type="button" id="modal-cancel" class="flex-1 h-10 bg-gray-700 text-gray-200 font-medium rounded-lg hover:bg-gray-600 transition-colors text-sm">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- New Updates Modal -->
  <div id="updates-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
    <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 shadow-2xl w-full max-w-3xl mx-4">
      <h3 class="text-lg font-semibold text-white mb-2">Paste Search Console Updates</h3>
      <p class="text-xs text-gray-400 mb-3">Paste URLs from Google Search Console. Select the status category these URLs belong to.</p>
      <div class="mb-3">
        <label class="block text-xs font-medium text-gray-400 mb-1">Status Category</label>
        <select id="updates-status" class="h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 w-full sm:w-48">
          <option value="indexed">Indexed</option>
          <option value="discovered">Discovered</option>
          <option value="not_indexed">Not Indexed</option>
          <option value="excluded">Excluded</option>
          <option value="error">Error</option>
        </select>
      </div>
      <textarea id="updates-text" rows="15" class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 font-mono resize-y focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Paste Search Console data here...&#10;&#10;Example:&#10;https://www.scrabblewordsfinder.com/about/ Jun 12, 2026&#10;https://www.scrabblewordsfinder.com/blog/ N/A"></textarea>
      <div class="flex items-center justify-between mt-4">
        <p id="updates-preview" class="text-xs text-gray-500"></p>
        <div class="flex gap-3">
          <button id="updates-cancel" type="button" class="px-4 py-2 rounded-lg bg-gray-700 text-gray-200 font-medium text-sm hover:bg-gray-600 transition-colors">Cancel</button>
          <button id="updates-submit" type="button" class="px-4 py-2 rounded-lg bg-emerald-600 text-white font-medium text-sm hover:bg-emerald-500 transition-colors">Update</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Analyse Sitemap Modal -->
  <div id="analyse-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
    <div class="bg-gray-900 rounded-2xl border border-cyan-700/50 p-6 shadow-2xl w-full max-w-lg mx-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-white">🔍 Sitemap Analysis</h3>
        <button id="analyse-close" class="text-gray-400 hover:text-gray-200 text-xl">✕</button>
      </div>
      <div id="analyse-content" class="text-sm text-gray-300">Loading...</div>
    </div>
  </div>

  <script is:inline>
  (function() {
    var tableBody = document.getElementById('seo-table-body');
    var modal = document.getElementById('seo-modal');
    var form = document.getElementById('seo-form');
    var filterStatus = document.getElementById('filter-status');
    var filterSearch = document.getElementById('filter-search');

    var statusColors = {
      indexed: 'text-green-400 bg-green-900/30 border-green-700',
      discovered: 'text-amber-400 bg-amber-900/30 border-amber-700',
      not_indexed: 'text-red-400 bg-red-900/30 border-red-700',
      excluded: 'text-gray-400 bg-gray-800 border-gray-700',
      error: 'text-red-500 bg-red-900/40 border-red-600'
    };

    function escHtml(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    var currentOffset = 0;
    var pageSize = parseInt(localStorage.getItem('swf_seo_pagesize') || '25');
    var pinnedActive = false;
    var currentEntries = [];
    var sortField = 'url';
    var sortDir = 'asc';

    async function loadData() {
      var params = new URLSearchParams();
      if (filterStatus.value) params.set('status', filterStatus.value);
      if (filterSearch.value) params.set('search', filterSearch.value);
      if (pinnedActive) params.set('pinned', '1');
      params.set('limit', pageSize);
      params.set('offset', currentOffset);
      if (sortField) params.set('sort', sortField);
      params.set('order', sortDir);

      var res = await fetch('/api/seo-index?' + params.toString());
      var data = await res.json();

      var counts = { indexed: 0, discovered: 0, not_indexed: 0, excluded: 0, error: 0 };
      (data.summary || []).forEach(function(s) { counts[s.status] = s.count; });
      var grandTotal = counts.indexed + counts.discovered + counts.not_indexed + counts.excluded + counts.error;
      document.getElementById('count-indexed').textContent = counts.indexed;
      document.getElementById('count-discovered').textContent = counts.discovered;
      document.getElementById('count-not_indexed').textContent = counts.not_indexed;
      document.getElementById('count-excluded').textContent = counts.excluded;
      document.getElementById('count-total').textContent = grandTotal;
      document.getElementById('count-avg-h2').textContent = data.avg_h2 || '0';
      document.getElementById('count-avg-kw').textContent = data.has_keywords || '0';

      // Pagination info
      var totalPages = Math.ceil(data.total / pageSize);
      var currentPage = Math.floor(currentOffset / pageSize) + 1;
      document.getElementById('page-info').textContent = 'Page ' + currentPage + ' of ' + totalPages + ' (' + data.total + ' total)';
      document.getElementById('prev-page').disabled = currentOffset === 0;
      document.getElementById('next-page').disabled = currentOffset + pageSize >= data.total;

      if (!data.entries || data.entries.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="10" class="px-4 py-8 text-center text-gray-500 italic">No entries found.</td></tr>';
        return;
      }

      var priLabels = {'1.0':'Homepage','0.8':'Blog Index','0.7':'Category Hub','0.6':'Blog Post','0.5':'Secondary','0.4':'Utility','0.3':'Legal'};
      function getPriority(url) {
        if (url === '/') return '1.0';
        if (url === '/blog/' || url === '/blog') return '0.8';
        if (/^\/blog\/(beginner-guides|two-letter-words|three-letter-words|strategy|tournament|bingos|high-scoring|letter-guides|dictionaries)\/?$/.test(url)) return '0.7';
        if (/^\/blog\//.test(url)) return '0.6';
        if (/^\/(guide|faq|achievements|releases|tech-stack)\/?$/.test(url)) return '0.5';
        if (/^\/(suggest|contact|settings)\/?$/.test(url)) return '0.4';
        if (/^\/(privacy|disclaimer|terms)\/?$/.test(url)) return '0.3';
        return '0.6';
      }

      currentEntries = data.entries;
      renderTable();
    }

    function renderTable() {
      tableBody.innerHTML = currentEntries.map(function(e) {
        var colors = statusColors[e.status] || statusColors.error;
        var titleLen = e.seo_title_length || 0;
        var descLen = e.seo_desc_length || 0;
        var titleColor = titleLen > 70 ? 'text-red-400' : titleLen < 30 ? 'text-amber-400' : 'text-green-400';
        var descColor = descLen > 155 ? 'text-red-400' : descLen < 120 ? 'text-amber-400' : 'text-green-400';
        return '<tr class="hover:bg-gray-800/50">' +
          '<td class="px-3 py-2 text-gray-200 font-mono text-xs max-w-[200px] truncate" title="' + escHtml(e.url) + '">' + (e.pinned ? '<span class="text-amber-400 mr-1">📌</span>' : '') + '<a href="' + escHtml(e.url) + '" target="_blank" class="hover:text-blue-400 transition-colors">🔗</a> ' + escHtml(e.url) + '</td>' +
          '<td class="px-3 py-2"><span class="px-2 py-0.5 rounded text-xs font-medium border ' + colors + '">' + e.status + '</span></td>' +
          '<td class="px-3 py-2 text-xs ' + titleColor + '" title="' + escHtml(e.seo_title) + '">' + titleLen + '</td>' +
          '<td class="px-3 py-2 text-xs ' + descColor + '">' + descLen + '</td>' +
          '<td class="px-3 py-2 text-xs text-gray-400">' + (e.seo_h2_count || 0) + '</td>' +
          '<td class="px-3 py-2 text-xs">' + (e.seo_json_ld_article ? '<span class="text-green-400">✓</span>' : '<span class="text-red-400">✗</span>') + ' ' + (e.seo_json_ld_faq ? '<span class="text-green-400">✓</span>' : '<span class="text-red-400">✗</span>') + '</td>' +
          '<td class="px-3 py-2 text-xs text-gray-500">' + (e.seo_word_count || 0) + '</td>' +
          '<td class="px-3 py-2 text-xs text-gray-500">' + (e.seo_internal_links || 0) + '</td>' +
          '<td class="px-3 py-2 text-gray-400 text-xs">' + (e.last_crawled || '—') + '</td>' +
          '<td class="px-3 py-2 text-center">' +
            '<button class="edit-btn text-blue-400 hover:text-blue-300 text-xs mr-1" data-record=\'' + JSON.stringify({id:e.id,url:e.url,status:e.status,last_crawled:e.last_crawled||'',first_indexed:e.first_indexed||'',notes:e.notes||'',pinned:e.pinned||0,seo_title:e.seo_title||'',seo_h1:e.seo_h1||'',seo_meta_description:e.seo_meta_description||'',seo_meta_keywords:e.seo_meta_keywords||'',seo_h2_count:e.seo_h2_count||0,seo_json_ld_article:e.seo_json_ld_article||0,seo_json_ld_faq:e.seo_json_ld_faq||0}).replace(/'/g,"&#39;") + '\'>Edit</button>' +
            '<button class="del-btn text-red-400 hover:text-red-300 text-xs" data-id="' + e.id + '">✕</button>' +
          '</td></tr>';
      }).join('');

      document.querySelectorAll('.edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { openEdit(JSON.parse(btn.dataset.record)); });
      });
      document.querySelectorAll('.del-btn').forEach(function(btn) {
