---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/global.css';
---

<Layout title="Ops — Admin — ScrabbleWordsFinder" description="Operations panel for ScrabbleWordsFinder.com" keywords="admin, ops, operations, scrabble word finder">
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/report/" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/ops/" class="text-purple-400 font-medium">Ops</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-white mb-2">⚙️ Operations</h1>
    <p class="text-gray-400 mb-8">System operations, monitoring, and quick actions.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- DB Stats -->
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-6">
        <h2 class="font-semibold text-white mb-3">📈 Database Stats</h2>
        <div id="db-stats" class="text-sm text-gray-400">
          <p class="italic">Loading...</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-6">
        <h2 class="font-semibold text-white mb-3">🚀 Quick Actions</h2>
        <div class="space-y-3">
          <button id="refresh-stats-btn" class="w-full px-4 py-2 rounded-lg bg-purple-900/50 border border-purple-700 text-purple-200 text-sm font-medium hover:bg-purple-800 transition-colors">
            🔄 Refresh Stats
          </button>
          <button id="count-clicks-btn" class="w-full px-4 py-2 rounded-lg bg-blue-900/50 border border-blue-700 text-blue-200 text-sm font-medium hover:bg-blue-800 transition-colors">
            📊 Count Total Clicks
          </button>
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-gray-800 bg-gray-900/50 p-6">
      <h2 class="font-semibold text-white mb-3">📋 System Info</h2>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div><span class="text-gray-500">Environment:</span> <span class="text-white font-mono" id="env-label">Production</span></div>
        <div><span class="text-gray-500">Database:</span> <span class="text-white font-mono">Cloudflare D1</span></div>
        <div><span class="text-gray-500">Framework:</span> <span class="text-white font-mono">Astro 6.4</span></div>
        <div><span class="text-gray-500">Runtime:</span> <span class="text-white font-mono">Cloudflare Workers</span></div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  async function loadStats() {
    const el = document.getElementById('db-stats');
    try {
      const [clicksRes, tasksRes] = await Promise.all([
        fetch('/api/clicks?count=true'),
        fetch('/api/tasks?limit=1'),
      ]);
      const clicks = await clicksRes.json();
      const tasks = await tasksRes.json();
      el.innerHTML = `
        <div class="space-y-2">
          <div class="flex justify-between"><span>Total Clicks:</span><span class="font-mono text-blue-400">${(clicks.total || 0).toLocaleString()}</span></div>
          <div class="flex justify-between"><span>Total Tasks:</span><span class="font-mono text-purple-400">${tasks.total || 0}</span></div>
        </div>
      `;
    } catch (e) {
      el.innerHTML = '<p class="text-red-400">Failed to load stats</p>';
    }
  }

  loadStats();
  document.getElementById('refresh-stats-btn').addEventListener('click', loadStats);

  document.getElementById('count-clicks-btn').addEventListener('click', async function() {
    const res = await fetch('/api/clicks?count=true');
    const data = await res.json();
    alert('Total clicks: ' + (data.total || 0).toLocaleString());
  });
</script>
