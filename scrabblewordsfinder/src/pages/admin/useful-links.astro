// Filter out empty categories
const filteredCategories = categories.filter(c => c.links.length > 0);

// Total count
const totalOrphans = filteredCategories.reduce((sum, c) => sum + c.links.length, 0);
---

<Layout title="Useful Links in Blogs — Admin" description="Orphan blog pages with no inbound links, organized by category" keywords="admin, useful links, orphan pages, internal linking">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/useful-links/" class="text-amber-400 font-medium">Useful Links</a>
      <a href="/admin/seo/" class="hover:text-blue-400 transition-colors">SEO</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-2">
      <h1 class="text-3xl font-bold text-white">🔗 Useful Links in Blogs</h1>
      <span class="text-sm text-gray-500 bg-gray-800 px-3 py-1 rounded-full">{totalOrphans} orphan pages</span>
    </div>
    <p class="text-gray-400 mb-8 max-w-2xl">
      Blog pages that exist but have <strong class="text-amber-400">zero inbound links</strong> from any other page, navigation, or sitemap.
      These are invisible to both users and search engines until linked.
    </p>

    <!-- Summary Strip -->
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-10">
      {filteredCategories.slice(0, 7).map(cat => (
        <div class="text-center p-3 rounded-lg bg-gray-800/60 border border-gray-700">
          <p class="text-lg font-bold text-white">{cat.links.length}</p>
          <p class="text-[10px] text-gray-400 leading-tight mt-0.5">{cat.name.split('(')[0].trim()}</p>
        </div>
      ))}
    </div>

    <!-- Category Panels -->
    <div class="space-y-4">
      {filteredCategories.map(cat => (
        <details open={!cat.collapsed} class="group rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none hover:bg-gray-800/30 transition-colors">
            <div class="flex items-center gap-3">
              <span class="text-xl">{cat.icon}</span>
              <h2 class="text-lg font-semibold text-white">{cat.name}</h2>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full bg-${cat.color}-900/40 text-${cat.color}-400 border border-${cat.color}-800/50`}>
                {cat.links.length}
              </span>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5 pt-2">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
              {cat.links.map(slug => (
                <a
                  href={`/blog/${slug}/`}
                  target="_blank"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-800 hover:border-amber-700 hover:bg-amber-900/10 transition-all group/link text-sm"
                >
                  <span class="text-amber-500 group-hover/link:translate-x-0.5 transition-transform shrink-0">→</span>
                  <span class="text-gray-300 group-hover/link:text-amber-400 transition-colors truncate">
                    {slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
                  </span>
                  <svg class="w-3.5 h-3.5 text-gray-600 shrink-0 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Footer info -->
    <div class="mt-10 p-4 rounded-xl border border-gray-800 bg-gray-900/30 text-sm text-gray-500">
      <p><strong class="text-gray-300">How to fix:</strong> Add inbound links to these pages from related blog posts, category landing pages, or the letter-guides hub. Each page linked from at least one other page helps Google discover and rank it.</p>
      <p class="mt-2">Run <code class="bg-gray-800 px-1.5 py-0.5 rounded text-amber-400 text-xs">CheckPorts swf</code> or the SEO health check to monitor progress.</p>
    </div>
  </div>
</Layout>
