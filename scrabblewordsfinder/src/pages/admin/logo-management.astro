---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Logo Management — Admin — ScrabbleWordsFinder" description="Select the active logo for ScrabbleWordsFinder.com" keywords="admin, logo, branding">
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/report/" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/ops/" class="hover:text-blue-400 transition-colors">Ops</a>
      <a href="/admin/logo-management/" class="text-blue-400 font-medium">Logo</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">🎨 Logo Management</h1>
    <p class="text-gray-400 mb-8">Select the active logo for ScrabbleWordsFinder.com. Your choice will be stored in the database and used site-wide.</p>

    <!-- Security notice -->
    <div class="mb-6 rounded-xl border border-amber-800/50 bg-amber-950/20 p-3 flex items-center gap-3">
      <span class="text-amber-400 text-lg">🔒</span>
      <p class="text-xs text-amber-300/80">Logo changes require re-authentication. Only <strong class="text-amber-200">raj007@gmail.com</strong> and <strong class="text-amber-200">xconvert24@gmail.com</strong> can update the active logo.</p>
    </div>

    <!-- Current active indicator -->
    <div id="current-logo-banner" class="mb-6 rounded-xl border border-blue-800 bg-blue-950/30 p-4 flex items-center gap-4">
      <img id="current-logo-img" src="/logo-options/option-1.svg" alt="Current active logo" class="h-12 w-12 rounded-lg bg-gray-800 p-1" />
      <div>
        <p class="text-blue-300 text-sm font-medium">Active Logo: <span id="current-logo-label">Option 1</span></p>
        <p class="text-gray-400 text-xs" id="current-logo-updated">Loading...</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="logo-grid">

      <!-- Option 1 -->
      <div class="logo-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-5 text-center transition-all" data-option="1">
        <div class="flex items-center justify-center bg-gray-800 rounded-lg p-6 mb-4">
          <img src="/logo-options/option-1.svg" alt="Logo option 1" class="h-20 w-20" />
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Option 1</h3>
        <p class="text-xs text-gray-400 mb-3">Magnifier lens with S tile inside. Classic search metaphor.</p>
        <button class="set-logo-btn w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-4 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-option="1">
          Set as Active
        </button>
      </div>

      <!-- Option 2 -->
      <div class="logo-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-5 text-center transition-all" data-option="2">
        <div class="flex items-center justify-center bg-gray-800 rounded-lg p-6 mb-4">
          <img src="/logo-options/option-2.svg" alt="Logo option 2" class="h-20 w-20" />
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Option 2</h3>
        <p class="text-xs text-gray-400 mb-3">Full Scrabble tile with blue magnifier overlay. Tile-first brand.</p>
        <button class="set-logo-btn w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-4 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-option="2">
          Set as Active
        </button>
      </div>

      <!-- Option 3 -->
      <div class="logo-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-5 text-center transition-all" data-option="3">
        <div class="flex items-center justify-center bg-gray-800 rounded-lg p-6 mb-4">
          <img src="/logo-options/option-3.svg" alt="Logo option 3" class="h-20 w-20" />
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Option 3</h3>
        <p class="text-xs text-gray-400 mb-3">Green magnifier with tile-textured lens. Nature/word-garden vibe.</p>
        <button class="set-logo-btn w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-4 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-option="3">
          Set as Active
        </button>
      </div>

      <!-- Option 4 -->
      <div class="logo-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-5 text-center transition-all" data-option="4">
        <div class="flex items-center justify-center bg-gray-800 rounded-lg p-6 mb-4">
          <img src="/logo-options/option-4.svg" alt="Logo option 4" class="h-20 w-20" />
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Option 4</h3>
        <p class="text-xs text-gray-400 mb-3">Tilted tile with red floating magnifier. Playful and dynamic.</p>
        <button class="set-logo-btn w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-4 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-option="4">
          Set as Active
        </button>
      </div>

      <!-- Option 5 -->
      <div class="logo-option rounded-xl border-2 border-gray-700 bg-gray-900/50 p-5 text-center transition-all" data-option="5">
        <div class="flex items-center justify-center bg-gray-800 rounded-lg p-6 mb-4">
          <img src="/logo-options/option-5.svg" alt="Logo option 5" class="h-20 w-20" />
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Option 5</h3>
        <p class="text-xs text-gray-400 mb-3">Minimalist modern brand mark. Navy + gold gradient. Cleanest.</p>
        <button class="set-logo-btn w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-4 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-option="5">
          Set as Active
        </button>
      </div>

    </div>

    <!-- Confirmation -->
    <div id="confirmation" class="hidden mt-6 rounded-xl border border-green-800 bg-green-950/30 p-4 text-center">
      <p class="text-green-300 text-sm font-medium">✅ Logo updated!</p>
      <p class="text-gray-400 text-xs mt-1" id="confirmation-text"></p>
    </div>

    <!-- Error -->
    <div id="error-banner" class="hidden mt-6 rounded-xl border border-red-800 bg-red-950/30 p-4 text-center">
      <p class="text-red-300 text-sm font-medium" id="error-text">❌ Something went wrong.</p>
    </div>
  </div>

  <script>
    const descriptions: Record<string, string> = {
      '1': 'Option 1 — Magnifier with S tile',
      '2': 'Option 2 — Full tile with blue magnifier',
      '3': 'Option 3 — Green magnifier, tile-textured',
      '4': 'Option 4 — Tilted tile, red magnifier',
      '5': 'Option 5 — Minimalist modern brand mark',
    };

    let activeOption = '1';

    function highlightActive(option: string) {
      document.querySelectorAll('.logo-option').forEach(el => {
        const opt = (el as HTMLElement).dataset.option;
        if (opt === option) {
          el.classList.remove('border-gray-700');
          el.classList.add('border-blue-500', 'ring-2', 'ring-blue-500/30');
          const btn = el.querySelector('.set-logo-btn') as HTMLButtonElement;
          if (btn) {
            btn.disabled = true;
            btn.textContent = '✓ Active';
          }
        } else {
          el.classList.remove('border-blue-500', 'ring-2', 'ring-blue-500/30');
          el.classList.add('border-gray-700');
          const btn = el.querySelector('.set-logo-btn') as HTMLButtonElement;
          if (btn) {
            btn.disabled = false;
            btn.textContent = 'Set as Active';
          }
        }
      });

      // Update banner
      const img = document.getElementById('current-logo-img') as HTMLImageElement;
      const label = document.getElementById('current-logo-label')!;
      if (img) img.src = `/logo-options/option-${option}.svg`;
      if (label) label.textContent = descriptions[option] || `Option ${option}`;
    }

    // Load current status from API
    async function loadStatus() {
      try {
        const res = await fetch('/api/site-status');
        if (!res.ok) throw new Error('Failed to load');
        const data = await res.json();
        activeOption = String(data.logo_option || '1');
        highlightActive(activeOption);

        const updatedEl = document.getElementById('current-logo-updated');
        if (updatedEl && data.updated_at) {
          const d = new Date(data.updated_at + 'Z');
          updatedEl.textContent = `Last updated: ${d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })} by ${data.updated_by || 'system'}`;
        }
      } catch {
        highlightActive('1');
      }
    }

    // Set logo via API (with re-auth handling)
    async function setLogo(option: string) {
      const confirmation = document.getElementById('confirmation')!;
      const confirmText = document.getElementById('confirmation-text')!;
      const errorBanner = document.getElementById('error-banner')!;
      const errorText = document.getElementById('error-text')!;

      errorBanner.classList.add('hidden');

      // Show re-auth confirmation
      if (!confirm('🔒 Changing the active logo requires authentication.\n\nOnly raj007@gmail.com and xconvert24@gmail.com can make this change.\n\nProceed?')) {
        return;
      }

      try {
        const res = await fetch('/api/site-status', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ logo_option: Number(option) }),
        });

        if (res.status === 401) {
          // Session expired or missing — redirect to re-login then come back
          const err = await res.json();
          errorBanner.classList.remove('hidden');
          errorText.textContent = `🔒 ${err.error || 'Session expired.'} Redirecting to login...`;
          setTimeout(() => {
            window.location.href = '/api/auth/login?redirect=/admin/logo-management';
          }, 1500);
          return;
        }

        if (res.status === 403) {
          const err = await res.json();
          errorBanner.classList.remove('hidden');
          errorText.textContent = `⛔ ${err.error || 'Access denied.'}`;
          setTimeout(() => errorBanner.classList.add('hidden'), 6000);
          return;
        }

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || 'Update failed');
        }

        activeOption = option;
        highlightActive(option);

        confirmation.classList.remove('hidden');
        confirmText.textContent = `${descriptions[option]} is now the active website logo.`;
        setTimeout(() => confirmation.classList.add('hidden'), 4000);
      } catch (e: any) {
        errorBanner.classList.remove('hidden');
        errorText.textContent = `❌ ${e.message}`;
        setTimeout(() => errorBanner.classList.add('hidden'), 5000);
      }
    }

    // Bind click handlers
    document.querySelectorAll('.set-logo-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const option = (btn as HTMLElement).dataset.option;
        if (option) setLogo(option);
      });
    });

    // Init
    loadStatus();
  </script>
</Layout>
