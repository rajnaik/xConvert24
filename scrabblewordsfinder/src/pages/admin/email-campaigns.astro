---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Email Campaigns — Admin — ScrabbleWordsFinder" description="Manage outreach campaign leads" keywords="admin, campaigns, leads" >
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/emails/" class="hover:text-blue-400 transition-colors">Emails</a>
      <a href="/admin/email-campaigns/" class="text-blue-400 font-medium">Campaigns</a>
      <a href="/admin/clicks/" class="hover:text-blue-400 transition-colors">Clicks</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">📬 Email Campaigns</h1>
    <p class="text-gray-400 mb-6">Manage outreach leads from the <code class="text-xs bg-gray-800 px-1.5 py-0.5 rounded">campaign_leads</code> table. Track who you've emailed and responses.</p>

    <!-- Stats -->
    <div class="grid grid-cols-4 sm:grid-cols-8 gap-3 mb-6">
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Total Leads</p>
        <p class="text-2xl font-bold text-white" id="stat-total">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Sent</p>
        <p class="text-2xl font-bold text-green-400" id="stat-sent">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Pending</p>
        <p class="text-2xl font-bold text-amber-400" id="stat-pending">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Bounced</p>
        <p class="text-2xl font-bold text-red-400" id="stat-bounced">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Prospective</p>
        <p class="text-2xl font-bold text-emerald-400" id="stat-prospective">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">No Response</p>
        <p class="text-2xl font-bold text-amber-400" id="stat-noresponse">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Campaign Set</p>
        <p class="text-2xl font-bold text-blue-400" id="stat-set">1</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4 flex flex-col items-center justify-center cursor-pointer hover:bg-gray-700/60 transition-colors" id="download-extract-tile">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Download Extract</p>
        <p class="text-xl font-bold text-purple-400">📥</p>
        <p class="text-[10px] text-gray-500 mt-1 download-status">Excel (14 sheets, 250/batch)</p>
      </div>
    </div>

    <!-- Email Variant Selector -->
    <div class="mb-4 p-3 rounded-lg border border-gray-700 bg-gray-800/40 flex flex-wrap items-center gap-3">
      <span class="text-xs text-gray-400 font-semibold uppercase tracking-wide">Email variant:</span>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="office" checked class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">office@</span>
      </label>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="admin" class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">admin@</span>
      </label>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="enquiries" class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">enquiries@</span>
      </label>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="info" class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">info@</span>
      </label>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="reception" class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">reception@</span>
      </label>
      <label class="flex items-center gap-1.5 cursor-pointer">
        <input type="radio" name="email-variant" value="all" class="w-3 h-3 text-purple-500 bg-gray-800 border-gray-600 focus:ring-purple-500/30">
        <span class="text-xs text-gray-300">All (comma list)</span>
      </label>
    </div>

    <!-- Batch Status Panel (compact) -->
    <details class="mb-4">
      <summary class="cursor-pointer text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 py-2 rounded-lg border border-gray-700 bg-gray-800/40 hover:bg-gray-700/40 transition-colors">Batch Status ▾</summary>
      <div class="mt-2 p-3 rounded-xl border border-gray-700 bg-gray-800/40">
        <div id="batch-toggles" class="flex flex-wrap gap-2"></div>
      </div>
    </details>

    <!-- Filters + Actions -->
    <div class="flex gap-3 mb-4 flex-wrap">
      <select id="filter-batch" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm">
        <option value="">All Batches</option>
      </select>
      <select id="filter-sent" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm">
        <option value="">All</option>
        <option value="0">Not sent</option>
        <option value="1">Sent</option>
      </select>
      <select id="filter-bounced" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm">
        <option value="">All</option>
        <option value="1">Bounced only</option>
        <option value="0">Not bounced</option>
        <option value="prospective">Prospective (has response)</option>
      </select>
      <button id="filter-pinned" class="h-9 px-3 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm hover:border-amber-500 hover:text-amber-400 transition-colors">📌 Pinned</button>
      <button id="refresh-btn" class="h-9 px-4 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors">🔄 Refresh</button>
      <button id="add-btn" class="h-9 px-4 rounded-lg bg-green-600 hover:bg-green-500 text-white text-sm font-medium transition-colors ml-auto">+ Add Lead</button>
    </div>

    <!-- Extract Range -->
    <div class="flex items-center gap-3 mb-4 p-3 rounded-lg bg-gray-800/40 border border-gray-700">
      <span class="text-xs text-gray-400">Extract:</span>
      <input id="extract-from" type="number" min="1" placeholder="From" class="h-8 w-20 px-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm text-center" />
      <span class="text-gray-500">→</span>
      <input id="extract-to" type="number" min="1" placeholder="To" class="h-8 w-20 px-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm text-center" />
      <button id="extract-btn" class="h-8 px-4 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors">Extract</button>
    </div>

    <!-- Extract Result Bubble -->
    <div id="extract-bubble" class="hidden mb-4 p-4 rounded-xl border border-purple-500/30 bg-purple-950/20 relative">
      <button id="extract-close" class="absolute top-2 right-3 text-gray-400 hover:text-white text-lg">&times;</button>
      <p class="text-xs text-purple-400 uppercase tracking-wider font-semibold mb-2">Extracted Records</p>
      <pre id="extract-content" class="text-xs text-gray-300 whitespace-pre-wrap max-h-64 overflow-y-auto"></pre>
      <button id="extract-copy" class="mt-3 h-7 px-3 rounded-lg bg-purple-700 hover:bg-purple-600 text-white text-xs font-medium transition-colors">Copy to Clipboard</button>
      <button id="extract-save" class="mt-3 ml-2 h-7 px-3 rounded-lg bg-blue-700 hover:bg-blue-600 text-white text-xs font-medium transition-colors">Save to Disk</button>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/80">
          <tr>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">#</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">School</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">Email</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">Contact</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">Town</th>
            <th class="px-3 py-2 text-center text-gray-400 font-medium">Sent</th>
            <th class="px-3 py-2 text-center text-gray-400 font-medium">Variant</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">Sent At</th>
            <th class="px-3 py-2 text-left text-gray-400 font-medium">Batch</th>
            <th class="px-3 py-2 text-center text-gray-400 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody id="leads-table" class="divide-y divide-gray-800"></tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500 mt-2" id="row-count"></p>
    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4">
      <button id="prev-btn" class="h-8 px-4 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm hover:bg-gray-700 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">&lt; Prev</button>
      <span id="page-info" class="text-sm text-gray-400"></span>
      <button id="next-btn" class="h-8 px-4 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 text-sm hover:bg-gray-700 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">Next &gt;</button>
    </div>

    <!-- View/Edit Modal -->
    <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70">
      <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <h2 class="text-xl font-bold text-white mb-4" id="modal-title">Lead Details</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1">School Name</label>
            <input id="f-school" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Email</label>
            <input id="f-email" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Contact Person</label>
            <input id="f-contact" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Role</label>
              <input id="f-role" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Town</label>
              <input id="f-town" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Campaign Set</label>
              <input id="f-set" type="number" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Sent</label>
              <select id="f-sent" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm">
                <option value="0">No</option>
                <option value="1">Yes</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Sent At</label>
            <input id="f-sent-at" type="date" class="w-full h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Response / Notes</label>
            <textarea id="f-response" rows="3" class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-200 text-sm"></textarea>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button id="modal-cancel" class="h-9 px-4 rounded-lg bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm transition-colors">Cancel</button>
          <button id="modal-delete" class="h-9 px-4 rounded-lg bg-red-600 hover:bg-red-500 text-white text-sm transition-colors hidden">Delete</button>
          <button id="modal-save" class="h-9 px-4 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors">Save</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    let currentId = null;
    let currentOffset = 0;
    const PAGE_SIZE = 50;

    async function loadLeads() {
      const sent = document.getElementById('filter-sent').value;
      const batch = document.getElementById('filter-batch').value;
      const bounced = document.getElementById('filter-bounced').value;
      const params = new URLSearchParams();
      if (sent) params.set('sent', sent);
      if (batch) params.set('batch', batch);
      if (bounced === '1' || bounced === '0') params.set('bounced', bounced);
      if (bounced === 'prospective') params.set('has_response', '1');
      const pinnedActive = document.getElementById('filter-pinned').dataset.active;
      if (pinnedActive === '1') params.set('pinned', '1');
      params.set('limit', PAGE_SIZE);
      params.set('offset', currentOffset);

      const res = await fetch('/api/campaign-leads/?' + params.toString());
      const data = await res.json();
      if (!data.leads) return;

      document.getElementById('stat-total').textContent = data.global_total || data.total;
      document.getElementById('stat-sent').textContent = data.sent_count;
      document.getElementById('stat-pending').textContent = (data.global_total || data.total) - data.sent_count;
      document.getElementById('stat-bounced').textContent = data.bounced_count || 0;
      document.getElementById('stat-prospective').textContent = data.prospective_count || 0;
      document.getElementById('stat-noresponse').textContent = data.no_response_count || 0;

      // Populate batch filter dropdown and batch toggles from API
      const batchSelect = document.getElementById('filter-batch');
      const currentBatch = batchSelect.value;
      const batches = data.batches || [];
      const batchNames = batches.map(b => b.name);
      const existingOpts = [...batchSelect.options].map(o => o.value).filter(Boolean);
      if (JSON.stringify(batchNames) !== JSON.stringify(existingOpts)) {
        batchSelect.innerHTML = '<option value="">All Batches</option>' + batchNames.map(b => `<option value="${b}" ${b === currentBatch ? 'selected' : ''}>${b}</option>`).join('');
      }

      // Render batch status cards with 3-position slider
      const toggleContainer = document.getElementById('batch-toggles');
      toggleContainer.innerHTML = batches.map(b => {
        // Use status from API (persisted in batch_status table)
        const statusMap = { 'not_started': 0, 'scheduled': 1, 'finished': 2 };
        let pos = statusMap[b.status] !== undefined ? statusMap[b.status] : (b.sent === b.total ? 2 : b.sent === 0 ? 0 : 1);
        const colors = ['border-gray-600 bg-gray-900/50', 'border-amber-500/40 bg-amber-950/20', 'border-green-500/40 bg-green-950/20'];
        const dotColors = ['bg-gray-500', 'bg-amber-400', 'bg-green-400'];
        const labels = ['Not Started', 'Scheduled', 'Finished'];
        return `
          <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg border ${colors[pos]} text-xs">
            <span class="text-gray-300 font-medium">${b.name}</span>
            <span class="text-gray-500">(${b.sent}/${b.total})</span>
            <input type="range" min="0" max="2" value="${pos}" class="batch-slider w-14 h-1.5 rounded-lg appearance-none cursor-pointer" data-batch="${b.name}" style="accent-color: ${pos === 0 ? '#6b7280' : pos === 1 ? '#f59e0b' : '#22c55e'}" />
            <span class="w-2 h-2 rounded-full ${dotColors[pos]}"></span>
          </div>`;
      }).join('');

      // Pagination state
      const totalPages = Math.ceil(data.total / PAGE_SIZE);
      const currentPage = Math.floor(currentOffset / PAGE_SIZE) + 1;
      document.getElementById('page-info').textContent = `Page ${currentPage} of ${totalPages}`;
      document.getElementById('prev-btn').disabled = currentOffset === 0;
      document.getElementById('next-btn').disabled = currentOffset + PAGE_SIZE >= data.total;

      const tbody = document.getElementById('leads-table');
      tbody.innerHTML = data.leads.map((l, idx) => {
        const isProspective = !l.bounced && l.response && l.response.trim() !== '';
        const isNoResponse = !l.bounced && !isProspective && l.sent;
        const rowClass = 'hover:bg-gray-800/50';
        // Email variant cell color: red=bounced, green=prospective, amber=sent no response
        const variantColor = l.bounced ? 'bg-red-900/40 text-red-400' : isProspective ? 'bg-green-900/40 text-green-400' : isNoResponse ? 'bg-amber-900/40 text-amber-400' : 'text-gray-500';
        const variantText = l.email_variant_sent || '—';
        const bouncedBadge = l.bounced ? '<span class="ml-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-900/50 text-red-400">BOUNCED</span>' : isProspective ? '<span class="ml-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-green-900/50 text-green-400">PROSPECTIVE</span>' : isNoResponse ? '<span class="ml-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-900/50 text-amber-400">NO RESPONSE</span>' : '';
        return `
        <tr class="${rowClass} transition-colors">
          <td class="px-3 py-2 text-gray-500 text-xs">${currentOffset + idx + 1}</td>
          <td class="px-3 py-2 text-gray-200 font-medium">${esc(l.school_name)}${bouncedBadge}</td>
          <td class="px-3 py-2 text-gray-400 text-xs">${esc(l.email)}</td>
          <td class="px-3 py-2 text-gray-300 text-xs">${esc(l.contact_person)}</td>
          <td class="px-3 py-2 text-gray-400 text-xs">${esc(l.town)}</td>
          <td class="px-3 py-2 text-center">${l.bounced ? '<span class="text-red-400">✗</span>' : l.sent ? '<span class="text-green-400">✓</span>' : '<span class="text-gray-600">—</span>'}</td>
          <td class="px-3 py-2 text-center"><span class="px-1.5 py-0.5 rounded text-[10px] font-medium ${variantColor}">${variantText || '—'}</span></td>
          <td class="px-3 py-2 text-gray-400 text-xs">${l.sent_at || '—'}</td>
          <td class="px-3 py-2 text-gray-400 text-xs">${esc(l.batch || '—')}</td>
          <td class="px-3 py-2 text-center">
            <button onclick="togglePin(${l.id}, ${l.pinned ? 0 : 1})" class="text-xs ${l.pinned ? 'text-amber-400' : 'text-gray-600 hover:text-amber-400'} transition-colors" title="${l.pinned ? 'Unpin' : 'Pin'}">📌</button>
            <button onclick="viewLead(${l.id})" class="text-blue-400 hover:text-blue-300 text-xs mr-2">View</button>
            <button onclick="markSent(${l.id})" class="text-green-400 hover:text-green-300 text-xs ${l.sent || l.bounced ? 'hidden' : ''}">Mark Sent</button>
          </td>
        </tr>`;
      }).join('');

      document.getElementById('row-count').textContent = `Showing ${data.leads.length} of ${data.total} leads`;
    }

    function esc(str) { return (str || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

    async function viewLead(id) {
      const res = await fetch('/api/campaign-leads/?id=' + id);
      const data = await res.json();
      if (!data.lead) return;
      const l = data.lead;

      currentId = l.id;
      document.getElementById('f-school').value = l.school_name || '';
      document.getElementById('f-email').value = l.email || '';
      document.getElementById('f-contact').value = l.contact_person || '';
      document.getElementById('f-role').value = l.role || '';
      document.getElementById('f-town').value = l.town || '';
      document.getElementById('f-set').value = l.campaign_email_set || 1;
      document.getElementById('f-sent').value = l.sent || 0;
      document.getElementById('f-sent-at').value = l.sent_at || '';
      document.getElementById('f-response').value = l.response || '';

      document.getElementById('modal-title').textContent = 'Edit: ' + l.school_name;
      document.getElementById('modal-delete').classList.remove('hidden');
      showModal();
    }

    async function togglePin(id, pinValue) {
      await fetch('/api/campaign-leads/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, pinned: pinValue })
      });
      loadLeads();
    }

    async function markSent(id) {
      const today = new Date().toISOString().split('T')[0];
      await fetch('/api/campaign-leads/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, sent: 1, sent_at: today })
      });
      loadLeads();
    }

    function showModal() {
      const m = document.getElementById('modal');
      m.classList.remove('hidden');
      m.classList.add('flex');
    }

    function hideModal() {
      const m = document.getElementById('modal');
      m.classList.add('hidden');
      m.classList.remove('flex');
      currentId = null;
    }

    document.getElementById('add-btn').addEventListener('click', () => {
      currentId = null;
      document.getElementById('f-school').value = '';
      document.getElementById('f-email').value = '';
      document.getElementById('f-contact').value = '';
      document.getElementById('f-role').value = 'Headteacher';
      document.getElementById('f-town').value = '';
      document.getElementById('f-set').value = '1';
      document.getElementById('f-sent').value = '0';
      document.getElementById('f-sent-at').value = '';
      document.getElementById('f-response').value = '';
      document.getElementById('modal-title').textContent = 'Add New Lead';
      document.getElementById('modal-delete').classList.add('hidden');
      showModal();
    });

    document.getElementById('modal-cancel').addEventListener('click', hideModal);
    document.getElementById('modal').addEventListener('click', (e) => { if (e.target === e.currentTarget) hideModal(); });

    document.getElementById('modal-save').addEventListener('click', async () => {
      const payload = {
        school_name: document.getElementById('f-school').value,
        email: document.getElementById('f-email').value,
        contact_person: document.getElementById('f-contact').value,
        role: document.getElementById('f-role').value,
        town: document.getElementById('f-town').value,
        campaign_email_set: parseInt(document.getElementById('f-set').value) || 1,
        sent: parseInt(document.getElementById('f-sent').value) || 0,
        sent_at: document.getElementById('f-sent-at').value || null,
        response: document.getElementById('f-response').value,
      };

      if (currentId) {
        payload.id = currentId;
        await fetch('/api/campaign-leads/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      } else {
        await fetch('/api/campaign-leads/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      }
      hideModal();
      loadLeads();
    });

    document.getElementById('modal-delete').addEventListener('click', async () => {
      if (!currentId) return;
      if (!confirm('Delete this lead permanently?')) return;
      await fetch('/api/campaign-leads/', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: currentId }) });
      hideModal();
      loadLeads();
    });

    document.getElementById('filter-sent').addEventListener('change', () => { currentOffset = 0; loadLeads(); });
    document.getElementById('filter-batch').addEventListener('change', () => { currentOffset = 0; loadLeads(); });
    document.getElementById('filter-bounced').addEventListener('change', () => { currentOffset = 0; loadLeads(); });
    document.getElementById('filter-pinned').addEventListener('click', function() {
      const isActive = this.classList.contains('border-amber-500');
      if (isActive) {
        this.classList.remove('border-amber-500', 'text-amber-400', 'bg-amber-900/20');
        this.classList.add('border-gray-700', 'text-gray-300');
        this.dataset.active = '';
      } else {
        this.classList.add('border-amber-500', 'text-amber-400', 'bg-amber-900/20');
        this.classList.remove('border-gray-700', 'text-gray-300');
        this.dataset.active = '1';
      }
      currentOffset = 0;
      loadLeads();
    });
    document.getElementById('refresh-btn').addEventListener('click', loadLeads);
    document.getElementById('prev-btn').addEventListener('click', () => { currentOffset = Math.max(0, currentOffset - PAGE_SIZE); loadLeads(); });
    document.getElementById('next-btn').addEventListener('click', () => { currentOffset += PAGE_SIZE; loadLeads(); });

    // Batch slider delegation (3-position: 0=not started, 1=scheduled, 2=finished)
    document.getElementById('batch-toggles').addEventListener('change', async (e) => {
      if (!e.target.classList.contains('batch-slider')) return;
      const batch = e.target.dataset.batch;
      const pos = parseInt(e.target.value);
      const statusNames = ['not_started', 'scheduled', 'finished'];
      const statusLabels = ['Not Started', 'Scheduled', 'Finished'];

      if (pos === 0) {
        if (!confirm('Reset all leads in ' + batch + ' to "Not Sent"?')) {
          loadLeads();
          return;
        }
        await fetch('/api/campaign-leads/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ batch_update: true, batch, sent: 0 })
        });
      } else if (pos === 2) {
        if (!confirm('Mark all leads in ' + batch + ' as "Finished/Sent"?')) {
          loadLeads();
          return;
        }
        await fetch('/api/campaign-leads/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ batch_update: true, batch, sent: 1 })
        });
      } else {
        // pos === 1: save "scheduled" status without changing lead sent values
        await fetch('/api/campaign-leads/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ batch_status_update: true, batch, status: 'scheduled' })
        });
      }
      loadLeads();
    });

    // Extract range
    document.getElementById('extract-btn').addEventListener('click', async () => {
      const from = parseInt(document.getElementById('extract-from').value) || 1;
      const to = parseInt(document.getElementById('extract-to').value) || from;
      if (to < from) return alert('To must be >= From');
      const limit = to - from + 1;
      const offset = from - 1;
      const batch = document.getElementById('filter-batch').value;
      const sent = document.getElementById('filter-sent').value;
      const params = new URLSearchParams({ limit, offset });
      if (batch) params.set('batch', batch);
      if (sent) params.set('sent', sent);

      const res = await fetch('/api/campaign-leads/?' + params.toString());
      const data = await res.json();
      if (!data.leads || !data.leads.length) return alert('No records found in that range');

      const text = data.leads.map((l) => `${l.school_name}, ${l.email}, ${l.contact_person}`).join('\n');
      document.getElementById('extract-content').textContent = text;
      document.getElementById('extract-bubble').classList.remove('hidden');
    });

    document.getElementById('extract-close').addEventListener('click', () => {
      document.getElementById('extract-bubble').classList.add('hidden');
    });

    document.getElementById('extract-copy').addEventListener('click', () => {
      const text = document.getElementById('extract-content').textContent;
      navigator.clipboard.writeText(text).then(() => {
        document.getElementById('extract-copy').textContent = 'Copied!';
        setTimeout(() => { document.getElementById('extract-copy').textContent = 'Copy to Clipboard'; }, 2000);
      });
    });

    document.getElementById('extract-save').addEventListener('click', () => {
      const text = document.getElementById('extract-content').textContent;
      const blob = new Blob([text], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'campaign-leads-extract.csv';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // Download Extract — all records as multi-sheet XLSX (1 sheet per batch)
    document.getElementById('download-extract-tile').addEventListener('click', async () => {
      const statusEl = document.querySelector('#download-extract-tile .download-status');
      statusEl.textContent = 'Loading library...';

      // Load SheetJS from CDN if not already loaded
      if (!window.XLSX) {
        await new Promise((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js';
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }

      statusEl.textContent = 'Fetching data...';
      const res = await fetch('/api/campaign-leads/?limit=5000&offset=0');
      const data = await res.json();
      if (!data.leads || !data.leads.length) { statusEl.textContent = 'No data'; return; }

      statusEl.textContent = 'Building workbook...';
      const wb = XLSX.utils.book_new();

      // Group leads by batch
      const batches = {};
      data.leads.forEach(l => {
        if (!batches[l.batch]) batches[l.batch] = [];
        batches[l.batch].push(l);
      });

      // Sort batch names numerically
      const sortedBatches = Object.keys(batches).sort((a, b) => {
        const na = parseInt(a.replace('Batch', '')) || 0;
        const nb = parseInt(b.replace('Batch', '')) || 0;
        return na - nb;
      });

      // Create one sheet per batch
      const selectedVariant = document.querySelector('input[name="email-variant"]:checked')?.value || 'office';

      sortedBatches.forEach(batchName => {
        const rows = batches[batchName].map(l => {
          // Extract single email based on selected variant
          let emailValue = l.email;
          if (selectedVariant !== 'all') {
            const emails = (l.email || '').split(',').map(e => e.trim());
            const matched = emails.find(e => e.startsWith(selectedVariant + '@'));
            if (matched) {
              emailValue = matched;
            } else {
              // Fallback: construct from domain of first email
              const firstEmail = emails[0] || '';
              const domain = firstEmail.split('@')[1] || '';
              emailValue = domain ? selectedVariant + '@' + domain : firstEmail;
            }
          }
          return {
            'School Name': l.school_name,
            'Email': emailValue,
            'Contact Person': l.contact_person,
            'Role': l.role,
            'Town': l.town,
            'Sent': l.sent ? 'Yes' : 'No',
            'Bounced': l.bounced ? 'Yes' : '',
            'Response': l.response || '',
            'Sent At': l.sent_at || ''
          };
        });
        const ws = XLSX.utils.json_to_sheet(rows);
        ws['!cols'] = [{wch:35},{wch:40},{wch:25},{wch:18},{wch:18},{wch:6},{wch:8},{wch:40},{wch:12}];
        const sheetName = batchName.length > 31 ? batchName.slice(0, 31) : batchName;
        XLSX.utils.book_append_sheet(wb, ws, sheetName);
      });

      // Download
      XLSX.writeFile(wb, 'campaign-leads-' + selectedVariant + '.xlsx');
      statusEl.textContent = sortedBatches.length + ' sheets (' + selectedVariant + '@)';
    });

    loadLeads();
  </script>
</Layout>
