---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Diamond Hunt — Admin — ScrabbleWordsFinder" description="Manage Diamond Hunt mines across the site" keywords="admin, diamond hunt, gamification">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/diamond-hunt/" class="text-blue-400 font-medium">Diamond Hunt</a>
      <a href="/admin/banner-management/" class="hover:text-blue-400 transition-colors">Banner</a>
      <a href="/admin/ops/" class="hover:text-blue-400 transition-colors">Ops</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">💎 Diamond Hunt Management</h1>
    <p class="text-gray-400 mb-8">Manage diamond mines embedded across 50+ pages. Each mine has a finite pool — first come, first served.</p>

    <!-- Summary stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="rounded-xl border border-blue-800 bg-blue-950/30 p-4 text-center">
        <p class="text-2xl font-bold text-blue-300" id="stat-total">—</p>
        <p class="text-xs text-gray-400">Total Mines</p>
      </div>
      <div class="rounded-xl border border-green-800 bg-green-950/30 p-4 text-center">
        <p class="text-2xl font-bold text-green-300" id="stat-active">—</p>
        <p class="text-xs text-gray-400">Active</p>
      </div>
      <div class="rounded-xl border border-amber-800 bg-amber-950/30 p-4 text-center">
        <p class="text-2xl font-bold text-amber-300" id="stat-depleted">—</p>
        <p class="text-xs text-gray-400">Depleted</p>
      </div>
      <div class="rounded-xl border border-purple-800 bg-purple-950/30 p-4 text-center">
        <p class="text-2xl font-bold text-purple-300" id="stat-claims">—</p>
        <p class="text-xs text-gray-400">Total Claims</p>
      </div>
    </div>

    <!-- Add new mine -->
    <div class="mb-6 rounded-xl border border-gray-700 bg-gray-900/50 p-4">
      <h2 class="text-sm font-semibold text-white mb-3">➕ Add New Mine</h2>
      <div class="flex flex-wrap gap-3 items-end">
        <div>
          <label class="block text-xs text-gray-400 mb-1">ID (slot number)</label>
          <input type="number" id="new-id" min="1" placeholder="Auto" class="w-24 rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Diamonds Remaining</label>
          <input type="number" id="new-remaining" value="10" min="1" class="w-24 rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Per Claim</label>
          <input type="number" id="new-per-claim" value="1" min="1" class="w-20 rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">End Date (optional)</label>
          <input type="date" id="new-end-date" class="rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">DOM Location</label>
          <input type="text" id="new-dom-loc" placeholder="e.g. #sidebar-diamond" class="w-48 rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
        </div>
        <button id="add-mine-btn" class="rounded-lg bg-blue-600 hover:bg-blue-500 px-4 py-2 text-sm font-medium text-white transition-colors">Add Mine</button>
      </div>
    </div>

    <!-- Mines table -->
    <div class="rounded-xl border border-gray-700 bg-gray-900/50 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="border-b border-gray-700 bg-gray-800/50">
            <tr>
              <th class="px-4 py-3 text-gray-400 font-medium">ID</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Slug</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Remaining</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Per Claim</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Status</th>
              <th class="px-4 py-3 text-gray-400 font-medium">End Date</th>
              <th class="px-4 py-3 text-gray-400 font-medium">DOM Loc</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Claims</th>
              <th class="px-4 py-3 text-gray-400 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody id="mines-table-body">
            <tr><td colspan="9" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 bg-black/70 z-40 hidden items-center justify-center">
      <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
        <h3 class="text-lg font-semibold text-white mb-4">✏️ Edit Mine</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs text-gray-400 mb-1">Mine ID</label>
            <input type="number" id="edit-id" min="1" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Diamonds Remaining</label>
            <input type="number" id="edit-remaining" min="0" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Per Claim</label>
            <input type="number" id="edit-per-claim" min="1" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">End Date (optional)</label>
            <input type="date" id="edit-end-date" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">DOM Location</label>
            <input type="text" id="edit-dom-loc" placeholder="e.g. #sidebar-diamond" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Status</label>
            <select id="edit-status" class="w-full rounded-lg border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-white">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
        </div>
        <div class="flex gap-3 mt-6">
          <button id="edit-save-btn" class="flex-1 rounded-lg bg-blue-600 hover:bg-blue-500 px-4 py-2 text-sm font-medium text-white transition-colors">Save</button>
          <button id="edit-cancel-btn" class="flex-1 rounded-lg border border-gray-600 hover:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-300 transition-colors">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="fixed bottom-6 right-6 rounded-xl border border-green-600 bg-green-950/90 px-4 py-3 text-sm text-green-300 shadow-lg opacity-0 transition-opacity pointer-events-none z-50">
      Saved!
    </div>
  </div>

  <script is:inline>
  (function() {
    var diamonds = [];

    function loadData() {
      fetch('/api/diamond-hunt/?all=true')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          diamonds = data.diamonds || [];
          renderTable();
          renderStats();
        })
        .catch(function(e) { console.error('Failed to load diamonds:', e); });
    }

    function renderStats() {
      var total = diamonds.length;
      var active = diamonds.filter(function(d) { return d.status === 'active' && d.diamonds_remaining > 0; }).length;
      var depleted = diamonds.filter(function(d) { return d.diamonds_remaining <= 0; }).length;
      var claims = diamonds.reduce(function(sum, d) { return sum + (d.total_claims || 0); }, 0);

      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-active').textContent = active;
      document.getElementById('stat-depleted').textContent = depleted;
      document.getElementById('stat-claims').textContent = claims;
    }

    function renderTable() {
      var tbody = document.getElementById('mines-table-body');
      if (diamonds.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" class="px-4 py-8 text-center text-gray-500">No mines yet. Add one above.</td></tr>';
        return;
      }

      tbody.innerHTML = diamonds.map(function(d) {
        var isActive = d.status === 'active';
        var isDepleted = d.diamonds_remaining <= 0;
        var statusClass = isDepleted ? 'text-red-400' : (isActive ? 'text-green-400' : 'text-gray-500');
        var statusLabel = isDepleted ? 'Depleted' : (isActive ? 'Active' : 'Inactive');
        var endDate = d.end_date ? d.end_date.split('T')[0] : '∞';

        return '<tr class="border-b border-gray-800 hover:bg-gray-800/30">' +
          '<td class="px-4 py-3 text-white font-mono">#' + d.id + '</td>' +
          '<td class="px-4 py-3 text-gray-300 font-mono text-xs">DiamondHunt' + d.id + '</td>' +
          '<td class="px-4 py-3 text-white">' + d.diamonds_remaining + '</td>' +
          '<td class="px-4 py-3 text-white">' + d.diamonds_per_claim + ' 💎</td>' +
          '<td class="px-4 py-3"><span class="' + statusClass + ' font-medium">' + statusLabel + '</span></td>' +
          '<td class="px-4 py-3 text-gray-400">' + endDate + '</td>' +
          '<td class="px-4 py-3 text-gray-400 font-mono text-xs">' + (d.dom_loc || '—') + '</td>' +
          '<td class="px-4 py-3 text-gray-400">' + (d.total_claims || 0) + '</td>' +
          '<td class="px-4 py-3 flex gap-2">' +
            '<button onclick="editMine(' + d.id + ')" class="text-xs px-2 py-1 rounded border border-blue-600 text-blue-400 hover:bg-blue-950/30">Edit</button>' +
            '<button onclick="toggleStatus(' + d.id + ', \'' + (isActive ? 'inactive' : 'active') + '\')" class="text-xs px-2 py-1 rounded border ' + (isActive ? 'border-amber-600 text-amber-400 hover:bg-amber-950/30' : 'border-green-600 text-green-400 hover:bg-green-950/30') + '">' + (isActive ? 'Deactivate' : 'Activate') + '</button>' +
            '<button onclick="deleteMine(' + d.id + ')" class="text-xs px-2 py-1 rounded border border-red-600 text-red-400 hover:bg-red-950/30">Delete</button>' +
          '</td>' +
        '</tr>';
      }).join('');
    }

    window.toggleStatus = function(id, newStatus) {
      fetch('/api/diamond-hunt/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, status: newStatus })
      })
        .then(function(r) { return r.json(); })
        .then(function() { showToast(newStatus === 'active' ? '✅ Activated' : '⏸️ Deactivated'); loadData(); })
        .catch(function() { showToast('❌ Error', true); });
    };

    window.deleteMine = function(id) {
      if (!confirm('Delete mine #' + id + '? This also removes all its claims.')) return;
      fetch('/api/diamond-hunt/', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
      })
        .then(function(r) { return r.json(); })
        .then(function() { showToast('🗑️ Deleted'); loadData(); })
        .catch(function() { showToast('❌ Error', true); });
    };

    document.getElementById('add-mine-btn').addEventListener('click', function() {
      var idVal = document.getElementById('new-id').value;
      var remaining = parseInt(document.getElementById('new-remaining').value) || 10;
      var perClaim = parseInt(document.getElementById('new-per-claim').value) || 1;
      var endDate = document.getElementById('new-end-date').value || null;
      var domLoc = document.getElementById('new-dom-loc').value || '';

      var payload = { admin_create: true, diamonds_remaining: remaining, diamonds_per_claim: perClaim, end_date: endDate, dom_loc: domLoc };
      if (idVal) payload.id = parseInt(idVal);

      fetch('/api/diamond-hunt/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) { showToast('❌ ' + data.error, true); return; }
          showToast('✅ Mine added'); loadData();
        })
        .catch(function() { showToast('❌ Error', true); });
    });

    function showToast(msg, isError) {
      var toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.className = toast.className.replace(/border-\\w+-600/g, '').replace(/bg-\\w+-950/g, '').replace(/text-\\w+-300/g, '');
      if (isError) {
        toast.classList.add('border-red-600', 'bg-red-950/90', 'text-red-300');
      } else {
        toast.classList.add('border-green-600', 'bg-green-950/90', 'text-green-300');
      }
      toast.style.opacity = '1';
      setTimeout(function() { toast.style.opacity = '0'; }, 2500);
    }

    var editOriginalId = null;

    window.editMine = function(id) {
      var mine = diamonds.find(function(d) { return d.id === id; });
      if (!mine) return;
      editOriginalId = id;
      document.getElementById('edit-id').value = id;
      document.getElementById('edit-remaining').value = mine.diamonds_remaining;
      document.getElementById('edit-per-claim').value = mine.diamonds_per_claim;
      document.getElementById('edit-end-date').value = mine.end_date ? mine.end_date.split('T')[0] : '';
      document.getElementById('edit-dom-loc').value = mine.dom_loc || '';
      document.getElementById('edit-status').value = mine.status;
      var modal = document.getElementById('edit-modal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    };

    function closeEditModal() {
      var modal = document.getElementById('edit-modal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.getElementById('edit-cancel-btn').addEventListener('click', closeEditModal);
    document.getElementById('edit-modal').addEventListener('click', function(e) {
      if (e.target === this) closeEditModal();
    });

    document.getElementById('edit-save-btn').addEventListener('click', function() {
      var newId = parseInt(document.getElementById('edit-id').value);
      var remaining = parseInt(document.getElementById('edit-remaining').value);
      var perClaim = parseInt(document.getElementById('edit-per-claim').value);
      var endDate = document.getElementById('edit-end-date').value || null;
      var domLoc = document.getElementById('edit-dom-loc').value || '';
      var status = document.getElementById('edit-status').value;

      var payload = { id: editOriginalId, diamonds_remaining: remaining, diamonds_per_claim: perClaim, end_date: endDate, dom_loc: domLoc, status: status };
      if (newId !== editOriginalId) payload.new_id = newId;

      fetch('/api/diamond-hunt/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) { showToast('❌ ' + data.error, true); return; }
          showToast('✅ Mine #' + (newId || editOriginalId) + ' updated');
          closeEditModal();
          loadData();
        })
        .catch(function() { showToast('❌ Error saving', true); });
    });

    loadData();
  })();
  </script>
</Layout>
