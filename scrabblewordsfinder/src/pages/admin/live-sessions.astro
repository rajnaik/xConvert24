---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Live Sessions — Admin — ScrabbleWordsFinder" description="Real-time active users on the site" keywords="admin, live sessions, active users">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/admin/" class="hover:text-blue-400 transition-colors">Admin</a>
      <a href="/admin/report/" class="hover:text-blue-400 transition-colors">Reports</a>
      <a href="/admin/clicks/" class="hover:text-blue-400 transition-colors">Clicks</a>
      <a href="/admin/live-sessions/" class="text-blue-400 font-medium">Live</a>
      <a href="/admin/banner-management/" class="hover:text-blue-400 transition-colors">Banner</a>
      <a href="/" class="hover:text-blue-400 transition-colors">← Site</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">🟢 Live Sessions</h1>
    <p class="text-gray-400 mb-6">Users currently active on the site (heartbeat within last 2 minutes).</p>

    <!-- Stats row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Active Now</p>
        <p class="text-2xl font-bold text-emerald-400" id="stat-active">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Unique Pages</p>
        <p class="text-2xl font-bold text-white" id="stat-pages">—</p>
      </div>
      <div class="rounded-lg bg-gray-800/60 p-4">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Last Updated</p>
        <p class="text-2xl font-bold text-white" id="stat-updated">—</p>
      </div>
    </div>

    <!-- Controls -->
    <div class="flex flex-wrap gap-3 mb-4 items-center">
      <button id="refresh-btn" class="h-9 px-4 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors">🔄 Refresh</button>
      <label class="flex items-center gap-2 text-sm text-gray-400">
        <input type="checkbox" id="auto-refresh" checked class="rounded" />
        Auto-refresh (10s)
      </label>
      <select id="time-window" class="h-9 px-3 bg-gray-800 border border-gray-700 rounded-lg text-gray-300 text-sm">
        <option value="2">Last 2 min</option>
        <option value="5">Last 5 min</option>
        <option value="10">Last 10 min</option>
        <option value="30">Last 30 min</option>
      </select>
    </div>

    <!-- Page breakdown -->
    <div id="page-breakdown" class="mb-6 hidden">
      <h2 class="text-lg font-semibold text-white mb-3">Pages Being Viewed</h2>
      <div id="page-bars" class="space-y-2"></div>
    </div>

    <!-- Sessions table -->
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-800/80 text-gray-400 text-xs uppercase">
          <tr>
            <th class="px-4 py-3">User ID</th>
            <th class="px-4 py-3">Page</th>
            <th class="px-4 py-3">IP Address</th>
            <th class="px-4 py-3">Last Seen</th>
          </tr>
        </thead>
        <tbody id="sessions-tbody" class="divide-y divide-gray-800 text-gray-300">
          <tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function escapeHtml(str: string): string {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function timeAgo(dateStr: string): string {
      const now = new Date();
      const then = new Date(dateStr + 'Z'); // Assume UTC from DB
      const diffMs = now.getTime() - then.getTime();
      const diffS = Math.floor(diffMs / 1000);
      if (diffS < 10) return 'just now';
      if (diffS < 60) return diffS + 's ago';
      const diffM = Math.floor(diffS / 60);
      return diffM + 'm ago';
    }

    let autoRefreshInterval: ReturnType<typeof setInterval> | null = null;

    async function loadSessions() {
      const minutes = (document.getElementById('time-window') as HTMLSelectElement).value;
      try {
        const res = await fetch(`/api/heartbeat/?minutes=${minutes}`);
        if (!res.ok) throw new Error('Failed to fetch');
        const data = await res.json();
        const sessions = data.sessions || [];
        const count = data.count || 0;

        // Stats
        document.getElementById('stat-active')!.textContent = String(count);
        const uniquePages = new Set(sessions.map((s: any) => s.page));
        document.getElementById('stat-pages')!.textContent = String(uniquePages.size);
        document.getElementById('stat-updated')!.textContent = new Date().toLocaleTimeString();

        // Page breakdown
        const pageBreakdown = document.getElementById('page-breakdown')!;
        const pageBars = document.getElementById('page-bars')!;
        if (count > 0) {
          pageBreakdown.classList.remove('hidden');
          const pageCounts: Record<string, number> = {};
          sessions.forEach((s: any) => {
            pageCounts[s.page] = (pageCounts[s.page] || 0) + 1;
          });
          const sorted = Object.entries(pageCounts).sort((a, b) => b[1] - a[1]);
          const maxCount = sorted[0][1];

          pageBars.innerHTML = sorted.map(([page, num]) => {
            const pct = Math.round((num / maxCount) * 100);
            return `
              <div class="flex items-center gap-3">
                <code class="text-xs text-gray-300 w-40 truncate shrink-0">${escapeHtml(page)}</code>
                <div class="flex-1 bg-gray-800 rounded-full h-5 overflow-hidden">
                  <div class="bg-emerald-500/70 h-full rounded-full flex items-center px-2" style="width: ${pct}%">
                    <span class="text-xs text-white font-medium">${num}</span>
                  </div>
                </div>
              </div>
            `;
          }).join('');
        } else {
          pageBreakdown.classList.add('hidden');
        }

        // Table
        const tbody = document.getElementById('sessions-tbody')!;
        if (!sessions.length) {
          tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">No active sessions right now.</td></tr>';
          return;
        }

        tbody.innerHTML = sessions.map((s: any) => `
          <tr class="hover:bg-gray-800/40 transition-colors">
            <td class="px-4 py-3 font-mono text-xs text-gray-400">${escapeHtml(s.uid || '—')}</td>
            <td class="px-4 py-3"><code class="text-emerald-300 bg-gray-800 px-1.5 py-0.5 rounded text-xs">${escapeHtml(s.page)}</code></td>
            <td class="px-4 py-3 font-mono text-xs text-gray-400">${escapeHtml(s.ip_address || '—')}</td>
            <td class="px-4 py-3 text-xs text-gray-400">${timeAgo(s.last_seen)}</td>
          </tr>
        `).join('');
      } catch {
        document.getElementById('sessions-tbody')!.innerHTML =
          '<tr><td colspan="4" class="px-4 py-8 text-center text-red-400">⚠️ Failed to load sessions.</td></tr>';
      }
    }

    // Initial load
    loadSessions();

    // Refresh button
    document.getElementById('refresh-btn')!.addEventListener('click', loadSessions);

    // Time window change
    document.getElementById('time-window')!.addEventListener('change', loadSessions);

    // Auto-refresh toggle
    function startAutoRefresh() {
      if (autoRefreshInterval) clearInterval(autoRefreshInterval);
      autoRefreshInterval = setInterval(loadSessions, 10000);
    }

    function stopAutoRefresh() {
      if (autoRefreshInterval) {
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
      }
    }

    const autoCheckbox = document.getElementById('auto-refresh') as HTMLInputElement;
    autoCheckbox.addEventListener('change', () => {
      if (autoCheckbox.checked) startAutoRefresh();
      else stopAutoRefresh();
    });

    // Start auto-refresh by default
    startAutoRefresh();
  </script>
</Layout>
