---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Contact Us — Free Scrabble Word Finder Support" description="Get in touch with ScrabbleWordsFinder.com. Bug reports, feature suggestions, or questions about our free instant Scrabble solver. No sign-up needed to use." keywords="contact scrabble word finder, support, bug report, feature request, free scrabble solver help">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 border-b border-gray-800">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-blue-400">Scrabble</span><span class="text-gray-300">WordsFinder</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="/" class="hover:text-blue-400 transition-colors">Solver</a>
      <a href="/blog" class="hover:text-blue-400 transition-colors">Blog</a>
      <a href="/settings" class="hover:text-purple-400 transition-colors">⚙️</a>
    </div>
  </nav>

  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Contact Us</h1>
    <p class="text-gray-400 mb-8">We'd love to hear from you. Whether it's a bug, an idea, or just a question — send us a message.</p>

    <!-- Contact Form -->
    <form id="contact-form" class="space-y-5 rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
      <div>
        <label for="contact-name" class="block text-sm font-medium text-gray-300 mb-1.5">Name <span class="text-gray-500">(optional)</span></label>
        <input type="text" id="contact-name" name="name" placeholder="Your name" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors" />
      </div>

      <div>
        <label for="contact-email" class="block text-sm font-medium text-gray-300 mb-1.5">Email <span class="text-gray-500">(optional — only if you'd like a reply)</span></label>
        <input type="email" id="contact-email" name="email" placeholder="you@example.com" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors" />
      </div>

      <div>
        <label for="contact-subject" class="block text-sm font-medium text-gray-300 mb-1.5">Subject</label>
        <select id="contact-subject" name="subject" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors">
          <option value="general">General Question</option>
          <option value="bug">Bug Report</option>
          <option value="feature">Feature Suggestion</option>
          <option value="privacy">Privacy / Data</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="contact-message" class="block text-sm font-medium text-gray-300 mb-1.5">Message <span class="text-red-400">*</span></label>
        <textarea id="contact-message" name="message" rows="5" required placeholder="Tell us what's on your mind..." class="w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors resize-y"></textarea>
      </div>

      <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-950 transition-colors">
        Send Message
      </button>
    </form>

    <h2 class="text-xl font-semibold text-white mt-10 mb-3">What We Can Help With</h2>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Bug reports:</strong> Something broken? Tell us what happened, what browser you're using, and what you expected.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Feature suggestions:</strong> Have an idea? <a href="/suggest" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Submit it here</a> — we build the most-requested features first.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">General questions:</strong> How something works, dictionary differences, tile scoring — check the <a href="/guide" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">User Guide</a> or ask away.</span></li>
      <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">→</span><span><strong class="text-white">Privacy concerns:</strong> Questions about your data or how to delete it — see our <a href="/privacy" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Privacy Policy</a> or <a href="/settings" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Settings</a>.</span></li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Response Time</h2>
    <p class="text-gray-300 mb-4">We aim to reply within <strong class="text-white">48 hours</strong>. Most messages get a response the same day.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Part of xConvert24</h2>
    <p class="text-gray-300">ScrabbleWordsFinder.com is part of the <a href="https://xconvert24.com" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">xConvert24.com</a> family of free online tools.</p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I contact ScrabbleWordsFinder?", "acceptedAnswer": { "@type": "Answer", "text": "Use the contact form on this page to send us a message. We typically respond within 24-48 hours to all inquiries." } },
    { "@type": "Question", "name": "Can I report a bug or missing word?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, use the contact form with the \"Bug Report\" subject category. Include details about the issue and we will investigate promptly." } },
    { "@type": "Question", "name": "Is my email address stored securely?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, your email is stored securely in our database and is only used to respond to your inquiry. We never share personal information with third parties." } }
  ]
}
</script>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();
    if (!message) { alert('Please enter a message.'); return; }

    const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    const subject = (document.getElementById('contact-subject') as HTMLSelectElement).value;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, subject, message }),
      });

      if (res.ok) {
        form.reset();
        btn.textContent = '✓ Sent!';
        btn.classList.replace('bg-blue-600', 'bg-green-600');
        setTimeout(() => {
          btn.textContent = 'Send Message';
          btn.classList.replace('bg-green-600', 'bg-blue-600');
          btn.disabled = false;
        }, 3000);
      } else {
        const data = await res.json();
        throw new Error(data.error || 'Failed to send');
      }
    } catch (err: any) {
      alert('Failed to send: ' + err.message);
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
