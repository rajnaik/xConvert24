  // ── Copy & Paste buttons ────────────────────────────────────────────────
  const copyBtn = document.getElementById('copy-solver')!;
  const pasteBtn = document.getElementById('paste-solver')!;

  textSolver.addEventListener('input', () => {
    if (textSolver.value.trim()) copyBtn.classList.remove('opacity-30');
    else copyBtn.classList.add('opacity-30');
  });

  copyBtn.addEventListener('click', (e) => {
    e.preventDefault();
    const text = textSolver.value.trim();
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.innerHTML = '<span class="text-xs text-green-400">✓</span>';
      setTimeout(() => { copyBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>'; }, 1000);
    });
  });

  pasteBtn.addEventListener('click', (e) => {
    e.preventDefault();
    navigator.clipboard.readText().then(text => {
      const clean = text.replace(/[^a-zA-Z?]/g, '').toUpperCase().slice(0, 15);
      if (clean) {
        textSolver.value = clean;
        textSolver.dispatchEvent(new Event('input'));
        copyBtn.classList.remove('opacity-30');
      }
    }).catch(() => {});
  });

  // ── Check if user has achievements (show link in Tile Scores header) ────
  (function checkAchievements() {
    const uid = localStorage.getItem('swf-uid') || '';
    if (!uid) return;
    fetch(`/api/achievements/?user_id=${encodeURIComponent(uid)}`).then(r => r.json()).then(data => {
      if (data.achievements && data.achievements.length > 1) {
        const link = document.getElementById('view-achievements-link');
        if (link) {
          link.classList.remove('hidden');
          link.textContent = `🏅 View ${data.achievements.length} Achievements →`;
        }
      }
    }).catch(() => {});
  })();

  // ── Tile Scores Display ─────────────────────────────────────────────────
  const scoresEl = document.getElementById('tile-scores')!;
  scoresEl.innerHTML = Object.entries(scores).map(([letter, pts]) =>
    `<div class="scrabble-tile w-16 h-16 sm:w-[72px] sm:h-[72px] rounded-lg flex flex-col items-center justify-center cursor-default select-none relative overflow-hidden" data-letter="${letter}" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882;">
      <span class="text-3xl sm:text-4xl font-black text-gray-900 leading-none relative z-[1]" style="font-family: 'Arial Black', sans-serif;">${letter}</span>
      <span class="text-xs sm:text-sm font-bold text-gray-900 absolute bottom-1 right-2 leading-none z-[1]" style="font-family: 'Arial Black', sans-serif;">${pts}</span>
    </div>`
  ).join('');

  // ── Highlight Tiles ─────────────────────────────────────────────────────
  function highlightTiles(word: string) {
    const heading = document.getElementById('tile-scores-heading')!;
    document.querySelectorAll('.scrabble-tile').forEach(tile => {
      (tile as HTMLElement).style.outline = ''; (tile as HTMLElement).style.outlineOffset = '';
      tile.classList.remove('tile-highlighted');
    });
    if (!word) { heading.textContent = 'Scrabble Tile Scores'; showEncouragement(0, ''); return; }
    const score = wordScore(word);
    heading.innerHTML = `Tile Scores = <span class="text-blue-400">${score} pts</span> <span class="text-sm font-normal text-gray-400">(${word.toUpperCase()})</span>`;
    const letterCounts: Record<string, number> = {};
    for (const ch of word.toUpperCase()) { letterCounts[ch] = (letterCounts[ch] || 0) + 1; }
    document.querySelectorAll('.scrabble-tile').forEach(tile => {
      const letter = (tile as HTMLElement).dataset.letter!;
      if (letterCounts[letter] && letterCounts[letter] > 0) {
        (tile as HTMLElement).style.outline = '4px solid #3b82f6';
        (tile as HTMLElement).style.outlineOffset = '2px';
        tile.classList.add('tile-highlighted');
      }
    });
    showEncouragement(score, word);
  }

  // ── Score Encouragement System ──────────────────────────────────────────
  function getEncouragementLevel(score: number): { icon: string; text: string; level: number; name: string } {
    if (score >= 50) return { icon: '🌟', text: 'Legendary! You are a Scrabble master. Scores like this win tournaments.', level: 5, name: 'Scrabble Legend' };
    if (score >= 30) return { icon: '🏆', text: 'Outstanding! Triple-word territory. Premium squares bow to your strategy.', level: 4, name: 'Triple Threat' };
    if (score >= 20) return { icon: '🔥', text: 'Great play! You are on fire. You are reading the board well.', level: 3, name: 'Hot Streak' };
    if (score >= 10) return { icon: '👍', text: 'Nice word! Keep building. You are finding solid plays.', level: 2, name: 'Word Builder' };
    return { icon: '⭐', text: 'Good start! Every point counts. Keep going!', level: 1, name: 'Rising Star' };
  }

  function showEncouragement(score: number, word: string) {
    const el = document.getElementById('tile-score-encouragement')!;
    if (score === 0) {
      el.innerHTML = '<p class="text-sm text-gray-500 italic">Solve a word to see your Tile Scores</p>';
      return;
    }
    const { icon, text, level, name } = getEncouragementLevel(score);
    el.innerHTML = `
      <div class="flex items-center justify-center gap-3">
        <span class="text-3xl">${icon}</span>
        <div>
          <p class="text-sm font-medium text-gray-200">${name}: ${text}</p>
          <p class="text-xs text-gray-500">${word.toUpperCase()} = ${score} pts (Level ${level}/5)</p>
        </div>
        <button id="save-achievement-btn" class="ml-3 px-3 py-1.5 rounded-lg bg-purple-600/30 border border-purple-500/50 text-xs font-medium text-purple-300 hover:bg-purple-600/50 transition-colors" data-score="${score}" data-word="${word}" data-level="${level}" data-text="${text}">
          Save ${icon}
        </button>
      </div>`;
    const saveBtn = document.getElementById('save-achievement-btn');
    if (saveBtn) {
      saveBtn.addEventListener('click', () => {
        // Show achievement modal with optional note
        el.innerHTML = `
          <div class="flex flex-col items-center gap-3 p-4 rounded-xl bg-gray-800/80 border border-purple-500/30">
            <span class="text-4xl">${icon}</span>
            <p class="text-base font-semibold text-gray-100">${name}</p>
            <p class="text-xs text-gray-400 text-center max-w-xs">${text}</p>
            <p class="text-xs text-gray-500">${word.toUpperCase()} = ${score} pts</p>
            <textarea id="achievement-note" maxlength="200" rows="4" placeholder="Add a note (optional)" class="w-full max-w-xs px-3 py-2 rounded-lg bg-gray-900 border border-gray-700 text-xs text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none"></textarea>
            <div class="flex gap-2">
              <button id="achievement-file-btn" class="px-4 py-2 rounded-lg bg-purple-600 text-white text-xs font-semibold hover:bg-purple-500 transition-colors">File Achievement ${icon}</button>
              <button id="achievement-cancel-btn" class="px-4 py-2 rounded-lg bg-gray-700 text-gray-300 text-xs font-medium hover:bg-gray-600 transition-colors">Cancel</button>
            </div>
          </div>`;
        // File button
        document.getElementById('achievement-file-btn')!.addEventListener('click', () => {
          const note = (document.getElementById('achievement-note') as HTMLTextAreaElement).value.trim();
          const uid = localStorage.getItem('swf-uid') || 'anonymous';
          const fileBtn = document.getElementById('achievement-file-btn')!;
          fileBtn.innerHTML = '⏳ Saving...';
          fetch('/api/achievements/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: uid, achievement_id: level, encouragement_words: note || text, score, word: word.toUpperCase() })
          }).then(res => {
            if (res.ok) {
              // Check if user has multiple achievements
              const uid = localStorage.getItem('swf-uid') || '';
              fetch(`/api/achievements/?user_id=${encodeURIComponent(uid)}`).then(r => r.json()).then(data => {
                const count = data.achievements?.length || 1;
                const viewAll = count > 1 ? ` <a href="/achievements/" class="text-xs text-blue-400 hover:underline ml-2">View all ${count} achievements →</a>` : '';
                el.innerHTML = `<div class="flex items-center justify-center gap-2 py-2 flex-wrap"><span class="text-2xl">${icon}</span><p class="text-sm text-green-400 font-medium">Achievement filed! ${name} — ${word.toUpperCase()} (${score} pts)</p>${viewAll}</div>`;
              }).catch(() => {
                el.innerHTML = `<div class="flex items-center justify-center gap-2 py-2"><span class="text-2xl">${icon}</span><p class="text-sm text-green-400 font-medium">Achievement filed! ${name} — ${word.toUpperCase()} (${score} pts)</p></div>`;
              });
            } else {
              fileBtn.innerHTML = '❌ Error — try again';
            }
          }).catch(() => { fileBtn.innerHTML = '❌ Error'; });
        });
        // Cancel button
        document.getElementById('achievement-cancel-btn')!.addEventListener('click', () => {
          showEncouragement(score, word);
        });
      });
    }
  }

  // ── Reference Panels ────────────────────────────────────────────────────
  function populateReferencePanels() {
    if (!dictionaryLoaded) return;

    const twoLetterEl = document.getElementById('two-letter-words');
    if (twoLetterEl) {
      const twoLetters = WORDS.filter(w => w.length === 2).sort();
      twoLetterEl.innerHTML = `<div class="flex flex-wrap gap-1.5">${twoLetters.map(w => `<span data-achieve-word="${w}" class="inline-block px-1.5 py-0.5 bg-blue-900/20 border border-blue-800 rounded font-mono font-semibold uppercase text-blue-300 cursor-pointer hover:bg-blue-900/40 transition-all">${w}<sup class="ml-0.5 text-gray-500" style="font-size:0.5rem">${wordScore(w)}</sup></span>`).join('')}</div><p class="mt-2 text-xs text-gray-500">${twoLetters.length} words total</p>`;
      applyAchievements(twoLetterEl); bindAchievementClicks(twoLetterEl);
    }

    const threeLetterEl = document.getElementById('three-letter-words');
    if (threeLetterEl) {
      const threeLetters = WORDS.filter(w => w.length === 3).map(w => ({ word: w, score: wordScore(w) })).sort((a, b) => b.score - a.score).slice(0, 30);
      threeLetterEl.innerHTML = `<div class="flex flex-wrap gap-1.5">${threeLetters.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-blue-900/20 border border-blue-800 rounded font-mono font-semibold uppercase text-blue-300 cursor-pointer hover:bg-blue-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-500" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}</div><p class="mt-2 text-xs text-gray-500">Top 30 by score</p>`;
      applyAchievements(threeLetterEl); bindAchievementClicks(threeLetterEl);
    }

    const qNoUEl = document.getElementById('q-without-u');
    if (qNoUEl) {
      const qNoU = WORDS.filter(w => w.includes('q') && !w.includes('u')).map(w => ({ word: w, score: wordScore(w) })).sort((a, b) => b.score - a.score);
      if (qNoU.length) {
        qNoUEl.innerHTML = `<div class="flex flex-wrap gap-1.5">${qNoU.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 bg-purple-900/20 border border-purple-800 rounded font-mono font-semibold uppercase text-purple-300 cursor-pointer hover:bg-purple-900/40 transition-all">${w.word}<sup class="ml-0.5 text-gray-500" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}</div><p class="mt-2 text-xs text-gray-500">${qNoU.length} words — memorise these!</p>`;
        applyAchievements(qNoUEl); bindAchievementClicks(qNoUEl);
      }
    }
  }

  const panelInterval = setInterval(() => { if (dictionaryLoaded) { clearInterval(panelInterval); populateReferencePanels(); initRareLetterTabs(); } }, 200);

  // ── Rare Letter Tabs ────────────────────────────────────────────────────
  function initRareLetterTabs() {
    const tabs = document.querySelectorAll('.rare-tab');
    const resultsEl = document.getElementById('rare-letter-results');
    if (!tabs.length || !resultsEl) return;

    function showRareLetter(letter: string) {
      const words = WORDS.filter(w => w.includes(letter)).map(w => ({ word: w, score: wordScore(w) })).sort((a, b) => b.score - a.score).slice(0, 40);
      const colors: Record<string, { bg: string; border: string; text: string }> = {
        q: { bg: 'bg-purple-900/20', border: 'border-purple-800', text: 'text-purple-300' },
        z: { bg: 'bg-red-900/20', border: 'border-red-800', text: 'text-red-300' },
        x: { bg: 'bg-orange-900/20', border: 'border-orange-800', text: 'text-orange-300' },
        j: { bg: 'bg-emerald-900/20', border: 'border-emerald-800', text: 'text-emerald-300' },
      };
      const c = colors[letter] || colors.q;
      resultsEl.innerHTML = `<div class="flex flex-wrap gap-1.5">${words.map(w => `<span data-achieve-word="${w.word}" class="inline-block px-1.5 py-0.5 ${c.bg} border ${c.border} rounded font-mono font-semibold uppercase ${c.text} cursor-pointer hover:opacity-80 transition-all">${w.word}<sup class="ml-0.5 text-gray-500" style="font-size:0.5rem">${w.score}</sup></span>`).join('')}</div><p class="mt-2 text-xs text-gray-500">Top 40 words containing "${letter.toUpperCase()}" by score</p>`;
      applyAchievements(resultsEl); bindAchievementClicks(resultsEl);
      tabs.forEach(tab => {
        const t = tab as HTMLElement;
        if (t.dataset.rare === letter) t.className = `rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold ${c.bg} ${c.text} border ${c.border}`;
        else t.className = 'rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:bg-gray-700';
      });
    }
    showRareLetter('q');
    tabs.forEach(tab => { tab.addEventListener('click', () => showRareLetter((tab as HTMLElement).dataset.rare!)); });
  }

  // ── Tile Probability Calculator ─────────────────────────────────────────
  const FULL_BAG: Record<string, number> = { A:9,B:2,C:2,D:4,E:12,F:2,G:3,H:2,I:9,J:1,K:1,L:4,M:2,N:6,O:8,P:2,Q:1,R:6,S:4,T:6,U:4,V:2,W:2,X:1,Y:2,Z:1,'?':2 };
  const PROB_STORAGE_KEY = 'scbTileProb';

  function loadProbState(): { inBag: number; played: number } {
    try { const saved = JSON.parse(localStorage.getItem(PROB_STORAGE_KEY) || '{}'); return { inBag: saved.inBag ?? 100, played: saved.played ?? 0 }; }
    catch { return { inBag: 100, played: 0 }; }
  }
  function saveProbState(inBag: number, played: number) { localStorage.setItem(PROB_STORAGE_KEY, JSON.stringify({ inBag, played })); }

  const probState = loadProbState();
  const inBagInput = document.getElementById('tiles-in-bag') as HTMLInputElement;
  const playedInput = document.getElementById('tiles-played') as HTMLInputElement;
  inBagInput.value = String(probState.inBag);
  playedInput.value = String(probState.played);

  // Reset button
  document.getElementById('prob-reset-btn')!.addEventListener('click', () => {
    inBagInput.value = '100';
    playedInput.value = '0';
    saveProbState(100, 0);
    updateProbability();
  });

  function updateProbability() {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    const inBag = parseInt(inBagInput.value) || 0;
    const rackEl = document.getElementById('prob-your-rack');
    const chancesEl = document.getElementById('prob-draw-chances');
    if (!rackEl || !chancesEl) return;
    rackEl.textContent = String(tiles.length);
    saveProbState(inBag, parseInt(playedInput.value) || 0);
    if (tiles.length === 0 || inBag === 0) { chancesEl.innerHTML = '<span class="italic">Enter your rack letters above ↑ to see draw probabilities</span>'; return; }
    const bag = { ...FULL_BAG };
    for (const ch of tiles) { const key = ch === '?' ? '?' : ch; if (bag[key] && bag[key] > 0) bag[key]--; }
    const remaining = Math.max(0, inBag);
    const keyTiles = ['S','E','R','T','N','?','Z','Q','X','J'];
    const rows = keyTiles.filter(t => bag[t] > 0).map(t => {
      const count = bag[t]; const pct = remaining > 0 ? ((count / remaining) * 100).toFixed(1) : '0.0';
      const label = t === '?' ? 'Blank' : t;
      return `<div class="flex items-center justify-between"><span class="font-mono font-semibold">${label}</span><span>${count} left — <strong class="text-blue-400">${pct}%</strong> chance</span></div>`;
    });
    chancesEl.innerHTML = `<div class="text-xs font-medium text-gray-300 mb-2">Draw probability (next tile from bag of ${remaining}):</div><div class="space-y-1 text-xs text-gray-400">${rows.join('')}</div>`;
  }

  function onWordPlayed(wordLength: number) {
    const currentPlayed = parseInt(playedInput.value) || 0;
    const currentInBag = parseInt(inBagInput.value) || 0;
    playedInput.value = String(currentPlayed + wordLength);
    inBagInput.value = String(Math.max(0, currentInBag - wordLength));
    updateProbability();
  }

  document.getElementById('tiles')!.addEventListener('input', updateProbability);
  inBagInput.addEventListener('input', updateProbability);
  playedInput.addEventListener('input', updateProbability);
  updateProbability();

  // ── Probability Popup Toggle ────────────────────────────────────────────
  const probPopupBtn = document.getElementById('prob-popup-btn')!;
  const probPopup = document.getElementById('prob-popup')!;

  probPopupBtn.addEventListener('click', () => {
    probPopup.classList.toggle('hidden');
    updateProbability();
  });

  // ── Rack Leave Analyzer ─────────────────────────────────────────────────
  function analyzeLeave(playedWord: string) {
    const panel = document.getElementById('rack-leave-panel');
    if (!panel) return;
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    if (!tiles || tiles.length < 2) { panel.innerHTML = '<div class="text-xs text-gray-500 italic">Enter your rack tiles first</div>'; return; }

    const leave: string[] = [...tiles.split('')];
    for (const ch of playedWord.toUpperCase().split('')) {
      const idx = leave.indexOf(ch);
      if (idx !== -1) leave.splice(idx, 1);
      else { const bi = leave.indexOf('?'); if (bi !== -1) leave.splice(bi, 1); }
    }

    if (leave.length === 0) {
      panel.innerHTML = `<div class="bg-green-900/20 border border-green-800 rounded-lg p-3"><div class="text-sm font-semibold text-green-300">🎯 Bingo! You used all your tiles</div><div class="text-xs text-green-400 mt-1">+50 bonus points in a real game</div></div>`;
      return;
    }

    const vowels = leave.filter(l => 'AEIOU'.includes(l)).length;
    const consonants = leave.filter(l => l !== '?' && !'AEIOU'.includes(l)).length;
    const blanks = leave.filter(l => l === '?').length;
    const hasS = leave.includes('S');
    const highValue = leave.filter(l => (scores[l] || 0) >= 4);
    const leaveScore = leave.reduce((sum, l) => sum + (scores[l] || 0), 0);

    let quality = 50;
    const ratio = leave.length > 0 ? vowels / leave.length : 0;
    if (ratio >= 0.3 && ratio <= 0.5) quality += 15;
    else if (ratio === 0 || ratio >= 0.7) quality -= 20;
    else quality -= 5;
    if (hasS) quality += 12;
    quality += blanks * 15;
    quality += leave.filter(l => 'ERSTNA'.includes(l)).length * 3;
    if (highValue.length > 0 && vowels === 0) quality -= 15;
    const counts: Record<string, number> = {};
    leave.forEach(l => { counts[l] = (counts[l] || 0) + 1; });
    quality -= Object.values(counts).filter(c => c > 1).length * 8;
    quality = Math.max(0, Math.min(100, quality));

    let qualityLabel: string; let qualityColor: string;
    if (quality >= 75) { qualityLabel = 'Excellent'; qualityColor = 'text-green-400'; }
    else if (quality >= 55) { qualityLabel = 'Good'; qualityColor = 'text-blue-400'; }
    else if (quality >= 35) { qualityLabel = 'Fair'; qualityColor = 'text-blue-400'; }
    else { qualityLabel = 'Poor'; qualityColor = 'text-red-400'; }

    const advice: string[] = [];
    if (vowels === 0) advice.push('⚠️ No vowels — you may struggle next turn');
    if (ratio >= 0.7) advice.push('⚠️ Too many vowels');
    if (hasS) advice.push('✓ Keeping S is great for plurals');
    if (blanks > 0) advice.push('✓ Blank tiles give maximum flexibility');

    panel.innerHTML = `
      <div class="space-y-3">
        <div class="text-sm font-medium text-gray-300">After playing <span class="font-mono font-bold uppercase text-blue-400">${playedWord}</span>:</div>
        <div class="flex items-center gap-2">${leave.map(l => `<span class="inline-flex items-center justify-center w-8 h-8 rounded bg-blue-900/30 border border-blue-700 font-mono font-bold text-blue-200 text-sm">${l === '?' ? '★' : l}</span>`).join('')}<span class="ml-2 text-xs text-gray-500">(${leaveScore} pts in hand)</span></div>
        <div class="flex items-center gap-2">
          <div class="flex-1 h-2 bg-gray-700 rounded-full overflow-hidden"><div class="h-full rounded-full ${quality >= 75 ? 'bg-green-500' : quality >= 55 ? 'bg-blue-500' : quality >= 35 ? 'bg-blue-500' : 'bg-red-500'}" style="width:${quality}%"></div></div>
          <span class="text-sm font-semibold ${qualityColor}">${qualityLabel}</span><span class="text-xs text-gray-500">${quality}/100</span>
        </div>
        <div class="text-xs text-gray-400 space-y-1"><div>Vowels: ${vowels} · Consonants: ${consonants}${blanks ? ' · Blanks: ' + blanks : ''}</div>${advice.length ? '<div class="mt-1 space-y-0.5">' + advice.map(a => `<div>${a}</div>`).join('') + '</div>' : ''}</div>
      </div>`;
  }

  // ── Best Opening Moves ──────────────────────────────────────────────────
  function updateBestOpeners() {
    const panel = document.getElementById('best-opening-panel');
    if (!panel || !dictionaryLoaded) return;
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim();
    if (!tiles || tiles.length < 2) { panel.innerHTML = '<div class="text-xs text-gray-500 italic">Enter your tiles above ↑ to see your best opening plays</div>'; return; }

    const playable = WORDS.filter(w => w.length >= 2 && w.length <= tiles.length && canMake(w, tiles))
      .map(w => ({ word: w, baseScore: wordScore(w), openingScore: wordScore(w) * 2 }))
      .sort((a, b) => b.openingScore - a.openingScore).slice(0, 10);

    if (!playable.length) { panel.innerHTML = '<div class="text-xs text-gray-500 italic">No valid opening words from these tiles</div>'; return; }

    panel.innerHTML = `
      <div class="space-y-1.5">
        ${playable.map((w, i) => {
          const isBingo = w.word.length === tiles.length && tiles.length === 7;
          const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
          const totalScore = isBingo ? w.openingScore + 50 : w.openingScore;
          return `<div class="flex items-center justify-between px-3 py-2 bg-gray-800 rounded-lg"><div class="flex items-center gap-2">${medal ? `<span class="text-sm">${medal}</span>` : `<span class="text-xs text-gray-500 w-5">${i + 1}.</span>`}<span class="font-mono font-bold uppercase text-white text-sm">${w.word}</span><span class="text-xs text-gray-500">(${w.word.length} letters)</span></div><div class="text-right"><span class="font-bold text-blue-400 text-sm">${totalScore} pts</span>${isBingo ? ' <span class="text-green-400 font-semibold">+50 bingo!</span>' : ''}<div class="text-xs text-gray-500">${w.baseScore} × 2 DWS</div></div></div>`;
        }).join('')}
      </div>
      <div class="mt-3 text-xs text-gray-500">DWS = Double Word Score (centre star bonus on opening move)</div>`;
  }

  document.getElementById('tiles')!.addEventListener('input', updateBestOpeners);
  document.getElementById('text-solve-btn')!.addEventListener('click', updateBestOpeners);

  // ── Word Definitions ────────────────────────────────────────────────────
  async function showDefinition(target: HTMLElement, word: string) {
    const existing = target.querySelector('.word-def-tooltip');
    if (existing) { existing.remove(); return; }
    document.querySelectorAll('.word-def-tooltip').forEach(t => t.remove());
    const tooltip = document.createElement('div');
    tooltip.className = 'word-def-tooltip absolute left-0 -bottom-1 translate-y-full z-10 p-2 bg-gray-800 border border-gray-700 rounded-lg shadow-lg text-xs text-gray-300';
    tooltip.style.minWidth = '200px'; tooltip.style.width = 'max-content'; tooltip.style.maxWidth = '280px';
    tooltip.textContent = 'Looking up…';
    target.style.position = 'relative'; target.appendChild(tooltip);
    try {
      const res = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
      if (!res.ok) throw new Error('not found');
      const data = await res.json();
      const meaning = data[0]?.meanings?.[0];
      const def = meaning?.definitions?.[0]?.definition || 'No definition available';
      const partOfSpeech = meaning?.partOfSpeech || '';
      tooltip.innerHTML = `<span class="font-semibold text-blue-400 uppercase">${word}</span> <span class="italic text-gray-500">(${partOfSpeech})</span><br/>${def}`;
    } catch { tooltip.innerHTML = `<span class="font-semibold uppercase">${word}</span> — <span class="italic text-gray-500">No definition found</span>`; }
    setTimeout(() => { tooltip.remove(); }, 8000);
  }

  document.getElementById('results')!.addEventListener('click', async (e) => {
    const target = (e.target as HTMLElement).closest('[data-highlight-word]') as HTMLElement | null;
    if (!target) return;
    showDefinition(target, target.dataset.highlightWord!);
  });

  ['two-letter-words', 'three-letter-words', 'q-without-u', 'rare-letter-results'].forEach(id => {
    const container = document.getElementById(id);
    if (container) {
      container.addEventListener('click', async (e) => {
        const target = (e.target as HTMLElement).closest('[data-achieve-word]') as HTMLElement | null;
        if (!target) return;
        showDefinition(target, target.dataset.achieveWord!);
      });
    }
  });

  // ── Word of the Day on Solver ──
  (async function loadSolverWotd() {
    try {
      const res = await fetch('/api/wotd/');
      if (!res.ok) return;
      const { word } = await res.json();
      if (!word || !word.word) return;

      const btn = document.getElementById('wotd-solver-btn')!;
      const wordEl = document.getElementById('wotd-solver-word')!;
      const bubble = document.getElementById('wotd-solver-bubble')!;
      const bubbleWord = document.getElementById('wotd-solver-bubble-word')!;
      const bubbleMeaning = document.getElementById('wotd-solver-bubble-meaning')!;

      wordEl.textContent = word.word;
      bubbleWord.textContent = word.word;
      bubbleMeaning.textContent = word.meaning || 'Click "Lookup" on Activities to fetch meaning';

      // If WOTD is already saved in MWB, show green tick on load
      try {
        const saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
        if (saved.find((a: any) => a.word === word.word.toUpperCase())) {
          const addBtn = document.getElementById('wotd-add-btn')!;
          addBtn.textContent = '✓';
          addBtn.classList.add('text-green-400', 'border-green-500/50');
        }
      } catch {}

      let open = false;
      btn.addEventListener('click', () => {
        open = !open;
        if (open) {
          bubble.classList.remove('hidden');
          bubble.style.opacity = '0';
          bubble.style.transform = 'translateY(-8px) scale(0.95)';
          requestAnimationFrame(() => {
            bubble.style.transition = 'opacity 0.25s ease-out, transform 0.25s ease-out';
            bubble.style.opacity = '1';
            bubble.style.transform = 'translateY(0) scale(1)';
          });
          // If no meaning yet, try fetching
          if (!word.meaning) {
            fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word.word.toLowerCase())
              .then(r => r.json())
              .then(data => {
                const def = data[0]?.meanings?.[0]?.definitions?.[0]?.definition;
                if (def) { bubbleMeaning.textContent = def; word.meaning = def; }
              }).catch(() => {});
          }
        } else {
          bubble.style.opacity = '0';
          bubble.style.transform = 'translateY(-8px) scale(0.95)';
          setTimeout(() => bubble.classList.add('hidden'), 200);
        }
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (open && !btn.contains(e.target as Node) && !bubble.contains(e.target as Node) && !(e.target as HTMLElement).closest('#wotd-add-btn')) {
          open = false;
          bubble.style.opacity = '0';
          bubble.style.transform = 'translateY(-8px) scale(0.95)';
          setTimeout(() => bubble.classList.add('hidden'), 200);
        }
      });

      // WOTD + button: Add to Memory WordBench under 'wotd' category
      document.getElementById('wotd-add-btn')!.addEventListener('click', () => {
        const wotdWord = wordEl.textContent?.trim().toUpperCase();
        if (!wotdWord || wotdWord === '...') return;

        const ACHIEVEMENTS_KEY = 'scbAchievements';
        let achievements: any[] = [];
        try { achievements = JSON.parse(localStorage.getItem(ACHIEVEMENTS_KEY) || '[]'); } catch {}

        // Check if already saved — keep green permanently
        if (achievements.find((a: any) => a.word === wotdWord)) {
          const addBtn = document.getElementById('wotd-add-btn')!;
          addBtn.textContent = '✓';
          addBtn.classList.add('text-green-400', 'border-green-500/50');
          return;
        }

        const meaning = bubbleMeaning.textContent || '';
        achievements.unshift({ word: wotdWord, meaning, category: 'wotd', dateAdded: new Date().toISOString() });
        localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(achievements));

        // Notify MWB to refresh immediately
        document.dispatchEvent(new CustomEvent('mwb-updated'));

        // Visual feedback — stays green permanently once saved
        const addBtn = document.getElementById('wotd-add-btn')!;
        addBtn.textContent = '✓';
        addBtn.classList.add('text-green-400', 'border-green-500/50');

        // If meaning is empty, fetch it
        if (!meaning || meaning === 'Click "Lookup" on Activities to fetch meaning') {
          fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + wotdWord.toLowerCase())
            .then(r => r.json())
            .then(data => {
              const def = data[0]?.meanings?.[0]?.definitions?.[0]?.definition;
              if (def) {
                const updated = JSON.parse(localStorage.getItem(ACHIEVEMENTS_KEY) || '[]');
                const entry = updated.find((a: any) => a.word === wotdWord);
                if (entry) { entry.meaning = def; localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(updated)); }
              }
            }).catch(() => {});
        }

        // Sync
        const uid = localStorage.getItem('swf-uid') || '';
        if (uid) {
          fetch('/api/scrabble-sync', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid, achievements: JSON.parse(localStorage.getItem(ACHIEVEMENTS_KEY) || '[]') }),
          }).catch(() => {});
        }

        if (typeof renderSavedWords === 'function') renderSavedWords();
      });
    } catch {}
  })();
</script>
