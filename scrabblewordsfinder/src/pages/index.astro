---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout showSectionLinks={true} title="Free Scrabble Word Finder & Solver — Instant, No Sign-Up" description="Free Scrabble word finder and solver. Enter your tiles, get the highest-scoring words instantly from 74,000+ SOWPODS words. No sign-up needed." keywords="scrabble word finder, free scrabble solver, scrabble cheat, anagram solver, words with friends solver, instant scrabble solver, scrabble helper, scrabble dictionary, no signup word finder, realtime word finder, scrabble rack solver, SOWPODS dictionary online">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What dictionary does this Scrabble word finder use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This tool uses the SOWPODS dictionary — the international Scrabble word list used in official tournaments outside North America. It contains over 74,000 valid words between 2 and 7 letters long."
        }
      },
      {
        "@type": "Question",
        "name": "How are Scrabble tile scores calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each letter tile has a fixed point value. Common letters like E, A, I, O score 1 point, while rare letters like Q and Z score 10 points. The word score is the sum of all individual tile values. Blank tiles (wildcards) score 0 points."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use blank tiles or wildcards?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Enter a question mark (?) for each blank tile in your rack — up to 2 wildcards are supported. The solver will treat each as any letter and find all possible words, though blank tiles contribute 0 points to the word score."
        }
      },
      {
        "@type": "Question",
        "name": "Does this work for Words With Friends too?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. While Words With Friends uses a slightly different dictionary and scoring system, the SOWPODS word list covers virtually all valid WWF words. The tile scores shown are for standard Scrabble — WWF scores differ slightly for some letters."
        }
      }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ScrabbleWordsFinder",
    "url": "https://www.scrabblewordsfinder.com",
    "description": "Free Scrabble word finder and solver. Enter your tiles, find the highest-scoring words instantly from 74,000+ SOWPODS words.",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "browserRequirements": "Requires JavaScript"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Use the Scrabble Word Finder",
    "description": "Find the highest-scoring Scrabble words from your rack in 3 simple steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter your tiles", "text": "Type your Scrabble rack letters into the input field. Use ? for blank tiles." },
      { "@type": "HowToStep", "position": 2, "name": "Find words instantly", "text": "Results appear automatically as you type. The solver searches 74,000+ words from the SOWPODS Scrabble dictionary." },
      { "@type": "HowToStep", "position": 3, "name": "Click to collect achievements", "text": "Click any word to add it to your achievements, copy it to clipboard, and see your rack leave analysis." }
    ]
  })} />

  <style is:inline>
    [id^="section-"] { scroll-margin-top: 35px; }
    .scrabble-tile {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }
    .scrabble-tile:hover {
      transform: scale(2) rotate(-3deg) translateY(-4px);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), inset 0 -2px 0 rgba(0,0,0,0.1), 0 8px 20px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.2) !important;
      z-index: 10;
      position: relative;
    }
    .scrabble-tile.tile-highlighted {
      animation: tile-glow 1.2s ease-in-out infinite alternate;
    }
    @keyframes tile-glow {
      0% { outline-color: #3b82f6; transform: scale(1); }
      100% { outline-color: #dc2626; transform: scale(1.08); }
    }
    @media (max-width: 639px) {
      .scrabble-tile { width: 44px !important; height: 44px !important; }
      .scrabble-tile .text-3xl { font-size: 1.25rem !important; }
      .scrabble-tile .text-xs { font-size: 0.55rem !important; bottom: 2px !important; right: 4px !important; }
    }
  </style>



  <!-- Main solver area -->
  <main class="mx-auto max-w-5xl px-4 sm:px-6 pb-20">


    <!-- Two-column layout: Solver + Saved Words -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6 mb-6">
      <!-- Left: Input & Results -->
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 sm:p-6">

        <!-- Word Solver (up to 15 letters) -->
        <div class="mb-4">
          <label for="text-solver" class="block text-sm font-medium text-gray-300 mb-1.5">Word Solver</label>
          <div class="flex gap-2 sm:gap-3">
            <input id="text-solver" type="text" maxlength="15" placeholder="Type all your tiles e.g. ARRESTEDERNING" inputmode="text" autocapitalize="characters" class="flex-1 h-11 px-3 bg-gray-800 border border-gray-700 rounded-lg text-blue-300 text-lg font-mono uppercase tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="off"/>
            <button id="text-solve-btn" class="h-11 px-5 rounded-lg bg-blue-500 text-gray-950 font-semibold hover:bg-blue-400 transition-colors text-sm">Solve</button>
          </div>
          <p class="mt-1.5 text-xs text-gray-500">Use ? for blank tiles. Up to 15 letters. Finds all words you can make.</p>
        </div>

        <div class="border-t border-gray-800 my-4"></div>

        <!-- Tile Rack (7 boxes — your current Scrabble rack) -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1.5">Tile Rack <span class="text-gray-500 font-normal">(7 tiles max)</span></label>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 items-center">
            <div class="flex gap-1.5" id="tile-inputs">
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="0" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="1" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="2" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="3" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="4" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="5" autocomplete="off" inputmode="text" />
              <input type="text" maxlength="1" class="tile-box w-12 h-14 sm:w-14 sm:h-16 text-center bg-gray-800 border-2 border-purple-700/50 rounded-lg text-blue-300 text-2xl sm:text-3xl font-mono uppercase focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-colors" data-idx="6" autocomplete="off" inputmode="text" />
            </div>
            <button id="solve-btn" class="h-12 sm:h-16 px-6 rounded-lg bg-blue-500 text-gray-950 font-semibold hover:bg-blue-400 transition-colors text-base sm:text-lg">Find Words</button>
          </div>
          <p class="mt-2 text-xs text-gray-500">One letter per tile. Use <kbd class="rounded bg-gray-800 px-1 py-0.5 font-mono text-blue-400">?</kbd> for blanks.</p>
          <input id="tiles" type="hidden" />
        </div>

        <!-- Filters -->
        <div class="space-y-3 mb-4">
          <div class="flex flex-wrap gap-3 items-end">
            <div>
              <label for="dictionary" class="text-xs text-gray-400">Dictionary</label>
              <div class="flex items-center gap-1.5 relative">
                <select id="dictionary" class="h-8 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                  <option value="sowpods">SOWPODS (International)</option>
                  <option value="twl">TWL / NASPA (US/Canada)</option>
                  <option value="wwf">Words With Friends</option>
                  <option value="collins">Collins Official</option>
                </select>
                <button id="dict-info-btn" type="button" class="w-7 h-7 flex items-center justify-center rounded bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-colors text-sm" title="Dictionary info" aria-label="Dictionary info">📖</button>
                <div id="dict-info-popup" class="hidden absolute top-full left-0 mt-1.5 px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-xs text-gray-300 z-20 shadow-lg w-[320px]">
                  <span id="dict-info-text"></span>
                </div>
              </div>
            </div>
            <div>
              <label for="sort-by" class="text-xs text-gray-400">Sort by</label>
              <select id="sort-by" class="h-8 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                <option value="score">Highest Score</option>
                <option value="length">Longest First</option>
                <option value="alpha">A–Z</option>
              </select>
            </div>
            <div>
              <label for="min-len" class="text-xs text-gray-400">Min length</label>
              <select id="min-len" class="h-8 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
              </select>
            </div>
          </div>
          <div class="flex flex-wrap gap-3 items-end">
            <div>
              <label for="contains" class="text-xs text-gray-400">Contains</label>
              <input id="contains" type="text" maxlength="5" placeholder="e.g. TH" class="h-8 w-16 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
            <div>
              <label for="starts-with" class="text-xs text-gray-400">Starts with</label>
              <input id="starts-with" type="text" maxlength="3" placeholder="e.g. QU" class="h-8 w-14 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
            <div>
              <label for="ends-with" class="text-xs text-gray-400">Ends with</label>
              <input id="ends-with" type="text" maxlength="3" placeholder="e.g. ED" class="h-8 w-14 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
          </div>
        </div>

        <!-- Results -->
        <div id="results" class="min-h-[100px]">
          <div class="text-center py-8 text-gray-500 text-sm italic">Enter your tiles above and click Find Words</div>
        </div>
        <div id="high-scoring-panel" class="hidden"></div>
      </div>

      <!-- Right: Saved Words -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6 h-fit lg:sticky lg:top-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-white flex items-center gap-2">
            <span aria-hidden="true">👑</span> Saved Words
          </h2>
          <div class="flex items-center gap-2">
            <button id="download-saved-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-400 hover:bg-blue-900/20 transition-colors opacity-30" title="Download saved words" aria-label="Download saved words">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3"/></svg>
            </button>
            <span id="saved-count" class="text-xs text-gray-400">0</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 mb-3">Click any word in results or reference panels to save it here.</p>
        <div id="saved-words-list" class="max-h-[400px] overflow-y-auto">
          <p id="saved-empty" class="text-sm text-gray-500 text-center py-4 italic">No saved words yet. Click any word to collect it.</p>
        </div>

        <!-- Rack Leave Analyzer -->
        <div id="section-rack-leave" class="mt-6 pt-4 border-t border-purple-800/40">
          <h3 class="font-semibold text-white mb-2 flex items-start gap-2 text-sm"><span aria-hidden="true">🧠</span> Rack Leave Analyzer</h3>
          <p class="text-xs text-gray-400 mb-3">Click a word in your results to see what tiles remain on your rack.</p>
          <div id="rack-leave-panel">
            <div class="text-xs text-gray-500 italic">Find words first, then click one to analyze your leave</div>
          </div>
        </div>

        <!-- Tile Bag Probability (compact) -->
        <div id="section-probability" class="mt-6 pt-4 border-t border-purple-800/40">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-white flex items-center gap-1.5"><span aria-hidden="true">🎲</span> Tile Bag</span>
            <button id="prob-popup-btn" type="button" class="px-2 py-1 rounded bg-gray-800 border border-gray-700 text-xs font-medium text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-colors">Draw %</button>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <div class="flex items-center gap-1">
              <span class="text-gray-500">Bag:</span>
              <input id="tiles-in-bag" type="number" min="0" max="100" value="100" class="w-9 text-center text-xs font-bold text-white bg-gray-800 border border-gray-700 rounded px-1 py-0.5 focus:outline-none focus:border-blue-500" />
            </div>
            <div class="flex items-center gap-1">
              <span class="text-gray-500">Rack:</span>
              <span id="prob-your-rack" class="text-xs font-bold text-blue-400">0</span>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-gray-500">Played:</span>
              <input id="tiles-played" type="number" min="0" max="86" value="0" class="w-9 text-center text-xs font-bold text-rose-400 bg-gray-800 border border-gray-700 rounded px-1 py-0.5 focus:outline-none focus:border-blue-500" />
            </div>
          </div>
          <div id="prob-popup" class="hidden mt-3 pt-2 border-t border-gray-800">
            <div id="prob-draw-chances" class="text-xs text-gray-500 italic">Enter your rack letters to see draw probabilities</div>
          </div>
        </div>

        <!-- Best Opening Moves -->
        <div id="section-best-opening" class="mt-6 pt-4 border-t border-purple-800/40">
          <h3 class="font-semibold text-white mb-2 flex items-start gap-2 text-sm"><span aria-hidden="true">🚀</span> Best Opening Moves</h3>
          <p class="text-xs text-gray-400 mb-3">Highest-scoring first moves from your rack (double word through centre star).</p>
          <div id="best-opening-panel">
            <div class="text-xs text-gray-500 italic">Enter your tiles above ↑ to see your best opening plays</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tile Scores -->
    <div id="section-tile-scores" class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
      <h2 id="tile-scores-heading" class="font-semibold text-white mb-4">Scrabble Tile Scores</h2>
      <div class="grid grid-cols-5 sm:grid-cols-7 md:grid-cols-9 lg:grid-cols-13 gap-3 justify-items-center" id="tile-scores"></div>
    </div>

    <!-- Reference Panels -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
      <div id="section-two-letter" class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="font-semibold text-white mb-2 flex items-start gap-2"><span aria-hidden="true">🔤</span> Two-Letter Words</h2>
        <p class="text-xs text-gray-400 mb-3">All valid 2-letter Scrabble words (SOWPODS)</p>
        <div id="two-letter-words" class="text-xs text-gray-500 italic">Loading dictionary…</div>
      </div>
      <div id="section-three-letter" class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="font-semibold text-white mb-2 flex items-start gap-2"><span aria-hidden="true">🏆</span> Top 3-Letter Words</h2>
        <p class="text-xs text-gray-400 mb-3">Highest-scoring 3-letter words</p>
        <div id="three-letter-words" class="text-xs text-gray-500 italic">Loading dictionary…</div>
      </div>
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="font-semibold text-white mb-2 flex items-start gap-2"><span aria-hidden="true">🅀</span> Q Without U</h2>
        <p class="text-xs text-gray-400 mb-3">Legal Scrabble words with Q but no U</p>
        <div id="q-without-u" class="text-xs text-gray-500 italic">Loading dictionary…</div>
      </div>
    </div>

    <!-- Rare Letters -->
    <div id="section-rare-letters" class="mt-6 rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
      <h2 class="font-semibold text-white mb-2 flex items-start gap-2"><span aria-hidden="true">💎</span> Words with Rare Letters</h2>
      <div class="flex gap-2 mb-4" id="rare-tabs">
        <button data-rare="q" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-purple-900/30 text-purple-300 border border-purple-800">Q</button>
        <button data-rare="z" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:bg-gray-700">Z</button>
        <button data-rare="x" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:bg-gray-700">X</button>
        <button data-rare="j" class="rare-tab px-3 py-1.5 rounded-lg text-sm font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:bg-gray-700">J</button>
      </div>
      <div id="rare-letter-results" class="text-xs text-gray-500 italic">Loading dictionary…</div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
      <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 shadow-2xl w-full max-w-sm mx-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-white">Edit Saved Word</h3>
          <button id="edit-modal-close" class="text-gray-400 hover:text-gray-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="mb-3">
          <div id="edit-word-display" class="text-2xl font-mono font-bold text-blue-400 uppercase tracking-wider"></div>
          <div id="edit-word-score" class="text-xs text-gray-500 mt-1"></div>
        </div>
        <div class="space-y-4">
          <div class="hidden"><div id="star-rating" class="flex gap-2">
            <button data-star="1" class="star-btn w-10 h-10 rounded-lg border border-gray-700 flex items-center justify-center text-lg">👍</button>
            <button data-star="2" class="star-btn w-10 h-10 rounded-lg border border-gray-700 flex items-center justify-center text-lg">🔹</button>
            <button data-star="3" class="star-btn w-10 h-10 rounded-lg border border-gray-700 flex items-center justify-center text-lg">⭐</button>
            <button data-star="4" class="star-btn w-10 h-10 rounded-lg border border-gray-700 flex items-center justify-center text-lg">🪄</button>
            <button data-star="5" class="star-btn w-10 h-10 rounded-lg border border-gray-700 flex items-center justify-center text-lg">🎯</button>
          </div></div>
          <div>
            <label for="edit-comment" class="block text-xs font-medium text-gray-400 mb-1">Meaning / Note</label>
            <textarea id="edit-comment" rows="3" placeholder="e.g. (noun) a type of plant..." class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
          </div>
          <div class="hidden"><input id="edit-datetime" type="datetime-local" class="w-full h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm"/></div>
        </div>
        <div class="flex gap-2 mt-5">
          <button id="edit-save-btn" class="flex-1 h-10 bg-blue-500 text-gray-950 font-semibold rounded-lg hover:bg-blue-400 transition-colors text-sm">Save</button>
          <button id="edit-cancel-btn" class="flex-1 h-10 bg-gray-700 text-gray-200 font-semibold rounded-lg hover:bg-gray-600 transition-colors text-sm">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Related Articles -->
    <div class="mt-10 rounded-xl border border-gray-800 bg-gray-900/50 p-6">
      <h2 class="font-semibold text-white mb-4 flex items-center gap-2"><span aria-hidden="true">📝</span> Related Articles</h2>
      <ul class="space-y-3">
        <li><a href="/blog/scrabble-history-origins-great-depression" class="flex items-center gap-3 text-sm text-gray-400 hover:text-blue-400 transition-colors"><span class="shrink-0 text-base" aria-hidden="true">🏛️</span><span>The History of Scrabble: From the Great Depression to Global Phenomenon</span></a></li>
        <li><a href="/blog/scrabble-tile-strategy-letters-scoring" class="flex items-center gap-3 text-sm text-gray-400 hover:text-blue-400 transition-colors"><span class="shrink-0 text-base" aria-hidden="true">🎯</span><span>Scrabble Tile Strategy: Letter Values, Rack Management & Scoring Tips</span></a></li>
        <li><a href="/blog/scrabble-dictionaries-languages-weird-words" class="flex items-center gap-3 text-sm text-gray-400 hover:text-blue-400 transition-colors"><span class="shrink-0 text-base" aria-hidden="true">📖</span><span>Scrabble Dictionaries: Languages, Weird Words & What Counts</span></a></li>
        <li><a href="/blog/competitive-scrabble-tournament-world" class="flex items-center gap-3 text-sm text-gray-400 hover:text-blue-400 transition-colors"><span class="shrink-0 text-base" aria-hidden="true">🏆</span><span>Inside Competitive Scrabble: Tournaments, Records & the Mental Game</span></a></li>
      </ul>
    </div>

  </main>

  <!-- Footer -->
</Layout>

<script>
  // ── Tile Input Boxes Logic ──────────────────────────────────────────────
  // After entering a letter, cursor moves to the box on the RIGHT.
  // User can click any box to start. Backspace moves LEFT.
  const tileBoxes = document.querySelectorAll('.tile-box') as NodeListOf<HTMLInputElement>;
  const hiddenTiles = document.getElementById('tiles') as HTMLInputElement;
  let syncingFromTextSolver = false; // Guard to prevent circular sync

  function syncTiles() {
    if (syncingFromTextSolver) return; // Don't overwrite when Word Solver is driving
    const val = Array.from(tileBoxes).map(b => b.value.toUpperCase()).join('');
    hiddenTiles.value = val;
    hiddenTiles.dispatchEvent(new Event('input'));
    // Sync tile rack → Word Solver (bidirectional)
    const textSolverEl = document.getElementById('text-solver') as HTMLInputElement;
    if (textSolverEl) textSolverEl.value = val;
  }

  tileBoxes.forEach((box, idx) => {
    box.addEventListener('focus', () => box.select());

    box.addEventListener('input', () => {
      const v = box.value;
      if (v.length > 0) {
        box.value = v.slice(-1).toUpperCase();
        // After entering a letter, move cursor to the box on the RIGHT
        if (idx < tileBoxes.length - 1) {
          tileBoxes[idx + 1].focus();
        }
      }
      syncTiles();
    });

    box.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace') {
        if (box.value !== '') {
          box.value = '';
          syncTiles();
          // Backspace moves cursor LEFT (opposite of fill direction)
          if (idx > 0) tileBoxes[idx - 1].focus();
          e.preventDefault();
        } else if (idx > 0) {
          tileBoxes[idx - 1].focus();
          e.preventDefault();
        }
      } else if (e.key === 'ArrowLeft' && idx > 0) {
        tileBoxes[idx - 1].focus();
      } else if (e.key === 'ArrowRight' && idx < tileBoxes.length - 1) {
        tileBoxes[idx + 1].focus();
      } else if (e.key === 'Enter') {
        (document.getElementById('solve-btn') as HTMLElement).click();
      }
    });
  });

  // ── Scrabble tile scores ────────────────────────────────────────────────
  const scores: Record<string, number> = {
    A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,
    N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10
  };

  let WORDS: string[] = [];
  let SOWPODS: string[] = [];
  let TWL: string[] = [];
  let dictionaryLoaded = false;
  let currentDict = localStorage.getItem('scbDictionary') || 'sowpods';

  async function loadDictionary() {
    try {
      const [sowRes, twlRes, longRes] = await Promise.all([
        fetch('/data/sowpods-2-7.json'),
        fetch('/data/twl06-2-7.json'),
        fetch('/data/sowpods-8-15.json'),
      ]);
      if (!sowRes.ok) throw new Error('Failed to load SOWPODS');
      const sowShort: string[] = await sowRes.json();
      let longWords: string[] = [];
      if (longRes.ok) {
        try {
          longWords = await longRes.json();
          console.log('[SWF] Long words (8-15) loaded:', longWords.length);
        } catch (e) {
          console.warn('[SWF] Failed to parse sowpods-8-15.json:', e);
        }
      } else {
        console.warn('[SWF] sowpods-8-15.json fetch failed:', longRes.status);
      }
      SOWPODS = [...sowShort, ...longWords];
      let twlShort: string[] = [];
      if (twlRes.ok) {
        try { twlShort = await twlRes.json(); } catch { twlShort = []; }
      }
      TWL = twlShort.length > 0 ? [...twlShort, ...longWords] : SOWPODS;
      WORDS = (currentDict === 'twl') ? TWL : SOWPODS;
      dictionaryLoaded = true;
      console.log('[SWF] Dictionary loaded:', WORDS.length, 'words (' + currentDict + ', 2-15 letters)');

      (document.getElementById('dictionary') as HTMLSelectElement).value = currentDict;

      const resultsEl = document.getElementById('results')!;
      const highScoringPanel = document.getElementById('high-scoring-panel')!;

      if (resultsEl.querySelector('.text-sm.italic') || resultsEl.querySelector('.italic')) {
        function topByLen(len: number, count: number): {word: string, score: number}[] {
          return WORDS
            .filter(w => w.length === len)
            .map(w => ({ word: w, score: w.split('').reduce((s, c) => s + (scores[c.toUpperCase()] || 0), 0) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, count);
        }
        const top2 = topByLen(2, 5);
        const top3 = topByLen(3, 5);
        const top4 = topByLen(4, 5);
        const top5 = topByLen(5, 5);

        function renderRow(words: {word: string, score: number}[]): string {
          return words.map(w => `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-800 font-mono relative cursor-pointer hover:ring-2 hover:ring-blue-400 transition-all" data-achieve-word="${w.word}"><span class="font-bold text-white uppercase" style="font-size:0.85rem">${w.word}</span><span class="text-blue-400" style="font-size:0.7rem">${w.score}</span></span>`).join(' ');
        }

        resultsEl.innerHTML = '';

        highScoringPanel.innerHTML = `
          <div class="text-center mb-3"><span class="inline-flex items-center gap-2 text-sm font-semibold text-blue-400"><span>🏆</span> High-Scoring Words by Length</span></div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden">
              <thead class="bg-gray-800"><tr><th class="px-4 py-3 text-left font-semibold text-gray-300 w-32">Length</th><th class="px-4 py-3 text-left font-semibold text-gray-300">Highest Scoring Words</th></tr></thead>
              <tbody class="divide-y divide-gray-800">
                <tr class="bg-gray-900"><td class="px-4 py-3 font-bold text-blue-400 text-base">2-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top2)}</div></td></tr>
                <tr class="bg-gray-900/50"><td class="px-4 py-3 font-bold text-blue-400 text-base">3-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top3)}</div></td></tr>
                <tr class="bg-gray-900"><td class="px-4 py-3 font-bold text-blue-400 text-base">4-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top4)}</div></td></tr>
                <tr class="bg-gray-900/50"><td class="px-4 py-3 font-bold text-blue-400 text-base">5-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top5)}</div></td></tr>
              </tbody>
            </table>
          </div>`;
        highScoringPanel.classList.remove('hidden');
        applyAchievements(highScoringPanel);
        bindAchievementClicks(highScoringPanel);
      }
    } catch {
      WORDS = ["quiz","qi","qat","ax","ox","za","zo","xi","xu"];
      dictionaryLoaded = true;
    }
  }

  loadDictionary();

  function wordScore(word: string): number {
    return word.split('').reduce((sum, ch) => sum + (scores[ch.toUpperCase()] || 0), 0);
  }

  function canMake(word: string, tiles: string): boolean {
    const available = tiles.toUpperCase().split('');
    const blanks = available.filter(t => t === '?').length;
    const tileCount: Record<string, number> = {};
    available.filter(t => t !== '?').forEach(t => { tileCount[t] = (tileCount[t] || 0) + 1; });
    let blanksNeeded = 0;
    for (const ch of word.toUpperCase()) {
      if (tileCount[ch] && tileCount[ch] > 0) { tileCount[ch]--; }
      else { blanksNeeded++; if (blanksNeeded > blanks) return false; }
    }
    return true;
  }

  function solve(overrideMaxLen?: number) {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    const maxLen = overrideMaxLen || tiles.length;
    const minLen = parseInt((document.getElementById('min-len') as HTMLSelectElement).value);
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement).value;
    const startsWith = (document.getElementById('starts-with') as HTMLInputElement).value.trim().toLowerCase();
    const endsWith = (document.getElementById('ends-with') as HTMLInputElement).value.trim().toLowerCase();
    const contains = (document.getElementById('contains') as HTMLInputElement).value.trim().toLowerCase();
    const resultsEl = document.getElementById('results')!;

    if (!dictionaryLoaded) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">Loading dictionary…</div>'; return; }
    if (!tiles || tiles.length < 2) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">Enter at least 2 tiles</div>'; return; }

    let found = WORDS.filter(w => {
      if (w.length < minLen || w.length > maxLen) return false;
      if (startsWith && !w.startsWith(startsWith)) return false;
      if (endsWith && !w.endsWith(endsWith)) return false;
      if (contains && !w.includes(contains)) return false;
      return canMake(w, tiles);
    });

    if (sortBy === 'score') found.sort((a, b) => wordScore(b) - wordScore(a));
    else if (sortBy === 'length') found.sort((a, b) => b.length - a.length || wordScore(b) - wordScore(a));
    else found.sort((a, b) => a.localeCompare(b));

    if (!found.length) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">No words found with those tiles</div>'; return; }

    const achievements = getAchievedWords();
    resultsEl.innerHTML = `
      <div class="text-xs text-gray-400 mb-3">${found.length} words found — click to save and copy to clipboard</div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 p-1">
        ${found.slice(0, 100).map(w => {
          const isAchieved = achievements.includes(w);
          const achievedClass = isAchieved ? 'ring-2 ring-emerald-500' : '';
          const tiara = isAchieved ? '<span class="achievement-tiara absolute -top-2 -left-1 text-xs">👑</span>' : '';
          const rareLetters = ['q','z','x','j'];
          const rareMatch = rareLetters.filter(l => w.includes(l));
          const rareIcon = rareMatch.length ? `<span class="absolute -top-2 -right-1 text-xs" title="Contains rare letter: ${rareMatch.join(', ').toUpperCase()}">💎</span>` : '';
          return `<div class="relative flex items-center justify-between px-3 py-2.5 bg-gray-800 rounded-lg cursor-pointer hover:ring-2 hover:ring-blue-400 transition-all ${achievedClass}" data-achieve-word="${w}" data-highlight-word="${w}">${tiara}${rareIcon}<span class="font-mono font-semibold text-white uppercase tracking-wider" style="font-size:0.65rem">${w}</span><div class="flex items-center gap-1"><span class="text-green-400" style="font-size:0.5rem" title="Valid in dictionary">✓</span><span class="font-bold text-blue-400" style="font-size:0.6rem">${wordScore(w)} pts</span></div></div>`;
        }).join('')}
      </div>
      ${found.length > 100 ? '<div class="mt-2 text-xs text-gray-500 text-center">Showing top 100 of ' + found.length + '</div>' : ''}`;

    resultsEl.querySelectorAll('[data-achieve-word]').forEach(el => {
      el.addEventListener('click', () => {
        const word = (el as HTMLElement).dataset.achieveWord!;
        toggleAchievement(word, el as HTMLElement);
        highlightTiles(word);
        onWordPlayed(word.length);
        analyzeLeave(word);
      });
    });
  }

  // ── Saved Words / Achievements ──────────────────────────────────────────
  const ACHIEVEMENTS_KEY = 'scbAchievements';
  interface Achievement { word: string; meaning: string; }

  function getAchievements(): Achievement[] {
    try {
      const data = JSON.parse(localStorage.getItem(ACHIEVEMENTS_KEY) || '[]');
      if (data.length > 0 && typeof data[0] === 'string') {
        const migrated = data.map((w: string) => ({ word: w, meaning: '' })).reverse();
        localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(migrated));
        return migrated;
      }
      return data;
    } catch { return []; }
  }

  function getAchievedWords(): string[] { return getAchievements().map(a => a.word); }

  function saveAchievements(achievements: Achievement[]) {
    localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(achievements));
    // Sync to server in background
    const uid = getOrCreateUid();
    fetch('/api/scrabble-sync', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ uid, achievements, dictionary: currentDict }),
    }).catch(() => {});
  }

  // ── UID Management ──────────────────────────────────────────────────────
  function getOrCreateUid(): string {
    let uid = localStorage.getItem('swf-uid');
    if (!uid) {
      uid = crypto.randomUUID();
      localStorage.setItem('swf-uid', uid);
    }
    return uid;
  }

  async function fetchMeaning(word: string): Promise<string> {
    try {
      const res = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
      if (!res.ok) return '';
      const data = await res.json();
      const meaning = data[0]?.meanings?.[0];
      const def = meaning?.definitions?.[0]?.definition || '';
      const pos = meaning?.partOfSpeech || '';
      return pos ? `(${pos}) ${def}` : def;
    } catch { return ''; }
  }

  function toggleAchievement(word: string, el: HTMLElement) {
    let achievements = getAchievements();
    const exists = achievements.find(a => a.word === word);
    if (exists) {
      achievements = achievements.filter(a => a.word !== word);
      el.classList.remove('ring-2', 'ring-emerald-500');
      const tiara = el.querySelector('.achievement-tiara');
      if (tiara) tiara.remove();
    } else {
      achievements.unshift({ word, meaning: '' });
      el.classList.add('ring-2', 'ring-emerald-500');
      if (!el.querySelector('.achievement-tiara')) {
        const tiara = document.createElement('span');
        tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
        tiara.textContent = '👑';
        el.style.position = 'relative';
        el.appendChild(tiara);
      }
      navigator.clipboard.writeText(word.toUpperCase()).catch(() => {});
      savedWordsPage = 0;
      fetchMeaning(word).then(meaning => {
        const updated = getAchievements();
        const entry = updated.find(a => a.word === word);
        if (entry) { entry.meaning = meaning; saveAchievements(updated); renderSavedWords(); }
      });
    }
    saveAchievements(achievements);
    renderSavedWords();
  }

  function applyAchievements(container: HTMLElement) {
    const achievedWords = getAchievedWords();
    container.querySelectorAll('[data-achieve-word]').forEach(el => {
      const word = (el as HTMLElement).dataset.achieveWord!;
      if (achievedWords.includes(word)) {
        el.classList.add('ring-2', 'ring-emerald-500');
        if (!el.querySelector('.achievement-tiara')) {
          const tiara = document.createElement('span');
          tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
          tiara.textContent = '👑';
          (el as HTMLElement).style.position = 'relative';
          el.appendChild(tiara);
        }
      }
    });
  }

  function bindAchievementClicks(container: HTMLElement) {
    container.querySelectorAll('[data-achieve-word]').forEach(el => {
      el.addEventListener('click', () => {
        const word = (el as HTMLElement).dataset.achieveWord!;
        toggleAchievement(word, el as HTMLElement);
      });
    });
  }

  // ── Render Saved Words ──────────────────────────────────────────────────
  const downloadBtn = document.getElementById('download-saved-btn')!;
  let savedWordsPage = 0;

  function updateDownloadBtnVisibility() {
    const achievements = getAchievements();
    if (achievements.length > 0) { downloadBtn.classList.remove('opacity-30'); downloadBtn.classList.add('opacity-100'); }
    else { downloadBtn.classList.add('opacity-30'); downloadBtn.classList.remove('opacity-100'); }
  }

  function renderSavedWords() {
    const achievements = getAchievements();
    const listEl = document.getElementById('saved-words-list')!;
    const countEl = document.getElementById('saved-count')!;
    countEl.textContent = `${achievements.length}`;
    updateDownloadBtnVisibility();

    if (!achievements.length) {
      savedWordsPage = 0;
      listEl.innerHTML = '<p class="text-sm text-gray-500 text-center py-4 italic">No saved words yet. Click any word to collect it.</p>';
      return;
    }
    if (savedWordsPage >= achievements.length) savedWordsPage = achievements.length - 1;
    if (savedWordsPage < 0) savedWordsPage = 0;

    const a = achievements[savedWordsPage];
    const idx = savedWordsPage;

    listEl.innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <button id="saved-prev-btn" class="p-1.5 rounded-lg transition-colors ${idx === 0 ? 'text-gray-600 cursor-not-allowed' : 'text-gray-400 hover:text-blue-400 cursor-pointer'}" ${idx === 0 ? 'disabled' : ''} aria-label="Previous saved word"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></button>
        <span class="text-xs text-gray-400 font-mono">${idx + 1} / ${achievements.length}</span>
        <button id="saved-next-btn" class="p-1.5 rounded-lg transition-colors ${idx === achievements.length - 1 ? 'text-gray-600 cursor-not-allowed' : 'text-gray-400 hover:text-blue-400 cursor-pointer'}" ${idx === achievements.length - 1 ? 'disabled' : ''} aria-label="Next saved word"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
      </div>
      <div class="p-4 bg-gray-800 rounded-lg">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2"><span class="text-lg">👑</span><span class="font-mono font-bold text-lg text-white uppercase tracking-wider">${escapeHtml(a.word)}</span></div>
          <span class="text-sm font-bold text-blue-400">${wordScore(a.word)} pts</span>
        </div>
        ${a.meaning ? `<p class="text-xs text-gray-400 mt-1 leading-relaxed">${escapeHtml(a.meaning)}</p>` : '<p class="text-xs text-gray-500 italic mt-1">No meaning saved</p>'}
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-700">
          <button class="edit-achievement-btn flex-1 py-1.5 text-xs text-center text-gray-400 hover:text-blue-400 hover:bg-blue-900/20 rounded transition-colors" data-idx="${idx}">✏️ Edit</button>
          <button class="delete-achievement-btn flex-1 py-1.5 text-xs text-center text-gray-400 hover:text-red-400 hover:bg-red-900/20 rounded transition-colors" data-idx="${idx}">🗑️ Delete</button>
        </div>
      </div>`;

    document.getElementById('saved-prev-btn')?.addEventListener('click', () => { if (savedWordsPage > 0) { savedWordsPage--; renderSavedWords(); } });
    document.getElementById('saved-next-btn')?.addEventListener('click', () => { if (savedWordsPage < achievements.length - 1) { savedWordsPage++; renderSavedWords(); } });
    listEl.querySelectorAll('.edit-achievement-btn').forEach(btn => { btn.addEventListener('click', () => openEditModal(parseInt((btn as HTMLElement).dataset.idx!))); });
    listEl.querySelectorAll('.delete-achievement-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        let achs = getAchievements(); const removed = achs[idx]; achs.splice(idx, 1); saveAchievements(achs); renderSavedWords();
        document.querySelectorAll(`[data-achieve-word="${removed?.word}"]`).forEach(el => { el.classList.remove('ring-2', 'ring-emerald-500'); el.querySelector('.achievement-tiara')?.remove(); });
      });
    });
  }

  downloadBtn.addEventListener('click', () => {
    const achievements = getAchievements();
    const exportData = { version: 2, exportedAt: new Date().toISOString(), achievements };
    const json = JSON.stringify(exportData, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `scrabble-words-${new Date().toISOString().slice(0, 10)}.json`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  });

  // ── Edit Modal ──────────────────────────────────────────────────────────
  let editingIdx = -1;
  const editModal = document.getElementById('edit-modal')!;
  const editWordDisplay = document.getElementById('edit-word-display')!;
  const editWordScore = document.getElementById('edit-word-score')!;
  const editComment = document.getElementById('edit-comment') as HTMLTextAreaElement;

  function openEditModal(idx: number) {
    const achievements = getAchievements();
    if (idx < 0 || idx >= achievements.length) return;
    const a = achievements[idx]; editingIdx = idx;
    editWordDisplay.textContent = a.word;
    editWordScore.textContent = `${wordScore(a.word)} pts`;
    editComment.value = a.meaning || '';
    highlightTiles(a.word);
    editModal.classList.remove('hidden'); editModal.classList.add('flex');
  }

  function closeEditModal() { editModal.classList.add('hidden'); editModal.classList.remove('flex'); editingIdx = -1; highlightTiles(''); }

  document.getElementById('edit-save-btn')!.addEventListener('click', () => {
    const achievements = getAchievements();
    if (editingIdx < 0 || editingIdx >= achievements.length) return;
    achievements[editingIdx].meaning = editComment.value.trim();
    saveAchievements(achievements); closeEditModal(); renderSavedWords();
  });
  document.getElementById('edit-cancel-btn')!.addEventListener('click', closeEditModal);
  document.getElementById('edit-modal-close')!.addEventListener('click', closeEditModal);

  renderSavedWords();

  // ── Restore from server if localStorage is empty ────────────────────────
  (function syncFromServer() {
    const uid = localStorage.getItem('swf-uid');
    if (!uid) return;
    const local = getAchievements();
    if (local.length === 0) {
      fetch(`/api/scrabble-sync?uid=${encodeURIComponent(uid)}`)
        .then(r => r.json())
        .then(data => {
          if (data.achievements && data.achievements.length > 0) {
            localStorage.setItem(ACHIEVEMENTS_KEY, JSON.stringify(data.achievements));
            if (data.dictionary) {
              localStorage.setItem('scbDictionary', data.dictionary);
              currentDict = data.dictionary;
              WORDS = (data.dictionary === 'twl') ? TWL : SOWPODS;
              (document.getElementById('dictionary') as HTMLSelectElement).value = data.dictionary;
            }
            savedWordsPage = 0;
            renderSavedWords();
          }
        })
        .catch(() => {});
    }
  })();

  // ── Helpers ─────────────────────────────────────────────────────────────
  function escapeHtml(s: string): string { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

  // ── Sticky Filter Preferences (localStorage) ─────────────────────────────
  const PREFS_KEY = 'scbFilterPrefs';

  function loadFilterPrefs() {
    try {
      const prefs = JSON.parse(localStorage.getItem(PREFS_KEY) || '{}');
      if (prefs.dictionary) {
        (document.getElementById('dictionary') as HTMLSelectElement).value = prefs.dictionary;
        currentDict = prefs.dictionary;
        WORDS = (prefs.dictionary === 'twl') ? TWL : SOWPODS;
      }
      if (prefs.sortBy) (document.getElementById('sort-by') as HTMLSelectElement).value = prefs.sortBy;
      if (prefs.minLen) (document.getElementById('min-len') as HTMLSelectElement).value = prefs.minLen;
      if (prefs.contains) (document.getElementById('contains') as HTMLInputElement).value = prefs.contains;
      if (prefs.startsWith) (document.getElementById('starts-with') as HTMLInputElement).value = prefs.startsWith;
      if (prefs.endsWith) (document.getElementById('ends-with') as HTMLInputElement).value = prefs.endsWith;
    } catch {}
  }

  function saveFilterPref(key: string, value: string) {
    try {
      const prefs = JSON.parse(localStorage.getItem(PREFS_KEY) || '{}');
      prefs[key] = value;
      localStorage.setItem(PREFS_KEY, JSON.stringify(prefs));
    } catch {}
  }

  // Load saved prefs on startup
  loadFilterPrefs();

  // ── Init Event Listeners ────────────────────────────────────────────────
  document.getElementById('solve-btn')!.addEventListener('click', () => solve(7));
  document.getElementById('tiles')!.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') solve(7); });

  document.getElementById('min-len')!.addEventListener('change', () => {
    saveFilterPref('minLen', (document.getElementById('min-len') as HTMLSelectElement).value);
    solve();
  });

  document.getElementById('sort-by')!.addEventListener('change', () => {
    saveFilterPref('sortBy', (document.getElementById('sort-by') as HTMLSelectElement).value);
    solve();
  });

  document.getElementById('starts-with')!.addEventListener('input', () => {
    saveFilterPref('startsWith', (document.getElementById('starts-with') as HTMLInputElement).value);
    if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve();
  });

  document.getElementById('ends-with')!.addEventListener('input', () => {
    saveFilterPref('endsWith', (document.getElementById('ends-with') as HTMLInputElement).value);
    if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve();
  });

  document.getElementById('contains')!.addEventListener('input', () => {
    saveFilterPref('contains', (document.getElementById('contains') as HTMLInputElement).value);
    if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve();
  });

  document.getElementById('dictionary')!.addEventListener('change', () => {
    const dict = (document.getElementById('dictionary') as HTMLSelectElement).value;
    currentDict = dict;
    WORDS = (dict === 'twl') ? TWL : SOWPODS;
    saveFilterPref('dictionary', dict);
    localStorage.setItem('scbDictionary', dict);
    if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve();
    populateReferencePanels();
  });

  // ── Dictionary Info Popup ───────────────────────────────────────────────
  const dictInfoBtn = document.getElementById('dict-info-btn')!;
  const dictInfoPopup = document.getElementById('dict-info-popup')!;
  const dictInfoText = document.getElementById('dict-info-text')!;
  let dictInfoTimer: ReturnType<typeof setTimeout> | null = null;

  function getDictLabel(): string {
    const dict = (document.getElementById('dictionary') as HTMLSelectElement).value;
    const count = WORDS.length.toLocaleString();
    const active = (d: string) => d === dict ? '🟢' : '⚪';
    return `<div class="mb-2 font-medium text-white">📖 Active: ${count} words loaded</div>
<div class="space-y-1.5">
  <div>${active('sowpods')} <strong class="text-white">SOWPODS</strong> — International tournament list (Collins + TWL combined). Used in official play outside North America. 74,000+ words.</div>
  <div>${active('twl')} <strong class="text-white">TWL / NASPA</strong> — North American tournament list. Used in US/Canada official Scrabble. Slightly smaller than SOWPODS.</div>
  <div>${active('wwf')} <strong class="text-white">Words With Friends</strong> — Zynga's custom word list. Includes some words not in Scrabble dictionaries. Different tile scoring.</div>
  <div>${active('collins')} <strong class="text-white">Collins Official</strong> — Collins Scrabble Words (CSW). The most comprehensive list, includes all SOWPODS words plus additions.</div>
</div>
<div class="mt-2 text-gray-500 italic">Green dot = currently selected dictionary</div>`;
