    const playedInput = document.getElementById('tiles-played') as HTMLInputElement;
    const rackCount = document.getElementById('prob-your-rack');
    if (bagInput) bagInput.value = '100';
    if (playedInput) playedInput.value = '0';
    if (rackCount) rackCount.textContent = '0';
    // Reset rack leave panel
    const rackLeavePanel = document.getElementById('rack-leave-panel');
    if (rackLeavePanel) rackLeavePanel.innerHTML = '<div class="text-xs text-gray-500 italic">Find words first, then click one to analyze your leave</div>';
    // Reset best opening panel
    const bestOpeningPanel = document.getElementById('best-opening-panel');
    if (bestOpeningPanel) bestOpeningPanel.innerHTML = '<div class="text-xs text-gray-500 italic">Enter your tiles above ↑ to see your best opening plays</div>';
    // Reset tile score highlights
    highlightTiles('');
    // Reset high-scoring panel
    const highScoringPanel = document.getElementById('high-scoring-panel');
    if (highScoringPanel) { highScoringPanel.classList.add('hidden'); highScoringPanel.innerHTML = ''; }
    // Reset draw chances
    const drawChances = document.getElementById('prob-draw-chances');
    if (drawChances) drawChances.innerHTML = '<div class="text-xs text-gray-500 italic">Enter your rack letters to see draw probabilities</div>';
