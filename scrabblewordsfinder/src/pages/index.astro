        <p class="mt-1.5 text-xs text-gray-500">Enter your tiles and I'll find the best word</p>
      </div>

      <!-- Response Area -->
      <div id="lex-solver-response" class="flex-1 overflow-y-auto p-4 min-h-[200px] max-h-[50vh]">
        <div class="flex items-start gap-2">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50 max-w-[85%]">
            <p class="text-sm text-gray-200">Hey! Enter your rack tiles above and I'll find the best words you can make — with scores, strategy tips, and rack leave advice.</p>
          </div>
