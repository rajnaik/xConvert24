  function getDictLabel(): string {
    const dict = (document.getElementById('dictionary') as HTMLSelectElement).value;
    const count = WORDS.length.toLocaleString();
    const active = (d: string) => d === dict ? '<span class="text-green-400 text-xs font-bold">✓</span>' : '<span class="text-red-400/60 text-xs">✗</span>';
    return `<div class="mb-2 font-medium text-white">📖 Active: <span class="text-green-400">${count} words</span> loaded</div>
<div class="space-y-1.5">
  <div>${active('sowpods')} <a href="/blog/sowpods-dictionary/" class="text-purple-300 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-200 font-bold">SOWPODS</a> — <a href="/blog/sowpods-dictionary/" class="text-gray-300 underline decoration-gray-600 decoration-1 underline-offset-2 hover:text-purple-300">International tournament list (Collins + TWL combined). Used in official play outside North America. 74,000+ words.</a></div>
  <div>${active('twl')} <a href="/blog/twl-naspa-dictionary/" class="text-purple-300 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-200 font-bold">TWL / NASPA</a> — <a href="/blog/twl-naspa-dictionary/" class="text-gray-300 underline decoration-gray-600 decoration-1 underline-offset-2 hover:text-purple-300">North American tournament list. Used in US/Canada official Scrabble. Slightly smaller than SOWPODS.</a></div>
  <div>${active('wwf')} <a href="/blog/words-with-friends-dictionary/" class="text-purple-300 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-200 font-bold">Words With Friends</a> — <a href="/blog/words-with-friends-dictionary/" class="text-gray-300 underline decoration-gray-600 decoration-1 underline-offset-2 hover:text-purple-300">Zynga's custom word list. Includes some words not in Scrabble dictionaries. Different tile scoring.</a></div>
  <div>${active('collins')} <a href="/blog/collins-official-dictionary/" class="text-purple-300 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-200 font-bold">Collins Official</a> — <a href="/blog/collins-official-dictionary/" class="text-gray-300 underline decoration-gray-600 decoration-1 underline-offset-2 hover:text-purple-300">Collins Scrabble Words (CSW). The most comprehensive list, includes all SOWPODS words plus additions.</a></div>
</div>
<div class="mt-2 text-gray-500 italic"><span class="text-green-400 text-xs font-bold">✓</span> = selected &nbsp; <span class="text-red-400/60 text-xs">✗</span> = available. <a href="/blog/dictionaries/" class="text-purple-400 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-300">Learn more →</a></div>`;
  }

  function showDictInfo() {
    dictInfoText.innerHTML = getDictLabel();
    dictInfoPopup.classList.remove('hidden');
    // Auto-hide after 30 seconds
    if (dictInfoTimer) clearTimeout(dictInfoTimer);
    dictInfoTimer = setTimeout(() => { dictInfoPopup.classList.add('hidden'); }, 30000);
  }

  function hideDictInfo() {
    dictInfoPopup.classList.add('hidden');
    if (dictInfoTimer) { clearTimeout(dictInfoTimer); dictInfoTimer = null; }
  }

  dictInfoBtn.addEventListener('click', () => {
    if (dictInfoPopup.classList.contains('hidden')) showDictInfo();
    else hideDictInfo();
  });

  // Hide popup when clicking elsewhere
  document.addEventListener('click', (e) => {
    if (!dictInfoBtn.contains(e.target as Node) && !dictInfoPopup.contains(e.target as Node)) {
      hideDictInfo();
    }
  });

  // Instant search (debounced)
  let solveTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('tiles')!.addEventListener('input', () => {
    if (solveTimer) clearTimeout(solveTimer);
    solveTimer = setTimeout(() => { if ((document.getElementById('tiles') as HTMLInputElement).value.trim().length >= 2) solve(); }, 300);
  });

  // ── Word Solver (one-way sync to tile rack, solves up to 15 letters) ──
  const textSolver = document.getElementById('text-solver') as HTMLInputElement;
  const textSolveBtn = document.getElementById('text-solve-btn')!;

  function syncTextToRack() {
    const text = textSolver.value.toUpperCase();
    // Render visual rack tiles (first 7 only)
    renderRack(text);
    // Hidden tiles gets the FULL text solver value (including ? as wildcards)
    hiddenTiles.value = text;
    hiddenTiles.dispatchEvent(new Event('input'));
  }

  textSolver.addEventListener('input', () => {
    textSolver.value = textSolver.value.toUpperCase();
    syncTextToRack();
  });

  // "Find Words" button — finds words up to the FULL text input length (up to 15)
  textSolveBtn.addEventListener('click', () => {
    const text = textSolver.value.trim().toUpperCase();
    if (!text || text.length < 2) return;
    hiddenTiles.value = text;
    solve();
  });

  textSolver.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const text = textSolver.value.trim().toUpperCase();
      if (!text || text.length < 2) return;
      hiddenTiles.value = text;
      solve();
    }
  });

