  function openEditModal(idx: number) {
    const achievements = getAchievements();
    if (idx < 0 || idx >= achievements.length) return;
    const a = achievements[idx]; editingIdx = idx;
    editWordDisplay.textContent = a.word;
    editWordScore.textContent = `${wordScore(a.word)} pts`;
    editComment.value = a.meaning || '';
    highlightTiles(a.word);
    editModal.classList.remove('hidden'); editModal.classList.add('flex');
  }

  function closeEditModal() { editModal.classList.add('hidden'); editModal.classList.remove('flex'); editingIdx = -1; highlightTiles(''); }

  document.getElementById('edit-save-btn')!.addEventListener('click', () => {
    const achievements = getAchievements();
    if (editingIdx < 0 || editingIdx >= achievements.length) return;
    achievements[editingIdx].meaning = editComment.value.trim();
    saveAchievements(achievements); closeEditModal(); renderSavedWords();
