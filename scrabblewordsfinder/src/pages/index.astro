  <!-- Lex Solver Modal Script -->
  <script is:inline>
  (function() {
    const modal = document.getElementById('lex-solver-modal');
    const openBtn = document.getElementById('ask-lex-tile');
    const closeBtn = document.getElementById('lex-solver-close');
    const rackInput = document.getElementById('lex-rack-input');
    const solveBtn = document.getElementById('lex-solve-btn');
    const responseArea = document.getElementById('lex-solver-response');

    if (!modal || !openBtn || !closeBtn || !rackInput || !solveBtn || !responseArea) return;

    // Open modal — pre-fill from solver input if available
    openBtn.addEventListener('click', () => {
      const solverInput = document.getElementById('text-solver');
      if (solverInput && solverInput.value.trim()) {
        rackInput.value = solverInput.value.trim().toUpperCase().slice(0, 7);
      }
      modal.classList.remove('hidden');
      rackInput.focus();
    });

    // Close modal
    closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) modal.classList.add('hidden'); });

    // Ask Lex
    let isLoading = false;
    async function askLex() {
      const rack = rackInput.value.trim().toUpperCase().replace(/[^A-Z?]/g, '');
      if (!rack || rack.length < 2) {
        showResponse('Please enter at least 2 tiles to find words.', true);
        return;
      }
      if (isLoading) return;
      isLoading = true;
      solveBtn.disabled = true;
      solveBtn.textContent = 'Thinking...';

      // Show loading state
      responseArea.innerHTML = `
        <div class="flex items-start gap-2">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50 max-w-[85%]">
            <p class="text-sm text-gray-400 italic">Analysing ${rack}...</p>
            <div class="flex gap-1 mt-1"><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:0.15s"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:0.3s"></span></div>
          </div>
        </div>`;

      try {
        const res = await fetch('/api/lex-solve/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rack })
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Request failed' }));
          showResponse(err.error || 'Something went wrong. Try again.', true);
          return;
        }

        const data = await res.json();
        renderResponse(data);
      } catch (e) {
        showResponse('Network error — please check your connection.', true);
      } finally {
        isLoading = false;
        solveBtn.disabled = false;
        solveBtn.textContent = 'Ask Lex';
      }
    }

    solveBtn.addEventListener('click', askLex);
    rackInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') askLex(); });

    function showResponse(msg, isError) {
      responseArea.innerHTML = `
        <div class="flex items-start gap-2">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50 max-w-[85%]">
            <p class="text-sm ${isError ? 'text-red-300' : 'text-gray-200'}">${msg}</p>
          </div>
        </div>`;
    }

    function renderResponse(data) {
      const { words, coaching } = data;
      let html = '';

      // Top words section
      if (words && words.length > 0) {
        html += `<div class="mb-3">
          <p class="text-xs font-semibold text-purple-300 mb-1.5">Top Words from ${rackInput.value.toUpperCase()}</p>
          <div class="space-y-1">`;
        words.slice(0, 10).forEach(w => {
          html += `<div class="flex items-center justify-between px-2 py-1 rounded bg-gray-800/60 border border-gray-700/40">
            <span class="font-mono text-sm text-blue-300 font-bold">${w.word}</span>
            <span class="text-xs text-green-400 font-semibold">${w.score} pts</span>
          </div>`;
        });
        html += `</div></div>`;
      }

      // AI coaching
      if (coaching) {
        html += `<div class="flex items-start gap-2 mt-3">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50">
            <div class="text-sm text-gray-200 leading-relaxed lex-coaching-text">${coaching}</div>
          </div>
        </div>`;
      }

      responseArea.innerHTML = html || '<p class="text-sm text-gray-400">No words found for this rack.</p>';
    }

    // ── Lex Chat (free-form questions) ──────────────────────────────────────
    const chatForm = document.getElementById('lex-solver-chat-form');
    const chatInput = document.getElementById('lex-solver-chat-input');
    const chatSendBtn = document.getElementById('lex-solver-chat-send');

    if (chatForm && chatInput && chatSendBtn) {
      let chatLoading = false;

      chatForm.addEventListener('submit', function(e) { e.preventDefault(); sendChat(); });

      chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
      });

      // Auto-resize textarea
      chatInput.addEventListener('input', function() {
        chatInput.style.height = 'auto';
        chatInput.style.height = Math.min(chatInput.scrollHeight, 96) + 'px';
      });

      async function sendChat() {
        const msg = chatInput.value.trim();
        if (!msg || chatLoading) return;

        chatLoading = true;
        chatSendBtn.disabled = true;

        // Show user message in response area
        const userBubble = `<div class="flex items-start gap-2 justify-end mt-3">
          <div class="rounded-lg rounded-tr-none px-3 py-2 bg-blue-900/40 border border-blue-700/30 max-w-[85%]">
            <p class="text-sm text-gray-200">${msg.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
          </div>
        </div>`;

        const loadingBubble = `<div id="lex-chat-loading" class="flex items-start gap-2 mt-3">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50">
            <div class="flex gap-1"><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:0.15s"></span><span class="w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay:0.3s"></span></div>
          </div>
        </div>`;

        responseArea.innerHTML += userBubble + loadingBubble;
        responseArea.scrollTop = responseArea.scrollHeight;
        chatInput.value = '';
        chatInput.style.height = 'auto';

        try {
          const res = await fetch('/api/lex-chat/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg, context: { rack: rackInput.value.trim().toUpperCase().replace(/[^A-Z?]/g, '') || '' } })
          });

          const loadingEl = document.getElementById('lex-chat-loading');
          if (loadingEl) loadingEl.remove();

          if (!res.ok) {
            const err = await res.json().catch(() => ({ error: 'Request failed' }));
            appendLexReply(err.error || 'Something went wrong. Try again.', true);
          } else {
            const data = await res.json();
            appendLexReply(data.reply || 'I couldn\'t generate a response.', false);
          }
        } catch (e) {
          const loadingEl = document.getElementById('lex-chat-loading');
          if (loadingEl) loadingEl.remove();
          appendLexReply('Network error — please check your connection.', true);
        } finally {
          chatLoading = false;
          chatSendBtn.disabled = false;
          chatInput.focus();
        }
      }

      function appendLexReply(text, isError) {
        const bubble = `<div class="flex items-start gap-2 mt-3">
          <div class="w-6 h-6 rounded-full bg-purple-900/50 flex items-center justify-center shrink-0 mt-0.5">
            <img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />
          </div>
          <div class="rounded-lg rounded-tl-none px-3 py-2 bg-gray-800/80 border border-gray-700/50 max-w-[85%]">
            <p class="text-sm ${isError ? 'text-red-300' : 'text-gray-200'} leading-relaxed">${text}</p>
          </div>
        </div>`;
        responseArea.innerHTML += bubble;
        responseArea.scrollTop = responseArea.scrollHeight;
      }
    }
  })();
  </script>
</Layout>

<script>
  import { ACHIEVEMENTS_KEY, type Achievement, LETTER_SCORES, wordScore as _wordScore, escapeHtml, getAchievements, getAchievedWords, getCategories, getOrCreateUid, saveAchievements as _saveAchievements, fetchMeaning as _fetchMeaning, isRealMeaning } from '../lib/wordbench';
  import { logPracticeWord, getAutoPlaySpeed, saveAutoPlaySpeed } from '../lib/practice';

  // Re-export with local wrappers that inject dependencies
  function wordScore(word: string): number { return _wordScore(word); }
  function saveAchievements(achievements: Achievement[]) { _saveAchievements(achievements, currentDict); }
  async function fetchMeaning(word: string): Promise<string> { return _fetchMeaning(word, swfDict); }

  // ── Tile Rack (Read-Only Visual Display) ─────────────────────────────────
  // One-way sync: Word Solver text input → visual rack tiles
  const rackTiles = document.querySelectorAll('.rack-tile') as NodeListOf<HTMLElement>;
  const hiddenTiles = document.getElementById('tiles') as HTMLInputElement;

  const scores: Record<string, number> = {
    A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,
    N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10
  };

  // ── Render Rack (one-way: text → visual tiles with drop animation) ──────
  let prevRackLetters: string[] = ['','','','','','',''];

  function renderRack(text: string) {
    const letters = text.toUpperCase().slice(0, 7).split('');
    rackTiles.forEach((tile, i) => {
      const letter = letters[i] || '';
      const prevLetter = prevRackLetters[i] || '';
      if (letter === prevLetter) return; // No change on this tile

      if (!letter) {
        // Empty tile — show faded placeholder
        tile.innerHTML = '';
        tile.style.opacity = '0.3';
        tile.classList.remove('tile-drop');
      } else {
        // Filled tile — show letter + score with drop animation
        const pts = letter === '?' ? 0 : (scores[letter] || 0);
        const displayChar = letter === '?' ? '★' : letter;
        tile.innerHTML = `
          <span class="text-3xl sm:text-4xl font-black text-gray-900 leading-none" style="font-family: 'Arial Black', sans-serif;">${displayChar}</span>
          <span class="text-[10px] sm:text-sm font-bold text-blue-600 absolute bottom-0.5 right-1.5 leading-none" style="font-family: 'Arial Black', sans-serif;">${pts}</span>
        `;
        tile.style.opacity = '1';
        // Trigger drop animation
        tile.classList.remove('tile-drop');
        void tile.offsetWidth; // Force reflow to restart animation
        tile.classList.add('tile-drop');
      }
    });
    prevRackLetters = Array.from({ length: 7 }, (_, i) => letters[i] || '');
  }

  // ── Rack + Button: Add tiles as a word to Memory WordBench ──
  document.getElementById('rack-add-btn')!.addEventListener('click', () => {
    const text = (document.getElementById('text-solver') as HTMLInputElement)?.value?.toUpperCase().trim() || '';
    if (!text || text.length < 2) return;

    const btn = document.getElementById('rack-add-btn')!;
    let achievements = getAchievements();

    // Check if already saved
    if (achievements.find(a => a.word === text)) {
      btn.textContent = '✓';
      btn.classList.add('text-green-400', 'border-green-500/50');
      setTimeout(() => { btn.textContent = '+'; btn.classList.remove('text-green-400', 'border-green-500/50'); }, 1500);
      return;
    }

    // Add word (same as clicking a word in results)
    achievements.unshift({ word: text, meaning: '', category: 'manual', dateAdded: new Date().toISOString() });
    saveAchievements(achievements);

    // Copy to clipboard
    navigator.clipboard.writeText(text).catch(() => {});

    // Visual feedback
    btn.textContent = '✓';
    btn.classList.add('text-green-400', 'border-green-500/50');
    setTimeout(() => { btn.textContent = '+'; btn.classList.remove('text-green-400', 'border-green-500/50'); }, 2000);

    // Show the new word in Memory WordBench
    savedWordsPage = 0;
    renderSavedWords();

    // Fetch meaning in background (same as toggleAchievement)
    fetchMeaning(text).then(meaning => {
      const updated = getAchievements();
      const entry = updated.find(a => a.word === text);
      if (entry) { entry.meaning = meaning; saveAchievements(updated); renderSavedWords(); }
    });
  });

  let WORDS: string[] = [];
  let SOWPODS: string[] = [];
  let TWL: string[] = [];
  let dictionaryLoaded = false;
  let currentDict = localStorage.getItem('scbDictionary') || 'sowpods';

  async function loadDictionary() {
    try {
      const [sowRes, twlRes, longRes] = await Promise.all([
        fetch('/data/sowpods-2-7.json'),
        fetch('/data/twl06-2-7.json'),
        fetch('/data/sowpods-8-15.json'),
      ]);
      if (!sowRes.ok) throw new Error('Failed to load SOWPODS');
      const sowShort: string[] = await sowRes.json();
      let longWords: string[] = [];
      if (longRes.ok) {
        try {
          longWords = await longRes.json();
          console.log('[SWF] Long words (8-15) loaded:', longWords.length);
        } catch (e) {
          console.warn('[SWF] Failed to parse sowpods-8-15.json:', e);
        }
      } else {
        console.warn('[SWF] sowpods-8-15.json fetch failed:', longRes.status);
      }
      SOWPODS = [...sowShort, ...longWords];
      let twlShort: string[] = [];
      if (twlRes.ok) {
        try { twlShort = await twlRes.json(); } catch { twlShort = []; }
      }
      TWL = twlShort.length > 0 ? [...twlShort, ...longWords] : SOWPODS;
      WORDS = (currentDict === 'twl') ? TWL : SOWPODS;
      dictionaryLoaded = true;
      console.log('[SWF] Dictionary loaded:', WORDS.length, 'words (' + currentDict + ', 2-15 letters)');

      (document.getElementById('dictionary') as HTMLSelectElement).value = currentDict;

      const resultsEl = document.getElementById('results')!;
      const highScoringPanel = document.getElementById('high-scoring-panel')!;

      if (resultsEl.querySelector('.text-sm.italic') || resultsEl.querySelector('.italic')) {
        function topByLen(len: number, count: number): {word: string, score: number}[] {
          return WORDS
            .filter(w => w.length === len)
            .map(w => ({ word: w, score: w.split('').reduce((s, c) => s + (scores[c.toUpperCase()] || 0), 0) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, count);
        }
        const top2 = topByLen(2, 5);
        const top3 = topByLen(3, 5);
        const top4 = topByLen(4, 5);
        const top5 = topByLen(5, 5);

        function renderRow(words: {word: string, score: number}[]): string {
          return words.map(w => `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-800 font-mono relative cursor-pointer hover:ring-2 hover:ring-blue-400 transition-all" data-achieve-word="${w.word}"><span class="font-bold text-white uppercase" style="font-size:0.85rem">${w.word}</span><span class="text-blue-400" style="font-size:0.7rem">${w.score}</span></span>`).join(' ');
        }

        resultsEl.innerHTML = '';

        highScoringPanel.innerHTML = `
          <div class="text-center mb-3"><span class="inline-flex items-center gap-2 text-sm font-semibold text-blue-400"><span>🏆</span> High-Scoring Words by Length</span> <button id="import-highscoring-btn" class="ml-2 px-2 py-0.5 rounded text-xs text-purple-400 border border-purple-700 hover:bg-purple-900/30 transition-colors" title="Import all to Memory WordBench">📥 Import</button></div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-gray-700 rounded-lg overflow-hidden">
              <thead class="bg-gray-800"><tr><th class="px-4 py-3 text-left font-semibold text-gray-300 w-32">Length</th><th class="px-4 py-3 text-left font-semibold text-gray-300">Highest Scoring Words</th></tr></thead>
              <tbody class="divide-y divide-gray-800">
                <tr class="bg-gray-900"><td class="px-4 py-3 font-bold text-blue-400 text-base">2-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top2)}</div></td></tr>
                <tr class="bg-gray-900/50"><td class="px-4 py-3 font-bold text-blue-400 text-base">3-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top3)}</div></td></tr>
                <tr class="bg-gray-900"><td class="px-4 py-3 font-bold text-blue-400 text-base">4-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top4)}</div></td></tr>
                <tr class="bg-gray-900/50"><td class="px-4 py-3 font-bold text-blue-400 text-base">5-letter</td><td class="px-4 py-3"><div class="flex flex-wrap gap-2">${renderRow(top5)}</div></td></tr>
              </tbody>
            </table>
          </div>`;
        highScoringPanel.classList.remove('hidden');
        applyAchievements(highScoringPanel);
        bindAchievementClicks(highScoringPanel);
        // Import all high-scoring words to Memory WordBench
        document.getElementById('import-highscoring-btn')?.addEventListener('click', () => {
          const words = highScoringPanel.querySelectorAll('[data-achieve-word]');
          let imported = 0;
          const importedWords: string[] = [];
          const wordsNeedingMeaning: string[] = [];
          const existing = getAchievedWords();
          words.forEach(el => {
            const word = (el as HTMLElement).dataset.achieveWord;
            if (!word) return;
            if (!existing.includes(word)) {
              const achievements = getAchievements();
              achievements.unshift({ word, meaning: '', category: 'high-scoring', dateAdded: new Date().toISOString() });
              saveAchievements(achievements);
              importedWords.push(word);
              imported++;
            } else {
              const achievements = getAchievements();
              const entry = achievements.find(a => a.word === word && !a.meaning);
              if (entry) wordsNeedingMeaning.push(word);
            }
          });
          const btn = document.getElementById('import-highscoring-btn')!;
          btn.textContent = imported > 0 ? `✅ ${imported} imported` : `✅ fetching…`;
          setTimeout(() => { btn.textContent = '📥 Import'; }, 3000);
          renderSavedWords();
          // Fetch meanings in background for newly imported + existing without meaning
          const allToFetch = [...importedWords, ...wordsNeedingMeaning];
          allToFetch.forEach((word, i) => {
            setTimeout(() => {
              fetchMeaning(word).then(meaning => {
                if (!meaning) return;
                const updated = getAchievements();
                const entry = updated.find(a => a.word === word && !a.meaning);
                if (entry) { entry.meaning = meaning; saveAchievements(updated); renderSavedWords(); }
              });
            }, i * 150);
          });
        });
      }
    } catch {
      WORDS = ["quiz","qi","qat","ax","ox","za","zo","xi","xu"];
      dictionaryLoaded = true;
    }
  }

  loadDictionary();

  // ── SWF Dictionary (pre-scraped meanings) ───────────────────────────────
  let swfDict: Record<string, string> = {};
  fetch('/data/swfdict.json').then(r => r.ok ? r.json() : {}).then(d => { swfDict = d || {}; }).catch(() => {});

  // wordScore imported from ../lib/wordbench

  function canMake(word: string, tiles: string): boolean {
    const available = tiles.toUpperCase().split('');
    const blanks = available.filter(t => t === '?').length;
    const tileCount: Record<string, number> = {};
    available.filter(t => t !== '?').forEach(t => { tileCount[t] = (tileCount[t] || 0) + 1; });
    let blanksNeeded = 0;
    for (const ch of word.toUpperCase()) {
      if (tileCount[ch] && tileCount[ch] > 0) { tileCount[ch]--; }
      else { blanksNeeded++; if (blanksNeeded > blanks) return false; }
    }
    return true;
  }

  function solve(overrideMaxLen?: number) {
    const tiles = (document.getElementById('tiles') as HTMLInputElement).value.trim().toUpperCase();
    const maxLen = overrideMaxLen || tiles.length;
    const minLen = parseInt((document.getElementById('min-len') as HTMLSelectElement).value);
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement).value;
    const startsWith = (document.getElementById('starts-with') as HTMLInputElement).value.trim().toLowerCase();
    const endsWith = (document.getElementById('ends-with') as HTMLInputElement).value.trim().toLowerCase();
    const contains = (document.getElementById('contains') as HTMLInputElement).value.trim().toLowerCase();
    const resultsEl = document.getElementById('results')!;

    if (!dictionaryLoaded) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">Loading dictionary…</div>'; return; }
    if (!tiles || tiles.length < 2) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">Enter at least 2 tiles</div>'; return; }

    let found = WORDS.filter(w => {
      if (w.length < minLen || w.length > maxLen) return false;
      if (startsWith && !w.startsWith(startsWith)) return false;
      if (endsWith && !w.endsWith(endsWith)) return false;
      if (contains && !w.includes(contains)) return false;
      return canMake(w, tiles);
    });

    if (sortBy === 'score') found.sort((a, b) => wordScore(b) - wordScore(a));
    else if (sortBy === 'length') found.sort((a, b) => b.length - a.length || wordScore(b) - wordScore(a));
    else found.sort((a, b) => a.localeCompare(b));

    if (!found.length) { resultsEl.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">No words found with those tiles</div>'; return; }

    const achievements = getAchievedWords();
    resultsEl.innerHTML = `
      <div class="text-xs text-gray-400 mb-3">${found.length} words found — click to save and copy to clipboard <span class="ml-2">💎 = 20+ points</span></div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 p-1">
        ${found.slice(0, 100).map(w => {
          const isAchieved = achievements.includes(w);
          const achievedClass = isAchieved ? 'ring-2 ring-emerald-500' : '';
          const tiara = isAchieved ? '<span class="achievement-tiara absolute -top-2 -left-1 text-xs">👑</span>' : '';
          const wScore = wordScore(w);
          const diamondIcon = wScore > 20 ? `<span class="absolute -top-2 -right-1 text-xs" title="High scorer: ${wScore} pts">💎</span>` : '';
          return `<div class="relative flex items-center justify-between px-3 py-2.5 bg-gray-800 rounded-lg cursor-pointer hover:ring-2 hover:ring-blue-400 transition-all ${achievedClass}" data-achieve-word="${w}" data-highlight-word="${w}">${tiara}${diamondIcon}<span class="font-mono font-semibold text-white uppercase tracking-wider" style="font-size:0.65rem">${w}</span><div class="flex items-center gap-1"><span class="text-green-400" style="font-size:0.5rem" title="Valid in dictionary">✓</span><span class="font-bold text-blue-400" style="font-size:0.6rem">${wScore} pts</span></div></div>`;
        }).join('')}
      </div>
      ${found.length > 100 ? '<div class="mt-2 text-xs text-gray-500 text-center">Showing top 100 of ' + found.length + '</div>' : ''}`;

    resultsEl.querySelectorAll('[data-achieve-word]').forEach(el => {
      el.addEventListener('click', () => {
        const word = (el as HTMLElement).dataset.achieveWord!;
        toggleAchievement(word, el as HTMLElement);
        highlightTiles(word);
        onWordPlayed(word.length);
        analyzeLeave(word);
      });
    });
  }

  // ── Memory WordBench / Achievements (imported from ../lib/wordbench) ──────
  let activeCategory = 'all';

  // ── UID + saveAchievements + fetchMeaning (imported from ../lib/wordbench) ──

  function toggleAchievement(word: string, el: HTMLElement) {
    let achievements = getAchievements();
    const exists = achievements.find(a => a.word === word);
    if (exists) {
      achievements = achievements.filter(a => a.word !== word);
      el.classList.remove('ring-2', 'ring-emerald-500');
      const tiara = el.querySelector('.achievement-tiara');
      if (tiara) tiara.remove();
    } else {
      achievements.unshift({ word, meaning: '', category: 'manual', dateAdded: new Date().toISOString() });
      el.classList.add('ring-2', 'ring-emerald-500');
      if (!el.querySelector('.achievement-tiara')) {
        const tiara = document.createElement('span');
        tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
        tiara.textContent = '👑';
        el.style.position = 'relative';
        el.appendChild(tiara);
      }
      navigator.clipboard.writeText(word.toUpperCase()).catch(() => {});
      savedWordsPage = 0;
      fetchMeaning(word).then(meaning => {
        const updated = getAchievements();
        const entry = updated.find(a => a.word === word);
        if (entry) { entry.meaning = meaning; saveAchievements(updated); renderSavedWords(); }
      });
    }
    saveAchievements(achievements);
    renderSavedWords();
  }

  function applyAchievements(container: HTMLElement) {
    const achievedWords = getAchievedWords();
    container.querySelectorAll('[data-achieve-word]').forEach(el => {
      const word = (el as HTMLElement).dataset.achieveWord!;
      if (achievedWords.includes(word)) {
        el.classList.add('ring-2', 'ring-emerald-500');
        if (!el.querySelector('.achievement-tiara')) {
          const tiara = document.createElement('span');
          tiara.className = 'achievement-tiara absolute -top-2 -left-1 text-xs';
          tiara.textContent = '👑';
          (el as HTMLElement).style.position = 'relative';
          el.appendChild(tiara);
        }
      }
    });
  }

