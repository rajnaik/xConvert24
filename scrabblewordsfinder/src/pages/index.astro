---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import EVScore from '../components/EVScore.astro';
import { TAGLINE } from '../lib/constants';
import '../styles/global.css';
---

<Layout showSectionLinks={true} title="Free Scrabble Word Finder — Fast, Fun & No Sign-Up" description="Fun, free, fast Scrabble word finder and solver. Enter your tiles, get the highest-scoring words instantly from 74,000+ SOWPODS words. No sign-up needed." keywords="scrabble word finder, scrabble solver, scrabble dictionary, free scrabble solver, scrabble cheat, anagram solver, words with friends solver, instant scrabble solver, scrabble helper, no signup word finder, realtime word finder, scrabble rack solver, SOWPODS dictionary online">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What dictionary does this Scrabble word finder use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This tool uses the SOWPODS dictionary — the international Scrabble word list used in official tournaments outside North America. It contains over 74,000 valid words between 2 and 7 letters long."
        }
      },
      {
        "@type": "Question",
        "name": "How are Scrabble tile scores calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each letter tile has a fixed point value. Common letters like E, A, I, O score 1 point, while rare letters like Q and Z score 10 points. The word score is the sum of all individual tile values. Blank tiles (wildcards) score 0 points."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use blank tiles or wildcards?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Enter a question mark (?) for each blank tile in your rack — up to 2 wildcards are supported. The solver will treat each as any letter and find all possible words, though blank tiles contribute 0 points to the word score."
        }
      },
      {
        "@type": "Question",
        "name": "Does this work for Words With Friends too?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. While Words With Friends uses a slightly different dictionary and scoring system, the SOWPODS word list covers virtually all valid WWF words. The tile scores shown are for standard Scrabble — WWF scores differ slightly for some letters."
        }
      }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ScrabbleWordsFinder",
    "url": "https://www.scrabblewordsfinder.com",
    "description": "Free Scrabble word finder and solver. Enter your tiles, find the highest-scoring words instantly from 74,000+ SOWPODS words.",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "browserRequirements": "Requires JavaScript"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Use the Scrabble Word Finder",
    "description": "Find the highest-scoring Scrabble words from your rack in 3 simple steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter your tiles", "text": "Type your Scrabble rack letters into the input field. Use ? for blank tiles." },
      { "@type": "HowToStep", "position": 2, "name": "Find words instantly", "text": "Results appear automatically as you type. The solver searches 74,000+ words from the SOWPODS Scrabble dictionary." },
      { "@type": "HowToStep", "position": 3, "name": "Click to collect achievements", "text": "Click any word to add it to your achievements, copy it to clipboard, and see your rack leave analysis." }
    ]
  })} />

  <style is:inline>
    [id^="section-"] { scroll-margin-top: 35px; }
    .scrabble-tile {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }
    .scrabble-tile:hover {
      transform: scale(2) rotate(-3deg) translateY(-4px);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), inset 0 -2px 0 rgba(0,0,0,0.1), 0 8px 20px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.2) !important;
      z-index: 10;
      position: relative;
    }
    .scrabble-tile.tile-highlighted {
      animation: tile-glow 1.2s ease-in-out infinite alternate;
    }
    @keyframes tile-glow {
      0% { outline-color: #3b82f6; transform: scale(1); }
      100% { outline-color: #dc2626; transform: scale(1.08); }
    }
    .rack-tile {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
    }
    .rack-tile.tile-drop {
      animation: rack-tile-drop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes rack-tile-drop {
      0% { transform: translateY(-18px) scale(0.7); opacity: 0; }
      60% { transform: translateY(3px) scale(1.05); opacity: 1; }
      100% { transform: translateY(0) scale(1); opacity: 1; }
    }
    @media (max-width: 639px) {
      .scrabble-tile { width: 44px !important; height: 44px !important; }
      .scrabble-tile .text-3xl { font-size: 1.25rem !important; }
      .scrabble-tile .text-xs { font-size: 0.55rem !important; bottom: 2px !important; right: 4px !important; }
    }
  </style>



  <!-- Main solver area -->
  <main class="mx-auto max-w-[1049px] px-4 sm:px-6 pb-20 pt-2">

    <div class="flex flex-wrap items-center gap-3 mb-3">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight"><span class="text-blue-400">Scrabble</span> Words Finder</h1>
      <span id="site-tagline" class="text-sm text-blue-400 font-medium">{TAGLINE}</span>
      <!-- Word of the Day bubble -->
      <div class="relative flex items-center gap-1.5">
        <button id="wotd-solver-btn" class="px-2.5 py-1 rounded-full bg-purple-600/20 border border-purple-500/40 text-xs font-semibold text-purple-300 hover:bg-purple-600/40 transition-all cursor-pointer" title="Word of the Day — click to reveal meaning">
          <span id="wotd-solver-word" class="tracking-wider">...</span>
        </button>
        <button id="wotd-add-btn" class="w-6 h-6 flex items-center justify-center rounded-full border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 text-sm font-bold transition-all" title="Add WOTD to Memory WordBench">+</button>
        <div id="wotd-solver-bubble" class="hidden absolute top-full left-0 mt-2 z-50 w-64 p-3 rounded-xl bg-gray-900 border border-purple-500/50 shadow-xl shadow-purple-900/20 text-left">
          <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-1">📖 Word of the Day</p>
          <p id="wotd-solver-bubble-word" class="text-lg font-black text-purple-300 tracking-wider mb-1"></p>
          <p id="wotd-solver-bubble-meaning" class="text-xs text-gray-300 italic leading-relaxed"></p>
          <a href="/activities/" class="inline-block mt-2 text-[10px] text-blue-400 hover:underline">View on Activities →</a>
        </div>
      </div>
      <!-- Quick links (desktop only — Header handles mobile nav) -->
      <div class="hidden sm:flex items-center gap-2 ml-auto relative">
        <button id="bookmark-btn" type="button" class="w-9 h-9 flex items-center justify-center rounded-full bg-sky-600/20 border border-sky-500/40 hover:bg-sky-600/40 transition-colors relative" title="Bookmark this page" aria-label="Bookmark this page">
          <span class="text-lg leading-none">🔖</span>
        </button>
        <!-- Bookmark instruction bubble -->
        <div id="bookmark-bubble" class="hidden absolute top-12 right-0 z-50 w-72 rounded-xl border border-sky-700/40 bg-gray-900/95 px-4 py-3 shadow-xl backdrop-blur-sm">
          <div class="absolute -top-2 right-16 w-4 h-4 rotate-45 bg-gray-900/95 border-l border-t border-sky-700/40"></div>
          <p class="text-xs font-semibold text-sky-300 mb-2">⭐ Bookmark ScrabbleWordsFinder</p>
          <ol id="bookmark-steps" class="text-xs text-gray-300 leading-relaxed space-y-1 list-decimal list-inside"></ol>
          <p class="mt-2 text-[10px] text-gray-500">Or drag this link to your bookmarks bar: <a href="https://www.scrabblewordsfinder.com/" class="text-sky-400 hover:underline">ScrabbleWordsFinder.com</a></p>
          <button id="bookmark-bubble-close" class="mt-2 text-xs text-gray-500 hover:text-sky-400 transition-colors">Got it ✓</button>
        </div>
        <a href="/leaderboard/" class="w-9 h-9 flex items-center justify-center rounded-full bg-amber-600/20 border border-amber-500/40 hover:bg-amber-600/40 transition-colors" title="🪜 Leaderboard — See top players">
          <span class="text-lg leading-none">🪜</span>
        </a>
        <a href="/diamond-hunt/" class="w-9 h-9 flex items-center justify-center rounded-full bg-purple-600/20 border border-purple-500/40 hover:bg-purple-600/40 transition-colors" title="💎 Diamond Hunt — Find hidden diamonds across the site">
          <span class="text-lg leading-none">💎</span>
        </a>
        <a href="/activities/" class="w-9 h-9 flex items-center justify-center rounded-full bg-blue-600/20 border border-blue-500/40 hover:bg-blue-600/40 transition-colors" title="Word Quiz">
          <span class="text-lg leading-none">🧠</span>
        </a>
        <a href="/activities/" class="w-9 h-9 flex items-center justify-center rounded-full bg-purple-600/20 border border-purple-500/40 hover:bg-purple-600/40 transition-colors" title="Word of the Day">
          <span class="text-lg leading-none">📖</span>
        </a>
        <a href="/activities/#60seconds" class="w-9 h-9 flex items-center justify-center rounded-full bg-green-600/20 border border-green-500/40 hover:bg-green-600/40 transition-colors" title="60-Second Challenge">
          <span class="text-lg leading-none">⏱️</span>
        </a>
        <a href="/activities/#anagram" class="w-9 h-9 flex items-center justify-center rounded-full bg-amber-600/20 border border-amber-500/40 hover:bg-amber-600/40 transition-colors" title="Daily Anagram">
          <span class="text-lg leading-none">🔀</span>
        </a>
        <a href="/activities/#drc" class="w-9 h-9 flex items-center justify-center rounded-full bg-cyan-600/20 border border-cyan-500/40 hover:bg-cyan-600/40 transition-colors" title="Daily Rack Challenge">
          <span class="text-lg leading-none">🎲</span>
        </a>
      </div>
    </div>

    <!-- Two-column layout: Solver + Memory WordBench -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_calc(50%-33px)] gap-6 mb-6">
      <!-- Left: Input & Results -->
      <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-4 sm:p-6">

        <!-- Word Solver (up to 15 letters) -->
        <div class="mb-4">
          <div class="flex items-center gap-2 mb-2">
            <h2 class="font-semibold text-white flex items-center gap-2">
              <span aria-hidden="true">🔍</span> Word Solver
            </h2>
            <a id="copy-solver" href="#" class="flex items-center justify-center w-7 h-7 rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 transition-colors" title="Copy to clipboard"><svg class="w-4 h-4 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg></a>
            <a id="paste-solver" href="#" class="flex items-center justify-center w-7 h-7 rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 transition-colors" title="Paste from clipboard"><svg class="w-4 h-4 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg></a>
            <a id="clear-text-solver" href="#" class="flex items-center justify-center w-7 h-7 rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 transition-colors" title="Clear">
              <svg class="w-3 h-3 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </a>
          </div>
          <div class="flex gap-2 sm:gap-3 items-center">
            <input id="text-solver" type="text" maxlength="15" size="15" placeholder="Type your tiles e.g. QUARTZ" inputmode="text" autocapitalize="characters" data-track="SolverUsed" class="h-11 w-[20ch] px-2 sm:px-3 bg-gray-800 border border-gray-700 rounded-lg text-blue-300 text-base sm:text-lg font-mono uppercase tracking-wider sm:tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500 min-w-0" autocomplete="off"/>
            <button id="text-solve-btn" class="h-11 px-3 rounded-lg border-2 border-purple-500 hover:border-purple-400 hover:bg-purple-900/20 text-green-400 font-semibold transition-colors text-sm whitespace-nowrap w-fit">Find Words</button>
            <!-- Ask Lex AI tile — opens modal -->
            <button id="ask-lex-tile" type="button" data-track="Ask Lex AI" class="relative group flex items-center justify-center h-11 px-3 rounded-lg border-2 border-purple-500 hover:border-purple-400 hover:bg-purple-900/20 transition-colors cursor-pointer" title="Ask Lex AI for strategy help">
              <img src="/lex-avatar-32.png" alt="Lex" width="20" height="20" class="rounded-full absolute -top-2.5 left-1/2 -translate-x-1/2 border border-purple-400"/>
              <span class="text-sm font-semibold text-green-400">Ask Lex AI</span>
              <!-- Enlarged Lex avatar on hover — positioned just above the button -->
              <img src="/lex-avatar-lg.webp" alt="Lex AI" width="160" height="160" class="absolute bottom-full mb-1 left-1/2 -translate-x-1/2 rounded-full border-2 border-purple-400 shadow-lg shadow-purple-500/30 opacity-0 scale-75 group-hover:opacity-100 group-hover:scale-100 transition-all duration-200 pointer-events-none"/>
            </button>
          </div>
          <p class="mt-1.5 text-xs text-gray-500">Use <span class="text-blue-400 font-mono font-bold">?</span> for blank tiles. Up to 15 letters. Finds all words you can make.</p>
          <!-- EV Score (rack quality) — updates as tiles are typed -->
          <div class="flex items-center gap-2 mt-2">
            <a href="#ev-score-info" class="text-xs font-semibold text-gray-400 hover:text-blue-400 transition-colors cursor-help" title="EV Score measures your rack quality (0-100) based on vowel balance, power tiles, bingo potential, letter synergy, and duplicate penalties. Higher scores mean better chances of finding high-scoring words.">EV Score:</a>
            <EVScore targetInput="#text-solver" id="ev-score-widget" />
          </div>
        </div>

        <div class="border-t border-gray-800 my-4"></div>

        <!-- Tile Rack (read-only visual display synced from Word Solver) -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1.5">Tile Rack <span class="text-gray-500 font-normal">(first 7 tiles)</span></label>
          <div class="flex gap-1.5" id="tile-rack">
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="0" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="1" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="2" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="3" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="4" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="5" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <div class="rack-tile w-[46px] h-14 sm:w-[54px] sm:h-16 rounded-lg flex flex-col items-center justify-center select-none relative overflow-hidden" data-idx="6" style="background: linear-gradient(145deg, #e8d5c0, #dcc8b0); box-shadow: inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.2); border: 2px solid #c4a882; opacity: 0.3;"></div>
            <button id="rack-add-btn" type="button" class="w-8 h-8 rounded-full flex items-center justify-center border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 text-sm font-bold transition-all self-center" title="Add tiles to Memory WordBench">+</button>
          </div>
          <p class="mt-2 text-xs text-gray-500">Tiles mirror first 7 letters from Word Solver.</p>
          <input id="tiles" type="hidden" />
        </div>

        <!-- Filters -->
        <div class="space-y-3 mb-4">
          <div class="flex flex-wrap gap-3 items-end">
            <div>
              <label for="dictionary" class="text-xs text-gray-400 min-h-[24px] inline-flex items-center"><a href="/blog/dictionaries/" class="text-purple-400 underline decoration-purple-500/50 decoration-1 underline-offset-2 hover:text-purple-300 hover:decoration-purple-400 transition-colors py-1">Dictionary</a></label>
              <div class="flex items-center gap-1.5 relative">
                <select id="dictionary" class="h-10 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                  <option value="sowpods">SOWPODS (International)</option>
                  <option value="twl">TWL / NASPA (US/Canada)</option>
                  <option value="wwf">Words With Friends</option>
                  <option value="collins">Collins Official</option>
                </select>
                <button id="dict-info-btn" type="button" class="w-7 h-7 flex items-center justify-center rounded bg-gray-800 border border-gray-700 text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-colors text-sm" title="Dictionary info" aria-label="Dictionary info">📖</button>
                <div id="dict-info-popup" class="hidden absolute top-full left-0 mt-1.5 px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-xs text-gray-300 z-20 shadow-lg w-[320px]">
                  <span id="dict-info-text"></span>
                </div>
              </div>
            </div>
            <div>
              <label for="sort-by" class="text-xs text-gray-400">Sort by</label>
              <select id="sort-by" class="h-8 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                <option value="score">Highest Score</option>
                <option value="length">Longest First</option>
                <option value="alpha">A–Z</option>
              </select>
            </div>
            <div>
              <label for="min-len" class="text-xs text-gray-400">Min length</label>
              <select id="min-len" class="h-8 px-2 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100">
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
              </select>
            </div>
          </div>
          <div class="flex flex-wrap gap-3 items-end">
            <div>
              <label for="contains" class="text-xs text-gray-400">Contains</label>
              <input id="contains" type="text" maxlength="5" placeholder="e.g. TH" class="h-8 w-16 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
            <div>
              <label for="starts-with" class="text-xs text-gray-400">Starts with</label>
              <input id="starts-with" type="text" maxlength="3" placeholder="e.g. QU" class="h-8 w-14 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
            <div>
              <label for="ends-with" class="text-xs text-gray-400">Ends with</label>
              <input id="ends-with" type="text" maxlength="3" placeholder="e.g. ED" class="h-8 w-14 px-1.5 bg-gray-800 border border-gray-700 rounded text-sm text-gray-100 uppercase font-mono" autocomplete="off"/>
            </div>
          </div>
        </div>

        <!-- Results -->
        <div id="results" class="min-h-[100px]">
          <div class="text-center py-8 text-gray-500 text-sm italic">Enter your tiles above and click Find Words</div>
        </div>
        <div id="high-scoring-panel" class="hidden"></div>
      </div>

      <!-- Right: Memory WordBench -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6 h-fit lg:sticky lg:top-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-white flex items-center gap-2">
            <span aria-hidden="true">👑</span> Memory WordBench
          </h2>
          <div class="flex items-center gap-2">
            <button id="fetch-meanings-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-green-400 hover:bg-green-900/20 transition-colors" title="Fetch meanings for all words" aria-label="Fetch meanings for all words">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </button>
