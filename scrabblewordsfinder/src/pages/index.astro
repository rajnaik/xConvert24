  <!-- Bookmark button bubble script -->
  <script is:inline>
  (function() {
    var btn = document.getElementById('bookmark-btn');
    var bubble = document.getElementById('bookmark-bubble');
    var closeBtn = document.getElementById('bookmark-bubble-close');
    var stepsEl = document.getElementById('bookmark-steps');
    if (!btn || !bubble || !stepsEl) return;

    var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform || navigator.userAgent);
    var steps = isMac
      ? ['Press <strong class="text-sky-300">\u2318D</strong> (Command + D) on your keyboard',
         'A dialog will appear — click <strong class="text-sky-300">Add</strong> to save',
         'Find it later in your Bookmarks menu or Favourites Bar']
      : ['Press <strong class="text-sky-300">Ctrl+D</strong> on your keyboard',
         'A dialog will appear — click <strong class="text-sky-300">Done</strong> to save',
         'Find it later in your Bookmarks Bar or Menu'];
    stepsEl.innerHTML = steps.map(function(s) { return '<li>' + s + '</li>'; }).join('');

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isHidden = bubble.classList.contains('hidden');
      bubble.classList.toggle('hidden', !isHidden);
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        bubble.classList.add('hidden');
      });
    }

    document.addEventListener('click', function(e) {
      if (!bubble.classList.contains('hidden') && !bubble.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
        bubble.classList.add('hidden');
      }
    });
  })();
  </script>

  <!-- DB-driven constants (tagline + newsflash) — single request instead of 3 -->
  <script is:inline>
    (async function() {
      try {
        const res = await fetch('/api/constants/?active=true');
        if (!res.ok) return;
        const { constants } = await res.json();
        if (!constants) return;
        var map = {};
        for (var i = 0; i < constants.length; i++) map[constants[i].name] = constants[i].text;

        // Tagline
        if (map['TAGLINE']) {
          var el = document.getElementById('site-tagline');
          if (el) el.textContent = map['TAGLINE'];
        }

        // NewsFlash content
        if (map['NEWS_FLASH']) {
          var nf = document.getElementById('newsflash-content');
          if (nf) {
            var txt = map['NEWS_FLASH'].trim();
            if (txt.startsWith('<')) {
              nf.innerHTML = txt;
            } else {
              var items = txt.split(/\.\s+/).filter(function(s){ return s.trim(); });
              nf.innerHTML = items.map(function(item){
                return '<div class="border border-purple-500/40 rounded px-2 py-1">' + item.trim().replace(/\.$/, '') + '.</div>';
              }).join('');
            }
          }
        }

        // NewsFlash header
        if (map['NEWSFLASH_HEADER']) {
          var nh = document.getElementById('newsflash-heading');
          if (nh) nh.textContent = map['NEWSFLASH_HEADER'];
        }
      } catch (e) { /* fallback to static text */ }
    })();
  </script>

