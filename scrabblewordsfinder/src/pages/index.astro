    hiddenTiles.value = '';
    renderRack('');
    document.getElementById('results')!.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm italic">Enter at least 2 tiles</div>';
    document.getElementById('copy-solver')!.classList.add('opacity-30');
