  // + green button in header — add current displayed word to solver input
  document.getElementById('mwb-add-to-solver-btn')!.addEventListener('click', () => {
    const achievements = getAchievements();
    const filtered = activeCategory === 'all' ? achievements : achievements.filter(a => (a.category || 'manual') === activeCategory);
    if (!filtered.length) return;
    const word = filtered[savedWordsPage]?.word || '';
    if (!word) return;
    const solver = document.getElementById('text-solver') as HTMLInputElement;
    if (solver) { solver.value = word; solver.dispatchEvent(new Event('input', { bubbles: true })); }
    const btn = document.getElementById('mwb-add-to-solver-btn')!;
    btn.textContent = '✓';
    setTimeout(() => { btn.textContent = '+'; }, 1500);
  });

  // Fetch All Meanings button — fills in missing definitions for all saved words
  document.getElementById('fetch-meanings-btn')!.addEventListener('click', () => {
    const all = getAchievements();
    const missing = all.filter(a => !a.meaning);
    if (!missing.length) {
      const btn = document.getElementById('fetch-meanings-btn')!;
      btn.title = 'All words have meanings!';
      btn.classList.add('text-green-400');
      setTimeout(() => { btn.classList.remove('text-green-400'); btn.title = 'Fetch meanings for all words'; }, 2000);
      return;
    }
    const btn = document.getElementById('fetch-meanings-btn')!;
    btn.classList.add('animate-pulse', 'text-green-400');
    btn.title = `Fetching ${missing.length} meanings…`;
    let fetched = 0;
    missing.forEach((entry, i) => {
      setTimeout(() => {
        fetchMeaning(entry.word).then(meaning => {
          fetched++;
          if (meaning) {
            const updated = getAchievements();
            const match = updated.find(a => a.word === entry.word && !a.meaning);
            if (match) { match.meaning = meaning; saveAchievements(updated); renderSavedWords(); }
          }
          if (fetched >= missing.length) {
            btn.classList.remove('animate-pulse', 'text-green-400');
            btn.title = 'Fetch meanings for all words';
          }
        });
      }, i * 300);
    });
  });

  function renderFlashCard(cards: Achievement[]) {
    const listEl = document.getElementById('saved-words-list')!;
    const card = cards[flashCardIdx];
    if (!card) { flashCardMode = false; renderSavedWords(); return; }

    // If in fullscreen, update card content in-place to avoid destroying the fullscreen element
    if (document.fullscreenElement || mwbCssFullscreen) {
      const fcBody = document.getElementById('flashcard-body');
      const fcCounter = listEl.querySelector('.text-purple-400');
      const fcPrev = document.getElementById('fc-prev');
      const fcNext = document.getElementById('fc-next');
      const fcCatLabel = listEl.querySelector('.text-xs.text-gray-500:not(.italic):not(.animate-pulse)');
      if (fcBody && fcCounter) {
        // Update counter
        fcCounter.textContent = `Flash Card ${flashCardIdx + 1} / ${cards.length}`;
        // Update card body content
        fcBody.innerHTML = `
          <span class="font-mono font-extrabold text-2xl text-white uppercase tracking-widest ${flashCardRevealed ? 'fc-word-pulse' : ''}">${card.word}</span>
          <span class="text-sm text-blue-400 mt-1">${wordScore(card.word)} pts</span>
          ${flashCardRevealed ? `<div class="fc-meaning-reveal mt-3"><p class="text-xs text-gray-400 max-w-[220px] text-center leading-relaxed">${card.meaning || 'No definition saved'}</p></div>` : '<p class="text-xs text-gray-500 mt-3 italic animate-pulse cursor-pointer">Tap to reveal meaning</p>'}`;
        // Ensure cursor-pointer on body for tap-to-flip
        fcBody.style.cursor = 'pointer';
        // Update nav button states
        if (fcPrev) {
          if (flashCardIdx === 0) { fcPrev.classList.add('opacity-30', 'pointer-events-none'); } else { fcPrev.classList.remove('opacity-30', 'pointer-events-none'); }
        }
        if (fcNext) {
          if (flashCardIdx >= cards.length - 1) { fcNext.classList.add('opacity-30', 'pointer-events-none'); } else { fcNext.classList.remove('opacity-30', 'pointer-events-none'); }
        }
        if (fcCatLabel) fcCatLabel.textContent = card.category || 'manual';
        // Re-bind click on flashcard body for tap-to-flip
        fcBody.onclick = () => { if (!flashCardRevealed) { flashCardRevealed = true; renderFlashCard(cards); } };
        // Inject speed slider into fullscreen area if not present
        ensureFullscreenSlider();
        applyFullscreenStyles();
        return;
      }
    }

    listEl.innerHTML = `
      <style>
        @keyframes fcSlideIn { from { transform: translateX(30px) rotateY(15deg); opacity: 0; } to { transform: translateX(0) rotateY(0); opacity: 1; } }
        @keyframes fcSlideOut { from { transform: translateX(-30px) rotateY(-15deg); opacity: 0; } to { transform: translateX(0) rotateY(0); opacity: 1; } }
        @keyframes fcReveal { 0% { max-height: 0; opacity: 0; transform: translateY(-5px); } 100% { max-height: 80px; opacity: 1; transform: translateY(0); } }
        @keyframes fcWordPulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
        .fc-card-enter { animation: fcSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
        .fc-meaning-reveal { animation: fcReveal 0.5s ease-out both; overflow: hidden; }
        .fc-word-pulse { animation: fcWordPulse 0.3s ease-out; }
      </style>
      <div class="relative">
        <div class="absolute top-2 right-2 flex items-center gap-1.5">
          <span id="fc-timer-display" class="text-[10px] font-mono text-amber-400 ${(document.getElementById('mwb-autoplay') as HTMLInputElement)?.checked ? '' : 'hidden'}">0:00</span>
          <a href="/wordbench-practice/" class="w-6 h-6 flex items-center justify-center rounded-full bg-green-600/20 border border-green-500/40 hover:bg-green-600/40 text-green-300 transition-colors" title="Practice History"><span class="text-[10px]">📚</span></a>
          <button id="mwb-fullscreen-btn" class="w-7 h-7 flex items-center justify-center rounded-full bg-gray-600/30 border border-gray-500/50 hover:bg-gray-600/50 text-gray-300 text-sm transition-colors" title="Full screen" aria-label="Full screen"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/></svg></button>
          <button id="flashcard-autoplay-toggle" class="w-7 h-7 flex items-center justify-center rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 text-purple-300 text-sm transition-colors" title="Auto-play">${(document.getElementById('mwb-autoplay') as HTMLInputElement)?.checked ? '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>' : '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'}</button>
          <button id="flashcard-close" class="w-7 h-7 flex items-center justify-center rounded-full bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 text-purple-300 text-sm transition-colors">✕</button>
        </div>
        <div class="text-center py-6">
          <p class="text-[10px] text-purple-400 uppercase tracking-wider mb-2">Flash Card ${flashCardIdx + 1} / ${cards.length}</p>
          <div class="fc-card-enter p-6 bg-gray-800 rounded-xl border border-purple-800/50 min-h-[120px] flex flex-col items-center justify-center cursor-pointer transition-shadow hover:shadow-lg hover:shadow-purple-900/20" id="flashcard-body">
            <span class="font-mono font-extrabold text-2xl text-white uppercase tracking-widest ${flashCardRevealed ? 'fc-word-pulse' : ''}">${card.word}</span>
            <span class="text-sm text-blue-400 mt-1">${wordScore(card.word)} pts</span>
            ${flashCardRevealed ? `<div class="fc-meaning-reveal mt-3"><p class="text-xs text-gray-400 max-w-[220px] text-center leading-relaxed">${card.meaning || 'No definition saved'}</p></div>` : '<p class="text-xs text-gray-500 mt-3 italic animate-pulse">Tap to reveal meaning</p>'}
          </div>
          <div class="flex items-center justify-center gap-4 mt-4">
            <button id="fc-prev" class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-all ${flashCardIdx === 0 ? 'opacity-30 pointer-events-none' : ''}">&lt;</button>
            <span class="text-xs text-gray-500">${card.category || 'manual'}</span>
            <button id="fc-next" class="px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-all ${flashCardIdx >= cards.length - 1 ? 'opacity-30 pointer-events-none' : ''}">&gt;</button>
          </div>
        </div>
      </div>`;

    document.getElementById('flashcard-body')!.addEventListener('click', () => {
      if (!flashCardRevealed) { flashCardRevealed = true; renderFlashCard(cards); }
    });
    document.getElementById('fc-prev')!.addEventListener('click', () => {
      if (flashCardIdx > 0) { flashCardIdx--; flashCardRevealed = false; renderFlashCard(cards); }
    });
    document.getElementById('fc-next')!.addEventListener('click', () => {
      if (flashCardIdx < cards.length - 1) { flashCardIdx++; flashCardRevealed = false; renderFlashCard(cards); }
    });
    document.getElementById('flashcard-close')!.addEventListener('click', () => {
      if (document.fullscreenElement) document.exitFullscreen();
      if ((document.getElementById('flashcard-body')?.closest('.relative') as HTMLElement)?.dataset?.cssFullscreen) exitMwbCssFullscreen();
      flashCardMode = false;
      stopMwbAutoPlay();
      renderSavedWords();
    });
    document.getElementById('flashcard-autoplay-toggle')!.addEventListener('click', () => {
      document.getElementById('mwb-autoplay-btn')!.click();
    });
    document.getElementById('mwb-fullscreen-btn')!.addEventListener('click', () => {
      const fcArea = document.getElementById('flashcard-body')!.closest('.relative') as HTMLElement;
      if (!fcArea) return;

      // If currently in CSS fullscreen, exit it
      if (fcArea.dataset.cssFullscreen) {
        exitMwbCssFullscreen();
        return;
      }

      // If currently in native fullscreen, exit it
      if (document.fullscreenElement || (document as any).webkitFullscreenElement) {
        ((document.exitFullscreen || (document as any).webkitExitFullscreen) as Function).call(document);
        return;
      }

      // Try native fullscreen first (works on desktop + Android)
      if (fcArea.requestFullscreen) {
        fcArea.requestFullscreen().then(() => {
          fcArea.style.padding = '2rem';
          fcArea.style.display = 'flex';
          fcArea.style.flexDirection = 'column';
          fcArea.style.justifyContent = 'center';
          fcArea.style.alignItems = 'center';
          fcArea.style.background = '#0f172a';
          fcArea.style.overflow = 'auto';
          applyFullscreenStyles();
          ensureFullscreenSlider();
          const btn = document.getElementById('mwb-fullscreen-btn')!;
          btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 4H4v4M16 4h4v4M8 20H4v-4M16 20h4v-4"/></svg>';
          btn.title = 'Exit full screen';
        }).catch(() => {
          // Native failed (iOS) — use CSS fallback
          enterMwbCssFullscreen(fcArea);
        });
      } else if ((fcArea as any).webkitRequestFullscreen) {
        (fcArea as any).webkitRequestFullscreen();
      } else {
        // No native support — CSS fallback (iOS Safari)
        enterMwbCssFullscreen(fcArea);
      }
    });
    applyFullscreenStyles();
  }

  // ── Solver Memory WordBench Auto-play ──
  let mwbAutoTimer: any = null;
  let mwbAutoPhase = 'word';
  let mwbTimerInterval: any = null;
  let mwbTimerStart = 0;

  // isRealMeaning imported from ../lib/wordbench

  function startMwbAutoPlay() {
    let cards = getAchievements();
    if (activeCategory !== 'all') cards = cards.filter(a => (a.category || 'manual') === activeCategory);
    const realOnly = (document.getElementById('mwb-real-only') as HTMLInputElement).checked;
    if (realOnly) cards = cards.filter(a => isRealMeaning(a.meaning));
    if (!cards.length) return;

    if (!flashCardMode) {
      flashCardMode = true;
      flashCardIdx = 0;
      flashCardRevealed = false;
      renderFlashCard(cards);
    }

    // Start timer
    mwbTimerStart = Date.now();
    clearInterval(mwbTimerInterval);
    mwbTimerInterval = setInterval(() => {
      const el = document.getElementById('fc-timer-display');
      if (el) {
        const elapsed = Math.floor((Date.now() - mwbTimerStart) / 1000);
        const mins = Math.floor(elapsed / 60);
        const secs = elapsed % 60;
        el.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
        el.classList.remove('hidden');
      }
    }, 1000);

    mwbAutoPhase = 'word';
    scheduleMwbNext(cards);
  }

  function scheduleMwbNext(cards: Achievement[]) {
    clearTimeout(mwbAutoTimer);
    const speed = parseInt((document.getElementById('mwb-speed-slider') as HTMLInputElement).value) * 1000 || getAutoPlaySpeed();
    mwbAutoTimer = setTimeout(() => {
      if (!(document.getElementById('mwb-autoplay') as HTMLInputElement).checked) return;
      if (!flashCardMode) return;

      if (mwbAutoPhase === 'word') {
        // Reveal meaning
        const body = document.getElementById('flashcard-body');
        if (body) {
          const tapHint = body.querySelector('.animate-pulse');
          if (tapHint) {
            const card = cards[flashCardIdx];
            const meaningText = card?.meaning || 'No definition saved';
            tapHint.outerHTML = `<div class="fc-meaning-reveal mt-3"><p class="text-xs text-gray-400 max-w-[220px] text-center leading-relaxed">${meaningText}</p></div>`;
          }
        }
        flashCardRevealed = true;
        mwbAutoPhase = 'meaning';
        scheduleMwbNext(cards);
      } else {
        // Log the word to practice DB
        const currentCard = cards[flashCardIdx];
        logPracticeWord(currentCard?.word || '', currentCard?.meaning || '');
        // Advance to next card
        flashCardIdx = (flashCardIdx + 1) % cards.length;
        flashCardRevealed = false;
        renderFlashCard(cards);
        mwbAutoPhase = 'word';
        scheduleMwbNext(cards);
      }
    }, speed);
  }

  function stopMwbAutoPlay() {
    clearTimeout(mwbAutoTimer);
    clearInterval(mwbTimerInterval);
    mwbAutoTimer = null;
    mwbTimerInterval = null;
    (document.getElementById('mwb-autoplay') as HTMLInputElement).checked = false;
    document.getElementById('mwb-speed-wrap')!.classList.add('hidden');
  }

  document.getElementById('mwb-autoplay-btn')!.addEventListener('click', () => {
    const checkbox = document.getElementById('mwb-autoplay') as HTMLInputElement;
    if (!checkbox.checked) {
      checkbox.checked = true;
      document.getElementById('mwb-speed-wrap')!.classList.remove('hidden');
      if (document.fullscreenElement) ensureFullscreenSlider();
      startMwbAutoPlay();
    } else {
      checkbox.checked = false;
      document.getElementById('mwb-speed-wrap')!.classList.add('hidden');
      removeFullscreenSlider();
      clearTimeout(mwbAutoTimer);
    }
  });

  // Load saved speed from localStorage
  (() => {
    const saved = localStorage.getItem('swf-fc-speed');
    if (saved) {
      (document.getElementById('mwb-speed-slider') as HTMLInputElement).value = saved;
      document.getElementById('mwb-speed-label')!.textContent = saved + 's';
    }
  })();

  document.getElementById('mwb-speed-slider')!.addEventListener('input', () => {
    const val = (document.getElementById('mwb-speed-slider') as HTMLInputElement).value;
    document.getElementById('mwb-speed-label')!.textContent = val + 's';
    saveAutoPlaySpeed(parseInt(val));
    if ((document.getElementById('mwb-autoplay') as HTMLInputElement).checked && flashCardMode) {
      let cards = getAchievements();
      if (activeCategory !== 'all') cards = cards.filter(a => (a.category || 'manual') === activeCategory);
      const realOnly = (document.getElementById('mwb-real-only') as HTMLInputElement).checked;
      if (realOnly) cards = cards.filter(a => isRealMeaning(a.meaning));
      clearTimeout(mwbAutoTimer);
      scheduleMwbNext(cards);
    }
  });

  document.getElementById('mwb-real-only')!.addEventListener('change', () => {
    if (flashCardMode) {
      let cards = getAchievements();
      if (activeCategory !== 'all') cards = cards.filter(a => (a.category || 'manual') === activeCategory);
      const realOnly = (document.getElementById('mwb-real-only') as HTMLInputElement).checked;
      if (realOnly) cards = cards.filter(a => isRealMeaning(a.meaning));
      if (cards.length) { flashCardIdx = 0; flashCardRevealed = false; renderFlashCard(cards); }
      else { flashCardMode = false; renderSavedWords(); }
    }
  });

  downloadBtn.addEventListener('click', () => {
    const achievements = getAchievements();
    const exportData = { version: 2, exportedAt: new Date().toISOString(), achievements };
    const json = JSON.stringify(exportData, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `www.scrabblewordsfinder.com_wordbench-export_${new Date().toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}).replace(/ /g,'')}:${new Date().toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'}).replace(/:/g,'-')}.json`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  });

  // ── MWB CSS Fullscreen Helpers (iOS/mobile fallback) ──────────────────────
  let mwbCssFullscreen = false;

  function isMwbInFullscreen(): boolean {
    return !!(document.fullscreenElement || (document as any).webkitFullscreenElement || mwbCssFullscreen);
  }

  function enterMwbCssFullscreen(fcArea: HTMLElement) {
    mwbCssFullscreen = true;
    fcArea.dataset.cssFullscreen = '1';
    fcArea.style.position = 'fixed';
    fcArea.style.inset = '0';
    fcArea.style.zIndex = '9999';
    fcArea.style.overflow = 'auto';
    fcArea.style.borderRadius = '0';
    fcArea.style.padding = '2rem';
    fcArea.style.display = 'flex';
    fcArea.style.flexDirection = 'column';
    fcArea.style.justifyContent = 'center';
    fcArea.style.alignItems = 'center';
    fcArea.style.background = '#0f172a';
    document.body.style.overflow = 'hidden';
    applyFullscreenStyles();
    ensureFullscreenSlider();
    const btn = document.getElementById('mwb-fullscreen-btn');
    if (btn) {
      btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 4H4v4M16 4h4v4M8 20H4v-4M16 20h4v-4"/></svg>';
      btn.title = 'Exit full screen';
    }
  }

  function exitMwbCssFullscreen() {
    mwbCssFullscreen = false;
    const fcArea = document.querySelector('[data-css-fullscreen]') as HTMLElement;
    if (!fcArea) return;
    delete fcArea.dataset.cssFullscreen;
    fcArea.style.position = '';
    fcArea.style.inset = '';
    fcArea.style.zIndex = '';
    fcArea.style.overflow = '';
    fcArea.style.borderRadius = '';
    fcArea.style.padding = '';
    fcArea.style.display = '';
    fcArea.style.flexDirection = '';
    fcArea.style.justifyContent = '';
    fcArea.style.alignItems = '';
    fcArea.style.background = '';
    document.body.style.overflow = '';
    removeFullscreenSlider();
    // Reset flashcard sizes
    const fcBody = document.getElementById('flashcard-body') as HTMLElement;
    if (fcBody) {
      const fcWord = fcBody.querySelector('.font-mono.font-extrabold') as HTMLElement;
      if (fcWord) fcWord.style.fontSize = '';
      const fcMeaning = fcBody.querySelector('.text-xs.text-gray-400') as HTMLElement;
      if (fcMeaning) { fcMeaning.style.fontSize = ''; fcMeaning.style.maxWidth = ''; }
      const fcMeaningWrap = fcBody.querySelector('.fc-meaning-reveal') as HTMLElement;
      if (fcMeaningWrap) { fcMeaningWrap.style.animation = ''; fcMeaningWrap.style.maxHeight = ''; fcMeaningWrap.style.opacity = ''; }
      const fcScore = fcBody.querySelector('.text-blue-400') as HTMLElement;
      if (fcScore) fcScore.style.fontSize = '';
      const fcHint = fcBody.querySelector('.animate-pulse') as HTMLElement;
      if (fcHint) fcHint.style.fontSize = '';
      fcBody.style.minHeight = '';
      fcBody.style.padding = '';
    }
    // Reset button icon
    const btn = document.getElementById('mwb-fullscreen-btn');
    if (btn) {
      btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/></svg>';
      btn.title = 'Full screen';
    }
  }

  // ── MWB Fullscreen Slider Injection ────────────────────────────────────────
  function ensureFullscreenSlider() {
    if (!isMwbInFullscreen()) return;
    const fcArea = (document.fullscreenElement || document.querySelector('[data-css-fullscreen]')) as HTMLElement;
    if (!fcArea) return;
    // Only inject if not already present
    if (fcArea.querySelector('#fs-speed-wrap')) return;
    const speedSlider = document.getElementById('mwb-speed-slider') as HTMLInputElement;
    const speedLabel = document.getElementById('mwb-speed-label');
    const autoplayChecked = (document.getElementById('mwb-autoplay') as HTMLInputElement)?.checked;
    // Only show slider if autoplay is active
    if (!autoplayChecked) return;
    const wrap = document.createElement('div');
    wrap.id = 'fs-speed-wrap';
    wrap.className = 'flex items-center gap-2 mt-4';
    wrap.innerHTML = `
      <span class="text-[10px] text-gray-400">Speed:</span>
      <input type="range" id="fs-speed-slider" min="1" max="30" value="${speedSlider?.value || '5'}" class="w-32 h-1.5 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500" />
      <span id="fs-speed-label" class="text-xs text-gray-400 font-mono">${speedLabel?.textContent || '5s'}</span>
    `;
    // Insert after the nav buttons row
    const navRow = fcArea.querySelector('.flex.items-center.justify-center.gap-4.mt-4');
    if (navRow) { navRow.after(wrap); } else { fcArea.appendChild(wrap); }
    // Sync the clone slider with the real one
    const fsSlider = wrap.querySelector('#fs-speed-slider') as HTMLInputElement;
    fsSlider?.addEventListener('input', () => {
      const val = fsSlider.value;
      const lbl = wrap.querySelector('#fs-speed-label');
      if (lbl) lbl.textContent = val + 's';
      // Sync to real slider
      if (speedSlider) { speedSlider.value = val; speedSlider.dispatchEvent(new Event('input')); }
    });
  }

  function removeFullscreenSlider() {
    document.getElementById('fs-speed-wrap')?.remove();
  }

  // ── MWB Fullscreen Styles Helper ──────────────────────────────────────────
  function applyFullscreenStyles() {
    if (!isMwbInFullscreen()) return;
    const fcBody = document.getElementById('flashcard-body') as HTMLElement;
    if (fcBody) {
      const fcWord = fcBody.querySelector('.font-mono.font-extrabold') as HTMLElement;
      if (fcWord) fcWord.style.fontSize = '6rem';
      const fcMeaning = fcBody.querySelector('.text-xs.text-gray-400') as HTMLElement;
      if (fcMeaning) {
        fcMeaning.style.fontSize = '1.5rem';
        fcMeaning.style.maxWidth = 'none';
      }
      // Also enlarge the meaning container and remove max-height cap from animation
      const fcMeaningWrap = fcBody.querySelector('.fc-meaning-reveal') as HTMLElement;
      if (fcMeaningWrap) {
        fcMeaningWrap.style.animation = 'none';
        fcMeaningWrap.style.maxHeight = 'none';
        fcMeaningWrap.style.opacity = '1';
      }
      const fcScore = fcBody.querySelector('.text-blue-400') as HTMLElement;
      if (fcScore) fcScore.style.fontSize = '1.25rem';
      // Enlarge the "Tap to reveal" hint in fullscreen
      const fcHint = fcBody.querySelector('.animate-pulse') as HTMLElement;
      if (fcHint) fcHint.style.fontSize = '1.25rem';
      fcBody.style.minHeight = '300px';
      fcBody.style.padding = '3rem';
      fcBody.style.cursor = 'pointer';
    }
  }

  // ── MWB Fullscreen exit handler ─────────────────────────────────────────
  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) {
      removeFullscreenSlider();
      const fcArea = document.querySelector('#flashcard-body')?.closest('.relative') as HTMLElement;
      if (fcArea) {
        fcArea.style.padding = '';
        fcArea.style.display = '';
        fcArea.style.flexDirection = '';
        fcArea.style.justifyContent = '';
        fcArea.style.alignItems = '';
        fcArea.style.background = '';
