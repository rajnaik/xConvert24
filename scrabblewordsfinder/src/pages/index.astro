  // ── Import All Word Lists (Solver MWB) ──────────────────────────────────
  function bindMwbImportAllBtn() {
    const btn = document.getElementById('mwb-import-all-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      btn.setAttribute('disabled', 'true');
      btn.textContent = '⏳ Loading dictionary…';
      Promise.all([
        fetch('/data/sowpods-2-7.json').then(r => r.json()),
        fetch('/data/swfdict.json').then(r => r.json()).catch(() => ({}))
      ]).then(([words, meanings]: [string[], Record<string, string>]) => {
        const scores: Record<string, number> = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
        function wScore(w: string) { return w.split('').reduce((s, c) => s + (scores[c.toUpperCase()] || 0), 0); }

        // Two-Letter Words (all)
        const twoLetter = words.filter(w => w.length === 2).sort();
        // Top 3-Letter Words (top 30 by score)
        const threeLetter = words.filter(w => w.length === 3)
          .map(w => ({ word: w, score: wScore(w) }))
          .sort((a, b) => b.score - a.score)
          .slice(0, 30)
          .map(w => w.word);
        // Q without U
        const qNoU = words.filter(w => w.indexOf('q') !== -1 && w.indexOf('u') === -1).sort();
        // High-Scoring by Length (top 5 per length 2-5)
        const highScoring: string[] = [];
        [2, 3, 4, 5].forEach(len => {
          words.filter(w => w.length === len)
            .map(w => ({ word: w, score: wScore(w) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, 5)
            .forEach(item => highScoring.push(item.word));
        });
        // Rare letters (top 40 each: Q, Z, X, J)
        const rareSet: Record<string, boolean> = {};
        ['q', 'z', 'x', 'j'].forEach(letter => {
          words.filter(w => w.indexOf(letter) !== -1)
            .map(w => ({ word: w, score: wScore(w) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, 40)
            .forEach(item => { rareSet[item.word] = true; });
        });
        const rareAll = Object.keys(rareSet);

        // Build import list with categories
        const toImport: { word: string; category: string }[] = [];
        const seen: Record<string, boolean> = {};
        twoLetter.forEach(w => { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'two-letter' }); } });
        threeLetter.forEach(w => { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'three-letter' }); } });
        qNoU.forEach(w => { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'q-without-u' }); } });
        highScoring.forEach(w => { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'high-scoring' }); } });
        rareAll.forEach(w => { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'rare-letters' }); } });

        // Merge with existing
        const existing = getAchievements();
        const existingWords: Record<string, boolean> = {};
        existing.forEach(a => { existingWords[a.word] = true; });
        let imported = 0;
        const now = new Date().toISOString();
        toImport.forEach(item => {
          if (!existingWords[item.word]) {
            const def = meanings[item.word.toLowerCase()] || '';
            existing.unshift({ word: item.word, meaning: def, category: item.category, dateAdded: now });
            existingWords[item.word] = true;
            imported++;
          }
        });
        saveAchievements(existing);

        // Success feedback
        btn.textContent = `✅ Imported ${imported} words!`;
        btn.className = 'mt-2 px-4 py-2 rounded-lg bg-green-600/30 border border-green-500/50 text-sm text-green-300 font-medium';

        // Refresh panel
        setTimeout(() => { renderSavedWords(); }, 1500);
      }).catch(err => {
        btn.textContent = '❌ Failed — try again';
        btn.removeAttribute('disabled');
        btn.className = 'mt-2 px-4 py-2 rounded-lg bg-red-600/30 border border-red-500/50 text-sm text-red-300 hover:bg-red-600/50 transition-colors font-medium';
        console.error('[MWB] Import All failed:', err);
      });
    });
  }

