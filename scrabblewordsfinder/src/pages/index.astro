  }

  function bindCatTabs(container: HTMLElement) {
    container.querySelectorAll('.cat-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = (btn as HTMLElement).dataset.cat || 'all';
        savedWordsPage = 0;
        renderSavedWords();
      });
    });
    container.querySelectorAll('.cat-delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset.delCat;
        if (!cat) return;
        const achs = getAchievements();
        const count = achs.filter(a => (a.category || 'manual') === cat).length;
        const withNotes = achs.filter(a => (a.category || 'manual') === cat && a.meaning).length;
        const noteWarning = withNotes > 0 ? `\n\n⚠️ ${withNotes} of these words have saved meanings/notes that will be permanently lost.` : '';
        if (!confirm(`Delete all ${count} words in "${cat}"?${noteWarning}\n\nThis cannot be undone.`)) return;
        const removed = achs.filter(a => (a.category || 'manual') === cat);
        const kept = achs.filter(a => (a.category || 'manual') !== cat);
        saveAchievements(kept);
        // Remove crowns/rings from deleted words
        removed.forEach(r => {
          document.querySelectorAll(`[data-achieve-word="${r.word}"]`).forEach(el => {
            el.classList.remove('ring-2', 'ring-emerald-500');
            el.querySelector('.achievement-tiara')?.remove();
          });
        });
        if (activeCategory === cat) activeCategory = 'all';
        savedWordsPage = 0;
        renderSavedWords();
      });
    });
  }

  // ── Bind import buttons (reusable for dynamic buttons in MWB empty state) ──
  function bindImportButtons(container: HTMLElement) {
    container.querySelectorAll('.import-section-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const sectionId = (btn as HTMLElement).dataset.section!;
