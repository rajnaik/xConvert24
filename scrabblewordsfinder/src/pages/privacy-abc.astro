---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Privacy Policy — Auto Clicker Extension" description="Privacy policy for the Auto Clicker Chrome extension." keywords="auto clicker privacy, chrome extension privacy">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Privacy Policy — Auto Clicker Extension</h1>
    <p class="text-gray-400 mb-8">Last updated: June 11, 2026</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Data Collection</h2>
    <p class="text-gray-300 mb-4">The Auto Clicker extension does <strong class="text-white">NOT</strong> collect, store, or transmit any personal data. All settings are stored locally on your device using Chrome's built-in storage API.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">What We Store (Locally Only)</h2>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> Your saved CSS selectors</li>
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> Click interval preferences</li>
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> Active clicker state</li>
    </ul>
    <p class="text-gray-300 mb-4">This data never leaves your browser. We have no servers, no analytics, no tracking.</p>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Permissions</h2>
    <ul class="space-y-2 text-gray-300 mb-6">
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> <strong>activeTab:</strong> Required to interact with the current page and click elements</li>
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> <strong>scripting:</strong> Required to inject the auto-click script into the page</li>
      <li class="flex items-start gap-2"><span class="text-blue-400">-</span> <strong>storage:</strong> Required to save your preferences locally</li>
    </ul>

    <h2 class="text-xl font-semibold text-white mt-8 mb-3">Contact</h2>
    <p class="text-gray-300">Questions? Contact us at <span class="text-blue-400">contact@scrabblewordsfinder.com</span></p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Does the Auto Button Clicker extension collect any data?", "acceptedAnswer": { "@type": "Answer", "text": "No, the Auto Button Clicker stores only your CSS selectors and interval preferences locally in your browser. No data ever leaves your device or is sent to external servers." } },
    { "@type": "Question", "name": "Does the extension track my browsing history?", "acceptedAnswer": { "@type": "Answer", "text": "No, the extension does not access, store, or transmit your browsing history. It only interacts with the current active tab when you explicitly activate it." } },
    { "@type": "Question", "name": "What permissions does the extension need and why?", "acceptedAnswer": { "@type": "Answer", "text": "The extension requires activeTab (to click elements on the current page), scripting (to inject the click script), storage (to save your preferences), and tabs (to detect chrome:// pages where it cannot operate)." } }
  ]
}
</script>
</Layout>
