---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Suggest a Feature — Free Scrabble Word Finder" description="Have an idea for our free Scrabble word finder? Submit your feature suggestion. No sign-up needed — we build the most-requested features first." keywords="suggest feature, scrabble word finder feedback, free solver improvement, feature request">
<div class="max-w-3xl mx-auto px-6 pt-4 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">Suggest a Feature</h1>
    <p class="text-gray-400 mb-8">Got an idea that would make ScrabbleWordsFinder better? We want to hear it. We read every suggestion and build the most-requested features first.</p>

    <form id="suggest-form" class="space-y-6" action="/api/suggest" method="POST">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Name <span class="text-gray-500">(optional)</span></label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Your name"
          class="w-full rounded-lg border border-gray-700 bg-gray-900 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email <span class="text-gray-500">(optional — only if you want a reply)</span></label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          class="w-full rounded-lg border border-gray-700 bg-gray-900 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
        />
      </div>

      <div>
        <label for="suggestion" class="block text-sm font-medium text-gray-300 mb-2">Your Suggestion <span class="text-red-400">*</span></label>
        <textarea
          id="suggestion"
          name="suggestion"
          rows="6"
          required
          placeholder="Describe the feature you'd like to see. What problem would it solve? How would you use it?"
          class="w-full rounded-lg border border-gray-700 bg-gray-900 px-4 py-3 text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors resize-y"
        ></textarea>
      </div>

      <button
        type="submit"
        class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-950 transition-colors"
      >
        Submit Suggestion
      </button>
    </form>

    <div class="border border-purple-800/50 rounded-lg p-6 mt-10 bg-gray-900/50">
      <h2 class="text-lg font-semibold text-white mb-2">How we handle suggestions</h2>
      <ul class="space-y-2 text-gray-300">
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span>We read every single suggestion</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span>Most-requested features get built first</span></li>
        <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">✓</span><span>If you leave your email, we'll let you know when your feature ships</span></li>
      </ul>
      <p class="text-gray-400 text-sm mt-4">✉️ Prefer email? <a href="/contact" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Contact us directly</a>.</p>
    </div>

    <p class="text-gray-400 text-sm mt-8 text-center">
      Want to go back to finding words? <a href="/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Return to the solver →</a>
    </p>
  </div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I suggest a new feature?", "acceptedAnswer": { "@type": "Answer", "text": "Fill in the suggestion form on this page with your idea. Include as much detail as possible about what you would like to see and how it would help your gameplay." } },
    { "@type": "Question", "name": "Will my suggestion be implemented?", "acceptedAnswer": { "@type": "Answer", "text": "We review all suggestions and prioritise based on user demand and feasibility. Popular requests are more likely to be implemented in future updates." } },
    { "@type": "Question", "name": "Can I suggest words to add to the dictionary?", "acceptedAnswer": { "@type": "Answer", "text": "The dictionaries we use (TWL and SOWPODS) are maintained by official Scrabble organisations. We cannot add custom words, but we do update to the latest official dictionary versions." } }
  ]
}
</script>
</Layout>

<script>
  const form = document.getElementById('suggest-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const suggestion = (document.getElementById('suggestion') as HTMLTextAreaElement).value.trim();
    if (!suggestion) {
      alert('Please enter a suggestion.');
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/suggest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, suggestion }),
      });
      const data = await res.json();
      if (data.ok) {
        alert('Thanks! Your suggestion has been recorded. We read every one.');
        form.reset();
      } else {
        alert('Something went wrong: ' + (data.error || 'Unknown error'));
      }
    } catch {
      alert('Network error. Please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Submit Suggestion';
    }
  });

  // Prefill from URL params (e.g., /suggest?title=Feature+Name)
  const params = new URLSearchParams(window.location.search);
  const title = params.get('title');
  if (title) {
    const textarea = document.getElementById('suggestion') as HTMLTextAreaElement;
    textarea.value = `Feature for: ${title}\n\n`;
    textarea.focus();
    textarea.setSelectionRange(textarea.value.length, textarea.value.length);
  }
</script>
