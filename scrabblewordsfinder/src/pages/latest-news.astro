---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import '../styles/global.css';

const db = (env as any).DB;

let newsItems: any[] = [];
let categories: string[] = [];
let lastFetch: string = '';
let heroNews: any[] = [];

try {
  // Hero news: items with media
  const heroRes = await db.prepare("SELECT * FROM latest_news WHERE active = 1 AND media_url != '' AND fetched_at > datetime('now', '-30 days') ORDER BY fetched_at DESC LIMIT 3").all();
  heroNews = heroRes.results || [];

  // Regular news (exclude hero items)
  const heroIds = heroNews.map((h: any) => h.id);
  const res = await db.prepare("SELECT * FROM latest_news WHERE active = 1 AND fetched_at > datetime('now', '-30 days') ORDER BY fetched_at DESC LIMIT 50").all();
  newsItems = (res.results || []).filter((n: any) => !heroIds.includes(n.id));

  const catRes = await db.prepare("SELECT DISTINCT category FROM latest_news WHERE active = 1 ORDER BY category").all();
  categories = (catRes.results || []).map((r: any) => r.category);

  const statusRes = await db.prepare("SELECT last_news_fetch FROM site_status WHERE id = 1").first();
  lastFetch = statusRes?.last_news_fetch || '';
} catch (e) {
  console.error('Failed to fetch latest news:', e);
}

const categoryIcons: Record<string, string> = {
  tournament: '🏆',
  player: '👤',
  rules: '📜',
  community: '🌍',
  general: '📰',
};

const categoryColors: Record<string, string> = {
  tournament: 'text-amber-400 bg-amber-900/30 border-amber-500/40',
  player: 'text-blue-400 bg-blue-900/30 border-blue-500/40',
  rules: 'text-purple-400 bg-purple-900/30 border-purple-500/40',
  community: 'text-green-400 bg-green-900/30 border-green-500/40',
  general: 'text-gray-400 bg-gray-800/30 border-gray-600/40',
};

function timeAgo(dateStr: string) {
  const now = new Date();
  const then = new Date(dateStr);
  const diffMs = now.getTime() - then.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 14) return '1 week ago';
  return `${Math.floor(diffDays / 7)} weeks ago`;
}
---

<Layout
  title="Latest Scrabble News — Tournaments, Players & Community Updates"
  description="Daily-refreshed Scrabble news from around the world. Tournament results, player achievements, rule changes, and community updates. Auto-curated, always fresh."
  keywords="scrabble news, scrabble tournament news, WESPA news, NASPA news, competitive scrabble updates, scrabble community, scrabble player news, tournament results"
>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Latest Scrabble News",
  "description": "Daily-refreshed Scrabble news from tournaments, players, and the community worldwide.",
  "url": "https://www.scrabblewordsfinder.com/latest-news/",
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How often is the Scrabble news updated?",
      "acceptedAnswer": { "@type": "Answer", "text": "The news feed is automatically refreshed daily at midnight UTC. Our AI searches across multiple sources for the latest Scrabble tournament results, player achievements, and community updates from the last 30 days." }
    },
    {
      "@type": "Question",
      "name": "Where does the Scrabble news come from?",
      "acceptedAnswer": { "@type": "Answer", "text": "News is aggregated from tournament reports, Scrabble community sites, player announcements, and official WESPA/NASPA publications. Each item includes a source link when available." }
    },
    {
      "@type": "Question",
      "name": "Can I submit Scrabble news?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes! Use our Suggest feature to submit news tips. Tournament organisers and players can share results, records, and announcements that we'll review and add to the feed." }
    }
  ]
})} />

<div class="max-w-4xl mx-auto px-4 py-8">

  <!-- Hero -->
  <div class="text-center mb-8">
    <h1 class="text-3xl md:text-4xl font-light text-white mb-3">Latest Scrabble News</h1>
    <p class="text-gray-400 text-sm max-w-xl mx-auto">Tournament results, player achievements, and community updates from the last 30 days.</p>
    <div class="flex flex-wrap justify-center gap-3 mt-2 text-xs text-gray-500">
      <span>🔄 Auto-refreshed daily</span>
      <span>•</span>
      <span>{newsItems.length} items</span>
      {lastFetch && <>
        <span>•</span>
        <span>Last fetch: {lastFetch.replace('T', ' ').slice(0, 16)} UTC</span>
      </>}
    </div>
  </div>

  <!-- Hero News (items with media) -->
  {heroNews.length > 0 && (
    <div class="mb-10">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Featured</h2>
      <div class={`grid gap-4 ${heroNews.length === 1 ? 'grid-cols-1' : heroNews.length === 2 ? 'grid-cols-1 md:grid-cols-2' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3'}`}>
        {heroNews.map((item: any) => {
          const catClass = categoryColors[item.category] || categoryColors.general;
          return (
            <div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden hover:border-blue-700 transition-all">
              {/* Media */}
              <div class="aspect-video bg-gray-800 relative">
                {item.media_type === 'youtube' && (
                  <iframe
                    src={item.media_url}
                    class="w-full h-full"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                    title={item.title}
                  ></iframe>
                )}
                {item.media_type === 'video' && (
                  <video src={item.media_url} class="w-full h-full object-cover" controls preload="none"></video>
                )}
                {item.media_type === 'image' && (
                  <img src={item.media_url} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                )}
                {!item.media_type && (
                  <div class="w-full h-full flex items-center justify-center text-4xl text-gray-600">📰</div>
                )}
              </div>
              {/* Content */}
              <div class="p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`px-2 py-0.5 rounded text-[10px] font-medium uppercase ${catClass}`}>{item.category}</span>
                  <span class="text-[10px] text-gray-500">{timeAgo(item.fetched_at)}</span>
                </div>
                <h3 class="text-white font-semibold text-sm leading-snug mb-1">{item.title}</h3>
                <p class="text-gray-400 text-xs leading-relaxed">{item.summary.slice(0, 150)}</p>
                {item.source_url && (
                  <a href={item.source_url} target="_blank" rel="noopener" class="text-xs text-blue-400 hover:underline mt-2 inline-block">{item.source_name || 'Source'} →</a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Category Filter -->
  {categories.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2 mb-8">
      <button data-cat="all" class="cat-btn active px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-600/20 text-blue-400 border border-blue-500/40 transition-all">All</button>
      {categories.map(cat => (
        <button data-cat={cat} class={`cat-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-800/50 text-gray-400 border border-gray-700 hover:border-gray-500 transition-all`}>
          {categoryIcons[cat] || '📰'} {cat.charAt(0).toUpperCase() + cat.slice(1)}
        </button>
      ))}
    </div>
  )}

  <!-- News Feed -->
  {newsItems.length > 0 ? (
    <div class="space-y-4" id="news-feed">
      {newsItems.map((item: any) => {
        const catClass = categoryColors[item.category] || categoryColors.general;
        const icon = categoryIcons[item.category] || '📰';
        return (
          <article class="news-item p-5 rounded-xl border border-gray-800 bg-gray-900/30 hover:border-gray-700 transition-all" data-category={item.category}>
            <div class="flex items-start gap-4">
              <div class="shrink-0 mt-1">
                <span class={`inline-flex items-center justify-center w-10 h-10 rounded-lg border ${catClass}`}>
                  <span class="text-lg">{icon}</span>
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <h2 class="text-white font-semibold text-sm leading-snug">{item.title}</h2>
                  <span class="shrink-0 text-[10px] text-gray-500 whitespace-nowrap">{timeAgo(item.fetched_at)}</span>
                </div>
                <p class="text-gray-400 text-sm mt-1.5 leading-relaxed">
                  <span class="news-preview">{item.summary.slice(0, 120)}{item.summary.length > 120 ? '...' : ''}</span>
                  {item.summary.length > 120 && (
                    <span class="news-full hidden">{item.summary}</span>
                  )}
                  {item.summary.length > 120 && (
                    <button class="read-more-btn text-blue-400 hover:text-blue-300 text-xs ml-1 font-medium">Read More</button>
                  )}
                </p>
                <div class="flex items-center gap-3 mt-3">
                  <span class={`px-2 py-0.5 rounded text-[10px] font-medium uppercase ${catClass}`}>{item.category}</span>
                  {item.source_name && item.source_url && (
                    <a href={item.source_url} target="_blank" rel="noopener" class="text-xs text-blue-400 hover:underline">{item.source_name} →</a>
                  )}
                  {item.source_name && !item.source_url && (
                    <span class="text-xs text-gray-500">via {item.source_name}</span>
                  )}
                  {item.published_date && (
                    <span class="text-xs text-gray-600">{item.published_date}</span>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  ) : (
    <div class="text-center py-16">
      <p class="text-4xl mb-4">📰</p>
      <p class="text-gray-400 text-sm">Tournament results, player achievements, and community updates from the last 30 days.</p>
      <p class="text-gray-500 text-xs mt-2">The news feed refreshes daily at midnight UTC.</p>
    </div>
  )}

  <!-- CTA -->
  <div class="mt-10 text-center p-5 rounded-xl border border-gray-800 bg-gradient-to-r from-blue-900/10 to-purple-900/10">
    <p class="text-gray-300 text-sm mb-3">Want to stay updated? Check back daily or subscribe to notifications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/world-rankings/" class="px-4 py-2 rounded-lg border border-gray-700 hover:border-blue-600 text-gray-300 hover:text-white text-sm transition-all">🏅 World Rankings →</a>
      <a href="/suggest/?title=Scrabble+News+Tip" class="px-4 py-2 rounded-lg border border-gray-700 hover:border-amber-600 text-gray-300 hover:text-white text-sm transition-all">💡 Submit News Tip →</a>
      <a href="/blog/tournament/" class="px-4 py-2 rounded-lg border border-gray-700 hover:border-purple-600 text-gray-300 hover:text-white text-sm transition-all">📚 Tournament Guides →</a>
    </div>
  </div>

</div>

<script is:inline>
(function() {
  // Category filter
  const buttons = document.querySelectorAll('.cat-btn');
  const items = document.querySelectorAll('.news-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-cat');
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-blue-600/20', 'text-blue-400', 'border-blue-500/40');
        b.classList.add('bg-gray-800/50', 'text-gray-400', 'border-gray-700');
      });
      btn.classList.add('active', 'bg-blue-600/20', 'text-blue-400', 'border-blue-500/40');
      btn.classList.remove('bg-gray-800/50', 'text-gray-400', 'border-gray-700');

      items.forEach(item => {
        if (cat === 'all' || item.getAttribute('data-category') === cat) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // Read More toggle
  document.querySelectorAll('.read-more-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('p');
      const preview = parent.querySelector('.news-preview');
      const full = parent.querySelector('.news-full');
      if (full.classList.contains('hidden')) {
        preview.classList.add('hidden');
        full.classList.remove('hidden');
        btn.textContent = 'Show Less';
      } else {
        preview.classList.remove('hidden');
        full.classList.add('hidden');
        btn.textContent = 'Read More';
      }
    });
  });
})();
</script>

</Layout>
