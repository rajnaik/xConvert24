  'twl-naspa-dictionary': ['Word Finder', 'Dictionary'],
  'how-scrabble-dictionaries-update': ['Dictionary'],
  'foreign-words-valid-in-scrabble': ['Word Finder', 'Dictionary'],
  // Strategy & Tactics
  'scrabble-comeback-strategies': ['Word Finder'],
  'scrabble-first-move-advantages': ['Word Finder'],
  'scrabble-premium-square-strategy': ['Word Finder'],
  'scrabble-double-triple-word-combos': ['Word Finder'],
  'scrabble-setup-plays-traps': ['Word Finder'],
  'lex-ai-scrabble-coach': ['Word Finder'],
  'scrabble-building-a-word-list-from-scratch': ['Word Finder'],
  'scrabble-200-must-know-words-intermediate': ['Word Finder'],
  'scrabble-reading-your-opponent': ['Word Finder'],
  'scrabble-board-geometry-explained': ['Word Finder'],
  'scrabble-complete-tile-strategy-masterclass': ['Word Finder'],
  'scrabble-anatomy-of-a-perfect-game': ['Word Finder'],
  'scrabble-when-to-exchange-tiles': ['Word Finder'],
  'scrabble-playing-the-endgame-like-a-pro': ['Word Finder'],
  'scrabble-highest-scoring-words-every-length': ['Word Finder'],
  'scrabble-hotspots-board-positions': ['Word Finder'],
  'scrabble-leave-analysis-guide': ['Word Finder'],
  'scrabble-bluffing-challenges': ['Word Finder', 'Dictionary'],
  // Skills & Techniques
  'scrabble-anagram-finding-techniques': ['Word Finder', 'Anagram'],
  'scrabble-mental-math-scoring': ['Word Finder'],
  'scrabble-tile-tracking-methods': ['Word Finder'],
