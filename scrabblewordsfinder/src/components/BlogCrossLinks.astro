const linked = (crossLinks[slug] || []).map(name => ({ name, ...tools[name] })).filter(c => c.href);
---

<div class="flex items-center gap-3 flex-wrap mb-2 not-prose">
  

  {linked.length > 0 && (
    <div class="flex items-center gap-1.5 shrink-0">
      {linked.map(tool => (
        <a href={tool.href} class="inline-flex items-center gap-1 px-2 py-1 bg-blue-900/20 border border-blue-800 rounded-lg text-xs text-blue-400 hover:bg-blue-900/40 transition-colors" title={tool.name}>
          <span aria-hidden="true">{tool.icon}</span>
          <span class="hidden sm:inline">{tool.name}</span>
        </a>
      ))}
    </div>
  )}
</div>
