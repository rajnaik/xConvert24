---
/**
 * DiamondHuntSlot — Embeddable diamond mine slot
 *
 * Drop this component on any page to show a claimable diamond.
 * The Layout/BlogLayout scripts handle visibility checks + claim logic.
 *
 * Props:
 *   id — the diamond_hunt row ID (from the admin panel)
 *
 * Usage:
 *   <DiamondHuntSlot id={1} />
 */
interface Props {
  id: number;
}

const { id } = Astro.props;
---

<div
  class="diamond-hunt-slot hidden my-4 mx-auto max-w-xs cursor-pointer select-none"
  data-diamond-id={id}
  role="button"
  tabindex="0"
  aria-label="Claim a hidden diamond"
>
  <div class="flex items-center justify-center gap-3 rounded-xl border border-purple-700/50 bg-gradient-to-r from-purple-950/40 to-blue-950/40 px-5 py-3 shadow-lg shadow-purple-900/20 hover:shadow-purple-700/30 hover:border-purple-500/60 transition-all group">
    <span class="text-2xl group-hover:scale-110 transition-transform">💎</span>
    <div class="text-left">
      <p class="text-sm font-semibold text-purple-200 group-hover:text-white transition-colors">Hidden Diamond!</p>
      <p class="text-xs text-gray-400"><span class="diamond-remaining">?</span> remaining — click to claim</p>
    </div>
    <svg class="w-5 h-5 text-purple-400 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</div>
