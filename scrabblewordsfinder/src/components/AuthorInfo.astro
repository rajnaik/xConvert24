---
/**
 * AuthorInfo — displays author, updated date, reviewer, sources, and reading time
 * at the bottom of blog articles.
 *
 * Props:
 *   updated: string — date in "Month Day, Year" format (e.g., "June 28, 2026")
 *   readingTime: string — e.g., "8 min read" (optional, auto-calculated if omitted)
 */

interface Props {
  updated?: string;
  readingTime?: string;
}

const { updated = 'July 2026', readingTime } = Astro.props;
---

<aside class="not-prose mt-10 pt-6 border-t border-gray-700">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-gray-400">
    <div class="flex items-start gap-2">
      <span class="text-blue-400 font-semibold shrink-0">Author:</span>
      <a href="/about/" class="text-gray-300 hover:text-blue-400 transition-colors">Raj Naik</a>
    </div>
    <div class="flex items-start gap-2">
      <span class="text-green-400 font-semibold shrink-0">Updated:</span>
      <span class="text-gray-300">{updated}</span>
    </div>
    <div class="flex items-start gap-2">
      <span class="text-purple-400 font-semibold shrink-0">Reviewed:</span>
      <span class="text-gray-300">ScrabbleWordsFinder Editorial</span>
    </div>
    <div class="flex items-start gap-2">
      <span class="text-amber-400 font-semibold shrink-0">Sources:</span>
      <span class="text-gray-300">Books, Internet Articles, Videos & personal experience</span>
    </div>
    {readingTime && (
      <div class="flex items-start gap-2">
        <span class="text-cyan-400 font-semibold shrink-0">Reading time:</span>
        <span class="text-gray-300">{readingTime}</span>
      </div>
    )}
  </div>
</aside>
