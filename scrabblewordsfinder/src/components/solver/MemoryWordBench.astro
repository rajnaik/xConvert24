<!-- Memory WordBench -->
<div class="mt-6 pt-4 border-t border-purple-800/40">
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-semibold text-white flex items-center gap-2">
      <span aria-hidden="true">👑</span> Memory WordBench
    </h2>
    <div class="flex items-center gap-2">
      <button id="fetch-meanings-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-green-400 hover:bg-green-900/20 transition-colors" title="Fetch meanings for all words" aria-label="Fetch meanings for all words">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      </button>
      <button id="flashcard-mode-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-purple-400 hover:bg-purple-900/20 transition-colors" title="Flash Cards Mode" aria-label="Flash Cards Mode">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </button>
      <button id="mwb-add-to-solver-btn" type="button" class="p-1 rounded-full border-2 border-green-500/50 bg-green-900/20 hover:bg-green-600/30 hover:border-green-400 text-green-300 text-xs font-bold transition-all w-6 h-6 flex items-center justify-center" title="Add current word to Solver" aria-label="Add to Solver">+</button>
      <a href="/workbench-data/" class="p-1.5 rounded-lg text-gray-400 hover:text-purple-400 hover:bg-purple-900/20 transition-colors" title="View all data" aria-label="View all data">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 2 3 8 3s8-1 8-3V7M4 7c0 2 2 3 8 3s8-1 8-3M4 7c0-2 2-3 8-3s8 1 8 3M4 12c0 2 2 3 8 3s8-1 8-3"/></svg>
      </a>
      <button id="download-saved-btn" type="button" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-400 hover:bg-blue-900/20 transition-colors opacity-30" title="Download memory workbench" aria-label="Download memory workbench">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3"/></svg>
      </button>
      <span id="saved-count" class="text-xs text-gray-400">0</span>
    </div>
  </div>
  <p class="text-xs text-gray-500 mb-3">Click any word in results or reference panels to save it here.</p>
  <!-- Auto-play & Filter controls -->
  <div id="mwb-controls" class="hidden mb-3">
    <div class="flex items-center gap-3">
      <label class="flex items-center gap-1.5 cursor-pointer select-none">
        <input type="checkbox" id="mwb-real-only" class="w-3.5 h-3.5 rounded border-gray-600 bg-gray-800 text-purple-500 focus:ring-purple-500/30 focus:ring-offset-0" checked />
        <span class="text-[10px] text-gray-400">Meaningful words only</span>
      </label>
      <select id="mwb-speed" class="hidden h-5 px-1 bg-gray-800 border border-gray-700 rounded text-[10px] text-gray-300">
        <option value="5" selected>5s</option>
      </select>
      <div id="mwb-speed-wrap" class="hidden flex items-center gap-2">
        <input type="range" id="mwb-speed-slider" min="1" max="30" value="5" class="w-20 h-1 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500" />
        <span id="mwb-speed-label" class="text-[10px] text-gray-400 font-mono w-6">5s</span>
      </div>
    </div>
  </div>
  <input type="checkbox" id="mwb-autoplay" class="hidden" />
  <button id="mwb-autoplay-btn" class="hidden"></button>
  <div id="saved-words-list" class="max-h-[400px] overflow-y-auto">
    <p id="saved-empty" class="text-sm text-gray-500 text-center py-4 italic">No memory workbench yet. Click any word to collect it.</p>
  </div>
</div>
