<!-- Tile Bag Probability (compact) -->
<div id="section-probability" class="mt-6 pt-4 border-t border-purple-800/40">
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm font-semibold text-white flex items-center gap-1.5"><span aria-hidden="true">🎲</span> Tile Bag</span>
    <div class="flex items-center gap-2">
      <button id="prob-reset-btn" type="button" class="px-2 py-1 rounded bg-gray-800 border border-gray-700 text-xs font-medium text-gray-400 hover:text-rose-400 hover:border-rose-700 transition-colors">↺ Reset</button>
      <button id="prob-popup-btn" type="button" class="px-2 py-1 rounded bg-gray-800 border border-gray-700 text-xs font-medium text-gray-400 hover:text-blue-400 hover:border-blue-700 transition-colors">Draw %</button>
    </div>
  </div>
  <div class="flex items-center gap-5 text-xs">
    <div class="flex items-center gap-1.5">
      <label for="tiles-in-bag" class="sr-only">Tiles in bag</label>
      <span class="text-gray-400 font-medium">Bag:</span>
      <input id="tiles-in-bag" type="number" min="0" max="100" value="100" class="w-[55px] text-center text-xs font-bold text-white bg-gray-800 border border-gray-700 rounded px-1.5 py-1 focus:outline-none focus:border-blue-500" />
    </div>
    <div class="flex items-center gap-1.5">
      <span class="text-gray-400 font-medium">Rack:</span>
      <span id="prob-your-rack" class="text-xs font-bold text-blue-400">0</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="text-gray-400 font-medium">Played:</span>
      <input id="tiles-played" type="number" min="0" max="86" value="0" aria-label="Tiles played" class="w-[55px] text-center text-xs font-bold text-rose-400 bg-gray-800 border border-gray-700 rounded px-1 py-0.5 focus:outline-none focus:border-blue-500" />
    </div>
  </div>
  <div id="prob-popup" class="hidden mt-3 pt-2 border-t border-gray-800">
    <div id="prob-draw-chances" class="text-xs text-gray-500 italic">Enter your rack letters to see draw probabilities</div>
  </div>
</div>
