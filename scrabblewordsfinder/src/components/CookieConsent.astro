---
/**
 * Cookie Consent Banner — SWF Edition (dark theme, blue accent)
 */
---

<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 hidden" role="dialog" aria-label="Cookie consent">
  <div class="bg-gray-900 border-t border-gray-700 shadow-2xl">
    <div class="max-w-5xl mx-auto px-4 py-5 lg:px-8">
      <div id="banner-main">
        <div class="flex flex-col lg:flex-row lg:items-center gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-lg">🍪</span>
              <h2 class="text-sm font-semibold text-white">We value your privacy</h2>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">We use cookies to enhance your experience and analyse site traffic. <a href="/privacy/" class="text-blue-400 hover:underline">Learn more</a></p>
          </div>
          <div class="flex flex-wrap items-center gap-2 shrink-0">
            <button id="cookie-manage-btn" class="px-4 py-2.5 text-sm font-medium text-gray-300 border border-gray-600 rounded-lg hover:bg-gray-800 transition-colors">Manage</button>
            <button id="cookie-reject-btn" class="px-4 py-2.5 text-sm font-medium text-gray-300 border border-gray-600 rounded-lg hover:bg-gray-800 transition-colors">Reject All</button>
            <button id="cookie-accept-btn" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-500 transition-colors">Accept All</button>
          </div>
        </div>
      </div>
      <div id="banner-preferences" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-white">Cookie Preferences</h2>
          <button id="cookie-back-btn" class="text-xs text-gray-400 hover:text-gray-200">← Back</button>
        </div>
        <div class="space-y-3 mb-5">
          <div class="flex items-center justify-between p-3 bg-gray-800 rounded-lg border border-gray-700">
            <div><div class="text-sm font-medium text-white">Essential</div><div class="text-xs text-gray-400 mt-0.5">Required for the site to function.</div></div>
            <span class="px-2 py-0.5 text-xs font-medium bg-green-900/30 text-green-400 rounded-full">Always on</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-gray-800 rounded-lg border border-gray-700">
            <div><div class="text-sm font-medium text-white">Analytics</div><div class="text-xs text-gray-400 mt-0.5">Understand how visitors use the site.</div></div>
            <label class="relative inline-flex items-center cursor-pointer"><input type="checkbox" id="consent-analytics" class="sr-only peer" checked /><div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-500"></div></label>
          </div>
          <div class="flex items-center justify-between p-3 bg-gray-800 rounded-lg border border-gray-700">
            <div><div class="text-sm font-medium text-white">Marketing</div><div class="text-xs text-gray-400 mt-0.5">Deliver relevant ads and track campaigns.</div></div>
            <label class="relative inline-flex items-center cursor-pointer"><input type="checkbox" id="consent-marketing" class="sr-only peer" /><div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-500"></div></label>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-3 mb-3">⚠️ Rejecting cookies means saved words, achievements, and theme preferences won't persist between visits. The solver still works fully.</p>
        <div class="flex justify-end"><button id="cookie-save-btn" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-500 transition-colors">Save</button></div>
      </div>
    </div>
  </div>
</div>
<button id="cookie-settings-trigger" class="fixed bottom-4 left-4 z-40 hidden w-10 h-10 bg-gray-900 border border-gray-700 rounded-full shadow-lg items-center justify-center text-lg hover:scale-110 transition-transform" aria-label="Cookie settings">🍪</button>

<script is:inline>
(function(){
  var CN='swf_consent',CD=30;
  function set(v){var d=new Date();d.setTime(d.getTime()+CD*864e5);document.cookie=CN+'='+encodeURIComponent(JSON.stringify(v))+';expires='+d.toUTCString()+';path=/;SameSite=Lax';}
  function get(){var m=document.cookie.match(new RegExp('(^| )'+CN+'=([^;]+)'));if(m){try{return JSON.parse(decodeURIComponent(m[2]));}catch(e){}}return null;}
  function apply(p){if(typeof gtag==='function'){gtag('consent','update',{'analytics_storage':p.analytics?'granted':'denied','ad_storage':p.marketing?'granted':'denied','ad_user_data':p.marketing?'granted':'denied','ad_personalization':p.marketing?'granted':'denied'});}}
  var b=document.getElementById('cookie-banner'),mp=document.getElementById('banner-main'),pp=document.getElementById('banner-preferences');
  var t=document.getElementById('cookie-settings-trigger'),ac=document.getElementById('consent-analytics'),mc=document.getElementById('consent-marketing');
  function show(){b.classList.remove('hidden');mp.classList.remove('hidden');pp.classList.add('hidden');t.classList.add('hidden');}
  function hide(){b.classList.add('hidden');t.classList.remove('hidden');t.style.display='flex';}
  document.getElementById('cookie-accept-btn').addEventListener('click',function(){var p={analytics:true,marketing:true,timestamp:Date.now()};set(p);apply(p);hide();});
  document.getElementById('cookie-reject-btn').addEventListener('click',function(){var p={analytics:false,marketing:false,timestamp:Date.now()};set(p);apply(p);hide();});
  document.getElementById('cookie-manage-btn').addEventListener('click',function(){mp.classList.add('hidden');pp.classList.remove('hidden');});
  document.getElementById('cookie-back-btn').addEventListener('click',function(){pp.classList.add('hidden');mp.classList.remove('hidden');});
  document.getElementById('cookie-save-btn').addEventListener('click',function(){var p={analytics:ac.checked,marketing:mc.checked,timestamp:Date.now()};set(p);apply(p);hide();});
  t.addEventListener('click',show);
  var ex=get();
  if(ex){apply(ex);ac.checked=!!ex.analytics;mc.checked=!!ex.marketing;t.classList.remove('hidden');t.style.display='flex';}else{show();}
})();
</script>
