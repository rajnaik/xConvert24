---
interface Props {
  showSectionLinks?: boolean;
  variant?: 'main' | 'blog';
}

const { showSectionLinks = false, variant = 'main' } = Astro.props;
const bannerIdPrefix = variant === 'blog' ? 'blog-banner' : 'hero-banner';
---

<header class="mx-auto max-w-6xl px-4 sm:px-6 pt-[5px] pb-0 -mb-10">
  <!-- Desktop: 3-row grid layout -->
  <div class="hidden sm:grid sm:grid-cols-[auto_1fr] sm:grid-rows-3 gap-x-3 gap-y-0">
    <a href="/" class="sm:row-span-3 flex items-start justify-start">
      <img id="site-logo" src="/logo-options/option-3.svg" alt="ScrabbleWordsFinder" class="h-[188px] w-[188px] rounded-lg" />
    </a>
    <div class="flex items-center gap-3 whitespace-nowrap overflow-x-auto text-sm justify-end">
      <a href="/blog/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">📝 Blog</a>
      <a href="/guide/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">📘 Guide</a>
      <a href="/about/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">ℹ️ About</a>
      <a href="/privacy/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🔒 Privacy</a>
      <a href="/contact/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">✉️ Contact</a>
      <a href="/suggest/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">💡 Suggest</a>
      {variant === 'main' && <a href="/faq/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">❓ FAQ</a>}
      <a href="/activities/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🎯 Activities</a>
      <a href="/roadmap/" class="text-gray-400 hover:text-blue-400 transition-colors shrink-0">🗺️ Roadmap</a>
      <button id="theme-toggle" class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full border border-white/50 hover:border-purple-400 transition-colors" title="Toggle dark/light mode"><svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg></button>
      <button id="push-bell" class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full border border-white/50 hover:border-amber-400 transition-colors relative" title="Get daily Word of the Day notifications"><svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg><span id="push-bell-dot" class="hidden absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-amber-400"></span></button>
      {variant === 'main' && <a href="/settings/" class="text-gray-400 hover:text-purple-400 transition-colors shrink-0">⚙️ Settings</a>}
    </div>
    <a id={`${bannerIdPrefix}-link`} href="/" class="block cursor-pointer self-start -mt-[15px]">
      <img id={`${bannerIdPrefix}-img`} src="/banner-options/banner-1.svg" alt="Scrabble Word Finder" class="w-full h-auto max-h-[80px] object-cover rounded-lg" width="1200" height="80" fetchpriority="high" />
    </a>
    <!-- Row 3: Section links + icons + search -->
    <div class="flex flex-nowrap items-center gap-1.5 overflow-x-auto" style="margin-top:-25px;margin-bottom:8px;">
      {showSectionLinks && <>
      <a href="#section-probability" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🎲</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Probability</span></a>
      <a href="#section-rack-leave" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🧮</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Rack Leave</span></a>
      <a href="#section-best-opening" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🚀</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Openers</span></a>
      <a href="#section-two-letter" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xs font-bold text-blue-400">2L</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Two-Letter Words</span></a>
      <a href="#section-rare-letters" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">💎</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Rare Letters</span></a>
      <a href="#section-three-letter" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xs font-bold text-blue-400">3L</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Top 3-Letter</span></a>
      <a href="#q-without-u" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🅀</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Q Without U</span></a>
      <a href="#section-tile-scores" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🔢</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Tile Scores</span></a>
      </>}
      <div class="ml-auto shrink-0 flex items-center gap-1.5">
        {!showSectionLinks && <a href="/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🔍</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Solver</span></a>}
        {!showSectionLinks && <a href="/favourites/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-red-900/30 transition-colors"><span class="text-xl">❤️</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Favourites</span></a>}
        {!showSectionLinks && <a href="/activities/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-blue-900/30 transition-colors"><span class="text-xl">🎯</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Activities</span></a>}
        {!showSectionLinks && <a href="/leaderboard/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-amber-900/30 transition-colors"><span class="text-xl">🏆</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Leaderboard</span></a>}
        <a href="/cheat-sheets/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-emerald-900/30 transition-colors"><span class="text-xl">🗂️</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Cheat Sheets</span></a>
        <a href="/blog/roadmap-to-being-a-pro-player/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-yellow-900/30 transition-colors"><span class="text-xl">🎓</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Pro Player</span></a>
        <a href="/contact/?subject=bug" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-red-900/30 transition-colors"><span class="text-xl">🐛</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Report Bug</span></a>
        <a href="/suggest/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-purple-900/30 transition-colors"><span class="text-xl">💡</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Suggest</span></a>
        <a href="/chat/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-cyan-900/30 transition-colors"><img src="/lex-avatar.webp" alt="Lex AI" width="24" height="24" class="rounded-full" /><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Lex AI</span></a>
        <a href="/blog/useful-links/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-green-900/30 transition-colors"><span class="text-xl">🔗</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Useful Links</span></a>
        <a href="/achievements/" class="relative group flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800 hover:bg-amber-900/30 transition-colors"><span class="text-xl">🏅</span><span class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 px-2 py-1 rounded bg-gray-900 border border-gray-700 text-xs text-gray-200 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50">Achievements</span></a>
        <div class="w-3"></div>
        <div class="relative">
          <input id="dict-search" type="text" placeholder="Search pages, blog..." class="h-7 w-36 pl-7 pr-2 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" autocomplete="off" />
          <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <a id="search-find-btn" href="/chat/" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-blue-600/20 border border-blue-500/30 text-xs font-medium text-blue-400 hover:bg-blue-600/40 hover:text-blue-300 transition-colors cursor-pointer">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          <span>Find</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile: vertical stack layout -->
  <div class="sm:hidden space-y-2">
    <div class="flex items-start gap-3">
      <a href="/" class="shrink-0">
        <img id="site-logo-mobile" src="/logo-options/option-3.svg" alt="ScrabbleWordsFinder" class="h-14 w-14 rounded-lg" />
      </a>
      <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-2 text-xs pt-1">
        <a href="/blog/" class="text-gray-400 hover:text-blue-400 transition-colors">📝 Blog</a>
        <a href="/guide/" class="text-gray-400 hover:text-blue-400 transition-colors">📘 Guide</a>
        <a href="/about/" class="text-gray-400 hover:text-blue-400 transition-colors">ℹ️ About</a>
        <a href="/contact/" class="text-gray-400 hover:text-blue-400 transition-colors">✉️ Contact</a>
        <a href="/privacy/" class="text-gray-400 hover:text-blue-400 transition-colors">🔒 Privacy</a>
        <a href="/suggest/" class="text-gray-400 hover:text-blue-400 transition-colors">💡 Suggest</a>
        {variant === 'main' && <a href="/faq/" class="text-gray-400 hover:text-blue-400 transition-colors">❓ FAQ</a>}
        <a href="/activities/" class="text-gray-400 hover:text-blue-400 transition-colors">🎯 Activities</a>
        <a href="/roadmap/" class="text-gray-400 hover:text-blue-400 transition-colors">🗺️ Roadmap</a>
        <button id="theme-toggle-mobile" class="w-6 h-6 flex items-center justify-center rounded-full border border-white/50 hover:border-purple-400 transition-colors" title="Toggle dark/light mode"><svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg></button>
      </div>
    </div>
    <!-- Banner -->
    <a id={`${bannerIdPrefix}-link-mobile`} href="/" class="block">
      <img id={`${bannerIdPrefix}-img-mobile`} src="/banner-options/banner-1.svg" alt="Scrabble Word Finder" class="w-full h-auto max-h-[60px] object-cover rounded-lg" width="800" height="60" fetchpriority="high" />
    </a>
    <!-- Section link icons -->
    <div class="flex flex-wrap items-center gap-1.5">
      {showSectionLinks && <>
      <a href="#section-probability" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Probability"><span class="text-lg">🎲</span></a>
      <a href="#section-rack-leave" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Rack Leave"><span class="text-lg">🧮</span></a>
      <a href="#section-best-opening" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Openers"><span class="text-lg">🚀</span></a>
      <a href="#section-two-letter" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Two-Letter"><span class="text-xs font-bold text-blue-400">2L</span></a>
      <a href="#section-rare-letters" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Rare Letters"><span class="text-lg">💎</span></a>
      <a href="#section-three-letter" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Top 3-Letter"><span class="text-xs font-bold text-blue-400">3L</span></a>
      <a href="#q-without-u" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Q Without U"><span class="text-lg">🅀</span></a>
      <a href="#section-tile-scores" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Tile Scores"><span class="text-lg">🔢</span></a>
      </>}
      {!showSectionLinks && <a href="/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Solver"><span class="text-lg">🔍</span></a>}
      {!showSectionLinks && <a href="/favourites/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Favourites"><span class="text-lg">❤️</span></a>}
      {!showSectionLinks && <a href="/activities/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Activities"><span class="text-lg">🎯</span></a>}
      {!showSectionLinks && <a href="/leaderboard/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Leaderboard"><span class="text-lg">🏆</span></a>}
      <a href="/cheat-sheets/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Cheat Sheets"><span class="text-lg">🗂️</span></a>
      <a href="/contact/?subject=bug" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Bug"><span class="text-lg">🐛</span></a>
      <a href="/suggest/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Suggest"><span class="text-lg">💡</span></a>
      <a href="/chat/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Lex AI"><img src="/lex-avatar-32.png" alt="Lex AI" width="22" height="22" class="rounded-full" /></a>
      <a href="/blog/useful-links/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Useful Links"><span class="text-lg">🔗</span></a>
      <a href="/achievements/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Achievements"><span class="text-lg">🏅</span></a>
      {variant === 'main' && <a href="/settings/" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-800" title="Settings"><span class="text-lg">⚙️</span></a>}
    </div>
    <!-- Search bar -->
    <div class="flex items-center gap-2">
      <div class="relative flex-1">
        <input id="dict-search-mobile" type="text" placeholder="Search words, blog..." class="h-8 w-full pl-7 pr-2 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-400 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="off" />
        <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      <a id="search-find-btn-mobile" href="/chat/" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-blue-600/20 border border-blue-500/30 text-xs font-medium text-blue-400">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <span>Find</span>
      </a>
    </div>
    <div class="border-t border-purple-800/50 -mt-1"></div>
  </div>
</header>
