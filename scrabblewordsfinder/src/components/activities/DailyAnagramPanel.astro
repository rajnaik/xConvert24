<script is:inline>
(function() {
  // ── Daily Anagram Puzzle ──
  (function loadDailyAnagram() {
    var S = window.__swfStore;
    var uid = S.getRaw('swf-uid') || '';
    var ANAGRAM_STATE_KEY = 'swf-anagram-' + new Date().toISOString().split('T')[0];
    var DA_CACHE_KEY = 'swf-da-tile';
    var anagramState = { scrambled: '', hint: '', wordLength: 0, guesses: [], gameOver: false, solved: false, answer: '' };
    var anagramStartTime = 0; // timestamp (ms) when puzzle was shown to user
    var anagramStartTime = 0; // timestamp (ms) when puzzle first rendered for this session

    // Load streak
    var streakData = JSON.parse(S.getRaw('swf-anagram-streak') || '{"count":0,"lastDate":""}');
    if (streakData.count > 0) {
      var streakEl = document.getElementById('anagram-streak');
      streakEl.textContent = '🔥 ' + streakData.count;
      streakEl.classList.remove('hidden');
    }

    // Show history button if user has played at least 1 game
    if (uid) {
      fetch('/api/anagram-history/?count=true&user_id=' + encodeURIComponent(uid))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.count >= 1) {
            document.getElementById('anagram-history-btn').classList.remove('hidden');
          }
        }).catch(function() {});
    }

    // Restore local state if exists
    var localState = S.getRaw(ANAGRAM_STATE_KEY);
    if (localState) {
      try { anagramState = JSON.parse(localState); } catch(e) {}
    }

    // Cache-first: try localStorage, fallback to API
    var cached = S.getIfValid(DA_CACHE_KEY);
    if (cached) {
      handleAnagramData(cached);
    } else {
      fetchAnagram();
    }

    function fetchAnagram() {
      fetch('/api/daily-anagram/' + (uid ? '?user_id=' + encodeURIComponent(uid) : ''))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) {
            document.getElementById('anagram-loading').innerHTML = '<p class="text-xs text-gray-400">No puzzle available today. Check back tomorrow!</p>';
            return;
          }
          // Cache tile data with server-provided expiry
          if (data.expiresAt) {
            S.setWithExpiry(DA_CACHE_KEY, data, data.expiresAt);
          }
          handleAnagramData(data);
        }).catch(function() {
          document.getElementById('anagram-loading').innerHTML = '<p class="text-xs text-red-400">Failed to load puzzle</p>';
        });
    }

    function handleAnagramData(data) {
      if (data.error) {
        document.getElementById('anagram-loading').innerHTML = '<p class="text-xs text-gray-400">No puzzle available today. Check back tomorrow!</p>';
        return;
      }

      document.getElementById('anagram-loading').classList.add('hidden');
      document.getElementById('anagram-content').classList.remove('hidden');

      anagramState.scrambled = data.scrambled;
      anagramState.hint = data.hint;
      anagramState.wordLength = data.word_length;

      // If server says user already played, restore
      if (data.userResult) {
        var ur = data.userResult;
        anagramState.guesses = JSON.parse(ur.guesses || '[]');
        anagramState.solved = ur.solved === 1;
        anagramState.gameOver = ur.solved === 1 || anagramState.guesses.length >= 5;
        if (data.answer) anagramState.answer = data.answer;
      }

      renderAnagramTiles();
      renderAnagramGuesses();
      updateAnagramRemaining();

      // Start timer only if game is still in progress
      if (!anagramState.gameOver && !anagramState.solved) {
        anagramStartTime = Date.now();
      }

      if (anagramState.gameOver || anagramState.solved) {
        showAnagramResult(data.answer || anagramState.answer);
      }

      // Hint button
      document.getElementById('anagram-hint-btn').addEventListener('click', function() {
        document.getElementById('anagram-hint-text').textContent = anagramState.hint;
        document.getElementById('anagram-hint-text').classList.remove('hidden');
        this.classList.add('hidden');
      });

      // Stats display
      if (data.stats && data.stats.players > 0) {
        var pct = data.stats.solvers ? Math.round((data.stats.solvers / data.stats.players) * 100) : 0;
        var statsText = data.stats.players + ' played · ' + pct + '% solved';
        var remEl = document.getElementById('anagram-remaining');
        if (remEl.textContent) remEl.textContent += ' · ' + statsText;
      }
    }

    function renderAnagramTiles() {
      // Set dynamic data-track so the click tracker logs Guess-<SCRAMBLED>
      document.getElementById('anagram-submit').setAttribute('data-track', 'Guess-' + anagramState.scrambled);
      var tiles = anagramState.scrambled.split('').map(function(letter) {
        return '<div class="w-11 h-14 rounded-lg flex flex-col items-center justify-center select-none" style="background:linear-gradient(145deg,#f0d0d0,#e8b8b8);box-shadow:inset 0 2px 0 rgba(255,255,255,0.4),inset 0 -3px 0 rgba(0,0,0,0.08),0 4px 8px rgba(0,0,0,0.2);border:2px solid #c88888;">' +
          '<span class="text-lg font-black text-gray-800">' + letter + '</span>' +
        '</div>';
      }).join('');
      document.getElementById('anagram-tiles').innerHTML = tiles;
    }

    function renderAnagramGuesses() {
      var container = document.getElementById('anagram-guesses');
      if (anagramState.guesses.length === 0) { container.innerHTML = ''; return; }

      container.innerHTML = anagramState.guesses.map(function(g) {
        var cells = g.guess.split('').map(function(letter, i) {
          var fb = g.feedback[i] || 'gray';
          var bgClass = fb === 'green' ? 'bg-green-600 border-green-500' :
                        fb === 'yellow' ? 'bg-amber-600 border-amber-500' :
                        'bg-gray-700 border-gray-600';
          return '<div class="w-9 h-9 rounded flex items-center justify-center text-sm font-bold text-white border ' + bgClass + '">' + letter + '</div>';
        }).join('');
        return '<div class="flex gap-1 justify-center">' + cells + '</div>';
      }).join('');
    }

    function updateAnagramRemaining() {
      var remaining = 5 - anagramState.guesses.length;
      var el = document.getElementById('anagram-remaining');
      if (anagramState.gameOver || anagramState.solved) {
        el.textContent = '';
      } else {
        el.textContent = remaining + ' guess' + (remaining === 1 ? '' : 'es') + ' remaining';
      }
    }

    function showAnagramResult(answer) {
      document.getElementById('anagram-input-row').classList.add('hidden');
      document.getElementById('anagram-result').classList.remove('hidden');

      var emoji, text;
      if (anagramState.solved) {
        var attempts = anagramState.guesses.length;
        emoji = attempts === 1 ? '🏆' : attempts <= 3 ? '🎉' : '✅';
        text = attempts === 1 ? 'Genius! First try!' : 'Solved in ' + attempts + '/5 guesses!';
        // Update streak
        var today = new Date().toISOString().split('T')[0];
        if (streakData.lastDate !== today) {
          var yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
          if (streakData.lastDate === yesterday) { streakData.count++; }
          else { streakData.count = 1; }
          streakData.lastDate = today;
          S.setRaw('swf-anagram-streak', JSON.stringify(streakData));
          var streakEl = document.getElementById('anagram-streak');
          streakEl.textContent = '🔥 ' + streakData.count;
          streakEl.classList.remove('hidden');
        }
      } else {
        emoji = '😔';
        text = 'Not this time!';
      }

      document.getElementById('anagram-result-emoji').textContent = emoji;
      document.getElementById('anagram-result-text').textContent = text;
      document.getElementById('anagram-result-word').textContent = answer || '???';
      document.getElementById('anagram-result-stats').textContent = anagramState.guesses.length + '/5 attempts used';
    }

    // Submit guess
    function submitGuess() {
      var input = document.getElementById('anagram-input');
      var guess = input.value.trim().toUpperCase();
      if (!guess || guess.length !== anagramState.wordLength) {
        input.style.borderColor = '#ef4444';
        setTimeout(function() { input.style.borderColor = ''; }, 500);
        return;
      }
      if (anagramState.gameOver || anagramState.solved) return;

      input.disabled = true;
      document.getElementById('anagram-submit').disabled = true;

      fetch('/api/daily-anagram/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, guess: guess, time_taken: anagramStartTime ? Math.round((Date.now() - anagramStartTime) / 1000) : 0 })
      }).then(function(r) { return r.json(); })
      .then(function(data) {
        input.disabled = false;
        document.getElementById('anagram-submit').disabled = false;
        input.value = '';

        if (data.already_solved) {
          anagramState.solved = true;
          anagramState.gameOver = true;
          anagramState.answer = data.answer;
          showAnagramResult(data.answer);
          return;
        }

        anagramState.guesses = data.guesses || anagramState.guesses;
        anagramState.solved = data.correct;
        anagramState.gameOver = data.correct || data.game_over;
        if (data.answer) anagramState.answer = data.answer;

        S.setRaw(ANAGRAM_STATE_KEY, JSON.stringify(anagramState));
        // Invalidate tile cache so next visit fetches fresh stats
        S.removeItem(DA_CACHE_KEY);
        renderAnagramGuesses();
        updateAnagramRemaining();
        // Award anagram star on first guess
        if (anagramState.guesses.length === 1) { window.__awardStar && window.__awardStar('anagram'); }

        if (anagramState.gameOver || anagramState.solved) {
          showAnagramResult(data.answer);
        } else {
          input.focus();
        }
      }).catch(function() {
        input.disabled = false;
        document.getElementById('anagram-submit').disabled = false;
      });
    }

    document.getElementById('anagram-submit').addEventListener('click', submitGuess);
    document.getElementById('anagram-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') submitGuess();
    });

    // Share button
    document.getElementById('anagram-share-btn').addEventListener('click', function() {
      var today = new Date().toISOString().split('T')[0];
      var emojis = anagramState.guesses.map(function(g) {
        return g.feedback.map(function(f) {
          return f === 'green' ? '🟩' : f === 'yellow' ? '🟨' : '⬛';
        }).join('');
      }).join('\n');
      var text = '🔤 SWF Daily Anagram ' + today + '\n' +
        (anagramState.solved ? anagramState.guesses.length + '/5' : 'X/5') + '\n\n' +
        emojis + '\n\nhttps://www.scrabblewordsfinder.com/activities/';
      navigator.clipboard.writeText(text).then(function() {
        document.getElementById('anagram-share-btn').textContent = '✓ Copied!';
        setTimeout(function() { document.getElementById('anagram-share-btn').textContent = '📋 Share'; }, 2000);
      });
    });

    // Add to WordBench
    document.getElementById('anagram-add-btn').addEventListener('click', function() {
      var word = anagramState.answer;
      if (!word) return;
      var saved = JSON.parse(S.getRaw('scbAchievements') || '[]');
      if (saved.find(function(s) { return s.word === word; })) { this.textContent = 'Already saved ✓'; return; }
      saved.push({ word: word, score: 0, category: 'anagram', meaning: anagramState.hint || '', dateAdded: new Date().toISOString() });
      S.setRaw('scbAchievements', JSON.stringify(saved));
      this.textContent = 'Added ✓';
      setTimeout(function() { document.getElementById('anagram-add-btn').textContent = '+ WordBench'; }, 2000);
    });

    // Countdown
    (function anagramCountdown() {
      var el = document.getElementById('anagram-countdown');
      function update() {
        var now = new Date();
        var tomorrow = new Date(now);
        tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
        tomorrow.setUTCHours(0, 0, 0, 0);
        var diff = tomorrow - now;
        if (diff <= 0) { el.textContent = 'New puzzle!'; return; }
        var h = Math.floor(diff / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.textContent = 'Next puzzle in ' + h + 'h ' + (m < 10 ? '0' : '') + m + 'm ' + (s < 10 ? '0' : '') + s + 's';
      }
      update();
      setInterval(update, 1000);
    })();

    // ── Lex Anagram Coach Modal ──
    (function lexAnagramCoach() {
      var modal = document.getElementById('lex-anagram-modal');
      var backdrop = document.getElementById('lex-anagram-backdrop');
      var closeBtn = document.getElementById('lex-anagram-close');
      var loadingEl = document.getElementById('lex-anagram-loading');
      var resultEl = document.getElementById('lex-anagram-result');
      var errorEl = document.getElementById('lex-anagram-error');
      var statsBar = document.getElementById('lex-stats-bar');
      var analysisText = document.getElementById('lex-analysis-text');
      var lexBtn = document.getElementById('LexAnagram');

      function openModal() {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        // Reset state
        loadingEl.classList.remove('hidden');
        resultEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        // Fetch coaching
        fetchCoaching();
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      function fetchCoaching() {
        var userId = S.getRaw('swf-uid') || '';
        fetch('/api/lex-anagram-coach/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          loadingEl.classList.add('hidden');
          if (data.error) {
            errorEl.classList.remove('hidden');
            return;
          }
          resultEl.classList.remove('hidden');

          // Show stats bar if history exists
          if (data.hasHistory && data.stats) {
            statsBar.classList.remove('hidden');
            document.getElementById('lex-stat-games').textContent = data.stats.totalGames;
            document.getElementById('lex-stat-rate').textContent = data.stats.solveRate + '%';
            document.getElementById('lex-stat-streak').textContent = data.stats.streak;
          } else {
            statsBar.classList.add('hidden');
          }

          analysisText.textContent = data.analysis || 'No analysis available.';
        })
        .catch(function() {
          loadingEl.classList.add('hidden');
          errorEl.classList.remove('hidden');
        });
      }

      // Event listeners
      lexBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);

      // Close on Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });
    })();
  })();

})();
</script>
