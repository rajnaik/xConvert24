      <!-- Panel 6: 60-Second Word Finder -->
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-6">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2"><span>⏱️</span> 60-Second Word Finder <span class="star-indicator ml-auto text-sm opacity-40 cursor-help" data-game="sixty" title="⭐ Earn star: Play 1 round">⭐</span><span class="star-tick hidden text-green-400 text-sm font-bold" data-game="sixty">✅</span></h2>
          <span id="sixty-pb-badge" class="px-2 py-0.5 rounded-full bg-amber-900/30 border border-amber-500/30 text-xs text-amber-300 font-mono">PB: —</span>
        </div>
        <p class="text-xs text-gray-500 mb-4">Find as many words as you can from 7 tiles in 60 seconds!</p>

        <!-- Setup state -->
        <div id="sp-setup" class="text-center py-4">
          <div class="flex items-center justify-center gap-3 mb-4">
            <label class="text-xs text-gray-400">Dict:</label>
            <select id="sp-dict" class="h-7 px-2 bg-gray-800 border border-gray-700 rounded text-xs text-white">
              <option value="sowpods">SOWPODS</option>
              <option value="twl">TWL</option>
            </select>
          </div>
          <button id="sp-start" class="px-6 py-2.5 rounded-xl bg-green-600 text-white font-bold text-sm hover:bg-green-500 transition-colors shadow-lg shadow-green-900/30">▶ Start</button>
          <p id="sp-dict-status" class="text-[10px] text-gray-600 mt-2">Loading dictionary...</p>
        </div>

        <!-- Active state -->
        <div id="sp-active" class="hidden">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <span id="sp-timer" class="text-2xl font-black text-green-400 font-mono tabular-nums">60</span>
              <span class="text-xs text-gray-500">sec</span>
            </div>
            <div class="flex items-center gap-4">
              <div class="text-center"><p id="sp-score" class="text-lg font-black text-amber-400 font-mono">0</p><p class="text-[9px] text-gray-500">pts</p></div>
              <div class="text-center"><p id="sp-words" class="text-lg font-black text-blue-400 font-mono">0</p><p class="text-[9px] text-gray-500">words</p></div>
            </div>
          </div>
          <div id="sp-tiles" class="flex gap-1.5 justify-center mb-3"></div>
          <div class="flex gap-2 mb-3">
            <input id="sp-input" type="text" maxlength="7" placeholder="Type a word..." class="flex-1 h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white uppercase tracking-wider font-mono placeholder-gray-500 focus:outline-none focus:border-green-500" autocomplete="off" />
            <button id="sp-submit" class="h-10 px-4 rounded-lg bg-green-600 text-white font-bold text-sm hover:bg-green-500 transition-colors">Go</button>
          </div>
          <div id="sp-feedback" class="hidden mb-2 p-2 rounded-lg text-center text-xs font-medium"></div>
          <div id="sp-found" class="flex flex-wrap gap-1.5 max-h-24 overflow-y-auto"></div>
        </div>

        <!-- Game over state -->
        <div id="sp-over" class="hidden text-center py-4">
          <p id="sp-result-emoji" class="text-3xl mb-2">🎉</p>
          <p id="sp-result-title" class="text-lg font-bold text-white mb-1">Time's Up!</p>
          <div class="flex items-center justify-center gap-6 my-3">
            <div><p id="sp-final-score" class="text-xl font-black text-amber-400">0</p><p class="text-[9px] text-gray-500">pts</p></div>
            <div><p id="sp-final-words" class="text-xl font-black text-blue-400">0</p><p class="text-[9px] text-gray-500">words</p></div>
            <div><p id="sp-final-best" class="text-xl font-black text-purple-400">—</p><p class="text-[9px] text-gray-500">best</p></div>
          </div>
          <div id="sp-missed-section" class="hidden mt-3 pt-3 border-t border-gray-800 text-left">
            <p class="text-[9px] text-gray-500 uppercase mb-1">Top missed words</p>
            <div id="sp-missed" class="flex flex-wrap gap-1"></div>
          </div>
          <div class="flex gap-2 justify-center mt-4">
            <button id="sp-again" class="px-4 py-2 rounded-lg bg-green-600 text-white font-bold text-sm hover:bg-green-500 transition-colors">🔄 Again</button>
            <button id="sp-share" class="px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-purple-300 text-sm font-bold hover:bg-purple-600/50 transition-colors">📋 Share</button>
          </div>
        </div>
      </div>

<script is:inline>
(function() {
  var SCORES = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
  var TILE_BAG = 'AAAAAAAAABBCCDDDDEEEEEEEEEEEEFFGGGHHIIIIIIIIIJKLLLLMMNNNNNNOOOOOOOOPPQRRRRRRSSSSTTTTTTUUUUVVWWXYYZ';
  var WORDS = [];
  var dictLoaded = false;
  var gameActive = false;
  var timer = null;
  var timeLeft = 60;
  var score = 0;
  var foundWords = [];
  var currentTiles = '';
  var PB_KEY = 'swf-60s-pb';

  var pb = parseInt(localStorage.getItem(PB_KEY) || '0');
  document.getElementById('sixty-pb-badge').textContent = 'PB: ' + (pb > 0 ? pb + ' pts' : '\u2014');

  var dictPref = localStorage.getItem('scbDictionary') || 'sowpods';
  document.getElementById('sp-dict').value = dictPref;

  function loadDict(name) {
    var urls = name === 'twl' ? ['/data/twl06-2-7.json'] : ['/data/sowpods-2-7.json'];
    Promise.all(urls.map(function(u) { return fetch(u).then(function(r) { return r.json(); }); }))
      .then(function(results) { WORDS = results[0].map(function(w) { return w.toUpperCase(); }); dictLoaded = true; document.getElementById('sp-dict-status').textContent = WORDS.length.toLocaleString() + ' words ready'; document.getElementById('sp-start').textContent = '\u25B6 Start'; })
      .catch(function() { document.getElementById('sp-dict-status').textContent = 'Failed to load'; });
  }
  loadDict(dictPref);

  document.getElementById('sp-dict').addEventListener('change', function() {
    dictPref = this.value; localStorage.setItem('scbDictionary', dictPref);
    dictLoaded = false; document.getElementById('sp-dict-status').textContent = 'Loading...';
    loadDict(dictPref);
  });

  function drawTiles() {
    var bag = TILE_BAG.split(''); var tiles = '';
    for (var i = 0; i < 7; i++) { var idx = Math.floor(Math.random() * bag.length); tiles += bag[idx]; bag.splice(idx, 1); }
    return tiles;
  }

  function renderTiles(tiles) {
    document.getElementById('sp-tiles').innerHTML = tiles.split('').map(function(l) {
      var pts = SCORES[l] || 0;
      return '<div class="w-10 h-12 rounded-lg flex flex-col items-center justify-center select-none" style="background:linear-gradient(145deg,#d4f0d4,#b8e8b8);box-shadow:inset 0 1px 0 rgba(255,255,255,0.5),0 3px 6px rgba(0,0,0,0.3);border:2px solid #6db86d;"><span class="text-base font-black text-gray-800">' + l + '</span><span class="text-[8px] text-gray-600">' + pts + '</span></div>';
    }).join('');
  }

  function canMake(word, rack) {
    var a = rack.split('');
    for (var i = 0; i < word.length; i++) { var idx = a.indexOf(word[i]); if (idx === -1) return false; a.splice(idx, 1); }
    return true;
  }

  function wordScore(w) { return w.split('').reduce(function(s, c) { return s + (SCORES[c] || 0); }, 0); }

  function startGame() {
    if (!dictLoaded) return;
    gameActive = true; timeLeft = 60; score = 0; foundWords = []; currentTiles = drawTiles();
    document.getElementById('sp-setup').classList.add('hidden');
    document.getElementById('sp-over').classList.add('hidden');
    document.getElementById('sp-active').classList.remove('hidden');
    renderTiles(currentTiles);
    document.getElementById('sp-timer').textContent = '60';
    document.getElementById('sp-timer').classList.remove('text-red-400');
    document.getElementById('sp-timer').classList.add('text-green-400');
    document.getElementById('sp-score').textContent = '0';
    document.getElementById('sp-words').textContent = '0';
    document.getElementById('sp-found').innerHTML = '';
    document.getElementById('sp-feedback').classList.add('hidden');
    document.getElementById('sp-input').value = '';
    document.getElementById('sp-input').focus();
    timer = setInterval(function() {
      timeLeft--;
      document.getElementById('sp-timer').textContent = timeLeft;
      if (timeLeft <= 10) { document.getElementById('sp-timer').classList.remove('text-green-400'); document.getElementById('sp-timer').classList.add('text-red-400'); }
      if (timeLeft <= 0) endGame();
    }, 1000);
  }

  function submitWord() {
    if (!gameActive) return;
    var input = document.getElementById('sp-input');
    var word = input.value.trim().toUpperCase(); input.value = '';
    if (!word || word.length < 2) return;
    var fb = document.getElementById('sp-feedback');
    if (foundWords.indexOf(word) !== -1) { showFb(fb, 'Already found', 'amber'); return; }
    if (!canMake(word, currentTiles)) { showFb(fb, "Can't make", 'red'); return; }
    if (WORDS.indexOf(word) === -1) { showFb(fb, 'Not valid', 'red'); return; }
    var pts = wordScore(word);
    score += pts; foundWords.push(word);
    document.getElementById('sp-score').textContent = score;
    document.getElementById('sp-words').textContent = foundWords.length;
    document.getElementById('sp-found').innerHTML += '<span class="px-1.5 py-0.5 rounded bg-green-900/30 border border-green-700/50 text-[10px] text-green-300 font-mono uppercase">' + word + ' ' + pts + '</span>';
    showFb(fb, word + ' = ' + pts + ' pts', 'green');
    input.focus();
  }

  function showFb(el, text, color) {
    var cls = { green: 'bg-green-900/30 border border-green-500/50 text-green-300', red: 'bg-red-900/30 border border-red-500/50 text-red-300', amber: 'bg-amber-900/30 border border-amber-500/50 text-amber-300' };
    el.className = 'mb-2 p-2 rounded-lg text-center text-xs font-medium ' + (cls[color] || '');
    el.textContent = text; el.classList.remove('hidden');
    setTimeout(function() { el.classList.add('hidden'); }, 1200);
  }

  function endGame() {
    gameActive = false; clearInterval(timer);
    document.getElementById('sp-active').classList.add('hidden');
    document.getElementById('sp-over').classList.remove('hidden');
    document.getElementById('sp-final-score').textContent = score;
    document.getElementById('sp-final-words').textContent = foundWords.length;
    // Award sixty star
    window.__awardStar && window.__awardStar('sixty');
    var best = foundWords.reduce(function(b, w) { var s = wordScore(w); return s > b.s ? {w:w,s:s} : b; }, {w:'\u2014',s:0});
    document.getElementById('sp-final-best').textContent = best.w;
    var emoji = score >= 100 ? '\uD83C\uDFC6' : score >= 60 ? '\uD83C\uDF89' : score >= 30 ? '\uD83D\uDC4D' : '\uD83D\uDCAA';
    document.getElementById('sp-result-emoji').textContent = emoji;
    document.getElementById('sp-result-title').textContent = score >= 100 ? 'Amazing!' : score >= 60 ? 'Great!' : score >= 30 ? 'Nice!' : "Time's Up!";
    if (score > pb) { pb = score; localStorage.setItem(PB_KEY, String(pb)); document.getElementById('sixty-pb-badge').textContent = 'PB: ' + pb + ' pts \uD83C\uDD95'; }
    var possible = WORDS.filter(function(w) { return w.length <= 7 && canMake(w, currentTiles); });
    var missed = possible.filter(function(w) { return foundWords.indexOf(w) === -1; }).sort(function(a,b) { return wordScore(b) - wordScore(a); }).slice(0, 10);
    if (missed.length > 0) {
      document.getElementById('sp-missed-section').classList.remove('hidden');
      document.getElementById('sp-missed').innerHTML = missed.map(function(w) { return '<span class="px-1.5 py-0.5 rounded bg-gray-800 border border-gray-700 text-[9px] text-gray-400 font-mono uppercase">' + w + '</span>'; }).join('');
    } else { document.getElementById('sp-missed-section').classList.add('hidden'); }
  }

  document.getElementById('sp-start').addEventListener('click', startGame);
  document.getElementById('sp-again').addEventListener('click', startGame);
  document.getElementById('sp-submit').addEventListener('click', submitWord);
  document.getElementById('sp-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') submitWord(); });
  document.getElementById('sp-share').addEventListener('click', function() {
    var text = '\u23F1\uFE0F 60s Word Finder\n\uD83C\uDFC5 ' + score + ' pts | ' + foundWords.length + ' words\nhttps://www.scrabblewordsfinder.com/activities/';
    navigator.clipboard.writeText(text).then(function() { document.getElementById('sp-share').textContent = '\u2713 Copied'; setTimeout(function() { document.getElementById('sp-share').textContent = '\uD83D\uDCCB Share'; }, 2000); });
  });
})();
</script>
