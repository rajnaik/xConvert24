      <!-- Star Bar — Daily Progress -->
      <div id="star-bar" class="col-span-1 lg:col-span-2 rounded-xl border border-amber-800/50 bg-gradient-to-r from-amber-950/20 via-gray-900/50 to-purple-950/20 p-4">
        <div class="flex items-center justify-between flex-wrap gap-3">
          <!-- Stars -->
          <div class="flex items-end gap-2">
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">WOTD</span>
              <span id="sb-wotd" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="📖 Word of the Day — Add word to Memory WordBench + Lookup meaning">📖</span>
            </div>
            <a href="/diamond-hunt/" class="flex flex-col items-center gap-0.5 no-underline" title="💎 Diamond Hunt — Find hidden diamonds across the site">
              <span class="text-[9px] text-purple-400 leading-none font-bold">Hunt</span>
              <span class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-purple-700/50 bg-purple-900/20 hover:bg-purple-800/30 hover:border-purple-500/60 transition-all cursor-pointer relative">💎<span class="absolute -top-1.5 -right-1.5 text-[8px] font-bold text-purple-300 bg-purple-900/80 border border-purple-600/50 rounded-full px-1 leading-tight">121</span></span>
            </a>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">Quiz</span>
              <span id="sb-quiz" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="🧠 Word Quiz — Complete 1 quiz round">🧠</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">MWB</span>
              <span id="sb-wordbench" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="🃏 Memory WordBench — Auto-play 3+ cards">🃏</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">Rack</span>
              <span id="sb-rack" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="🎲 Daily Rack — Submit 1 valid word">🎲</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">Anagram</span>
              <span id="sb-anagram" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="🔤 Daily Anagram — Make 1 guess">🔤</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">60s</span>
              <span id="sb-sixty" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="⏱️ 60-Second — Play 1 round">⏱️</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">CaB</span>
              <span id="sb-cab" class="w-8 h-8 rounded-lg flex items-center justify-center text-lg border border-gray-700 bg-gray-800/50 opacity-40 transition-all cursor-help" title="🐄 Cows and Bulls — Solve 1 game">🐄</span>
            </div>
            <span class="text-gray-600 mx-1 mb-1">→</span>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-[9px] text-gray-500 leading-none">💎</span>
              <span id="sb-diamond" class="w-9 h-9 rounded-lg flex items-center justify-center text-xl border-2 border-gray-700 bg-gray-800/50 opacity-30 transition-all cursor-help" title="💎 Diamond — Earn all stars to unlock!">💎</span>
            </div>
            <span id="sb-diamond-msg" class="hidden ml-2 mb-1 text-[11px] text-purple-300 font-medium px-3 py-1.5 rounded-lg border border-purple-500/50 bg-purple-900/20 whitespace-nowrap"></span>
          </div>
          <!-- Stats — single line with counts in () -->
          <div class="flex items-center gap-4 text-xs">
            <span class="text-gray-400">🔥 Streak (<span id="sb-streak" class="text-amber-400 font-bold">0</span>)</span>
            <span class="text-gray-400">⭐ Total (<span id="sb-total-stars" class="text-amber-400 font-bold">0</span>)</span>
            <span class="text-gray-400">💎 Total (<span id="sb-total-diamonds" class="text-purple-400 font-bold">0</span>)</span>
            <a href="/mybag/" id="sb-mybag-link" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg border border-amber-700/40 bg-amber-950/30 hover:bg-amber-900/40 hover:border-amber-500/60 text-amber-400 hover:text-amber-300 transition-all" title="MyBag — View your star & diamond earnings">🎒 <span class="hidden sm:inline">MyBag</span><span id="sb-mybag-count" class="hidden text-[10px] font-bold text-amber-300 ml-0.5"></span></a>
            <a href="/diamond-hunt/" id="sb-diamond-hunt-link" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg border border-purple-700/40 bg-purple-950/30 hover:bg-purple-900/40 hover:border-purple-500/60 text-purple-400 hover:text-purple-300 transition-all" title="Diamond Hunt — Find hidden diamonds across the site">
              <span class="text-lg leading-none">💎</span> <span class="hidden sm:inline">Diamond Hunt</span><span id="sb-hunt-count" class="hidden text-[10px] font-bold text-purple-300 ml-0.5"></span>
            </a>
          </div>
        </div>
        <p id="sb-message" class="text-xs text-gray-400 font-medium mt-1"></p>
      </div>

<script is:inline>
(function() {
  var S = window.__swfStore;
  var uid = S.getRaw('swf-uid') || '';

  // Global star award helper with localStorage failsafe
  var STARS_LS_KEY = 'swf-stars-earned-' + new Date().toISOString().split('T')[0];

  window.__awardStar = function(game) {
    if (!uid) return;
    // 1. Save to localStorage immediately (never fails)
    var todayStars = JSON.parse(S.getRaw(STARS_LS_KEY) || '[]');
    if (todayStars.indexOf(game) === -1) {
      todayStars.push(game);
      S.setRaw(STARS_LS_KEY, JSON.stringify(todayStars));
    }
    // 2. Sync ALL localStorage stars to DB (batch — covers any missed POSTs)
    syncStarsToDb(todayStars);
    // 3. Update UI immediately
    window.dispatchEvent(new CustomEvent('swf-star-earned', { detail: { game: game } }));
  };

  function syncStarsToDb(stars) {
    // POST each unsynced star — API is idempotent so duplicates are safe
    stars.forEach(function(game) {
      fetch('/api/daily-progress/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, game: game }),
        keepalive: true
      }).catch(function() {});
    });
  }

  // On page load: sync any localStorage stars that might not have reached DB
  var savedStars = JSON.parse(S.getRaw(STARS_LS_KEY) || '[]');
  if (savedStars.length > 0) { syncStarsToDb(savedStars); }

  // Light up star indicators on each panel header — turn green permanently when earned
  function markStarGreen(game) {
    var indicators = document.querySelectorAll('.star-indicator[data-game="' + game + '"]');
    indicators.forEach(function(el) {
      el.classList.remove('opacity-40');
      el.classList.add('opacity-100', 'text-green-400');
      el.title = '⭐ Star earned!';
    });
  }

  savedStars.forEach(function(game) { markStarGreen(game); });

  window.addEventListener('swf-star-earned', function(e) {
    var game = e.detail && e.detail.game;
    if (game) {
      markStarGreen(game);
      // Show static tick elements for this game
      var ticks = document.querySelectorAll('.star-tick[data-game="' + game + '"]');
      ticks.forEach(function(tick) {
        tick.classList.remove('hidden');
        tick.style.opacity = '1';
        // Fade out after 5 seconds
        setTimeout(function() { tick.style.transition = 'opacity 0.7s'; tick.style.opacity = '0'; setTimeout(function() { tick.classList.add('hidden'); }, 700); }, 5000);
      });
    }
  });

  if (!uid) {
    document.getElementById('sb-message').textContent = 'Start playing to earn stars!';
    return;
  }

  var cacheKey = 'swf-stars-' + new Date().toISOString().split('T')[0];
  var cached = S.getRaw(cacheKey);
  if (cached) { try { renderStarBar(JSON.parse(cached)); } catch(e) {} }

  fetch('/api/daily-progress/?user_id=' + encodeURIComponent(uid))
    .then(function(r) { return r.json(); })
    .then(function(data) { S.setRaw(cacheKey, JSON.stringify(data)); renderStarBar(data); })
    .catch(function() {});

  function renderStarBar(data) {
    var stars = data.today && data.today.stars_earned ? data.today.stars_earned : [];
    // Merge with localStorage (failsafe — localStorage might have stars DB doesn't yet)
    var lsStars = JSON.parse(S.getRaw(STARS_LS_KEY) || '[]');
    lsStars.forEach(function(s) { if (stars.indexOf(s) === -1) stars.push(s); });
    var games = data.games || [];
    games.forEach(function(g) {
      var el = document.getElementById('sb-' + g.slug);
      if (el && stars.indexOf(g.slug) !== -1) {
        el.classList.remove('opacity-40', 'border-gray-700', 'bg-gray-800/50');
        el.classList.add('opacity-100', 'border-amber-500', 'bg-amber-900/30');
      }
      // Turn star indicator green permanently for earned stars
      if (stars.indexOf(g.slug) !== -1) {
        markStarGreen(g.slug);
      }
    });
    var threshold = data.diamond_threshold || games.length || 6;
    var allStarsEarned = stars.length >= threshold;
    var diamondClaimed = data.today && data.today.diamond;
    // Diamond is auto-awarded when all stars earned — light it up immediately
    if (allStarsEarned || diamondClaimed) {
      var dEl = document.getElementById('sb-diamond');
      if (dEl) { dEl.classList.remove('opacity-30', 'border-gray-700', 'bg-gray-800/50'); dEl.classList.add('opacity-100', 'border-purple-500', 'bg-purple-900/30'); }
    }
    var lt = data.lifetime || {};
    document.getElementById('sb-streak').textContent = lt.current_streak || 0;
    document.getElementById('sb-total-stars').textContent = lt.total_stars || 0;
    document.getElementById('sb-total-diamonds').textContent = lt.total_diamonds || 0;
    // Show diamond counts on MyBag and Diamond Hunt buttons
    var mybagCount = document.getElementById('sb-mybag-count');
    var huntCount = document.getElementById('sb-hunt-count');
    if (mybagCount && (lt.diamonds_earned || 0) > 0) { mybagCount.textContent = '- ' + lt.diamonds_earned; mybagCount.classList.remove('hidden'); }
    if (huntCount && (lt.diamonds_mined || 0) > 0) { huntCount.textContent = '- ' + lt.diamonds_mined; huntCount.classList.remove('hidden'); }
    var earned = stars.length; var remaining = threshold - earned; var msg = '';
    var msgEl = document.getElementById('sb-message');
    var diamondMsgEl = document.getElementById('sb-diamond-msg');
    if (allStarsEarned || diamondClaimed) {
      msgEl.textContent = '';
      diamondMsgEl.textContent = '💎 Diamond earned! Come back tomorrow!'; diamondMsgEl.classList.remove('hidden');
    } else {
      diamondMsgEl.textContent = ''; diamondMsgEl.classList.add('hidden');
      if (earned > 0) { msg = earned + '/' + threshold + ' stars — ' + remaining + ' more for 💎'; }
      else { msg = 'Play any game to earn your first ⭐ today'; }
      msgEl.textContent = msg;
    }
  }

  window.addEventListener('swf-star-earned', function(e) {
    var detail = (e && e.detail) ? e.detail : {};
    var el = document.getElementById('sb-' + detail.game);
    if (el) {
      el.classList.remove('opacity-40', 'border-gray-700', 'bg-gray-800/50');
      el.classList.add('opacity-100', 'border-amber-500', 'bg-amber-900/30');
    }
    fetch('/api/daily-progress/?user_id=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) { S.setRaw(cacheKey, JSON.stringify(data)); renderStarBar(data); })
      .catch(function() {});
  });
})();
</script>
