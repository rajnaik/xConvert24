      <!-- Panel 4: Daily Rack Challenge -->
      <div class="rounded-xl border border-amber-800/50 bg-gray-900/50 p-6">
        <h2 class="text-lg font-semibold text-white mb-2 flex items-center gap-2"><span>🎲</span> Daily Rack Challenge</h2>
        <p class="text-xs text-gray-500 mb-4">Find the highest-scoring word from today's 7 tiles. Same rack for everyone!</p>
        <div id="drc-loading" class="text-center py-4"><p class="text-xs text-gray-500">Loading today's rack...</p></div>
        <div id="drc-content" class="hidden">
          <!-- Today's tiles -->
          <div id="drc-tiles" class="flex gap-1.5 justify-center mb-4"></div>
          <!-- Input -->
          <div class="flex gap-2 mb-3">
            <input id="drc-input" type="text" maxlength="15" placeholder="Type your best word..." class="flex-1 h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white uppercase tracking-wider font-mono placeholder-gray-500 focus:outline-none focus:border-amber-500" autocomplete="off" />
            <button id="drc-submit" class="h-10 px-4 rounded-lg bg-amber-600 text-white font-semibold text-sm hover:bg-amber-500 transition-colors">Submit</button>
          </div>
          <!-- Feedback -->
          <div id="drc-feedback" class="hidden mb-3 p-3 rounded-lg text-center text-sm font-medium"></div>
          <!-- Your submissions -->
          <div id="drc-your-words" class="hidden mb-3">
            <p class="text-[10px] text-gray-500 uppercase mb-1">Your words today</p>
            <div id="drc-your-list" class="flex flex-wrap gap-1.5"></div>
          </div>
          <!-- Best score -->
          <div class="flex items-center justify-between pt-3 border-t border-gray-800">
            <span class="text-[10px] text-gray-500">Today's best</span>
            <span id="drc-best" class="text-sm font-bold text-amber-400">—</span>
          </div>
        </div>
      </div>

<script is:inline>
(function() {
  // ── Daily Rack Challenge ──
  (function loadDailyRack() {
    var uid = localStorage.getItem('swf-uid') || '';
    var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
    var dailyRack = '';
    var userWords = [];

    fetch('/api/daily-rack/' + (uid ? '?user_id=' + encodeURIComponent(uid) : ''))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        document.getElementById('drc-loading').classList.add('hidden');
        document.getElementById('drc-content').classList.remove('hidden');
        dailyRack = data.rack || '';

        // Render tiles
        var tilesHtml = dailyRack.split('').map(function(letter) {
          var pts = scores[letter] || 0;
          return '<div class="w-11 h-14 rounded-lg flex flex-col items-center justify-center select-none" style="background:linear-gradient(145deg,#e8d5c0,#dcc8b0);box-shadow:inset 0 2px 0 rgba(255,255,255,0.4),inset 0 -3px 0 rgba(0,0,0,0.08),0 4px 8px rgba(0,0,0,0.2);border:2px solid #c4a882;">' +
            '<span class="text-lg font-black text-gray-800">' + letter + '</span>' +
            '<span class="text-[8px] text-gray-600 -mt-0.5">' + pts + '</span>' +
          '</div>';
        }).join('');
        document.getElementById('drc-tiles').innerHTML = tilesHtml;

        // Best score
        if (data.best_word) {
          document.getElementById('drc-best').textContent = data.best_word + ' (' + data.best_score + ' pts)';
        }

        // Show user's previous submissions
        if (data.userScores && data.userScores.length > 0) {
          userWords = data.userScores;
          renderUserWords();
        }
      }).catch(function() {
        document.getElementById('drc-loading').innerHTML = '<p class="text-xs text-red-400">Failed to load</p>';
      });

    function renderUserWords() {
      if (userWords.length === 0) return;
      document.getElementById('drc-your-words').classList.remove('hidden');
      document.getElementById('drc-your-list').innerHTML = userWords.map(function(w) {
        return '<span class="px-2 py-0.5 rounded bg-amber-900/30 border border-amber-700/50 text-xs text-amber-300 font-mono uppercase">' + w.word + ' <span class="text-amber-500 font-bold">' + w.score + '</span></span>';
      }).join('');
    }

    function canMakeFromRack(word, rack) {
      var available = rack.toUpperCase().split('');
      for (var i = 0; i < word.length; i++) {
        var idx = available.indexOf(word[i].toUpperCase());
        if (idx === -1) return false;
        available.splice(idx, 1);
      }
      return true;
    }

    function calcScore(word) {
      return word.toUpperCase().split('').reduce(function(s, c) { return s + (scores[c] || 0); }, 0);
    }

    document.getElementById('drc-submit').addEventListener('click', function() {
      var input = document.getElementById('drc-input');
      var word = input.value.trim().toUpperCase();
      if (!word || word.length < 2) return;

      var fb = document.getElementById('drc-feedback');

      // Check if word can be made from rack
      if (!canMakeFromRack(word, dailyRack)) {
        fb.className = 'mb-3 p-3 rounded-lg text-center text-sm font-medium bg-red-900/30 border border-red-500/50 text-red-300';
        fb.textContent = "❌ Can't make '" + word + "' from today's tiles!";
        fb.classList.remove('hidden');
        return;
      }

      var wordPts = calcScore(word);

      // Submit to API
      fetch('/api/daily-rack/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: uid, word: word, score: wordPts })
      }).then(function() {
        fb.className = 'mb-3 p-3 rounded-lg text-center text-sm font-medium bg-green-900/30 border border-green-500/50 text-green-300';
        fb.textContent = '✅ ' + word + ' = ' + wordPts + ' pts!';
        fb.classList.remove('hidden');
        userWords.unshift({ word: word, score: wordPts });
        renderUserWords();
        input.value = '';
      }).catch(function() {
        fb.className = 'mb-3 p-3 rounded-lg text-center text-sm font-medium bg-red-900/30 border border-red-500/50 text-red-300';
        fb.textContent = '❌ Failed to submit. Try again.';
        fb.classList.remove('hidden');
      });
    });

    // Submit on Enter
    document.getElementById('drc-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') document.getElementById('drc-submit').click();
    });
  })();
})();
</script>
