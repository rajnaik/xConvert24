      <!-- Panel 1: Word of the Day -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📖</span> Word of the Day <span class="star-indicator text-sm opacity-40 cursor-help" data-game="wotd" title="⭐ Earn star: Add WOTD to Memory WordBench (auto-awarded if already saved)">⭐</span><span class="star-tick hidden text-green-400 text-sm font-bold" data-game="wotd">✅</span>
          <button id="wotd-history-btn" class="ml-auto w-7 h-7 flex items-center justify-center rounded-full border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all" title="WOTD History">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
        </h2>
        <div id="wotd-panel">
          <div class="text-center py-8">
            <p id="wotd-word" class="text-4xl font-black text-purple-400 tracking-wider mb-1">—</p>
            <p id="wotd-viewing-date" class="text-xs text-purple-300/60 mb-3 font-mono"></p>
            <p id="wotd-meaning" class="text-sm text-gray-300 italic mb-3">Loading today's word...</p>
            <!-- Explore WOTD button -->
            <button id="wotd-explore-btn" class="hidden mb-4 px-4 py-2 rounded-lg bg-purple-600/20 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/40 hover:border-purple-400 transition-all">
              🔍 Explore WOTD
            </button>
            <!-- Enriched content blurb (revealed by Explore button) -->
            <div id="wotd-enriched" class="hidden text-left mx-auto max-w-sm mb-4 space-y-2">
              <p id="wotd-fact" class="text-xs text-gray-400"><span class="text-yellow-400 font-semibold">Fun fact:</span> <span class="wotd-fact-text"></span></p>
              <p id="wotd-origin" class="text-xs text-gray-400"><span class="text-purple-400 font-semibold">Origin:</span> <span class="wotd-origin-text"></span></p>
              <p id="wotd-usage" class="text-xs text-gray-400"><span class="text-blue-400 font-semibold">Example:</span> <span class="wotd-usage-text italic"></span></p>
              <p id="wotd-spelling" class="text-xs text-gray-400"><span class="text-green-400 font-semibold">Spelling tip:</span> <span class="wotd-spelling-text"></span></p>
              <p id="wotd-cultural" class="text-xs text-gray-400"><span class="text-amber-400 font-semibold">Did you know?</span> <span class="wotd-cultural-text"></span></p>
              <div id="wotd-languages" class="hidden">
                <p class="text-xs text-gray-400"><span class="text-cyan-400 font-semibold">🌍 In other languages:</span> <span class="wotd-languages-text italic"></span></p>
              </div>
            </div>
            <div class="flex items-center justify-center gap-3">
              <button id="wotd-prev" class="w-8 h-8 flex items-center justify-center rounded-full border border-purple-600/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all text-lg font-bold" title="Previous day">&lsaquo;</button>
              <button id="wotd-add-workbench" class="px-4 py-2 rounded-lg bg-red-600/20 border border-red-500/50 text-sm text-red-400 hover:bg-red-600/40 transition-colors">
                Save to WordBench ✗
              </button>
              <button id="wotd-fetch-meaning" class="px-3 py-2 rounded-lg bg-blue-600/30 border border-blue-500/50 text-sm text-blue-300 hover:bg-blue-600/50 transition-colors">
                📖 Lookup
              </button>
              <button id="wotd-next" class="w-8 h-8 flex items-center justify-center rounded-full border border-purple-600/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all text-lg font-bold" title="Next day">&rsaquo;</button>
            </div>
            <!-- Memorised checkbox -->
            <label id="wotd-memorised-label" class="flex items-center justify-center gap-2 mt-3 cursor-pointer select-none group">
              <input id="wotd-memorised-checkbox" type="checkbox" class="w-4 h-4 rounded border-2 border-amber-500/50 bg-gray-800 text-amber-500 focus:ring-amber-400 focus:ring-offset-0 cursor-pointer accent-amber-500" />
              <span class="text-xs text-amber-300 group-hover:text-amber-200 transition-colors">Memorised</span>
            </label>
          </div>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-center"><span id="wotd-date" class="hidden"></span><span id="wotd-cache-status" class="hidden"></span><span id="wotd-countdown" class="text-purple-400 font-mono"></span></p>
          </div>
        </div>
        <!-- WOTD History Panel (toggled by history button) -->
        <div id="wotd-history-panel" class="hidden mt-4 rounded-xl border border-purple-800/50 bg-gray-900/80 p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-purple-300 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              WOTD History
            </h3>
            <button id="wotd-history-close" class="text-gray-500 hover:text-white text-lg leading-none">&times;</button>
          </div>
          <div id="wotd-history-empty" class="hidden text-center py-4">
            <p class="text-xs text-gray-500 mb-3">No WOTD history yet. Words appear here as you save them.</p>
            <button id="wotd-history-add-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 text-xs font-medium transition-all" title="Add today's WOTD to Memory WordBench">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
              Add WOTD to WordBench
            </button>
          </div>
          <div id="wotd-history-content" class="hidden">
            <div class="overflow-x-auto max-h-64 overflow-y-auto">
              <table class="w-full text-xs border border-gray-700 rounded overflow-hidden">
                <thead class="bg-gray-800 sticky top-0">
                  <tr>
                    <th class="px-2 py-1.5 text-left text-gray-400">Word</th>
                    <th class="px-2 py-1.5 text-left text-gray-400">Meaning</th>
                    <th class="px-2 py-1.5 text-left text-gray-400">Date</th>
                  </tr>
                </thead>
                <tbody id="wotd-history-body" class="divide-y divide-gray-800"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

<script is:inline>
(function() {
    var S = window.__swfStore;
    var uid = S.getRaw('swf-uid') || '';

    // Show "use workbench words" option if user has saved words with meanings
    var saved = JSON.parse(S.getRaw('scbAchievements') || '[]');
    var wordsWithMeaning = saved.filter(function(w) {
      if (!w.meaning || !w.meaning.trim()) return false;
      var m = w.meaning.toLowerCase();
      if (m.indexOf('scrabble-legal word') !== -1) return false;
      if (m.indexOf('no standard definition') !== -1) return false;
      return true;
    });
    if (wordsWithMeaning.length >= 3) {
      var wbLabel = document.getElementById('quiz-from-workbench-label');
      if (wbLabel) wbLabel.classList.remove('hidden');
    }

    if (uid) {
      fetch('/api/quiz-scores/?user_id=' + encodeURIComponent(uid))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var scores = data.scores || [];
          if (scores.length === 0) return;
          var btn = document.getElementById('quiz-history-btn');
          if (btn) { btn.classList.remove('hidden'); btn.style.display = 'flex'; }
          var countEl = document.getElementById('quiz-history-count');
          if (countEl) countEl.textContent = scores.length;
        }).catch(function() {});
    }

  // ── Word of the Day (with server-provided TTL cache) ──
  var WOTD_CACHE_KEY = 'swf-wotd-cache';

  function getWotdCache() {
    return S.getIfValid(WOTD_CACHE_KEY);
  }

  function setWotdCache(data, expiresAt) {
    if (expiresAt) {
      S.setWithExpiry(WOTD_CACHE_KEY, data, expiresAt);
    } else {
      // Fallback: expire at next midnight UTC
      S.setWithExpiry(WOTD_CACHE_KEY, data, S.getNextMidnightUTC());
    }
  }

  function checkWotdInMwb(word) {
    if (!word || word === '—') return;
    var mwb = JSON.parse(S.getRaw('scbAchievements') || '[]');
    var alreadySaved = mwb.find(function(s) { return s.word === word; });
    if (alreadySaved) {
      var btn = document.getElementById('wotd-add-workbench');
      if (btn) {
        btn.textContent = 'Saved ✓';
        btn.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
      }
      // Auto-award star — word was already saved before this WOTD session
      window.__awardStar && window.__awardStar('wotd');
    }
  }

  // ── Fetch and display multilingual translations (GLM-4.7-flash) ──
  function fetchWotdLanguages() {
    var word = document.getElementById('wotd-word').textContent;
    if (!word || word === '—') return;
    var langEl = document.getElementById('wotd-languages');
    var langText = langEl ? langEl.querySelector('.wotd-languages-text') : null;
    if (!langEl || !langText) return;

    // Check localStorage cache first (keyed by word)
    var cacheKey = 'swf-wotd-lang:' + word;
    var cached = S.getRaw(cacheKey);
    if (cached) {
      try {
        var cachedData = JSON.parse(cached);
        if (cachedData && cachedData.length > 0) {
          langText.textContent = cachedData.map(function(t) { return t.translation + ' (' + t.language + ')'; }).join(' · ');
          langEl.classList.remove('hidden');
          return;
        }
      } catch(e) {}
    }

    // Fetch from API
    langText.textContent = 'Loading...';
    langEl.classList.remove('hidden');
    fetch('/api/wotd-languages/?word=' + encodeURIComponent(word))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.translations && data.translations.length > 0) {
          langText.textContent = data.translations.map(function(t) { return t.translation + ' (' + t.language + ')'; }).join(' · ');
          // Cache for this word
          S.setRaw(cacheKey, JSON.stringify(data.translations));
        } else {
          langEl.classList.add('hidden');
        }
      })
      .catch(function() { langEl.classList.add('hidden'); });
  }

  function renderWotd(word) {
    document.getElementById('wotd-word').textContent = word.word || '—';
    document.getElementById('wotd-meaning').textContent = word.meaning || 'Tap "Lookup" to fetch the meaning';
    document.getElementById('wotd-date').textContent = word.date || new Date().toISOString().split('T')[0];
    // Enriched content — show Explore button if data exists
    var enrichedEl = document.getElementById('wotd-enriched');
    var exploreBtn = document.getElementById('wotd-explore-btn');
    var hasEnriched = word.origin || word.usage_example || word.spelling_tip || word.cultural_note || word.fun_fact;
    // Always show the Explore button — even without traditional enriched data,
    // we can fetch multilingual translations for any word
    var hasAnyContent = hasEnriched || true;
    if (hasAnyContent && enrichedEl) {
      // Populate the enriched fields
      var factEl = enrichedEl.querySelector('.wotd-fact-text');
      var originEl = enrichedEl.querySelector('.wotd-origin-text');
      var usageEl = enrichedEl.querySelector('.wotd-usage-text');
      var spellingEl = enrichedEl.querySelector('.wotd-spelling-text');
      var culturalEl = enrichedEl.querySelector('.wotd-cultural-text');
      if (factEl) factEl.textContent = word.fun_fact || '';
      if (originEl) originEl.textContent = word.origin || '';
      if (usageEl) usageEl.textContent = word.usage_example || '';
      if (spellingEl) spellingEl.textContent = word.spelling_tip || '';
      if (culturalEl) culturalEl.textContent = word.cultural_note || '';
      document.getElementById('wotd-fact').style.display = word.fun_fact ? '' : 'none';
      document.getElementById('wotd-origin').style.display = word.origin ? '' : 'none';
      document.getElementById('wotd-usage').style.display = word.usage_example ? '' : 'none';
      document.getElementById('wotd-spelling').style.display = word.spelling_tip ? '' : 'none';
      document.getElementById('wotd-cultural').style.display = word.cultural_note ? '' : 'none';
      // Check if user already explored this word's date (keyed by URL) — if so, show enriched directly
      var exploredKey = 'swf-wotd-explored:' + window.location.pathname;
      var exploredDate = S.getRaw(exploredKey);
      var wordDate = word.date || new Date().toISOString().split('T')[0];
      if (exploredDate === wordDate) {
        // Already explored today — show enriched content, hide button
        enrichedEl.classList.remove('hidden');
        if (exploreBtn) exploreBtn.classList.add('hidden');
        // Also fetch translations since enriched is visible
        fetchWotdLanguages();
      } else {
        // Not explored yet — show button, hide enriched
        if (exploreBtn) exploreBtn.classList.remove('hidden');
        enrichedEl.classList.add('hidden');
      }
    } else {
      if (enrichedEl) enrichedEl.classList.add('hidden');
      if (exploreBtn) exploreBtn.classList.add('hidden');
    }
    checkWotdInMwb(word.word);
  }

  var cached = getWotdCache();
  if (cached) { renderWotd(cached); document.getElementById('wotd-cache-status').textContent = 'from cache'; }

  // Track current viewing date for navigation
  var wotdCurrentDate = new Date().toISOString().split('T')[0];
  var wotdToday = wotdCurrentDate;

  // Initial state — disable next button since we start on today
  (function() {
    var nextBtn = document.getElementById('wotd-next');
    if (nextBtn) {
      nextBtn.disabled = true;
      nextBtn.classList.add('opacity-30', 'cursor-not-allowed');
      nextBtn.classList.remove('hover:bg-purple-600/30', 'hover:border-purple-400');
    }
  })();

  function updateViewingDate(date) {
    var el = document.getElementById('wotd-viewing-date');
    if (!el) return;
    if (date === wotdToday) {
      el.textContent = 'Today';
      el.className = 'text-xs text-purple-300/60 mb-3 font-mono';
    } else {
      el.textContent = date;
      el.className = 'text-xs text-purple-300/60 mb-3 font-mono cursor-pointer hover:text-purple-300';
      el.title = 'Click to return to today';
      el.onclick = function() { navigateWotd(wotdToday); };
    }
  }

  function navigateWotd(date) {
    wotdCurrentDate = date;
    updateViewingDate(date);
    updateNextBtnState();
    // Disable nav buttons during fetch
    var prevBtn = document.getElementById('wotd-prev');
    var nextBtn = document.getElementById('wotd-next');
    if (prevBtn) prevBtn.disabled = true;
    if (nextBtn) nextBtn.disabled = true;

    fetch('/api/wotd/?date=' + date).then(function(r) {
      if (r.status === 404) {
        document.getElementById('wotd-word').textContent = '—';
        document.getElementById('wotd-meaning').textContent = 'No word for this date';
        var enrichedEl = document.getElementById('wotd-enriched');
        if (enrichedEl) enrichedEl.classList.add('hidden');
        return;
      }
      return r.json();
    }).then(function(d) {
      if (d && d.word) {
        renderWotd(d.word);
        updateViewingDate(d.word.date || date);
        // Reset workbench button state
        var btn = document.getElementById('wotd-add-workbench');
        if (btn) {
          btn.textContent = 'Save to WordBench ✗';
          btn.className = 'px-4 py-2 rounded-lg bg-red-600/20 border border-red-500/50 text-sm text-red-400 hover:bg-red-600/40 transition-colors';
        }
        // Reset explore button (hide enriched, show button again)
        var exploreBtn = document.getElementById('wotd-explore-btn');
        var enrichedEl = document.getElementById('wotd-enriched');
        if (enrichedEl) enrichedEl.classList.add('hidden');
        // Hide languages section until re-explored
        var langEl = document.getElementById('wotd-languages');
        if (langEl) langEl.classList.add('hidden');
        checkWotdInMwb(d.word.word);
      }
    }).catch(function() {}).finally(function() {
      if (prevBtn) prevBtn.disabled = false;
      if (nextBtn) nextBtn.disabled = false;
      updateNextBtnState();
    });
  }

  // Navigation button handlers
  function updateNextBtnState() {
    var nextBtn = document.getElementById('wotd-next');
    if (!nextBtn) return;
    if (wotdCurrentDate >= wotdToday) {
      nextBtn.disabled = true;
      nextBtn.classList.add('opacity-30', 'cursor-not-allowed');
      nextBtn.classList.remove('hover:bg-purple-600/30', 'hover:border-purple-400');
    } else {
      nextBtn.disabled = false;
      nextBtn.classList.remove('opacity-30', 'cursor-not-allowed');
      nextBtn.classList.add('hover:bg-purple-600/30', 'hover:border-purple-400');
    }
  }

  document.getElementById('wotd-prev').addEventListener('click', function() {
    var d = new Date(wotdCurrentDate + 'T12:00:00Z');
    d.setUTCDate(d.getUTCDate() - 1);
    navigateWotd(d.toISOString().split('T')[0]);
  });

  document.getElementById('wotd-next').addEventListener('click', function() {
    // Don't navigate past today
    if (wotdCurrentDate >= wotdToday) return;
    var d = new Date(wotdCurrentDate + 'T12:00:00Z');
    d.setUTCDate(d.getUTCDate() + 1);
    // Cap at today
    var target = d.toISOString().split('T')[0];
    if (target > wotdToday) target = wotdToday;
    navigateWotd(target);
  });

  fetch('/api/wotd/').then(function(r) { return r.json(); }).then(function(d) {
    if (d.word) {
      renderWotd(d.word);
      setWotdCache(d.word, d.expiresAt);
      document.getElementById('wotd-cache-status').textContent = 'live';
      wotdCurrentDate = d.word.date || wotdToday;
      updateViewingDate(wotdCurrentDate);
      updateNextBtnState();
    }
  }).catch(function() {
    if (!cached) document.getElementById('wotd-meaning').textContent = 'Could not load — try refreshing';
    document.getElementById('wotd-cache-status').textContent = 'offline (cached)';
  });

  // ── Explore WOTD Button ──
  document.getElementById('wotd-explore-btn').addEventListener('click', function() {
    var enrichedEl = document.getElementById('wotd-enriched');
    if (enrichedEl) {
      enrichedEl.classList.remove('hidden');
      this.classList.add('hidden');
      // Store the WOTD date (keyed by URL) so the button stays hidden until the next day's word
      var wotdDate = document.getElementById('wotd-date').textContent || new Date().toISOString().split('T')[0];
      S.setRaw('swf-wotd-explored:' + window.location.pathname, wotdDate);
      // Fetch multilingual translations
      fetchWotdLanguages();
    }
  });

  document.getElementById('wotd-fetch-meaning').addEventListener('click', async function() {
    var word = document.getElementById('wotd-word').textContent.toLowerCase();
    if (!word || word === '—') return;
    this.textContent = '...';
    try {
      var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word);
      if (res.ok) {
        var data = await res.json();
        var meaning = data[0]?.meanings?.[0]?.definitions?.[0]?.definition || 'No definition found';
        document.getElementById('wotd-meaning').textContent = meaning;
        var c = getWotdCache(); if (c) { c.meaning = meaning; setWotdCache(c); }
        fetch('/api/wotd/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ word: word.toUpperCase(), meaning: meaning }) });
      }
    } catch(e) {}
    this.textContent = '📖 Lookup';
  });

  document.getElementById('wotd-add-workbench').addEventListener('click', function() {
    var word = document.getElementById('wotd-word').textContent;
    if (!word || word === '—') return;
    var saved = JSON.parse(S.getRaw('scbAchievements') || '[]');
    if (saved.find(function(s) { return s.word === word; })) {
      this.textContent = 'Saved ✓';
      this.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
      return;
    }
    saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent, dateAdded: new Date().toISOString() });
    S.setRaw('scbAchievements', JSON.stringify(saved));
    this.textContent = 'Saved ✓';
    this.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
    // Notify MWB to refresh immediately
    document.dispatchEvent(new CustomEvent('mwb-updated'));
    // Award WOTD star — saving the word is sufficient, meaning lookup is not required
    window.__awardStar && window.__awardStar('wotd');
  });

  // ── WOTD Countdown Timer ──
  (function startCountdown() {
    var el = document.getElementById('wotd-countdown');
    function update() {
      var now = new Date();
      var tomorrow = new Date(now);
      tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
      tomorrow.setUTCHours(0, 0, 0, 0);
      var diff = tomorrow - now;
      if (diff <= 0) { el.textContent = 'New word!'; return; }
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      el.textContent = 'Next WOTD in ' + h + 'h ' + (m < 10 ? '0' : '') + m + 'm ' + (s < 10 ? '0' : '') + s + 's';
    }
    update();
    setInterval(update, 1000);
  })();

  // ── WOTD History Panel ──
  var wotdHistBtn = document.getElementById('wotd-history-btn');
  var wotdHistPanel = document.getElementById('wotd-history-panel');
  var wotdHistClose = document.getElementById('wotd-history-close');

  function renderWotdHistory() {
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var wotdWords = saved.filter(function(w) { return w.category === 'wotd'; });
    // Sort by date descending (newest first)
    wotdWords.sort(function(a, b) { return (b.dateAdded || '').localeCompare(a.dateAdded || ''); });

    var emptyEl = document.getElementById('wotd-history-empty');
    var contentEl = document.getElementById('wotd-history-content');
    var bodyEl = document.getElementById('wotd-history-body');

    if (wotdWords.length === 0) {
      emptyEl.classList.remove('hidden');
      contentEl.classList.add('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    var html = '';
    wotdWords.forEach(function(w) {
      var date = w.dateAdded ? w.dateAdded.split('T')[0] : '—';
      var meaning = w.meaning || '—';
      if (meaning.length > 60) meaning = meaning.substring(0, 57) + '...';
      html += '<tr class="hover:bg-gray-800/50">' +
        '<td class="px-2 py-1.5 font-bold text-purple-300">' + (w.word || '—') + '</td>' +
        '<td class="px-2 py-1.5 text-gray-400 italic">' + meaning + '</td>' +
        '<td class="px-2 py-1.5 text-gray-500 whitespace-nowrap">' + date + '</td>' +
      '</tr>';
    });
    bodyEl.innerHTML = html;
  }

  if (wotdHistBtn) {
    wotdHistBtn.addEventListener('click', function() {
      if (wotdHistPanel.classList.contains('hidden')) {
        renderWotdHistory();
        wotdHistPanel.classList.remove('hidden');
      } else {
        wotdHistPanel.classList.add('hidden');
      }
    });
  }

  if (wotdHistClose) {
    wotdHistClose.addEventListener('click', function() {
      wotdHistPanel.classList.add('hidden');
    });
  }

  // ── WOTD History "Add to WordBench" button ──
  var wotdHistAddBtn = document.getElementById('wotd-history-add-btn');
  if (wotdHistAddBtn) {
    wotdHistAddBtn.addEventListener('click', function() {
      var word = document.getElementById('wotd-word').textContent;
      if (!word || word === '—') return;
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      if (saved.find(function(s) { return s.word === word; })) {
        wotdHistAddBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Already saved';
        wotdHistAddBtn.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-green-500/50 bg-green-900/20 text-green-300 text-xs font-medium transition-all';
        return;
      }
      saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent || '', dateAdded: new Date().toISOString() });
      localStorage.setItem('scbAchievements', JSON.stringify(saved));
      wotdHistAddBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Saved!';
      wotdHistAddBtn.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-green-500/50 bg-green-900/20 text-green-300 text-xs font-medium transition-all';
      // Notify MWB to refresh + award WOTD star
      document.dispatchEvent(new CustomEvent('mwb-updated'));
      window.__awardStar && window.__awardStar('wotd');
      // Re-render history to show the new word
      renderWotdHistory();
    });
  }

  // ── Memorised Checkbox ──
  var memorisedCheckbox = document.getElementById('wotd-memorised-checkbox');
  var memorisedLabel = document.getElementById('wotd-memorised-label');

  // Load memorised words for this user on init
  var memorisedWordsSet = new Set();
  (function loadMemorisedWords() {
    if (!uid) return;
    fetch('/api/memorised-words/?userid=' + encodeURIComponent(uid))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        (data.words || []).forEach(function(w) { memorisedWordsSet.add(w.word); });
        // Check current word
        syncMemorisedCheckbox();
      }).catch(function() {});
  })();

  function syncMemorisedCheckbox() {
    if (!memorisedCheckbox) return;
    var word = document.getElementById('wotd-word').textContent;
    if (!word || word === '—') {
      memorisedCheckbox.checked = false;
      memorisedCheckbox.disabled = true;
      return;
    }
    memorisedCheckbox.disabled = false;
    memorisedCheckbox.checked = memorisedWordsSet.has(word.toUpperCase());
  }

  // Sync checkbox when WOTD changes (navigation, initial load)
  var origRenderWotd = renderWotd;
  renderWotd = function(word) {
    origRenderWotd(word);
    syncMemorisedCheckbox();
  };

  if (memorisedCheckbox) {
    memorisedCheckbox.addEventListener('change', function() {
      var word = document.getElementById('wotd-word').textContent;
      if (!word || word === '—' || !uid) return;

      var checked = memorisedCheckbox.checked;
      memorisedCheckbox.disabled = true;

      if (checked) {
        // Add to memorised
        fetch('/api/memorised-words/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userid: uid, word: word })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.success) {
            memorisedWordsSet.add(word.toUpperCase());
          } else {
            memorisedCheckbox.checked = false;
          }
        }).catch(function() {
          memorisedCheckbox.checked = false;
        }).finally(function() {
          memorisedCheckbox.disabled = false;
        });
      } else {
        // Remove from memorised
        fetch('/api/memorised-words/', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userid: uid, word: word })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.success) {
            memorisedWordsSet.delete(word.toUpperCase());
          } else {
            memorisedCheckbox.checked = true;
          }
        }).catch(function() {
          memorisedCheckbox.checked = true;
        }).finally(function() {
          memorisedCheckbox.disabled = false;
        });
      }
    });
  }

})();
</script>
