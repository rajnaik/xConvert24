      <!-- Panel 1: Word of the Day -->
      <div class="rounded-xl border border-purple-800/50 bg-gray-900/50 p-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><span>📖</span> Word of the Day <span class="star-indicator text-sm opacity-40 cursor-help" data-game="wotd" title="⭐ Earn star: Add WOTD to Memory WordBench (auto-awarded if already saved)">⭐</span><span class="star-tick hidden text-green-400 text-sm font-bold" data-game="wotd">✅</span>
          <button id="wotd-history-btn" class="ml-auto w-7 h-7 flex items-center justify-center rounded-full border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all" title="WOTD History">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
        </h2>
        <div id="wotd-panel">
          <div class="text-center py-8">
            <p id="wotd-word" class="text-4xl font-black text-purple-400 tracking-wider mb-3">—</p>
            <p id="wotd-meaning" class="text-sm text-gray-300 italic mb-4">Loading today's word...</p>
            <p id="wotd-fact" class="text-xs text-gray-500 mb-4"></p>
            <div class="flex items-center justify-center gap-3">
              <button id="wotd-add-workbench" class="px-4 py-2 rounded-lg bg-red-600/20 border border-red-500/50 text-sm text-red-400 hover:bg-red-600/40 transition-colors">
                Save to WordBench ✗
              </button>
              <button id="wotd-fetch-meaning" class="px-3 py-2 rounded-lg bg-blue-600/30 border border-blue-500/50 text-sm text-blue-300 hover:bg-blue-600/50 transition-colors">
                📖 Lookup
              </button>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-gray-800">
            <p class="text-xs text-center"><span id="wotd-date" class="hidden"></span><span id="wotd-cache-status" class="hidden"></span><span id="wotd-countdown" class="text-purple-400 font-mono"></span></p>
          </div>
        </div>
        <!-- WOTD History Panel (toggled by history button) -->
        <div id="wotd-history-panel" class="hidden mt-4 rounded-xl border border-purple-800/50 bg-gray-900/80 p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-purple-300 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              WOTD History
            </h3>
            <button id="wotd-history-close" class="text-gray-500 hover:text-white text-lg leading-none">&times;</button>
          </div>
          <div id="wotd-history-empty" class="hidden text-center py-4">
            <p class="text-xs text-gray-500 mb-3">No WOTD history yet. Words appear here as you save them.</p>
            <button id="wotd-history-add-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 text-xs font-medium transition-all" title="Add today's WOTD to Memory WordBench">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
              Add WOTD to WordBench
            </button>
          </div>
          <div id="wotd-history-content" class="hidden">
            <div class="overflow-x-auto max-h-64 overflow-y-auto">
              <table class="w-full text-xs border border-gray-700 rounded overflow-hidden">
                <thead class="bg-gray-800 sticky top-0">
                  <tr>
                    <th class="px-2 py-1.5 text-left text-gray-400">Word</th>
                    <th class="px-2 py-1.5 text-left text-gray-400">Meaning</th>
                    <th class="px-2 py-1.5 text-left text-gray-400">Date</th>
                  </tr>
                </thead>
                <tbody id="wotd-history-body" class="divide-y divide-gray-800"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

<script is:inline>
(function() {
    var uid = localStorage.getItem('swf-uid') || '';

    // Show "use workbench words" option if user has saved words with meanings
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var wordsWithMeaning = saved.filter(function(w) {
      if (!w.meaning || !w.meaning.trim()) return false;
      var m = w.meaning.toLowerCase();
      if (m.indexOf('scrabble-legal word') !== -1) return false;
      if (m.indexOf('no standard definition') !== -1) return false;
      return true;
    });
    if (wordsWithMeaning.length >= 3) {
      var wbLabel = document.getElementById('quiz-from-workbench-label');
      if (wbLabel) wbLabel.classList.remove('hidden');
    }

    if (uid) {
      fetch('/api/quiz-scores/?user_id=' + encodeURIComponent(uid))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var scores = data.scores || [];
          if (scores.length === 0) return;
          var btn = document.getElementById('quiz-history-btn');
          if (btn) { btn.classList.remove('hidden'); btn.style.display = 'flex'; }
          var countEl = document.getElementById('quiz-history-count');
          if (countEl) countEl.textContent = scores.length;
        }).catch(function() {});
    }

  // ── Word of the Day (with 24h localStorage cache) ──
  var WOTD_CACHE_KEY = 'swf-wotd-cache';
  var WOTD_CACHE_TTL = 24 * 60 * 60 * 1000;

  function getWotdCache() {
    try {
      var cached = JSON.parse(localStorage.getItem(WOTD_CACHE_KEY));
      if (cached && Date.now() - cached.ts < WOTD_CACHE_TTL) return cached.data;
    } catch(e) {}
    return null;
  }

  function setWotdCache(data) {
    localStorage.setItem(WOTD_CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data }));
  }

  function checkWotdInMwb(word) {
    if (!word || word === '—') return;
    var mwb = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var alreadySaved = mwb.find(function(s) { return s.word === word; });
    if (alreadySaved) {
      var btn = document.getElementById('wotd-add-workbench');
      if (btn) {
        btn.textContent = 'Saved ✓';
        btn.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
      }
      // Auto-award star — word was already saved before this WOTD session
      window.__awardStar && window.__awardStar('wotd');
    }
  }

  function renderWotd(word) {
    document.getElementById('wotd-word').textContent = word.word || '—';
    document.getElementById('wotd-meaning').textContent = word.meaning || 'Tap "Lookup" to fetch the meaning';
    document.getElementById('wotd-fact').textContent = word.fun_fact || '';
    document.getElementById('wotd-date').textContent = word.date || new Date().toISOString().split('T')[0];
    checkWotdInMwb(word.word);
  }

  var cached = getWotdCache();
  if (cached) { renderWotd(cached); document.getElementById('wotd-cache-status').textContent = 'from cache'; }

  fetch('/api/wotd/').then(function(r) { return r.json(); }).then(function(d) {
    if (d.word) { renderWotd(d.word); setWotdCache(d.word); document.getElementById('wotd-cache-status').textContent = 'live'; }
  }).catch(function() {
    if (!cached) document.getElementById('wotd-meaning').textContent = 'Could not load — try refreshing';
    document.getElementById('wotd-cache-status').textContent = 'offline (cached)';
  });

  document.getElementById('wotd-fetch-meaning').addEventListener('click', async function() {
    var word = document.getElementById('wotd-word').textContent.toLowerCase();
    if (!word || word === '—') return;
    this.textContent = '...';
    try {
      var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word);
      if (res.ok) {
        var data = await res.json();
        var meaning = data[0]?.meanings?.[0]?.definitions?.[0]?.definition || 'No definition found';
        document.getElementById('wotd-meaning').textContent = meaning;
        var c = getWotdCache(); if (c) { c.meaning = meaning; setWotdCache(c); }
        fetch('/api/wotd/', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ word: word.toUpperCase(), meaning: meaning }) });
      }
    } catch(e) {}
    this.textContent = '📖 Lookup';
  });

  document.getElementById('wotd-add-workbench').addEventListener('click', function() {
    var word = document.getElementById('wotd-word').textContent;
    if (!word || word === '—') return;
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    if (saved.find(function(s) { return s.word === word; })) {
      this.textContent = 'Saved ✓';
      this.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
      return;
    }
    saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent, dateAdded: new Date().toISOString() });
    localStorage.setItem('scbAchievements', JSON.stringify(saved));
    this.textContent = 'Saved ✓';
    this.className = 'px-4 py-2 rounded-lg bg-green-600/20 border border-green-500/50 text-sm text-green-400 transition-colors';
    // Notify MWB to refresh immediately
    document.dispatchEvent(new CustomEvent('mwb-updated'));
    // Award WOTD star — saving the word is sufficient, meaning lookup is not required
    window.__awardStar && window.__awardStar('wotd');
  });

  // ── WOTD Countdown Timer ──
  (function startCountdown() {
    var el = document.getElementById('wotd-countdown');
    function update() {
      var now = new Date();
      var tomorrow = new Date(now);
      tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
      tomorrow.setUTCHours(0, 0, 0, 0);
      var diff = tomorrow - now;
      if (diff <= 0) { el.textContent = 'New word!'; return; }
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      el.textContent = 'Next WOTD in ' + h + 'h ' + (m < 10 ? '0' : '') + m + 'm ' + (s < 10 ? '0' : '') + s + 's';
    }
    update();
    setInterval(update, 1000);
  })();

  // ── WOTD History Panel ──
  var wotdHistBtn = document.getElementById('wotd-history-btn');
  var wotdHistPanel = document.getElementById('wotd-history-panel');
  var wotdHistClose = document.getElementById('wotd-history-close');

  function renderWotdHistory() {
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var wotdWords = saved.filter(function(w) { return w.category === 'wotd'; });
    // Sort by date descending (newest first)
    wotdWords.sort(function(a, b) { return (b.dateAdded || '').localeCompare(a.dateAdded || ''); });

    var emptyEl = document.getElementById('wotd-history-empty');
    var contentEl = document.getElementById('wotd-history-content');
    var bodyEl = document.getElementById('wotd-history-body');

    if (wotdWords.length === 0) {
      emptyEl.classList.remove('hidden');
      contentEl.classList.add('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    var html = '';
    wotdWords.forEach(function(w) {
      var date = w.dateAdded ? w.dateAdded.split('T')[0] : '—';
      var meaning = w.meaning || '—';
      if (meaning.length > 60) meaning = meaning.substring(0, 57) + '...';
      html += '<tr class="hover:bg-gray-800/50">' +
        '<td class="px-2 py-1.5 font-bold text-purple-300">' + (w.word || '—') + '</td>' +
        '<td class="px-2 py-1.5 text-gray-400 italic">' + meaning + '</td>' +
        '<td class="px-2 py-1.5 text-gray-500 whitespace-nowrap">' + date + '</td>' +
      '</tr>';
    });
    bodyEl.innerHTML = html;
  }

  if (wotdHistBtn) {
    wotdHistBtn.addEventListener('click', function() {
      if (wotdHistPanel.classList.contains('hidden')) {
        renderWotdHistory();
        wotdHistPanel.classList.remove('hidden');
      } else {
        wotdHistPanel.classList.add('hidden');
      }
    });
  }

  if (wotdHistClose) {
    wotdHistClose.addEventListener('click', function() {
      wotdHistPanel.classList.add('hidden');
    });
  }

  // ── WOTD History "Add to WordBench" button ──
  var wotdHistAddBtn = document.getElementById('wotd-history-add-btn');
  if (wotdHistAddBtn) {
    wotdHistAddBtn.addEventListener('click', function() {
      var word = document.getElementById('wotd-word').textContent;
      if (!word || word === '—') return;
      var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
      if (saved.find(function(s) { return s.word === word; })) {
        wotdHistAddBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Already saved';
        wotdHistAddBtn.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-green-500/50 bg-green-900/20 text-green-300 text-xs font-medium transition-all';
        return;
      }
      saved.push({ word: word, score: 0, category: 'wotd', meaning: document.getElementById('wotd-meaning').textContent || '', dateAdded: new Date().toISOString() });
      localStorage.setItem('scbAchievements', JSON.stringify(saved));
      wotdHistAddBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Saved!';
      wotdHistAddBtn.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border-2 border-green-500/50 bg-green-900/20 text-green-300 text-xs font-medium transition-all';
      // Notify MWB to refresh + award WOTD star
      document.dispatchEvent(new CustomEvent('mwb-updated'));
      window.__awardStar && window.__awardStar('wotd');
      // Re-render history to show the new word
      renderWotdHistory();
    });
  }

})();
</script>
