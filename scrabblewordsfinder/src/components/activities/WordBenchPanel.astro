<script is:inline>
(function() {
  // ── Memory WordBench ──
  var fcState = { words: [], current: 0, flipped: false, active: false, activeCategory: null };

  var catColors = {
    'wotd': { border: 'border-purple-500/50', bg: 'bg-purple-900/20', text: 'text-purple-300', label: '📖 Word of the Day' },
    'quiz': { border: 'border-blue-500/50', bg: 'bg-blue-900/20', text: 'text-blue-300', label: '🧠 Quiz' },
    'manual': { border: 'border-amber-500/50', bg: 'bg-amber-900/20', text: 'text-amber-300', label: '⭐ Saved' },
    'solver': { border: 'border-green-500/50', bg: 'bg-green-900/20', text: 'text-green-300', label: '🔍 Solver' },
    'default': { border: 'border-gray-500/50', bg: 'bg-gray-900/20', text: 'text-gray-300', label: '📝 Other' }
  };

  function getCatStyle(cat) { return catColors[cat] || catColors['default']; }

  function shuffleArray(arr) {
    var copy = arr.slice();
    for (var i = copy.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = copy[i]; copy[i] = copy[j]; copy[j] = tmp;
    }
    return copy;
  }

  function renderFlashCard() {
    var card = document.getElementById('fc-card');
    var wordEl = document.getElementById('fc-word');
    var meaningEl = document.getElementById('fc-meaning');
    var hintEl = document.getElementById('fc-hint');
    var counterEl = document.getElementById('fc-counter');
    var scoreEl = document.getElementById('fc-score');
    var actionsEl = document.getElementById('fc-actions');

    if (fcState.words.length === 0) return;

    var w = fcState.words[fcState.current];
    var style = getCatStyle(w.category || 'manual');

    // Calculate score
    var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
    var pts = (w.word || '').split('').reduce(function(s, c) { return s + (scores[c.toUpperCase()] || 0); }, 0);

    // Reset flip state
    fcState.flipped = false;
    wordEl.textContent = w.word || '?';
    wordEl.style.fontSize = '';
    wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
    scoreEl.textContent = pts + ' pts';
    scoreEl.classList.remove('hidden');
    meaningEl.textContent = w.meaning || 'No meaning saved';
    meaningEl.classList.add('hidden');
    hintEl.textContent = 'tap to flip';
    hintEl.classList.remove('hidden');
    counterEl.textContent = (fcState.current + 1) + ' / ' + fcState.words.length;

    // Show actions + controls
    actionsEl.classList.remove('hidden');
    document.getElementById('fc-speed-wrap').classList.remove('hidden');

    // Apply category colour to card border
    card.className = 'mx-auto w-full max-w-sm h-48 rounded-2xl border-2 flex flex-col items-center justify-center cursor-pointer transition-all select-none ' + style.border + ' ' + style.bg + ' hover:scale-[1.02]';

    // Animate card entry
    card.style.opacity = '0';
    card.style.transform = 'rotateY(90deg)';
    requestAnimationFrame(function() {
      card.style.transition = 'opacity 0.3s, transform 0.3s';
      card.style.opacity = '1';
      card.style.transform = 'rotateY(0deg)';
    });
  }

  function flipCard() {
    var wordEl = document.getElementById('fc-word');
    var meaningEl = document.getElementById('fc-meaning');
    var hintEl = document.getElementById('fc-hint');
    var card = document.getElementById('fc-card');

    fcState.flipped = !fcState.flipped;

    if (fcState.flipped) {
      card.style.transition = 'transform 0.2s';
      card.style.transform = 'rotateY(90deg)';
      setTimeout(function() {
        meaningEl.classList.remove('hidden');
        hintEl.textContent = 'tap to see word';
        wordEl.style.fontSize = '1.2rem';
        wordEl.className = 'font-black tracking-wider mb-2 text-gray-500';
        card.style.transform = 'rotateY(0deg)';
      }, 200);
    } else {
      card.style.transition = 'transform 0.2s';
      card.style.transform = 'rotateY(90deg)';
      setTimeout(function() {
        meaningEl.classList.add('hidden');
        hintEl.textContent = 'tap to flip';
        wordEl.style.fontSize = '';
        var style = getCatStyle((fcState.words[fcState.current] || {}).category || 'manual');
        wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
        card.style.transform = 'rotateY(0deg)';
      }, 200);
    }
  }

  // Reusable filter: returns true if a word has a "real" meaning
  function hasMeaningfulDef(w) {
    if (!w.meaning || w.meaning.trim() === '') return false;
    var m = w.meaning.toLowerCase();
    if (m === 'no meaning saved') return false;
    if (m.indexOf('scrabble-legal word') !== -1) return false;
    if (m.indexOf('no standard definition') !== -1) return false;
    var generics = [
      'a type of plant found in tropical regions','to move swiftly in a specified direction',
      'a container used for storage','relating to the process of growth',
      'a sound made by striking two objects','to arrange in a particular order',
      'a feeling of deep satisfaction','the outer covering of a seed',
      'to reduce in size or quantity','a tool used for cutting',
      'relating to water or moisture','a method of preparation',
      'to express disapproval strongly','the quality of being bright',
      'a passage between rooms or buildings','to combine separate elements',
      'relating to the earth or soil','a measurement of distance',
      'to make a continuous low sound','a type of fabric or textile'
    ];
    if (generics.indexOf(m) !== -1) return false;
    return true;
  }

  function startFlashCards(filterCategory, autoPlay) {
    var saved = JSON.parse(window.__swfStore.getRaw('scbAchievements') || '[]');
    if (saved.length === 0) {
      var emptyEl = document.getElementById('fc-empty');
      emptyEl.innerHTML = '<div class="space-y-3 text-center py-2">' +
        '<p class="text-sm text-gray-300 font-medium">No words saved yet!</p>' +
        '<p class="text-xs text-gray-400">Import all essential Scrabble word lists in one click:</p>' +
        '<button id="fc-import-all-btn" class="mt-3 px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 hover:border-purple-400 transition-colors font-medium">📥 Import All Word Lists</button>' +
        '<p class="text-[10px] text-gray-500 mt-3">Imports 2-letter, top 3-letter, Q-without-U, high-scoring by length, and rare letter words with categories.</p>' +
      '</div>';
      emptyEl.classList.remove('hidden');
      bindImportAllBtn();
      return;
    }
    // Show import prompt when All category has 10 or fewer words
    var importHintEl = document.getElementById('fc-import-hint');
    if (importHintEl) {
      if (saved.length <= 10) {
        importHintEl.innerHTML = '<button id="fc-import-all-btn" class="px-3 py-1 rounded-lg bg-purple-600/30 border border-purple-500/50 text-[11px] text-purple-300 hover:bg-purple-600/50 hover:border-purple-400 transition-colors font-medium">📥 Import All Word Lists</button>';
        importHintEl.classList.remove('hidden');
        bindImportAllBtn();
      } else {
        importHintEl.innerHTML = '';
        importHintEl.classList.add('hidden');
      }
    }

    // Build category filters — counts respect "Meaningful only" checkbox
    var filterReal = document.getElementById('fc-real-meanings').checked;
    var pool = filterReal ? saved.filter(hasMeaningfulDef) : saved;
    var cats = {};
    pool.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
    var filtersEl = document.getElementById('fc-cat-filters');
    if (Object.keys(cats).length > 1 || pool.length > 0) {
      filtersEl.classList.remove('hidden');
      var activeCat = filterCategory || fcState.activeCategory || 'all';
      // If stored category no longer exists in data, fall back to 'all'
      if (activeCat !== 'all' && !cats[activeCat]) activeCat = 'all';
      fcState.activeCategory = activeCat;
      var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
        (activeCat === 'all' ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
        '" data-cat="all">All (' + pool.length + ')</button>';
      Object.keys(cats).sort().forEach(function(c) {
        html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
          (activeCat === c ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
          '" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
      });
      filtersEl.innerHTML = html;
      filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
        btn.addEventListener('click', function() {
          startFlashCards(btn.dataset.cat, true);
        });
      });
    }

    // Apply category filter
    var words = saved;
    var effectiveCat = filterCategory || fcState.activeCategory || 'all';
    if (effectiveCat && effectiveCat !== 'all') {
      words = saved.filter(function(w) { return (w.category || 'manual') === effectiveCat; });
    }

    // Filter to words with real meanings if checkbox is checked
    if (filterReal) {
      var meaningWords = words.filter(hasMeaningfulDef);
      // If meaningful filter empties the deck for a specific category, skip the filter
      if (meaningWords.length > 0) {
        words = meaningWords;
      }
    }

    if (words.length === 0) {
      document.getElementById('fc-empty').textContent = 'No words with real meanings in this category. Use "📖 Lookup" on Word of the Day or click words in the solver to fetch definitions.';
      document.getElementById('fc-empty').classList.remove('hidden');
      document.getElementById('fc-card').classList.add('hidden');
      document.getElementById('fc-controls').classList.add('hidden');
      return;
    }

    fcState.words = shuffleArray(words);
    fcState.current = 0;
    fcState.active = true;

    document.getElementById('fc-empty').classList.add('hidden');
    document.getElementById('fc-card').classList.remove('hidden');
    document.getElementById('fc-controls').classList.remove('hidden');
    document.getElementById('fc-controls').style.display = 'flex';
    document.getElementById('fc-start-btn').textContent = '🔀 Shuffle';

    renderFlashCard();

    // Auto-start playback when triggered from category tab click
    if (autoPlay) {
      var checkbox = document.getElementById('fc-autoplay');
      var apBtn = document.getElementById('fc-autoplay-btn');
      if (!checkbox.checked) {
        checkbox.checked = true;
        document.getElementById('fc-speed-wrap').classList.remove('hidden');
        apBtn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
        fcTimerStart = Date.now();
        document.getElementById('fc-timer').classList.remove('hidden');
        fcTimerInterval = setInterval(function() {
          var elapsed = Math.floor((Date.now() - fcTimerStart) / 1000);
          var mins = Math.floor(elapsed / 60);
          var secs = elapsed % 60;
          document.getElementById('fc-timer').textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
        }, 1000);
      }
      autoPlayCardsAdvanced = 0;
      startAutoPlay();
    }
  }

  document.getElementById('fc-start-btn').addEventListener('click', function() { startFlashCards(); });

  // ── Import All Word Lists ───────────────────────────────────────────────
  function bindImportAllBtn() {
    var btn = document.getElementById('fc-import-all-btn');
    if (!btn) return;
    btn.addEventListener('click', function() {
      btn.disabled = true;
      btn.textContent = '⏳ Loading dictionary…';
      Promise.all([
        fetch('/data/sowpods-2-7.json').then(function(r) { return r.json(); }),
        fetch('/data/swfdict.json').then(function(r) { return r.json(); }).catch(function() { return {}; })
      ])
        .then(function(results) {
          var words = results[0];
          var meanings = results[1];
          var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
          function wScore(w) { return w.split('').reduce(function(s, c) { return s + (scores[c.toUpperCase()] || 0); }, 0); }

          // Build categorised word lists
          var twoLetter = words.filter(function(w) { return w.length === 2; }).sort();
          var threeLetter = words.filter(function(w) { return w.length === 3; })
            .map(function(w) { return { word: w, score: wScore(w) }; })
            .sort(function(a, b) { return b.score - a.score; })
            .slice(0, 30)
            .map(function(w) { return w.word; });
          var qNoU = words.filter(function(w) { return w.indexOf('q') !== -1 && w.indexOf('u') === -1; }).sort();
          var rareQ = words.filter(function(w) { return w.indexOf('q') !== -1; })
            .map(function(w) { return { word: w, score: wScore(w) }; })
            .sort(function(a, b) { return b.score - a.score; })
            .slice(0, 40)
            .map(function(w) { return w.word; });
          var rareZ = words.filter(function(w) { return w.indexOf('z') !== -1; })
            .map(function(w) { return { word: w, score: wScore(w) }; })
            .sort(function(a, b) { return b.score - a.score; })
            .slice(0, 40)
            .map(function(w) { return w.word; });
          var rareX = words.filter(function(w) { return w.indexOf('x') !== -1; })
            .map(function(w) { return { word: w, score: wScore(w) }; })
            .sort(function(a, b) { return b.score - a.score; })
            .slice(0, 40)
            .map(function(w) { return w.word; });
          var rareJ = words.filter(function(w) { return w.indexOf('j') !== -1; })
            .map(function(w) { return { word: w, score: wScore(w) }; })
            .sort(function(a, b) { return b.score - a.score; })
            .slice(0, 40)
            .map(function(w) { return w.word; });

          // High-Scoring Words by Length (top 5 per length 2-5, matches solver panel)
          var highScoring = [];
          [2, 3, 4, 5].forEach(function(len) {
            words.filter(function(w) { return w.length === len; })
              .map(function(w) { return { word: w, score: wScore(w) }; })
              .sort(function(a, b) { return b.score - a.score; })
              .slice(0, 5)
              .forEach(function(item) { highScoring.push(item.word); });
          });

          // Merge rare letters (deduplicate)
          var rareSet = {};
          rareQ.concat(rareZ).concat(rareX).concat(rareJ).forEach(function(w) { rareSet[w] = true; });
          var rareAll = Object.keys(rareSet);

          // Build category map: word → category
          var toImport = [];
          var seen = {};

          twoLetter.forEach(function(w) { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'two-letter' }); } });
          threeLetter.forEach(function(w) { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'three-letter' }); } });
          qNoU.forEach(function(w) { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'q-without-u' }); } });
          highScoring.forEach(function(w) { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'high-scoring' }); } });
          rareAll.forEach(function(w) { if (!seen[w]) { seen[w] = true; toImport.push({ word: w, category: 'rare-letters' }); } });

          // Load existing achievements and merge
          var existing = JSON.parse(window.__swfStore.getRaw('scbAchievements') || '[]');
          var existingWords = {};
          existing.forEach(function(a) { existingWords[a.word] = true; });

          var imported = 0;
          var now = new Date().toISOString();
          toImport.forEach(function(item) {
            if (!existingWords[item.word]) {
              var def = meanings[item.word.toLowerCase()] || '';
              existing.unshift({ word: item.word, meaning: def, category: item.category, dateAdded: now });
              existingWords[item.word] = true;
              imported++;
            }
          });

          window.__swfStore.setRaw('scbAchievements', JSON.stringify(existing));

          // Update UI
          btn.textContent = '✅ Imported ' + imported + ' words!';
          btn.className = 'mt-3 px-4 py-2 rounded-lg bg-green-600/30 border border-green-500/50 text-sm text-green-300 font-medium';


          // Refresh the panel after short delay
          setTimeout(function() {
            refreshWordBench();
            document.dispatchEvent(new Event('mwb-updated'));
          }, 1500);
        })
        .catch(function(err) {
          btn.textContent = '❌ Failed — try again';
          btn.disabled = false;
          btn.className = 'mt-3 px-4 py-2 rounded-lg bg-red-600/30 border border-red-500/50 text-sm text-red-300 hover:bg-red-600/50 transition-colors font-medium';
          console.error('[MWB] Import All failed:', err);
        });
    });
  }

  // Initialize word count and category tabs on load
  function refreshWordBench() {
    var saved = JSON.parse(window.__swfStore.getRaw('scbAchievements') || '[]');
    // Show import prompt when no words saved
    if (saved.length === 0) {
      var emptyEl = document.getElementById('fc-empty');
      emptyEl.innerHTML = '<div class="space-y-3 text-center py-2">' +
        '<p class="text-sm text-gray-300 font-medium">No words saved yet!</p>' +
        '<p class="text-xs text-gray-400">Import all essential Scrabble word lists in one click:</p>' +
        '<button id="fc-import-all-btn" class="mt-3 px-4 py-2 rounded-lg bg-purple-600/30 border border-purple-500/50 text-sm text-purple-300 hover:bg-purple-600/50 hover:border-purple-400 transition-colors font-medium">📥 Import All Word Lists</button>' +
        '<p class="text-[10px] text-gray-500 mt-3">Imports 2-letter, top 3-letter, Q-without-U, high-scoring by length, and rare letter words with categories.</p>' +
      '</div>';
      emptyEl.classList.remove('hidden');
      bindImportAllBtn();
      return;
    }
    // Show/hide import hint when All category has 10 or fewer words
    var importHintEl = document.getElementById('fc-import-hint');
    if (importHintEl) {
      if (saved.length <= 10) {
        importHintEl.innerHTML = '<button id="fc-import-all-btn" class="px-3 py-1 rounded-lg bg-purple-600/30 border border-purple-500/50 text-[11px] text-purple-300 hover:bg-purple-600/50 hover:border-purple-400 transition-colors font-medium">📥 Import All Word Lists</button>';
        importHintEl.classList.remove('hidden');
        bindImportAllBtn();
      } else {
        importHintEl.innerHTML = '';
        importHintEl.classList.add('hidden');
      }
    }
    // Show category tabs immediately
    if (saved.length > 0) {
      var filterReal = document.getElementById('fc-real-meanings').checked;
      var pool = filterReal ? saved.filter(hasMeaningfulDef) : saved;
      var cats = {};
      pool.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
      if (Object.keys(cats).length > 1 || pool.length > 0) {
        var filtersEl = document.getElementById('fc-cat-filters');
        // Reset activeCategory to 'all' so Start button shows all words (not a stale filter)
        fcState.activeCategory = 'all';
        var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-green-500/50 bg-green-900/30 text-green-300" data-cat="all">All (' + pool.length + ')</button>';
        Object.keys(cats).sort().forEach(function(c) {
          html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
        });
        filtersEl.innerHTML = html;
        filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
          btn.addEventListener('click', function() { startFlashCards(btn.dataset.cat, true); });
        });
      }
    }
  }
  refreshWordBench();

  // Rebuild tabs + reload deck when "Meaningful only" is toggled
  document.getElementById('fc-real-meanings').addEventListener('change', function() {
    refreshWordBench();
    if (fcState.active) { startFlashCards(); }
  });

  // Auto-refresh MWB when a word is saved from WOTD or elsewhere
  document.addEventListener('mwb-updated', function() {
    refreshWordBench();
    // If flash cards are active, reload the deck to include new word
    if (fcState.active) { startFlashCards(); }
  });

  // Copy button
  document.getElementById('fc-copy-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    navigator.clipboard.writeText(fcState.words[fcState.current].word).catch(function(){});
    this.textContent = '✓ Copied';
    var self = this;
    setTimeout(function() { self.textContent = '📋 Copy'; }, 1500);
  });

  // Delete button
  document.getElementById('fc-delete-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    var wordToDelete = fcState.words[fcState.current].word;
    var saved = JSON.parse(window.__swfStore.getRaw('scbAchievements') || '[]');
    saved = saved.filter(function(a) { return a.word !== wordToDelete; });
    window.__swfStore.setRaw('scbAchievements', JSON.stringify(saved));
    // Remove from current deck
    fcState.words.splice(fcState.current, 1);
    if (fcState.words.length === 0) {
      document.getElementById('fc-card').classList.add('hidden');
      document.getElementById('fc-controls').classList.add('hidden');
      document.getElementById('fc-actions').classList.add('hidden');
      document.getElementById('fc-empty').classList.remove('hidden');
      fcState.active = false;
    } else {
      if (fcState.current >= fcState.words.length) fcState.current = 0;
      renderFlashCard();
    }
  });

  // Edit button — prompt to edit meaning
  document.getElementById('fc-edit-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    var w = fcState.words[fcState.current];
    var newMeaning = prompt('Edit meaning for ' + w.word + ':', w.meaning || '');
    if (newMeaning === null) return; // cancelled
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var match = saved.find(function(a) { return a.word === w.word; });
    if (match) { match.meaning = newMeaning; localStorage.setItem('scbAchievements', JSON.stringify(saved)); }
    w.meaning = newMeaning;
    if (fcState.flipped) {
      document.getElementById('fc-meaning').textContent = newMeaning || 'No meaning saved';
    }
  });

  // + to Solver button — navigate to solver with the word
  document.getElementById('fc-card').addEventListener('click', function() {
    if (fcState.active) flipCard();
  });

  document.getElementById('fc-prev').addEventListener('click', function() {
    if (!fcState.active || fcState.words.length === 0) return;
    fcState.current = (fcState.current - 1 + fcState.words.length) % fcState.words.length;
    renderFlashCard();
  });

  document.getElementById('fc-next').addEventListener('click', function() {
    if (!fcState.active || fcState.words.length === 0) return;
    fcState.current = (fcState.current + 1) % fcState.words.length;
    renderFlashCard();
  });

  // Keyboard navigation for flash cards
  document.addEventListener('keydown', function(e) {
    if (!fcState.active) return;
    if (e.key === 'ArrowLeft') { stopAutoPlay(); document.getElementById('fc-prev').click(); }
    else if (e.key === 'ArrowRight') { stopAutoPlay(); document.getElementById('fc-next').click(); }
    else if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipCard(); }
  });

  // ── Auto-play ──
  var autoPlayTimer = null;
  var autoPlayPhase = 'word'; // 'word' → show word, 'meaning' → show meaning, then advance

  function getAutoPlaySpeed() {
    return parseInt(document.getElementById('fc-speed').value) * 1000 || 5000;
  }

  // Load saved speed from localStorage
  (function initSpeed() {
    var saved = localStorage.getItem('swf-fc-speed');
    if (saved) {
      document.getElementById('fc-speed').value = saved;
      document.getElementById('fc-speed-label').textContent = saved + 's';
    }
  })();

  function startAutoPlay() {
    if (!fcState.active) { startFlashCards(); }
    if (!fcState.active) return; // still no words
    autoPlayPhase = 'word';
    scheduleNext();
  }

  var autoPlayCardsAdvanced = 0;

  function scheduleNext() {
    clearTimeout(autoPlayTimer);
    var speed = getAutoPlaySpeed();
    autoPlayTimer = setTimeout(function() {
      if (!document.getElementById('fc-autoplay').checked) return;

      if (autoPlayPhase === 'word') {
        // Flip to show meaning
        if (!fcState.flipped) flipCard();
        autoPlayPhase = 'meaning';
        scheduleNext();
      } else {
        // Log the current word to practice history before advancing
        var practiced = fcState.words[fcState.current];
        if (practiced && practiced.word) {
          var uid = localStorage.getItem('swf-uid') || '';
          if (uid) {
            fetch('/api/wordbench-practice/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ user_id: uid, word: practiced.word, meaning: practiced.meaning || '' })
            }).catch(function() {});
          }
        }
        // Advance to next card
        fcState.current = (fcState.current + 1) % fcState.words.length;
        renderFlashCard();
        autoPlayPhase = 'word';
        autoPlayCardsAdvanced++;
        // Award wordbench star after 3 cards
        if (autoPlayCardsAdvanced === 3) { window.__awardStar && window.__awardStar('wordbench'); }
        scheduleNext();
      }
    }, speed);
  }

  var fcTimerInterval = null;
  var fcTimerStart = 0;

  function stopAutoPlay() {
    clearTimeout(autoPlayTimer);
    clearInterval(fcTimerInterval);
    autoPlayTimer = null;
    fcTimerInterval = null;
    document.getElementById('fc-autoplay').checked = false;
    document.getElementById('fc-speed-wrap').classList.add('hidden');
    document.getElementById('fc-timer').classList.add('hidden');
    var btn = document.getElementById('fc-autoplay-btn');
    btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
  }

  // ── Pause autoplay on mouse hover over card, resume on leave ──
  var fcCard = document.getElementById('fc-card');
  var autoPlayPaused = false;
  fcCard.addEventListener('mouseenter', function() {
    if (document.getElementById('fc-autoplay').checked && autoPlayTimer) {
      clearTimeout(autoPlayTimer);
      autoPlayPaused = true;
    }
  });
  fcCard.addEventListener('mouseleave', function() {
    if (autoPlayPaused && document.getElementById('fc-autoplay').checked) {
      autoPlayPaused = false;
      scheduleNext();
    }
  });

  document.getElementById('fc-autoplay-btn').addEventListener('click', function() {
    var checkbox = document.getElementById('fc-autoplay');
    var btn = document.getElementById('fc-autoplay-btn');
    if (!checkbox.checked) {
      checkbox.checked = true;
      document.getElementById('fc-speed-wrap').classList.remove('hidden');
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
      // Start timer
      fcTimerStart = Date.now();
      document.getElementById('fc-timer').classList.remove('hidden');
      fcTimerInterval = setInterval(function() {
        var elapsed = Math.floor((Date.now() - fcTimerStart) / 1000);
        var mins = Math.floor(elapsed / 60);
        var secs = elapsed % 60;
        document.getElementById('fc-timer').textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
      }, 1000);
      startAutoPlay();
    } else {
      checkbox.checked = false;
      document.getElementById('fc-speed-wrap').classList.add('hidden');
      document.getElementById('fc-timer').classList.add('hidden');
      clearTimeout(autoPlayTimer);
      clearInterval(fcTimerInterval);
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
    }
  });

  document.getElementById('fc-speed').addEventListener('input', function() {
    var val = this.value;
    document.getElementById('fc-speed-label').textContent = val + 's';
    localStorage.setItem('swf-fc-speed', val);
    if (document.getElementById('fc-autoplay').checked) {
      clearTimeout(autoPlayTimer);
      scheduleNext();
    }
  });

  // ── Fullscreen toggle (with CSS fallback for iOS/mobile) ──
  var isCssFullscreen = false;

  function applyFsStyles(panel) {
    panel.style.padding = '2rem';
    panel.style.display = 'flex';
    panel.style.flexDirection = 'column';
    panel.style.justifyContent = 'center';
    panel.style.alignItems = 'center';
    panel.style.background = '#0f172a';
    var card = document.getElementById('fc-card');
    if (card) {
      card.style.width = '700px';
      card.style.maxWidth = '90vw';
      card.style.height = '300px';
      card.style.borderRadius = '2rem';
    }
    var word = document.getElementById('fc-word');
    if (word) word.style.fontSize = '5.625rem';
    var meaning = document.getElementById('fc-meaning');
    if (meaning) meaning.style.fontSize = '1.5rem';
    var score = document.getElementById('fc-score');
    if (score) score.style.fontSize = '1.25rem';
    var hint = document.getElementById('fc-hint');
    if (hint) hint.style.fontSize = '0.875rem';
    var counter = document.getElementById('fc-counter');
    if (counter) counter.style.fontSize = '1rem';
  }

  function resetFsStyles(panel) {
    panel.style.padding = '';
    panel.style.display = '';
    panel.style.flexDirection = '';
    panel.style.justifyContent = '';
    panel.style.alignItems = '';
    panel.style.background = '';
    panel.style.position = '';
    panel.style.inset = '';
    panel.style.zIndex = '';
    panel.style.overflow = '';
    panel.style.borderRadius = '';
    var card = document.getElementById('fc-card');
    if (card) { card.style.width = ''; card.style.maxWidth = ''; card.style.height = ''; card.style.borderRadius = ''; }
    var word = document.getElementById('fc-word');
    if (word) word.style.fontSize = '';
    var meaning = document.getElementById('fc-meaning');
    if (meaning) meaning.style.fontSize = '';
    var score = document.getElementById('fc-score');
    if (score) score.style.fontSize = '';
    var hint = document.getElementById('fc-hint');
    if (hint) hint.style.fontSize = '';
    var counter = document.getElementById('fc-counter');
    if (counter) counter.style.fontSize = '';
  }

  function enterCssFullscreen(panel) {
    isCssFullscreen = true;
    panel.dataset.cssFullscreen = '1';
    panel.style.position = 'fixed';
    panel.style.inset = '0';
    panel.style.zIndex = '9999';
    panel.style.overflow = 'auto';
    panel.style.borderRadius = '0';
    applyFsStyles(panel);
    document.body.style.overflow = 'hidden';
    updateFsBtn(true);
  }

  function exitCssFullscreen(panel) {
    isCssFullscreen = false;
    delete panel.dataset.cssFullscreen;
    resetFsStyles(panel);
    document.body.style.overflow = '';
    updateFsBtn(false);
  }

  function updateFsBtn(isFullscreen) {
    var btn = document.getElementById('fc-fullscreen-btn');
    if (isFullscreen) {
      btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 4H4v4M16 4h4v4M8 20H4v-4M16 20h4v-4"/></svg>';
      btn.title = 'Exit full screen';
    } else {
      btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/></svg>';
      btn.title = 'Full screen';
    }
  }

  function isFullscreenSupported() {
    return !!(document.documentElement.requestFullscreen || document.documentElement.webkitRequestFullscreen);
  }

  document.getElementById('fc-fullscreen-btn').addEventListener('click', function() {
    var panel = this.closest('.rounded-xl');

    // If currently in CSS fullscreen, exit it
    if (isCssFullscreen) {
      exitCssFullscreen(panel);
      return;
    }

    // If currently in native fullscreen, exit it
    if (document.fullscreenElement || document.webkitFullscreenElement) {
      (document.exitFullscreen || document.webkitExitFullscreen).call(document);
      return;
    }

    // Try native fullscreen first (works on desktop + Android)
    if (panel.requestFullscreen) {
      panel.requestFullscreen().then(function() {
        applyFsStyles(panel);
      }).catch(function() {
        // Native failed (iOS) — use CSS fallback
        enterCssFullscreen(panel);
      });
    } else if (panel.webkitRequestFullscreen) {
      panel.webkitRequestFullscreen();
      applyFsStyles(panel);
    } else {
      // No native support — CSS fallback (iOS Safari)
      enterCssFullscreen(panel);
    }
  });

  document.addEventListener('fullscreenchange', function() {
    var panel = document.getElementById('fc-fullscreen-btn').closest('.rounded-xl');
    if (!document.fullscreenElement) {
      resetFsStyles(panel);
      updateFsBtn(false);
    } else {
      updateFsBtn(true);
    }
  });

  document.addEventListener('webkitfullscreenchange', function() {
    var panel = document.getElementById('fc-fullscreen-btn').closest('.rounded-xl');
    if (!document.webkitFullscreenElement) {
      resetFsStyles(panel);
      updateFsBtn(false);
    } else {
      updateFsBtn(true);
    }
  });

  // ── Practice History Panel ──
  document.getElementById('fc-history-btn').addEventListener('click', function() {
    var panel = document.getElementById('fc-history-panel');
    if (!panel.classList.contains('hidden')) {
      panel.classList.add('hidden');
      return;
    }
    panel.classList.remove('hidden');
    loadPracticeHistory();
  });

  document.getElementById('fc-history-close').addEventListener('click', function() {
    document.getElementById('fc-history-panel').classList.add('hidden');
  });

  function loadPracticeHistory() {
    var uid = localStorage.getItem('swf-uid') || '';
    var loading = document.getElementById('fc-history-loading');
    var empty = document.getElementById('fc-history-empty');
    var content = document.getElementById('fc-history-content');

    loading.classList.remove('hidden');
    empty.classList.add('hidden');
    content.classList.add('hidden');

    if (!uid) {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    fetch('/api/wordbench-practice/?user_id=' + encodeURIComponent(uid))
      .then(function(res) { return res.json(); })
      .then(function(data) {
        loading.classList.add('hidden');
        var records = data.records || [];
        if (records.length === 0) { empty.classList.remove('hidden'); return; }

        // Stats
        var uniqueWords = {};
        records.forEach(function(r) { uniqueWords[r.word] = true; });
        var uniqueCount = Object.keys(uniqueWords).length;
        var days = {};
        records.forEach(function(r) { if (r.created_at) days[r.created_at.split(' ')[0]] = true; });
        var dayCount = Object.keys(days).length;

        document.getElementById('fc-history-stats').innerHTML =
          '<div class="rounded-lg bg-gray-800/80 border border-purple-800/30 p-2 text-center">' +
            '<p class="text-lg font-bold text-purple-400">' + records.length + '</p>' +
            '<p class="text-[9px] text-gray-500">Reviews</p>' +
          '</div>' +
          '<div class="rounded-lg bg-gray-800/80 border border-blue-800/30 p-2 text-center">' +
            '<p class="text-lg font-bold text-blue-400">' + uniqueCount + '</p>' +
            '<p class="text-[9px] text-gray-500">Unique</p>' +
          '</div>' +
          '<div class="rounded-lg bg-gray-800/80 border border-green-800/30 p-2 text-center">' +
            '<p class="text-lg font-bold text-green-400">' + dayCount + '</p>' +
            '<p class="text-[9px] text-gray-500">Days</p>' +
          '</div>';

        // Table (show last 50)
        var rows = records.slice(0, 50).map(function(r, i) {
          var when = '—';
          if (r.created_at) {
            var d = new Date(r.created_at + 'Z');
            when = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ' ' +
                   d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
          }
          var meaning = r.meaning || '';
          if (meaning.length > 40) meaning = meaning.slice(0, 40) + '…';
          var bg = i % 2 === 0 ? 'bg-gray-900' : 'bg-gray-900/50';
          return '<tr class="' + bg + '">' +
            '<td class="px-2 py-1 font-mono font-bold text-white uppercase tracking-wider">' + r.word + '</td>' +
            '<td class="px-2 py-1 text-gray-400 italic">' + meaning + '</td>' +
            '<td class="px-2 py-1 text-gray-500 whitespace-nowrap">' + when + '</td>' +
          '</tr>';
        });
        document.getElementById('fc-history-body').innerHTML = rows.join('');
        content.classList.remove('hidden');
      })
      .catch(function() {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
      });
  }

})();
</script>
