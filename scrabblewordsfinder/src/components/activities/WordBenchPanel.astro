      <!-- Panel 3: Memory WordBench (Flash Cards) -->
      <div class="rounded-xl border border-green-800/50 bg-gray-900/50 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2"><span>🃏</span> Memory WordBench</h2>
          <div class="flex items-center gap-2">
            <button id="fc-start-btn" class="px-3 py-1.5 rounded-lg bg-green-600/30 border border-green-500/50 text-sm text-green-300 hover:bg-green-600/50 transition-colors">▶ Start</button>
            <span id="fc-word-count" class="text-xs text-gray-400">0 words</span>
          </div>
        </div>
        <!-- Category tabs -->
        <div id="fc-cat-filters" class="flex flex-wrap gap-1.5 mb-3"></div>
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input type="checkbox" id="fc-real-meanings" class="w-3.5 h-3.5 rounded border-gray-600 bg-gray-800 text-purple-500 focus:ring-purple-500/30 focus:ring-offset-0" checked />
            <span class="text-xs text-gray-400">Meaningful only</span>
          </label>
          <div id="fc-speed-wrap" class="hidden flex items-center gap-3">
            <input type="range" id="fc-speed" min="1" max="30" value="5" class="w-24 h-1 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500" />
            <span id="fc-speed-label" class="text-[10px] text-gray-400 font-mono w-6">5s</span>
            <button id="fc-autoplay-btn" class="w-7 h-7 flex items-center justify-center rounded-full border-2 border-purple-500/50 bg-purple-900/20 hover:bg-purple-600/30 hover:border-purple-400 text-purple-300 transition-all" title="Auto-play">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <span id="fc-timer" class="hidden text-[10px] font-mono text-amber-400">0:00</span>
          </div>
        </div>
        <input type="checkbox" id="fc-autoplay" class="hidden" />
        <div id="fc-panel" class="relative text-center py-6">
          <div id="fc-card" class="hidden mx-auto w-full max-w-sm h-48 rounded-2xl border-2 border-green-500/30 bg-gradient-to-br from-gray-800 to-gray-900 flex flex-col items-center justify-center cursor-pointer transition-all hover:border-green-400 select-none">
            <p id="fc-word" class="text-3xl font-black text-green-400 tracking-wider mb-2">WORD</p>
            <p id="fc-score" class="text-sm text-blue-400 hidden"></p>
            <p id="fc-meaning" class="text-sm text-gray-400 italic px-4 hidden">Click to reveal meaning</p>
            <p id="fc-hint" class="text-xs text-gray-600 mt-2">tap to flip</p>
          </div>
          <div id="fc-empty" class="text-sm text-gray-500 italic">Add words to your Memory WordBench first, then practice here.</div>
          <div id="fc-controls" class="hidden flex items-center justify-center gap-4 mt-4">
            <button id="fc-prev" class="px-3 py-1.5 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">← Prev</button>
            <span id="fc-counter" class="text-xs text-gray-500">1 / 10</span>
            <button id="fc-next" class="px-3 py-1.5 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">Next →</button>
          </div>
          <!-- Word action buttons -->
          <div id="fc-actions" class="hidden flex items-center justify-center gap-2 mt-3">
            <button id="fc-copy-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-green-400 hover:bg-green-900/20 rounded transition-colors">📋 Copy</button>
            <button id="fc-edit-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-blue-400 hover:bg-blue-900/20 rounded transition-colors">✏️ Edit</button>
            <button id="fc-delete-btn" class="px-2.5 py-1 text-xs text-gray-400 hover:text-red-400 hover:bg-red-900/20 rounded transition-colors">🗑️ Delete</button>
            <a href="/wordbench-practice/" class="px-2.5 py-1 text-xs text-gray-400 hover:text-purple-400 hover:bg-purple-900/20 rounded transition-colors">📚 Practice</a>
          </div>
        </div>
      </div>

<script is:inline>
(function() {
  // ── Memory WordBench ──
  var fcState = { words: [], current: 0, flipped: false, active: false };

  var catColors = {
    'wotd': { border: 'border-purple-500/50', bg: 'bg-purple-900/20', text: 'text-purple-300', label: '📖 Word of the Day' },
    'quiz': { border: 'border-blue-500/50', bg: 'bg-blue-900/20', text: 'text-blue-300', label: '🧠 Quiz' },
    'manual': { border: 'border-amber-500/50', bg: 'bg-amber-900/20', text: 'text-amber-300', label: '⭐ Saved' },
    'solver': { border: 'border-green-500/50', bg: 'bg-green-900/20', text: 'text-green-300', label: '🔍 Solver' },
    'default': { border: 'border-gray-500/50', bg: 'bg-gray-900/20', text: 'text-gray-300', label: '📝 Other' }
  };

  function getCatStyle(cat) { return catColors[cat] || catColors['default']; }

  function shuffleArray(arr) {
    var copy = arr.slice();
    for (var i = copy.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = copy[i]; copy[i] = copy[j]; copy[j] = tmp;
    }
    return copy;
  }

  function renderFlashCard() {
    var card = document.getElementById('fc-card');
    var wordEl = document.getElementById('fc-word');
    var meaningEl = document.getElementById('fc-meaning');
    var hintEl = document.getElementById('fc-hint');
    var counterEl = document.getElementById('fc-counter');
    var scoreEl = document.getElementById('fc-score');
    var actionsEl = document.getElementById('fc-actions');

    if (fcState.words.length === 0) return;

    var w = fcState.words[fcState.current];
    var style = getCatStyle(w.category || 'manual');

    // Calculate score
    var scores = {A:1,B:3,C:3,D:2,E:1,F:4,G:2,H:4,I:1,J:8,K:5,L:1,M:3,N:1,O:1,P:3,Q:10,R:1,S:1,T:1,U:1,V:4,W:4,X:8,Y:4,Z:10};
    var pts = (w.word || '').split('').reduce(function(s, c) { return s + (scores[c.toUpperCase()] || 0); }, 0);

    // Reset flip state
    fcState.flipped = false;
    wordEl.textContent = w.word || '?';
    wordEl.style.fontSize = '';
    wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
    scoreEl.textContent = pts + ' pts';
    scoreEl.classList.remove('hidden');
    meaningEl.textContent = w.meaning || 'No meaning saved';
    meaningEl.classList.add('hidden');
    hintEl.textContent = 'tap to flip';
    hintEl.classList.remove('hidden');
    counterEl.textContent = (fcState.current + 1) + ' / ' + fcState.words.length;

    // Show actions + controls
    actionsEl.classList.remove('hidden');
    document.getElementById('fc-speed-wrap').classList.remove('hidden');

    // Apply category colour to card border
    card.className = 'mx-auto w-full max-w-sm h-48 rounded-2xl border-2 flex flex-col items-center justify-center cursor-pointer transition-all select-none ' + style.border + ' ' + style.bg + ' hover:scale-[1.02]';

    // Animate card entry
    card.style.opacity = '0';
    card.style.transform = 'rotateY(90deg)';
    requestAnimationFrame(function() {
      card.style.transition = 'opacity 0.3s, transform 0.3s';
      card.style.opacity = '1';
      card.style.transform = 'rotateY(0deg)';
    });
  }

  function flipCard() {
    var wordEl = document.getElementById('fc-word');
    var meaningEl = document.getElementById('fc-meaning');
    var hintEl = document.getElementById('fc-hint');
    var card = document.getElementById('fc-card');

    fcState.flipped = !fcState.flipped;

    if (fcState.flipped) {
      card.style.transition = 'transform 0.2s';
      card.style.transform = 'rotateY(90deg)';
      setTimeout(function() {
        meaningEl.classList.remove('hidden');
        hintEl.textContent = 'tap to see word';
        wordEl.style.fontSize = '1.2rem';
        wordEl.className = 'font-black tracking-wider mb-2 text-gray-500';
        card.style.transform = 'rotateY(0deg)';
      }, 200);
    } else {
      card.style.transition = 'transform 0.2s';
      card.style.transform = 'rotateY(90deg)';
      setTimeout(function() {
        meaningEl.classList.add('hidden');
        hintEl.textContent = 'tap to flip';
        wordEl.style.fontSize = '';
        var style = getCatStyle((fcState.words[fcState.current] || {}).category || 'manual');
        wordEl.className = 'text-3xl font-black tracking-wider mb-2 ' + style.text;
        card.style.transform = 'rotateY(0deg)';
      }, 200);
    }
  }

  function startFlashCards(filterCategory) {
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    if (saved.length === 0) return;

    // Build category filters
    var cats = {};
    saved.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
    var filtersEl = document.getElementById('fc-cat-filters');
    if (Object.keys(cats).length > 1) {
      filtersEl.classList.remove('hidden');
      var activeCat = filterCategory || 'all';
      var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
        (activeCat === 'all' ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
        '" data-cat="all">All (' + saved.length + ')</button>';
      Object.keys(cats).sort().forEach(function(c) {
        html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border transition-colors ' +
          (activeCat === c ? 'border-green-500/50 bg-green-900/30 text-green-300' : 'border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50') +
          '" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
      });
      filtersEl.innerHTML = html;
      filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
        btn.addEventListener('click', function() {
          startFlashCards(btn.dataset.cat);
        });
      });
    }

    // Apply category filter
    var words = saved;
    if (filterCategory && filterCategory !== 'all') {
      words = saved.filter(function(w) { return (w.category || 'manual') === filterCategory; });
    }

    // Filter to words with real meanings if checkbox is checked
    var filterReal = document.getElementById('fc-real-meanings').checked;
    if (filterReal) {
      words = words.filter(function(w) {
        if (!w.meaning || w.meaning.trim() === '') return false;
        var m = w.meaning.toLowerCase();
        if (m === 'no meaning saved') return false;
        if (m.indexOf('scrabble-legal word') !== -1) return false;
        if (m.indexOf('no standard definition') !== -1) return false;
        if (m === 'a type of plant found in tropical regions') return false;
        if (m === 'to move swiftly in a specified direction') return false;
        if (m === 'a container used for storage') return false;
        if (m === 'relating to the process of growth') return false;
        if (m === 'a sound made by striking two objects') return false;
        if (m === 'to arrange in a particular order') return false;
        if (m === 'a feeling of deep satisfaction') return false;
        if (m === 'the outer covering of a seed') return false;
        if (m === 'to reduce in size or quantity') return false;
        if (m === 'a tool used for cutting') return false;
        if (m === 'relating to water or moisture') return false;
        if (m === 'a method of preparation') return false;
        if (m === 'to express disapproval strongly') return false;
        if (m === 'the quality of being bright') return false;
        if (m === 'a passage between rooms or buildings') return false;
        if (m === 'to combine separate elements') return false;
        if (m === 'relating to the earth or soil') return false;
        if (m === 'a measurement of distance') return false;
        if (m === 'to make a continuous low sound') return false;
        if (m === 'a type of fabric or textile') return false;
        return true;
      });
    }

    if (words.length === 0) {
      document.getElementById('fc-empty').textContent = 'No words with real meanings in this category. Use "📖 Lookup" on Word of the Day or click words in the solver to fetch definitions.';
      document.getElementById('fc-empty').classList.remove('hidden');
      document.getElementById('fc-card').classList.add('hidden');
      document.getElementById('fc-controls').classList.add('hidden');
      return;
    }

    fcState.words = shuffleArray(words);
    fcState.current = 0;
    fcState.active = true;

    document.getElementById('fc-empty').classList.add('hidden');
    document.getElementById('fc-card').classList.remove('hidden');
    document.getElementById('fc-controls').classList.remove('hidden');
    document.getElementById('fc-controls').style.display = 'flex';
    document.getElementById('fc-start-btn').textContent = '🔀 Shuffle';

    renderFlashCard();
  }

  document.getElementById('fc-start-btn').addEventListener('click', startFlashCards);

  // Initialize word count and category tabs on load
  (function initWordBench() {
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    document.getElementById('fc-word-count').textContent = saved.length + ' words';
    // Show category tabs immediately
    if (saved.length > 0) {
      var cats = {};
      saved.forEach(function(w) { var c = w.category || 'manual'; if (!cats[c]) cats[c] = 0; cats[c]++; });
      if (Object.keys(cats).length > 1) {
        var filtersEl = document.getElementById('fc-cat-filters');
        var html = '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-green-500/50 bg-green-900/30 text-green-300" data-cat="all">All (' + saved.length + ')</button>';
        Object.keys(cats).sort().forEach(function(c) {
          html += '<button class="fc-cat-filter px-2 py-0.5 rounded text-[10px] font-medium border border-gray-700 bg-gray-800 text-gray-400 hover:border-green-500/50" data-cat="' + c + '">' + c + ' (' + cats[c] + ')</button>';
        });
        filtersEl.innerHTML = html;
        filtersEl.querySelectorAll('.fc-cat-filter').forEach(function(btn) {
          btn.addEventListener('click', function() { startFlashCards(btn.dataset.cat); });
        });
      }
    }
  })();

  // Copy button
  document.getElementById('fc-copy-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    navigator.clipboard.writeText(fcState.words[fcState.current].word).catch(function(){});
    this.textContent = '✓ Copied';
    var self = this;
    setTimeout(function() { self.textContent = '📋 Copy'; }, 1500);
  });

  // Delete button
  document.getElementById('fc-delete-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    var wordToDelete = fcState.words[fcState.current].word;
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    saved = saved.filter(function(a) { return a.word !== wordToDelete; });
    localStorage.setItem('scbAchievements', JSON.stringify(saved));
    // Remove from current deck
    fcState.words.splice(fcState.current, 1);
    document.getElementById('fc-word-count').textContent = saved.length + ' words';
    if (fcState.words.length === 0) {
      document.getElementById('fc-card').classList.add('hidden');
      document.getElementById('fc-controls').classList.add('hidden');
      document.getElementById('fc-actions').classList.add('hidden');
      document.getElementById('fc-empty').classList.remove('hidden');
      fcState.active = false;
    } else {
      if (fcState.current >= fcState.words.length) fcState.current = 0;
      renderFlashCard();
    }
  });

  // Edit button — prompt to edit meaning
  document.getElementById('fc-edit-btn').addEventListener('click', function() {
    if (!fcState.active || !fcState.words[fcState.current]) return;
    var w = fcState.words[fcState.current];
    var newMeaning = prompt('Edit meaning for ' + w.word + ':', w.meaning || '');
    if (newMeaning === null) return; // cancelled
    var saved = JSON.parse(localStorage.getItem('scbAchievements') || '[]');
    var match = saved.find(function(a) { return a.word === w.word; });
    if (match) { match.meaning = newMeaning; localStorage.setItem('scbAchievements', JSON.stringify(saved)); }
    w.meaning = newMeaning;
    if (fcState.flipped) {
      document.getElementById('fc-meaning').textContent = newMeaning || 'No meaning saved';
    }
  });

  // + to Solver button — navigate to solver with the word
  document.getElementById('fc-card').addEventListener('click', function() {
    if (fcState.active) flipCard();
  });

  document.getElementById('fc-prev').addEventListener('click', function() {
    if (!fcState.active || fcState.words.length === 0) return;
    fcState.current = (fcState.current - 1 + fcState.words.length) % fcState.words.length;
    renderFlashCard();
  });

  document.getElementById('fc-next').addEventListener('click', function() {
    if (!fcState.active || fcState.words.length === 0) return;
    fcState.current = (fcState.current + 1) % fcState.words.length;
    renderFlashCard();
  });

  // Keyboard navigation for flash cards
  document.addEventListener('keydown', function(e) {
    if (!fcState.active) return;
    if (e.key === 'ArrowLeft') { stopAutoPlay(); document.getElementById('fc-prev').click(); }
    else if (e.key === 'ArrowRight') { stopAutoPlay(); document.getElementById('fc-next').click(); }
    else if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipCard(); }
  });

  // ── Auto-play ──
  var autoPlayTimer = null;
  var autoPlayPhase = 'word'; // 'word' → show word, 'meaning' → show meaning, then advance

  function getAutoPlaySpeed() {
    return parseInt(document.getElementById('fc-speed').value) * 1000 || 5000;
  }

  // Load saved speed from localStorage
  (function initSpeed() {
    var saved = localStorage.getItem('swf-fc-speed');
    if (saved) {
      document.getElementById('fc-speed').value = saved;
      document.getElementById('fc-speed-label').textContent = saved + 's';
    }
  })();

  function startAutoPlay() {
    if (!fcState.active) { startFlashCards(); }
    if (!fcState.active) return; // still no words
    autoPlayPhase = 'word';
    scheduleNext();
  }

  function scheduleNext() {
    clearTimeout(autoPlayTimer);
    var speed = getAutoPlaySpeed();
    autoPlayTimer = setTimeout(function() {
      if (!document.getElementById('fc-autoplay').checked) return;

      if (autoPlayPhase === 'word') {
        // Flip to show meaning
        if (!fcState.flipped) flipCard();
        autoPlayPhase = 'meaning';
        scheduleNext();
      } else {
        // Advance to next card
        fcState.current = (fcState.current + 1) % fcState.words.length;
        renderFlashCard();
        autoPlayPhase = 'word';
        scheduleNext();
      }
    }, speed);
  }

  var fcTimerInterval = null;
  var fcTimerStart = 0;

  function stopAutoPlay() {
    clearTimeout(autoPlayTimer);
    clearInterval(fcTimerInterval);
    autoPlayTimer = null;
    fcTimerInterval = null;
    document.getElementById('fc-autoplay').checked = false;
    document.getElementById('fc-speed-wrap').classList.add('hidden');
    document.getElementById('fc-timer').classList.add('hidden');
    var btn = document.getElementById('fc-autoplay-btn');
    btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
  }

  document.getElementById('fc-autoplay-btn').addEventListener('click', function() {
    var checkbox = document.getElementById('fc-autoplay');
    var btn = document.getElementById('fc-autoplay-btn');
    if (!checkbox.checked) {
      checkbox.checked = true;
      document.getElementById('fc-speed-wrap').classList.remove('hidden');
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
      // Start timer
      fcTimerStart = Date.now();
      document.getElementById('fc-timer').classList.remove('hidden');
      fcTimerInterval = setInterval(function() {
        var elapsed = Math.floor((Date.now() - fcTimerStart) / 1000);
        var mins = Math.floor(elapsed / 60);
        var secs = elapsed % 60;
        document.getElementById('fc-timer').textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
      }, 1000);
      startAutoPlay();
    } else {
      checkbox.checked = false;
      document.getElementById('fc-speed-wrap').classList.add('hidden');
      document.getElementById('fc-timer').classList.add('hidden');
      clearTimeout(autoPlayTimer);
      clearInterval(fcTimerInterval);
      btn.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
    }
  });

  document.getElementById('fc-speed').addEventListener('input', function() {
    var val = this.value;
    document.getElementById('fc-speed-label').textContent = val + 's';
    localStorage.setItem('swf-fc-speed', val);
    if (document.getElementById('fc-autoplay').checked) {
      clearTimeout(autoPlayTimer);
      scheduleNext();
    }
  });

})();
</script>
