            <button id="fc-fullscreen-btn" class="w-7 h-7 flex items-center justify-center rounded-full border-2 border-gray-600 bg-gray-800/50 hover:bg-gray-700 hover:border-gray-500 text-gray-400 hover:text-white transition-all" title="Full screen">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/></svg>
