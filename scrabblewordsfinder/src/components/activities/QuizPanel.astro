    function renderPerformanceGraph(games) {
      var section = document.getElementById('lex-quiz-graph-section');
      var canvas = document.getElementById('lex-quiz-graph');
      if (!section || !canvas || !games || games.length < 2) {
        if (section) section.classList.add('hidden');
        return;
      }

      // Sort games chronologically (gameNumber ascending)
      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });

      section.classList.remove('hidden');
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);

      // Layout
      var pad = { top: 16, right: 40, bottom: 28, left: 36 };
      var plotW = w - pad.left - pad.right;
      var plotH = h - pad.top - pad.bottom;
      var n = sorted.length;

      // Data
      var accuracies = sorted.map(function(g) { return g.accuracy; });
      var times = sorted.map(function(g) { return g.timeUsed; });
      var maxTime = Math.max.apply(null, times) || 1;
      // Round up maxTime to nearest 10 for clean axis
      maxTime = Math.ceil(maxTime / 10) * 10;

      // Clear
      ctx.clearRect(0, 0, w, h);

      // Draw grid lines
      ctx.strokeStyle = 'rgba(255,255,255,0.06)';
      ctx.lineWidth = 1;
      for (var i = 0; i <= 4; i++) {
        var y = pad.top + (plotH / 4) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(w - pad.right, y);
        ctx.stroke();
      }

      // Y-axis labels (left = accuracy 0-100%)
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillStyle = 'rgba(74,222,128,0.7)';
      for (var i = 0; i <= 4; i++) {
        var val = 100 - i * 25;
        var y = pad.top + (plotH / 4) * i;
        ctx.fillText(val + '%', pad.left - 6, y + 3);
      }

      // Y-axis labels (right = time 0-maxTime)
      ctx.textAlign = 'left';
      ctx.fillStyle = 'rgba(34,211,238,0.7)';
      for (var i = 0; i <= 4; i++) {
        var val = Math.round(maxTime - (maxTime / 4) * i);
        var y = pad.top + (plotH / 4) * i;
        ctx.fillText(val + 's', w - pad.right + 6, y + 3);
      }

      // X-axis labels (game numbers)
      ctx.textAlign = 'center';
      ctx.fillStyle = 'rgba(255,255,255,0.4)';
      var labelStep = Math.max(1, Math.floor(n / 8));
      for (var i = 0; i < n; i += labelStep) {
        var x = pad.left + (plotW / (n - 1)) * i;
        ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14);
      }
      // Always label last game
      if ((n - 1) % labelStep !== 0) {
        var x = pad.left + plotW;
        ctx.fillText('#' + sorted[n - 1].gameNumber, x, h - pad.bottom + 14);
      }

      // Helper to get x,y for a data point
      function getXY(index, value, maxVal) {
        var x = pad.left + (plotW / (n - 1)) * index;
        var y = pad.top + plotH - (value / maxVal) * plotH;
        return { x: x, y: y };
      }

      // Draw accuracy line (green)
      ctx.strokeStyle = 'rgba(74,222,128,0.9)';
      ctx.lineWidth = 2;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      ctx.beginPath();
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, accuracies[i], 100);
        if (i === 0) ctx.moveTo(pt.x, pt.y);
        else ctx.lineTo(pt.x, pt.y);
      }
      ctx.stroke();

      // Draw accuracy dots
      ctx.fillStyle = 'rgba(74,222,128,1)';
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, accuracies[i], 100);
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, 3, 0, Math.PI * 2);
        ctx.fill();
      }

      // Draw time line (cyan)
      ctx.strokeStyle = 'rgba(34,211,238,0.9)';
      ctx.lineWidth = 2;
      ctx.beginPath();
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, times[i], maxTime);
        if (i === 0) ctx.moveTo(pt.x, pt.y);
        else ctx.lineTo(pt.x, pt.y);
      }
      ctx.stroke();

      // Draw time dots
      ctx.fillStyle = 'rgba(34,211,238,1)';
      for (var i = 0; i < n; i++) {
        var pt = getXY(i, times[i], maxTime);
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function renderTimeCommentary(games, stats) {
      var container = document.getElementById('lex-quiz-time-commentary');
      var textEl = document.getElementById('lex-quiz-time-commentary-text');
      if (!container || !textEl || !games || games.length < 2) {
        if (container) container.classList.add('hidden');
        return;
      }

      var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
      var times = sorted.map(function(g) { return g.timeUsed; });
      var fastest = Math.min.apply(null, times);
      var slowest = Math.max.apply(null, times);
      var avg = Math.round(times.reduce(function(a, b) { return a + b; }, 0) / times.length);

      // Find the game with fastest/slowest
      var fastestGame = sorted.find(function(g) { return g.timeUsed === fastest; });
      var slowestGame = sorted.find(function(g) { return g.timeUsed === slowest; });

      // Time trend: compare last 2 games
      var recent = sorted[sorted.length - 1];
      var prev = sorted[sorted.length - 2];
      var timeDiff = recent.timeUsed - prev.timeUsed;
      var trendText = '';
      if (timeDiff < -10) trendText = 'You\'re getting faster — ' + Math.abs(timeDiff) + 's quicker than your previous round.';
      else if (timeDiff > 10) trendText = 'You took ' + timeDiff + 's longer this round — maybe tougher words or more careful answers.';
      else trendText = 'Your pace is consistent between recent rounds.';

      // Build commentary
      var parts = [];
      parts.push('Fastest: ' + fastest + 's (Game #' + fastestGame.gameNumber + ') · Slowest: ' + slowest + 's (Game #' + slowestGame.gameNumber + ') · Avg: ' + avg + 's.');
      parts.push(trendText);

      // Speed vs accuracy insight
      if (fastest === recent.timeUsed && recent.accuracy >= 80) {
        parts.push('Your fastest round was also highly accurate — great speed + precision combo.');
      } else if (slowest === recent.timeUsed && recent.accuracy < 60) {
        parts.push('Slower round with lower accuracy — could indicate harder vocabulary.');
      }

      container.classList.remove('hidden');
      textEl.textContent = parts.join(' ');
    }

    function renderGameAnalysis(games) {
      var container = document.getElementById('lex-quiz-games');
      var list = document.getElementById('lex-quiz-games-list');
      var countEl = document.getElementById('lex-quiz-games-count');
      if (!container || !list || !games || games.length === 0) return;

      container.classList.remove('hidden');
      countEl.textContent = games.length + ' game' + (games.length === 1 ? '' : 's');

      var ratingColors = {
        perfect: { border: 'border-green-500/40', bg: 'bg-green-900/10', badge: 'bg-green-600/30 text-green-300', icon: '🏆' },
        great: { border: 'border-blue-500/40', bg: 'bg-blue-900/10', badge: 'bg-blue-600/30 text-blue-300', icon: '⚡' },
        good: { border: 'border-amber-500/40', bg: 'bg-amber-900/10', badge: 'bg-amber-600/30 text-amber-300', icon: '✅' },
        fair: { border: 'border-orange-500/40', bg: 'bg-orange-900/10', badge: 'bg-orange-600/30 text-orange-300', icon: '📚' },
        weak: { border: 'border-red-500/40', bg: 'bg-red-900/10', badge: 'bg-red-600/30 text-red-300', icon: '⚠️' }
      };

      var html = '';
      for (var i = 0; i < games.length; i++) {
        var g = games[i];
        var colors = ratingColors[g.rating] || ratingColors.fair;
        var dateStr = g.date ? new Date(g.date + 'Z').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '—';

        // Weaknesses HTML
        var weakHtml = '';
        if (g.weaknesses && g.weaknesses.length > 0) {
          weakHtml = '<div class="mt-2"><p class="text-[10px] font-semibold text-red-400 uppercase tracking-wide mb-1">⚠ Weaknesses</p>';
          for (var w = 0; w < g.weaknesses.length; w++) {
            weakHtml += '<p class="text-[11px] text-red-300/80 pl-3 border-l-2 border-red-500/30 mb-1">' + g.weaknesses[w] + '</p>';
          }
          weakHtml += '</div>';
        }

        // Improvements HTML
        var impHtml = '';
        if (g.improvements && g.improvements.length > 0) {
          impHtml = '<div class="mt-2"><p class="text-[10px] font-semibold text-green-400 uppercase tracking-wide mb-1">✓ Strengths</p>';
          for (var s = 0; s < g.improvements.length; s++) {
            impHtml += '<p class="text-[11px] text-green-300/80 pl-3 border-l-2 border-green-500/30 mb-1">' + g.improvements[s] + '</p>';
          }
          impHtml += '</div>';
        }

        // Missed words HTML
        var missedHtml = '';
        if (g.missedWords && g.missedWords.length > 0) {
          missedHtml = '<div class="mt-2 flex flex-wrap gap-1">';
          for (var m = 0; m < g.missedWords.length; m++) {
            missedHtml += '<span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-red-900/30 border border-red-700/40 text-red-300">' + g.missedWords[m] + '</span>';
          }
          missedHtml += '</div>';
        }

        html += '<div class="rounded-xl ' + colors.border + ' ' + colors.bg + ' border p-3">' +
          '<div class="flex items-center justify-between mb-1">' +
            '<div class="flex items-center gap-2">' +
              '<span class="text-base">' + colors.icon + '</span>' +
              '<span class="text-xs font-bold text-white">Game #' + g.gameNumber + '</span>' +
              '<span class="px-1.5 py-0.5 rounded text-[10px] font-semibold ' + colors.badge + '">' + g.rating.toUpperCase() + '</span>' +
            '</div>' +
            '<span class="text-[10px] text-gray-500">' + dateStr + '</span>' +
          '</div>' +
          '<div class="flex items-center gap-3 text-[11px] text-gray-400 mb-1">' +
            '<span>Score: <b class="text-white">' + g.score + '/' + g.total + '</b> (' + g.accuracy + '%)</span>' +
            '<span>Time: <b class="text-white">' + g.timeUsed + 's</b>/' + g.timerLimit + 's</span>' +
            (g.timedOut ? '<span class="text-red-400 font-semibold">⏰ Timed Out</span>' : '') +
          '</div>' +
          impHtml + weakHtml + missedHtml +
        '</div>';
      }

      list.innerHTML = html;
    }

    // Event listeners
    lexBtn.addEventListener('click', function(e) {
      e.preventDefault();
      openModal();
    });
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  })();

})();
</script>
