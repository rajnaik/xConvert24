        <!-- Time commentary -->
        <div id="lex-cab-time-commentary" class="hidden mb-4 px-3 py-2 rounded-lg bg-cyan-900/20 border border-cyan-700/30">
          <p class="text-[10px] text-cyan-400 font-semibold uppercase mb-1">⏱ Time Insight</p>
          <p id="lex-cab-time-text" class="text-[11px] text-gray-300 leading-relaxed"></p>
        </div>
        <!-- AI analysis -->
        <div id="lex-cab-analysis-text" class="text-sm text-gray-200 leading-relaxed whitespace-pre-wrap mb-4"></div>
        <!-- Per-game cards -->
        <div id="lex-cab-games" class="hidden mb-4">
          <div class="flex items-center justify-between mb-2">
            <p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold">Per-Game Analysis</p>
            <span id="lex-cab-games-count" class="text-[10px] text-gray-600"></span>
          </div>
          <div id="lex-cab-games-list" class="flex flex-col gap-2 max-h-64 overflow-y-auto"></div>
        </div>
        <!-- Chat link -->
        <div class="pt-3 border-t border-gray-700/50">
          <a href="/chat/?context=cab" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-800/50 border border-gray-700/40 hover:border-cyan-500/40 hover:bg-gray-800 transition-colors group">
            <span class="text-sm" aria-hidden="true">💬</span>
            <span class="text-xs text-gray-300 group-hover:text-cyan-300 transition-colors">Ask Lex for detailed coaching in chat</span>
          </a>
