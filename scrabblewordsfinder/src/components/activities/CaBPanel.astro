        <p class="text-sm text-red-400">Something went wrong. Try again later.</p>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var coachModal = document.getElementById('lex-cab-coach-modal');
  var coachBackdrop = document.getElementById('lex-cab-coach-backdrop');
  var coachClose = document.getElementById('lex-cab-coach-close');
  var coachLoading = document.getElementById('lex-cab-coach-loading');
  var coachResult = document.getElementById('lex-cab-coach-result');
  var coachError = document.getElementById('lex-cab-coach-error');
  var coachBtn = document.getElementById('cab-lex-coach-btn');

  function openCoachModal() {
    coachModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    coachLoading.classList.remove('hidden');
    coachResult.classList.add('hidden');
    coachError.classList.add('hidden');
    fetchCabCoaching();
  }

  function closeCoachModal() {
    coachModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function fetchCabCoaching() {
    var S = window.__swfStore;
    var userId = S ? S.getRaw('swf-uid') : (localStorage.getItem('swf-uid') || '');
    fetch('/api/lex-cab-coach/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: userId })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      coachLoading.classList.add('hidden');
      if (data.error) { coachError.classList.remove('hidden'); return; }
      coachResult.classList.remove('hidden');

      if (data.hasHistory && data.stats) {
        document.getElementById('lex-cab-stats-bar').classList.remove('hidden');
        document.getElementById('lex-cab-stat-games').textContent = data.stats.totalGames;
        document.getElementById('lex-cab-stat-rate').textContent = data.stats.solveRate + '%';
        document.getElementById('lex-cab-stat-avg').textContent = data.stats.avgAttempts;
        document.getElementById('lex-cab-stat-quick').textContent = data.stats.quickSolves;
      }

      document.getElementById('lex-cab-analysis-text').textContent = data.analysis || 'No analysis available.';
      renderCabGraph(data.gameAnalysis || []);
      renderCabTimeCommentary(data.gameAnalysis || [], data.stats || {});
      renderCabGameAnalysis(data.gameAnalysis || []);

      // PDF Download + Save to Library buttons
      if (typeof appendCoachingPDFButtons === 'function') {
        var existingBtns = document.getElementById('lex-cab-pdf-buttons');
        if (existingBtns) existingBtns.remove();
        var btnContainer = document.createElement('div');
        btnContainer.id = 'lex-cab-pdf-buttons';
        var cabResult = document.getElementById('lex-cab-coach-result');
        if (cabResult) cabResult.appendChild(btnContainer);
        appendCoachingPDFButtons(btnContainer, 'cab', data.analysis || '', data.stats || {}, null);
      }
    })
    .catch(function() {
      coachLoading.classList.add('hidden');
      coachError.classList.remove('hidden');
    });
  }

  function renderCabGraph(games) {
    var section = document.getElementById('lex-cab-graph-section');
    var canvas = document.getElementById('lex-cab-graph');
    if (!section || !canvas || !games || games.length < 2) { if (section) section.classList.add('hidden'); return; }

    var sorted = games.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
    section.classList.remove('hidden');
    var ctx = canvas.getContext('2d');
    var dpr = window.devicePixelRatio || 1;
    var w = canvas.clientWidth;
    var h = canvas.clientHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.scale(dpr, dpr);

    var pad = { top: 16, right: 12, bottom: 28, left: 30 };
    var plotW = w - pad.left - pad.right;
    var plotH = h - pad.top - pad.bottom;
    var n = sorted.length;

    // Max attempts on graph (cap at 10 for readability)
    var attempts = sorted.map(function(g) { return g.solved ? g.attempts : 10; });
    var maxAtt = Math.min(Math.max.apply(null, attempts) + 1, 12);
    var solvedAtts = attempts.filter(function(a) { return a < 10; });
    var avgAtt = solvedAtts.length > 0 ? Math.round(solvedAtts.reduce(function(a, b) { return a + b; }, 0) / solvedAtts.length * 10) / 10 : 0;

    ctx.clearRect(0, 0, w, h);

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    for (var i = 0; i <= 5; i++) {
      var y = pad.top + (plotH / 5) * i;
      ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
    }

    // Y-axis labels
    ctx.font = '10px system-ui, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(74,222,128,0.7)';
    for (var i = 0; i <= 5; i++) {
      var val = Math.round((maxAtt / 5) * i);
      var y = pad.top + (plotH / 5) * i;
      ctx.fillText(val === 0 ? '' : String(val), pad.left - 6, y + 3);
    }

    // X-axis labels
    ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    var labelStep = Math.max(1, Math.floor(n / 8));
    for (var i = 0; i < n; i += labelStep) {
      var x = pad.left + (plotW / Math.max(n - 1, 1)) * i;
      ctx.fillText('#' + sorted[i].gameNumber, x, h - pad.bottom + 14);
    }
    if ((n - 1) % labelStep !== 0 && n > 1) {
      ctx.fillText('#' + sorted[n - 1].gameNumber, pad.left + plotW, h - pad.bottom + 14);
    }

    function getXY(index, value) {
      var x = pad.left + (plotW / Math.max(n - 1, 1)) * index;
      var y = pad.top + (value / maxAtt) * plotH;
      return { x: x, y: y };
    }

    // Average line (dashed)
    if (avgAtt > 0) {
      var avgY = pad.top + (avgAtt / maxAtt) * plotH;
      ctx.setLineDash([4, 4]);
      ctx.strokeStyle = 'rgba(255,255,255,0.3)';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(pad.left, avgY); ctx.lineTo(w - pad.right, avgY); ctx.stroke();
      ctx.setLineDash([]);
    }

    // Line connecting dots
    ctx.strokeStyle = 'rgba(251,146,60,0.6)';
    ctx.lineWidth = 1.5;
    ctx.lineJoin = 'round';
    ctx.beginPath();
    for (var i = 0; i < n; i++) {
      var pt = getXY(i, attempts[i]);
      if (i === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y);
    }
    ctx.stroke();

    // Dots
    for (var i = 0; i < n; i++) {
      var pt = getXY(i, attempts[i]);
      ctx.fillStyle = sorted[i].solved ? 'rgba(74,222,128,1)' : 'rgba(248,113,113,1)';
      ctx.beginPath();
      ctx.arc(pt.x, pt.y, sorted[i].attempts <= 2 && sorted[i].solved ? 5 : 3.5, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function renderCabTimeCommentary(games, stats) {
    var container = document.getElementById('lex-cab-time-commentary');
    var textEl = document.getElementById('lex-cab-time-text');
    if (!container || !textEl) return;

    var timed = games.filter(function(g) { return g.splitTime > 0; });
    if (timed.length < 2) { container.classList.add('hidden'); return; }

    var sorted = timed.slice().sort(function(a, b) { return a.gameNumber - b.gameNumber; });
    var times = sorted.map(function(g) { return g.splitTime; });
    var fastest = Math.min.apply(null, times);
    var slowest = Math.max.apply(null, times);
    var avg = Math.round(times.reduce(function(a, b) { return a + b; }, 0) / times.length);

    var fastestGame = sorted.find(function(g) { return g.splitTime === fastest; });
    var slowestGame = sorted.find(function(g) { return g.splitTime === slowest; });

    var recent = sorted[sorted.length - 1];
    var prev = sorted[sorted.length - 2];
    var diff = recent.splitTime - prev.splitTime;
    var trend = diff < -20 ? 'Getting faster — ' + Math.abs(diff) + 's quicker than previous.' :
                diff > 20 ? 'Took ' + diff + 's longer — possibly a tougher word.' :
                'Consistent pace between recent games.';

    container.classList.remove('hidden');
    textEl.textContent = 'Fastest: ' + fastest + 's (Game #' + fastestGame.gameNumber + ') · Slowest: ' + slowest + 's (Game #' + slowestGame.gameNumber + ') · Avg: ' + avg + 's. ' + trend;
  }

  function renderCabGameAnalysis(games) {
    var container = document.getElementById('lex-cab-games');
    var list = document.getElementById('lex-cab-games-list');
    var countEl = document.getElementById('lex-cab-games-count');
    if (!container || !list || !games || games.length === 0) return;

    container.classList.remove('hidden');
    var display = games.slice(0, 20);
    countEl.textContent = display.length + ' of ' + games.length + ' games';

    var ratingColors = {
      ace: { border: 'border-purple-500/40', bg: 'bg-purple-900/10', badge: 'bg-purple-600/30 text-purple-300', icon: '🏆' },
      brilliant: { border: 'border-green-500/40', bg: 'bg-green-900/10', badge: 'bg-green-600/30 text-green-300', icon: '⚡' },
      great: { border: 'border-blue-500/40', bg: 'bg-blue-900/10', badge: 'bg-blue-600/30 text-blue-300', icon: '✅' },
      good: { border: 'border-amber-500/40', bg: 'bg-amber-900/10', badge: 'bg-amber-600/30 text-amber-300', icon: '👍' },
      tough: { border: 'border-orange-500/40', bg: 'bg-orange-900/10', badge: 'bg-orange-600/30 text-orange-300', icon: '😤' },
      failed: { border: 'border-red-500/40', bg: 'bg-red-900/10', badge: 'bg-red-600/30 text-red-300', icon: '❌' }
    };

    var html = '';
    for (var i = 0; i < display.length; i++) {
      var g = display[i];
      var colors = ratingColors[g.rating] || ratingColors.good;
      var dateStr = g.date && g.date !== '?' ? new Date(g.date + 'T00:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '—';

      var impHtml = '';
      if (g.improvements && g.improvements.length > 0) {
        impHtml = '<div class="mt-1.5">';
        for (var s = 0; s < g.improvements.length; s++) {
          impHtml += '<p class="text-[11px] text-green-300/80 pl-2 border-l-2 border-green-500/30 mb-0.5">' + g.improvements[s] + '</p>';
        }
        impHtml += '</div>';
      }

      var weakHtml = '';
      if (g.weaknesses && g.weaknesses.length > 0) {
        weakHtml = '<div class="mt-1.5">';
        for (var w = 0; w < g.weaknesses.length; w++) {
          weakHtml += '<p class="text-[11px] text-red-300/80 pl-2 border-l-2 border-red-500/30 mb-0.5">' + g.weaknesses[w] + '</p>';
        }
        weakHtml += '</div>';
      }

      var resultText = g.solved ? 'Solved in ' + g.attempts + ' guesses' : 'Not solved';
      var timeText = g.splitTime > 0 ? ' · ' + g.splitTime + 's' : '';

      html += '<div class="rounded-xl ' + colors.border + ' ' + colors.bg + ' border p-3">' +
        '<div class="flex items-center justify-between mb-1">' +
          '<div class="flex items-center gap-2">' +
            '<span class="text-base">' + colors.icon + '</span>' +
            '<span class="text-xs font-bold text-white">Game #' + g.gameNumber + '</span>' +
            '<span class="px-1.5 py-0.5 rounded text-[10px] font-semibold ' + colors.badge + '">' + g.rating.toUpperCase() + '</span>' +
          '</div>' +
          '<span class="text-[10px] text-gray-500">' + dateStr + '</span>' +
        '</div>' +
        '<div class="flex items-center gap-3 text-[11px] text-gray-400">' +
          '<span>' + resultText + '</span>' +
          (timeText ? '<span>Time: <b class="text-white">' + g.splitTime + 's</b></span>' : '') +
          '<span class="text-gray-600">' + g.wordLength + '-letter word</span>' +
          (g.word ? '<span class="font-mono uppercase text-orange-300">' + g.word + '</span>' : '') +
        '</div>' +
        impHtml + weakHtml +
      '</div>';
    }

    list.innerHTML = html;
  }

  // Wire up the "Coach me" button to open the analysis modal instead
  if (coachBtn) {
    coachBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      openCoachModal();
    });
  }

  coachClose.addEventListener('click', closeCoachModal);
  coachBackdrop.addEventListener('click', closeCoachModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !coachModal.classList.contains('hidden')) {
      closeCoachModal();
    }
  });
})();
</script>
