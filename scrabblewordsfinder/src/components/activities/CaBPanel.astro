<script is:inline>
(function() {
  var modal = document.getElementById('cab-lex-modal');
  var openBtn = document.getElementById('LexCandB');
  var closeBtn = document.getElementById('cab-lex-close');
  var form = document.getElementById('cab-lex-form');
  var input = document.getElementById('cab-lex-input');
  var messagesEl = document.getElementById('cab-lex-messages');
  var coachBtn = document.getElementById('cab-lex-coach-btn');

  var diamondBtn = document.getElementById('cab-lex-diamond-btn');

  var conversationHistory = [];
  var isStreaming = false;
  var hasAutoCoached = false;

  // Open modal — auto-coach on first click if user has game history
  openBtn.addEventListener('click', function() {
    modal.classList.remove('hidden');
    input.focus();
  });

  // Close modal
  closeBtn.addEventListener('click', function() {
    modal.classList.add('hidden');
  });

  // Close on backdrop click
  modal.addEventListener('click', function(e) {
    if (e.target === modal) modal.classList.add('hidden');
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      modal.classList.add('hidden');
    }
  });

  // Auto-resize textarea
  input.addEventListener('input', function() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 96) + 'px';
  });

  // Enter to send
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!isStreaming && input.value.trim()) {
        form.dispatchEvent(new Event('submit'));
      }
    }
  });

  // Coach button — now handled by the dedicated coaching modal script below
  // (the new script uses stopPropagation to intercept clicks)

  // Diamond Hunt Details button — ask Lex to explain Diamond Hunt + Badges
  diamondBtn.addEventListener('click', function() {
    if (isStreaming) return;
    var prompt = '[DIAMOND HUNT — DETAILS REQUEST]\n\n';
    prompt += 'Please tell me everything about the Diamond Hunt feature and the Badges system on ScrabbleWordsFinder.com.\n\n';
    prompt += 'Include:\n';
    prompt += '1. How Diamond Hunt works (finding mines, claiming diamonds, reward tiers)\n';
    prompt += '2. How the Badges/Achievements system works (word scoring milestones, categories)\n';
    prompt += '3. How diamonds from Diamond Hunt relate to the Star Bar daily system\n';
    prompt += '4. Tips for maximising diamond earnings\n\n';
    prompt += 'Please also provide links to explore these features:\n';
    prompt += '- /diamond-hunt/ — Diamond Hunt page\n';
    prompt += '- /achievements/ — Achievements & Badges\n';
    prompt += '- /mybag/ — MyBag (star & diamond earnings)\n';
    prompt += '- /activities/ — All daily games\n';

    input.value = prompt;
    form.dispatchEvent(new Event('submit'));
  });

  // Diamond Hunt - Details button
  if (diamondBtn) {
    diamondBtn.addEventListener('click', function() {
      if (isStreaming) return;
      var prompt = '[DIAMOND HUNT — DETAILS REQUEST]\n\n';
      prompt += 'Please explain the Diamond Hunt and Badges system on ScrabbleWordsFinder in detail. Include:\n';
      prompt += '1. How Diamond Hunt works (hidden diamonds on pages, claiming them)\n';
      prompt += '2. How to earn diamonds (complete all 7 daily activities in a single day)\n';
      prompt += '3. The badge progression tiers (Word Maker at 25 diamonds through Grand Word Deity at 1,000,000)\n';
      prompt += '4. How the 7 daily activities contribute (WOTD, Quiz, Memory WordBench, Daily Rack, Daily Anagram, 60-Second Challenge, Cows & Bulls)\n';
      prompt += '5. Where to check progress (MyBag page)\n\n';
      prompt += 'Include these links for the user to explore:\n';
      prompt += '- Diamond Hunt page: /diamond-hunt/\n';
      prompt += '- Badges & Tiers: /badges/\n';
      prompt += '- Activities hub: /activities/\n';
      prompt += '- MyBag (progress): /mybag/\n\n';
      prompt += 'Format your response clearly with sections and links.';

      input.value = prompt;
      form.dispatchEvent(new Event('submit'));
    });
  }

  // Submit form
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var text = input.value.trim();
    if (!text || isStreaming) return;

    // Add user message
    addMessage('user', text);
    conversationHistory.push({ role: 'user', content: text });
    input.value = '';
    input.style.height = 'auto';

    // Stream response
    streamResponse();
  });

  function addMessage(role, content) {
    var wrapper = document.createElement('div');
    wrapper.className = 'flex items-start gap-2' + (role === 'user' ? ' flex-row-reverse' : '');

    if (role === 'user') {
      var bubble = document.createElement('div');
      bubble.className = 'lex-msg-user rounded-lg rounded-tr-none px-3 py-2 max-w-[85%]';
      // Show shortened version for long coaching prompts
      var displayText = content.length > 100
        ? (content.indexOf('DIAMOND HUNT') !== -1 ? '💎 Tell me about Diamond Hunt & Badges' : '🧠 Coach me on my Cows & Bulls games')
        : content;
      bubble.innerHTML = '<p class="text-sm text-gray-200">' + escapeHtml(displayText) + '</p>';
      wrapper.appendChild(bubble);
    } else {
      var avatar = document.createElement('div');
      avatar.className = 'w-6 h-6 rounded-full bg-cyan-900/50 flex items-center justify-center shrink-0 mt-0.5';
      avatar.innerHTML = '<img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />';

      var bubble = document.createElement('div');
      bubble.className = 'lex-msg-bot rounded-lg rounded-tl-none px-3 py-2 max-w-[85%]';
      bubble.innerHTML = '<p class="text-sm text-gray-200 whitespace-pre-wrap">' + formatContent(content) + '</p>';

      wrapper.appendChild(avatar);
      wrapper.appendChild(bubble);
    }

    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return wrapper;
  }

  function addTypingIndicator() {
    var wrapper = document.createElement('div');
    wrapper.className = 'flex items-start gap-2';
    wrapper.id = 'cab-lex-typing';

    var avatar = document.createElement('div');
    avatar.className = 'w-6 h-6 rounded-full bg-cyan-900/50 flex items-center justify-center shrink-0 mt-0.5';
    avatar.innerHTML = '<img src="/lex-avatar-32.png" alt="Lex" width="16" height="16" class="rounded-full" />';

    var bubble = document.createElement('div');
    bubble.className = 'lex-msg-bot rounded-lg rounded-tl-none px-3 py-2';
    bubble.innerHTML = '<div class="lex-typing flex gap-1"><span class="w-2 h-2 rounded-full bg-cyan-400 inline-block"></span><span class="w-2 h-2 rounded-full bg-cyan-400 inline-block"></span><span class="w-2 h-2 rounded-full bg-cyan-400 inline-block"></span></div>';

    wrapper.appendChild(avatar);
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTypingIndicator() {
    var el = document.getElementById('cab-lex-typing');
    if (el) el.remove();
  }

  function streamResponse() {
    isStreaming = true;
    addTypingIndicator();

    fetch('/api/chat/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: conversationHistory })
    })
      .then(function(response) {
        if (!response.ok) throw new Error('AI unavailable');
        var reader = response.body.getReader();
        var decoder = new TextDecoder();
        var fullText = '';
        var botWrapper = null;

        function read() {
          reader.read().then(function(result) {
            if (result.done) {
              isStreaming = false;
              if (fullText) {
                conversationHistory.push({ role: 'assistant', content: fullText });
              }
              return;
            }

            var chunk = decoder.decode(result.value, { stream: true });
            var lines = chunk.split('\n');
            for (var i = 0; i < lines.length; i++) {
              var line = lines[i].trim();
              if (!line.startsWith('data:')) continue;
              var jsonStr = line.slice(5).trim();
              if (jsonStr === '[DONE]') continue;
              try {
                var parsed = JSON.parse(jsonStr);
                var token = parsed.response || '';
                if (token) {
                  if (!botWrapper) {
                    removeTypingIndicator();
                    botWrapper = addMessage('bot', '');
                  }
                  fullText += token;
                  var p = botWrapper.querySelector('p');
                  if (p) p.innerHTML = formatContent(fullText);
                  messagesEl.scrollTop = messagesEl.scrollHeight;
                }
              } catch(e) {}
            }
            read();
          }).catch(function() {
            isStreaming = false;
            removeTypingIndicator();
          });
        }
        read();
      })
      .catch(function(err) {
        isStreaming = false;
        removeTypingIndicator();
        addMessage('bot', 'Sorry, I couldn\'t connect to the AI service. Please try again later.');
      });
  }

  function formatContent(text) {
    // Basic markdown-like formatting
    var html = escapeHtml(text);
    // Bold
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-white">$1</strong>');
    // Links
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-cyan-400 underline hover:text-cyan-300" target="_blank">$1</a>');
    return html;
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
})();
</script>

