{
  "name": "playground",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && cd dist/server && npx wrangler deploy --config wrangler.json",
    "test": "npx playwright test tests/playground.spec.ts --config tests/playwright.config.ts --reporter=list",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.6.1",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.4",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "wrangler": "^4.100.0"
  }
}
