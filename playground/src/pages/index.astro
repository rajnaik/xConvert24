---
import '../styles/global.css';
---
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>xSoft Playground</title>
  <style>
    .toolbar-btn { width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; border-radius: 0.25rem; color: #d1d5db; font-size: 0.875rem; font-weight: 500; cursor: pointer; user-select: none; transition: all 0.15s; }
    .toolbar-btn:hover { background: #374151; color: #fff; }
    .toolbar-btn.active { background: rgba(217,119,6,0.3); color: #fbbf24; border: 1px solid rgba(245,158,11,0.5); }
    .toolbar-sep { width: 1px; height: 1.5rem; background: #374151; margin: 0 0.25rem; }
    .color-dot { width: 1.25rem; height: 1.25rem; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.15s; }
    .color-dot:hover { border-color: #fff; }
    #editor-rich { min-height: 300px; max-height: 60vh; overflow-y: auto; padding: 0.75rem 1rem; background: #1f2937; border: 1px solid #374151; border-top: none; border-radius: 0 0 0.5rem 0.5rem; font-size: 0.875rem; color: #f3f4f6; outline: none; }
    #editor-rich:focus { border-color: #f59e0b; }
    #editor-rich h1 { font-size: 1.5rem; font-weight: 700; color: #fff; margin: 0.5rem 0; }
    #editor-rich h2 { font-size: 1.25rem; font-weight: 600; color: #fbbf24; margin: 0.5rem 0; }
    #editor-rich h3 { font-size: 1.125rem; font-weight: 500; color: #60a5fa; margin: 0.25rem 0; }
    #editor-rich ul { list-style: disc; padding-left: 1.5rem; margin: 0.5rem 0; }
    #editor-rich ol { list-style: decimal; padding-left: 1.5rem; margin: 0.5rem 0; }
    #editor-rich li { margin: 0.125rem 0; }
    #editor-rich blockquote { border-left: 4px solid #f59e0b; padding-left: 1rem; margin: 0.75rem 0; font-style: italic; color: #9ca3af; }
    #editor-rich pre { background: #111827; border: 1px solid #374151; border-radius: 0.375rem; padding: 0.75rem; margin: 0.5rem 0; font-family: monospace; font-size: 0.75rem; overflow-x: auto; }
    #editor-rich code { background: #111827; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.75rem; font-family: monospace; color: #4ade80; }
    #editor-rich a { color: #60a5fa; text-decoration: underline; }
    #editor-rich hr { border-color: #374151; margin: 1rem 0; }
    .clean-border { border: 2px solid #a855f7; border-radius: 4px; padding: 2px 4px; display: inline; }
    .clean-border.expired { border-color: transparent; }
    .folder-card { cursor: pointer; transition: all 0.15s; }
    .folder-card:hover { border-color: #fbbf24; }
    .folder-card.drag-over { border-color: #22c55e; background: rgba(34,197,94,0.1); transform: scale(1.05); }
    .note-card[draggable="true"] { cursor: grab; }
    .note-card[draggable="true"]:active { cursor: grabbing; }
    .note-card.dragging { opacity: 0.5; transform: scale(0.95); }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <header class="border-b border-gray-800 px-4 py-3 flex items-center justify-between">
    <h1 class="text-lg font-bold text-white">📝 xSoft Playground</h1>
    <nav class="flex items-center gap-4 text-sm">
      <a href="/" class="text-amber-400 font-medium">Notes</a>
      <a href="/media/" class="text-gray-400 hover:text-white transition-colors">Media</a>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2 text-sm" id="breadcrumb">
        <span class="text-amber-400">📁 Root</span>
      </div>
      <div class="flex gap-2 items-center">
        <button id="new-folder-btn" class="px-3 py-1.5 rounded-lg bg-blue-600/30 border border-blue-500/50 text-xs text-blue-300 hover:bg-blue-600/50 transition-colors">+ Folder</button>
        <button id="new-note-btn" class="px-4 py-2 rounded-lg bg-amber-600 text-white text-sm font-semibold hover:bg-amber-500 transition-colors">+ New Note</button>
        <span class="text-xs text-gray-500" id="notes-count"></span>
      </div>
    </div>

    <!-- Folders row -->
    <div id="folders-row" class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3 mb-6"></div>

    <!-- Editor -->
    <div id="editor-panel" class="hidden mb-8 rounded-xl border border-gray-800 bg-gray-900/50 p-6">
      <div class="flex items-center justify-between mb-3">
        <input id="note-title" type="text" placeholder="Note title (optional)" class="flex-1 h-10 px-3 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-500 mr-3" />
        <div class="flex gap-2">
          <button id="save-note-btn" class="px-4 py-2 rounded-lg bg-green-600 text-white text-sm font-semibold hover:bg-green-500 transition-colors">💾 Save</button>
          <button id="cancel-note-btn" class="px-3 py-2 rounded-lg bg-gray-700 text-gray-300 text-sm hover:bg-gray-600 transition-colors">Cancel</button>
        </div>
      </div>

      <!-- Toolbar -->
      <div id="toolbar" class="flex flex-wrap items-center gap-0.5 p-2 bg-gray-900 border border-gray-700 rounded-t-lg">
        <button class="toolbar-btn" data-cmd="bold" title="Bold"><b>B</b></button>
        <button class="toolbar-btn" data-cmd="italic" title="Italic"><i>I</i></button>
        <button class="toolbar-btn" data-cmd="underline" title="Underline"><u>U</u></button>
        <button class="toolbar-btn" data-cmd="strikeThrough" title="Strike"><s>S</s></button>
        <div class="toolbar-sep"></div>
        <button class="toolbar-btn text-xs" data-cmd="formatBlock" data-val="h1" title="Heading 1">H1</button>
        <button class="toolbar-btn text-xs" data-cmd="formatBlock" data-val="h2" title="Heading 2">H2</button>
        <button class="toolbar-btn text-xs" data-cmd="formatBlock" data-val="h3" title="Heading 3">H3</button>
        <button class="toolbar-btn text-xs" data-cmd="formatBlock" data-val="p" title="Paragraph">¶</button>
        <div class="toolbar-sep"></div>
        <button class="toolbar-btn" data-cmd="insertUnorderedList" title="Bullets">•</button>
        <button class="toolbar-btn" data-cmd="insertOrderedList" title="Numbers">1.</button>
        <button class="toolbar-btn" data-cmd="formatBlock" data-val="blockquote" title="Quote">❝</button>
        <div class="toolbar-sep"></div>
        <button class="toolbar-btn" data-cmd="insertHorizontalRule" title="Line">—</button>
        <button class="toolbar-btn" id="btn-code" title="Code">{ }</button>
        <button class="toolbar-btn" id="btn-link" title="Link">🔗</button>
        <button class="toolbar-btn" id="btn-highlight" title="Highlight">🖍️</button>
        <div class="toolbar-sep"></div>
        <button class="toolbar-btn" data-cmd="justifyLeft" title="Left">⫷</button>
        <button class="toolbar-btn" data-cmd="justifyCenter" title="Center">☰</button>
        <button class="toolbar-btn" data-cmd="justifyRight" title="Right">⫸</button>
        <div class="toolbar-sep"></div>
        <!-- Text color -->
        <div class="relative">
          <button class="toolbar-btn" id="btn-color" title="Text Color">A<span class="block w-4 h-1 bg-red-500 rounded-full mt-0.5"></span></button>
          <div id="color-picker" class="hidden absolute top-full left-0 mt-1 p-2 bg-gray-800 border border-gray-700 rounded-lg shadow-xl z-50 grid grid-cols-6 gap-1.5 w-40">
            <div class="color-dot bg-white" data-color="#ffffff"></div>
            <div class="color-dot bg-red-500" data-color="#ef4444"></div>
            <div class="color-dot bg-orange-500" data-color="#f97316"></div>
            <div class="color-dot bg-amber-400" data-color="#fbbf24"></div>
            <div class="color-dot bg-green-500" data-color="#22c55e"></div>
            <div class="color-dot bg-blue-500" data-color="#3b82f6"></div>
            <div class="color-dot bg-purple-500" data-color="#a855f7"></div>
            <div class="color-dot bg-pink-500" data-color="#ec4899"></div>
            <div class="color-dot bg-cyan-400" data-color="#22d3ee"></div>
            <div class="color-dot bg-lime-400" data-color="#a3e635"></div>
            <div class="color-dot bg-rose-400" data-color="#fb7185"></div>
            <div class="color-dot bg-gray-400" data-color="#9ca3af"></div>
          </div>
        </div>
        <!-- BG color -->
        <div class="relative">
          <button class="toolbar-btn" id="btn-bg-color" title="Highlight Color">🎨</button>
          <div id="bg-color-picker" class="hidden absolute top-full left-0 mt-1 p-2 bg-gray-800 border border-gray-700 rounded-lg shadow-xl z-50 grid grid-cols-6 gap-1.5 w-40">
            <div class="color-dot bg-yellow-300/60" data-color="rgba(253,224,71,0.3)"></div>
            <div class="color-dot bg-green-300/60" data-color="rgba(134,239,172,0.3)"></div>
            <div class="color-dot bg-blue-300/60" data-color="rgba(147,197,253,0.3)"></div>
            <div class="color-dot bg-purple-300/60" data-color="rgba(216,180,254,0.3)"></div>
            <div class="color-dot bg-pink-300/60" data-color="rgba(249,168,212,0.3)"></div>
            <div class="color-dot bg-orange-300/60" data-color="rgba(253,186,116,0.3)"></div>
          </div>
        </div>
        <div class="toolbar-sep"></div>
        <button class="toolbar-btn" data-cmd="undo" title="Undo">↩</button>
        <button class="toolbar-btn" data-cmd="redo" title="Redo">↪</button>
        <button class="toolbar-btn" data-cmd="removeFormat" title="Clear">✕</button>
        <button class="toolbar-btn" id="btn-clean-highlight" title="Clean + Purple Border (48h)" style="border:1px solid #a855f7;">🧹</button>
      </div>

      <!-- Editable area -->
      <div id="editor-rich" contenteditable="true"></div>
      <p id="editor-filename" class="text-xs text-gray-500 mt-2"></p>
      <input type="hidden" id="editing-note-id" value="" />
    </div>

    <!-- Notes List -->
    <div id="notes-list" class="space-y-3"></div>
  </main>

  <script is:inline>
  (function() {
    var currentFolder = null;

    function generateFilename() {
      var now = new Date();
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var dd = String(now.getDate()).padStart(2, '0');
      return dd + months[now.getMonth()] + now.getFullYear() + '_Kiro';
    }

    // Toolbar commands
    document.querySelectorAll('#toolbar .toolbar-btn[data-cmd]').forEach(function(btn) {
      btn.addEventListener('mousedown', function(e) { e.preventDefault(); });
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        document.execCommand(this.dataset.cmd, false, this.dataset.val || null);
        document.getElementById('editor-rich').focus();
      });
    });

    document.getElementById('btn-code').addEventListener('click', function(e) {
      e.preventDefault();
      var sel = window.getSelection();
      var text = sel.toString() || 'code';
      document.execCommand('insertHTML', false, '<pre><code>' + text + '</code></pre>');
    });

    document.getElementById('btn-link').addEventListener('click', function(e) {
      e.preventDefault();
      var url = prompt('URL:', 'https://');
      if (url) document.execCommand('createLink', false, url);
    });

    document.getElementById('btn-highlight').addEventListener('click', function(e) {
      e.preventDefault();
      document.execCommand('hiliteColor', false, 'rgba(253,224,71,0.3)');
    });

    // Clean + Purple border (48h expiry)
    document.getElementById('btn-clean-highlight').addEventListener('mousedown', function(e) { e.preventDefault(); });
    document.getElementById('btn-clean-highlight').addEventListener('click', function(e) {
      e.preventDefault();
      var sel = window.getSelection();
      if (!sel || sel.rangeCount === 0 || sel.isCollapsed) return;
      document.execCommand('removeFormat', false, null);
      var text = sel.toString();
      if (!text) return;
      var expires = Date.now() + (48 * 60 * 60 * 1000);
      var html = '<span class="clean-border" data-expires="' + expires + '">' + text + '</span>';
      document.execCommand('insertHTML', false, html);
    });

    // Expire old purple borders on load + mutation
    (function expireOldBorders() {
      var editor = document.getElementById('editor-rich');
      if (!editor) return;
      function checkExpiry() {
        var spans = editor.querySelectorAll('.clean-border[data-expires]');
        var now = Date.now();
        spans.forEach(function(span) {
          var exp = parseInt(span.getAttribute('data-expires') || '0');
          if (exp > 0 && now > exp) {
            span.style.border = 'none';
            span.style.padding = '0';
            span.removeAttribute('data-expires');
            span.classList.remove('clean-border');
          }
        });
      }
      var observer = new MutationObserver(checkExpiry);
      observer.observe(editor, { childList: true, subtree: true });
      setInterval(checkExpiry, 60000);
      checkExpiry();
    })();

    // Color pickers
    var cp = document.getElementById('color-picker');
    var bgp = document.getElementById('bg-color-picker');

    document.getElementById('btn-color').addEventListener('mousedown', function(e) { e.preventDefault(); });
    document.getElementById('btn-color').addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      cp.classList.toggle('hidden'); bgp.classList.add('hidden');
    });
    cp.querySelectorAll('.color-dot').forEach(function(d) {
      d.addEventListener('mousedown', function(e) { e.preventDefault(); });
      d.addEventListener('click', function(e) {
        e.stopPropagation();
        document.execCommand('foreColor', false, this.dataset.color);
        cp.classList.add('hidden');
      });
    });

    document.getElementById('btn-bg-color').addEventListener('mousedown', function(e) { e.preventDefault(); });
    document.getElementById('btn-bg-color').addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      bgp.classList.toggle('hidden'); cp.classList.add('hidden');
    });
    bgp.querySelectorAll('.color-dot').forEach(function(d) {
      d.addEventListener('mousedown', function(e) { e.preventDefault(); });
      d.addEventListener('click', function(e) {
        e.stopPropagation();
        document.execCommand('hiliteColor', false, this.dataset.color);
        bgp.classList.add('hidden');
      });
    });

    document.addEventListener('click', function() { cp.classList.add('hidden'); bgp.classList.add('hidden'); });

    // ─── Folder Management ───
    function loadContent() { loadFolders(); loadNotes(); }

    function loadFolders() {
      var url = '/api/folders/' + (currentFolder ? '?parent_id=' + currentFolder : '');
      fetch(url).then(function(r) { return r.json(); }).then(function(data) {
        var folders = data.folders || [];
        var html = folders.map(function(f) {
          return '<div class="folder-card rounded-lg border border-gray-700 bg-gray-900/50 p-3 text-center group relative" data-folder-id="' + f.id + '" data-folder-name="' + f.name + '">' +
            '<div class="text-2xl mb-1">📁</div>' +
            '<p class="text-xs text-gray-300 truncate">' + f.name + '</p>' +
            '<div class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 flex gap-0.5">' +
              '<button class="rename-folder-btn w-5 h-5 rounded text-[10px] text-blue-400 hover:bg-blue-900/30" data-id="' + f.id + '" data-name="' + f.name + '">✏️</button>' +
              '<button class="delete-folder-btn w-5 h-5 rounded text-[10px] text-red-400 hover:bg-red-900/30" data-id="' + f.id + '">🗑️</button>' +
            '</div></div>';
        }).join('');
        document.getElementById('folders-row').innerHTML = html;

        // Folder event listeners
        document.querySelectorAll('.folder-card').forEach(function(card) {
          card.addEventListener('click', function(e) {
            if (e.target.closest('.rename-folder-btn') || e.target.closest('.delete-folder-btn')) return;
            openFolder(this.dataset.folderId, this.dataset.folderName);
          });
          // Drag-drop: accept notes dragged into folders
          card.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('drag-over'); });
          card.addEventListener('dragleave', function() { this.classList.remove('drag-over'); });
          card.addEventListener('drop', function(e) {
            e.preventDefault(); this.classList.remove('drag-over');
            var noteId = e.dataTransfer.getData('text/note-id');
            if (noteId) moveNoteToFolder(parseInt(noteId), parseInt(this.dataset.folderId));
          });
        });
        document.querySelectorAll('.rename-folder-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var newName = prompt('Rename folder:', this.dataset.name);
            if (newName && newName.trim()) {
              fetch('/api/folders/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: parseInt(this.dataset.id), name: newName.trim() }) }).then(loadContent);
            }
          });
        });
        document.querySelectorAll('.delete-folder-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            if (!confirm('Delete folder? Notes inside will move to root.')) return;
            fetch('/api/folders/?id=' + this.dataset.id, { method: 'DELETE' }).then(loadContent);
          });
        });
      });
    }

    function openFolder(id, name) {
      currentFolder = id;
      var bc = document.getElementById('breadcrumb');
      bc.innerHTML = '<span class="text-gray-400 cursor-pointer hover:text-amber-400" id="bc-root">📁 Root</span><span class="text-gray-600 mx-1">›</span><span class="text-amber-400">📁 ' + name + '</span>';
      document.getElementById('bc-root').addEventListener('click', function() {
        currentFolder = null;
        document.getElementById('breadcrumb').innerHTML = '<span class="text-amber-400">📁 Root</span>';
        loadContent();
      });
      loadContent();
    }

    function moveNoteToFolder(noteId, folderId) {
      fetch('/api/notes/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: noteId, folder_id: folderId }) }).then(loadContent);
    }

    document.getElementById('new-folder-btn').addEventListener('click', function() {
      var name = prompt('New folder name:');
      if (!name || !name.trim()) return;
      fetch('/api/folders/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name.trim(), parent_id: currentFolder }) }).then(loadContent);
    });

    // ─── Notes CRUD ───
    function loadNotes() {
      fetch('/api/notes/').then(function(r) { return r.json(); }).then(function(data) {
        var allNotes = data.notes || [];
        // Filter by current folder
        var notes = allNotes.filter(function(n) {
          if (currentFolder === null) return !n.folder_id;
          return n.folder_id == currentFolder;
        });
        document.getElementById('notes-count').textContent = notes.length + ' note' + (notes.length !== 1 ? 's' : '');
        var html = notes.map(function(n) {
          var date = new Date(n.updated_at || n.created_at);
          var dateStr = date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) + ' ' + date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
          return '<div class="note-card rounded-lg border border-gray-800 bg-gray-900/50 p-4 hover:border-amber-500/50 transition-colors cursor-pointer group" draggable="true" data-id="' + n.id + '">' +
            '<div class="flex items-center justify-between"><div>' +
            '<p class="text-sm font-medium text-white group-hover:text-amber-400 transition-colors">' + (n.title || n.filename) + '</p>' +
            '<p class="text-xs text-gray-500 mt-0.5">' + n.filename + ' · ' + dateStr + '</p></div>' +
            '<div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">' +
            '<button class="edit-btn px-2 py-1 text-xs text-blue-400 hover:bg-blue-900/20 rounded" data-id="' + n.id + '">✏️</button>' +
            '<button class="delete-btn px-2 py-1 text-xs text-red-400 hover:bg-red-900/20 rounded" data-id="' + n.id + '">🗑️</button>' +
            '</div></div></div>';
        }).join('');
        document.getElementById('notes-list').innerHTML = html || '<p class="text-sm text-gray-500 text-center py-8">No notes here. Click "+ New Note" to start.</p>';

        // Drag-and-drop for notes
        document.querySelectorAll('.note-card[draggable]').forEach(function(card) {
          card.addEventListener('dragstart', function(e) {
            e.dataTransfer.setData('text/note-id', this.dataset.id);
            this.classList.add('dragging');
          });
          card.addEventListener('dragend', function() { this.classList.remove('dragging'); });
          card.addEventListener('click', function(e) {
            if (e.target.closest('.edit-btn') || e.target.closest('.delete-btn')) return;
            editNote(this.dataset.id);
          });
        });
        document.querySelectorAll('.edit-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) { e.stopPropagation(); editNote(this.dataset.id); });
        });
        document.querySelectorAll('.delete-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) { e.stopPropagation(); deleteNote(this.dataset.id); });
        });
      });
    }

    function showEditor(clear) {
      document.getElementById('editor-panel').classList.remove('hidden');
      if (clear) {
        document.getElementById('note-title').value = '';
        document.getElementById('editor-rich').innerHTML = '';
        document.getElementById('editing-note-id').value = '';
        document.getElementById('editor-filename').textContent = 'Filename: ' + generateFilename();
      }
      document.getElementById('editor-rich').focus();
    }

    function hideEditor() { document.getElementById('editor-panel').classList.add('hidden'); }

    function editNote(id) {
      fetch('/api/notes/?id=' + id).then(function(r) { return r.json(); }).then(function(data) {
        if (!data.note) return;
        document.getElementById('note-title').value = data.note.title || '';
        document.getElementById('editor-rich').innerHTML = data.note.content || '';
        document.getElementById('editing-note-id').value = id;
        document.getElementById('editor-filename').textContent = 'File: ' + data.note.filename;
        showEditor(false);
      });
    }

    function deleteNote(id) {
      if (!confirm('Delete this note?')) return;
      fetch('/api/notes/?id=' + id, { method: 'DELETE' }).then(function() { loadContent(); });
    }

    function saveNote() {
      var title = document.getElementById('note-title').value.trim();
      var content = document.getElementById('editor-rich').innerHTML;
      var id = document.getElementById('editing-note-id').value;
      if (!content.replace(/<[^>]*>/g, '').trim() && !title) return;
      var method = id ? 'PUT' : 'POST';
      var body = id ? { id: parseInt(id), title: title, content: content } : { title: title, content: content, folder_id: currentFolder ? parseInt(currentFolder) : null };
      fetch('/api/notes/', { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function(r) { return r.json(); }).then(function() { hideEditor(); loadContent(); });
    }

    document.getElementById('new-note-btn').addEventListener('click', function() { showEditor(true); });
    document.getElementById('save-note-btn').addEventListener('click', saveNote);
    document.getElementById('cancel-note-btn').addEventListener('click', hideEditor);
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); if (!document.getElementById('editor-panel').classList.contains('hidden')) saveNote(); }
    });
    loadContent();
  })();
  </script>
</body>
</html>
