---
import '../styles/global.css';
---
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Avatar Collage — Bottts × Scrabble</title>
</head>
<body class="min-h-screen bg-gray-950 text-white">
  <div class="p-6 max-w-7xl mx-auto">
    <a href="/" class="text-sm text-teal-400 hover:underline mb-4 inline-block">← Back to Playground</a>
    <h1 class="text-3xl font-bold mb-2">🤖 Avatar Style Collage — Bottts</h1>
    <p class="text-gray-400 mb-6">50 unique Bottts avatars seeded from Scrabble terms. Each seed produces a distinctive robot character. These are the production avatars for SWF.</p>

    <!-- Style info banner -->
    <div class="mb-8 p-4 rounded-xl bg-teal-950/30 border border-teal-700/40">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">🎲</span>
        <div>
          <p class="font-semibold text-teal-300">DiceBear Bottts</p>
          <p class="text-xs text-gray-400">Pablo Stanley — Free for personal and commercial use</p>
        </div>
      </div>
      <p class="text-sm text-gray-300">Robot/creature heads with unique shapes, colors, and expressions. Gender-neutral, highly distinctive at small sizes, perfect for anonymous game identities.</p>
    </div>

    <!-- Filter controls -->
    <div class="flex flex-wrap gap-2 mb-6 sticky top-0 bg-gray-950/95 backdrop-blur py-3 z-10 border-b border-gray-800">
      <button data-filter="grid" class="filter-btn active px-3 py-1.5 rounded-lg text-sm font-medium bg-teal-600 text-white">Grid View</button>
      <button data-filter="list" class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700">List View</button>
      <span class="ml-auto text-xs text-gray-500 self-center">50 avatars × 50 Scrabble terms</span>
    </div>

    <!-- Grid view -->
    <div id="grid-view" class="grid grid-cols-5 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-3 mb-10">
    </div>

    <!-- List view (hidden by default) -->
    <div id="list-view" class="hidden space-y-2 mb-10">
    </div>

    <!-- Naming reference table -->
    <div class="mt-8 p-4 rounded-xl bg-gray-900 border border-gray-700">
      <h2 class="text-lg font-semibold mb-3">📋 Scrabble-Flavoured Naming Theme</h2>
      <p class="text-sm text-gray-400 mb-4">Display names use the pattern: <span class="text-teal-300 font-mono">Adjective + Scrabble Term</span> → e.g. "Crimson Bingo", "Swift Triple", "Jade Rack"</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Adjectives -->
        <div>
          <p class="text-xs uppercase tracking-wider text-gray-500 mb-2">40 Adjectives</p>
          <div class="flex flex-wrap gap-1">
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Blue</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Red</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Silver</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Golden</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Amber</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Jade</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Coral</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Ivory</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Crimson</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Violet</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Azure</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Rusty</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Misty</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Shadow</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Storm</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Frost</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Ember</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Dusty</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Lucky</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Swift</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Bold</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Clever</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Brave</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Wild</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Noble</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Cosmic</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Lunar</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Solar</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Star</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Iron</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Copper</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Bronze</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Steel</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Crystal</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Velvet</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Thunder</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Mystic</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Arctic</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Tropical</span>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-xs text-gray-300">Midnight</span>
          </div>
        </div>

        <!-- Scrabble Terms -->
        <div>
          <p class="text-xs uppercase tracking-wider text-gray-500 mb-2">50 Scrabble Terms (one per avatar)</p>
          <div id="terms-list" class="flex flex-wrap gap-1">
          </div>
        </div>
      </div>
    </div>

    <!-- Sample names showcase -->
    <div class="mt-6 p-4 rounded-xl bg-gray-900 border border-gray-700">
      <h2 class="text-lg font-semibold mb-3">🎲 Sample Display Names</h2>
      <p class="text-xs text-gray-400 mb-3">Each player gets a fixed Scrabble term (by avatar ID) + a random adjective:</p>
      <div id="sample-names" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
      </div>
      <button id="reshuffle" type="button" class="mt-4 px-4 py-2 rounded-lg bg-teal-700 hover:bg-teal-600 text-white text-sm font-medium cursor-pointer transition-colors">🔀 Reshuffle Adjectives</button>
    </div>
  </div>

  <script is:inline>
    const SCRABBLE_TERMS = [
      'Bingo', 'Hook', 'Rack', 'Triple', 'Double',
      'Blank', 'Swap', 'Block', 'Stem', 'Leave',
      'Bridge', 'Phoney', 'Tile', 'Bonus', 'Opener',
      'Endgame', 'Crossword', 'Parallel', 'Float', 'Dump',
      'Anchor', 'Premium', 'Exchange', 'Challenge', 'Pass',
      'Vowel', 'Scoring', 'Ladder', 'Stack', 'Spread',
      'Hotspot', 'Turnover', 'Setup', 'Blocker', 'Outplay',
      'Extend', 'Counter', 'Suffix', 'Prefix', 'Anagram',
      'Unplay', 'Overlap', 'Flanker', 'Keeper', 'Burner',
      'Sleeper', 'Clincher', 'Sniper', 'Joker', 'Ace',
    ];

    const ADJECTIVES = [
      'Blue', 'Red', 'Silver', 'Golden', 'Amber',
      'Jade', 'Coral', 'Ivory', 'Crimson', 'Violet',
      'Azure', 'Rusty', 'Misty', 'Shadow', 'Storm',
      'Frost', 'Ember', 'Dusty', 'Lucky', 'Swift',
      'Bold', 'Clever', 'Brave', 'Wild', 'Noble',
      'Cosmic', 'Lunar', 'Solar', 'Star', 'Iron',
      'Copper', 'Bronze', 'Steel', 'Crystal', 'Velvet',
      'Thunder', 'Mystic', 'Arctic', 'Tropical', 'Midnight',
    ];

    // --- Build Grid View ---
    const gridEl = document.getElementById('grid-view');
    SCRABBLE_TERMS.forEach((term, i) => {
      const id = i + 1;
      const card = document.createElement('div');
      card.className = 'avatar-card flex flex-col items-center gap-1 p-2 rounded-xl bg-gray-900/60 border border-gray-700/50 hover:border-teal-500/60 hover:bg-gray-800/80 transition-all cursor-pointer';
      card.innerHTML = `
        <img src="/avatars/avatar-${id}.svg" alt="${term}" class="w-14 h-14 rounded-full bg-gray-800" loading="lazy" />
        <span class="text-[10px] text-gray-400 truncate w-full text-center">${term}</span>
        <span class="text-[9px] text-teal-500/80 font-mono">#${id}</span>
      `;
      gridEl.appendChild(card);
    });

    // --- Build List View ---
    const listEl = document.getElementById('list-view');
    SCRABBLE_TERMS.forEach((term, i) => {
      const id = i + 1;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-2 rounded-lg bg-gray-900/40 border border-gray-800/50 hover:bg-gray-800/60 transition-colors';
      const adj = ADJECTIVES[Math.floor(Math.random() * ADJECTIVES.length)];
      row.innerHTML = `
        <img src="/avatars/avatar-${id}.svg" alt="${term}" class="w-10 h-10 rounded-full bg-gray-800 shrink-0" loading="lazy" />
        <span class="text-sm font-medium text-white w-24">#${id}</span>
        <span class="text-sm text-teal-300 font-medium flex-1">${term}</span>
        <span class="text-sm text-gray-400">${adj} ${term}</span>
      `;
      listEl.appendChild(row);
    });

    // --- Terms reference list ---
    const termsListEl = document.getElementById('terms-list');
    SCRABBLE_TERMS.forEach((term, i) => {
      const span = document.createElement('span');
      span.className = 'px-2 py-0.5 rounded bg-teal-900/40 border border-teal-700/30 text-xs text-teal-300';
      span.textContent = `${i + 1}. ${term}`;
      termsListEl.appendChild(span);
    });

    // --- Sample names ---
    function renderSampleNames() {
      const el = document.getElementById('sample-names');
      el.innerHTML = '';
      for (let i = 0; i < 15; i++) {
        const term = SCRABBLE_TERMS[Math.floor(Math.random() * SCRABBLE_TERMS.length)];
        const adj = ADJECTIVES[Math.floor(Math.random() * ADJECTIVES.length)];
        const id = SCRABBLE_TERMS.indexOf(term) + 1;
        const card = document.createElement('div');
        card.className = 'flex items-center gap-2 p-2 rounded-lg bg-gray-800/60 border border-gray-700/30';
        card.innerHTML = `
          <img src="/avatars/avatar-${id}.svg" alt="${term}" class="w-8 h-8 rounded-full" />
          <span class="text-xs text-white font-medium">${adj} ${term}</span>
        `;
        el.appendChild(card);
      }
    }
    renderSampleNames();

    document.getElementById('reshuffle').addEventListener('click', renderSampleNames);

    // --- View toggle ---
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('active', 'bg-teal-600', 'text-white');
          b.classList.add('bg-gray-800', 'text-gray-300');
        });
        btn.classList.add('active', 'bg-teal-600', 'text-white');
        btn.classList.remove('bg-gray-800', 'text-gray-300');

        const filter = btn.dataset.filter;
        document.getElementById('grid-view').classList.toggle('hidden', filter !== 'grid');
        document.getElementById('list-view').classList.toggle('hidden', filter !== 'list');
      });
    });
  </script>
</body>
</html>
