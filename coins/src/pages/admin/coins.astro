---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Coins Admin">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <h1>🪙 Coins</h1>
    <div style="display:flex;gap:0.5rem;">
      <button class="btn btn-add" id="addBtn">+ Add Coin</button>
      <button class="btn btn-add" id="fetchAllBtn" style="background:#8b5cf6;">⚡ Fetch All Coins Data</button>
      <button class="btn btn-track" id="rugCheckBtn">🛡️ RugCheck All</button>
      <select id="trendHours" style="padding:0.4rem;background:#0f172a;border:1px solid #475569;border-radius:4px;color:#e2e8f0;font-size:0.85rem;"><option value="1">1hr</option><option value="2">2hr</option><option value="3">3hr</option><option value="4">4hr</option><option value="5">5hr</option></select>
      <button class="btn btn-add" id="updateTrendsBtn" style="background:#f59e0b;color:#000;">📈 Update Trends</button>
      <a href="/admin/analysis" class="btn btn-add" style="text-decoration:none;background:#0ea5e9;">📊 Analysis</a>
      <button class="btn btn-add" id="fetchHistoryBtn" style="background:#06b6d4;">📜 Fetch History</button>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>CA</th>
        <th>Narrative</th>
        <th>Status</th>
        <th>Trend</th>
        <th>Safety</th>
        <th>Enabled</th>
        <th>Created On</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="coinsTable"></tbody>
  </table>

  <!-- Modal -->
  <div class="modal-overlay" id="modal">
    <div class="modal">
      <h2 id="modalTitle">Add Coin</h2>
      <input type="hidden" id="editCoinId" />
      <input type="hidden" id="fIconUrl" />      <div class="form-group">
        <label>Coin Name *</label>
        <div style="display:flex;gap:0.5rem;">
          <input type="text" id="fCoinName" placeholder="e.g. MOVE, RENDER, ONDO" style="flex:1;" />
          <button type="button" class="btn btn-track" id="autofillBtn" style="white-space:nowrap;">🔍 Auto-fill</button>
        </div>
      </div>
      <div class="form-group">
        <label>CA (Contract Address)</label>
        <input type="text" id="fCA" maxlength="50" placeholder="Contract address" />
      </div>
      <div class="form-group">
        <label>DexScreener URL</label>
        <input type="url" id="fDexUrl" placeholder="https://dexscreener.com/solana/..." />
      </div>
      <div class="form-group">
        <label>Narrative</label>
        <input type="text" id="fNarrative" placeholder="e.g. Movement Coin, AI Agent, RWA" />
      </div>
      <div class="form-group">
        <label>Current Status</label>
        <input type="text" id="fStatus" placeholder="e.g. Consolidating, Pumping, Dead" />
      </div>
      <div class="form-group">
        <label>Trend</label>
        <select id="fTrend">
          <option value="">Select...</option>
          <option value="accumulating">Accumulating</option>
          <option value="distributing">Distributing</option>
          <option value="pumping">Pumping</option>
          <option value="dumping">Dumping</option>
          <option value="consolidating">Consolidating</option>
          <option value="dead">Dead</option>
        </select>
      </div>
      <div class="form-group">
        <label>Expert Comment</label>
        <textarea id="fComment" placeholder="Your analysis..."></textarea>
      </div>
      <div class="form-group">
        <label>Enabled</label>
        <select id="fEnabled">
          <option value="yes">Yes</option>
          <option value="no">No</option>
        </select>
      </div>
      <div class="modal-actions">
        <button class="btn btn-save" id="saveBtn">Save</button>
        <button class="btn btn-cancel" id="cancelBtn">Cancel</button>
      </div>
    </div>
  </div>

  <script is:inline>
    var table = document.getElementById('coinsTable');
    var modal = document.getElementById('modal');
    var toast = document.getElementById('toast');
    var coinsData = [];


    function getTrendColor(status, trend) {
      var s = (status || "").toLowerCase();
      var t = (trend || "").toLowerCase();
      if (s === "mooning" || s === "pumping hard" || t === "pumping") return "#10b981";
      if (s === "pumping" || s === "creeping up" || t === "accumulating") return "#4ade80";
      if (s === "consolidating" || t === "consolidating") return "#f59e0b";
      if (s === "bleeding" || t === "distributing") return "#f97316";
      if (s === "dumping" || s === "profit taking" || t === "dumping") return "#ef4444";
      if (s === "dumping hard" || s === "crashing") return "#dc2626";
      if (s === "dead cat bounce") return "#a855f7";
      return "#94a3b8";
    }    // Drumroll audio
    var drumAudio = new Audio("/media/drumroll.mp3");
    var drumLoopInterval = null;
    function startDrumroll() {
      drumAudio.currentTime = 0;
      drumAudio.play();
      drumLoopInterval = setInterval(function() { if (drumAudio.currentTime >= 4) drumAudio.currentTime = 0; }, 50);
    }
    function finishDrumroll() {
      if (drumLoopInterval) { clearInterval(drumLoopInterval); drumLoopInterval = null; }
      drumAudio.currentTime = 4;
      drumAudio.play();
    }
    function stopDrumroll() {
      if (drumLoopInterval) { clearInterval(drumLoopInterval); drumLoopInterval = null; }
      drumAudio.pause();
      drumAudio.currentTime = 0;
    }
    function showToast(msg, type) {
      toast.textContent = msg;
      toast.className = 'toast toast-' + type;
      toast.style.display = 'block';
      setTimeout(function() { toast.style.display = 'none'; }, 3000);
    }

    async function loadCoins() {
      var res = await fetch('/api/coins');
      var data = await res.json();
      coinsData = data.coins;
      table.innerHTML = coinsData.map(function(c) {
        var caShort = c.ca ? (c.ca.length > 12 ? c.ca.slice(0,6) + '...' + c.ca.slice(-4) : c.ca) : '\u2014';
        return '<tr>' +
          '<td>' + c.coinid + '</td>' +
          '<td>' + (c.icon_url ? '<img src="' + c.icon_url + '" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;margin-right:6px;" />' : '') + '<strong>' + (c.coinname || '\u2014') + '</strong></td>' +
          '<td title="' + (c.ca || '') + '"><code style="font-size:0.75rem;color:#94a3b8;">' + caShort + '</code></td>' +
          '<td>' + (c.narrative || '\u2014') + '</td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + '"><strong>' + (c.currentstatus || '—') + '</strong></td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + '">' + (c.trend || '—') + '</td>' +
          '<td>' + (c.safety || '\u2014') + '</td>' +
          '<td><span class="badge badge-' + (c.enabled === 'yes' ? 'yes' : 'no') + '">' + c.enabled + '</span></td>' +
          '<td>' + (c.createdon ? c.createdon.slice(0, 10) : c.datecreated ? c.datecreated.slice(0, 10) : '\u2014') + '</td>' +
          '<td>' +
            '<button class="btn btn-edit" onclick="editCoin(' + c.coinid + ')">Edit</button> ' +
            '<button class="btn btn-delete" onclick="deleteCoin(' + c.coinid + ')">Delete</button> ' +
            '<button class="btn btn-track" onclick="trackCoin(' + c.coinid + ')">Track</button>' +
          '</td>' +
        '</tr>';
      }).join('');
    }

    function openModal(coin) {
      document.getElementById('modalTitle').textContent = coin ? 'Edit Coin' : 'Add Coin';
      document.getElementById('editCoinId').value = coin ? coin.coinid : '';
      document.getElementById('fCoinName').value = coin ? (coin.coinname || '') : '';
      document.getElementById('fCA').value = coin ? (coin.ca || '') : '';
      document.getElementById('fDexUrl').value = coin ? (coin.dexscreenerurl || '') : '';
      document.getElementById('fNarrative').value = coin ? (coin.narrative || '') : '';
      document.getElementById('fStatus').value = coin ? (coin.currentstatus || '') : '';
      document.getElementById('fTrend').value = coin ? (coin.trend || '') : '';
      document.getElementById('fComment').value = coin ? (coin.expert_comment || '') : '';
      document.getElementById('fEnabled').value = coin ? (coin.enabled || 'yes') : 'yes';
      document.getElementById('fIconUrl').value = coin ? (coin.icon_url || '') : '';      modal.classList.add('active');
    }

    window.editCoin = function(id) {
      var coin = coinsData.find(function(c) { return c.coinid === id; });
      if (coin) openModal(coin);
    };

    window.deleteCoin = async function(id) {
      if (!confirm('Delete this coin?')) return;
      var res = await fetch('/api/coins?coinid=' + id, { method: 'DELETE' });
      if (res.ok) { showToast('Coin deleted', 'success'); loadCoins(); }
      else showToast('Delete failed', 'error');
    };

    window.trackCoin = function(id) {
      window.location.href = '/admin/tracker?coinid=' + id;
    };

    document.getElementById('addBtn').addEventListener('click', function() { openModal(null); });
    document.getElementById('cancelBtn').addEventListener('click', function() { modal.classList.remove('active'); });
    modal.addEventListener('click', function(e) { if (e.target === modal) modal.classList.remove('active'); });

    document.getElementById('saveBtn').addEventListener('click', async function() {
      var coinid = document.getElementById('editCoinId').value;
      var body = {
        coinid: coinid ? Number(coinid) : undefined,
        coinname: document.getElementById('fCoinName').value,
        ca: document.getElementById('fCA').value,
        dexscreenerurl: document.getElementById('fDexUrl').value,
        narrative: document.getElementById('fNarrative').value,
        currentstatus: document.getElementById('fStatus').value,
        trend: document.getElementById('fTrend').value,
        expert_comment: document.getElementById('fComment').value,
        enabled: document.getElementById('fEnabled').value,
        icon_url: document.getElementById('fIconUrl').value,
      };
      if (!body.coinname) { showToast('Coin Name is required', 'error'); return; }
      var method = coinid ? 'PUT' : 'POST';
      var res = await fetch('/api/coins', { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      if (res.ok) { showToast(coinid ? 'Coin updated' : 'Coin added', 'success'); modal.classList.remove('active'); loadCoins(); }
      else showToast('Save failed', 'error');
    });

    // Auto-fill from DexScreener search
    document.getElementById('autofillBtn').addEventListener('click', async function() {
      var name = document.getElementById('fCoinName').value.trim();
      if (!name) { showToast('Enter a coin name first', 'error'); return; }
      this.disabled = true;
      this.textContent = '...';
      try {
        var res = await fetch('/api/autofill', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ coinname: name }) });
        if (res.ok) {
          var data = await res.json();
          document.getElementById('fCoinName').value = data.coinname || name;
          document.getElementById('fCA').value = data.ca || '';
          document.getElementById('fIconUrl').value = data.icon_url || '';          document.getElementById('fDexUrl').value = data.dexscreenerurl || '';
          document.getElementById('fStatus').value = data.currentstatus || '';
          document.getElementById('fTrend').value = data.trend || '';
          document.getElementById('fComment').value = data.extra ? 'Price: ' + data.extra.priceUsd + ' | FDV: ' + data.extra.fdv + ' | Liq: ' + data.extra.liquidity + ' | 24h: ' + data.extra.h24Change + ' | Chain: ' + data.extra.chain + ' | DEX: ' + data.extra.dex : '';
          showToast('Auto-filled (' + (data.extra ? data.extra.totalResults : 0) + ' results found)', 'success');
        } else {
          var err = await res.json();
          showToast(err.error || 'Not found', 'error');
        }
      } catch(e) { showToast('Error: ' + e.message, 'error'); }
      this.disabled = false;
      this.textContent = '\uD83D\uDD0D Auto-fill';
    });

    // RugCheck All
    // Fetch All Coins Data
    document.getElementById("fetchAllBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Fetching all...";
      startDrumroll();      try {
        var res = await fetch("/api/fetch-all", { method: "POST" });
        if (res.ok) {
          var data = await res.json();
          var ok = data.results.filter(function(r) { return r.status === "success"; }).length;
          var fail = data.results.filter(function(r) { return r.status === "failed"; }).length;
          finishDrumroll();          showToast("Batch " + data.batchId + ": " + ok + " fetched, " + fail + " failed", ok > 0 ? "success" : "error");
          loadCoins();
        } else { stopDrumroll(); showToast("Fetch all failed", "error"); }
      } catch(e) { stopDrumroll(); showToast("Error: " + e.message, "error"); }
      this.disabled = false;
      this.textContent = "⚡ Fetch All Coins Data";
    });
    // Update Trends
    // Fetch History
    document.getElementById("fetchHistoryBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Loading history...";
      startDrumroll();
      try {
        var res = await fetch("/api/fetch-history", { method: "POST" });
        if (res.ok) {
          var data = await res.json();
          finishDrumroll();
          var total = data.results.reduce(function(s, r) { return s + (r.hourlyCandles || 0) + (r.dailyCandles || 0); }, 0);
          showToast("Loaded " + total + " candles for " + data.results.length + " coins", "success");
        } else { stopDrumroll(); showToast("Fetch history failed", "error"); }
      } catch(e) { stopDrumroll(); showToast("Error: " + e.message, "error"); }
      this.disabled = false;
      this.textContent = "📜 Fetch History";
    });
    document.getElementById("updateTrendsBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Updating...";
      startDrumroll();
      try {
        var hours = document.getElementById("trendHours").value;
        var res = await fetch("/api/update-trends", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({hours: Number(hours)}) });
        if (res.ok) {
          var data = await res.json();
          finishDrumroll();
          showToast("Trends updated for " + data.results.length + " coins", "success");
          loadCoins();
        } else { stopDrumroll(); showToast("Update failed", "error"); }
      } catch(e) { stopDrumroll(); showToast("Error: " + e.message, "error"); }
      this.disabled = false;
      this.textContent = "📈 Update Trends";
    });
    document.getElementById('rugCheckBtn').addEventListener('click', async function() {
      this.disabled = true;
      this.textContent = '\uD83D\uDD04 Checking...';
      try {
        var res = await fetch('/api/rugcheck', { method: 'POST' });
        if (res.ok) {
          var data = await res.json();
          showToast('RugCheck complete for ' + data.results.length + ' coins', 'success');
          loadCoins();
        } else showToast('RugCheck failed', 'error');
      } catch(e) { showToast('Error: ' + e.message, 'error'); }
      this.disabled = false;
      this.textContent = '\uD83D\uDEE1\uFE0F RugCheck All';
    });

    loadCoins();
  </script>
</Layout>
