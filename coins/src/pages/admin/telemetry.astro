---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Telemetry — Admin" showHeader={false}>
  <nav style="background:linear-gradient(180deg,#2a2a3a,#1a1a28);padding:0.8rem 1.5rem;border-bottom:1px solid #3f3f5a;display:flex;align-items:center;justify-content:space-between;">
    <div style="display:flex;align-items:center;gap:1rem;">
      <a href="/admin" style="color:#a1a1aa;font-weight:700;text-decoration:none;font-size:1rem;">⚙️ Admin</a>
      <a href="/admin/emails" style="color:#a1a1aa;text-decoration:none;font-size:0.85rem;">Emails</a>
      <a href="/admin/clicks" style="color:#a1a1aa;text-decoration:none;font-size:0.85rem;">Clicks</a>
      <a href="/admin/telemetry" style="color:#c084fc;text-decoration:none;font-size:0.85rem;">Telemetry</a>
    </div>
    <div style="display:flex;gap:1rem;align-items:center;">
      <a href="/" style="color:#71717a;text-decoration:none;font-size:0.85rem;">← Site</a>
      <a href="/api/auth/logout" style="color:#ef4444;text-decoration:none;font-size:0.85rem;">Logout</a>
    </div>
  </nav>
  <div style="max-width:900px;margin:2rem auto;padding:0 1rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <h1 style="font-size:1.5rem;font-weight:700;color:#fafafa;">📡 Telemetry</h1>
      <button class="btn" onclick="runCheck()" id="checkBtn" style="font-size:0.8rem;">Run Health Check</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;">
      <div style="padding:1rem;border-radius:8px;border:1px solid #10b981;background:rgba(16,185,129,0.05);text-align:center;">
        <p id="healthyCount" style="font-size:1.3rem;font-weight:700;color:#10b981;">—</p>
        <p style="color:#71717a;font-size:0.75rem;">Healthy</p>
      </div>
      <div style="padding:1rem;border-radius:8px;border:1px solid #ef4444;background:rgba(239,68,68,0.05);text-align:center;">
        <p id="issueCount" style="font-size:1.3rem;font-weight:700;color:#ef4444;">—</p>
        <p style="color:#71717a;font-size:0.75rem;">Issues</p>
      </div>
      <div style="padding:1rem;border-radius:8px;border:1px solid #06b6d4;background:rgba(6,182,212,0.05);text-align:center;">
        <p id="avgMs" style="font-size:1.3rem;font-weight:700;color:#06b6d4;">—</p>
        <p style="color:#71717a;font-size:0.75rem;">Avg ms</p>
      </div>
    </div>
    <div id="checks" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
    <h2 style="color:#a1a1aa;font-size:0.9rem;margin-top:2rem;margin-bottom:1rem;">History (last 20)</h2>
    <div style="overflow-x:auto;">
      <table><thead><tr><th>Endpoint</th><th>Status</th><th>Response</th><th>Time</th></tr></thead><tbody id="historyBody"></tbody></table>
    </div>
  </div>
  <script is:inline>
    async function runCheck() {
      document.getElementById('checkBtn').textContent = 'Checking...';
      try {
        var res = await fetch('/api/telemetry');
        if (!res.ok) return;
        var data = await res.json();
        document.getElementById('healthyCount').textContent = data.summary?.healthy || '0';
        document.getElementById('issueCount').textContent = data.summary?.issues || '0';
        document.getElementById('avgMs').textContent = (data.summary?.avgMs || '0') + 'ms';
        var el = document.getElementById('checks');
        el.innerHTML = (data.checks || []).map(function(c) {
          var color = c.healthy ? '#10b981' : '#ef4444';
          return '<div style="padding:0.8rem;border-radius:8px;border:1px solid '+color+';background:rgba('+(c.healthy?'16,185,129':'239,68,68')+',0.05);display:flex;justify-content:space-between;align-items:center;"><span style="color:#fafafa;font-size:0.85rem;">'+c.name+'</span><span style="color:'+color+';font-size:0.85rem;font-weight:600;">'+c.ms+'ms ('+c.status+')</span></div>';
        }).join('');
      } catch(e) {}
      document.getElementById('checkBtn').textContent = 'Run Health Check';
      loadHistory();
    }
    async function loadHistory() {
      try {
        var res = await fetch('/api/telemetry?history=true');
        if (!res.ok) return;
        var data = await res.json();
        var tbody = document.getElementById('historyBody');
        tbody.innerHTML = (data.history || []).slice(0,20).map(function(h) {
          var color = h.healthy ? '#10b981' : '#ef4444';
          return '<tr><td style="font-size:0.8rem;">'+h.endpoint_name+'</td><td style="color:'+color+';font-size:0.8rem;">'+h.status_code+'</td><td style="font-size:0.8rem;">'+h.response_ms+'ms</td><td style="font-size:0.75rem;color:#71717a;">'+h.checked_at+'</td></tr>';
        }).join('');
      } catch(e) {}
    }
    loadHistory();
  </script>
</Layout>
