---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — xCrypto24" description="Get in touch with xCrypto24. Report bugs, request features, or ask questions about our free crypto tracking tool." keywords="contact xcrypto24, crypto tracker support, report bug, feature request">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Contact — xCrypto24","url":"https://xcrypto24.com/contact","description":"Get in touch with xCrypto24. Report bugs, request features, or ask questions about our free crypto tracking tool."})} />
  <div style="max-width:600px;margin:2rem auto;padding:0 1rem;">
    <h1 style="font-size:2rem;font-weight:700;color:#fafafa;margin-bottom:0.5rem;">📬 Contact Us</h1>
    <p style="color:#a1a1aa;margin-bottom:1.5rem;">Have a question, found a bug, or want to collaborate?</p>

    <div style="margin-bottom:2rem;display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;">
      <div style="padding:0.8rem;border-radius:8px;border:1px solid #3f3f5a;background:#16161f;text-align:center;">
        <p style="font-size:1.2rem;margin-bottom:0.2rem;">⚡</p>
        <p style="font-size:0.75rem;color:#a1a1aa;">Usually reply within 24h</p>
      </div>
      <div style="padding:0.8rem;border-radius:8px;border:1px solid #3f3f5a;background:#16161f;text-align:center;">
        <p style="font-size:1.2rem;margin-bottom:0.2rem;">💡</p>
        <p style="font-size:0.75rem;color:#a1a1aa;"><a href="/suggest" style="color:#c084fc;text-decoration:none;">Have a feature idea? →</a></p>
      </div>
    </div>

    <form id="contactForm" style="display:flex;flex-direction:column;gap:1rem;">
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Name</label>
        <input type="text" id="cName" placeholder="Your name" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;" />
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Email</label>
        <input type="email" id="cEmail" placeholder="you@example.com" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;" />
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Subject</label>
        <select id="cSubject" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;">
          <option value="general">General Question</option>
          <option value="bug">Bug Report</option>
          <option value="feature">Feature Request</option>
          <option value="data">Data / API Issue</option>
          <option value="privacy">Privacy / Data Deletion</option>
          <option value="partnership">Partnership / Collaboration</option>
        </select>
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Message *</label>
        <textarea id="cMessage" rows="5" placeholder="Your message..." required style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;resize:vertical;"></textarea>
      </div>
      <button type="submit" class="btn btn-add" style="align-self:flex-start;">Send Message →</button>
      <div id="contactStatus" style="font-size:0.85rem;"></div>
    </form>

    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #27272a;">
      <h2 style="font-size:0.9rem;color:#71717a;margin-bottom:0.8rem;">Quick Links</h2>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/guide" style="color:#c084fc;font-size:0.8rem;text-decoration:none;">📖 User Guide</a>
        <a href="/privacy" style="color:#c084fc;font-size:0.8rem;text-decoration:none;">🔒 Privacy Policy</a>
        <a href="/terms" style="color:#c084fc;font-size:0.8rem;text-decoration:none;">📋 Terms</a>
        <a href="/disclaimer" style="color:#c084fc;font-size:0.8rem;text-decoration:none;">⚠️ Disclaimer</a>
      </div>
    </div>

    <div style="margin-top:2rem;text-align:center;">
      <a href="/coins" style="color:#71717a;font-size:0.85rem;text-decoration:none;">← Back to Coins</a>
    </div>
  </div>

  <script is:inline>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var status = document.getElementById('contactStatus');
      var msg = document.getElementById('cMessage').value.trim();
      if (!msg) { status.textContent = 'Message required'; status.style.color = '#f87171'; return; }
      status.textContent = 'Sending...'; status.style.color = '#a1a1aa';
      try {
        var res = await fetch('/api/contact', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: document.getElementById('cName').value, email: document.getElementById('cEmail').value, subject: document.getElementById('cSubject').value, message: msg })
        });
        if (res.ok) { status.textContent = '✓ Message sent! We\'ll get back to you within 24 hours.'; status.style.color = '#4ade80'; document.getElementById('contactForm').reset(); }
        else { status.textContent = 'Failed to send. Try again.'; status.style.color = '#f87171'; }
      } catch(err) { status.textContent = 'Error: ' + err.message; status.style.color = '#f87171'; }
    });
  </script>
</Layout>
