---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact">
  <h1>Contact Us</h1>
  <div style="max-width:500px;">
    <p style="color:#94a3b8;margin-bottom:1.5rem;">Got a question, found a bug, or want to say hi? Send us a message.</p>
    <form id="contactForm">
      <div class="form-group"><label>Name</label><input type="text" id="cName" placeholder="Your name" required /></div>
      <div class="form-group"><label>Email</label><input type="email" id="cEmail" placeholder="your@email.com" required /></div>
      <div class="form-group"><label>Subject</label>
        <select id="cSubject"><option value="general">General</option><option value="bug">Bug Report</option><option value="feature">Feature Suggestion</option><option value="other">Other</option></select>
      </div>
      <div class="form-group"><label>Message</label><textarea id="cMessage" placeholder="Your message..." required></textarea></div>
      <button type="submit" class="btn btn-add" style="width:100%;padding:0.8rem;">Send Message</button>
    </form>
    <div id="cResult" style="margin-top:1rem;display:none;"></div>
  </div>
  <script is:inline>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var res = await fetch('/api/contact', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ name: document.getElementById('cName').value, email: document.getElementById('cEmail').value, subject: document.getElementById('cSubject').value, message: document.getElementById('cMessage').value })
      });
      var r = document.getElementById('cResult');
      if (res.ok) { r.style.display = 'block'; r.style.color = '#10b981'; r.textContent = 'Message sent! We will get back to you soon.'; this.reset(); }
      else { r.style.display = 'block'; r.style.color = '#ef4444'; r.textContent = 'Failed to send. Please try again.'; }
    });
  </script>
</Layout>
