---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Release Notes — xCrypto24" description="Changelog and release notes for xCrypto24. See what's new, improved, and fixed." keywords="xcrypto24 releases, changelog, what's new, crypto tracker updates">
  <script type="application/ld+json" is:inline set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Release Notes","url":"https://xcrypto24.com/releases","description":"Changelog and release notes for xCrypto24."})} />
  <div style="max-width:800px;margin:2rem auto;padding:0 1rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;">
      <div>
        <h1 style="font-size:2rem;font-weight:700;color:#fafafa;margin-bottom:0.3rem;">📋 Release Notes</h1>
        <p style="color:#a1a1aa;font-size:0.9rem;">What's new in xCrypto24</p>
      </div>
      <a href="/tech-stack" style="display:flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;border-radius:6px;border:1px solid #3f3f5a;background:#16161f;text-decoration:none;color:#c084fc;font-size:0.8rem;">🛠 Tech Stack</a>
    </div>

    <!-- v1.0.0 -->
    <div style="margin-bottom:2rem;padding:1.5rem;border-radius:12px;border:1px solid rgba(139,92,246,0.4);background:linear-gradient(180deg,#1e1e2e,#16161f);">
      <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:1rem;">
        <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(139,92,246,0.2);border:1px solid rgba(139,92,246,0.4);color:#c084fc;font-size:0.75rem;font-weight:700;">v1.0.0</span>
        <span style="color:#71717a;font-size:0.8rem;">June 16, 2026</span>
        <span style="padding:0.15rem 0.5rem;border-radius:4px;background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;font-size:0.7rem;">LATEST</span>
      </div>
      <h3 style="color:#fafafa;font-size:1.1rem;margin-bottom:1rem;">🚀 Initial Public Release — Titanium Edition</h3>

      <h4 style="color:#c084fc;font-size:0.85rem;margin:1.2rem 0 0.6rem;text-transform:uppercase;letter-spacing:0.05em;">Coin Tracker</h4>
      <div style="display:flex;flex-direction:column;gap:0.4rem;">
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Real-time coin tracking with DexScreener data</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Add/Edit coins with autofill by name or contract address</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Scan New Coins — discover fresh tokens from DexScreener</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">RugCheck safety reports with detail modal</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Bubble Map integration (Bubblemaps.io)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Favourites system (DB-backed, purple hearts)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Filters: Market Cap, Age, Favourites, New (&lt;24h)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Sortable columns with direction indicators</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Age column with color-coded badges</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Media links (X, Website, Telegram) per coin</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Enable/disable toggle + history for disabled coins</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#4ade80;font-size:0.8rem;">✨</span><p style="font-size:0.85rem;color:#d4d4d8;">Dark/Light theme toggle</p></div>
      </div>

      <h4 style="color:#c084fc;font-size:0.85rem;margin:1.2rem 0 0.6rem;text-transform:uppercase;letter-spacing:0.05em;">Blog (50 Articles)</h4>
      <div style="display:flex;flex-direction:column;gap:0.4rem;">
        <div style="display:flex;gap:0.5rem;"><span style="color:#38bdf8;font-size:0.8rem;">📝</span><p style="font-size:0.85rem;color:#d4d4d8;">50 educational crypto blog posts across 6 categories</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#38bdf8;font-size:0.8rem;">📝</span><p style="font-size:0.85rem;color:#d4d4d8;">Categories: Bitcoin, Beginner, Altcoins, DeFi, Trading, History</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#38bdf8;font-size:0.8rem;">📝</span><p style="font-size:0.85rem;color:#d4d4d8;">Cross-links between all 50 posts (3 related per article)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#38bdf8;font-size:0.8rem;">📝</span><p style="font-size:0.85rem;color:#d4d4d8;">Rich visual blocks: stat strips, card grids, callout boxes</p></div>
      </div>

      <h4 style="color:#c084fc;font-size:0.85rem;margin:1.2rem 0 0.6rem;text-transform:uppercase;letter-spacing:0.05em;">Infrastructure</h4>
      <div style="display:flex;flex-direction:column;gap:0.4rem;">
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Google OAuth admin protection</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Cookie consent (GDPR compliant)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Anonymous click tracking (20-field, privacy-respecting)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Email service (contact + suggest → DB + notification)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Telemetry endpoint health monitoring</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">Admin dashboard: Emails, Clicks, Telemetry</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#f59e0b;font-size:0.8rem;">🔧</span><p style="font-size:0.85rem;color:#d4d4d8;">PWA manifest + social card</p></div>
      </div>

      <h4 style="color:#c084fc;font-size:0.85rem;margin:1.2rem 0 0.6rem;text-transform:uppercase;letter-spacing:0.05em;">Design</h4>
      <div style="display:flex;flex-direction:column;gap:0.4rem;">
        <div style="display:flex;gap:0.5rem;"><span style="color:#8b5cf6;font-size:0.8rem;">🎨</span><p style="font-size:0.85rem;color:#d4d4d8;">Titanium & carbon fiber visual theme</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#8b5cf6;font-size:0.8rem;">🎨</span><p style="font-size:0.85rem;color:#d4d4d8;">Purple accent palette (#8b5cf6, #c084fc)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#8b5cf6;font-size:0.8rem;">🎨</span><p style="font-size:0.85rem;color:#d4d4d8;">Shield + pulse logo (5 variants)</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#8b5cf6;font-size:0.8rem;">🎨</span><p style="font-size:0.85rem;color:#d4d4d8;">Mobile responsive</p></div>
      </div>

      <h4 style="color:#c084fc;font-size:0.85rem;margin:1.2rem 0 0.6rem;text-transform:uppercase;letter-spacing:0.05em;">SEO</h4>
      <div style="display:flex;flex-direction:column;gap:0.4rem;">
        <div style="display:flex;gap:0.5rem;"><span style="color:#10b981;font-size:0.8rem;">🔍</span><p style="font-size:0.85rem;color:#d4d4d8;">JSON-LD structured data on all pages</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#10b981;font-size:0.8rem;">🔍</span><p style="font-size:0.85rem;color:#d4d4d8;">Meta descriptions + keywords on all 64 pages</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#10b981;font-size:0.8rem;">🔍</span><p style="font-size:0.85rem;color:#d4d4d8;">Canonical URLs, OG tags, Twitter cards</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#10b981;font-size:0.8rem;">🔍</span><p style="font-size:0.85rem;color:#d4d4d8;">Sitemap (64 URLs) + robots.txt</p></div>
        <div style="display:flex;gap:0.5rem;"><span style="color:#10b981;font-size:0.8rem;">🔍</span><p style="font-size:0.85rem;color:#d4d4d8;">Admin noindex protection</p></div>
      </div>
    </div>

    <div style="margin-top:2rem;text-align:center;">
      <a href="/coins" style="color:#71717a;font-size:0.85rem;text-decoration:none;">← Back to Coins</a>
    </div>
  </div>
</Layout>
