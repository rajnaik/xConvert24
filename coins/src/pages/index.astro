---
import Layout from '../layouts/Layout.astro';
---
<Layout title="xCrypto24 — Free Real-Time Memecoin Tracker" description="Track memecoins in real-time. Analyze trends, check safety scores, scan new tokens, and monitor your crypto portfolio — all free, no signup." keywords="memecoin tracker, free crypto tracker, solana token scanner, real-time crypto prices, rug check, dexscreener, new coin scanner">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"xCrypto24 — Free Real-Time Memecoin Tracker","url":"https://xcrypto24.com/","description":"Track memecoins in real-time. Analyze trends, check safety scores, scan new tokens, and monitor your crypto portfolio — all free, no signup."})} />
  <div style="text-align:center;padding:3rem 1rem;">
    <h1 style="font-size:2.5rem;margin-bottom:1rem;">🪙 xCrypto24</h1>
    <p style="color:#94a3b8;font-size:1.1rem;max-width:600px;margin:0 auto 2rem;">Track memecoins in real-time. Analyze trends, check safety scores, and monitor your portfolio — all free.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/coins" class="btn btn-add" style="text-decoration:none;padding:0.8rem 2rem;font-size:1rem;">📊 View Coins Dashboard</a>
      <a href="/admin/analysis" class="btn btn-track" style="text-decoration:none;padding:0.8rem 2rem;font-size:1rem;">📈 Tech Analysis</a>
    </div>
  </div>
  <div style="max-width:800px;margin:2rem auto;padding:2rem;background:#1e293b;border-radius:12px;border:1px solid #334155;">
    <h2 style="margin-bottom:1rem;">What is xCrypto24?</h2>
    <p style="color:#94a3b8;line-height:1.7;">xCrypto24 is a free cryptocurrency tracking tool focused on memecoins and low-cap tokens on Solana. We pull real-time data from DexScreener and RugCheck to give you price charts, safety scores, holder analysis, and trend detection — all in one dashboard. No signup required, no API keys needed, completely free.</p>
    <h3 style="margin:1.5rem 0 0.8rem;color:#f59e0b;">Features</h3>
    <ul style="color:#94a3b8;line-height:2;padding-left:1.5rem;">
      <li>Real-time price data from DexScreener API</li>
      <li>Safety scores and rug check from RugCheck.xyz</li>
      <li>Historical OHLCV candlestick charts (GeckoTerminal)</li>
      <li>Trend detection — Pumping, Consolidating, Dumping, etc.</li>
      <li>Holder analysis and top holder concentration</li>
      <li>Bundle/insider network detection</li>
      <li>Buy/sell volume tracking</li>
      <li>Batch fetch all coins at once</li>
    </ul>
  </div>
</Layout>
