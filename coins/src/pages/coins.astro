    // RugCheck All
    // Fetch All Coins Data
    document.getElementById("fetchAllBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Fetching all...";
      startDrumroll();      try {
        var res = await fetch("/api/fetch-all", { method: "POST" });
        if (res.ok) {
          var data = await res.json();
          var ok = data.results.filter(function(r) { return r.status === "success"; }).length;
          var fail = data.results.filter(function(r) { return r.status === "failed"; }).length;
          finishDrumroll();          showToast("Batch " + data.batchId + ": " + ok + " fetched, " + fail + " failed", ok > 0 ? "success" : "error");
          loadCoins();
