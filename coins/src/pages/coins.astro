    });
    // Update Trends
    // Fetch History
    document.getElementById("fetchHistoryBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Loading history...";
      startDrumroll();
      try {
        var res = await fetch("/api/fetch-history", { method: "POST" });
        if (res.ok) {
          var data = await res.json();
          finishDrumroll();
          var total = data.results.reduce(function(s, r) { return s + (r.hourlyCandles || 0) + (r.dailyCandles || 0); }, 0);
          showToast("Loaded " + total + " candles for " + data.results.length + " coins", "success");
        } else { stopDrumroll(); showToast("Fetch history failed", "error"); }
      } catch(e) { stopDrumroll(); showToast("Error: " + e.message, "error"); }
      this.disabled = false;
      this.textContent = "📜 Fetch History";
    });
    document.getElementById("updateTrendsBtn").addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "⏳ Updating...";
      startDrumroll();
      try {
        var hours = document.getElementById("trendHours").value;
        var res = await fetch("/api/update-trends", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({hours: Number(hours)}) });
        if (res.ok) {
          var data = await res.json();
          finishDrumroll();
          showToast("Trends updated for " + data.results.length + " coins", "success");
          loadCoins();
        } else { stopDrumroll(); showToast("Update failed", "error"); }
      } catch(e) { stopDrumroll(); showToast("Error: " + e.message, "error"); }
      this.disabled = false;
      this.textContent = "📈 Update Trends";
    });
    // Persist update frequency in localStorage and refresh on change
    var savedFreq = localStorage.getItem('xcrypto_update_frequency');
    if (savedFreq) {
      document.getElementById("trendHours").value = savedFreq;
    }
    document.getElementById("trendHours").addEventListener("change", function() {
      localStorage.setItem('xcrypto_update_frequency', this.value);
      window.location.reload();
    });
    document.getElementById('rugCheckBtn').addEventListener('click', async function() {
      this.disabled = true;
      this.textContent = '\uD83D\uDD04 Checking...';
      try {
        var res = await fetch('/api/rugcheck', { method: 'POST' });
        if (res.ok) {
          var data = await res.json();
          showToast('RugCheck complete for ' + data.results.length + ' coins', 'success');
          loadCoins();
        } else showToast('RugCheck failed', 'error');
      } catch(e) { showToast('Error: ' + e.message, 'error'); }
      this.disabled = false;
      this.textContent = '\uD83D\uDEE1\uFE0F RugCheck All';
    });

    // Update Latest — fetches fresh data for all coins and refreshes table
    // Show last update time from log
    var updateLog = JSON.parse(localStorage.getItem('updateLatestLog') || '[]');
    if (updateLog.length > 0) {
      var last = updateLog[updateLog.length - 1];
      var lastTime = typeof last === 'string' ? last : last.time;
      var lastInfo = typeof last === 'object' && last.failed > 0 ? ' (' + last.failed + ' failed ⓘ)' : '';
      document.getElementById("updateStatus").textContent = "Last updated: " + lastTime + lastInfo;
      document.getElementById("updateStatus").style.color = (typeof last === 'object' && last.failed > 0) ? "#f59e0b" : "#94a3b8";
    } else {
      document.getElementById("updateStatus").textContent = "Never updated";
      document.getElementById("updateStatus").style.color = "#64748b";
    }

    var lastFailedResults = [];

    document.getElementById("updateLatestBtn").addEventListener("click", async function() {
      var btn = this;
      var status = document.getElementById("updateStatus");
      var bubble = document.getElementById("updateBubble");
      bubble.style.display = "none";
      btn.disabled = true;
      btn.textContent = "⏳ Updating...";
      status.style.filter = "blur(3px)";
      status.style.opacity = "0.5";
      try {
        var res = await fetch("/api/fetch-all", { method: "POST" });
        if (res.ok) {
          var data = await res.json();
          var ok = data.results.filter(function(r) { return r.status === "success"; }).length;
          var failed = data.results.filter(function(r) { return r.status === "failed"; });
          var fail = failed.length;
          lastFailedResults = failed;
          var now = new Date().toLocaleString();
          // Log to localStorage (with error details)
          var log = JSON.parse(localStorage.getItem('updateLatestLog') || '[]');
          var logEntry = { time: now, success: ok, failed: fail, coins: data.results.filter(function(r) { return r.status === 'success'; }).map(function(r) { return r.coinname; }), errors: failed.map(function(r) { return r.coinname + ': ' + (r.error || 'Unknown'); }) };
          log.push(logEntry);
          if (log.length > 50) log = log.slice(-50);
          localStorage.setItem('updateLatestLog', JSON.stringify(log));
          status.textContent = "Updated " + ok + " coins" + (fail > 0 ? " (" + fail + " failed ⓘ)" : "") + " — " + now;
          status.style.color = fail > 0 ? "#f59e0b" : "#22c55e";
          loadCoins();
          // Also trigger Update Trends
          var hours = localStorage.getItem('xcrypto_update_frequency') || '1';
          fetch("/api/update-trends", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({hours: Number(hours)}) }).then(function() { loadCoins(); });
        } else {
          status.textContent = "Update failed";
          status.style.color = "#ef4444";
        }
      } catch(e) {
        status.textContent = "Error: " + e.message;
        status.style.color = "#ef4444";
      }
      btn.disabled = false;
      btn.textContent = "🔄 Update Latest";
      status.style.filter = "none";
      status.style.opacity = "1";
    });

    // Show bubble with failed details on status click
    document.getElementById("updateStatus").addEventListener("click", function() {
      if (lastFailedResults.length === 0) return;
      var bubble = document.getElementById("updateBubble");
      var content = document.getElementById("bubbleContent");
      content.innerHTML = lastFailedResults.map(function(r) {
        return '<div style="padding:0.3rem 0;border-bottom:1px solid #334155;">' +
          '<span style="color:#f8fafc;">' + (r.coinname || 'ID ' + r.coinid) + '</span>' +
          '<span style="color:#ef4444;margin-left:0.5rem;font-size:0.75rem;">' + (r.error || 'Unknown error') + '</span>' +
        '</div>';
      }).join('');
      bubble.style.display = "block";
    });

    document.getElementById("closeBubble").addEventListener("click", function() {
      document.getElementById("updateBubble").style.display = "none";
    });

    // Logs panel with pagination
    var logsPage = 0;
    var logsPerPage = 5;
    function renderLogs() {
      var logs = JSON.parse(localStorage.getItem('updateLatestLog') || '[]').slice().reverse();
      var content = document.getElementById("logsContent");
      var total = logs.length;
      if (total === 0) { content.innerHTML = '<span style="color:#64748b;">No logs yet</span>'; return; }
      var totalPages = Math.ceil(total / logsPerPage);
      if (logsPage >= totalPages) logsPage = totalPages - 1;
      var start = logsPage * logsPerPage;
      var pageItems = logs.slice(start, start + logsPerPage);
      var html = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;"><span style="color:#64748b;font-size:0.7rem;">Total: <strong style="color:#e2e8f0;">' + total + '</strong> updates</span>';
      if (total > logsPerPage) {
        html += '<span style="display:flex;gap:0.4rem;align-items:center;">' +
          '<button class="btn" style="padding:0.15rem 0.4rem;font-size:0.8rem;background:linear-gradient(180deg,#3f4f63 0%,#1e293b 100%);color:#e2e8f0;" onclick="logsPageNav(-1)" ' + (logsPage === 0 ? 'disabled style="opacity:0.4;padding:0.15rem 0.4rem;font-size:0.8rem;background:linear-gradient(180deg,#3f4f63 0%,#1e293b 100%);color:#e2e8f0;"' : '') + '>&lt;</button>' +
          '<span style="color:#94a3b8;font-size:0.8rem;">' + (logsPage + 1) + '/' + totalPages + '</span>' +
          '<button class="btn" style="padding:0.15rem 0.4rem;font-size:0.8rem;background:linear-gradient(180deg,#3f4f63 0%,#1e293b 100%);color:#e2e8f0;" onclick="logsPageNav(1)" ' + (logsPage >= totalPages - 1 ? 'disabled style="opacity:0.4;padding:0.15rem 0.4rem;font-size:0.8rem;background:linear-gradient(180deg,#3f4f63 0%,#1e293b 100%);color:#e2e8f0;"' : '') + '>&gt;</button>' +
        '</span>';
      }
      html += '</div>';
      html += '<table style="width:100%;font-size:0.7rem;"><tr style="color:#64748b;"><th style="text-align:left;padding:0.2rem;">Time</th><th>OK</th><th>Failed</th><th>Coins</th><th>Errors</th></tr>';
      html += pageItems.map(function(l) {
        if (typeof l === 'string') return '<tr><td style="padding:0.2rem;color:#94a3b8;">' + l + '</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>';
        return '<tr><td style="padding:0.2rem;color:#94a3b8;">' + l.time + '</td><td style="color:#22c55e;">' + (l.success || 0) + '</td><td style="color:#ef4444;">' + (l.failed || 0) + '</td><td style="color:#e2e8f0;font-size:0.8rem;max-width:300px;word-wrap:break-word;white-space:normal;">' + (l.coins ? l.coins.join(', ') : '') + '</td><td style="color:#f59e0b;font-size:0.8rem;max-width:200px;word-wrap:break-word;white-space:normal;">' + (l.errors ? l.errors.join(', ') : '') + '</td></tr>';
      }).join('');
      html += '</table>';
      content.innerHTML = html;
    }
    window.logsPageNav = function(dir) { logsPage += dir; renderLogs(); };
    document.getElementById("showLogsBtn").addEventListener("click", function() {
      var panel = document.getElementById("logsPanel");
      if (panel.style.display === "block") { panel.style.display = "none"; return; }
      logsPage = 0;
      renderLogs();
      panel.style.display = "block";
    });
    document.getElementById("closeLogsBtn").addEventListener("click", function() {
      document.getElementById("logsPanel").style.display = "none";
    });
    document.getElementById("clearLogsBtn").addEventListener("click", function() {
      if (!confirm('Delete all update logs?')) return;
      localStorage.removeItem('updateLatestLog');
      renderLogs();
      showToast('Logs cleared', 'success');
    });

    // Toggle enabled/disabled for a coin
    window.toggleEnabled = async function(coinid, current) {
      var newVal = current === 'yes' ? 'no' : 'yes';
      var res = await fetch('/api/coins', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ coinid: coinid, enabled: newVal })
      });
      if (res.ok) {
        showToast(newVal === 'yes' ? 'Coin enabled' : 'Coin disabled', 'success');
        loadCoins();
        loadDisabledCoins();
      } else {
        showToast('Toggle failed', 'error');
      }
    };

    // Disabled Coins section — always visible in side tile
    async function loadDisabledCoins() {
      var res = await fetch('/api/coins?all=true');
      var data = await res.json();
      var disabled = data.coins.filter(function(c) { return c.enabled === 'no'; });
      var container = document.getElementById('disabledList');
      container.innerHTML = disabled.map(function(c) {
        var socials = '';
        try { var s = c.socials ? JSON.parse(c.socials) : {}; socials = '<span style="display:flex;gap:2px;font-size:0.6rem;">' + (s.twitter ? '<a href="https://x.com/' + s.twitter + '" target="_blank" style="text-decoration:none;" title="X">𝕏</a>' : '') + (s.websites && s.websites[0] ? '<a href="' + s.websites[0] + '" target="_blank" style="text-decoration:none;" title="Web">🌐</a>' : '') + (s.telegram ? '<a href="https://t.me/' + s.telegram + '" target="_blank" style="text-decoration:none;" title="TG"><svg style="width:14px;height:14px;vertical-align:middle;" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg></a>' : '') + '</span>'; } catch(e) {}
        return '<div style="display:flex;align-items:center;gap:0.4rem;background:#0f172a;border:1px solid #334155;border-radius:6px;padding:0.4rem 0.6rem;cursor:pointer;" onclick="toggleEnabled(' + c.coinid + ',\'no\')" title="Click to re-enable">' +
          (c.icon_url ? '<img src="' + c.icon_url + '" style="width:18px;height:18px;border-radius:50%;" />' : '') +
          '<span style="font-size:0.85rem;color:#94a3b8;">' + (c.coinname || '—') + '</span>' +
          socials +
          '<span class="badge badge-yes" style="font-size:0.8rem;padding:0.1rem 0.4rem;">✅</span>' +
        '</div>';
      }).join('');
      if (disabled.length === 0) {
        container.innerHTML = '<span style="color:#64748b;font-size:0.75rem;text-align:center;">None</span>';
      }
    }

    // New Scan panel toggle
    var scanPinned = localStorage.getItem('xcrypto_scan_pinned') === 'true';
    if (scanPinned) {
      document.getElementById('scanPanel').style.display = 'block';
      document.getElementById('pinScanPanel').textContent = '🔒';
    }
    function updateScanBtnColor() {
      var panel = document.getElementById('scanPanel');
      var btn = document.getElementById('scanBtn');
      var visible = panel.style.display === 'block';
      btn.style.borderColor = visible ? '#4ade80' : '#22c55e';
      
    }
    if (scanPinned) updateScanBtnColor();
    document.getElementById('scanBtn').addEventListener('click', function() {
      var panel = document.getElementById('scanPanel');
      panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
      updateScanBtnColor();
    });
    document.getElementById('closeScanPanel').addEventListener('click', function() {
      document.getElementById('scanPanel').style.display = 'none';
      updateScanBtnColor();
    });
    document.getElementById('pinScanPanel').addEventListener('click', function() {
      scanPinned = !scanPinned;
      localStorage.setItem('xcrypto_scan_pinned', scanPinned ? 'true' : 'false');
      this.textContent = scanPinned ? '🔒' : '🔓';
      showToast(scanPinned ? 'Panel locked' : 'Panel unlocked', 'success');
    });

    // Scan auto-refresh interval
    var scanAutoInterval = null;
    var savedAutoRefresh = localStorage.getItem('xcrypto_scan_autorefresh') || '0';
    document.getElementById('scanAutoRefresh').value = savedAutoRefresh;
    function startScanAutoRefresh(seconds) {
      if (scanAutoInterval) clearInterval(scanAutoInterval);
      scanAutoInterval = null;
      if (seconds > 0) {
        scanAutoInterval = setInterval(function() {
          var fetchBtn = document.getElementById('scanFetchBtn');
          if (!fetchBtn.disabled) fetchBtn.click();
        }, seconds * 1000);
      }
    }
    document.getElementById('scanAutoRefresh').addEventListener('change', function() {
      localStorage.setItem('xcrypto_scan_autorefresh', this.value);
      startScanAutoRefresh(Number(this.value));
      showToast(this.value === '0' ? 'Auto-refresh off' : 'Auto-refresh every ' + this.options[this.selectedIndex].text, 'success');
    });
    if (Number(savedAutoRefresh) > 0) startScanAutoRefresh(Number(savedAutoRefresh));

    // Scan Age & Sort selection with localStorage
    function updateScanBtnState() {
      var hasUrl = document.getElementById('scanUrl').value.trim().length > 0;
      var hasAge = !!localStorage.getItem('xcrypto_scan_age');
      var hasSort = !!localStorage.getItem('xcrypto_scan_sort');
      var btn = document.getElementById('scanFetchBtn');
      var enabled = hasUrl && hasAge && hasSort;
      btn.disabled = !enabled;
      btn.style.opacity = enabled ? '1' : '0.4';
      btn.style.cursor = enabled ? 'pointer' : 'not-allowed';
    }

    // Restore saved selections
    var savedAge = localStorage.getItem('xcrypto_scan_age') || '';
    var savedSort = localStorage.getItem('xcrypto_scan_sort') || '';
    document.querySelectorAll('.scan-age-btn').forEach(function(btn) {
      if (btn.getAttribute('data-age') === savedAge) btn.style.background = '#f59e0b';
      btn.addEventListener('click', function() {
        document.querySelectorAll('.scan-age-btn').forEach(function(b) { b.style.background = '#334155'; });
        this.style.background = '#f59e0b';
        localStorage.setItem('xcrypto_scan_age', this.getAttribute('data-age'));
        updateScanBtnState();
      });
    });
    document.querySelectorAll('.scan-sort-btn').forEach(function(btn) {
      if (btn.getAttribute('data-sort') === savedSort) btn.style.background = '#3b82f6';
      btn.addEventListener('click', function() {
        document.querySelectorAll('.scan-sort-btn').forEach(function(b) { b.style.background = '#334155'; });
        this.style.background = '#3b82f6';
        localStorage.setItem('xcrypto_scan_sort', this.getAttribute('data-sort'));
        updateScanBtnState();
      });
    });
    document.getElementById('scanUrl').addEventListener('input', updateScanBtnState);
    updateScanBtnState();

    // URL History dropdown
    document.getElementById('scanUrlHistoryBtn').addEventListener('click', function() {
      var historyDiv = document.getElementById('scanUrlHistory');
      if (historyDiv.style.display === 'block') { historyDiv.style.display = 'none'; return; }
      var urls = JSON.parse(localStorage.getItem('xcrypto_scan_urls') || '[]');
      if (urls.length === 0) {
        historyDiv.innerHTML = '<span style="color:#64748b;font-size:0.8rem;">No saved URLs yet</span>';
      } else {
        historyDiv.innerHTML = urls.map(function(u) {
          return '<div style="display:flex;align-items:center;gap:0.4rem;padding:0.3rem 0;border-bottom:1px solid #334155;cursor:pointer;" onclick="document.getElementById(\'scanUrl\').value=\'' + u.replace(/'/g, "\\'") + '\';document.getElementById(\'scanUrlHistory\').style.display=\'none\';updateScanBtnState();">' +
            '<span style="flex:1;color:#e2e8f0;font-size:0.75rem;word-break:break-all;">' + u + '</span>' +
            '<button class="btn" style="padding:0.1rem 0.3rem;font-size:0.6rem;background:linear-gradient(180deg,#f87171 0%,#dc2626 100%);color:white;" onclick="event.stopPropagation();removeUrlFromHistory(\'' + u.replace(/'/g, "\\'") + '\')">×</button>' +
          '</div>';
        }).join('');
      }
      historyDiv.style.display = 'block';
    });
    window.removeUrlFromHistory = function(urlToRemove) {
      var urls = JSON.parse(localStorage.getItem('xcrypto_scan_urls') || '[]');
      urls = urls.filter(function(u) { return u !== urlToRemove; });
      localStorage.setItem('xcrypto_scan_urls', JSON.stringify(urls));
      document.getElementById('scanUrlHistoryBtn').click(); // refresh dropdown
    };

    // Scan Fetch
    document.getElementById('scanFetchBtn').addEventListener('click', async function() {
      var url = document.getElementById('scanUrl').value.trim();
      var results = document.getElementById('scanResults');
      if (!url) { results.innerHTML = '<span style="color:#ef4444;">Enter a DexScreener URL</span>'; return; }
      this.disabled = true;
      this.textContent = '⏳...';
      results.innerHTML = '';
      try {
        var res = await fetch('/api/scan', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url, age: localStorage.getItem('xcrypto_scan_age') || '24h', sort: localStorage.getItem('xcrypto_scan_sort') || 'desc' }) });
        var data = await res.json();
        if (!res.ok || !data.success) {
          results.innerHTML = '<span style="color:#ef4444;">❌ ' + (data.error || 'Fetch failed') + '</span>';
