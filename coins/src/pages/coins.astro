    document.getElementById('saveBtn').addEventListener('click', async function() {
      var coinid = document.getElementById('editCoinId').value;
      var body = {
        coinid: coinid ? Number(coinid) : undefined,
        coinname: document.getElementById('fCoinName').value,
        ca: document.getElementById('fCA').value,
        dexscreenerurl: document.getElementById('fDexUrl').value,
        narrative: document.getElementById('fNarrative').value,
        currentstatus: document.getElementById('fStatus').value,
        trend: document.getElementById('fTrend').value,
        expert_comment: document.getElementById('fComment').value,
        enabled: document.getElementById('fEnabled').value,
        icon_url: document.getElementById('fIconUrl').value,
        safety: document.getElementById('fSafety').value || undefined,
      };
      if (!body.coinname) { showToast('Coin Name is required', 'error'); return; }
      var method = coinid ? 'PUT' : 'POST';
      var res = await fetch('/api/coins', { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      if (res.ok) { showToast(coinid ? 'Coin updated' : 'Coin added', 'success'); modal.classList.remove('active'); loadCoins(); }
      else showToast('Save failed', 'error');
