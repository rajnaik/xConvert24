              '<span style="min-width:85px;width:85px;flex-shrink:0;">DEX</span>' +
              '<span style="min-width:80px;width:80px;flex-shrink:0;">Action</span>' +
            '</div>' +
            data.coins.map(function(c, i) {
              var changeColor = function(v) { var n = parseFloat(v); return n > 0 ? '#22c55e' : n < 0 ? '#ef4444' : '#64748b'; };
              return '<div style="display:flex;align-items:center;gap:1rem;padding:0.5rem 0;border-bottom:1px solid #334155;font-size:0.9rem;">' +
