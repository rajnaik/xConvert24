          document.getElementById('fCoinName').value = data.coinname || name;
          document.getElementById('fCA').value = data.ca || '';
          document.getElementById('fIconUrl').value = data.icon_url || '';
          document.getElementById('fDexUrl').value = data.dexscreenerurl || '';
          document.getElementById('fStatus').value = data.currentstatus || '';
          document.getElementById('fTrend').value = data.trend || '';
          var comment = data.extra ? 'Price: ' + data.extra.priceUsd + ' | FDV: ' + data.extra.fdv + ' | Liq: ' + data.extra.liquidity + ' | 24h: ' + data.extra.h24Change + ' | Chain: ' + data.extra.chain + ' | DEX: ' + data.extra.dex : '';
          if (data.safety) comment += ' | Safety: ' + data.safety;
          if (data.rugcheck) comment += ' | Holders: ' + (data.rugcheck.holders || '?') + ' | Top: ' + (data.rugcheck.topHolderPct || '?') + ' | Bundles: ' + data.rugcheck.bundles;
          document.getElementById('fComment').value = comment;
          document.getElementById('fSafety').value = data.safety || '';
          showToast('Auto-filled' + (data.safety ? ' — ' + data.safety : '') + ' (' + (data.extra ? data.extra.totalResults : 0) + ' results)', 'success');
          if (coinid) loadCoins();
        } else {
          var err = await res.json();
          showToast(err.error || 'Not found', 'error');
