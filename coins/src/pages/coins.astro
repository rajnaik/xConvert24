                '<span style="min-width:85px;width:85px;flex-shrink:0;color:#475569;font-size:0.8rem;">' + c.dex + '</span>' +
                '<span style="min-width:80px;width:80px;flex-shrink:0;display:flex;gap:2px;">' +
                  '<button class="btn btn-add" style="padding:0.15rem 0.4rem;font-size:0.8rem;" onclick="addScannedCoin(\'' + c.coinname.replace(/'/g, "\\'") + '\',\'' + c.ca + '\',\'' + c.dexscreenerurl + '\',\'' + (c.icon_url || '') + '\')" title="Add to tracked coins">+</button>' +
                '</span>' +
              '</div>';
            }).join('');
        }
      } catch(e) {
        results.innerHTML = '<span style="color:#ef4444;">❌ Error: ' + e.message + '</span>';
      }
      this.disabled = false;
      this.textContent = 'Fetch';
    });

    // Add a scanned coin to DB
    window.addScannedCoin = async function(coinname, ca, dexscreenerurl, icon_url) {
      var userId = localStorage.getItem('xcrypto_user_id') || '';
      var res = await fetch('/api/coins', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ coinname: coinname, ca: ca, dexscreenerurl: dexscreenerurl, icon_url: icon_url, user_id: userId, enabled: 'yes' })
      });
      if (res.ok) {
        showToast(coinname + ' added!', 'success');
        loadCoins();
      } else {
        showToast('Failed to add ' + coinname, 'error');
      }
    };

    // Show Bubble Map in modal
    window.showBubbleMap = function(ca, coinname) {
      document.getElementById('bubbleMapTitle').textContent = '🫧 ' + coinname + ' — Bubble Map';
      document.getElementById('bubbleMapFrame').src = 'https://app.bubblemaps.io/sol/token/' + ca;
      document.getElementById('bubbleMapModal').classList.add('active');
    };

    // Favourites management
    var favouriteIds = [];
    async function loadFavourites() {
      var userId = localStorage.getItem('xcrypto_user_id') || '';
      var res = await fetch('/api/favourites?user_id=' + encodeURIComponent(userId));
      if (res.ok) {
        var data = await res.json();
        favouriteIds = data.favourites.map(function(f) { return f.coinid; });
      }
    }
    window.toggleFavourite = async function(coinid) {
      var userId = localStorage.getItem('xcrypto_user_id') || '';
      var res = await fetch('/api/favourites', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ coinid: coinid, user_id: userId })
      });
      if (res.ok) {
        var data = await res.json();
        showToast(data.action === 'added' ? '💜 Added to favourites' : '🤍 Removed from favourites', 'success');
        await loadFavourites();
        renderTable();
      }
    };

    // Show RugCheck detail modal
    window.showRugcheck = function(coinid) {
      var coin = coinsData.find(function(c) { return c.coinid === coinid; });
      if (!coin || !coin.rugcheck_data) {
        showToast('No rugcheck data — click Update Latest first', 'error');
        return;
      }
      var data;
      try { data = JSON.parse(coin.rugcheck_data); } catch(e) { showToast('Invalid rugcheck data', 'error'); return; }
      var html = '';
      // Summary
      html += '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.8rem;margin-bottom:1rem;">';
      html += '<div style="background:#0f172a;padding:0.6rem;border-radius:6px;text-align:center;"><div style="color:#64748b;font-size:0.7rem;">Score</div><div style="color:#f59e0b;font-size:1.2rem;font-weight:700;">' + (data.score || 0) + '</div></div>';
      html += '<div style="background:#0f172a;padding:0.6rem;border-radius:6px;text-align:center;"><div style="color:#64748b;font-size:0.7rem;">Holders</div><div style="color:#e2e8f0;font-size:1.2rem;font-weight:700;">' + (data.totalHolders || '?') + '</div></div>';
      html += '<div style="background:#0f172a;padding:0.6rem;border-radius:6px;text-align:center;"><div style="color:#64748b;font-size:0.7rem;">LP Providers</div><div style="color:#e2e8f0;font-size:1.2rem;font-weight:700;">' + (data.totalLPProviders || '?') + '</div></div>';
      html += '</div>';
      // Rugged + Bundles + LP Lock
      html += '<div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">';
      html += '<span style="padding:0.3rem 0.8rem;border-radius:4px;font-size:0.8rem;background:' + (data.rugged ? '#7f1d1d' : '#065f46') + ';color:' + (data.rugged ? '#fca5a5' : '#6ee7b7') + ';">' + (data.rugged ? '🚨 RUGGED' : '✅ Not Rugged') + '</span>';
      html += '<span style="padding:0.3rem 0.8rem;border-radius:4px;font-size:0.8rem;background:#1e1b4b;color:#a5b4fc;">Bundles: ' + (data.insiderNetworks || 0) + '</span>';
      var lpLock = data.markets && data.markets[0] && data.markets[0].lp ? data.markets[0].lp.lpLockedPct : null;
      html += '<span style="padding:0.3rem 0.8rem;border-radius:4px;font-size:0.8rem;background:#1e293b;color:' + (lpLock > 80 ? '#22c55e' : lpLock > 0 ? '#f59e0b' : '#ef4444') + ';">LP Lock: ' + (lpLock != null ? lpLock.toFixed(1) + '%' : '?') + '</span>';
      html += '</div>';
      // Top Holders
      if (data.topHolders && data.topHolders.length > 0) {
        html += '<h4 style="color:#94a3b8;font-size:0.8rem;margin:0.8rem 0 0.4rem;">Top Holders</h4>';
        html += '<div style="font-size:0.75rem;">';
        data.topHolders.forEach(function(h, i) {
          var shortAddr = h.address ? h.address.slice(0,6) + '...' + h.address.slice(-4) : '?';
          html += '<div style="display:flex;justify-content:space-between;padding:0.2rem 0;border-bottom:1px solid #334155;"><span style="color:#94a3b8;">#' + (i+1) + ' ' + shortAddr + '</span><span style="color:#e2e8f0;font-weight:600;">' + h.pct + '%</span></div>';
        });
        html += '</div>';
      }
      // Risks
      if (data.risks && data.risks.length > 0) {
        html += '<h4 style="color:#94a3b8;font-size:0.8rem;margin:0.8rem 0 0.4rem;">Contract Risks (' + data.risks.length + ')</h4>';
        html += '<div style="font-size:0.75rem;">';
        data.risks.forEach(function(r) {
          var levelColor = r.level === 'critical' ? '#ef4444' : r.level === 'warn' ? '#f59e0b' : '#64748b';
          html += '<div style="padding:0.3rem 0;border-bottom:1px solid #334155;"><span style="color:' + levelColor + ';font-weight:600;">' + (r.level || '').toUpperCase() + '</span> <span style="color:#e2e8f0;">' + r.name + '</span>' + (r.description ? '<div style="color:#64748b;font-size:0.7rem;margin-top:0.1rem;">' + r.description + '</div>' : '') + '</div>';
        });
        html += '</div>';
      }
      document.getElementById('rugcheckTitle').textContent = '🛡️ ' + (coin.coinname || 'Coin') + ' — Safety Report';
      document.getElementById('rugcheckContent').innerHTML = html;
      document.getElementById('rugcheckModal').classList.add('active');
    };

    // Basket management (localStorage)
    function getBasket() {
      return JSON.parse(localStorage.getItem('xcrypto_basket') || '[]');
    }
    function isInBasket(ca) {
      return getBasket().some(function(item) { return item.ca === ca; });
    }
    window.toggleBasket = function(coinname, ca, dexscreenerurl, icon_url) {
      var basket = getBasket();
      var idx = basket.findIndex(function(item) { return item.ca === ca; });
      if (idx >= 0) {
        basket.splice(idx, 1);
        showToast(coinname + ' removed from basket', 'success');
      } else {
        basket.push({
          icon_url: icon_url,
          coinname: coinname,
          ca: ca,
          dexscreenerurl: dexscreenerurl,
          dateAdded: new Date().toISOString(),
          status: 'watching'
        });
        showToast(coinname + ' added to basket 🧺', 'success');
      }
      localStorage.setItem('xcrypto_basket', JSON.stringify(basket));
      // Re-trigger scan results render if visible
      var fetchBtn = document.getElementById('scanFetchBtn');
      if (document.getElementById('scanResults').innerHTML.length > 50) {
        fetchBtn.click();
      }
    };

    loadFavourites().then(function() { loadCoins(); });
    loadDisabledCoins();
    // Auto-trigger Update Latest on page load
    setTimeout(function() { document.getElementById('updateLatestBtn').click(); }, 500);
  </script>
</Layout>
