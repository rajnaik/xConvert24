    // Auto-fill from DexScreener search
    document.getElementById('autofillBtn').addEventListener('click', async function() {
      var name = document.getElementById('fCoinName').value.trim();
      if (!name) { showToast('Enter a coin name first', 'error'); return; }
      this.disabled = true;
      this.textContent = '...';
      try {
        var coinid = document.getElementById('editCoinId').value || '';
        var res = await fetch('/api/autofill', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ coinname: name, coinid: coinid ? Number(coinid) : undefined }) });
        if (res.ok) {
