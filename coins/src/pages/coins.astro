    // Sorting logic
    function parseNumeric(val) {
      if (!val || val === '—') return -Infinity;
      return parseFloat(String(val).replace(/[$,%,]/g, '')) || 0;
    }

    function sortCoins() {
      var sorted = coinsData.slice();
      sorted.sort(function(a, b) {
        var aVal = a[sortField] || '';
        var bVal = b[sortField] || '';
        if (['coinid', 'price_5m', 'price_1h', 'price_6h', 'price_24h', 'mktcap', 'price_usd', 'pair_created_at'].indexOf(sortField) >= 0) {
          var aNum = parseNumeric(aVal);
          var bNum = parseNumeric(bVal);
          return sortDir === 'asc' ? aNum - bNum : bNum - aNum;
        }
        aVal = String(aVal).toLowerCase();
        bVal = String(bVal).toLowerCase();
        if (aVal < bVal) return sortDir === 'asc' ? -1 : 1;
        if (aVal > bVal) return sortDir === 'asc' ? 1 : -1;
        return 0;
      });
      return sorted;
    }

    document.querySelectorAll('.sort-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var field = this.getAttribute('data-sort');
        if (sortField === field) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortField = field;
          sortDir = 'asc';
        }
        renderTable();
        document.querySelectorAll('.sort-link').forEach(function(l) { l.style.color = '#94a3b8'; l.textContent = l.textContent.replace(/ [▲▼]/, ''); });
        this.style.color = '#f59e0b';
        this.textContent = this.textContent.replace(/ [▲▼]/, '') + (sortDir === 'asc' ? ' ▲' : ' ▼');
      });
    });


    function getTrendColor(status, trend) {
      const s = (status || '').toLowerCase();
      const t = (trend || '').toLowerCase();

      // Tier 1: Critical (dark red) — severe downturn
      const critical = ['crashing', 'dumping hard'];
      if (critical.includes(s) || critical.includes(t)) return '#991b1b';

      // Tier 2: Very Negative (red) — significant decline
      const veryNegative = ['bleeding', 'dumping'];
      if (veryNegative.includes(s) || veryNegative.includes(t)) return '#dc2626';

      // Tier 3: Negative (orange/amber) — moderate decline
      const negative = ['falling', 'declining', 'distributing', 'profit taking'];
      if (negative.includes(s) || negative.includes(t)) return '#f59e0b';

      // Tier 4: Neutral (gray/slate) — sideways movement
      const neutral = ['stable', 'sideways', 'consolidating'];
      if (neutral.includes(s) || neutral.includes(t)) return '#64748b';

      // Tier 5: Positive (green) — moderate gain
      const positive = ['rising', 'gaining', 'creeping up', 'accumulating'];
      if (positive.includes(s) || positive.includes(t)) return '#22c55e';

      // Tier 6: Very Positive (bright green/emerald) — strong gain
      const veryPositive = ['mooning', 'pumping hard', 'surging', 'pumping'];
      if (veryPositive.includes(s) || veryPositive.includes(t)) return '#10b981';

      // Default: neutral gray for unknown values
      return '#64748b';
    }    // Drumroll audio
    var drumAudio = new Audio("/media/drumroll.mp3");
    var drumLoopInterval = null;
    function startDrumroll() {
      drumAudio.currentTime = 0;
      drumAudio.play();
      drumLoopInterval = setInterval(function() { if (drumAudio.currentTime >= 4) drumAudio.currentTime = 0; }, 50);
    }
    function finishDrumroll() {
      if (drumLoopInterval) { clearInterval(drumLoopInterval); drumLoopInterval = null; }
      drumAudio.currentTime = 4;
      drumAudio.play();
    }
    function stopDrumroll() {
      if (drumLoopInterval) { clearInterval(drumLoopInterval); drumLoopInterval = null; }
      drumAudio.pause();
      drumAudio.currentTime = 0;
    }
    function showToast(msg, type) {
      toast.textContent = msg;
      toast.className = 'toast toast-' + type;
      toast.style.display = 'block';
      setTimeout(function() { toast.style.display = 'none'; }, 3000);
    }

    function renderTable() {
      var sorted = sortCoins();
      // Apply market cap filter
      if (mcapFilter !== 'all') {
        sorted = sorted.filter(function(c) {
          var cap = parseNumeric(c.mktcap);
          if (cap === -Infinity) return false;
          if (mcapFilter === 'micro') return cap < 50000;
          if (mcapFilter === 'mid') return cap >= 50000 && cap < 250000;
          if (mcapFilter === 'high') return cap >= 250000 && cap <= 1000000;
          if (mcapFilter === 'mega') return cap > 1000000;
          return true;
        });
      }
      // Apply age filter
      if (ageFilterValue !== 'all') {
        var maxAge = ageFilterMs[ageFilterValue] || 0;
        if (maxAge > 0) {
          var now = Date.now();
          sorted = sorted.filter(function(c) {
            if (!c.pair_created_at || c.pair_created_at === 0) return false;
            return (now - c.pair_created_at) <= maxAge;
          });
        }
      }
      // Apply favourites filter
      if (favFilter === 'yes') {
        sorted = sorted.filter(function(c) { return favouriteIds.indexOf(c.coinid) >= 0; });
      }
      // Apply new filter (added to your list < 24h)
      if (newFilter === '24h') {
        var oneDayAgo = new Date(Date.now() - 24 * 3600000).toISOString().replace('T', ' ').slice(0, 19);
        sorted = sorted.filter(function(c) {
          return c.datecreated && c.datecreated >= oneDayAgo;
        });
      }
      // Empty state
      if (sorted.length === 0 && coinsData.length === 0) {
        table.innerHTML = '<tr><td colspan="13" style="text-align:center;padding:2rem;color:#94a3b8;">No coin data yet. Click <strong style="color:#3b82f6;">🔄 Update Latest</strong> to fetch live data from DexScreener.</td></tr>';
        return;
      }
      if (sorted.length === 0) {
        table.innerHTML = '<tr><td colspan="13" style="text-align:center;padding:1rem;color:#64748b;">No coins match the current filters.</td></tr>';
        return;
      }
      table.innerHTML = sorted.map(function(c) {
        function priceColor(val) {
          if (!val) return '#64748b';
          var n = parseFloat(val);
          if (n > 0) return '#22c55e';
          if (n < 0) return '#ef4444';
          return '#64748b';
        }
        return '<tr>' +
          '<td>' + c.coinid + '</td>' +
          '<td>' + (c.dexscreenerurl ? '<a href="' + c.dexscreenerurl + '" target="_blank" style="text-decoration:none;color:#a855f7;display:flex;align-items:center;gap:6px;">' : '') + (c.icon_url ? '<img src="' + c.icon_url + '" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;" />' : '') + '<strong>' + (c.coinname || '\u2014') + '</strong>' + (c.dexscreenerurl ? '</a>' : '') + '</td>' +
          '<td>' + (function() { if (!c.socials) return '—'; try { var s = JSON.parse(c.socials); var twUrl = s.twitter ? (s.twitter.startsWith('http') ? s.twitter : 'https://x.com/' + s.twitter) : ''; var tgUrl = s.telegram ? (s.telegram.startsWith('http') ? s.telegram : 'https://t.me/' + s.telegram) : ''; var webUrl = s.websites && s.websites[0] ? s.websites[0] : ''; var xIcon = '<svg style="width:16px;height:16px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#8b5cf6"/><path d="M16.5 8.5l-2.8 3.2 3 3.8h-2.2l-1.9-2.5-2.3 2.5H8.5l3-3.3-2.8-3.7h2.2l1.7 2.3 2.1-2.3h1.8z" fill="white"/></svg>'; var tgIcon = '<svg style="width:16px;height:16px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#8b5cf6"/><path d="M17.2 8.2l-1.6 7.5c-.1.5-.4.6-.8.4l-2.3-1.7-1.1 1.1c-.1.1-.2.2-.4.2l.2-2.4 4.4-4c.2-.2 0-.3-.3-.1l-5.4 3.4-2.3-.7c-.5-.2-.5-.5.1-.7l9-3.5c.4-.1.8.1.6.7z" fill="white"/></svg>'; return '<span style="display:flex;gap:4px;align-items:center;">' + (twUrl ? '<a href="' + twUrl + '" target="_blank" style="text-decoration:none;display:flex;" title="X">' + xIcon + '</a>' : '<span style="opacity:0.2;">' + xIcon + '</span>') + (webUrl ? '<a href="' + webUrl + '" target="_blank" style="text-decoration:none;font-size:0.9rem;" title="Website">🌐</a>' : '<span style="opacity:0.2;font-size:0.9rem;">🌐</span>') + (tgUrl ? '<a href="' + tgUrl + '" target="_blank" style="text-decoration:none;display:flex;" title="Telegram">' + tgIcon + '</a>' : '<span style="opacity:0.2;">' + tgIcon + '</span>') + '</span>'; } catch(e) { return '—'; } })() + '</td>' +
          '<td style="text-align:center;"><span style="cursor:pointer;font-size:1.1rem;" onclick="toggleFavourite(' + c.coinid + ')">' + (favouriteIds.indexOf(c.coinid) >= 0 ? '💜' : '🤍') + '</span></td>' +
          '<td>' + (function() { var ts = c.pair_created_at; if (!ts || ts === 0) return '<span style="color:#64748b;font-size:0.7rem;cursor:pointer;" onclick="document.getElementById(\'updateLatestBtn\').click()" title="Click to fetch">⟳ fetch</span>'; var diff = Date.now() - ts; var min = Math.floor(diff/60000); var hr = Math.floor(diff/3600000); var day = Math.floor(diff/86400000); var age = min < 60 ? min + 'm' : hr < 24 ? hr + 'h' : day + 'd'; var color = day < 1 ? '#22c55e' : day < 7 ? '#f59e0b' : day < 30 ? '#f97316' : '#ef4444'; return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:3px;font-size:0.75rem;background:' + color + '20;color:' + color + ';border-left:3px solid ' + color + ';">' + age + '</span>'; })() + '</td>' +
          '<td style="text-align:center;">' + (c.ca ? '<span style="cursor:pointer;font-size:1rem;" onclick="showBubbleMap(\'' + c.ca + '\',\'' + (c.coinname || '').replace(/'/g, "\\'") + '\')" title="Bubble Map">🫧</span>' : '') + '</td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + ';font-size:0.85rem;font-weight:600;">' + (c.price_usd ? '$' + c.price_usd : '—') + '</td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + ';font-size:0.85rem;">' + (c.mktcap || '—') + '</td>' +
          '<td style="color:' + priceColor(c.price_5m) + ';font-size:0.85rem;">' + (c.price_5m || '—') + '</td>' +
          '<td style="color:' + priceColor(c.price_1h) + ';font-size:0.85rem;">' + (c.price_1h || '—') + '</td>' +
          '<td style="color:' + priceColor(c.price_6h) + ';font-size:0.85rem;">' + (c.price_6h || '—') + '</td>' +
          '<td style="color:' + priceColor(c.price_24h) + ';font-size:0.85rem;">' + (c.price_24h || '—') + '</td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + '"><strong>' + (c.currentstatus || '—') + '</strong></td>' +
          '<td style="color:' + getTrendColor(c.currentstatus, c.trend) + '">' + (c.trend || '—') + '</td>' +
          '<td style="cursor:pointer;" onclick="showRugcheck(' + c.coinid + ')" title="Click for details">' + (c.safety || '\u2014') + '</td>' +
          '<td><span class="badge badge-' + (c.enabled === 'yes' ? 'yes' : 'no') + '" style="cursor:pointer;" onclick="toggleEnabled(' + c.coinid + ',\'' + c.enabled + '\')">' + (c.enabled === 'yes' ? '✅' : '❌') + '</span></td>' +
          '<td>' +
            '<button class="btn btn-edit" onclick="editCoin(' + c.coinid + ')">Edit</button>' +
          '</td>' +
        '</tr>';
      }).join('');
    }

    async function loadCoins() {
      var res = await fetch('/api/coins');
      var data = await res.json();
      coinsData = data.coins;
      renderTable();
    }

    function openModal(coin) {
      document.getElementById('modalTitle').textContent = coin ? 'Edit Coin' : 'Add Coin';
      document.getElementById('editCoinId').value = coin ? coin.coinid : '';
      document.getElementById('fCoinName').value = coin ? (coin.coinname || '') : '';
      document.getElementById('fCA').value = coin ? (coin.ca || '') : '';
      document.getElementById('fDexUrl').value = coin ? (coin.dexscreenerurl || '') : '';
      document.getElementById('fNarrative').value = coin ? (coin.narrative || '') : '';
      document.getElementById('fStatus').value = coin ? (coin.currentstatus || '') : '';
      document.getElementById('fTrend').value = coin ? (coin.trend || '') : '';
      document.getElementById('fComment').value = coin ? (coin.expert_comment || '') : '';
      document.getElementById('fEnabled').value = coin ? (coin.enabled || 'yes') : 'yes';
      document.getElementById('fIconUrl').value = coin ? (coin.icon_url || '') : '';
      document.getElementById('fSafety').value = coin ? (coin.safety || '') : '';
      modal.classList.add('active');
    }

    window.editCoin = function(id) {
      var coin = coinsData.find(function(c) { return c.coinid === id; });
      if (coin) openModal(coin);
    };

    window.deleteCoin = async function(id) {
      if (!confirm('Delete this coin?')) return;
      var res = await fetch('/api/coins?coinid=' + id, { method: 'DELETE' });
      if (res.ok) { showToast('Coin deleted', 'success'); loadCoins(); }
      else showToast('Delete failed', 'error');
    };

    window.trackCoin = function(id) {
      window.location.href = '/admin/tracker?coinid=' + id;
    };

    document.getElementById('addBtn').addEventListener('click', function() { openModal(null); });
    document.getElementById('cancelBtn').addEventListener('click', function() { modal.classList.remove('active'); });
