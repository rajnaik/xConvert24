              '<span style="min-width:95px;width:95px;flex-shrink:0;">Mkt Cap</span>' +
              '<span style="min-width:90px;width:90px;flex-shrink:0;">Liquidity</span>' +
              '<span style="min-width:90px;width:90px;flex-shrink:0;">Volume</span>' +
              '<span style="min-width:60px;width:60px;flex-shrink:0;">5m</span>' +
              '<span style="min-width:60px;width:60px;flex-shrink:0;">1h</span>' +
              '<span style="min-width:60px;width:60px;flex-shrink:0;">24h</span>' +
              '<span style="min-width:80px;width:80px;flex-shrink:0;">B/S</span>' +
