    var ageFilterValue = localStorage.getItem('xcrypto_filter_age') || 'all';
    var favFilter = localStorage.getItem('xcrypto_filter_fav') || 'all';

    // Age filter milliseconds
    var ageFilterMs = { '30m': 30*60000, '1h': 3600000, '3h': 3*3600000, '6h': 6*3600000, '12h': 12*3600000, '24h': 24*3600000, '3d': 3*86400000, '1w': 7*86400000, '2w': 14*86400000, '3w': 21*86400000, '1m': 30*86400000, '2m': 60*86400000, '3m': 90*86400000, '6m': 180*86400000, '1y': 365*86400000 };

    // Market Cap filter buttons
