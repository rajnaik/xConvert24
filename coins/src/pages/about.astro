---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About">
  <h1>About xCrypto24</h1>
  <div style="max-width:700px;color:#94a3b8;line-height:1.8;">
    <p style="margin-bottom:1rem;">xCrypto24 is a free memecoin tracking and analysis tool built for crypto enthusiasts who want real-time data without the noise. We aggregate data from multiple sources including DexScreener, GeckoTerminal, and RugCheck to give you a complete picture of any Solana token.</p>
    <p style="margin-bottom:1rem;">Built by <strong style="color:#f59e0b;">xSoft</strong> — the same team behind <a href="https://xconvert24.com" style="color:#3b82f6;">xConvert24.com</a> and <a href="https://scrabblewordsfinder.com" style="color:#3b82f6;">ScrabbleWordsFinder.com</a>.</p>
    <h2 style="margin:2rem 0 1rem;">Our Promise</h2>
    <ul style="padding-left:1.5rem;line-height:2;">
      <li>Always free — no premium tiers, no paywalls</li>
      <li>No signup required — just use it</li>
      <li>Privacy-focused — we don't sell your data</li>
      <li>Open data sources — we show where the data comes from</li>
    </ul>
    <h2 style="margin:2rem 0 1rem;">Contact</h2>
    <p>Got questions? <a href="/contact" style="color:#3b82f6;">Send us a message</a> or <a href="/suggest" style="color:#3b82f6;">suggest a feature</a>.</p>
  </div>
</Layout>
