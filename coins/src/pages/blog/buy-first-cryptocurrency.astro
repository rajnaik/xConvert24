      </div>

      <BlogCrossLinks current="buy-first-cryptocurrency" />
    </article>
    <div style="text-align:center;margin-top:2rem;">
      <a href="/blog" style="color:#71717a;font-size:0.85rem;text-decoration:none;">← Back to all articles</a>
