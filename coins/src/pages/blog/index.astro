---
<Layout title="Blog — Crypto Education & Analysis | xCrypto24" description="Crypto education, Bitcoin analysis, and trading insights. Learn about halving, supply mechanics, and how to evaluate digital assets." keywords="crypto blog, bitcoin education, cryptocurrency guide, bitcoin halving, bitcoin supply, crypto basics">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"CollectionPage","name":"xCrypto24 Blog","url":"https://xcrypto24.com/blog","description":"Crypto education, Bitcoin analysis, and trading insights."})} />
  <div style="max-width:800px;margin:2rem auto;padding:0 1rem;">
    <h1 style="font-size:2rem;font-weight:700;color:#fafafa;margin-bottom:0.5rem;">📝 Blog</h1>
    <p style="color:#a1a1aa;margin-bottom:0.5rem;">Crypto education, analysis, and insights — <strong style="color:#c084fc;">{posts.length} articles</strong></p>
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem;">
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.3);color:#c084fc;font-size:0.75rem;">Beginner</span>
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.3);color:#fbbf24;font-size:0.75rem;">Bitcoin</span>
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;font-size:0.75rem;">Altcoins</span>
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(56,189,248,0.15);border:1px solid rgba(56,189,248,0.3);color:#38bdf8;font-size:0.75rem;">DeFi</span>
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(248,113,113,0.15);border:1px solid rgba(248,113,113,0.3);color:#f87171;font-size:0.75rem;">Trading</span>
      <span style="padding:0.2rem 0.6rem;border-radius:4px;background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.3);color:#a855f7;font-size:0.75rem;">History</span>
    </div>

    <div style="display:flex;flex-direction:column;gap:1rem;">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} style="display:block;padding:1.2rem;border-radius:12px;border:1px solid #3f3f5a;background:linear-gradient(180deg,#1e1e2e,#16161f);text-decoration:none;transition:border-color 0.2s;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.4rem;">
            <span style="font-size:0.65rem;padding:0.1rem 0.4rem;border-radius:3px;background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.2);color:#a1a1aa;">{post.cat}</span>
          </div>
          <h2 style="font-size:1.1rem;font-weight:600;color:#fafafa;margin-bottom:0.4rem;">{post.title}</h2>
          <p style="font-size:0.85rem;color:#a1a1aa;line-height:1.5;margin-bottom:0.5rem;">{post.desc}</p>
          <div style="display:flex;gap:0.8rem;font-size:0.75rem;color:#71717a;">
            <time datetime={post.date}>{post.date}</time>
            <span>·</span>
            <span>{post.read} read</span>
          </div>
        </a>
      ))}
    </div>

    <div style="margin-top:2.5rem;padding:1.2rem;background:linear-gradient(135deg,rgba(139,92,246,0.1),rgba(109,40,217,0.05));border:1px solid rgba(139,92,246,0.3);border-radius:12px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <p style="color:#c084fc;font-size:0.9rem;font-weight:500;">🪙 Track crypto in real-time with our free tool</p>
      <a href="/coins" style="padding:0.5rem 1.2rem;background:linear-gradient(180deg,#a78bfa,#7c3aed);color:white;border-radius:6px;text-decoration:none;font-size:0.85rem;font-weight:600;">Open Tracker →</a>
    </div>
  </div>
</Layout>
