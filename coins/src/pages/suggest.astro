---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Suggest a Feature">
  <h1>💡 Suggest a Feature</h1>
  <div style="max-width:500px;">
    <p style="color:#94a3b8;margin-bottom:1.5rem;">What would make xCrypto24 better for you?</p>
    <form id="suggestForm">
      <div class="form-group"><label>Name (optional)</label><input type="text" id="sName" placeholder="Your name" /></div>
      <div class="form-group"><label>Email (optional)</label><input type="email" id="sEmail" placeholder="your@email.com" /></div>
      <div class="form-group"><label>Your suggestion *</label><textarea id="sMessage" placeholder="Describe the feature you'd like..." required></textarea></div>
      <button type="submit" class="btn btn-add" style="width:100%;padding:0.8rem;">Submit Suggestion</button>
    </form>
    <div id="sResult" style="margin-top:1rem;display:none;"></div>
  </div>
  <script is:inline>
    document.getElementById('suggestForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var res = await fetch('/api/contact', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ name: document.getElementById('sName').value, email: document.getElementById('sEmail').value, subject: 'suggestion', message: document.getElementById('sMessage').value })
      });
      var r = document.getElementById('sResult');
      if (res.ok) { r.style.display = 'block'; r.style.color = '#10b981'; r.textContent = 'Thanks for the suggestion!'; this.reset(); }
      else { r.style.display = 'block'; r.style.color = '#ef4444'; r.textContent = 'Failed. Please try again.'; }
    });
  </script>
</Layout>
