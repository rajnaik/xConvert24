---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Suggest a Feature — xCrypto24" description="Suggest a new feature for xCrypto24. We build what our users need." keywords="suggest feature, xcrypto24 feedback">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Suggest a Feature","url":"https://xcrypto24.com/suggest","description":"Suggest a new feature for xCrypto24. We build what our users need."})} />
  <div style="max-width:600px;margin:2rem auto;padding:0 1rem;">
    <h1 style="font-size:2rem;font-weight:700;color:#fafafa;margin-bottom:0.5rem;">💡 Suggest a Feature</h1>
    <p style="color:#a1a1aa;margin-bottom:1.5rem;">What would make xCrypto24 better for you? We read every suggestion.</p>

    <div style="margin-bottom:2rem;padding:1rem;border-radius:12px;border:1px solid rgba(139,92,246,0.3);background:rgba(88,28,135,0.1);">
      <p style="font-size:0.85rem;color:#d4d4d8;line-height:1.6;"><span style="color:#c084fc;font-weight:600;">Popular requests we've built:</span> Scan New Coins, Bubble Maps integration, Safety Reports, Age filtering, Favourites — all from user suggestions!</p>
    </div>

    <form id="suggestForm" style="display:flex;flex-direction:column;gap:1rem;">
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Name (optional)</label>
        <input type="text" id="sName" placeholder="Your name" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;" />
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Email (optional — for follow-up)</label>
        <input type="email" id="sEmail" placeholder="you@example.com" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;" />
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Category</label>
        <select id="sCat" style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;">
          <option value="feature">New Feature</option>
          <option value="improvement">Improve Existing</option>
          <option value="data">More Data / API</option>
          <option value="ui">UI / Design</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label style="display:block;color:#a1a1aa;font-size:0.85rem;margin-bottom:0.3rem;">Your Suggestion *</label>
        <textarea id="sMessage" rows="5" placeholder="Describe what you'd like to see..." required style="width:100%;padding:0.6rem;background:#0a0a0f;border:1px solid #3f3f5a;border-radius:6px;color:#d4d4d8;font-size:0.9rem;resize:vertical;"></textarea>
      </div>
      <button type="submit" class="btn btn-add" style="align-self:flex-start;">🚀 Submit Suggestion</button>
      <div id="sResult" style="font-size:0.85rem;display:none;"></div>
    </form>

    <div style="margin-top:2rem;text-align:center;">
      <a href="/coins" style="color:#71717a;font-size:0.85rem;text-decoration:none;">← Back to Coins</a>
    </div>
  </div>

  <script is:inline>
    // Pre-fill from URL param
    var params = new URLSearchParams(window.location.search);
    if (params.get('title')) {
      document.getElementById('sMessage').value = 'Feature for: ' + params.get('title') + '\n\n';
    }

    document.getElementById('suggestForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var r = document.getElementById('sResult');
      var msg = document.getElementById('sMessage').value.trim();
      if (!msg) { r.style.display = 'block'; r.style.color = '#f87171'; r.textContent = 'Please describe your suggestion'; return; }
      r.style.display = 'block'; r.style.color = '#a1a1aa'; r.textContent = 'Sending...';
      try {
        var res = await fetch('/api/contact', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ name: document.getElementById('sName').value, email: document.getElementById('sEmail').value, subject: 'suggestion:' + document.getElementById('sCat').value, message: msg })
        });
        if (res.ok) { r.style.color = '#4ade80'; r.textContent = '✓ Thanks! Your suggestion has been received.'; this.reset(); }
        else { r.style.color = '#f87171'; r.textContent = 'Failed to send. Please try again.'; }
      } catch(err) { r.style.color = '#f87171'; r.textContent = 'Error: ' + err.message; }
    });
  </script>
</Layout>
